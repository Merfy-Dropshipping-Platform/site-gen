---
import type { Product } from "../../types/product";
import VanillaPicture from "../img/VanillaPicture.astro";

interface Props {
	product: Product;
	priority?: boolean;
}

const { product, priority = false } = Astro.props;
const href = `/products/${product.id}`;

const swatchColors: Record<string, string> = {
	olive: "var(--vanilla-announcement-bg)",
	white: "var(--vanilla-surface)",
	gray: "var(--vanilla-surface)",
};

const colors = product.colors ?? [];
---

<article
	class="group flex flex-col gap-3"
	data-nt="vanilla-product-card"
	aria-label={product.name}
>
	<a
		href={href}
		class="relative block aspect-square w-full overflow-hidden bg-[var(--vanilla-card)]"
		aria-label={product.name}
	>
		<VanillaPicture
			src={product.image}
			alt={product.name}
			width="429"
			height="429"
			loading="eager"
			fetchpriority={priority ? "high" : undefined}
			class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
		/>
		{product.discount && (
			<span
				class="absolute left-2 top-2 inline-flex h-6 min-w-12 items-center justify-center bg-[var(--vanilla-announcement-bg)] px-1.5 font-vanilla-arsenal text-[9px] font-normal leading-none text-white"
			>
				Скидка
			</span>
		)}
		{colors.length > 0 && (
			<div
				class="absolute bottom-2 right-2 inline-flex items-center gap-0.5 bg-white p-0.5"
				aria-hidden="true"
				data-nt="variant-selector"
			>
				{colors.map((color) => (
					<span
						class="size-2 shrink-0 rounded-[1px]"
						style={`background-color: ${swatchColors[color] ?? swatchColors.olive}`}
					/>
				))}
			</div>
		)}
	</a>
	<div class="flex flex-col gap-1">
		<a
			href={href}
			class="font-vanilla-arsenal text-base font-normal uppercase leading-none text-black transition-opacity hover:opacity-70"
		>
			{product.name}
		</a>
		<div class="flex flex-wrap items-baseline gap-2">
			<span class="font-vanilla-arsenal text-base font-normal leading-none text-black">
				{product.price}
			</span>
			{product.oldPrice && (
				<span class="font-vanilla-arsenal text-[14px] font-normal leading-none text-[#444444] line-through">
					{product.oldPrice}
				</span>
			)}
		</div>
	</div>
</article>
