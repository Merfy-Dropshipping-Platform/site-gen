---
/**
 * Обёртка для WebP-растра из /public/images/.
 * Источники конвертируются через `pnpm run images:optimize` (prebuild).
 */
interface Props {
	src: string;
	alt: string;
	width?: number | string;
	height?: number | string;
	class?: string;
	loading?: "eager" | "lazy";
	fetchpriority?: "high" | "low" | "auto";
	decoding?: "sync" | "async" | "auto";
	sizes?: string;
	[key: `data-${string}`]: string | number | boolean | undefined;
}

const {
	src,
	alt,
	width,
	height,
	class: className,
	loading = "eager",
	fetchpriority,
	decoding = "async",
	sizes,
	...rest
} = Astro.props as Props;
---

<img
	src={src}
	alt={alt}
	width={width}
	height={height}
	class={className}
	loading={loading}
	fetchpriority={fetchpriority}
	decoding={decoding}
	sizes={sizes}
	{...rest}
/>
