---
// Единый storefront-рантайм витрины (cart-drawer + инициализация корзины/
// избранного/аккаунта + делегаты checkout/cart-open). Вшивается ВСЕМИ макетами
// (Layout.astro и BlogPost.astro), чтобы счётчики корзины/избранного, дровер и
// переходы работали на ЛЮБОЙ странице, независимо от выбранного макета. Раньше
// этот блок жил только в Layout.astro → страницы на BlogPost (например /about
// до миграции, посты блога) оставались без скриптов витрины.
import NtCartDrawer from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtCartDrawer.astro";
---

<NtCartDrawer rootId="cart-drawer-root" eventPrefix="rose:cart" />
<script>
	import { initCartUI } from "../lib/cart";
	import { initWishlistUI } from "../lib/wishlist";
	import { initAuthUI } from "../lib/auth";
	initCartUI();
	// Избранное (wishlist) — глобальный делегат сердец/бейджей, зеркало корзины.
	initWishlistUI();
	// Аккаунт покупателя — красит [data-auth-link] (/account vs /login),
	// auth/guest-only элементы; фоновая подгрузка профиля при наличии токена.
	initAuthUI();

	// Регулярное оформление («Оформить» корзины/drawer, data-action=checkout)
	// сбрасывает express «Купить сейчас» (sessionStorage rose:buynow) — чтобы
	// чекаут показал корзину покупателя, а не залипший buy-now товар.
	document.addEventListener(
		"click",
		(e) => {
			const el = e.target as Element | null;
			if (el && el.closest("[data-action='checkout']")) {
				try { sessionStorage.removeItem("rose:buynow"); } catch (err) {}
			}
		},
		true,
	);

	// Корзина «Сайдбар»/«Страница» (--cart-type): перехват клика по иконке
	// (<button data-cart-open>) в capture-фазе, опережая bubble-обработчик
	// панели (DS NtCartDrawer). page → /cart; drawer (дефолт) → панель сама.
	document.addEventListener(
		"click",
		(e) => {
			const el = e.target as Element | null;
			if (!el || !el.closest("[data-cart-open]")) return;
			const cartType = getComputedStyle(document.documentElement)
				.getPropertyValue("--cart-type")
				.trim()
				.replace(/['"]/g, "");
			if (cartType !== "page") return;
			e.preventDefault();
			e.stopImmediatePropagation();
			if (window.self === window.top) {
				window.location.assign("/cart");
			} else {
				const a = document.createElement("a");
				a.href = "/cart";
				document.body.appendChild(a);
				a.click();
				a.remove();
			}
		},
		true,
	);
</script>
