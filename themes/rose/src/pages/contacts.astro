---
import Layout from "../layouts/Layout.astro";
import Contacts from "../components/sections/Contacts.astro";
---

<Layout title="Контакты" description="Свяжитесь с Rose — контакты магазина и форма обратной связи">
	<Contacts />
</Layout>

<script>
	document.querySelector<HTMLFormElement>("[data-contacts-form]")?.addEventListener("submit", (event) => {
		event.preventDefault();
		const form = event.currentTarget as HTMLFormElement;
		const status = document.querySelector<HTMLElement>("[data-contacts-status]");
		if (status) {
			status.textContent = "Спасибо! Мы свяжемся с вами в ближайшее время.";
			status.classList.remove("hidden");
		}
		form.reset();
	});
</script>
