---
import BloomPicture from "../img/BloomPicture.astro";
import { DEFAULT_CATEGORY_HREF } from "../../data/categories";

// ОЖИВЛЕНИЕ (Фаза B, контракт rose Hero): читаем канон-схему theme-base
// Hero.puckConfig и раскладываем по разметке верстальщика. Тело ниже — verbatim,
// значения bloom = дефолты (страницы зовут <Hero /> без пропсов). blockDefaults
// variant='split-bloom' — дефолт-ветка полотна (отдельной ветки не требует).
// Поддержаны nested (Pupa) и legacy flat-пропсы.
const p = Astro.props as Record<string, any>;
const id = p.id;
const title = p.heading?.text ?? p.title ?? "Искусство заботы о себе";
const subtitle =
	p.text?.content ??
	p.subtitle ??
	"Уходовая косметика, которая дарит здоровье и сияние вашей коже и волосам";
const ctaText = p.primaryButton?.text ?? p.cta?.text ?? p.ctaText ?? "Начать ритуал";
const ctaLink =
	p.primaryButton?.link?.href ??
	p.primaryButton?.link ??
	p.cta?.href ??
	p.ctaLink ??
	DEFAULT_CATEGORY_HREF;
// Без мок-фолбэка «/images/hero-background.webp» — иначе пустое состояние неотличимо
// от заданного (картинка всегда есть). Пусто → backgroundImage === "" → плейсхолдер.
const backgroundImage =
	p.backgroundImages?.url1 ?? p.backgroundImage ?? p.image?.url ?? "";

// Figma 1:19335 — ДОСЛОВНЫЙ плейсхолдер пустого состояния секции «Изображение»
// (Hero). «Пусто» = мерчант НЕ задал НИ фон-картинку, НИ заголовок, НИ текст, НИ
// кнопку (все значения берутся из bloom-дефолтов верстальщика). Тогда секция
// рендерит пустую surface-плашку + overlay-лейбл «Изображение» + хелпер «Покажи и
// расскажи о своем товаре в одном блоке» + кнопку «Кнопка» (ветка рендера ниже), а
// НЕ дефолт-контент верстальщика («Искусство заботы о себе» / «Начать ритуал» /
// мок-фон). Проверяем СЫРЫЕ пропсы (heading.text/title, text.content/subtitle,
// primaryButton.text/cta), а не resolved-значения с фолбэками — иначе пустое
// состояние не отличить от заданного. Когда хоть что-то задано — рендер мерчанта
// дословно (не трогаем). Паритет rose Hero.astro.
const rawHeadingText =
	typeof p.heading?.text === "string"
		? p.heading.text
		: typeof p.title === "string"
			? p.title
			: "";
const rawSubtitleText =
	typeof p.text?.content === "string"
		? p.text.content
		: typeof p.subtitle === "string"
			? p.subtitle
			: "";
const rawPrimaryText =
	typeof p.primaryButton?.text === "string"
		? p.primaryButton.text
		: typeof p.cta?.text === "string"
			? p.cta.text
			: typeof p.ctaText === "string"
				? p.ctaText
				: "";
const isEmpty =
	!String(backgroundImage).trim() &&
	!String(p.backgroundImages?.url2 ?? p.backgroundImage2 ?? "").trim() &&
	!rawHeadingText.trim() &&
	!rawSubtitleText.trim() &&
	!rawPrimaryText.trim();
// Дословные тексты Figma-плейсхолдера (тип «Изображение»).
const PH_LABEL = "Изображение";
const PH_HELPER = "Покажи и расскажи о своем товаре в одном блоке";
const PH_BUTTON = "Кнопка";
// Figma 1:19335 — фон пустого состояния Hero = дизайн-ассет landscape-image.png
// (раздаётся на каждой теме из packages/theme-base/public/placeholders, copyPublic),
// а НЕ пустая surface (контракт картиночных секций, эталон rose Hero.astro). Overlay-
// лейбл/хелпер/кнопка ложатся ПОВЕРХ него; тёмная подложка-градиент даёт читаемость
// белого текста, как у настоящего фото.
const PH_BACKGROUND_IMAGE = "/placeholders/landscape-image.png";
// Канон backgroundImages (imagePair url2) / legacy backgroundImage2: сплит двух
// картинок 50/50 ТОЛЬКО когда второе фото задано; иначе одиночный рендер дословно.
const backgroundImage2 = p.backgroundImages?.url2 ?? p.backgroundImage2;

// ДВА НЕЗАВИСИМЫХ размера у Hero:
//   • p.size — ВЫСОТА секции (heroHeightCls ниже). НЕ шрифт.
//   • heading.size / text.size — размер ШРИФТА заголовка/текста (поля «Размер
//     заголовка»/«Размер текста»). Возвращены по решению владельца (откат unify
//     ee611471). font-size берётся ТОЛЬКО из heading.size/text.size, БЕЗ фолбэка
//     на p.size (иначе регулятор высоты снова менял бы кегль). Отсутствие → дефолт-
//     ветка large байт-в-байт прежнему рендеру (цвета → токены с пиксель-фоллбеком
//     родных #E38E9F по §7).
//   заголовок large 18/20 → medium 15/17 → small 13/14
//   текст     large 14/16 → medium 12/14 → small 10/11
const headingSize = p.heading?.size;
const headingCls =
	headingSize === "small"
		? "hero-animate-1 font-urbanist text-[13px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[14px]"
		: headingSize === "medium"
			? "hero-animate-1 font-urbanist text-[15px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[17px]"
			: "hero-animate-1 font-urbanist text-[18px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[20px]";
const textSize = p.text?.size;
const subtitleCls =
	textSize === "small"
		? "hero-animate-2 font-inter text-[10px] font-light leading-[1.2] text-[rgb(var(--color-text,227_142_159))] md:text-[11px]"
		: textSize === "medium"
			? "hero-animate-2 font-inter text-[12px] font-light leading-[1.2] text-[rgb(var(--color-text,227_142_159))] md:text-[14px]"
			: "hero-animate-2 font-inter text-[14px] font-light leading-[1.2] text-[rgb(var(--color-text,227_142_159))] md:text-[16px]";
// «Размер» → высота секции (вьюпорт). Раньше высоту Hero диктовал aspect-[...] на
// height-div'е, перебивая min-h от size → регулятор «Размер» не влиял (паритет бага
// rose). Фикс: aspect убран с обоих height-div'ов (empty + filled), высоту ведёт
// ТОЛЬКО heroHeightCls. large (дефолт bloom blockDefaults) ≈ прежней высоте полотна
// (aspect 1920/925 на десктопе) — подняты значения и добавлены брейкпоинты; medium/
// small заметно ниже. Дефолт (p.size не задан) = large.
const heroSize = p.size === "small" ? "small" : p.size === "medium" ? "medium" : "large";
const heroHeightCls = {
	large: "min-h-[min(80svh,620px)] sm:min-h-[600px] md:min-h-[620px] xl:min-h-[680px] 2xl:min-h-[720px]",
	medium: "min-h-[min(62svh,500px)] sm:min-h-[480px] md:min-h-[500px] xl:min-h-[540px]",
	small: "min-h-[min(46svh,380px)] sm:min-h-[360px] md:min-h-[380px] xl:min-h-[400px]",
}[heroSize];

// «Размер» (p.size) масштабирует не только высоту медиа, но и подложку-контейнер
// (max-w/gap/padding) + кнопку CTA — симметрично (medium ≈0.82×, small ≈0.64×). Шрифты
// героя НЕ трогаем (у них свои поля heading.size/text.size). large = дефолт bloom;
// max-w догоняет rose-паритет (540/640) для одинакового поведения панели по темам.
const panelMaxWCls = {
	large: "max-w-[330px]",
	medium: "max-w-[270px]",
	small: "max-w-[210px]",
}[heroSize];
const panelGapCls = {
	large: "gap-4",
	medium: "gap-3",
	small: "gap-2.5",
}[heroSize];
const panelPadCls = {
	large: "p-6 md:p-8",
	medium: "p-5 md:p-6",
	small: "p-4 md:p-5",
}[heroSize];
const ctaSizeCls = {
	large: "h-12 px-4 text-[16px]",
	medium: "h-10 px-3.5 text-[14px]",
	small: "h-9 px-3 text-[13px]",
}[heroSize];

// Канон secondaryButton {text, link: string|{href}} — рендер ТОЛЬКО при непустом
// тексте; кнопки встают рядом в ряд с зазором gap-3 (манера §3).
const secondaryText =
	typeof p.secondaryButton?.text === "string" && p.secondaryButton.text.trim()
		? p.secondaryButton.text
		: undefined;
const secondaryLink =
	p.secondaryButton?.link?.href ??
	(typeof p.secondaryButton?.link === "string" ? p.secondaryButton.link : undefined) ??
	DEFAULT_CATEGORY_HREF;

// Канон overlay 0-100 (число или строка) → слой затемнения между фото (z-0) и контентом (z-10).
const overlayN = Math.max(0, Math.min(100, Number(p.overlay) || 0));

// Канон container (toggle «Контейнер» панели «Изображение») — подложка-плашка
// ТОЛЬКО под текстовым блоком, НЕ затемнение всего экрана (overlay отдельно).
// На светлой плашке текст переключаем на тёмный цвет схемы для читаемости.
const boxed = String(p.container ?? "false") === "true";
const boxedCls = boxed
	? ` rounded-[var(--radius-card,8px)] bg-[rgb(var(--color-bg,255_255_255))]/95 ${panelPadCls} shadow-sm [&_h1]:!text-[rgb(var(--color-heading,0_0_0))] [&_p]:!text-[rgb(var(--color-text,0_0_0))]`
	: "";

// Канон position (видимое поле панели) / contentPosition (legacy hidden, те же
// 9 значений). Позиция управляет РАЗМЕЩЕНИЕМ контент-блока по сетке 3×3:
//   вертикаль — top / center(=середина) / bottom; горизонталь — left / center / right.
// Пустой проп = дефолт верстальщика bloom (ЛЕВЫЙ НИЖНИЙ угол: items-start +
// justify-end) — поэтому пустые ветки vPos/hPos дают "" (→ низ) и "left".
// Явное 'center' (По центру) = СЕРЕДИНА по вертикали + центр по горизонтали
// (раньше ошибочно сводилось к дефолту-низу — это и был баг).
// Выравнивание (alignment) теперь НЕЗАВИСИМО и отвечает только за выравнивание
// КОНТЕНТА (заголовок/текст/кнопки) ВНУТРИ блока, не двигая сам блок.
const posRaw =
	typeof p.position === "string" && p.position
		? p.position
		: typeof p.contentPosition === "string"
			? p.contentPosition
			: "";
const vPos = posRaw.startsWith("top")
	? "top"
	: posRaw.startsWith("bottom")
		? "bottom"
		: posRaw === "center" || posRaw.startsWith("center")
			? "middle"
			: ""; // пусто = дефолт bloom (низ)
const hPos = posRaw.endsWith("left")
	? "left"
	: posRaw.endsWith("right")
		? "right"
		: posRaw === "center" || posRaw.endsWith("-center")
			? "center"
			: "left"; // пусто = дефолт bloom (слева)
const vJustifyCls = vPos === "top" ? "justify-start" : vPos === "middle" ? "justify-center" : "justify-end";
const hItemsCls = hPos === "right" ? "items-end" : hPos === "center" ? "items-center" : "items-start"; // POSITION → размещение блока
// alignment — выравнивание КОНТЕНТА внутри блока (НЕ двигает сам блок — это делает
// Позиция через items на внешнем контейнере). items-* выравнивают заголовок/текст/
// кнопки друг относительно друга, text-align — многострочный текст. Дефолт bloom 'left'.
const alignItemsCls =
	p.alignment === "center" ? "items-center" : p.alignment === "right" ? "items-end" : "items-start"; // ALIGNMENT → контент внутри блока
const textAlignCls =
	p.alignment === "center" ? " text-center" : p.alignment === "right" ? " text-right" : "";
const buttonsJustifyCls =
	p.alignment === "center" ? "justify-center" : p.alignment === "right" ? "justify-end" : "justify-start";
// Верхний отступ контейнера нужен только при верхней/средней позиции (низ — литерал).
const needsTopPad = vPos === "top" || vPos === "middle";
const containerCls = `absolute inset-0 z-10 flex h-full w-full flex-col ${hItemsCls} ${vJustifyCls} px-4 pb-8 md:px-20 md:pb-12 xl:pb-20 2xl:px-[300px]${needsTopPad ? " pt-8 md:pt-12 xl:pt-20" : ""}`;

// Канон buttonStyle solid|outlined: outlined = pill с бордером/текстом цвета
// заливки кнопки на прозрачном фоне; solid/отсутствие = розовый pill верстальщика
// дословно (токены кнопки-1 §7, rounded-full → --radius-button 100px). Общий каркас
// ctaBaseCls (размер/радиус/шрифт/паддинг — bloom-манера font-inter/100px) для ОБЕИХ
// кнопок, чтобы вторая кнопка масштабировалась «Размером» и флипала заливку в паре.
const ctaBaseCls = `inline-flex ${ctaSizeCls} items-center justify-center rounded-[var(--radius-button,100px)] font-inter font-light leading-none transition-opacity hover:opacity-90 active:scale-95`;
const solidCls = `${ctaBaseCls} bg-[rgb(var(--color-button-bg,227_142_159))] text-[rgb(var(--color-button-text,255_255_255))]`;
const outlinedCls = `${ctaBaseCls} border border-solid border-[rgb(var(--color-button-bg,227_142_159))] bg-transparent text-[rgb(var(--color-button-bg,227_142_159))]`;
const ctaBtnCls = p.buttonStyle === "outlined" ? outlinedCls : solidCls;
// Вторая кнопка — СОГЛАСОВАННАЯ ПАРА с первой на ОДНОМ токене кнопки-1 (паритет rose
// Hero): заливка ПРОТИВОПОЛОЖНА первой (solid → первая залита/вторая контур; outlined
// → наоборот). Раньше была захардкоженная белая на токенах кнопки-2 → не флипала при
// outlined («вторая кнопка не меняла заливку»). Bloom-манера (font-inter/100px) цела.
const secondaryBtnCls = p.buttonStyle === "outlined" ? solidCls : outlinedCls;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T14).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

{
	isEmpty ? (
		/* Пустое состояние (Figma 1:19335, тип «Изображение»): пустая surface-плашка
		   на всю секцию + overlay-лейбл «Изображение» + хелпер-текст + кнопка
		   «Кнопка». Без мок-картинки и без дефолт-контента верстальщика. Puck-
		   subsection-атрибуты сохранены — блок остаётся выделяемым/редактируемым в
		   конструкторе (heading=100, text=101, primaryButton=102). */
		<section
			class="relative w-full overflow-hidden bg-[rgb(var(--color-surface,245_245_245))]"
			aria-labelledby="hero-title"
			data-puck-component-id={id}
			style={paddingStyle}
		>
			{/* Figma 1:19335: фон пустого состояния = дизайн-ассет landscape-image.png
			    (а НЕ пустая surface). Лежит на всю секцию (z-0); тёмный градиент снизу
			    (z-[1]) даёт читаемость белого overlay-текста, как у настоящего фото. */}
			<BloomPicture
				src={PH_BACKGROUND_IMAGE}
				alt=""
				loading="eager"
				fetchpriority="high"
				class="absolute inset-0 z-0 size-full object-cover object-center"
			/>
			<div class="pointer-events-none absolute inset-0 z-[1] bg-gradient-to-t from-black/40 to-transparent" aria-hidden="true"></div>
			<div
				class={`relative w-full ${heroHeightCls}`}
			>
				<div class="absolute inset-0 z-10 flex h-full w-full flex-col items-center justify-center gap-6 px-4 text-center md:px-20 2xl:px-[300px]">
					<div class="flex w-full max-w-[540px] flex-col items-center gap-2 text-center">
						<h1
							id="hero-title"
							class="font-urbanist text-[18px] font-normal uppercase leading-none text-[rgb(var(--color-heading,255_255_255))] md:text-[20px]"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="100"
							data-puck-subsection-field="heading"
						>
							{PH_LABEL}
						</h1>
						<p
							class="font-inter text-[14px] font-light leading-[1.2] text-[rgb(var(--color-text,255_255_255))] md:text-[16px]"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="101"
							data-puck-subsection-field="text"
						>
							{PH_HELPER}
						</p>
					</div>
					<a
						href={ctaLink}
						class="inline-flex h-12 items-center justify-center rounded-[var(--radius-button,100px)] bg-[rgb(var(--color-button-bg,227_142_159))] px-4 font-inter text-[16px] font-light leading-none text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-90 active:scale-95"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="102"
						data-puck-subsection-field="primaryButton"
					>
						{PH_BUTTON}
					</a>
				</div>
			</div>
		</section>
	) : (
<section
	class="relative w-full overflow-hidden bg-[rgb(var(--color-bg,255_255_255))]"
	aria-labelledby="hero-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	{/* Баг M$rkul «чёрные полосы сверху/снизу»: фон-картинка кроет ВСЮ секцию
	    (absolute на уровне <section> → заполняет padding-box целиком, включая зону
	    «Отступы») → фон цветовой схемы больше не проступает полосами. «Отступы»
	    (padding на <section>) теперь отодвигают КОНТЕНТ (inner-div ниже в нормальном
	    потоке), а не создают полосы. */}
	{
		backgroundImage2 ? (
			<div class="absolute inset-0 z-0 grid grid-cols-2">
				<BloomPicture
					src={backgroundImage}
					alt=""
					loading="eager"
					fetchpriority="high"
					class="size-full object-cover object-center"
				/>
				<BloomPicture
					src={backgroundImage2}
					alt=""
					loading="eager"
					fetchpriority="high"
					class="size-full object-cover object-center"
				/>
			</div>
		) : backgroundImage ? (
			<BloomPicture
				src={backgroundImage}
				alt=""
				loading="eager"
				fetchpriority="high"
				class="absolute inset-0 z-0 size-full object-cover object-center"
			/>
		) : (
			/* Ни фон-картинки, ни второго фото не задано, но блок НЕ пустой (есть
			   заголовок/текст/кнопка): вместо `null` — surface-подложка на всю секцию
			   (паритет rose Hero: фото-зона существует всегда). Иначе медиа-слой
			   пропадал при «заголовок задан + фон пуст». */
			<div class="absolute inset-0 z-0 bg-[rgb(var(--color-surface,245_245_245))]" aria-hidden="true" />
		)
	}

	{
		overlayN > 0 && (
			<div
				class="pointer-events-none absolute inset-0 z-[1] bg-black"
				style={`opacity:${overlayN / 100}`}
			/>
		)
	}

	<div
		class={`relative w-full ${heroHeightCls}`}
	>
		<div class={containerCls}>
			<div class={`flex w-full ${panelMaxWCls} flex-col ${alignItemsCls} ${panelGapCls}${boxedCls}`}>
				<div class={`flex flex-col ${alignItemsCls} gap-2${textAlignCls}`}>
					<h1
						id="hero-title"
						class={headingCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="100"
						data-puck-subsection-field="heading"
					>
						{title}
					</h1>
					<p
						class={subtitleCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="101"
						data-puck-subsection-field="text"
					>
						{subtitle}
					</p>
				</div>
				{
					secondaryText ? (
						<div class={`hero-animate-3 flex w-full flex-row flex-wrap items-center gap-3 ${buttonsJustifyCls}`}>
							<a
								href={ctaLink}
								class={ctaBtnCls}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="102"
								data-puck-subsection-field="primaryButton"
							>
								{ctaText}
							</a>
							<a
								href={secondaryLink}
								class={secondaryBtnCls}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="103"
								data-puck-subsection-field="secondaryButton"
							>
								{secondaryText}
							</a>
						</div>
					) : (
						<a
							href={ctaLink}
							class={`hero-animate-3 ${ctaBtnCls}`}
							data-puck-subsection-parent={id}
							data-puck-subsection-index="102"
							data-puck-subsection-field="primaryButton"
						>
							{ctaText}
						</a>
					)
				}
			</div>
		</div>
	</div>
</section>
	)
}
