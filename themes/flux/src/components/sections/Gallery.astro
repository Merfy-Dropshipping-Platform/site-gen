---
// ОЖИВЛЕНИЕ (контракт rose Gallery / flux Popular,Collections): полная
// конструкторная схема theme-base Gallery.puckConfig поверх ВЁРСТКИ
// ВЕРСТАЛЬЩИКОВ (репо flux-theme Gallery.astro: крупная плитка слева
// lg:grid-cols-[1fr_429px] + правая колонка карточек, ВСЁ font-roboto-flex
// font-light, плитки rounded-[8/12px], aspect-square / aspect-[429/314]).
// НЕ DS-компонент-шапка (он рендерил Comfortaa h2 / Manrope подзаголовок —
// мимо манеры flux): шапка = простой <h2>/<p> font-roboto-flex (как
// Popular/Collections). Канон-дефолты конструктора (headingSize/textSize medium →
// эталон, imagePosition left → большая плитка слева) дают пиксель верстальщика;
// цвета → токены с пиксель-фоллбеком (MANNER.md §7). Скролл-анимаций нет —
// манера flux статична (MANNER.md §6).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустое состояние (Figma 1:19335, контракт Gallery) — ДОСЛОВНЫЙ плейсхолдер:
// заголовок «Галерея», БЕЗ подзаголовка (в контракте Gallery подзаголовка нет →
// дефолт пуст). Заданный мерчантом heading/text/subtitle рендерится как есть
// (?? fallback срабатывает только при пустых данных); пустой subtitle →
// блок <p> не выводится.
const sectionTitle =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title ?? "Галерея";
const sectionSubtitle =
	(typeof p.text === "string" ? p.text : p.text?.content) ??
	(typeof p.subtitle === "string" ? p.subtitle : undefined) ??
	"";

// Шапка секции = простой <h2> font-roboto-flex uppercase (манера flux,
// как Popular/Collections), ЦЕНТРИРОВАНА (эталон rose Gallery + текущий flux).
// headingSize/textSize — ступени small/medium/large КАК rose, но на базе
// ЭТАЛОННЫХ размеров верстальщика (текст карточек 16/18/20px), НЕ раздутых
// DS-значений (46/35px). Цвет — токены (color-heading/color-muted) с фоллбеком
// чёрный/серый → colorScheme перекрашивает, без схемы пиксель эталона.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[16px] md:text-[18px]"
		: headingSize === "large"
			? "text-[20px] md:text-[24px]"
			: "text-[18px] md:text-[20px]"; // medium (canon-default) + absent → эталон
const textSize = p.textSize ?? p.text?.size;
const textSizeCls =
	textSize === "small"
		? "text-[14px]"
		: textSize === "large"
			? "text-[19px]"
			: "text-[16px]"; // medium (canon-default) + absent → 16px (как rose)
const headingCls = `font-roboto-flex font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))] ${headingSizeCls}`;
const subtitleCls = `font-roboto-flex font-normal leading-normal text-[rgb(var(--color-muted,153_153_153))] ${textSizeCls}`;
const headWrapCls = "flex flex-col items-center gap-2 text-center";

// Канон imagePosition left/right (как rose): 'left' (canon-default) и
// отсутствие = большая плитка слева (литерал lg:grid-cols-[1fr_429px]);
// 'right' — зеркало: шаблон колонок переворачивается + lg:order.
const mirror = p.imagePosition === "right";
const gridColsCls = mirror ? "lg:grid-cols-[429px_1fr]" : "lg:grid-cols-[1fr_429px]";
const heroOrderCls = mirror ? " lg:order-2" : "";
const sideOrderCls = mirror ? " lg:order-1" : "";

// Канон items[] (≤3, типы image/product/collection): плитки из пропсов. SSR
// рендерит канон-плейсхолдеры («Товар» 2 500 ₽ / «Выбери коллекцию»); резолв
// productId/collectionId → имя/цена/картинка/href делает гидрация ниже
// (data-gallery-product / -collection): live — /data/{products,collections}.json,
// превью — storefront-data.
type GalleryTile = {
	kind: "image" | "product" | "collection";
	url: string;
	alt: string;
	label: string;
	price: string;
	href: string;
	ref: string | null;
};
const galleryTiles: GalleryTile[] = (Array.isArray(p.items) ? p.items : [])
	.filter((x: any) => x && typeof x === "object")
	.slice(0, 3)
	.map((it: any): GalleryTile => {
		if (it.type === "product") {
			const pid = typeof it.productId === "string" && it.productId ? it.productId : null;
			return {
				kind: "product",
				url: "",
				alt: "Товар",
				label: "Товар",
				price: "2 500 ₽",
				href: pid ? `/product?id=${encodeURIComponent(pid)}` : "/catalog",
				ref: pid,
			};
		}
		if (it.type === "collection") {
			const cid = typeof it.collectionId === "string" && it.collectionId ? it.collectionId : null;
			return {
				kind: "collection",
				url: "",
				alt: "Коллекция",
				label: "Выбери коллекцию",
				price: "",
				href: cid ? `/catalog?collection=${encodeURIComponent(cid)}` : "/catalog",
				ref: cid,
			};
		}
		return {
			kind: "image",
			url: typeof it.url === "string" ? it.url : "",
			alt: typeof it.alt === "string" ? it.alt : "",
			label: "",
			price: "",
			href: "/catalog",
			ref: null,
		};
	});
// ПЛЕЙСХОЛДЕР пустой плитки (Figma 1:19335, контракт theme-base Gallery):
// НЕ фото верстальщика, а нейтральная заглушка-куртка по типу плитки. product
// (любой) и collection С ВЫБОРОМ → куртка-плейсхолдер blue
// (/placeholders/sweater-blue.svg; build-пайплайн копирует ассет из
// packages/theme-base/public по скану .astro, assemble-from-packages.ts:376).
// Этот <img> служит И визуальным плейсхолдером, И целью гидрации: когда товар/
// коллекция ВЫБРАНЫ, скрипт ниже (data-gallery-product / -collection) подменяет
// src/alt реальной картинкой — поведение «данные выбраны» цело.
const SWEATER_BLUE = "/placeholders/sweater-blue.svg";
galleryTiles.forEach((t) => {
	if (t.url) return;
	if (t.kind === "product") t.url = SWEATER_BLUE;
	else if (t.kind === "collection" && t.ref) t.url = SWEATER_BLUE;
});
// Гейт пустого состояния (Figma 1:19335): true ТОЛЬКО при реальном контенте
// плитки (image с непустым url, product/collection с выбранным ref). Пустые
// seed-плитки (url='' / ref=null) → false → рендерится empty-state плейсхолдер
// ниже. Читаем ref для product/collection (не url): forEach выше присваивает
// product url=SWEATER_BLUE.
const useItems = galleryTiles.some((t) => (t.kind === "image" ? !!t.url : !!t.ref));
const heroTile = useItems ? galleryTiles[0] : undefined;
const sideTiles = useItems ? galleryTiles.slice(1) : [];

// Аспекты и ховеры правой колонки — по позициям литерала верстальщика:
// плитка 1 (карточка товара) — aspect-square (scale-105 300ms), плитка 2
// (карточка коллекции) — aspect-[429/314] (scale-[1.03] 500ms ease-out).
const SIDE_ASPECTS = ["aspect-square", "aspect-[429/314]"];
const SIDE_HOVERS = [
	"transition-transform duration-300 group-hover:scale-105",
	"transition-transform duration-500 ease-out group-hover:scale-[1.03]",
];
// Подписи карточек = эталон верстальщика: товар text-[18px] md:text-[20px],
// коллекция text-[16px], ВСЁ font-roboto-flex font-light. Хук-классы гидрации
// (gallery-product-title / -price, gallery-collection-title) сохранены.
const productTitleCls =
	"gallery-product-title font-roboto-flex text-[18px] font-light leading-normal text-[rgb(var(--color-text,0_0_0))] md:text-[20px]";
const productPriceCls =
	"gallery-product-price font-roboto-flex text-[18px] font-light leading-normal text-[rgb(var(--color-text,0_0_0))] md:text-[20px]";
const collectionTitleCls =
	"gallery-collection-title font-roboto-flex text-[16px] font-light leading-normal text-[rgb(var(--color-text,0_0_0))]";

// Контейнер = flux-container эталона (как Popular/Collections/Footer/Header:
// mx-auto max-w-[1920px] px-4 md:px-20 2xl:px-80) + flex flex-col gap-8.
// Вертикаль py-10 md:py-16 (эталон); при заданном padding (настройка) py-классы
// убираются — inline-стиль ставит padding-top/bottom (паттерн Popular/Footer,
// чтобы не было двойного отступа).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
const containerCls = paddingStyle
	? "mx-auto flex w-full max-w-[1920px] flex-col gap-8 px-4 md:px-20 2xl:px-80"
	: "mx-auto flex w-full max-w-[1920px] flex-col gap-8 px-4 py-10 md:px-20 md:py-16 2xl:px-80";
---

<section
	id="gallery"
	class="w-full bg-[rgb(var(--color-bg,255_255_255))]"
	aria-labelledby="gallery-title"
	data-puck-component-id={id}
>
	<div class={containerCls} style={paddingStyle}>
		<div
			class={headWrapCls}
			data-puck-subsection-parent={id}
			data-puck-subsection-index="100"
			data-puck-subsection-field="heading"
			data-reveal
		>
			<h2 id="gallery-title" class={headingCls}>{sectionTitle}</h2>
			{sectionSubtitle && <p class={subtitleCls}>{sectionSubtitle}</p>}
		</div>

		<div class={`flex flex-col gap-4 lg:grid ${gridColsCls} lg:gap-4`}>
			{heroTile ? (
				<a
					href={heroTile.href}
					class={`gallery-hero-tile group relative block aspect-square w-full min-w-0 overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))] lg:aspect-auto lg:h-full${heroOrderCls}`}
					aria-label={heroTile.alt || heroTile.label || "Перейти в каталог"}
					data-gallery-product={heroTile.kind === "product" ? (heroTile.ref ?? undefined) : undefined}
					data-gallery-collection={heroTile.kind === "collection" ? (heroTile.ref ?? undefined) : undefined}
					data-puck-subsection-parent={id}
					data-puck-subsection-index={0}
					data-puck-subsection-field="items"
				>
					{heroTile.url && (
						<img
							src={heroTile.url}
							alt={heroTile.alt}
							loading="lazy"
							class="absolute inset-0 size-full object-cover object-left transition-transform duration-500 ease-out group-hover:scale-[1.02]"
						/>
					)}
				</a>
			) : (
				/* Плейсхолдер пустого состояния (Figma 1:19335): большая левая плитка =
				   дизайн-ассет /placeholders/landscape-gallery.png (картинка показывается
				   ВСЕГДА, НЕ пустой surface и НЕ мок-фото верстальщика). */
				<div
					class={`gallery-hero-tile group relative block aspect-square w-full min-w-0 overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))] lg:aspect-auto lg:h-full${heroOrderCls}`}
					aria-hidden="true"
				>
					<img
						src="/placeholders/landscape-gallery.png"
						alt=""
						aria-hidden="true"
						loading="lazy"
						class="absolute inset-0 size-full object-cover object-left"
					/>
				</div>
			)}

			{useItems ? sideTiles.length > 0 && (
				<div class={`grid min-w-0 grid-cols-2 gap-4 lg:flex lg:flex-col lg:gap-4${sideOrderCls}`}>
					{sideTiles.map((tile, i) => (
						<a
							href={tile.href}
							class="group flex min-w-0 flex-col gap-4"
							aria-label={tile.label || tile.alt || "Изображение"}
							data-gallery-product={tile.kind === "product" ? (tile.ref ?? undefined) : undefined}
							data-gallery-collection={tile.kind === "collection" ? (tile.ref ?? undefined) : undefined}
							data-puck-subsection-parent={id}
							data-puck-subsection-index={i + 1}
							data-puck-subsection-field="items"
						>
							<div
								class={`relative ${SIDE_ASPECTS[i] ?? SIDE_ASPECTS[0]} w-full min-h-0 overflow-hidden rounded-[12px] bg-[rgb(var(--color-surface,245_245_245))]`}
							>
								{tile.url && (
									<img
										src={tile.url}
										alt={tile.alt || tile.label}
										loading="lazy"
										class={`absolute inset-0 size-full max-w-none object-cover object-center ${SIDE_HOVERS[i] ?? SIDE_HOVERS[0]}`}
									/>
								)}
							</div>
							{(tile.label || tile.price) && (
								<div class="flex flex-col gap-1">
									{tile.label && (
										<h3 class={tile.kind === "collection" ? collectionTitleCls : productTitleCls}>
											{tile.label}
										</h3>
									)}
									{tile.price && <span class={productPriceCls}>{tile.price}</span>}
								</div>
							)}
						</a>
					))}
				</div>
			) : (
				/* ПЛЕЙСХОЛДЕР пустого состояния (Figma 1:19335, контракт theme-base
				   Gallery): карточка-товар (куртка blue + «Товар» / «2 500 ₽») +
				   карточка-коллекция (пустой image-rect + «Выбери коллекцию») вместо
				   мок-товаров верстальщика («M Phone 17» / «Смартфоны»). */
				<div class={`grid min-w-0 grid-cols-2 gap-4 lg:flex lg:flex-col lg:gap-4${sideOrderCls}`}>
					<div class="flex min-w-0 flex-col gap-4" aria-label="Товар">
						<div class="relative aspect-square w-full min-h-0 overflow-hidden rounded-[12px] bg-[rgb(var(--color-surface,245_245_245))]">
							<img
								src="/placeholders/sweater-blue.svg"
								alt="Товар"
								loading="lazy"
								class="absolute inset-0 size-full object-contain object-center p-[15%]"
							/>
						</div>
						<div class="flex flex-col gap-1">
							<h3 class={productTitleCls}>Товар</h3>
							<span class={productPriceCls}>2 500 ₽</span>
						</div>
					</div>

					<div class="flex min-w-0 flex-col gap-4" aria-label="Выбери коллекцию">
						<div
							class="relative aspect-[429/314] w-full min-h-0 overflow-hidden rounded-[12px] bg-[rgb(var(--color-surface,245_245_245))]"
							aria-hidden="true"
						/>
						<h3 class={collectionTitleCls}>Выбери коллекцию</h3>
					</div>
				</div>
			)}
		</div>
	</div>
</section>

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		findCollection,
		formatPrice,
		productHref,
		productImage,
	} from "../../lib/storefront-hydrate";

	// Резолв выбранных в конструкторе товара/коллекции на плитках галереи
	// (data-gallery-product / data-gallery-collection). SSR несёт
	// канон-плейсхолдеры; здесь подставляем имя/цену/картинку/ссылку реальной
	// сущности. Без данных (demo-сборка) — no-op.
	const hydrateGalleryTiles = async () => {
		const prodTiles = Array.from(document.querySelectorAll<HTMLElement>("[data-gallery-product]"));
		const colTiles = Array.from(document.querySelectorAll<HTMLElement>("[data-gallery-collection]"));
		if (prodTiles.length === 0 && colTiles.length === 0) return;
		const [products, collections] = await Promise.all([
			prodTiles.length ? loadRealProducts() : Promise.resolve(null),
			colTiles.length ? loadRealCollections() : Promise.resolve(null),
		]);
		for (const tile of prodTiles) {
			const ref = tile.getAttribute("data-gallery-product");
			const product = products?.find((x) => x.id === ref || x.slug === ref) ?? null;
			if (!product) continue;
			const title = tile.querySelector(".gallery-product-title");
			if (title && product.name) title.textContent = product.name;
			const price = tile.querySelector(".gallery-product-price");
			if (price) price.textContent = formatPrice(product.price);
			const img = tile.querySelector("img");
			const cover = productImage(product);
			if (img && cover) {
				img.setAttribute("src", cover);
				if (product.name) img.setAttribute("alt", product.name);
			}
			tile.setAttribute("href", productHref(product));
			if (product.name) tile.setAttribute("aria-label", product.name);
		}
		for (const tile of colTiles) {
			const col = findCollection(collections, tile.getAttribute("data-gallery-collection"));
			if (!col) continue;
			const title = tile.querySelector(".gallery-collection-title");
			if (title && col.name) title.textContent = col.name;
			const cover = col.image || (Array.isArray(col.images) ? col.images[0] : "");
			const img = tile.querySelector("img");
			if (img && cover) {
				img.setAttribute("src", cover);
				if (col.name) img.setAttribute("alt", col.name);
			}
			if (col.name) tile.setAttribute("aria-label", col.name);
			if (col.slug) tile.setAttribute("href", `/catalog?collection=${encodeURIComponent(col.slug)}`);
		}
	};

	hydrateGalleryTiles();
	document.addEventListener("astro:page-load", hydrateGalleryTiles);
</script>
