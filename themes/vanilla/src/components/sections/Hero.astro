---
import VanillaPicture from "../img/VanillaPicture.astro";
import { V_IMG } from "../../data/imageAssets";

// ОЖИВЛЕНИЕ (Фаза B, контракт rose/bloom Hero): канон-схема theme-base
// Hero.puckConfig ВКЛЮЧАЯ carousel-ветку «084 vanilla pilot» (mode, slides[]≤8,
// pagination, autoplay, interval) поверх карусели верстальщика. Тело — verbatim;
// страницы темы зовут <Hero /> без пропсов → дефолт = 3 слайда верстальщика
// байт-в-байт (цвета → токены с пиксель-фоллбеком родных литералов, MANNER §7).
// blockDefaults vanilla: mode=carousel, pagination=numbers, autoplay=true,
// interval=5, size=large, alignment/contentAlign=left, buttonStyle=solid,
// imageFullBleed=true. Параметры скрипту — ТОЛЬКО data-атрибуты (data-slides-json,
// data-autoplay, data-interval); таймер автолистания живёт в vanillaHeroCarousel.ts
// и заводится ТОЛЬКО при data-autoplay (дефолт-ветка без таймера = верстальщик).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Дефолтные слайды = литералы верстальщика (тексты/ссылки verbatim).
const CANON_SLIDES = [
	{
		image: V_IMG.hero(1),
		title: "Искусство жить уютно",
		subtitle: "Товары, которые делают дом особенным",
		ctaText: "Перейти к коллекции",
		ctaHref: "#collections",
	},
	{
		image: V_IMG.hero(2),
		title: "Дом, в который хочется возвращаться",
		subtitle: "Товары, создающие атмосферу тепла и спокойствия",
		ctaText: "Перейти к товарам",
		ctaHref: "/catalog/textile",
	},
	{
		image: V_IMG.hero(3),
		title: "Интерьер, наполненный смыслом",
		subtitle: "коллекция текстиля и декора для тех, кто ценит красоту в деталях",
		ctaText: "Новые поступления",
		ctaHref: "/catalog/textile",
	},
];

// Под Container API (live/превью v2) cwd ≠ корень темы: fs-проверка VanillaPicture
// не находит public/ и .png остался бы в src (на диске темы только .webp → 404).
// Подменяем расширение заранее (паттерн Collections); на сборке темы вывод тот же.
const toWebp = (src: string) => src.replace(/\.(png|jpe?g)$/i, ".webp");

// Hero = ОДИНОЧНОЕ изображение (одно полотно, без контролов карусели). Карусель —
// это ОТДЕЛЬНАЯ секция «Слайд-шоу» (Slideshow), Hero её не дублирует. Раньше
// blockDefaults vanilla форсил mode=carousel → Hero выглядел как Слайд-шоу (баг
// тестера «Изображение = Слайд-шоу»). Теперь Hero всегда single, даже если в
// старых данных лежит mode=carousel (артефакт сида — карусель живёт в Slideshow).
const mode = "single";

// Канон size — canon-носитель «Размера» (blockDefaults vanilla size='large').
const sectionSize = typeof p.size === "string" ? p.size : undefined;

// ДВА НЕЗАВИСИМЫХ размера у Hero:
//   • p.size (= sectionSize) — ВЫСОТА полотна (heroHeightCls ниже). НЕ шрифт.
//   • heading.size / text.size — размер ШРИФТА заголовка/текста (поля «Размер
//     заголовка»/«Размер текста»). Возвращены по решению владельца (откат unify
//     ee611471). font-size берётся ТОЛЬКО из heading.size/text.size (аргумент этих
//     функций), БЕЗ фолбэка на sectionSize — иначе регулятор высоты снова менял бы
//     кегль (та самая путаница). Отсутствие (undefined) → дефолт-ветка large =
//     ЛИТЕРАЛ верстальщика (§9) байт-в-байт прежнему виду.
// Лестница hero h1 (§9): large/отсутствие = text-2xl (24px); medium 20, small 17.
const headingClsFor = (s?: string) =>
	s === "small"
		? "hero-animate-1 vanilla-hero-slide-title font-vanilla-bitter text-[17px] font-normal italic tracking-normal text-[rgb(var(--color-heading,255_255_255))] md:whitespace-nowrap"
		: s === "medium"
			? "hero-animate-1 vanilla-hero-slide-title font-vanilla-bitter text-[20px] font-normal italic tracking-normal text-[rgb(var(--color-heading,255_255_255))] md:whitespace-nowrap"
			: "hero-animate-1 vanilla-hero-slide-title font-vanilla-bitter text-2xl font-normal italic tracking-normal text-[rgb(var(--color-heading,255_255_255))] md:whitespace-nowrap";

// Лестница hero-текста (§9): large/отсутствие = text-base (16); medium 14, small 11.
const textClsFor = (s?: string) =>
	s === "small"
		? "hero-animate-2 vanilla-hero-slide-subtitle font-vanilla-arsenal text-[11px] font-normal italic tracking-normal text-[rgb(var(--color-text,240_240_240))] md:whitespace-nowrap"
		: s === "medium"
			? "hero-animate-2 vanilla-hero-slide-subtitle font-vanilla-arsenal text-[14px] font-normal italic tracking-normal text-[rgb(var(--color-text,240_240_240))] md:whitespace-nowrap"
			: "hero-animate-2 vanilla-hero-slide-subtitle font-vanilla-arsenal text-base font-normal italic tracking-normal text-[rgb(var(--color-text,240_240_240))] md:whitespace-nowrap";

// «Размер» → высота полотна (min-height viewport). large (canon-default vanilla) =
// прежняя лестница min-h-[520px] md:620 xl:790 байт-в-байт; medium ≈0.82×,
// small ≈0.64×. Дефолт (p.size не задан) = large.
const heroSize = sectionSize === "small" ? "small" : sectionSize === "medium" ? "medium" : "large";
const heroHeightCls = {
	large: "min-h-[520px] md:min-h-[620px] xl:min-h-[790px]",
	medium: "min-h-[430px] md:min-h-[510px] xl:min-h-[650px]",
	small: "min-h-[335px] md:min-h-[400px] xl:min-h-[505px]",
}[heroSize];

// «Размер» масштабирует НЕ только высоту полотна, но и подложку/CTA симметрично
// (паттерн rose Hero «Размер»): large = ТЕКУЩИЕ значения vanilla байт-в-байт,
// medium ≈0.82×, small ≈0.64×. Шрифты заголовка/текста здесь НЕ участвуют
// (кегль h1/p живёт в headingClsFor/textClsFor от heading.size/text.size).
//   • panelMaxWCls — макс-ширина контент-блока (copyWrapCls, было 52rem);
//   • panelGapCls  — вертикальный зазор копи (было gap-5);
//   • panelPadCls  — паддинги подложки-плашки (heroBoxed=true, было p-6 md:p-10);
//   • ctaSizeCls   — размерная часть CTA-кнопки (высота/паддинги/кегль лейбла).
const panelMaxWCls = {
	large: "max-w-[min(100%,52rem)]",
	medium: "max-w-[min(100%,43rem)]",
	small: "max-w-[min(100%,33rem)]",
}[heroSize];
const panelGapCls = { large: "gap-5", medium: "gap-4", small: "gap-3" }[heroSize];
const panelPadCls = { large: "p-6 md:p-10", medium: "p-5 md:p-8", small: "p-4 md:p-6" }[heroSize];
const ctaSizeCls = {
	large: "h-12 min-h-12 px-4 text-base",
	medium: "h-10 min-h-10 px-3.5 text-[15px]",
	small: "h-9 min-h-9 px-3 text-[14px]",
}[heroSize];

type CanonSlide = {
	image: string;
	title: string;
	subtitle: string;
	ctaText: string;
	ctaHref: string;
	titleCls: string;
	subtitleCls: string;
};

// Канон slides[] ≤8 ({id, imageUrl, heading{text,size}, text{content,size},
// buttonText, buttonLink} + терпимость к legacy title/subtitle/ctaText/ctaUrl).
// Слайд без фото получает ассет верстальщика по позиции (принцип rose T15).
const slideFromProps = (s: any, i: number): CanonSlide => {
	const title = typeof s.heading === "string" ? s.heading : ((s.heading?.text ?? s.title ?? "") as string);
	const subtitle =
		typeof s.text === "string" ? s.text : ((s.text?.content ?? s.subtitle ?? "") as string);
	const ctaText =
		((typeof s.buttonText === "string" && s.buttonText.trim() ? s.buttonText : undefined) ??
			(typeof s.ctaText === "string" && s.ctaText.trim() ? s.ctaText : undefined) ??
			"") as string;
	const ctaHref =
		((typeof s.buttonLink === "string" && s.buttonLink ? s.buttonLink : undefined) ??
			s.buttonLink?.href ??
			(typeof s.ctaUrl === "string" && s.ctaUrl ? s.ctaUrl : undefined) ??
			(typeof s.ctaHref === "string" && s.ctaHref ? s.ctaHref : undefined) ??
			"/catalog") as string;
	const image =
		(typeof s.imageUrl === "string" && s.imageUrl.trim()) ||
		(typeof s.image === "string" && s.image.trim()) ||
		toWebp(V_IMG.hero((((i % 3) + 1) as 1 | 2 | 3)));
	return {
		image,
		title,
		subtitle,
		ctaText,
		ctaHref,
		// Кегль слайда — из ЕГО heading.size/text.size (НЕ sectionSize=высота).
		// Отсутствие → дефолт (large) внутри headingClsFor/textClsFor.
		titleCls: headingClsFor(s.heading?.size),
		subtitleCls: textClsFor(s.text?.size),
	};
};

const slides: CanonSlide[] =
	Array.isArray(p.slides) && p.slides.length > 0
		? p.slides.slice(0, 8).map(slideFromProps)
		: CANON_SLIDES.map((s) => ({
				...s,
				image: toWebp(s.image),
				// Демо-слайды без per-slide size → дефолт (large) кегль, НЕ sectionSize.
				titleCls: headingClsFor(undefined),
				subtitleCls: textClsFor(undefined),
			}));

// Канон top-level heading/text/primaryButton (+ legacy flat) в карусели правят
// ПЕРВЫЙ слайд — именно на него указывают subsection-маркеры 100/101/102 ниже
// (сайдбар v2 редактирует top-level пропсы, slides[] в сайдбаре скрыт; образец —
// bloom Hero, читающий p.heading.text). Непустой проп → копия слайда 1; без
// пропсов ничего не трогаем — литералы верстальщика байт-в-байт. slidesJson
// строится НИЖЕ, поэтому листание возвращает отредактированный текст на слайде 1.
const ovTitle = typeof p.heading === "string" ? p.heading : (p.heading?.text ?? p.title);
const ovSubtitle = typeof p.text === "string" ? p.text : (p.text?.content ?? p.subtitle);
const ovCtaText = p.primaryButton?.text ?? p.cta?.text ?? p.ctaText;
const ovCtaHref =
	p.primaryButton?.link?.href ??
	(typeof p.primaryButton?.link === "string" ? p.primaryButton.link : undefined) ??
	p.cta?.href ??
	p.ctaLink;
if (slides[0]) {
	if (typeof ovTitle === "string" && ovTitle.trim()) slides[0].title = ovTitle;
	if (typeof ovSubtitle === "string" && ovSubtitle.trim()) slides[0].subtitle = ovSubtitle;
	if (typeof ovCtaText === "string" && ovCtaText.trim()) slides[0].ctaText = ovCtaText;
	if (typeof ovCtaHref === "string" && ovCtaHref.trim()) slides[0].ctaHref = ovCtaHref;
	// Top-level «Размер заголовка»/«Размер текста» (heading.size/text.size) правят
	// кегль ПЕРВОГО слайда (на него указывает сайдбар v2). Только при заданном поле —
	// иначе остаётся дефолт/per-slide размер. Это кегль ШРИФТА, НЕ высота (p.size).
	if (p.heading?.size) slides[0].titleCls = headingClsFor(p.heading.size);
	if (p.text?.size) slides[0].subtitleCls = textClsFor(p.text.size);
}

// JSON для скрипта: копия + классы лестниц (смена слайда переключает и размер).
const slidesJson = JSON.stringify(
	slides.map(({ title, subtitle, ctaText, ctaHref, titleCls, subtitleCls }) => ({
		title,
		subtitle,
		ctaText,
		ctaHref,
		titleCls,
		subtitleCls,
	})),
);

// Канон autoplay/interval: таймер ТОЛЬКО при autoplay-пропе (blockDefaults vanilla
// пишут true/5с) — дефолт-ветка без пропсов остаётся без таймера (верстальщик).
const autoplayOn = p.autoplay === true || p.autoplay === "true";
const intervalMs = String(
	(typeof p.interval === "number" && p.interval >= 1 && p.interval <= 60 ? p.interval : 5) * 1000,
);

// Канон pagination: 'numbers' (canon-default из blockDefaults) И отсутствие =
// цифры верстальщика; dots/lines — плоские маркеры манеры через bg-current
// (скрипт переключает text-white/text-white/45 — цвет маркера следует за ним);
// 'none' — без маркеров (стрелки остаются).
const pagination =
	p.pagination === "dots" || p.pagination === "lines" || p.pagination === "none"
		? p.pagination
		: "numbers";

// Канон buttonStyle: solid (canon-default) = olive-CTA верстальщика дословно
// (токены кнопки-1); outlined = белый контур манеры на тёмном (§3, токены кнопки-2).
const ctaCls =
	p.buttonStyle === "outlined"
		? `hero-animate-3 inline-flex ${ctaSizeCls} max-w-full items-center justify-center border border-[rgb(var(--color-button-2-bg,255_255_255))] bg-transparent font-vanilla-arsenal font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-button-2-bg,255_255_255))] transition-opacity hover:opacity-80`
		: `hero-animate-3 inline-flex ${ctaSizeCls} max-w-full items-center justify-center bg-[rgb(var(--color-button-bg,58_69_48))] font-vanilla-arsenal font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-90`;

// Канон position (видимое поле панели) / contentPosition (legacy, те же 9
// значений) — РАЗМЕЩЕНИЕ контент-блока по сетке 3×3 (Figma 648-55404): вертикаль
// top / center(=середина) / bottom, горизонталь left / center / right. Раньше
// vanilla position ИГНОРИРОВАЛ (блок жёстко стоял по центру вертикали слева) —
// здесь добавляем поддержку. Манера верстальщика vanilla якорит копию ПО ЦЕНТРУ
// вертикали (внешний items-center), поэтому пустой проп → середина; а shipped-
// дефолт defaults/vanilla.json пишет 'bottom-left' (стале относительно верстки —
// верстальщик центрирует), значит ИМЕННО эту строку сводим к серединному якорю
// верстальщика, чтобы дефолтный вид остался байт-в-байт. Прочие явные top/bottom
// работают полноценно. Выравнивание (alignment) теперь НЕЗАВИСИМО — только текст.
// Раскладка position+alignment считается единой функцией: single-режим зовёт от
// top-level пропсов, карусель — от ПЕРВОГО слайда с фоллбеком на top-level (тот же
// принцип, что у size: s.heading?.size ?? sectionSize). Возвращает три класс-строки:
//   vItemsCls    — вертикаль блока на внешнем vanilla-pad (row-flex cross-axis);
//   hMarginCls   — горизонталь блока (auto-margin) на copyWrapCls;
//   copyWrapCls  — сам блок с выравниванием контента (items-* + text-*).
const layoutFor = (posInput: unknown, alignInput: unknown, contentAlignInput: unknown) => {
	const posRaw = typeof posInput === "string" && posInput ? posInput : "";
	// shipped-дефолт 'bottom-left' === манерный середина-слева верстальщика vanilla
	// (см. коммент выше): сводим строку к пустой, чтобы вертикаль упала в дефолт-ветку.
	const posNorm = posRaw === "bottom-left" ? "" : posRaw;
	const vPos = posNorm.startsWith("top")
		? "top"
		: posNorm.startsWith("bottom")
			? "bottom"
			: posNorm === "center" || posNorm.startsWith("center")
				? "middle"
				: ""; // пусто = дефолт верстальщика (середина)
	const hPos = posNorm.endsWith("left")
		? "left"
		: posNorm.endsWith("right")
			? "right"
			: posNorm === ""
				? "left" // дефолт верстальщика — блок слева
				: "center";
	// Вертикаль блока — на внешнем vanilla-pad (row-flex, cross-axis = вертикаль).
	const vItemsCls = vPos === "top" ? "items-start" : vPos === "bottom" ? "items-end" : "items-center";
	// Горизонталь блока — auto-margin на copyWrapCls. left = литерал верстальщика
	// (md:ml-4 lg:ml-0, без auto), center = mx-auto, right = ml-auto.
	const hMarginCls = hPos === "center" ? "mx-auto" : hPos === "right" ? "ml-auto" : "md:ml-4 lg:ml-0";
	// Канон alignment / contentAlign: 'left' (canon-default) И отсутствие = литерал
	// верстальщика (text-left). Теперь это ТОЛЬКО выравнивание контента ВНУТРИ блока
	// (items-* + text-*), НЕЗАВИСИМО от размещения самого блока (это hPos/vPos).
	const align =
		alignInput === "center" || alignInput === "right"
			? alignInput
			: contentAlignInput === "center"
				? "center"
				: "left";
	const alignItemsCls = align === "center" ? "items-center" : align === "right" ? "items-end" : "items-start";
	const textAlignCls = align === "center" ? "text-center" : align === "right" ? "text-right" : "text-left";
	const copyWrapCls = `pointer-events-auto flex w-full ${panelMaxWCls} flex-col ${panelGapCls} md:overflow-visible ${hMarginCls} ${alignItemsCls} ${textAlignCls}`;
	return { vItemsCls, copyWrapCls };
};

// Карусель: раскладка от ПЕРВОГО слайда (s.position/s.alignment) с фоллбеком на
// top-level p.position/p.alignment — манерой size-фоллбека. firstSlide — сырой проп.
const firstSlide = Array.isArray(p.slides) && p.slides.length > 0 ? p.slides[0] : undefined;
const carouselLayout = layoutFor(
	firstSlide?.position ?? p.position ?? p.contentPosition,
	firstSlide?.alignment ?? p.alignment,
	firstSlide?.contentAlign ?? p.contentAlign,
);
// Single-режим: раскладка от top-level пропсов.
const singleLayout = layoutFor(p.position ?? p.contentPosition, p.alignment, p.contentAlign);

// Канон overlay 0-100: отсутствие пропа = фикс-затемнение верстальщика bg-black/25;
// заданное число заменяет его слоем с opacity N/100.
const overlayRaw = p.overlay;
const hasOverlay = overlayRaw !== undefined && overlayRaw !== null && overlayRaw !== "";
const overlayN = hasOverlay ? Math.max(0, Math.min(100, Number(overlayRaw) || 0)) : 0;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн
// rose T14; seed пишет {0,0} — визуально ноль и есть).
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const paddingStyle = pad
	? `padding-top:${Number(pad.top) || 0}px;padding-bottom:${Number(pad.bottom) || 0}px;`
	: undefined;

// Одиночный режим (mode='single'): копия = канон heading/text/primaryButton
// (+ legacy flat), фон — backgroundImages.url1 / backgroundImage / image.url.
//
// ПЛЕЙСХОЛДЕР пустого состояния (Figma 1:19335, категория «Изображение /
// Слайд-шоу»): когда у секции НЕТ выбранных данных — рендерим контракт-
// плейсхолдер (пустой image-rect подложки темы + заголовок секции +
// поясняющий текст + Кнопка), а НЕ мок-демо верстальщика (CANON_SLIDES с
// фото vanilla-hero-slide-N и копи «Искусство жить уютно»). Когда мерчант
// задал хоть что-то (заголовок / текст / фоновое фото / CTA / slides[]) —
// рендер реальных данных НЕ трогаем (SSR-с-данными остаётся как был).
// Гейт = «есть ли курированные данные у секции» (паттерн theme-base
// PopularProducts collectionRef / Collections hasManualCollections).
const heroBgRaw =
	(typeof p.backgroundImages?.url1 === "string" && p.backgroundImages.url1.trim()) ||
	(typeof p.backgroundImage === "string" && p.backgroundImage.trim()) ||
	(typeof p.image?.url === "string" && p.image.url.trim()) ||
	"";
const heroHeadingRaw =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title ?? "";
const heroSubtitleRaw =
	(typeof p.text === "string" ? p.text : p.text?.content) ?? p.subtitle ?? "";
const heroCtaRaw = p.primaryButton?.text ?? p.cta?.text ?? p.ctaText ?? "";
const hasHeroSlides = Array.isArray(p.slides) && p.slides.length > 0;
const hasHeroData =
	!!heroBgRaw.trim() ||
	!!String(heroHeadingRaw).trim() ||
	!!String(heroSubtitleRaw).trim() ||
	!!String(heroCtaRaw).trim() ||
	hasHeroSlides;

// Контракт-лейблы плейсхолдера (тип «Изображение», Figma 1:19335): overlay
// «Изображение» + поясняющий текст «Покажи и расскажи о своем товаре в одном
// блоке» + Кнопка — ДОСЛОВНО как в Figma (НЕ мок-копи героя верстальщика и НЕ
// литералы соседних секций: ImageWithText/MultiRows «Изображение с текстом»).
// Тип «Слайд-шоу» (другой текст «Добавь несколько изображений…») реализует
// ОТДЕЛЬНАЯ секция Slideshow — Hero его не дублирует (mode='single').
const PLACEHOLDER_HEADING = "Изображение";
const PLACEHOLDER_TEXT = "Покажи и расскажи о своем товаре в одном блоке";
const PLACEHOLDER_CTA = "Кнопка";

const singleTitle = hasHeroData ? (heroHeadingRaw || CANON_SLIDES[0].title) : PLACEHOLDER_HEADING;
const singleSubtitle = hasHeroData
	? (heroSubtitleRaw || CANON_SLIDES[0].subtitle)
	: PLACEHOLDER_TEXT;
const singleCtaText = hasHeroData
	? (heroCtaRaw || CANON_SLIDES[0].ctaText)
	: PLACEHOLDER_CTA;
const singleCtaHref =
	p.primaryButton?.link?.href ??
	(typeof p.primaryButton?.link === "string" ? p.primaryButton.link : undefined) ??
	p.cta?.href ??
	p.ctaLink ??
	(hasHeroData ? CANON_SLIDES[0].ctaHref : "/catalog");
// Фон: выбранные данные → фото мерчанта/верстальщика. Пустое состояние (Figma
// 1:19335, тип «Изображение») → дизайн-ассет landscape-image.png из placeholders
// (контракт картиночных секций: картинка показывается ВСЕГДА — фолбэк = нужный
// landscape-*, НЕ пустой surface-rect и НЕ мок-фото героя). Ассет раздаётся на
// каждой теме как /placeholders/landscape-image.png.
const singleImage = hasHeroData
	? (heroBgRaw || toWebp(V_IMG.hero(1)))
	: "/placeholders/landscape-image.png";
// Single-режим: кегль из top-level heading.size/text.size (НЕ sectionSize=высота).
// Отсутствие → дефолт (large) внутри headingClsFor/textClsFor.
const singleTitleCls = headingClsFor(p.heading?.size);
const singleSubtitleCls = textClsFor(p.text?.size);
// Канон container (toggle «Контейнер») — порт rose Hero:120-123. Подложка-плашка
// ТОЛЬКО под текстовым блоком одиночного героя: полупрозрачный светлый фон манеры +
// паддинги + радиус карточки vanilla (0). На светлой плашке белая копи героя не
// читается → переключаем h1/p на тёмные токены манеры (паттерн rose boxedCls).
// blockDefaults vanilla container='false' → дефолт без плашки (рендер байт-в-байт);
// только явный true → плашка. Раньше vanilla тоггл игнорировал (мёртвая настройка).
const heroBoxed = String(p.container ?? "false") === "true";
const heroBoxedCls = heroBoxed
	? ` rounded-[var(--radius-card,0px)] bg-[rgb(var(--color-bg,238_238_238))]/95 ${panelPadCls} [&_h1]:!text-[rgb(var(--color-heading,38_49_28))] [&_p]:!text-[rgb(var(--color-text,68_68_68))]`
	: "";
// Вторая кнопка (только single) — рендер при непустом тексте, белый контур манеры.
const secondaryText =
	typeof p.secondaryButton?.text === "string" && p.secondaryButton.text.trim()
		? p.secondaryButton.text
		: undefined;
const secondaryHref =
	p.secondaryButton?.link?.href ??
	(typeof p.secondaryButton?.link === "string" ? p.secondaryButton.link : undefined) ??
	"/catalog/textile";
const secondaryCls =
	`inline-flex ${ctaSizeCls} max-w-full items-center justify-center border border-[rgb(var(--color-button-2-bg,255_255_255))] bg-transparent font-vanilla-arsenal font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-button-2-bg,255_255_255))] transition-opacity hover:opacity-80`;
---

{
	mode === "carousel" ? (
		<section
			class="relative w-full overflow-hidden bg-[var(--vanilla-green-deep)]"
			aria-labelledby="hero-title"
			data-vanilla-hero-carousel
			data-vanilla-stack
			data-slides-json={slidesJson}
			data-autoplay={autoplayOn ? "true" : undefined}
			data-interval={autoplayOn ? intervalMs : undefined}
			data-puck-component-id={id}
			style={paddingStyle}
		>
			<div
				id="hero-carousel-viewport"
				class={`relative w-full ${heroHeightCls}`}
				role="region"
				aria-roledescription="карусель"
				aria-label="Главный экран"
			>
				<div class="absolute inset-0 z-0 overflow-hidden">
					{slides.map((slide, i) => (
						<div
							data-hero-slide-img
							class:list={[
								"absolute inset-0 z-0 transition-opacity duration-500 ease-out",
								i === 0 ? "opacity-100" : "pointer-events-none opacity-0",
							]}
							aria-hidden={i !== 0 ? "true" : "false"}
							data-puck-subsection-parent={id}
							data-puck-subsection-index={i}
							data-puck-subsection-field="slides"
						>
							<VanillaPicture
								src={slide.image}
								alt=""
								decoding={i === 0 ? "sync" : "async"}
								loading={i === 0 ? "eager" : "lazy"}
								fetchpriority={i === 0 ? "high" : undefined}
								class="absolute inset-0 z-0 size-full object-cover object-center"
								aria-hidden="true"
							/>
						</div>
					))}
				</div>
				{hasOverlay ? (
					<div
						class="pointer-events-none absolute inset-0 z-[1] bg-black"
						style={`opacity:${overlayN / 100}`}
						aria-hidden="true"
					/>
				) : (
					<div class="pointer-events-none absolute inset-0 z-[1] bg-black/25" aria-hidden="true" />
				)}

				<div class:list={["vanilla-pad absolute inset-0 z-10 flex h-full w-full pointer-events-none", carouselLayout.vItemsCls]}>
					<div class="vanilla-container pointer-events-none">
						<div class={carouselLayout.copyWrapCls} aria-live="polite">
							<h1
								id="hero-title"
								data-hero-title
								class={slides[0].titleCls}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="100"
								data-puck-subsection-field="heading"
							>
								{slides[0].title}
							</h1>
							<p
								data-hero-subtitle
								class={slides[0].subtitleCls}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="101"
								data-puck-subsection-field="text"
							>
								{slides[0].subtitle}
							</p>
							<a
								data-hero-cta
								class:list={[ctaCls, !slides[0].ctaText && "hidden"]}
								href={slides[0].ctaHref}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="102"
								data-puck-subsection-field="primaryButton"
							>
								{slides[0].ctaText}
							</a>
						</div>
					</div>
				</div>
			</div>

			<div
				class="flex h-16 items-center justify-center gap-10 bg-[rgb(var(--color-bg,38_49_28))] font-vanilla-arsenal text-base leading-none md:gap-14"
				role="toolbar"
				aria-label="Переключение слайдов"
				data-hero-controls
				data-vanilla-hero-controls
			>
				<button
					type="button"
					data-hero-prev
					class="text-white hover:opacity-90"
					aria-label="Предыдущий слайд"
				>
					←
				</button>
				{pagination !== "none" && (
					<div class="flex items-center gap-10 md:gap-12">
						{slides.map((_, i) => (
							<button
								type="button"
								data-hero-bullet
								data-hero-index={String(i)}
								class:list={[
									"min-w-[1ch] p-1 font-normal uppercase tracking-normal hover:opacity-90",
									i === 0 ? "text-white" : "text-white/45",
								]}
								aria-current={i === 0 ? "true" : undefined}
								aria-label={`Слайд ${i + 1}`}
							>
								{pagination === "dots" ? (
									<span class="block size-2 bg-current" aria-hidden="true" />
								) : pagination === "lines" ? (
									<span class="block h-0.5 w-6 bg-current" aria-hidden="true" />
								) : (
									i + 1
								)}
							</button>
						))}
					</div>
				)}
				<button
					type="button"
					data-hero-next
					class="text-white hover:opacity-90"
					aria-label="Следующий слайд"
				>
					→
				</button>
			</div>
		</section>
	) : (
		<section
			class="relative w-full overflow-hidden bg-[var(--vanilla-green-deep)]"
			aria-labelledby="hero-title"
			data-puck-component-id={id}
			style={paddingStyle}
		>
			<div
				class={`relative w-full ${heroHeightCls}`}
				role="region"
				aria-label="Главный экран"
			>
				<div class="absolute inset-0 z-0 overflow-hidden">
					{singleImage ? (
						<VanillaPicture
							src={singleImage}
							alt=""
							decoding="sync"
							loading="eager"
							fetchpriority="high"
							class="absolute inset-0 z-0 size-full object-cover object-center"
							aria-hidden="true"
						/>
					) : (
						/* Пустое состояние (Figma 1:19335): фото не выбрано → пустой
						   image-rect подложки темы (конвенция пустых rect'ов vanilla —
						   Collections/Gallery/ImageWithText/Video/Slideshow используют
						   bg-[rgb(var(--color-surface,236_235_231))]), без мок-фото героя. */
						<div
							class="absolute inset-0 z-0 size-full bg-[rgb(var(--color-surface,236_235_231))]"
							aria-hidden="true"
						/>
					)}
				</div>
				{hasOverlay ? (
					<div
						class="pointer-events-none absolute inset-0 z-[1] bg-black"
						style={`opacity:${overlayN / 100}`}
						aria-hidden="true"
					/>
				) : singleImage ? (
					<div class="pointer-events-none absolute inset-0 z-[1] bg-black/25" aria-hidden="true" />
				) : (
					/* Лёгкий скрим над пустым image-rect — белая копи-плашка героя
					   (text-heading/255 фоллбек) остаётся читаемой на светлой подложке. */
					<div class="pointer-events-none absolute inset-0 z-[1] bg-black/40" aria-hidden="true" />
				)}

				<div class:list={["vanilla-pad absolute inset-0 z-10 flex h-full w-full pointer-events-none", singleLayout.vItemsCls]}>
					<div class="vanilla-container pointer-events-none">
						<div class={`${singleLayout.copyWrapCls}${heroBoxedCls}`}>
							<h1
								id="hero-title"
								class={singleTitleCls}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="100"
								data-puck-subsection-field="heading"
							>
								{singleTitle}
							</h1>
							<p
								class={singleSubtitleCls}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="101"
								data-puck-subsection-field="text"
							>
								{singleSubtitle}
							</p>
							{secondaryText ? (
								<div class="flex max-w-full flex-row flex-wrap items-center gap-3">
									<a
										class={ctaCls}
										href={singleCtaHref}
										data-puck-subsection-parent={id}
										data-puck-subsection-index="102"
										data-puck-subsection-field="primaryButton"
									>
										{singleCtaText}
									</a>
									<a
										class={secondaryCls}
										href={secondaryHref}
										data-puck-subsection-parent={id}
										data-puck-subsection-index="103"
										data-puck-subsection-field="secondaryButton"
									>
										{secondaryText}
									</a>
								</div>
							) : (
								<a
									class:list={[ctaCls, !singleCtaText && "hidden"]}
									href={singleCtaHref}
									data-puck-subsection-parent={id}
									data-puck-subsection-index="102"
									data-puck-subsection-field="primaryButton"
								>
									{singleCtaText}
								</a>
							)}
						</div>
					</div>
				</div>
			</div>
		</section>
	)
}

<style>
	/** Курсив + line-height ≈ 1 даёт наложение на следующую строку — см. блок выше в комментарии. */
	.vanilla-hero-slide-title {
		line-height: 1.2;
		font-synthesis: none;
		padding-bottom: 0.125em;
	}

	.vanilla-hero-slide-subtitle {
		line-height: 1.35;
		font-synthesis: none;
		text-transform: none;
	}
</style>

<script>
	import { bindVanillaHeroCarousel } from "../../scripts/vanillaHeroCarousel.ts";

	const boot = () =>
		document.querySelectorAll<HTMLElement>("[data-vanilla-hero-carousel]").forEach((el) =>
			bindVanillaHeroCarousel(el),
		);
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", boot, { once: true });
	} else {
		boot();
	}

	document.addEventListener("astro:page-load", boot);
</script>
