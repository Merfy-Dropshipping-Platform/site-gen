---
interface Props {
	name: string;
	image: string;
}

const { name, image } = Astro.props;
---

<article class="flex flex-col gap-[20px]">
	<div class="w-full aspect-[430/319] bg-gray-100 rounded-[8px] overflow-hidden cursor-pointer">
		<img
			src={image}
			alt={name}
			decoding="async"
			class="w-full h-full object-cover"
		/>
	</div>
	<h3 class="text-[16px] font-normal text-black font-manrope leading-[1.366]">
		{name}
	</h3>
</article>
