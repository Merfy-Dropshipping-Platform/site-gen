---
// Catalog — universal block, rendered identically in preview iframe и live
// SSG (modern Puck-driven architecture, parity с home-section блоками).
//
// Build pipeline (scaffold-builder): walks pagesData.page-catalog.content[]
// → generates `pages/page-catalog.astro` with `<Catalog props={...} />` import
// from `theme-base/blocks/Catalog/Catalog.astro`. Same flow как Hero/Collections
// на home — single source of truth.
//
// Preview iframe (preview.service.ts): Astro Container API renders this
// same .astro server-side с inlined inline-script hydration ниже.
//
// Inline-script: при наличии `siteId` фетчит реальные продукты из storefront
// API и replaces placeholder cards. Фильтры (Sort/Stock/Price/Color/Memory)
// и пагинация — vanilla JS state + URL sync.
//
// Legacy note: theme-satin шлёт через templates/astro/satin/src/pages/catalog.astro
// (React CatalogIsland) — единственная тема на старом intercept-pattern.
// flux/rose/bloom/vanilla используют этот файл напрямую.
import type { CatalogProps } from './Catalog.puckConfig';
import { CatalogClasses as C } from './Catalog.classes';
import { parseCatalogUrlParams, type CatalogUrlState } from './url-params';
import { resolveCatalogScope } from './auto-scope';
import { paginateProducts, getPageNumbers, totalPages } from './pagination';
import { getSweaterAsset } from '../../runtime/placeholders';

interface Props extends CatalogProps {
  id?: string;
  siteId?: string;
}

const {
  id,
  padding,
  // 096: editable title/subtitle (Figma flux 905-19049 — «СМАРТФОНЫ» / «M Phone»)
  categoryTitle,
  categorySubtitle,
  categorySubtitleColor,
  subtitle,
  cards = 8,
  columns = 4,
  productCard,
  showFilter,
  filterPosition,
  showSort,
  colorScheme,
  containerColorScheme,
  collectionSlug,
  // Legacy aliases (revisions saved before Figma redesign).
  showCollectionFilter,
  showSidebar,
  // 084 Stage 3 vanilla pilot — additive variants
  gridAspect,
  cardCaptionStyle,
  siteId,
} = Astro.props as Props;

// Pull URL state (initial — vanilla JS hydration will sync on client)
const urlState: CatalogUrlState = parseCatalogUrlParams(Astro.url.searchParams);

// Auto-scope cascade: explicit puck prop > Astro.params.slug > URL query
const routeSlug = (Astro.params as Record<string, string | undefined>)?.slug;
const explicitCollection = typeof collectionSlug === 'string' ? collectionSlug : undefined;
const effectiveCollection = resolveCatalogScope({
  explicitCollectionSlug: explicitCollection,
  routeSlug,
  urlQueryCollection: urlState.collection,
});

const paddingStyle = padding
  ? `padding-top:${padding.top ?? 120}px; padding-bottom:${padding.bottom ?? 120}px;`
  : 'padding-top:120px; padding-bottom:120px;';

const subtitleVisible = subtitle !== 'false' && subtitle !== false;
// Priority new field showFilter; fallback to legacy showSidebar only when
// showFilter is not set (otherwise toggling filters off keeps showing them
// because legacy default 'true' wins).
const filterVisible =
  showFilter !== undefined
    ? showFilter !== 'false' && showFilter !== false
    : showSidebar !== undefined
      ? showSidebar !== 'false' && showSidebar !== false
      : true;
// Каталог = Figma 1-34015: фильтры ВСЕГДА сверху (top-бар), во всех темах/сайтах.
// «Сбоку» (side) прятал фильтры на ширине превью/мобилке (hidden lg:flex) → каталог
// выглядел без фильтров (регресс после blob→секции). Форсим top глобально, не завися
// от filterPosition в ревизии (там у многих сайтов остался legacy 'side').
const filterSide = false;
void filterPosition;
const sortVisible = showSort !== 'false' && showSort !== false;
const collFilterLegacy =
  showCollectionFilter !== 'false' && showCollectionFilter !== false;

const cardCount = Math.max(2, Math.min(24, Number(cards) || 8));
// 098 revised: columns 1-6 без cap к sidebar mode. User: «после 5+ колонок
// не применяется, лимит 4 в ряду». Раньше capped к 4 на filterSide=true —
// теперь user сам решает. Desktop min 2 (1 column layout некрасиво на
// большом экране; mobile media query потом отдельно).
const colCount = Math.max(2, Math.min(6, Number(columns) || 4));
const placeholderCards = Array.from({ length: cardCount });

const cardAspect =
  productCard?.cardStyle === 'square' ? '1 / 1'
  : productCard?.cardStyle === 'wide' ? '4 / 3'
  : '3 / 4';
// 098: padding-bottom % trick для bulletproof aspect-ratio (works в любом
// browser независимо от CSS aspect-ratio support). 3:4 → 133.33%; 1:1 → 100%; 4:3 → 75%
const cardPaddingBottom =
  productCard?.cardStyle === 'square' ? '100%'
  : productCard?.cardStyle === 'wide' ? '75%'
  : '133.33%';

// Card chrome — toggle background/border based on cardBackground.
const cardBgOn =
  productCard?.cardBackground === 'true' || productCard?.cardBackground === true;
// Quick-add button (none / standard / cart).
const quickAddMode = productCard?.quickAdd ?? 'none';
const showQuickAdd = quickAddMode === 'standard' || quickAddMode === 'cart';
const quickAddText = quickAddMode === 'cart' ? 'В КОРЗИНУ' : 'БЫСТРЫЙ ПРОСМОТР';
// Button style affects pill colors.
const btnStyle = productCard?.buttonStyle ?? 'primary';
// User-spec: "Группа товаров" buttons reagируют на Основная кнопка scheme.
// Primary  → button-bg/text/border + button-bg-hover/text-hover
// Secondary → button-secondary-bg/text/border + secondary-bg-hover/text-hover
// Link     → transparent, text scheme
const btnBg = btnStyle === 'primary'
  ? 'rgb(var(--color-button-bg))'
  : btnStyle === 'secondary' ? 'rgb(var(--color-button-secondary-bg))' : 'transparent';
const btnFg = btnStyle === 'primary'
  ? 'rgb(var(--color-button-text))'
  : btnStyle === 'secondary' ? 'rgb(var(--color-button-secondary-text))' : 'rgb(var(--color-text))';
const btnBorder = btnStyle === 'link'
  ? 'none'
  : btnStyle === 'secondary'
    ? '1px solid rgb(var(--color-button-secondary-border))'
    : '1px solid rgb(var(--color-button-border))';
// Hover values для inline-script mouseover handler (style attribute не
// поддерживает :hover — нужен JS swap).
const btnBgHover = btnStyle === 'primary'
  ? 'rgb(var(--color-button-bg-hover))'
  : btnStyle === 'secondary' ? 'rgb(var(--color-button-secondary-bg-hover))' : 'transparent';
const btnFgHover = btnStyle === 'primary'
  ? 'rgb(var(--color-button-text-hover))'
  : btnStyle === 'secondary' ? 'rgb(var(--color-button-secondary-text-hover))' : 'rgb(var(--color-text))';
// Color scheme — apply CSS class so theme tokens swap.
const schemeClass =
  typeof colorScheme === 'string' && colorScheme
    ? `color-scheme-${colorScheme.replace('scheme-', '')}`
    : '';
// Figma 1:34017 — отдельная схема для внутреннего контейнера. Когда не задана —
// используется та же что и у секции (тогда визуально wrapper не отличается).
const containerSchemeClass =
  typeof containerColorScheme === 'string' && containerColorScheme
    ? `color-scheme-${containerColorScheme.replace('scheme-', '')}`
    : '';

// 084 Stage 3 vanilla pilot — additive grid + caption variants.
// Default → empty class (rose/satin/bloom/flux behavior unchanged).
const gridAspectProp =
  gridAspect === '1:1' || gridAspect === '4:5' || gridAspect === 'auto'
    ? gridAspect
    : 'auto';
const gridAspectClass = C.gridAspect[gridAspectProp];

const cardCaptionStyleProp =
  cardCaptionStyle === 'uppercase' ? 'uppercase' : 'default';
const cardCaptionClass = C.cardCaptionStyle[cardCaptionStyleProp];

const apiBase = 'https://gateway.merfy.ru/api';

// 098 SSR-fetch products чтобы preview iframe рендерил real cards в initial
// HTML (без placeholder flash). Mirrors PopularProducts.astro pattern.
type SsrProduct = { id?: string; name?: string; title?: string; slug?: string; handle?: string;
  price?: number | string; basePrice?: number | string; compareAtPrice?: number | string;
  images?: Array<string | { url?: string }>; variants?: unknown[]; isNew?: boolean;
};
let ssrProducts: SsrProduct[] = [];
let ssrCollections: unknown[] = [];
if (siteId) {
  try {
    const internalBase =
      (import.meta as unknown as { env?: { SITES_INTERNAL_BASE?: string } }).env?.SITES_INTERNAL_BASE
      ?? 'http://localhost:3114';
    const ssrRes = await fetch(`${internalBase}/api/sites/${siteId}/storefront-data`).catch(() => null);
    if (ssrRes && ssrRes.ok) {
      const data = (await ssrRes.json()) as { products?: SsrProduct[]; collections?: unknown[] };
      ssrProducts = Array.isArray(data.products) ? data.products : [];
      ssrCollections = Array.isArray(data.collections) ? data.collections : [];
    }
  } catch {
    /* fallback: placeholders */
  }
}
// Slice к cardCount для первой страницы
const initialSlice = ssrProducts.slice(0, cardCount);
// Pure helpers reused в Astro markup
const fmtPriceServer = (n: number | string | undefined): string => {
  const num = typeof n === 'number' ? n : parseFloat(String(n));
  if (!Number.isFinite(num)) return '';
  return Math.round(num).toLocaleString('ru-RU') + ' ₽';
};
---
<section
  class={schemeClass}
  data-puck-component-id={id}
  data-catalog-page
  data-block="catalog"
  data-site-id={siteId}
  data-api-base={apiBase}
  data-collection-slug={collectionSlug}
  data-card-bg={cardBgOn ? 'true' : 'false'}
  data-quick-add={quickAddMode}
  data-next-photo={(productCard?.nextPhoto === 'true' || productCard?.nextPhoto === true) ? 'true' : 'false'}
  data-next-photo-mode={productCard?.nextPhotoMode === 'zones' ? 'zones' : 'simple'}
  style={`background:rgb(var(--color-bg));color:rgb(var(--color-text));${paddingStyle}`}
>
  {/* 098 FIX фильтрация: встраиваем SSR-товары в страницу. Клиентский фетч
      gateway.merfy.ru/storefront-data блокируется CORS в превью-iframe (origin
      sslip.io) → state.allProducts пустой → фильтры не фильтруют. Клиент читает
      эти embedded-данные без cross-origin фетча (работает и в превью, и на live). */}
  <script is:inline set:html={`window.__MERFY_CATALOG_SSR__=${JSON.stringify({ products: ssrProducts, collections: ssrCollections }).replace(/</g, '\\u003c')};`}></script>
  <div
    class={containerSchemeClass}
    style="max-width: 1320px; margin: 0 auto; padding-left: 24px; padding-right: 24px; background: rgb(var(--color-bg)); color: rgb(var(--color-text));"
  >
    <div style="margin-bottom: 24px;">
      <h1
        style="font-size: var(--size-catalog-title, clamp(20px, 3vw, 36px)); font-weight: var(--weight-catalog-title, 400); text-transform: uppercase; line-height: 1.1; color: rgb(var(--color-heading)); margin: 0; font-family: var(--font-heading);"
      >{(() => {
        if (typeof categoryTitle === 'string' && categoryTitle.trim()) return categoryTitle;
        if (categoryTitle && typeof categoryTitle === 'object') {
          const t = (categoryTitle as { text?: string }).text;
          if (typeof t === 'string' && t.trim()) return t;
        }
        return 'КАТАЛОГ';
      })()}</h1>
      {subtitleVisible && (
        <p
          style={`font-size: var(--size-catalog-subtitle, clamp(14px, 1.5vw, 20px)); font-weight: 400; line-height: 1.4; color: rgb(var(${categorySubtitleColor === 'accent' ? '--color-accent' : '--color-muted'})); margin-top: 4px; font-family: var(--font-body);`}
        >{(() => {
          if (typeof categorySubtitle === 'string' && categorySubtitle.trim()) return categorySubtitle;
          if (categorySubtitle && typeof categorySubtitle === 'object') {
            const t = (categorySubtitle as { text?: string }).text;
            if (typeof t === 'string' && t.trim()) return t;
          }
          return 'Здесь начинается персональный стиль';
        })()}</p>
      )}
    </div>

{/* sort is rendered inside sidebar — top-bar sort removed for Figma alignment (905-19049). */}

    {((filterVisible && !filterSide) || (!filterSide && sortVisible)) && (
      <div
        data-catalog-filters-top
        style="display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid rgb(var(--color-text) / 0.1); align-items: center; justify-content: space-between;"
      >
        {filterVisible && !filterSide && (
          <div style="display: flex; flex-wrap: wrap; gap: 24px; align-items: center;">
            {/* Каждый фильтр — инлайн-дропдаун: триггер + панель (position:absolute) с
                РЕАЛЬНЫМИ контролами (те же name/data-атрибуты, что и side-панель,
                поэтому существующая applyFilters-логика подхватывает их через root).
                Top-дропдауны рендерятся только при !filterSide (side-aside тогда нет). */}
            {/* Наличие */}
            <div data-filter-dropdown="stock" style="position: relative;">
              <button type="button" data-filter-toggle="stock" style="background: transparent; border: 0; color: rgb(var(--color-text)); cursor: pointer; font-size: 14px; font-family: var(--font-body); display: inline-flex; align-items: center; gap: 6px; padding: 0;"><span>Наличие</span><span data-filter-chevron style="font-size: 10px; line-height: 1;">▾</span></button>
              <div data-filter-panel data-catalog-stock-filter style="display: none; position: absolute; top: calc(100% + 8px); left: 0; min-width: 180px; flex-direction: column; gap: 4px; padding: 8px; background: rgb(var(--color-bg)); border: 1px solid rgb(var(--color-text) / 0.1); border-radius: var(--radius-input); z-index: 20;">
                <label data-stock-row="all" style="display: flex; align-items: center; justify-content: space-between; padding: 6px 4px; cursor: pointer;">
                  <span style="display: flex; align-items: center; gap: 8px; font-size: 14px;"><input type="radio" name="cat-stock" value="all" checked /> Все</span>
                  <span data-stock-count="all" style="font-size: 14px; color: rgb(var(--color-muted));">0</span>
                </label>
                <label data-stock-row="in" style="display: flex; align-items: center; justify-content: space-between; padding: 6px 4px; cursor: pointer;">
                  <span style="display: flex; align-items: center; gap: 8px; font-size: 14px; color: rgb(var(--color-muted));"><input type="radio" name="cat-stock" value="in" /> В наличии</span>
                  <span data-stock-count="in" style="font-size: 14px; color: rgb(var(--color-muted));">0</span>
                </label>
                <label data-stock-row="out" style="display: flex; align-items: center; justify-content: space-between; padding: 6px 4px; cursor: pointer;">
                  <span style="display: flex; align-items: center; gap: 8px; font-size: 14px; color: rgb(var(--color-muted));"><input type="radio" name="cat-stock" value="out" /> Распродано</span>
                  <span data-stock-count="out" style="font-size: 14px; color: rgb(var(--color-muted));">0</span>
                </label>
              </div>
            </div>
            {/* Стоимость */}
            <div data-filter-dropdown="price" style="position: relative;">
              <button type="button" data-filter-toggle="price" style="background: transparent; border: 0; color: rgb(var(--color-text)); cursor: pointer; font-size: 14px; font-family: var(--font-body); display: inline-flex; align-items: center; gap: 6px; padding: 0;"><span>Стоимость</span><span data-filter-chevron style="font-size: 10px; line-height: 1;">▾</span></button>
              <div data-filter-panel data-catalog-price-filter style="display: none; position: absolute; top: calc(100% + 8px); left: 0; min-width: 200px; flex-direction: row; gap: 8px; padding: 12px; background: rgb(var(--color-bg)); border: 1px solid rgb(var(--color-text) / 0.1); border-radius: var(--radius-input); z-index: 20;">
                <div style="position: relative; flex: 1;">
                  <input type="text" data-cat-price-min placeholder="от" style="width: 100%; height: 44px; padding: 0 28px 0 12px; border: 1px solid rgb(var(--color-text) / 0.1); border-radius: var(--radius-input); background: rgb(var(--color-bg)); color: rgb(var(--color-text)); font-family: var(--font-body); font-size: 14px;" />
                  <span style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: rgb(var(--color-muted)); font-size: 14px;">₽</span>
                </div>
                <div style="position: relative; flex: 1;">
                  <input type="text" data-cat-price-max placeholder="до" style="width: 100%; height: 44px; padding: 0 28px 0 12px; border: 1px solid rgb(var(--color-text) / 0.1); border-radius: var(--radius-input); background: rgb(var(--color-bg)); color: rgb(var(--color-text)); font-family: var(--font-body); font-size: 14px;" />
                  <span style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: rgb(var(--color-muted)); font-size: 14px;">₽</span>
                </div>
              </div>
            </div>
            {/* Цвет — обёртка скрыта (display:none) пока JS не наполнит data-color-options
                и не покажет (мирроль side-логику colorFilterEl.style.display='flex'). */}
            <div data-filter-dropdown="color" style="position: relative; display: none;">
              <button type="button" data-filter-toggle="color" style="background: transparent; border: 0; color: rgb(var(--color-text)); cursor: pointer; font-size: 14px; font-family: var(--font-body); display: inline-flex; align-items: center; gap: 6px; padding: 0;"><span>Цвет</span><span data-filter-chevron style="font-size: 10px; line-height: 1;">▾</span></button>
              <div data-filter-panel data-catalog-color-filter style="display: none; position: absolute; top: calc(100% + 8px); left: 0; min-width: 200px; max-width: 320px; flex-direction: column; gap: 12px; padding: 12px; background: rgb(var(--color-bg)); border: 1px solid rgb(var(--color-text) / 0.1); border-radius: var(--radius-input); z-index: 20;">
                <div data-color-options style="display: flex; flex-wrap: wrap; gap: 8px;"></div>
              </div>
            </div>
            {/* Объём памяти — обёртка скрыта (display:none); JS показывает её только
                когда есть memory-опции (для не-электроники кнопки нет). Мирроль side
                memFilterEl.style.display='flex' при availableMemory.length > 0. */}
            <div data-filter-dropdown="memory" style="position: relative; display: none;">
              <button type="button" data-filter-toggle="memory" style="background: transparent; border: 0; color: rgb(var(--color-text)); cursor: pointer; font-size: 14px; font-family: var(--font-body); display: inline-flex; align-items: center; gap: 6px; padding: 0;"><span>Объём памяти</span><span data-filter-chevron style="font-size: 10px; line-height: 1;">▾</span></button>
              <div data-filter-panel data-catalog-attr-filter="memory" style="display: none; position: absolute; top: calc(100% + 8px); left: 0; min-width: 200px; max-width: 320px; flex-direction: column; gap: 12px; padding: 12px; background: rgb(var(--color-bg)); border: 1px solid rgb(var(--color-text) / 0.1); border-radius: var(--radius-input); z-index: 20;">
                <div data-attr-options="memory" style="display: flex; flex-wrap: wrap; gap: 8px;"></div>
              </div>
            </div>
          </div>
        )}
        {!filterSide && sortVisible && (
          <div data-catalog-sort-dropdown style="position:relative;min-width:200px;">
            <select data-catalog-sort-select style="display:none;" aria-hidden="true">
              <option value="popularity">По популярности</option>
              <option value="newest">По новизне</option>
              <option value="price-asc">По возрастанию цены</option>
              <option value="price-desc">По убыванию цены</option>
            </select>
            <button type="button" data-sort-trigger style="width:100%;height:44px;padding:0 36px 0 12px;border:1px solid rgb(var(--color-text)/0.1);border-radius:var(--radius-input);background:rgb(var(--color-bg));color:rgb(var(--color-text));font-family:var(--font-body);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;text-align:left;"><span data-sort-label>По популярности</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
            <ul data-sort-options style="position:absolute;top:calc(100% + 4px);left:0;right:0;margin:0;padding:4px;list-style:none;background:rgb(var(--color-bg));border:1px solid rgb(var(--color-text)/0.1);border-radius:var(--radius-input);z-index:10;display:none;">
              <li data-sort-option="popularity" style="padding:8px 12px;cursor:pointer;border-radius:calc(var(--radius-input) - 2px);font-family:var(--font-body);font-size:14px;color:rgb(var(--color-text));">По популярности</li>
              <li data-sort-option="newest" style="padding:8px 12px;cursor:pointer;border-radius:calc(var(--radius-input) - 2px);font-family:var(--font-body);font-size:14px;color:rgb(var(--color-text));">По новизне</li>
              <li data-sort-option="price-asc" style="padding:8px 12px;cursor:pointer;border-radius:calc(var(--radius-input) - 2px);font-family:var(--font-body);font-size:14px;color:rgb(var(--color-text));">По возрастанию цены</li>
              <li data-sort-option="price-desc" style="padding:8px 12px;cursor:pointer;border-radius:calc(var(--radius-input) - 2px);font-family:var(--font-body);font-size:14px;color:rgb(var(--color-text));">По убыванию цены</li>
            </ul>
          </div>
        )}
      </div>
    )}

    <button type="button" data-mobile-filter-trigger class={C.mobileTrigger} aria-label="Открыть фильтры">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="6" x2="20" y2="6" /><line x1="4" y1="12" x2="20" y2="12" /><line x1="4" y1="18" x2="20" y2="18" />
      </svg>
      Фильтры
      <span data-mobile-active-dot class={C.mobileTriggerDot} style="display: none;"></span>
    </button>

    <div data-mobile-drawer class={C.mobileDrawer} style="display: none;">
    </div>

    <div
      class={filterSide && (sortVisible || filterVisible) ? 'catalog-grid-with-sidebar' : 'catalog-grid-no-sidebar'}
      style="display: grid; gap: 32px; align-items: start;"
    >
      {/* 098: sidebar показывается если filterSide AND (Sort or Фильтры). */}
      {/* "Скрыть фильтры" в Figma 1:21287 = только filter sections, Sort остаётся */}
      {filterSide && (sortVisible || filterVisible) && (
        <aside
          class:list={['catalog-sidebar', C.sidebarBox]}
          style="flex-direction: column; gap: 24px; font-size: 14px; color: rgb(var(--color-text));"
        >
          {sortVisible && (
            <div data-catalog-sort-wrap style="display: flex; flex-direction: column; gap: 12px;">
              <div style="font-size: 14px; color: rgb(var(--color-text)); font-family: var(--font-body);">Сортировать по:</div>
              <div data-catalog-sort-dropdown style="position:relative;width:100%;">
                <select data-catalog-sort-select style="display:none;" aria-hidden="true">
                  <option value="popularity">По популярности</option>
                  <option value="newest">По новизне</option>
                  <option value="price-asc">По возрастанию цены</option>
                  <option value="price-desc">По убыванию цены</option>
                </select>
                <button type="button" data-sort-trigger style="width:100%;height:44px;padding:0 36px 0 12px;border:1px solid rgb(var(--color-text)/0.1);border-radius:var(--radius-input);background:rgb(var(--color-bg));color:rgb(var(--color-text));font-family:var(--font-body);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;text-align:left;"><span data-sort-label>По популярности</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
                <ul data-sort-options style="position:absolute;top:calc(100% + 4px);left:0;right:0;margin:0;padding:4px;list-style:none;background:rgb(var(--color-bg));border:1px solid rgb(var(--color-text)/0.1);border-radius:var(--radius-input);z-index:10;display:none;">
                  <li data-sort-option="popularity" style="padding:8px 12px;cursor:pointer;border-radius:calc(var(--radius-input) - 2px);font-family:var(--font-body);font-size:14px;color:rgb(var(--color-text));">По популярности</li>
                  <li data-sort-option="newest" style="padding:8px 12px;cursor:pointer;border-radius:calc(var(--radius-input) - 2px);font-family:var(--font-body);font-size:14px;color:rgb(var(--color-text));">По новизне</li>
                  <li data-sort-option="price-asc" style="padding:8px 12px;cursor:pointer;border-radius:calc(var(--radius-input) - 2px);font-family:var(--font-body);font-size:14px;color:rgb(var(--color-text));">По возрастанию цены</li>
                  <li data-sort-option="price-desc" style="padding:8px 12px;cursor:pointer;border-radius:calc(var(--radius-input) - 2px);font-family:var(--font-body);font-size:14px;color:rgb(var(--color-text));">По убыванию цены</li>
                </ul>
              </div>
            </div>
          )}

          {/* 098: filter sections скрываются когда filterVisible=false, Sort остаётся выше */}
          {filterVisible && (
          <>
          {collFilterLegacy && (
            <div data-catalog-collections>
              <div style="font-size: 14px; color: rgb(var(--color-text)); margin-bottom: 12px;">Коллекции</div>
              <label style="display: flex; align-items: center; justify-content: space-between; gap: 8px; padding: 4px 0;">
                <span style="display: flex; align-items: center; gap: 8px;"><input type="radio" name="cat-coll" checked /> Все</span>
              </label>
            </div>
          )}

          <div data-catalog-stock-filter style="display: flex; flex-direction: column; gap: 12px;">
            <div style="font-size: 14px; color: rgb(var(--color-text));">Наличие</div>
            <label data-stock-row="all" style="display: flex; align-items: center; justify-content: space-between; padding: 4px 0; cursor: pointer;">
              <span style="display: flex; align-items: center; gap: 8px; font-size: 14px;"><input type="radio" name="cat-stock" value="all" checked /> Все</span>
              <span data-stock-count="all" style="font-size: 14px; color: rgb(var(--color-muted));">0</span>
            </label>
            <label data-stock-row="in" style="display: flex; align-items: center; justify-content: space-between; padding: 4px 0; cursor: pointer;">
              <span style="display: flex; align-items: center; gap: 8px; font-size: 14px; color: rgb(var(--color-muted));"><input type="radio" name="cat-stock" value="in" /> В наличии</span>
              <span data-stock-count="in" style="font-size: 14px; color: rgb(var(--color-muted));">0</span>
            </label>
            <label data-stock-row="out" style="display: flex; align-items: center; justify-content: space-between; padding: 4px 0; cursor: pointer;">
              <span style="display: flex; align-items: center; gap: 8px; font-size: 14px; color: rgb(var(--color-muted));"><input type="radio" name="cat-stock" value="out" /> Распродано</span>
              <span data-stock-count="out" style="font-size: 14px; color: rgb(var(--color-muted));">0</span>
            </label>
          </div>

          <div data-catalog-price-filter style="display: flex; flex-direction: column; gap: 12px;">
            <div style="font-size: 14px; color: rgb(var(--color-text));">Стоимость</div>
            <div style="position: relative;">
              <input type="text" data-cat-price-min placeholder="от" style="width: 100%; height: 44px; padding: 0 12px; padding-right: 28px; border: 1px solid rgb(var(--color-text) / 0.1); border-radius: 4px; background: rgb(var(--color-bg)); color: rgb(var(--color-text)); font-family: var(--font-body); font-size: 14px;" />
              <span style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: rgb(var(--color-muted)); font-size: 14px;">₽</span>
            </div>
            <div style="position: relative;">
              <input type="text" data-cat-price-max placeholder="до" style="width: 100%; height: 44px; padding: 0 12px; padding-right: 28px; border: 1px solid rgb(var(--color-text) / 0.1); border-radius: 4px; background: rgb(var(--color-bg)); color: rgb(var(--color-text)); font-family: var(--font-body); font-size: 14px;" />
              <span style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: rgb(var(--color-muted)); font-size: 14px;">₽</span>
            </div>
          </div>

          <div data-catalog-color-filter style="display: none; flex-direction: column; gap: 12px;">
            <div style="font-size: 14px; color: rgb(var(--color-text));">Цвет</div>
            <div data-color-options style="display: flex; flex-wrap: wrap; gap: 8px;"></div>
          </div>

          <div data-catalog-attr-filter="memory" style="display: none; flex-direction: column; gap: 12px;">
            <div style="font-size: 14px; color: rgb(var(--color-text));">Объём памяти</div>
            <div data-attr-options="memory" style="display: flex; flex-wrap: wrap; gap: 8px;"></div>
          </div>
          </>
          )}
        </aside>
      )}

      <div
        data-catalog-grid
        data-loading={initialSlice.length === 0 ? 'true' : 'false'}
        style={`display: grid; --catalog-cols: ${colCount}; column-gap: 16px; row-gap: var(--catalog-grid-row-gap, 16px); align-items: stretch;`}
      >
        {initialSlice.length > 0
          ? initialSlice.map((p) => {
              const img0 = Array.isArray(p.images) && p.images[0]
                ? (typeof p.images[0] === 'string' ? p.images[0] : p.images[0].url)
                : '';
              const title = p.title || p.name || '';
              const basePrice = Number(p.basePrice ?? p.price ?? 0);
              const compPrice = Number(p.compareAtPrice ?? 0);
              const handle = p.handle || p.slug || p.id || '';
              return (
                <article data-product-id={p.id} data-product-handle={handle} style={`display:flex;flex-direction:column;gap:16px;${cardBgOn ? 'background:rgb(var(--color-surface,251 251 251));border-radius:12px;padding:12px;' : ''}position:relative;min-width:0;`}>
                  {/* <a> wrapper: и live (window.location), и preview-iframe
                       (preview-nav-agent intercepts → postMessage navigate)
                       работают единообразно. quickAdd button рендерится OTДЕЛЬНО
                       от <a> (button inside anchor = invalid HTML), кликается
                       только сам button благодаря его position:absolute z-1. */}
                  <a href={`/product/${encodeURIComponent(handle)}`} data-product-link style="text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:16px;cursor:pointer;">
                    <div class:list={[gridAspectClass]} style={`position:relative;width:100%;padding-bottom:${cardPaddingBottom};flex-shrink:0;overflow:hidden;border-radius:12px;background:rgb(var(--color-text) / 0.05);`}>
                      {img0 && <img src={img0} alt={title} loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;" />}
                      {compPrice > basePrice && basePrice > 0 && (
                        <div style="position:absolute;top:8px;left:8px;display:flex;flex-direction:column;gap:4px;z-index:1;">
                          <div style="background:rgb(var(--color-button-bg));color:rgb(var(--color-button-text));font-size:14px;font-family:var(--font-body);padding:4px 6px;border-radius:var(--radius-button);line-height:1;">{Math.round((1 - basePrice / compPrice) * 100)}%</div>
                        </div>
                      )}
                    </div>
                    <div style="display:flex;flex-direction:column;gap:4px;">
                      <div class:list={[cardCaptionClass]} style="font-size:16px;font-family:var(--font-body);color:rgb(var(--color-text));overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{title}</div>
                      <div style="font-size:16px;font-family:var(--font-body);color:rgb(var(--color-text));display:flex;gap:8px;align-items:baseline;">
                        <span>{fmtPriceServer(basePrice)}</span>
                        {compPrice > basePrice && <span style="text-decoration:line-through;color:rgb(var(--color-muted));font-size:14px;">{fmtPriceServer(compPrice)}</span>}
                      </div>
                    </div>
                  </a>
                  {showQuickAdd && (
                    <button type="button" data-quick-add-id={p.id} data-btn-bg={btnBg} data-btn-fg={btnFg} data-btn-bg-hover={btnBgHover} data-btn-fg-hover={btnFgHover} style={`width:100%;height:44px;padding:0 12px;border-radius:var(--radius-button);font-size:14px;font-family:var(--font-body);text-transform:uppercase;cursor:pointer;display:flex;align-items:center;justify-content:center;background:${btnBg};color:${btnFg};border:${btnBorder};transition:background-color 0.15s, color 0.15s;${btnStyle === 'link' ? 'text-decoration:underline;background:transparent;' : ''}`}>
                      {quickAddText}
                    </button>
                  )}
                </article>
              );
            })
          : placeholderCards.map((_, idx) => (
              <article data-placeholder="true" style={`display: flex; flex-direction: column; gap: 12px; min-width: 0; ${cardBgOn ? 'background:rgb(var(--color-surface,251 251 251));border-radius:12px;padding:12px;' : ''}`}>
                <div
                  class:list={[gridAspectClass]}
                  style={`position: relative; width: 100%; padding-bottom: ${cardPaddingBottom}; background: rgb(var(--color-muted) / 0.1); border-radius: 12px; overflow: hidden;`}
                >
                  <img src={getSweaterAsset(idx)} alt="Товар" loading="lazy" style="position:absolute;left:20%;top:20%;width:60%;height:60%;object-fit:contain;" />
                </div>
                <div style="display: flex; flex-direction: column; gap: 4px;">
                  <div class:list={[cardCaptionClass]} style="font-size: 14px; color: rgb(var(--color-text));">Товар</div>
                  <div style="font-size: 14px; color: rgb(var(--color-text));">2 500 ₽</div>
                </div>
                {showQuickAdd && (
                  <button
                    type="button"
                    style={`margin-top:4px;padding:8px 12px;border-radius:var(--radius-button);font-size:12px;cursor:pointer;background:${btnBg};color:${btnFg};border:${btnBorder};${btnStyle === 'link' ? 'text-decoration:underline;background:transparent;' : ''}`}
                  >
                    {quickAddText}
                  </button>
                )}
              </article>
            ))
        }
      </div>

      <div data-catalog-pagination class={C.paginationBar} style="display: none;">
        <button type="button" data-page-prev class={C.pageArrow} aria-label="Предыдущая страница">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6 6-6" />
          </svg>
        </button>
        <div data-page-numbers class={C.pageButtons}></div>
        <button type="button" data-page-next class={C.pageArrow} aria-label="Следующая страница">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6-6-6" />
          </svg>
        </button>
        <span data-page-total class={C.paginationCount}>0 товаров</span>
      </div>

      {/* 096: counter под grid (Figma 905-19049 "8 товаров" внизу) */}
      <div data-catalog-count style="margin-top: 24px; text-align: center; color: rgb(var(--color-muted)); font-size: 16px; font-family: var(--font-body); grid-column: 1 / -1;">{cardCount} товаров</div>
    </div>
  </div>
</section>

<style is:inline>
  /* Layout: sidebar OR no-sidebar */
  .catalog-grid-with-sidebar { grid-template-columns: 1fr; }
  .catalog-grid-no-sidebar { grid-template-columns: 1fr; }
  .catalog-sidebar { display: none; }
  /* Tablet/desktop (>= 1024px): show sidebar as fixed column. */
  @media (min-width: 1024px) {
    .catalog-grid-with-sidebar { grid-template-columns: var(--catalog-sidebar-w, 220px) 1fr; }
    .catalog-sidebar { display: flex; }
  }

  /* 098 Mobile responsive product grid.
     Уровни:
     - <640px (mobile): 2 columns (compact, ~150px per card)
     - 640-1023px (tablet): 3 columns (~200px)
     - >=1024px (desktop): user's --cols (1-6 columns)
     User-chosen `columns` стоит на inline style attr через --cols var.
   */
  [data-catalog-grid] {
    grid-template-columns: repeat(2, 1fr) !important;
  }
  @media (min-width: 640px) {
    [data-catalog-grid] {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }
  @media (min-width: 1024px) {
    [data-catalog-grid] {
      grid-template-columns: repeat(var(--catalog-cols, 4), 1fr) !important;
    }
  }
</style>

<script is:inline define:vars={{ siteId, apiBase, cardCount, cardBgOn, btnBg, btnFg, btnBorder, btnStyle, showQuickAdd, quickAddText, effectiveCollection, urlState, cardAspect, gridAspectClass, cardCaptionClass }}>
  // Mirror live storefront in constructor preview: fetch real products and
  // replace placeholder grid with actual cards. Honor productCard.* settings
  // so user changes (cardBackground, buttonStyle, quickAdd, etc) reflect.
  (function () {
    // Resolve effective siteId: explicit prop wins (set by preview controller),
    // fall back to window.__MERFY_CONFIG__.shopId so live SSG pages where the
    // static catalog.astro template doesn't pass siteId still hydrate from the
    // storefront-data API.
    const effectiveSiteId = siteId
      || (typeof window !== 'undefined' && window.__MERFY_CONFIG__ && (window.__MERFY_CONFIG__.shopId || window.__MERFY_CONFIG__.siteId))
      || '';
    if (!effectiveSiteId) return;
    const root = document.querySelector('section[data-block="catalog"]');
    if (!root) return;
    const grid = root.querySelector('[data-catalog-grid]');
    const count = root.querySelector('[data-catalog-count]');
    const collsEl = root.querySelector('[data-catalog-collections]');
    if (!grid) return;

    function fmtPrice(p) {
      const num = typeof p === 'number' ? p : parseFloat(p);
      if (!Number.isFinite(num)) return '';
      const rubles = num > 1000000 ? Math.round(num / 100) : Math.round(num);
      return rubles.toLocaleString('ru-RU') + ' ₽';
    }

    // 096 flux electronics — card chrome via CSS-vars (flux scheme-2 → --color-surface = #fbfbfb)
    const cardChrome = cardBgOn
      ? 'background:rgb(var(--color-surface,251 251 251));border-radius:12px;padding:12px;'
      : '';
    // 096 flux electronics — full-width «В КОРЗИНУ» button (h-44, uppercase, rounded-4).
    const buttonStyle = (
      'width:100%;height:44px;padding:0 12px;border-radius:var(--radius-button);font-size:14px;font-family:var(--font-body);text-transform:uppercase;cursor:pointer;display:flex;align-items:center;justify-content:center;' +
      'background:' + btnBg + ';color:' + btnFg + ';border:' + btnBorder + ';' +
      (btnStyle === 'link' ? 'text-decoration:underline;background:transparent;' : '')
    );

    function escAttr(s) {
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function cardHtml(p) {
      const imgAt = function (idx) {
        return (Array.isArray(p.images) && p.images[idx])
          ? (typeof p.images[idx] === 'string' ? p.images[idx] : p.images[idx].url)
          : '';
      };
      const img = imgAt(0);
      // 098: до 4 images для hover modes (simple uses img2; zones uses up to 4)
      const img2 = imgAt(1);
      const img3 = imgAt(2);
      const img4 = imgAt(3);
      const title = p.title || p.name || '';
      const basePrice = Number(p.basePrice ?? p.price ?? 0);
      const compPrice = Number(p.compareAtPrice ?? 0);
      const price = fmtPrice(basePrice);
      const compare = compPrice > basePrice ? fmtPrice(compPrice) : '';
      const handle = p.handle || p.slug || p.id;
      const imgWrapClassAttr = gridAspectClass ? ' class="' + gridAspectClass + '"' : '';
      // 098: padding-bottom % trick — bulletproof aspect-ratio (works в любом
      // browser, не зависит от CSS aspect-ratio parsing edge cases).
      // Container: position:relative + padding-bottom:X% → height = width * X/100.
      // Image: absolute inset:0 + object-fit:cover → fills container.
      const imgWrapStyle = 'position:relative;width:100%;padding-bottom:' + cardPaddingBottom + ';';
      // 098: data-img-primary/2/3/4 для hover modes ('simple' = img2 swap;
      // 'zones' = Avito-style position-based swap до 4 segments).
      let imgAttrs = 'data-img-primary="' + escAttr(img) + '"';
      if (img2) imgAttrs += ' data-img-secondary="' + escAttr(img2) + '" data-img-2="' + escAttr(img2) + '"';
      if (img3) imgAttrs += ' data-img-3="' + escAttr(img3) + '"';
      if (img4) imgAttrs += ' data-img-4="' + escAttr(img4) + '"';
      // flex-shrink:0 — критично! image area не должна сжиматься/расти в flex column
      // (uniform height только через aspect-ratio container).
      const imgBlock = img
        ? '<div' + imgWrapClassAttr + ' style="' + imgWrapStyle + 'flex-shrink:0;overflow:hidden;border-radius:12px;background:rgb(var(--color-text) / 0.05);">' +
          '<img ' + imgAttrs + ' src="' + escAttr(img) + '" alt="' + escAttr(title) + '" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;transition:opacity 0.2s;" />' +
          '</div>'
        : '<div' + imgWrapClassAttr + ' style="' + imgWrapStyle + 'flex-shrink:0;background:rgb(var(--color-text) / 0.05);border-radius:12px;"></div>';

      // 096: badges (Новинка / -N%) — Figma 905-19049 bg-accent (#fa5109)
      const badges = [];
      if (p.isNew) {
        badges.push('<div style="background:rgb(var(--color-button-bg));color:rgb(var(--color-button-text));font-size:14px;font-family:var(--font-body);padding:4px 6px;border-radius:var(--radius-button);line-height:1;">Новинка</div>');
      }
      if (compPrice > basePrice) {
        const disc = Math.round((1 - basePrice / compPrice) * 100);
        if (disc > 0) badges.push('<div style="background:rgb(var(--color-button-bg));color:rgb(var(--color-button-text));font-size:14px;font-family:var(--font-body);padding:4px 6px;border-radius:var(--radius-button);line-height:1;">' + disc + '%</div>');
      }
      const badgesBlock = badges.length
        ? '<div style="position:absolute;top:8px;left:8px;display:flex;flex-direction:column;gap:4px;z-index:1;">' + badges.join('') + '</div>'
        : '';

      // 096: variant pills (Объём памяти) — Figma 905-19049
      let memPills = '';
      const memNames = ['память', 'memory', 'storage', 'объём памяти', 'размер памяти'];
      if (Array.isArray(p.variants)) {
        const memVals = p.variants
          .filter(function (v) { return memNames.indexOf((v.name || '').toLowerCase().trim()) !== -1; })
          .map(function (v) { return { val: v.value, stock: typeof v.quantity === 'number' ? v.quantity : null }; });
        if (memVals.length > 0) {
          memPills = '<div style="display:flex;gap:4px;flex-wrap:wrap;">' + memVals.map(function (mv) {
            const soldOut = mv.stock === 0;
            const bg = soldOut ? 'rgb(var(--color-muted) / 0.15)' : 'transparent';
            const fg = soldOut ? 'rgb(var(--color-muted))' : 'rgb(var(--color-text))';
            const border = soldOut ? '0' : '1px solid rgb(var(--color-muted) / 0.2)';
            return '<div style="padding:4px;border:' + border + ';border-radius:2px;background:' + bg + ';color:' + fg + ';font-size:12px;font-family:var(--font-body);line-height:1;">' + escAttr(mv.val) + '</div>';
          }).join('') + '</div>';
        }
      }
      // 096: image wrapper с badges-overlay (Figma 905-19049)
      const imgWithBadges = imgBlock.replace('</div>', badgesBlock + '</div>');
      // <a> wrap content (image+title+price) для navigation parity с PopularProducts.
      // quickAdd button — снаружи <a> (button-in-anchor invalid HTML).
      return (
        '<article data-product-id="' + escAttr(p.id) + '" data-product-handle="' + escAttr(handle) + '" style="display:flex;flex-direction:column;gap:16px;' + cardChrome + 'position:relative;min-width:0;">' +
          '<a href="/product/' + encodeURIComponent(handle) + '" data-product-link style="text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:16px;cursor:pointer;">' +
            imgWithBadges +
            '<div style="display:flex;flex-direction:column;gap:4px;">' +
              '<div' + (cardCaptionClass ? ' class="' + cardCaptionClass + '"' : '') + ' style="font-size:16px;font-family:var(--font-body);color:rgb(var(--color-text));overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + escAttr(title) + '</div>' +
              '<div style="font-size:16px;font-family:var(--font-body);color:rgb(var(--color-text));display:flex;gap:8px;align-items:baseline;">' +
                '<span>' + price + '</span>' +
                (compare ? '<span style="text-decoration:line-through;color:rgb(var(--color-muted));font-size:14px;">' + compare + '</span>' : '') +
              '</div>' +
            '</div>' +
            memPills +
          '</a>' +
          (showQuickAdd ? '<button type="button" data-quick-add-id="' + escAttr(p.id) + '" style="' + buttonStyle + '">' + escAttr(quickAddText) + '</button>' : '') +
        '</article>'
      );
    }

    // 096: memory из URL (Figma 905-19049 "Объём памяти" pill filter)
    const memoryRaw = (typeof URLSearchParams !== 'undefined' ? new URLSearchParams(window.location.search).get('memory') : '') || '';
    const memoryFromUrl = memoryRaw ? memoryRaw.split(',').map(function (s) { return s.trim(); }).filter(Boolean) : [];

    // Local state for client-side filter/sort (preview parity with live).
    const state = {
      allProducts: [],
      sort: urlState.sort,
      stock: urlState.availability,  // 'all' | 'in' | 'out'
      priceMin: urlState.priceMin != null ? urlState.priceMin : null,
      priceMax: urlState.priceMax != null ? urlState.priceMax : null,
      collection: effectiveCollection || null,
      page: urlState.page,
      colors: urlState.colors,
      memory: memoryFromUrl,
    };

    function computePageNumbers(current, total) {
      if (total <= 7) {
        var arr = [];
        for (var i = 1; i <= total; i++) arr.push(i);
        return arr;
      }
      if (current <= 3) {
        return [1, 2, 3, 'ellipsis', total];
      }
      if (current >= total - 2) {
        return [1, 'ellipsis', total - 2, total - 1, total];
      }
      return [1, 'ellipsis', current - 1, current, current + 1, 'ellipsis', total];
    }

    function syncUrlState() {
      const params = new URLSearchParams(window.location.search);
      if (state.collection) params.set('collection', state.collection); else params.delete('collection');
      if (state.page > 1) params.set('page', String(state.page)); else params.delete('page');
      if (state.sort && state.sort !== 'newest') params.set('sort', state.sort); else params.delete('sort');
      if (state.stock && state.stock !== 'all') params.set('availability', state.stock); else params.delete('availability');
      if (Array.isArray(state.colors) && state.colors.length > 0) params.set('color', state.colors.join(',')); else params.delete('color');
      if (Array.isArray(state.memory) && state.memory.length > 0) params.set('memory', state.memory.join(',')); else params.delete('memory');
      if (state.priceMin != null) params.set('priceMin', String(state.priceMin)); else params.delete('priceMin');
      if (state.priceMax != null) params.set('priceMax', String(state.priceMax)); else params.delete('priceMax');
      const qs = params.toString();
      const newUrl = window.location.pathname + (qs ? '?' + qs : '') + window.location.hash;
      window.history.replaceState({}, '', newUrl);
    }

    function applyFilters(list) {
      let result = list.slice();
      // Collection filter
      if (state.collection) {
        result = result.filter(function (p) {
          if (!Array.isArray(p.collections)) return false;
          return p.collections.some(function (c) {
            return c && (c.id === state.collection || c.slug === state.collection || c.handle === state.collection);
          });
        });
      }
      // Stock
      if (state.stock === 'in') {
        result = result.filter(function (p) {
          const q = typeof p.quantity === 'number' ? p.quantity : 1;
          return q > 0;
        });
      } else if (state.stock === 'out') {
        result = result.filter(function (p) {
          const q = typeof p.quantity === 'number' ? p.quantity : 1;
          return q <= 0;
        });
      }
      // Color filter (OR semantics — selected color matches if ANY variant matches)
      if (Array.isArray(state.colors) && state.colors.length > 0) {
        result = result.filter(function (p) {
          if (!Array.isArray(p.variants)) return false;
          const productColors = p.variants
            .filter(function (v) { const n = (v.name || '').toLowerCase(); return n === 'цвет' || n === 'color'; })
            .map(function (v) { return v.value; });
          return state.colors.some(function (c) { return productColors.includes(c); });
        });
      }
      // 096: Memory filter (OR semantics, Figma 905-19049 "Объём памяти")
      if (Array.isArray(state.memory) && state.memory.length > 0) {
        const memNames = ['память', 'memory', 'storage', 'объём памяти', 'размер памяти'];
        result = result.filter(function (p) {
          if (!Array.isArray(p.variants)) return false;
          const productMem = p.variants
            .filter(function (v) { return memNames.indexOf((v.name || '').toLowerCase().trim()) !== -1; })
            .map(function (v) { return v.value; });
          return state.memory.some(function (m) { return productMem.indexOf(m) !== -1; });
        });
      }
      // Price range
      if (state.priceMin != null) {
        result = result.filter(function (p) {
          return Number(p.basePrice ?? p.price ?? 0) >= state.priceMin;
        });
      }
      if (state.priceMax != null) {
        result = result.filter(function (p) {
          return Number(p.basePrice ?? p.price ?? 0) <= state.priceMax;
        });
      }
      // Sort
      const priceOf = (p) => Number(p.basePrice ?? p.price ?? 0);
      if (state.sort === 'price-asc') result.sort((a, b) => priceOf(a) - priceOf(b));
      else if (state.sort === 'price-desc') result.sort((a, b) => priceOf(b) - priceOf(a));
      else if (state.sort === 'newest') result.sort((a, b) => String(b.createdAt || '').localeCompare(String(a.createdAt || '')));
      else if (state.sort === 'popularity') result.sort((a, b) => (b.quantity || 0) - (a.quantity || 0));
      return result;
    }

    function rerender() {
      const filtered = applyFilters(state.allProducts);
      const total = filtered.length;
      const ps = cardCount;
      const totalP = total === 0 ? 0 : Math.ceil(total / ps);
      const pageSafe = Math.max(1, Math.min(state.page, Math.max(1, totalP)));
      const slice = filtered.slice((pageSafe - 1) * ps, pageSafe * ps);

      // 096 Figma 905-19049: counter format "{total} товаров" (без "X из Y")
      if (count) count.textContent = total + ' товаров';
      // Заглушки (placeholder свитеры) видны ТОЛЬКО когда total=0. Если есть
      // хотя бы 1 товар — рендерим только реальные карточки, без добивки до cardCount.
      grid.removeAttribute('data-loading');
      if (slice.length) {
        grid.innerHTML = slice.map(cardHtml).join('');
      } else if (total === 0 && state.allProducts.length === 0) {
        // Реально нет товаров → показываем placeholder заглушки (убираем opacity:0).
        grid.querySelectorAll('article[data-placeholder]').forEach(function (a) {
          a.style.opacity = '';
        });
      } else {
        grid.innerHTML = '<div style="grid-column:1/-1;padding:40px;text-align:center;color:rgb(var(--color-muted));">Товары не найдены</div>';
      }

      // Pagination
      const pagination = root.querySelector('[data-catalog-pagination]');
      const pageNumbersEl = root.querySelector('[data-page-numbers]');
      const pageTotalEl = root.querySelector('[data-page-total]');
      const prevBtn = root.querySelector('[data-page-prev]');
      const nextBtn = root.querySelector('[data-page-next]');
      if (pagination) {
        if (totalP <= 1) {
          pagination.style.display = 'none';
        } else {
          pagination.style.display = '';
          if (pageTotalEl) pageTotalEl.textContent = total + ' товаров';
          if (pageNumbersEl) {
            const pages = computePageNumbers(pageSafe, totalP);
            pageNumbersEl.innerHTML = pages.map(function (p) {
              if (p === 'ellipsis') {
                return '<span class="flex items-center justify-center w-10 h-10 sm:w-[60px] sm:h-[60px]" style="color:rgb(var(--color-muted));">...</span>';
              }
              const isActive = p === pageSafe;
              return '<button type="button" data-page="' + p + '" class="flex items-center justify-center w-10 h-10 sm:w-[60px] sm:h-[60px]" style="color:rgb(var(--color-' + (isActive ? 'foreground' : 'muted') + '));cursor:pointer;">' + p + '</button>';
            }).join('');
          }
          if (prevBtn) {
            prevBtn.style.opacity = pageSafe <= 1 ? '0.4' : '1';
            prevBtn.style.cursor = pageSafe <= 1 ? 'not-allowed' : 'pointer';
            prevBtn.disabled = pageSafe <= 1;
          }
          if (nextBtn) {
            nextBtn.style.opacity = pageSafe >= totalP ? '0.4' : '1';
            nextBtn.style.cursor = pageSafe >= totalP ? 'not-allowed' : 'pointer';
            nextBtn.disabled = pageSafe >= totalP;
          }
        }
      }

      updateMobileActiveDot();
      syncMobileDrawer();
    }

    // 096: Sort dropdown (custom div-based для CSS scheme control over
    // selected option — native <select> игнорирует option styling в macOS).
    // Hidden <select> сохранён для backward compat (sort handler читает .value).
    const sortSelect = root.querySelector('[data-catalog-sort-select]');
    if (sortSelect) {
      if (state.sort) sortSelect.value = state.sort;
      sortSelect.addEventListener('change', function () {
        state.sort = this.value || 'newest';
        state.page = 1;
        syncUrlState();
        rerender();
      });
    }

    // Custom dropdown управление: open/close + click-on-option → emit
    // change event на hidden select.
    const sortDropdowns = root.querySelectorAll('[data-catalog-sort-dropdown]');
    function updateSortLabel(dropdown, value) {
      const opt = dropdown.querySelector('[data-sort-option="' + value + '"]');
      if (!opt) return;
      const labelEl = dropdown.querySelector('[data-sort-label]');
      if (labelEl) labelEl.textContent = opt.textContent;
      // Highlight selected option (scheme button-bg/text)
      dropdown.querySelectorAll('[data-sort-option]').forEach(function (o) {
        const isSel = o.getAttribute('data-sort-option') === value;
        o.style.background = isSel ? 'rgb(var(--color-button-bg))' : '';
        o.style.color = isSel ? 'rgb(var(--color-button-text))' : 'rgb(var(--color-text))';
      });
    }
    sortDropdowns.forEach(function (dropdown) {
      const trigger = dropdown.querySelector('[data-sort-trigger]');
      const optionsList = dropdown.querySelector('[data-sort-options]');
      const hidden = dropdown.querySelector('[data-catalog-sort-select]');
      if (!trigger || !optionsList || !hidden) return;
      // Sync initial label with current state.sort
      updateSortLabel(dropdown, state.sort || 'popularity');
      // Toggle on trigger click
      trigger.addEventListener('click', function (e) {
        e.stopPropagation();
        const isOpen = optionsList.style.display === 'block';
        // Close all dropdowns first
        root.querySelectorAll('[data-sort-options]').forEach(function (ol) { ol.style.display = 'none'; });
        if (!isOpen) optionsList.style.display = 'block';
      });
      // Click on option
      optionsList.addEventListener('click', function (e) {
        const li = e.target.closest('[data-sort-option]');
        if (!li) return;
        const value = li.getAttribute('data-sort-option');
        if (!value) return;
        updateSortLabel(dropdown, value);
        // Update hidden select + dispatch change so existing handler fires
        hidden.value = value;
        hidden.dispatchEvent(new Event('change', { bubbles: true }));
        optionsList.style.display = 'none';
      });
      // Hover highlight (без CSS :hover так как inline-style)
      optionsList.addEventListener('mouseover', function (e) {
        const li = e.target.closest('[data-sort-option]');
        if (!li) return;
        const isSel = li.getAttribute('data-sort-option') === hidden.value;
        if (!isSel) li.style.background = 'rgb(var(--color-text)/0.05)';
      });
      optionsList.addEventListener('mouseout', function (e) {
        const li = e.target.closest('[data-sort-option]');
        if (!li) return;
        const isSel = li.getAttribute('data-sort-option') === hidden.value;
        if (!isSel) li.style.background = '';
      });
    });
    // Click outside closes all dropdowns
    document.addEventListener('click', function () {
      root.querySelectorAll('[data-sort-options]').forEach(function (ol) { ol.style.display = 'none'; });
    });

    // Hover handler для quick-add кнопок — inline-style не поддерживает
    // :hover pseudo, поэтому swap через mouseover/mouseout JS.
    // data-btn-bg-hover / data-btn-fg-hover хранят целевые значения.
    function attachHover(scope) {
      scope.querySelectorAll('[data-quick-add-id]').forEach(function (btn) {
        const bgH = btn.getAttribute('data-btn-bg-hover');
        const fgH = btn.getAttribute('data-btn-fg-hover');
        const bg = btn.getAttribute('data-btn-bg');
        const fg = btn.getAttribute('data-btn-fg');
        if (!bgH || !fgH) return;
        btn.addEventListener('mouseover', function () {
          btn.style.background = bgH;
          btn.style.color = fgH;
        });
        btn.addEventListener('mouseout', function () {
          btn.style.background = bg || '';
          btn.style.color = fg || '';
        });
      });
    }
    attachHover(root);
    // FIX: attachSideFilters() была определена (~983), но НИКОГДА не вызывалась →
    // stock-радио и price-инпуты (и top-дропдауны, и side) не слушались → клик по
    // фильтру не фильтровал. Вызываем при гидрации (function declaration hoisted,
    // листенеры вызывают rerender() при изменении). Это первопричина «фильтры не работают».
    attachSideFilters();
    // Re-attach hover после rerender (новые кнопки в DOM).
    // Используем MutationObserver вместо переопределения rerender (что
    // ломает strict-mode function declaration reassignment).
    const gridObserver = new MutationObserver(function () {
      attachHover(root);
    });
    // `grid` уже объявлен ранее в этом IIFE (line 511) — используем ту же
    // переменную чтобы не получить SyntaxError 'Identifier already declared'
    // который ломает весь inline script (quick-add click не attach'ится).
    if (grid) gridObserver.observe(grid, { childList: true, subtree: false });

    // Pagination click handlers
    const paginationEl = root.querySelector('[data-catalog-pagination]');
    if (paginationEl) {
      paginationEl.addEventListener('click', function (ev) {
        const target = ev.target.closest('[data-page], [data-page-prev], [data-page-next]');
        if (!target) return;
        const filtered = applyFilters(state.allProducts);
        const totalP = filtered.length === 0 ? 0 : Math.ceil(filtered.length / cardCount);
        if (target.matches('[data-page-prev]')) {
          state.page = Math.max(1, state.page - 1);
        } else if (target.matches('[data-page-next]')) {
          state.page = Math.min(totalP, state.page + 1);
        } else {
          state.page = parseInt(target.getAttribute('data-page'), 10) || 1;
        }
        syncUrlState();
        rerender();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // Side-bar filters — Figma 905-19049 (stock radios with values + price inputs by data-attr)
    function attachSideFilters() {
      // Stock radios — use value="all|in|out"
      root.querySelectorAll('input[name="cat-stock"]').forEach(function (input) {
        input.addEventListener('change', function () {
          if (!this.checked) return;
          const v = this.value;
          state.stock = (v === 'in' || v === 'out') ? v : 'all';
          state.page = 1;
          syncUrlState();
          rerender();
        });
      });
      // Price inputs (от / до) by data-attribute
      const priceMinEl = root.querySelector('[data-cat-price-min]');
      const priceMaxEl = root.querySelector('[data-cat-price-max]');
      if (priceMinEl) {
        if (state.priceMin != null) priceMinEl.value = String(state.priceMin);
        priceMinEl.addEventListener('input', function () {
          const v = parseFloat(this.value);
          state.priceMin = Number.isFinite(v) ? v : null;
          state.page = 1;
          syncUrlState();
          rerender();
        });
      }
      if (priceMaxEl) {
        if (state.priceMax != null) priceMaxEl.value = String(state.priceMax);
        priceMaxEl.addEventListener('input', function () {
          const v = parseFloat(this.value);
          state.priceMax = Number.isFinite(v) ? v : null;
          state.page = 1;
          syncUrlState();
          rerender();
        });
      }
    }

    // Top-bar filter dropdowns — реальные: клик по триггеру открывает свою
    // панель (с настоящими контролами), закрывает остальные; клик вне — закрывает.
    // Контролы внутри панелей переиспользуют те же name/data-атрибуты, поэтому
    // attachSideFilters/color/memory-логика (scoped к root) уже их обслуживает.
    function closeAllFilterPanels(exceptWrap) {
      root.querySelectorAll('[data-filter-dropdown]').forEach(function (wrap) {
        if (wrap === exceptWrap) return;
        const panel = wrap.querySelector('[data-filter-panel]');
        const chevron = wrap.querySelector('[data-filter-chevron]');
        if (panel) panel.style.display = 'none';
        if (chevron) chevron.textContent = '▾';
      });
    }
    root.querySelectorAll('[data-filter-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        const wrap = btn.closest('[data-filter-dropdown]');
        if (!wrap) return;
        const panel = wrap.querySelector('[data-filter-panel]');
        const chevron = wrap.querySelector('[data-filter-chevron]');
        if (!panel) return;
        const isOpen = panel.style.display !== 'none';
        // Close other filter panels + любые open sort dropdowns.
        closeAllFilterPanels(wrap);
        root.querySelectorAll('[data-sort-options]').forEach(function (ol) { ol.style.display = 'none'; });
        if (isOpen) {
          panel.style.display = 'none';
          if (chevron) chevron.textContent = '▾';
        } else {
          panel.style.display = 'flex';
          if (chevron) chevron.textContent = '▴';
        }
      });
    });
    // Клик вне любого фильтр-дропдауна закрывает все панели.
    document.addEventListener('click', function (e) {
      if (e.target && e.target.closest && e.target.closest('[data-filter-dropdown]')) return;
      closeAllFilterPanels(null);
    });

    // Mobile drawer toggle
    const mobileTrigger = root.querySelector('[data-mobile-filter-trigger]');
    const mobileDrawer = root.querySelector('[data-mobile-drawer]');
    const mobileActiveDot = root.querySelector('[data-mobile-active-dot]');

    if (mobileTrigger && mobileDrawer) {
      mobileTrigger.addEventListener('click', function () {
        const isOpen = mobileDrawer.style.display !== 'none';
        mobileDrawer.style.display = isOpen ? 'none' : 'flex';
      });
    }

    // Update active dot when filters change
    function updateMobileActiveDot() {
      if (!mobileActiveDot) return;
      const hasActive = !!(
        state.collection ||
        state.priceMin != null || state.priceMax != null ||
        (state.stock && state.stock !== 'all') ||
        (Array.isArray(state.colors) && state.colors.length > 0)
      );
      mobileActiveDot.style.display = hasActive ? '' : 'none';
    }

    // Mirror sidebar into mobile drawer (clone DOM after sidebar is hydrated)
    function syncMobileDrawer() {
      if (!mobileDrawer) return;
      const sidebar = root.querySelector('aside');
      if (!sidebar) return;
      mobileDrawer.innerHTML = sidebar.innerHTML;
    }

    // Card navigation теперь через <a data-product-link> wrap (PopularProducts pattern).
    // - Live: native browser nav via <a href>.
    // - Preview iframe: preview-nav-agent.ts intercepts <a> click → postMessage navigate.
    // quickAdd button рендерится снаружи <a> чтобы клик по кнопке не триггерил nav.

    // Quick-add button click
    grid.addEventListener('click', function (ev) {
      const btn = ev.target.closest('button[data-quick-add-id]');
      if (!btn) return;
      ev.preventDefault();
      ev.stopPropagation();
      const productId = btn.getAttribute('data-quick-add-id');
      if (window.cartStore && typeof window.cartStore.addItem === 'function') {
        window.cartStore.addItem(productId, null, 1);
      }
      const orig = btn.textContent;
      btn.textContent = '✓ Добавлено';
      setTimeout(function () { btn.textContent = orig; }, 1500);
    });

    // 098 nextPhoto hover modes:
    // - 'simple': при hover swap img.src на data-img-secondary (single second photo)
    // - 'zones': Avito-style — hovering на разные X-сегменты image swaps to
    //   data-img-2/3/4 (показывает скрытые фото при наведении на правую/центр/левую части)
    var nextPhotoOn = root.getAttribute('data-next-photo') === 'true';
    var nextPhotoMode = root.getAttribute('data-next-photo-mode') || 'simple';
    if (nextPhotoOn && nextPhotoMode === 'zones') {
      grid.addEventListener('mousemove', function (ev) {
        var img = ev.target.closest('img[data-img-primary]');
        if (!img) return;
        var rect = img.getBoundingClientRect();
        var xRel = (ev.clientX - rect.left) / rect.width;
        var keys = ['data-img-primary', 'data-img-2', 'data-img-3', 'data-img-4'];
        var available = keys.filter(function (k) { return img.getAttribute(k); });
        var idx = Math.min(available.length - 1, Math.floor(xRel * available.length));
        if (idx < 0) idx = 0;
        var nextSrc = img.getAttribute(available[idx]);
        if (nextSrc && img.src !== nextSrc) img.src = nextSrc;
      });
      grid.addEventListener('mouseleave', function (ev) {
        var img = ev.target.closest('img[data-img-primary]');
        if (!img) return;
        var prim = img.getAttribute('data-img-primary');
        if (prim && img.src !== prim) img.src = prim;
      }, true);
    } else if (nextPhotoOn) {
      grid.addEventListener('mouseover', function (ev) {
        var img = ev.target.closest('img[data-img-secondary]');
        if (!img) return;
        var sec = img.getAttribute('data-img-secondary');
        if (sec && img.src !== sec) img.src = sec;
      });
      grid.addEventListener('mouseout', function (ev) {
        var img = ev.target.closest('img[data-img-primary]');
        if (!img) return;
        var prim = img.getAttribute('data-img-primary');
        if (prim && img.src !== prim) img.src = prim;
      });
    }

    // 098 FIX: embedded SSR-данные (window.__MERFY_CATALOG_SSR__) — в приоритете
    // над cross-origin фетчем gateway.merfy.ru (CORS-блок в превью). Фолбэк на
    // фетч только если embed пуст.
    const __ssrEmbed = (typeof window !== 'undefined' && window.__MERFY_CATALOG_SSR__) || null;
    const __dataSource = (__ssrEmbed && Array.isArray(__ssrEmbed.products) && __ssrEmbed.products.length)
      ? Promise.resolve(__ssrEmbed)
      : fetch(apiBase + '/sites/' + effectiveSiteId + '/storefront-data', { credentials: 'omit' })
          .catch(() => null)
          .then((r) => r && r.ok ? r.json() : null);
    __dataSource
      .then((data) => {
        if (!data) return;
        const products = data.products || data.data?.products || [];
        const colls = data.collections || data.data?.collections || [];
        // Hydrate collection filter (legacy productIds → state)
        if (state.collection && Array.isArray(colls)) {
          const matchingColl = colls.find(function (c) {
            return c.id === state.collection || c.handle === state.collection || c.slug === state.collection;
          });
          if (matchingColl && Array.isArray(matchingColl.productIds) && matchingColl.productIds.length) {
            const allowed = new Set(matchingColl.productIds);
            products.forEach(function (p) {
              if (allowed.has(p.id) && !Array.isArray(p.collections)) {
                p.collections = [{ id: matchingColl.id, slug: matchingColl.handle }];
              }
            });
          }
        }
        state.allProducts = products;

        // 096: Aggregate variant attributes (color, memory) — Figma 905-19049 pills
        const attrSets = { color: new Set(), memory: new Set() };
        function attrKey(name) {
          const n = (name || '').toLowerCase().trim();
          if (n === 'цвет' || n === 'color') return 'color';
          if (n === 'память' || n === 'memory' || n === 'storage' || n === 'объём памяти' || n === 'размер памяти') return 'memory';
          return null;
        }
        products.forEach(function (p) {
          if (Array.isArray(p.variants)) {
            p.variants.forEach(function (v) {
              const key = attrKey(v.name);
              if (key && v.value) attrSets[key].add(v.value);
            });
          }
          if (Array.isArray(p.variantGroups)) {
            p.variantGroups.forEach(function (g) {
              const key = attrKey(g.name);
              if (!key || !Array.isArray(g.options)) return;
              g.options.forEach(function (o) {
                const val = (o && (o.value || o.label)) || o;
                if (val) attrSets[key].add(val);
              });
            });
          }
        });
        const availableColors = Array.from(attrSets.color);
        const availableMemory = Array.from(attrSets.memory);

        // Pill renderer — Figma 905-19049 style. Active pill использует
        // primary button цвет из scheme; inactive — muted bg + text.
        function pillHtml(val, active, dataAttr) {
          const bg = active ? 'rgb(var(--color-button-bg))' : 'rgb(var(--color-muted) / 0.15)';
          const fg = active ? 'rgb(var(--color-button-text))' : 'rgb(var(--color-text))';
          return '<button type="button" ' + dataAttr + '="' + escAttr(val) + '" style="height:32px;padding:0 8px;border-radius:var(--radius-button);border:0;background:' + bg + ';color:' + fg + ';font-family:var(--font-body);font-size:14px;text-transform:uppercase;cursor:pointer;">' + escAttr(val) + '</button>';
        }

        // Reveal a filter section. Side: el is the section <div> → display:flex.
        // Top: el is the dropdown panel (must stay closed) → reveal its wrapper
        // [data-filter-dropdown] вместо панели, панель открывается toggle'ом.
        function revealFilter(el) {
          if (!el) return;
          const wrap = el.closest('[data-filter-dropdown]');
          if (wrap) wrap.style.display = '';        // top: show trigger wrapper
          else el.style.display = 'flex';           // side: show section inline
        }

        // Render color pills
        const colorFilterEl = root.querySelector('[data-catalog-color-filter]');
        const colorOptionsEl = root.querySelector('[data-color-options]');
        if (colorFilterEl && availableColors.length > 0) {
          revealFilter(colorFilterEl);
          if (colorOptionsEl) {
            colorOptionsEl.innerHTML = availableColors.map(function (c) {
              return pillHtml(c, state.colors.includes(c), 'data-color-value');
            }).join('');
            colorOptionsEl.addEventListener('click', function (ev) {
              const btn = ev.target.closest('[data-color-value]');
              if (!btn) return;
              const val = btn.getAttribute('data-color-value');
              if (state.colors.includes(val)) {
                state.colors = state.colors.filter(function (c) { return c !== val; });
              } else {
                state.colors.push(val);
              }
              state.page = 1;
              syncUrlState();
              // Re-render pills to update active state
              colorOptionsEl.innerHTML = availableColors.map(function (c) {
                return pillHtml(c, state.colors.includes(c), 'data-color-value');
              }).join('');
              rerender();
            });
          }
        }

        // Render memory pills (Figma "Объём памяти")
        const memFilterEl = root.querySelector('[data-catalog-attr-filter="memory"]');
        const memOptionsEl = root.querySelector('[data-attr-options="memory"]');
        if (!state.memory) state.memory = [];
        if (memFilterEl && availableMemory.length > 0) {
          revealFilter(memFilterEl);
          if (memOptionsEl) {
            memOptionsEl.innerHTML = availableMemory.map(function (m) {
              return pillHtml(m, state.memory.includes(m), 'data-memory-value');
            }).join('');
            memOptionsEl.addEventListener('click', function (ev) {
              const btn = ev.target.closest('[data-memory-value]');
              if (!btn) return;
              const val = btn.getAttribute('data-memory-value');
              if (state.memory.includes(val)) {
                state.memory = state.memory.filter(function (m) { return m !== val; });
              } else {
                state.memory.push(val);
              }
              state.page = 1;
              memOptionsEl.innerHTML = availableMemory.map(function (m) {
                return pillHtml(m, state.memory.includes(m), 'data-memory-value');
              }).join('');
              rerender();
            });
          }
        }

        // Stock counts (Figma — N справа от каждого radio)
        function updateStockCounts() {
          const total = products.length;
          let inCount = 0, outCount = 0;
          products.forEach(function (p) {
            const inStock = p.inStock === true || (typeof p.totalStock === 'number' && p.totalStock > 0) || (p.stock && p.stock !== 'out');
            if (inStock) inCount++;
            else outCount++;
          });
          const allEl = root.querySelector('[data-stock-count="all"]');
          const inEl = root.querySelector('[data-stock-count="in"]');
          const outEl = root.querySelector('[data-stock-count="out"]');
          if (allEl) allEl.textContent = String(total);
          if (inEl) inEl.textContent = String(inCount);
          if (outEl) outEl.textContent = String(outCount);
        }
        updateStockCounts();

        if (collsEl && Array.isArray(colls) && colls.length) {
          const items = colls.map(function (c) {
            const checked = c.id === state.collection || c.handle === state.collection ? 'checked' : '';
            return '<label data-coll-id="' + escAttr(c.id) + '" style="display:flex;align-items:center;gap:8px;padding:4px 0;cursor:pointer;"><input type="radio" name="cat-coll" ' + checked + ' /><span>' + escAttr(c.title || c.name || c.handle || c.id) + '</span></label>';
          }).join('');
          collsEl.innerHTML =
            '<div style="font-weight:500;margin-bottom:8px;">Коллекции</div>' +
            '<label data-coll-id="" style="display:flex;align-items:center;gap:8px;padding:4px 0;cursor:pointer;"><input type="radio" name="cat-coll" ' + (state.collection ? '' : 'checked') + ' /><span>Все</span></label>' +
            items;
          collsEl.addEventListener('click', function (ev) {
            const lbl = ev.target.closest('label[data-coll-id]');
            if (!lbl) return;
            state.collection = lbl.getAttribute('data-coll-id') || null;
            state.page = 1;  // reset page on filter/sort change
            syncUrlState();
            rerender();
          });
        }
        attachSideFilters();
        rerender();
      })
      .catch(() => {});

    window.addEventListener('popstate', function () {
      const newParams = new URLSearchParams(window.location.search);
      state.sort = (newParams.get('sort') || 'newest');
      state.stock = (newParams.get('availability') || 'all');
      const pageR = parseInt(newParams.get('page') || '1', 10);
      state.page = (Number.isFinite(pageR) && pageR >= 1) ? pageR : 1;
      state.collection = newParams.get('collection') || null;
      const colorsR = newParams.get('color') || '';
      state.colors = colorsR ? colorsR.split(',').map(function (s) { return s.trim(); }).filter(Boolean) : [];
      const memoryR = newParams.get('memory') || '';
      state.memory = memoryR ? memoryR.split(',').map(function (s) { return s.trim(); }).filter(Boolean) : [];
      const priceMinR = newParams.get('priceMin');
      state.priceMin = priceMinR && Number.isFinite(parseFloat(priceMinR)) ? parseFloat(priceMinR) : null;
      const priceMaxR = newParams.get('priceMax');
      state.priceMax = priceMaxR && Number.isFinite(parseFloat(priceMaxR)) ? parseFloat(priceMaxR) : null;
      rerender();
    });
  })();
</script>
