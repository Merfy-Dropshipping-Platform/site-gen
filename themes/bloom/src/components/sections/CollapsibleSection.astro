---
// Фаза B (bloom, группа misc): новая канон-секция CollapsibleSection в манере
// bloom (см. themes/bloom/MANNER.md; процесс-эталон — rose T16). Схема полей =
// packages/theme-base/blocks/CollapsibleSection/CollapsibleSection.puckConfig.ts.
// Секции нет у верстальщика — нативный <details>/<summary> (Container-safe, без
// JS): заголовок = секционная роль §1 (Urbanist 18/20 uppercase, акцент), вопрос
// Inter 16 400, ответ Inter 16 light muted, разделители = рамка манеры #F5F5F5
// (низ шапки H:49); chevron — /icons/dropdown-chevron.svg с group-open-поворотом
// (tailwind-классы, без <style>-блока).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading: string | { text, alignment, size }; canon-default «Часто
// задаваемые вопросы». Роль = заголовок секции (Collections.astro:18), цвет —
// токен с пиксель-фоллбеком акцента #E38E9F.
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Часто задаваемые вопросы");
// Лестница §9 (база-литерал 18/md:20 = canon-default medium): small 15/17, large 22/24.
const headingSize = p.headingSize ?? p.heading?.size;
const headingSizeCls =
	headingSize === "small"
		? "text-[15px] md:text-[17px]"
		: headingSize === "large"
			? "text-[22px] md:text-[24px]"
			: "text-[18px] md:text-[20px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-urbanist ${headingSizeCls} font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))]${headingAlignCls}`;

// Канон sections[] 1-10 {heading, content} (+ pupa items[] {title, content}).
// Отсутствие = canon-defaults (2 вопроса-болванки). content — set:html (HTML канона).
const CANON_SECTIONS = [
	{
		id: "section-1",
		heading: "Первый вопрос",
		content: "Ответ на первый вопрос. Поддерживается базовое HTML-форматирование.",
	},
	{ id: "section-2", heading: "Второй вопрос", content: "Ответ на второй вопрос." },
];
const rawSections =
	Array.isArray(p.sections) && p.sections.length
		? p.sections
		: Array.isArray(p.items) && p.items.length
			? p.items
			: CANON_SECTIONS;
const sections = rawSections.slice(0, 10).map((s: any) => ({
	heading:
		(typeof s.heading === "string" && s.heading) || (typeof s.title === "string" && s.title) || "",
	content: typeof s.content === "string" ? s.content : "",
}));

// Канон containerEnabled (toggle; legacy container.enabled) — подложка-поверхность
// манеры §4 (surface #F5F5F5, радиус карточки 12px) вокруг списка. Canon-default
// отсутствует → false = голый список.
const containerEnabled = String(p.containerEnabled ?? p.container?.enabled ?? "false") === "true";
// Канон containerColorScheme (hidden) — класс схемы на контейнере.
const containerSchemeCls =
	typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";
const listWrapCls = containerEnabled
	? `rounded-[var(--radius-card,12px)] bg-[rgb(var(--color-surface,245_245_245))] p-6 md:p-10${containerSchemeCls}`
	: containerSchemeCls.trim();

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-20 pt-20 md:px-20 md:pb-[120px] md:pt-[120px] 2xl:px-[300px]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[780px] flex-col gap-10">
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-animate
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}
		<div class={listWrapCls} data-animate data-animate-delay="0.1s">
			<ul class="flex w-full flex-col" role="list">
				{
					sections.map((s, i) => (
						<li
							class="border-b border-solid border-[rgb(var(--color-border,245_245_245))] first:border-t"
							data-puck-subsection-parent={id}
							data-puck-subsection-index={i}
							data-puck-subsection-field="sections"
						>
							<details class="group">
								<summary class="flex w-full cursor-pointer list-none items-center justify-between gap-4 py-5 font-inter text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70 [&::-webkit-details-marker]:hidden">
									<span>{s.heading}</span>
									<img
										src="/icons/dropdown-chevron.svg"
										alt=""
										width="10"
										height="6"
										aria-hidden="true"
										class="shrink-0 transition-transform duration-300 group-open:rotate-180"
									/>
								</summary>
								<div
									class="pb-5 font-inter text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
									set:html={s.content}
								/>
							</details>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
