---
// Фаза B (chrome): новая канон-секция PromoBanner в манере bloom (themes/bloom/MANNER.md §8).
// Схема полей = packages/theme-base/blocks/PromoBanner/PromoBanner.puckConfig.ts:
// text, link {text, href} (+ legacy linkText/linkUrl), size (thin/small/medium/large),
// textTransform (none/uppercase), colorScheme (обёртку даёт композитор), padding {top,bottom}.
// Тело = инлайн-полоса объявления верстальщика (Header.astro:43-47) дословно; в
// канон-композиции Header свою полосу не рендерит (там она только в статик-режиме).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Figma 1:19335 — пустое состояние секции «Панель объявлений»: пока мерчант НЕ
// задал текст объявления, секция показывает ДОСЛОВНЫЙ плейсхолдер на surface-полосе
// («Добавь текст в объявление» + ссылка «Перейти»), а НЕ дефолт-контент верстальщика
// (маркетинг-полосу «Бесплатная доставка…»). PromoBanner — информационная полоса
// (нет товаров/коллекций/картинок для гейта), поэтому единственные «данные» секции —
// сам проп text. Когда text ЗАДАН (мерчант/ревизия/puck-default) — рендер реального
// текста на цветной полосе верстальщика без изменений (эталон rose PromoBanner.astro).
const rawText = typeof p.text === "string" ? p.text.trim() : "";
const hasText = rawText.length > 0;
const text = hasText ? p.text : "";

// Канон link {text, href} + legacy linkText/linkUrl. Подчёркнутый хвост-ссылка —
// в заданном состоянии = НОВЫЙ элемент (у верстальщика инлайн-полоса без ссылки;
// классы хвоста — из header/PromoBanner.astro:17), рендерится ТОЛЬКО при непустом
// link.text. В пустом состоянии label ссылки по умолчанию = «Перейти» (Figma).
const linkText =
	(typeof p.link?.text === "string" && p.link.text.trim() ? p.link.text : undefined) ??
	(typeof p.linkText === "string" && p.linkText.trim() ? p.linkText : undefined);
const placeholderLinkText = linkText ?? "Перейти";
const linkHref =
	p.link?.href ?? p.linkUrl ?? (typeof p.link === "string" ? p.link : undefined) ?? "/";

// Канон «Размер текста» (Figma 648:57318) — меняет И ШРИФТ, И высоту полосы:
//   Маленький: h32 / 12px · Средний: h40 / 14px · Большой: h48 / 16px.
// Дефолт (нет пропа) = large (48/16) — эталон rose PromoBanner.astro SIZE_MAP.
// Высоты — лестница шагом 8px (min-h-8/10/12), текст центрируется флексом; шрифт
// масштабируется (text-[12px]/[14px]/[16px]) и применяется к тексту полосы.
const size = typeof p.size === "string" ? p.size : "large";
const SIZE_MAP: Record<string, { mh: string; text: string }> = {
	small: { mh: "min-h-8", text: "text-[12px]" },
	medium: { mh: "min-h-10", text: "text-[14px]" },
	large: { mh: "min-h-12", text: "text-[16px]" },
};
const sz = SIZE_MAP[size] ?? SIZE_MAP.large;
const rootCls = `flex ${sz.mh} w-full items-center justify-center bg-[rgb(var(--color-bg,227_142_159))] py-2 text-center`;

// Канон textTransform: 'uppercase' (canon-default из blockDefaults) И отсутствие =
// литерал верстальщика uppercase; явный 'none' снимает капс. Размер шрифта (sz.text)
// от «Размер текста».
const textCls =
	p.textTransform === "none"
		? `font-inter ${sz.text} font-normal leading-normal text-[rgb(var(--color-text,255_255_255))]`
		: `font-inter ${sz.text} font-normal uppercase leading-normal text-[rgb(var(--color-text,255_255_255))]`;

// «Отступы» убраны (Figma 648:57318): высоту полосы задаёт ТОЛЬКО «Размер»
// (min-h 32/40/48). padding из ревизии НЕ применяется — иначе старые баннеры
// с padding {12,12} выходят за макетную высоту (полоса толще макета). Эталон rose.
---

{
	hasText ? (
		/* Текст объявления задан мерчантом → цветная полоса верстальщика дословно
		   (классы/токены rootCls + textCls байт-в-байт, поведение не меняется). */
		<div
			class={rootCls}
			role="region"
			aria-live="polite"
			data-bloom-announcement
			data-puck-component-id={id}
		>
			<p
				class={textCls}
				data-puck-subsection-parent={id}
				data-puck-subsection-index="100"
				data-puck-subsection-field="text"
			>
				{text}
				{linkText && (
					<a
						href={linkHref}
						class="ml-1 underline decoration-1 underline-offset-2 transition-opacity hover:opacity-80"
					>
						{linkText}
					</a>
				)}
			</p>
		</div>
	) : (
		/* Пустое состояние (Figma 1:19335): дословный плейсхолдер «Добавь текст в
		   объявление. Перейти» на surface-полосе темы (НЕ цветная полоса верстальщика
		   и НЕ дефолт-акция «Бесплатная доставка…»). Эталон rose PromoBanner.astro. */
		<div
			class="flex min-h-12 w-full items-center justify-center overflow-hidden bg-[rgb(var(--color-surface,245_245_245))] px-4 py-2 text-center md:px-20 xl:px-[300px] 2xl:px-[680px]"
			role="region"
			aria-live="polite"
			data-bloom-announcement
			data-puck-component-id={id}
		>
			<p
				class="max-w-full text-center font-inter text-[12px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))]"
				data-puck-subsection-parent={id}
				data-puck-subsection-index="100"
				data-puck-subsection-field="text"
			>
				<span class="whitespace-pre-wrap">Добавь текст в объявление.</span>{" "}
				<a
					href={linkHref}
					class="underline decoration-1 underline-offset-2 transition-opacity hover:opacity-80"
				>
					{placeholderLinkText}
				</a>
			</p>
		</div>
	)
}
