---
import NtSearchBar from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtSearchBar.astro";
import FluxPicture from "../img/FluxPicture.astro";
import { SITE_TITLE } from "../../consts";

// ОЖИВЛЕНИЕ (Фаза B, контракт bloom Hero): читаем канон-схему theme-base
// Hero.puckConfig и раскладываем по разметке верстальщика. Тело ниже — verbatim;
// значения flux = дефолты (index.astro зовёт <Hero title=... /> легаси-пропсами —
// они поддержаны наравне с nested). Полотно — min-height clamp(500px,80vh,1080px)
// (НЕ aspect-лестница, Hero.astro:29); внизу полотна DS NtSearchBar — render-only
// часть манеры, сохраняется во всех ветках. Анимаций нет (манера flux статична, §6).
const p = Astro.props as Record<string, any>;
const id = p.id;
const nonEmpty = (v: unknown): string | undefined =>
	typeof v === "string" && v.trim() ? v : undefined;
const title = p.heading?.text ?? p.title ?? SITE_TITLE;
const subtitle = p.text?.content ?? p.subtitle ?? "Там, где классика встречается с характером";
const ctaText = p.primaryButton?.text ?? p.cta?.text ?? p.ctaText ?? "В каталог";
const ctaLink =
	p.primaryButton?.link?.href ??
	(typeof p.primaryButton?.link === "string" ? p.primaryButton.link : undefined) ??
	p.cta?.href ??
	p.ctaLink ??
	"#collections";
// Канон backgroundImages (imagePair) / legacy backgroundImage / image.url; пустые
// строки (впрыск коэрсера) не должны ронять фон — фоллбек на литерал верстальщика.
const backgroundImage =
	nonEmpty(p.backgroundImages?.url1) ??
	nonEmpty(p.backgroundImage) ??
	nonEmpty(p.image?.url) ??
	"/images/4x/Главный_экран.png";
// Сплит двух картинок 50/50 ТОЛЬКО когда второе фото задано; иначе одиночный рендер дословно.
const backgroundImage2 = nonEmpty(p.backgroundImages?.url2) ?? nonEmpty(p.backgroundImage2);

// Канон heading.size / text.size (+ секционный p.size как canon-носитель).
// 'large' И отсутствующий проп → ЛИТЕРАЛЬНАЯ лестница верстальщика (MANNER §9):
//   h1    large 32/40/48 → medium 27/34/41 → small 22/28/34 (Comfortaa БЕЗ uppercase)
//   текст large 16/18    → medium 14/15    → small 11/13    (Roboto Flex 300)
// Дефолтная ветка каждого тернарника = прежняя строка классов байт-в-байт
// (цвета → токены с пиксель-фоллбеком родного белого §7).
const headingSize = p.heading?.size ?? p.size;
const headingCls =
	headingSize === "small"
		? "font-comfortaa text-[22px] font-normal leading-[1.115] text-[rgb(var(--color-heading,255_255_255))] md:text-[28px] lg:text-[34px]"
		: headingSize === "medium"
			? "font-comfortaa text-[27px] font-normal leading-[1.115] text-[rgb(var(--color-heading,255_255_255))] md:text-[34px] lg:text-[41px]"
			: "font-comfortaa text-[32px] font-normal leading-[1.115] text-[rgb(var(--color-heading,255_255_255))] md:text-[40px] lg:text-[48px]";
const textSize = p.text?.size ?? p.size;
const subtitleCls =
	textSize === "small"
		? "font-roboto-flex text-[11px] font-light leading-[1.5] text-[rgb(var(--color-text,255_255_255))] md:text-[13px]"
		: textSize === "medium"
			? "font-roboto-flex text-[14px] font-light leading-[1.5] text-[rgb(var(--color-text,255_255_255))] md:text-[15px]"
			: "font-roboto-flex text-[16px] font-light leading-[1.5] text-[rgb(var(--color-text,255_255_255))] md:text-[18px]";

// НЮАНС flux: вторая кнопка «О нас» → #about ЕСТЬ в литерале (Hero.astro:70-75) —
// рендерим ПО УМОЛЧАНИЮ; пустой текст ЗАДАННОГО пропа скрывает (инверсия bloom,
// где secondary — новый элемент). Legacy flat-пропсы aboutText/aboutLink поддержаны.
const secondaryGiven = p.secondaryButton !== undefined && p.secondaryButton !== null;
const secondaryText = secondaryGiven
	? nonEmpty(p.secondaryButton?.text)
	: (nonEmpty(p.aboutText) ?? "О нас");
const secondaryLink =
	p.secondaryButton?.link?.href ??
	(typeof p.secondaryButton?.link === "string" ? p.secondaryButton.link : undefined) ??
	nonEmpty(p.aboutLink) ??
	"#about";

// Канон overlay 0-100 (число или строка) → чёрный слой между фото (z-0) и контентом (z-10).
const overlayN = Math.max(0, Math.min(100, Number(p.overlay) || 0));

// Канон container (toggle «Контейнер» панели «Изображение») — подложка-плашка
// ТОЛЬКО под текстовым блоком, НЕ затемнение всего экрана (overlay отдельно).
// На светлой плашке белый текст flux не читается → переключаем на тёмный схемы.
const boxed = String(p.container ?? "false") === "true";
const boxedCls = boxed
	? " rounded-[var(--radius-card,8px)] bg-[rgb(var(--color-bg,255_255_255))]/95 p-6 shadow-sm md:p-8 [&_h1]:!text-[rgb(var(--color-heading,0_0_0))] [&_p]:!text-[rgb(var(--color-text,0_0_0))]"
	: "";

// Канон position (видимое поле панели) / contentPosition (legacy, те же 9 значений).
// Позиция управляет РАЗМЕЩЕНИЕМ контент-блока по сетке 3×3 (как rose Hero):
//   вертикаль — top / center(=середина) / bottom; горизонталь — left / center / right.
// Выравнивание (alignment) теперь НЕЗАВИСИМО и отвечает только за выравнивание
// КОНТЕНТА внутри блока (заголовок/текст/кнопки), НЕ двигает сам блок.
// Раньше alignment (дефолт center) перебивал горизонталь позиции, а 'center'
// ошибочно не давал середину — это и был баг (см. rose Hero фикс).
//
// СОХРАНЕНИЕ ДЕФОЛТА ВЕРСТАЛЬЩИКА flux: дефолт = position:"left" (defaults/flux.json)
// и пустой проп (легаси-вызов index.astro <Hero title=.../>): оба = контент СЛЕВА
// СВЕРХУ. 'left' — горизонталь-только (нет верт-префикса) → hPos="left", vPos="".
// Пустой vPos у flux = ВЕРХ (justify-start), НЕ низ как у rose; пустой posRaw тоже
// трактуем как left-верх (родная раскладка flux). NtSearchBar — отдельный нижний
// слой, прижат к низу полотна во всех ветках (манера flux сохраняется).
const posRaw =
	typeof p.position === "string" && p.position
		? p.position
		: typeof p.contentPosition === "string"
			? p.contentPosition
			: "";
const vPos = posRaw.startsWith("top")
	? "top"
	: posRaw.startsWith("bottom")
		? "bottom"
		: posRaw === "center" || posRaw.startsWith("center")
			? "middle"
			: ""; // пусто = верх (родной дефолт flux)
const hPos = posRaw.endsWith("left")
	? "left"
	: posRaw.endsWith("right")
		? "right"
		: posRaw === "" // пусто = left (родной дефолт flux, не center как у rose)
			? "left"
			: "center";
// flux: пустой vPos = ВЕРХ (justify-start) вместо низа (rose-дефолт = bottom).
const vJustifyCls = vPos === "top" ? "justify-start" : vPos === "middle" ? "justify-center" : vPos === "bottom" ? "justify-end" : "justify-start";
const hItemsCls = hPos === "left" ? "items-start" : hPos === "right" ? "items-end" : "items-center"; // ПОЗИЦИЯ
// alignment — выравнивание КОНТЕНТА внутри блока (НЕ двигает сам блок — это делает
// Позиция через items на внешнем контейнере). items-* выравнивают заголовок/текст/
// кнопки друг относительно друга, text-align — многострочный текст.
// ВАЖНО flux: дефолт выравнивания (нет пропа alignment) = ВЛЕВО (родная раскладка
// верстальщика — контент у левого края блока), НЕ по центру как у rose. Явные
// alignment center/right двигают контент независимо от позиции.
const align = p.alignment === "center" || p.alignment === "right" ? p.alignment : "left";
const alignItemsCls = align === "right" ? "items-end" : align === "center" ? "items-center" : "items-start"; // ВЫРАВНИВАНИЕ
const textAlignCls = align === "right" ? "text-right" : align === "center" ? "text-center" : "text-left";
const buttonsJustifyCls = align === "right" ? "justify-end" : align === "center" ? "justify-center" : "justify-start";
const contentCls = `flex max-w-[432px] flex-col gap-8 ${alignItemsCls}${boxedCls}`;

// Канон buttonStyle solid|outlined для основной кнопки. solid/отсутствие = белая
// заливка верстальщика с оранжевым текстом дословно (токены кнопки-1 §7: в схемах
// flux кнопка-1 = фирменная); outlined = бордер+текст цвета заливки на прозрачном.
const ctaBtnCls =
	p.buttonStyle === "outlined"
		? "inline-flex h-12 items-center justify-center rounded-[var(--radius-button,6px)] border border-[rgb(var(--color-button-bg,255_255_255))] px-6 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-button-bg,255_255_255))] transition-colors hover:bg-[#FFFFFF]/10 md:text-[16px]"
		: "inline-flex h-12 items-center justify-center rounded-[var(--radius-button,6px)] border border-[rgb(var(--color-button-bg,255_255_255))] bg-[rgb(var(--color-button-bg,255_255_255))] px-6 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-button-text,250_81_9))] transition-opacity hover:opacity-90 md:text-[16px]";
// Вторая кнопка — outlined белая верстальщика на токенах кнопки-2 (паттерн bloom).
const secondaryBtnCls =
	"inline-flex h-12 items-center justify-center rounded-[var(--radius-button,6px)] border border-[rgb(var(--color-button-2-bg,255_255_255))] px-6 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-button-2-bg,255_255_255))] transition-colors hover:bg-[#FFFFFF]/10 md:text-[16px]";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose
// T14 / bloom Hero); добавляется к родному min-height полотна.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
const rootStyle = `min-height: clamp(500px, 80vh, 1080px)${paddingStyle ? `;${paddingStyle}` : ""}`;
---

<section
	class="relative w-full bg-[rgb(var(--color-bg,255_255_255))]"
	style={rootStyle}
	aria-labelledby="hero-title"
	data-puck-component-id={id}
>
	<div class="relative h-full w-full">
		<div
			class="absolute inset-0 z-0 w-full overflow-hidden"
			style="min-height: clamp(500px, 80vh, 1080px)"
		>
			{
				backgroundImage2 ? (
					<div class="absolute inset-0 grid grid-cols-2">
						<FluxPicture
							src={backgroundImage}
							alt={title}
							loading="eager"
							fetchpriority="high"
							class="size-full object-cover object-center"
						/>
						<FluxPicture
							src={backgroundImage2}
							alt=""
							loading="eager"
							fetchpriority="high"
							class="size-full object-cover object-center"
						/>
					</div>
				) : (
					<FluxPicture
						src={backgroundImage}
						alt={title}
						loading="eager"
						fetchpriority="high"
						class="absolute inset-0 size-full object-cover object-center"
					/>
				)
			}
		</div>

		{
			overlayN > 0 && (
				<div
					class="pointer-events-none absolute inset-0 z-[1] bg-black"
					style={`opacity:${overlayN / 100}`}
				/>
			)
		}

		<div
			class={`absolute inset-0 z-10 flex w-full flex-col ${hItemsCls} ${vJustifyCls} px-4 pb-28 pt-32 md:px-20 md:pb-32 md:pt-40 lg:pt-52 2xl:px-80`}
		>
			<div class={contentCls} data-reveal>
				<div class={`flex flex-col gap-2 ${alignItemsCls} ${textAlignCls}`}>
					<h1
						id="hero-title"
						class={headingCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="100"
						data-puck-subsection-field="heading"
					>
						{title}
					</h1>
					<p
						class={subtitleCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="101"
						data-puck-subsection-field="text"
					>
						{subtitle}
					</p>
				</div>

				<div class={`flex flex-wrap gap-3 ${buttonsJustifyCls}`}>
					<a
						href={ctaLink}
						class={ctaBtnCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="102"
						data-puck-subsection-field="primaryButton"
					>
						{ctaText}
					</a>
					{
						secondaryText && (
							<a
								href={secondaryLink}
								class={secondaryBtnCls}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="103"
								data-puck-subsection-field="secondaryButton"
							>
								{secondaryText}
							</a>
						)
					}
				</div>
			</div>
		</div>

		<div
			class="absolute inset-x-0 bottom-0 z-10 flex w-full justify-center px-4 pb-6 md:px-20 md:pb-10 2xl:px-80"
		>
			<div class="w-full max-w-[1320px]">
				<NtSearchBar />
			</div>
		</div>
	</div>
</section>
