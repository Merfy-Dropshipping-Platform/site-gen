{
  "$schema": "https://merfy.ru/schemas/theme-manifest.v2.json",
  "id": "rose",
  "name": "Rose",
  "version": "1.0.0",
  "extends": "@merfy/theme-base@workspace:*",
  "category": "fashion",
  "description": "Elegant rose theme — Merfy flagship storefront template (fashion & lifestyle)",
  "author": "Merfy",
  "tokens": "./tokens.json",

  "defaults": {
    "--font-heading": "'Comfortaa', sans-serif",
    "--font-body": "'Manrope', sans-serif",
    "--weight-heading": "400",
    "--weight-body": "400",
    "--container-max-width": "1320px",
    "--radius-button": "6px",
    "--radius-input": "4px",
    "--radius-card": "8px",
    "--radius-media": "8px",
    "--radius-field": "4px",
    "--size-hero-heading": "32px",
    "--size-hero-button-h": "48px",
    "--size-section-heading": "20px",
    "--size-nav-link": "16px",
    "--size-newsletter-form-w": "430px",
    "--size-logo-width": "120px",
    "--size-card-border": "1px",
    "--spacing-section-y": "120px",
    "--spacing-grid-col-gap": "16px",
    "--spacing-grid-row-gap": "40px",
    "--button-style": "solid",
    "--footer-layout": "3-column",
    "--contact-form-layout": "wide",
    "--cart-type": "drawer",
    "--card-style": "standard",
    "--card-alignment": "left",
    "--text-transform-heading": "uppercase",
    "--color-error": "252 165 165",
    "--color-input-bg": "255 255 255",
    "--color-input-border": "153 153 153",
    "--color-input-label": "153 153 153",
    "--color-input-placeholder": "153 153 153",
    "--color-link": "0 0 0",
    "--color-accent-fg": "255 255 255",
    "--color-accent-2": "58 58 58",
    "--color-border": "153 153 153",
    "--checkout-form-col-w": "652px",
    "--checkout-summary-col-w": "884px",
    "--checkout-gap": "84px",
    "--checkout-side-pad": "300px",
    "--size-checkout-brand": "24px",
    "--size-checkout-brand-image": "32px",
    "--size-h2": "20px",
    "--size-h3": "16px",
    "--size-body": "16px",
    "--size-small": "14px",
    "--size-tiny": "12px"
  },

  "blockDefaults": {
    "Footer": {
      "variant": "3-col"
    }
  },

  "colorSchemes": [
    {
      "id": "scheme-1",
      "name": "1",
      "tokens": {
        "--color-bg": "255 255 255",
        "--color-surface": "245 245 245",
        "--color-heading": "18 18 18",
        "--color-text": "18 18 18",
        "--color-muted": "153 153 153",
        "--color-primary": "0 0 0",
        "--color-accent": "0 0 0",
        "--color-button-bg": "0 0 0",
        "--color-button-text": "255 255 255",
        "--color-button-border": "0 0 0",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "229 231 235"
      }
    },
    {
      "$comment": "Scheme-2 is Light in Figma (sections use white background with dark text). Previous 'Dark' was wrong — all seed sites save scheme-2 for PopularProducts/Collections/ContactForm/Footer and they must stay light.",
      "id": "scheme-2",
      "name": "2",
      "tokens": {
        "--color-bg": "255 255 255",
        "--color-surface": "245 245 245",
        "--color-heading": "18 18 18",
        "--color-text": "18 18 18",
        "--color-muted": "153 153 153",
        "--color-primary": "0 0 0",
        "--color-accent": "0 0 0",
        "--color-button-bg": "0 0 0",
        "--color-button-text": "255 255 255",
        "--color-button-border": "0 0 0",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "229 231 235"
      }
    },
    {
      "id": "scheme-3",
      "name": "3",
      "tokens": {
        "--color-bg": "245 240 235",
        "--color-surface": "230 225 220",
        "--color-heading": "26 26 26",
        "--color-text": "26 26 26",
        "--color-muted": "153 153 153",
        "--color-primary": "0 0 0",
        "--color-accent": "0 0 0",
        "--color-button-bg": "0 0 0",
        "--color-button-text": "245 240 235",
        "--color-button-border": "0 0 0",
        "--color-button-2-bg": "245 240 235",
        "--color-button-2-text": "26 26 26",
        "--color-button-2-border": "220 215 210"
      }
    },
    {
      "id": "scheme-4",
      "name": "4",
      "tokens": {
        "--color-bg": "0 0 0",
        "--color-surface": "26 26 26",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "163 163 163",
        "--color-primary": "255 255 255",
        "--color-accent": "255 255 255",
        "--color-button-bg": "255 255 255",
        "--color-button-text": "0 0 0",
        "--color-button-border": "255 255 255",
        "--color-button-2-bg": "0 0 0",
        "--color-button-2-text": "255 255 255",
        "--color-button-2-border": "51 51 51"
      }
    }
  ],

  "blocks": {
    "Header": {
      "override": {
        "path": "./blocks/Header",
        "reason": "Rose uses 1920px container, 4 logo-position layouts, rose-specific SVG iconography, and scroll-up sticky transform."
      }
    },
    "Footer": {
      "override": {
        "path": "./blocks/Footer",
        "reason": "Rose uses 3-column grid (navigation / information / social) with inline-titled columns and unique social iconography."
      }
    },
    "Hero": { "variant": "overlay" },
    "PopularProducts": {},
    "Collections": {},
    "Product": {},
    "Newsletter": {},
    "ContactForm": {}
  },

  "features": {
    "newsletter": true,
    "cart-drawer": true,
    "otp-auth": true,
    "wishlist": false,
    "color-swatches": true,
    "filter-sidebar": true
  },

  "fonts": [
    { "family": "Comfortaa", "weights": [400, 500, 600, 700], "source": "google" },
    { "family": "Manrope",   "weights": [400, 500, 600, 700], "source": "google" }
  ]
}
