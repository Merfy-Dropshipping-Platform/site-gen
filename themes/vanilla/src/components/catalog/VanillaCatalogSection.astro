---
import VanillaProductCard from "../products/VanillaProductCard.astro";
import VanillaCatalogFilterSidebar from "./VanillaCatalogFilterSidebar.astro";
import { catalogProducts } from "../../data/products";

interface Props {
	section: "textile" | "decor";
	categoryTitle: string;
}

const { section, categoryTitle } = Astro.props;

const isTextile = section === "textile";

const textileFeaturedIds = ["bag-3", "bag-4", "bag-5", "bag-1"] as const;
const decorFeaturedIds = ["bag-2", "bag-6"] as const;

const featuredIds = isTextile ? textileFeaturedIds : decorFeaturedIds;

const displayedProducts = featuredIds
	.map((id) => catalogProducts.find((product) => product.id === id))
	.filter((product): product is (typeof catalogProducts)[number] => Boolean(product));

const totalCount = displayedProducts.length;
const showLoadMore = isTextile;

function pluralizeProducts(count: number): string {
	const mod10 = count % 10;
	const mod100 = count % 100;
	if (mod100 >= 11 && mod100 <= 14) return `${count} товаров`;
	if (mod10 === 1) return `${count} товар`;
	if (mod10 >= 2 && mod10 <= 4) return `${count} товара`;
	return `${count} товаров`;
}

const productCountLabel = pluralizeProducts(totalCount);
---

<section
	class="vanilla-pad w-full bg-[var(--vanilla-surface)] py-16 md:py-20"
	aria-labelledby="catalog-title"
	data-nt="vanilla-catalog-section"
	data-section={section}
>
	<div class="vanilla-container flex flex-col gap-10">
		<header>
			<h1
				id="catalog-title"
				class="font-vanilla-bitter text-[20px] font-normal italic uppercase leading-none tracking-normal text-black"
			>
				{categoryTitle}
			</h1>
		</header>

		<div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:gap-6">
			<VanillaCatalogFilterSidebar class="w-full lg:shrink-0" />

			<div class="flex min-w-0 flex-1 flex-col gap-8">
				<ul class="grid grid-cols-1 gap-x-3 gap-y-9 sm:grid-cols-2 md:gap-x-4 md:gap-y-12" role="list" data-nt="catalog-grid">
					{displayedProducts.map((product, index) => (
						<li data-product-id={product.id}>
							<VanillaProductCard product={product} priority={index < 2} />
						</li>
					))}
				</ul>

				<div
					class:list={[
						"flex flex-col items-stretch gap-4 sm:flex-row sm:items-center",
						showLoadMore ? "sm:justify-between" : "sm:justify-end",
					]}
				>
					{
						showLoadMore && (
							<button
								type="button"
								data-action="load-more"
								class="inline-flex h-12 min-h-12 w-full items-center justify-center bg-[var(--vanilla-header-bg)] px-6 font-vanilla-arsenal text-base font-normal uppercase leading-none text-white transition-opacity hover:opacity-90 sm:w-auto sm:px-16"
							>
								Смотреть ещё
							</button>
						)
					}
					<span class="font-vanilla-arsenal text-base font-normal leading-none text-black" data-nt="catalog-count">
						{productCountLabel}
					</span>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	document.addEventListener("click", (event) => {
		const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-action='load-more']");
		if (!button) return;
		button.disabled = true;
		button.textContent = "Больше товаров нет";
		button.classList.add("opacity-60", "pointer-events-none");
	});
</script>

<script>
	import { hydrateGrid, updateCount } from "../../lib/storefront-hydrate";

	// Реальные товары (Option B): на published-сайте /data/products.json реальный →
	// перерисовываем demo-grid и счётчик. На demo-сборке loadRealProducts() вернёт null → no-op.
	async function hydrateCatalog() {
		const items = await hydrateGrid('[data-nt="catalog-grid"]');
		if (items) updateCount('[data-nt="catalog-count"]', items.length);
	}

	hydrateCatalog();
	document.addEventListener("astro:page-load", hydrateCatalog);
</script>
