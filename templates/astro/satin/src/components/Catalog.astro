---
// Catalog (Satin) — Puck-bound wrapper around CatalogIsland (pupa sidebar+grid+pagination).
// This Astro component is the live-render counterpart for the Puck "Catalog"
// block: see packages/theme-base/blocks/Catalog/Catalog.puckConfig.ts.
//
// Renders the same React island used historically in the hardcoded catalog
// template, but driven by Puck props so the constructor can place / configure /
// remove it like any other block.
import CatalogIsland from './react/CatalogIsland';

interface Props {
  id?: string;
  collectionSlug?: string;
  showCollectionFilter?: boolean | string;
  padding?: { top?: number; bottom?: number };
  colorScheme?: string;
}

const {
  id,
  collectionSlug,
  showCollectionFilter = true,
  padding,
  colorScheme,
} = Astro.props as Props;

const showColl =
  showCollectionFilter === true ||
  showCollectionFilter === 'true' ||
  showCollectionFilter === undefined;

const paddingStyle = padding
  ? `padding-top:${padding.top ?? 0}px; padding-bottom:${padding.bottom ?? 0}px;`
  : '';
const schemeRaw = typeof colorScheme === 'string' ? colorScheme : undefined;
const schemeClass = schemeRaw ? `color-scheme-${schemeRaw.replace('scheme-', '')}` : '';
---
<section
  class:list={['relative w-full bg-[rgb(var(--color-bg))] text-[rgb(var(--color-text))]', schemeClass]}
  data-puck-component-id={id}
  data-block="catalog"
  style={paddingStyle}
>
  <div class="w-full max-w-[var(--container-max-width)] mx-auto px-[40px]">
    <CatalogIsland
      client:only="react"
      collectionSlug={collectionSlug}
      showCollectionFilter={showColl}
    />
  </div>
</section>
