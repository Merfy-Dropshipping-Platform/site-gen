---
import type { PageProps } from './Page.puckConfig';
import { PageClasses as C } from './Page.classes';
import { sanitizePageContent } from './Page.sanitize';

interface Props extends PageProps {
  id?: string;
}

const { id, headingSize, colorScheme, padding } = Astro.props as Props;
const raw = Astro.props as Record<string, unknown>;

// Bound mode (pageId → platform policy content) is resolved at build time:
// the build data-stage injects the policy title/content into heading/content.
// So the render is unified — always heading + content. Defensive reads keep
// legacy/empty/object props crash-safe (never "[object Object]").
const heading = typeof raw.heading === 'string' ? raw.heading.trim() : '';
const rawContent = typeof raw.content === 'string' ? raw.content : '';
// Authoritative XSS gate (Constitution II): sanitize on every render.
const safe = rawContent ? sanitizePageContent(rawContent) : '';

const hSize: 'small' | 'medium' | 'large' =
  headingSize === 'small' || headingSize === 'large' ? headingSize : 'medium';

const schemeClass =
  typeof colorScheme === 'string' && colorScheme
    ? `color-scheme-${colorScheme.replace('scheme-', '')}`
    : '';
const paddingStyle = padding
  ? `padding-top:${padding.top}px;padding-bottom:${padding.bottom}px;`
  : '';
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  style={paddingStyle}
>
  <div class={C.container}>
    <div class={C.column}>
      {/* Heading + content ВСЕГДА рендерятся как inline-editable элементы
          (Spec 101 WYSIWYG прямо в секции). Пустое состояние = пустой
          :empty-элемент → плейсхолдер рисует preview-агент через CSS
          (data-edit-placeholder). На live (без агента) пусто = просто пусто. */}
      <h2
        class:list={[C.heading, C.headingSize[hSize]]}
        data-edit-field="heading"
        data-edit-placeholder="Заголовок"
      >{heading}</h2>
      <div
        class={C.content}
        data-edit-field="content"
        data-edit-placeholder="Текст"
        set:html={safe}
      ></div>
    </div>
  </div>
</section>
