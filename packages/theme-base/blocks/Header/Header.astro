---
import type { HeaderProps } from './Header.puckConfig';
import { HeaderClasses as C } from './Header.classes';
import NavLinkItem from './NavLinkItem.astro';
import MobileMenuItem from './MobileMenuItem.astro';

const MENU_MAX_DEPTH = 3;

interface Props extends HeaderProps {
  id?: string;
}

const {
  id,
  siteTitle = 'Store',
  logo,
  logoPosition = 'top-left',
  stickiness = 'none',
  menuType = 'dropdown',
  navigationLinks = [],
  actionButtons = { showSearch: true, showCart: true, showProfile: true },
  colorScheme,
  padding,
} = Astro.props as Props;
const variant = (Astro.props as Record<string, unknown>).variant as 'standard' | 'two-tier' | undefined;
const isTwoTier = variant === 'two-tier';

// Optional promo strip above header (Figma flux 1:26341). flux opts in via
// theme.json blockDefaults.Header.promoBar.enabled.
const promoBar = (Astro.props as Record<string, unknown>).promoBar as
  | { enabled?: boolean | string; text?: string; linkText?: string; linkHref?: string }
  | undefined;
const promoEnabled = promoBar?.enabled === true || promoBar?.enabled === 'true';
const promoText = (promoBar?.text || '').trim();
const promoLinkText = (promoBar?.linkText || '').trim();
const promoLinkHref = promoBar?.linkHref || '#';

// Clamp padding ≤ 64 чтобы header не растягивался непропорционально
// из legacy revisions (старый default был 80). Slider в sidebar тоже 0..64
// — clamp и slider range совпадают, slider visually meaningful.
const _MAX_HEADER_PAD = 120;
const safePadding = padding
  ? { top: Math.min(padding.top || 0, _MAX_HEADER_PAD), bottom: Math.min(padding.bottom || 0, _MAX_HEADER_PAD) }
  : undefined;
const paddingStyle = safePadding ? `padding-top:${safePadding.top}px; padding-bottom:${safePadding.bottom}px;` : '';
const schemeClass = colorScheme ? `color-scheme-${String(colorScheme).replace('scheme-', '')}` : '';
// Figma constructor sidebar 314:34540 — отдельная схема для блока «Меню».
// Если merchant не выбрал — наследуем основную схему (нет дополнительного wrapper).
const menuColorScheme = (Astro.props as Record<string, unknown>).menuColorScheme as string | undefined;
const menuSchemeClass = menuColorScheme && menuColorScheme !== colorScheme
  ? `color-scheme-${String(menuColorScheme).replace('scheme-', '')}`
  : '';
const isCenterLeft = logoPosition === 'center-left';

// Figma constructor sidebar 314:34540 — поле «Тип меню».
//   - dropdown   (default) — inline nav на desktop, hamburger drawer на mobile.
//   - sidebar              — hamburger всегда (включая desktop), inline nav скрыт.
//   - mega-menu            — inline nav + uppercase tracked + bold links.
// Реализовано через conditional Tailwind classes (без <style> блока, который
// в Astro генерит виртуальный CSS-import → ломает .mjs runtime preview).
const isSidebar = menuType === 'sidebar';
const isMegaMenu = menuType === 'mega-menu';
const navInlineMenuClass = isSidebar ? 'md:!hidden' : '';
const navInlineLinkClass = isMegaMenu ? 'uppercase tracking-[0.06em] font-medium' : '';
const hamburgerOverrideClass = isSidebar ? 'md:!flex' : '';

// Treat the seed default `/logo.svg` as "merchant hasn't set a custom logo"
// and fall through to the styled text logo. The SVG file itself uses
// `fill="currentColor"` but <img> loads SVGs in an isolated context that
// doesn't inherit the parent `color`, so the mark renders black on dark
// schemes. Styled `<span>` matches the constructor's React render, which
// always uses text and honors --color-heading.
const hasCustomLogo = typeof logo === 'string' && logo.length > 0 && logo !== '/logo.svg';
---
<div class:list={[C.wrapper, C.sticky[stickiness], schemeClass]} data-header-wrapper data-header-variant={variant ?? 'standard'} data-puck-component-id={id}>
  {promoEnabled && promoText && (
    <div class="w-full bg-[rgb(var(--color-button-bg))] text-[rgb(var(--color-button-text))]" data-header-promo>
      <div class="flex items-center justify-center px-4 py-[14px] min-h-[48px]">
        <p class="[font-family:var(--font-body)] font-light text-[14px] leading-[20px] uppercase text-[rgb(var(--color-button-text))]">
          <span>{promoText}</span>
          {promoLinkText && (
            <>
              {' '}
              <a href={promoLinkHref} class="underline underline-offset-2 hover:opacity-80 transition-opacity">{promoLinkText}</a>
            </>
          )}
        </p>
      </div>
    </div>
  )}
  <header
    class:list={[C.header, !padding && !isTwoTier && 'min-h-[64px]', isTwoTier && 'border-b-0 py-3 min-h-[64px]']}
    data-menu-type={menuType}
    style={paddingStyle}
  >
    <nav class:list={[C.nav, !isCenterLeft && C.navJustified, isTwoTier && '!max-w-[1320px] !px-4']} aria-label="Primary navigation">

      {/* ============ LAYOUT: top-left (default) ============ */}
      {logoPosition === 'top-left' && (
        <>
          {/* Mobile hamburger — Phase 1c: React island handles menu toggle */}
          <button id="mobile-menu-button" aria-label="Меню" aria-expanded="false" data-hamburger class:list={[C.hamburger, hamburgerOverrideClass]}>
            <svg id="menu-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <path d="M11 17H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M11 23H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class={C.logoWrap['top-left']}>
            <a href="/" class={C.logoLink}>
              {hasCustomLogo ? <img src={logo} alt={siteTitle} class={C.logoImg} /> : <span class={C.logoText}>{siteTitle}</span>}
            </a>
          </div>

          {!isTwoTier && (
            <div data-nav-inline class:list={[C.navMenu, menuSchemeClass, navInlineMenuClass]}>
              {navigationLinks.map((link) => (
                <NavLinkItem link={link} menuType={menuType} maxDepth={MENU_MAX_DEPTH} linkClass={[C.navLink, navInlineLinkClass].filter(Boolean).join(' ')} />
              ))}
            </div>
          )}

          <div class:list={[C.actions, isTwoTier && '!gap-4']}>
            {actionButtons.showSearch && (
              <button type="button" aria-label="Поиск" class:list={[C.actionSearch, isTwoTier && '!w-8 !h-8']} data-action="search">
                <svg class:list={[isTwoTier ? 'w-6 h-6' : 'w-5 h-5 lg:w-6 lg:h-6']} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </button>
            )}
            {actionButtons.showCart && (
              <a href="/cart" id="header-cart-link" class:list={[C.actionCart, isTwoTier && '!w-8 !h-8']} aria-label="Корзина" data-action="cart">
                <svg class:list={[isTwoTier ? 'w-8 h-8' : 'w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 lg:w-10 lg:h-10']} viewBox="0 0 40 40" fill="none" aria-hidden="true">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M18.0295 11.6923C16.8004 11.6923 15.6678 12.3587 15.0708 13.4332C13.8175 15.6892 15.4488 18.4615 18.0295 18.4615H21.9704C24.5511 18.4615 26.1824 15.6892 24.9291 13.4332C24.3321 12.3587 23.1996 11.6923 21.9704 11.6923H18.0295ZM16.6847 14.3298C16.956 13.8414 17.4708 13.5385 18.0295 13.5385H21.9704C22.5291 13.5385 23.0439 13.8414 23.3152 14.3298C23.8849 15.3552 23.1434 16.6154 21.9704 16.6154H18.0295C16.8565 16.6154 16.115 15.3552 16.6847 14.3298Z" fill="currentColor"/>
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M17.2489 8C15.1954 8 13.2924 9.07744 12.2359 10.8383L8.83312 16.5096C8.28797 17.4182 8 18.4579 8 19.5175V26.1538C8 29.3826 10.6174 32 13.8462 32H26.1538C29.3826 32 32 29.3826 32 26.1538V19.5175C32 18.4579 31.712 17.4182 31.1669 16.5096L27.7641 10.8383C26.7076 9.07744 24.8046 8 22.7511 8H17.2489ZM13.819 11.7882C14.5419 10.5833 15.8439 9.84615 17.2489 9.84615H22.7511C24.1561 9.84615 25.4581 10.5833 26.181 11.7882L29.5838 17.4595C29.9568 18.0811 30.1538 18.7925 30.1538 19.5175V26.1538C30.1538 28.363 28.363 30.1538 26.1538 30.1538H13.8462C11.637 30.1538 9.84615 28.363 9.84615 26.1538V19.5175C9.84615 18.7925 10.0432 18.0811 10.4162 17.4595L13.819 11.7882Z" fill="currentColor"/>
                </svg>
                <span id="cart-badge" class={C.cartBadge}>0</span>
              </a>
            )}
            {actionButtons.showProfile && (
              <a href="/login" aria-label="Аккаунт" class:list={[C.actionProfile, isTwoTier && '!w-8 !h-8']} data-action="profile">
                <svg class:list={[isTwoTier ? 'w-6 h-6' : 'w-5 h-5 lg:w-6 lg:h-6']} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </a>
            )}
          </div>
        </>
      )}

      {/* ============ LAYOUT: center-absolute (084 vanilla pilot) ============ */}
      {/* Vanilla home: 3-col [hamburger | absolute-centered logo | actions]. */}
      {/* Reuses top-center markup but swaps logoWrap class to absolute-pin. */}
      {logoPosition === 'center-absolute' && (
        <>
          <button id="mobile-menu-button" aria-label="Меню" aria-expanded="false" data-hamburger class:list={[C.hamburger, hamburgerOverrideClass]}>
            <svg id="menu-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <path d="M11 17H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M11 23H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {!isTwoTier && (
            <div data-nav-inline class:list={[C.navMenu, menuSchemeClass, navInlineMenuClass]}>
              {navigationLinks.map((link) => (
                <NavLinkItem link={link} menuType={menuType} maxDepth={MENU_MAX_DEPTH} linkClass={[C.navLink, navInlineLinkClass].filter(Boolean).join(' ')} />
              ))}
            </div>
          )}

          <div class={C.logoWrap['center-absolute']}>
            <a href="/" class={C.logoLink}>
              {hasCustomLogo ? <img src={logo} alt={siteTitle} class={C.logoImg} /> : <span class={C.logoText}>{siteTitle}</span>}
            </a>
          </div>

          <div class={C.actions}>
            {actionButtons.showSearch && (
              <button type="button" aria-label="Поиск" class={C.actionSearch} data-action="search">
                <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </button>
            )}
            {actionButtons.showCart && (
              <a href="/cart" class={C.actionCart} aria-label="Корзина" data-action="cart">
                <svg class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 lg:w-10 lg:h-10" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M18.0295 11.6923C16.8004 11.6923 15.6678 12.3587 15.0708 13.4332C13.8175 15.6892 15.4488 18.4615 18.0295 18.4615H21.9704C24.5511 18.4615 26.1824 15.6892 24.9291 13.4332C24.3321 12.3587 23.1996 11.6923 21.9704 11.6923H18.0295Z" fill="currentColor"/>
                </svg>
                <span class={C.cartBadge}>0</span>
              </a>
            )}
            {actionButtons.showProfile && (
              <a href="/login" aria-label="Аккаунт" class={C.actionProfile} data-action="profile">
                <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </a>
            )}
          </div>
        </>
      )}

      {/* ============ LAYOUT: top-center ============ */}
      {logoPosition === 'top-center' && (
        <>
          <button id="mobile-menu-button" aria-label="Меню" aria-expanded="false" data-hamburger class:list={[C.hamburger, hamburgerOverrideClass]}>
            <svg id="menu-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <path d="M11 17H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M11 23H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {!isTwoTier && (
            <div data-nav-inline class:list={[C.navMenu, menuSchemeClass, navInlineMenuClass]}>
              {navigationLinks.map((link) => (
                <NavLinkItem link={link} menuType={menuType} maxDepth={MENU_MAX_DEPTH} linkClass={[C.navLink, navInlineLinkClass].filter(Boolean).join(' ')} />
              ))}
            </div>
          )}

          <div class={C.logoWrap['top-center']}>
            <a href="/" class={C.logoLink}>
              {hasCustomLogo ? <img src={logo} alt={siteTitle} class={C.logoImg} /> : <span class={C.logoText}>{siteTitle}</span>}
            </a>
          </div>

          <div class={C.actions}>
            {actionButtons.showSearch && (
              <button type="button" aria-label="Поиск" class={C.actionSearch} data-action="search">
                <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </button>
            )}
            {actionButtons.showCart && (
              <a href="/cart" class={C.actionCart} aria-label="Корзина" data-action="cart">
                <svg class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 lg:w-10 lg:h-10" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M18.0295 11.6923C16.8004 11.6923 15.6678 12.3587 15.0708 13.4332C13.8175 15.6892 15.4488 18.4615 18.0295 18.4615H21.9704C24.5511 18.4615 26.1824 15.6892 24.9291 13.4332C24.3321 12.3587 23.1996 11.6923 21.9704 11.6923H18.0295Z" fill="currentColor"/>
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M17.2489 8C15.1954 8 13.2924 9.07744 12.2359 10.8383L8.83312 16.5096C8.28797 17.4182 8 18.4579 8 19.5175V26.1538C8 29.3826 10.6174 32 13.8462 32H26.1538C29.3826 32 32 29.3826 32 26.1538V19.5175C32 18.4579 31.712 17.4182 31.1669 16.5096L27.7641 10.8383C26.7076 9.07744 24.8046 8 22.7511 8H17.2489Z" fill="currentColor"/>
                </svg>
                <span class={C.cartBadge}>0</span>
              </a>
            )}
            {actionButtons.showProfile && (
              <a href="/login" aria-label="Аккаунт" class={C.actionProfile} data-action="profile">
                <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </a>
            )}
          </div>
        </>
      )}

      {/* ============ LAYOUT: top-right ============ */}
      {logoPosition === 'top-right' && (
        <>
          <button id="mobile-menu-button" aria-label="Меню" aria-expanded="false" data-hamburger class:list={[C.hamburger, hamburgerOverrideClass]}>
            <svg id="menu-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <path d="M11 17H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M11 23H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {!isTwoTier && (
            <div data-nav-inline class:list={[C.navMenu, menuSchemeClass, navInlineMenuClass]}>
              {navigationLinks.map((link) => (
                <NavLinkItem link={link} menuType={menuType} maxDepth={MENU_MAX_DEPTH} linkClass={[C.navLink, navInlineLinkClass].filter(Boolean).join(' ')} />
              ))}
            </div>
          )}

          <div class={C.actions}>
            {actionButtons.showSearch && (
              <button type="button" aria-label="Поиск" class={C.actionSearch} data-action="search">
                <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </button>
            )}
            {actionButtons.showCart && (
              <a href="/cart" class={C.actionCart} aria-label="Корзина" data-action="cart">
                <svg class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 lg:w-10 lg:h-10" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M18.0295 11.6923C16.8004 11.6923 15.6678 12.3587 15.0708 13.4332C13.8175 15.6892 15.4488 18.4615 18.0295 18.4615H21.9704C24.5511 18.4615 26.1824 15.6892 24.9291 13.4332C24.3321 12.3587 23.1996 11.6923 21.9704 11.6923H18.0295Z" fill="currentColor"/>
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M17.2489 8C15.1954 8 13.2924 9.07744 12.2359 10.8383L8.83312 16.5096C8.28797 17.4182 8 18.4579 8 19.5175V26.1538C8 29.3826 10.6174 32 13.8462 32H26.1538C29.3826 32 32 29.3826 32 26.1538V19.5175C32 18.4579 31.712 17.4182 31.1669 16.5096L27.7641 10.8383C26.7076 9.07744 24.8046 8 22.7511 8H17.2489Z" fill="currentColor"/>
                </svg>
                <span class={C.cartBadge}>0</span>
              </a>
            )}
            {actionButtons.showProfile && (
              <a href="/login" aria-label="Аккаунт" class={C.actionProfile} data-action="profile">
                <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </a>
            )}
          </div>

          <div class={C.logoWrap['top-right']}>
            <a href="/" class={C.logoLink}>
              {hasCustomLogo ? <img src={logo} alt={siteTitle} class={C.logoImg} /> : <span class={C.logoText}>{siteTitle}</span>}
            </a>
          </div>
        </>
      )}

      {/* ============ LAYOUT: center-left (two rows) ============ */}
      {logoPosition === 'center-left' && (
        <div class="flex flex-col w-full">
          <div class="flex items-center justify-between w-full">
            <button id="mobile-menu-button" aria-label="Меню" aria-expanded="false" data-hamburger class:list={[C.hamburger, hamburgerOverrideClass]}>
              <svg id="menu-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                <path d="M11 17H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M11 23H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <a href="/" class={C.logoLink}>
              {hasCustomLogo ? <img src={logo} alt={siteTitle} class={C.logoImg} /> : <span class={C.logoText}>{siteTitle}</span>}
            </a>

            <div class={C.actions}>
              {actionButtons.showSearch && (
                <button type="button" aria-label="Поиск" class={C.actionSearch} data-action="search">
                  <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                  </svg>
                </button>
              )}
              {actionButtons.showCart && (
                <a href="/cart" class={C.actionCart} aria-label="Корзина" data-action="cart">
                  <svg class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 lg:w-10 lg:h-10" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M18.0295 11.6923C16.8004 11.6923 15.6678 12.3587 15.0708 13.4332C13.8175 15.6892 15.4488 18.4615 18.0295 18.4615H21.9704C24.5511 18.4615 26.1824 15.6892 24.9291 13.4332C24.3321 12.3587 23.1996 11.6923 21.9704 11.6923H18.0295Z" fill="currentColor"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M17.2489 8C15.1954 8 13.2924 9.07744 12.2359 10.8383L8.83312 16.5096C8.28797 17.4182 8 18.4579 8 19.5175V26.1538C8 29.3826 10.6174 32 13.8462 32H26.1538C29.3826 32 32 29.3826 32 26.1538V19.5175C32 18.4579 31.712 17.4182 31.1669 16.5096L27.7641 10.8383C26.7076 9.07744 24.8046 8 22.7511 8H17.2489Z" fill="currentColor"/>
                  </svg>
                  <span class={C.cartBadge}>0</span>
                </a>
              )}
              {actionButtons.showProfile && (
                <a href="/login" aria-label="Аккаунт" class={C.actionProfile} data-action="profile">
                  <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                </a>
              )}
            </div>
          </div>

          {!isTwoTier && (
            <div data-nav-inline class:list={[C.navMenuCentered, menuSchemeClass, navInlineMenuClass]}>
              {navigationLinks.map((link) => (
                <NavLinkItem link={link} menuType={menuType} maxDepth={MENU_MAX_DEPTH} linkClass={[C.navLink, navInlineLinkClass].filter(Boolean).join(' ')} />
              ))}
            </div>
          )}
        </div>
      )}
    </nav>
  </header>

  {/* Two-tier secondary nav row (Figma flux 1:26327). Все классы используют
       theme tokens — шрифт/вес/размер настраиваются через ThemeSettingsPanel
       в конструкторе (Типографика). */}
  {isTwoTier && !isSidebar && navigationLinks.length > 0 && (
    <div data-nav-inline class="hidden md:block w-full">
      <nav class="w-full max-w-[1320px] mx-auto px-4 flex items-center justify-start gap-8 h-6 mt-5" aria-label="Secondary navigation">
        {navigationLinks.map((link, idx) => (
          <NavLinkItem
            link={link}
            menuType={menuType}
            maxDepth={MENU_MAX_DEPTH}
            linkClass={'[font-family:var(--font-body)] text-[length:var(--size-nav-link)] leading-none text-[rgb(var(--color-muted))] hover:text-[rgb(var(--color-text))] transition-colors'}
          />
        ))}
      </nav>
    </div>
  )}

  {/* ============ Mobile navigation menu — Phase 1c: React island will drive show/hide ============ */}
  <div id="mobile-menu" data-mobile-menu class={C.mobileMenu.root}>
    <nav class={C.mobileMenu.nav} aria-label="Мобильная навигация">
      {actionButtons.showSearch && (
        <div class={C.mobileMenu.search}>
          <div class="relative">
            <input type="search" placeholder="Поиск..." class={C.mobileMenu.searchInput} />
            <button class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5" aria-label="Искать">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </button>
          </div>
        </div>
      )}
      <div class="flex flex-col">
        {navigationLinks.map((link) => (
          <MobileMenuItem link={link} level={1} maxDepth={MENU_MAX_DEPTH} />
        ))}
      </div>
      {actionButtons.showProfile && (
        <a href="/login" class={C.mobileMenu.link} data-action="profile">Войти</a>
      )}
    </nav>
  </div>

  {/* Phase 1c: React island handles — mobile menu toggle, submenu expand, scroll-up stickiness, cart badge, cart-store integration */}
</div>

<script is:inline>
  // Vanilla burger-menu toggle for preview iframe (where the React island
  // doesn't run). Live SSG sites bundle the React island so this script
  // double-binds harmlessly. NB: do NOT add a <style> block to this .astro
  // file — Astro compiler bakes an absolute dev-machine path into the
  // .mjs which then ENOENT-fails at runtime on Linux Docker images.
  // Use inline style.display toggle instead of CSS rule.
  (function () {
    document.querySelectorAll('#mobile-menu-button').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        const wrap = btn.closest('[data-header-wrapper]');
        const panel = wrap ? wrap.querySelector('[data-mobile-menu]') : null;
        if (panel) panel.style.display = expanded ? 'none' : 'block';
      });
    });

    // Desktop NavLinkItem submenu touch-toggle. На touch-устройствах
    // (`(hover: none)`) hover не работает — click на link с submenu
    // toggle'ит `data-open` на host; CSS variant `data-[open=true]:flex`
    // показывает submenu без hover. Desktop поведение (hover) не
    // изменяется.
    const isTouch = window.matchMedia('(hover: none)').matches;
    if (isTouch) {
      // Touch: click toggle.
      document.querySelectorAll('[data-submenu-trigger]').forEach(function (trigger) {
        trigger.addEventListener('click', function (e) {
          const host = trigger.closest('[data-submenu-host]');
          if (!host) return;
          const isOpen = host.getAttribute('data-open') === 'true';
          document.querySelectorAll('[data-submenu-host][data-open="true"]').forEach(function (h) {
            if (h !== host) h.setAttribute('data-open', 'false');
          });
          if (!isOpen) {
            e.preventDefault();
            host.setAttribute('data-open', 'true');
          }
        });
      });
      document.addEventListener('click', function (e) {
        if (!(e.target instanceof Element)) return;
        if (e.target.closest('[data-submenu-host]')) return;
        document.querySelectorAll('[data-submenu-host][data-open="true"]').forEach(function (h) {
          h.setAttribute('data-open', 'false');
        });
      });
    }
    // Desktop hover handled by inline-bridge in preview.service.ts (preview iframe)
    // and by React island Header.client.tsx (live SSG). Не дублируем здесь —
    // иначе два независимых обработчика дребезжат state на mouseover/mouseout.

    // Mobile drawer recursive accordion: каждая [data-mobile-toggle] кнопка
    // toggle'ит ближайший [data-mobile-submenu] sibling. Работает для любого
    // уровня вложенности (1/2/3+).
    document.querySelectorAll('[data-mobile-toggle]').forEach(function (toggle) {
      toggle.addEventListener('click', function () {
        const submenu = toggle.nextElementSibling;
        if (!submenu || !submenu.matches('[data-mobile-submenu]')) return;
        const wasHidden = submenu.classList.contains('hidden');
        submenu.classList.toggle('hidden');
        toggle.setAttribute('aria-expanded', wasHidden ? 'true' : 'false');
        const arrow = toggle.querySelector('.mobile-submenu-arrow');
        if (arrow) {
          arrow.style.transform = wasHidden ? 'rotate(180deg)' : '';
        }
      });
    });

    // Cart icon click — читает --cart-type из :root.
    // 'drawer' → preventDefault + window.cartDrawer.open() (drawer mode)
    // 'page' (или unset) → нативная навигация на /cart (page mode)
    // Theme Settings → Корзина (Сайдбар/Страница) меняет --cart-type через
    // CSS-var в iframe head; этот обработчик читает live значение на click.
    document.querySelectorAll('a[data-action="cart"]').forEach(function (cartLink) {
      cartLink.addEventListener('click', function (e) {
        var cartType = getComputedStyle(document.documentElement)
          .getPropertyValue('--cart-type')
          .trim()
          .replace(/['"]/g, '');
        if (cartType !== 'drawer') return; // page mode — let nav happen
        if (!window.cartDrawer || typeof window.cartDrawer.open !== 'function') return;
        e.preventDefault();
        window.cartDrawer.open();
      });
    });
  })();
</script>

