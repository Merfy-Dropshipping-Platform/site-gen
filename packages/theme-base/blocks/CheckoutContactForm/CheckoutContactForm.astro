---
// CheckoutContactForm — vanilla Astro + inline script (без React island).
// Floating-label pattern: label по центру при empty+blur, наверх при focus/value.
// Phone format: для phoneFormat="ru" — маска +7 (XXX) XXX-XX-XX.
import type { CheckoutContactFormProps } from './CheckoutContactForm.puckConfig';
import { CheckoutContactFormClasses as C } from './CheckoutContactForm.classes';

interface Props extends CheckoutContactFormProps { id?: string; }
const {
  id,
  heading,
  showAuthLink,
  authLinkText,
  authLinkHref,
  emailLabel,
  phoneLabel,
  phoneFormat,
  padding,
} = Astro.props as Props;
const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
---
<section
  class={C.root}
  data-puck-component-id={id}
  data-checkout-contact
  style={paddingStyle}
>
  <h2 class={C.heading}>
    <span>{heading}</span>
    {showAuthLink && <a href={authLinkHref} class={C.authLink}>{authLinkText}</a>}
  </h2>
  <div class={C.fields}>
    <div class={C.field} data-checkout-field="email">
      <input
        class={C.input}
        id="checkout-email"
        name="email"
        type="email"
        autocomplete="email"
        placeholder=" "
      />
      <label class={C.label} for="checkout-email">{emailLabel}</label>
    </div>
    <div class={C.field} data-checkout-field="phone" data-format={phoneFormat}>
      <input
        class={C.input}
        id="checkout-phone"
        name="phone"
        type="tel"
        autocomplete="tel"
        placeholder=" "
        data-checkout-phone
      />
      <label class={C.label} for="checkout-phone">{phoneLabel}</label>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var phoneInput = document.querySelector('[data-checkout-phone]');
    if (!phoneInput) return;

    var format = (phoneInput.closest('[data-format]') && phoneInput.closest('[data-format]').getAttribute('data-format')) || '';
    if (format !== 'ru') return;

    function formatRu(digits) {
      // digits — только цифры без + и пробелов
      if (!digits) return '';
      // Если начинается с 8 — заменяем на 7
      if (digits[0] === '8') digits = '7' + digits.slice(1);
      // Если не начинается с 7 — префиксуем 7
      if (digits[0] !== '7') digits = '7' + digits;
      digits = digits.slice(0, 11);
      var out = '+7';
      if (digits.length > 1) out += ' (' + digits.slice(1, 4);
      if (digits.length >= 4) out += ')';
      if (digits.length > 4) out += ' ' + digits.slice(4, 7);
      if (digits.length > 7) out += '-' + digits.slice(7, 9);
      if (digits.length > 9) out += '-' + digits.slice(9, 11);
      return out;
    }

    phoneInput.addEventListener('input', function () {
      var digits = (phoneInput.value || '').replace(/\D/g, '');
      phoneInput.value = formatRu(digits);
    });

    phoneInput.addEventListener('focus', function () {
      if (!phoneInput.value) phoneInput.value = '+7 (';
    });

    phoneInput.addEventListener('blur', function () {
      if (phoneInput.value === '+7 (' || phoneInput.value === '+7') phoneInput.value = '';
    });
  })();
</script>
