---
// Checkout page (rose theme, Phase 1 pilot of Live Per-Theme Checkout).
//
// Composes the SHARED theme-base mega-blocks CheckoutForm + CheckoutSummary.
// Those blocks carry ALL live logic via inline scripts (DaData autocomplete in
// CheckoutDeliveryForm, СДЭК delivery in CheckoutDeliveryMethod, YooKassa in
// CheckoutPayment, submit-chain in CheckoutSubmit). They are token-driven, so
// they inherit rose's colors. NO checkout-JS is rewritten here.
//
// Import mechanism: DIRECT relative import from packages/theme-base/blocks/.
// The block tree is fully self-contained (only sibling .astro + .classes value
// imports + type-only .puckConfig imports), so a relative path resolves the
// whole tree. astro.config.mjs adds vite.server.fs.allow = [workspaceRoot] so
// Vite can read files outside the themes/rose project root.
//
// Plumbing: the block inline-scripts need window.cartStore + window.__MERFY_CONFIG__
// (+ optional window.__DADATA_TOKEN__). themes/rose's native NtCart system does
// NOT expose window.cartStore, so we load the templates' cart-api.js + cart-store.js
// (copied into public/scripts/) and inject config on this page only — keeping the
// rest of the rose theme on its native cart.
import Layout from "../layouts/Layout.astro";
import CheckoutForm from "../../../../packages/theme-base/blocks/CheckoutForm/CheckoutForm.astro";
import CheckoutSummary from "../../../../packages/theme-base/blocks/CheckoutSummary/CheckoutSummary.astro";

// Pilot defaults. In production build.service.ts string-patches shopId and
// injects DADATA_API_KEY; here we hardcode the apiUrl and leave shopId/dadataToken
// to be patched at build/deploy time (the injection script below reads them).
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";
const dadataToken = "";
---
<Layout title="Оформление заказа" description="Оформление заказа" header="checkout">
  {/* Figma 1:13398 — checkout is always the light scheme regardless of theme default. */}
  <div class="color-scheme-2">
    <main class="flex-1 w-full" style="background: rgb(var(--color-bg)); color: rgb(var(--color-text));">
      {/* Figma 183-27866: половина-на-половину на ВСЮ ширину. Левая половина —
          белая (scheme страницы), форма ~434px прижата к центру (justify-end,
          pl-10/pr-2). Правая половина — фиксированный светло-серый фон #F5F5F5
          (как в Figma, НЕ scheme → нет прогалов при смене схемы) на всю высоту
          и до правого края; секция сводки прозрачна ([&>section]:!bg-transparent),
          её контент ~360px прижат влево-вверх с воздухом справа (как в Figma). */}
      <div class="grid grid-cols-1 lg:grid-cols-2 items-stretch">
        <div data-checkout-column="form" class="min-w-0 flex justify-center lg:justify-end">
          <div class="w-full max-w-[480px] px-4 sm:px-6 lg:pl-10 lg:pr-2 py-12">
            <CheckoutForm />
          </div>
        </div>
        <div
          data-checkout-column="summary"
          class="min-w-0 px-6 py-10 lg:pl-14 lg:pr-10 lg:py-14 [&>section]:!bg-transparent [&>section]:max-w-[360px]"
          style="background-color:#f5f5f5"
        >
          <CheckoutSummary />
        </div>
      </div>
    </main>
  </div>

  {/* --- Live checkout plumbing (checkout page only) --- */}
  {/* Config injection (templates pattern). build.service.ts patches shopId +
      DADATA_API_KEY at deploy; for the local pilot the script just has to exist. */}
  <script is:inline define:vars={{ shopId, apiUrl, dadataToken }}>
    // НЕ клоббер: превью (preview.controller.injectPreviewGlobals) может выставить
    // window.__MERFY_CONFIG__.checkout ДО этого скрипта. Создаём объект при
    // отсутствии и лишь дозаполняем shopId/apiUrl, сохраняя .checkout.
    window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {};
    if (!window.__MERFY_CONFIG__.shopId) window.__MERFY_CONFIG__.shopId = shopId || "";
    if (!window.__MERFY_CONFIG__.apiUrl)
      window.__MERFY_CONFIG__.apiUrl = apiUrl || "https://gateway.merfy.ru/api";
    if (dadataToken) {
      window.__DADATA_TOKEN__ = dadataToken;
    }
  </script>
  {/* Рантайм-канал настроек чекаута (Фаза 4a): без ребилда тянем per-store
      настройки формы из gateway и публикуем на window.__MERFY_CONFIG__.checkout
      + событие `checkout:config-ready`. Отказоустойчиво: любой сбой / пустой
      shopId → дефолты (полная форма), событие ВСЁ РАВНО диспатчится (консюмеры
      формы разблокируются). Превью проставляет .checkout сервер-сайд → fetch
      пропускается. is:inline обязателен (как у соседних checkout-скриптов).
      No-flash: настройки тянутся в рантайме, поэтому не-дефолтные магазины на миг
      видят дефолт-форму до `checkout:config-ready`. Принято намеренно; в будущем
      можно повесить лоадер / придержать конфиг-зависимые поля скрытыми до
      события, чтобы убрать мигание (Фаза 4a, no-flash вариант B). */}
  <script is:inline>
    (function () {
      var cfg = (window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {});
      function fire() {
        try {
          document.dispatchEvent(new CustomEvent("checkout:config-ready"));
        } catch (e) {}
      }
      function apply(s) {
        s = s || {};
        cfg.checkout = {
          contactMethod: s.contactMethod === "email" ? "email" : "email-phone",
          customerNameMode:
            s.customerNameMode === "surname" || s.customerNameMode === "name"
              ? s.customerNameMode
              : "name-surname",
          addressRequired: s.addressRequired === false ? false : true,
          // Блок 1 «Обязательная регистрация»: гость не может оформить заказ, пока
          // не вошёл. Fail-open — фиксируем true ТОЛЬКО при явном флаге; любой сбой
          // fetch / пустой shopId → apply(null) → false → без гейта (гость у
          // магазинов без флага не ломается). Настоящий барьер — серверный гейт
          // в orders (403); клиентский разворот ниже — только UX.
          requireCustomerAuth: s.requireCustomerAuth === true,
        };
        // Gate A (клиентский, ТОЛЬКО live-вкладка): токен-less покупатель на
        // магазине с requireCustomerAuth разворачивается на /login ДО события
        // checkout:config-ready. Значит блоки чекаута не разблокируются и submit
        // не активируется — «держим submit заблокированным до config-ready».
        // Токен читаем из localStorage напрямую: window.__roseAuth на /checkout
        // НЕ инициализирован (persistentAtom кодирует null как '' → пусто = гость).
        // window.self===window.top исключает превью конструктора: iframe не
        // навигируем (там cfg.checkout уже проставлен сервером → ранний выход выше).
        if (window.self === window.top && cfg.checkout.requireCustomerAuth) {
          var token = null;
          try {
            token = localStorage.getItem("merfy_customer_token");
          } catch (e) {}
          if (!token) {
            location.href = "/login?redirect=" + encodeURIComponent("/checkout");
            return;
          }
        }
        fire();
      }
      // Превью уже проставило cfg.checkout сервер-сайд — чтим его, без fetch.
      if (cfg.checkout) {
        fire();
        return;
      }
      var shopId = cfg.shopId;
      var apiUrl = cfg.apiUrl || "https://gateway.merfy.ru/api";
      if (!shopId) {
        apply(null);
        return;
      }
      try {
        fetch(apiUrl + "/public/sites/" + encodeURIComponent(shopId) + "/settings", {
          headers: { Accept: "application/json" },
        })
          .then(function (r) {
            return r && r.ok ? r.json() : null;
          })
          .then(function (j) {
            apply(j && j.settings);
          })
          .catch(function () {
            apply(null);
          });
      } catch (e) {
        apply(null);
      }
    })();
  </script>
  {/* `is:inline` is REQUIRED — without it Astro bundles these through Vite, can't
      resolve `/scripts/...` (public dir) and SILENTLY drops the tag, leaving
      window.cartStore undefined → empty checkout. cart-store.js imports cart-api.js,
      so both are loaded as ES modules. */}
  <script is:inline type="module" src="/scripts/cart-api.js"></script>
  <script is:inline type="module" src="/scripts/cart-store.js"></script>
  <script is:inline>
    // Чекаут рендерит «Сводку заказа» МГНОВЕННО из nt-cart (rose:cart:v1) — без
    // серверных запросов на загрузке. Серверная корзина (cartStore) синкается
    // позже, при «Оформить» (CheckoutSubmit → cartStore.syncToServer). Так товары
    // появляются сразу с лоадером, а не по одному.
    document.addEventListener("DOMContentLoaded", function () {
      var cs = window.cartStore;
      if (!cs) return;
      // express-ключ больше не используется (buy-now = вся корзина) — чистим на всякий
      try { sessionStorage.removeItem("rose:buynow"); } catch (e) {}
      var lines = [];
      try { lines = JSON.parse(localStorage.getItem("rose:cart:v1") || "[]"); } catch (e) { lines = []; }
      if (!Array.isArray(lines)) lines = [];
      // nt-cart → серверная форма для дисплея (priceCents = рубли*100). Серверные
      // запросы НЕ делаем — синк уйдёт в «Оформить» (cartStore.syncToServer).
      var display = lines.map(function (l) {
        var v = l.variant || {};
        var opts = {};
        if (v.color) opts["Цвет"] = v.color;
        if (v.size) opts["Размер"] = v.size;
        return {
          id: l.id,
          productId: l.productId,
          name: l.name,
          priceCents: Math.round((parseFloat(l.price) || 0) * 100),
          compareAtPriceCents: l.oldPrice ? Math.round((parseFloat(l.oldPrice) || 0) * 100) : undefined,
          image: l.image,
          imageUrl: l.image,
          quantity: l.quantity || 1,
          options: opts,
          variantCombinationId: (v.variantCombinationId) || null,
        };
      });
      // Резолвим из каталога ДО показа → первый кадр сводки актуальный (цена/наличие),
      // без мелькания старой цены. Fallback — обычный setLocalItems.
      if (cs.setLocalItemsReconciled) cs.setLocalItemsReconciled(display, "/data/products.json");
      else if (cs.setLocalItems) cs.setLocalItems(display);
      else if (cs.init) cs.init();

      // Фоновый синк серверной корзины ПОСЛЕ мгновенного локального first-paint.
      // Сервер при пересчёте сам добавляет авто-BOGO «Подарок» (0₽-позиция,
      // isBonus) — без синка он не виден до сабмита. syncToServer({notify:true})
      // создаёт серверную корзину из локальных items, кладёт серверные items
      // (с подарком) в state и шлёт cart:updated → сводка/итоги перерисуются.
      // Локальный рендер уже на экране — это второй проход, не теряем first-paint.
      // debounce: уступаем место мгновенному рендеру и не воюем с apply-промокода
      // (in-flight guard в syncToServer дедуплицирует параллельные синки).
      if (display.length && cs.syncToServer) {
        setTimeout(function () {
          try { cs.syncToServer({ notify: true }).catch(function () {}); }
          catch (e) { /* сеть/корзина недоступны — остаёмся на локальном рендере */ }
        }, 250);
      }
    });
  </script>
</Layout>
