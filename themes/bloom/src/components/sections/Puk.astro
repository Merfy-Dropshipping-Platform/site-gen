---
import BloomPicture from '../img/BloomPicture.astro';

// ОЖИВЛЕНИЕ Puk (контракт rose Collections / theme-base Collections.astro).
// Раньше секция была статическим мок-демо верстальщика (pukItems
// «HYDRO/DAILY/LIFT» + заголовок «АКЦИЯ ПУКНИ 3 раза»). Теперь:
// пустое/некурированное состояние (Figma 1:19335) = ПЛЕЙСХОЛДЕР по контракту
// «Список коллекций» — 3 пустые квадратные карточки (bg #FBFBFB ≈
// rgb(var(--color-surface))) с подписью «Коллекция». Когда мерчант ВЫБРАЛ
// карточки (prop `collections`/`items` непустой) — рендерим реальные карточки
// (фото + подпись) БЕЗ изменений исходного layout. Гейт = наличие выбранных
// items (паритет theme-base Collections DEMO_COLLECTIONS на hasManualCollections).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Заголовок/подзаголовок: рендерим только при заданном пропе (мок-строки
// «АКЦИЯ ПУКНИ…» / «ПУК ПУК ПУК» удалены как демо верстальщика).
const sectionTitle =
  (typeof p.heading === 'string' ? p.heading : p.heading?.text) ??
  (typeof p.title === 'string' ? p.title : undefined);
const sectionSubtitle =
  (typeof p.subtitle === 'string' && p.subtitle.trim() ? p.subtitle : undefined) ??
  (typeof p.text === 'string' ? p.text : p.text?.content) ??
  undefined;

// Реальные карточки (выбор мерчанта). Принимаем `collections` или `items`
// (массив { id?, title/name/heading, image }). Непустой → курированный рендер.
type PukCard = { id?: string; title: string; image: string };
const rawItems: any[] = Array.isArray(p.collections)
  ? p.collections
  : Array.isArray(p.items)
    ? p.items
    : [];
const selectedCards: PukCard[] = rawItems
  .map((it) => ({
    id: typeof it?.id === 'string' ? it.id : undefined,
    title: it?.title ?? it?.name ?? it?.heading ?? '',
    image: it?.image ?? it?.imageUrl ?? it?.images?.[0] ?? '',
  }))
  // карточка курирована, если у неё есть картинка (паритет «гейт на изображениях»)
  .filter((c) => typeof c.image === 'string' && c.image.trim().length > 0);

const hasCurated = selectedCards.length > 0;

// КОНТРАКТ-ПЛЕЙСХОЛДЕР (Figma 1:19335 / theme-base Collections.astro
// DEMO_COLLECTIONS): пустой выбор → НЕ мок-фото верстальщика, а 3 пустые
// квадратные карточки (gray fill #FBFBFB ≈ rgb(var(--color-surface))) с
// подписью «Коллекция» под каждой.
const PLACEHOLDER_COLLECTIONS: { title: string }[] = [
  { title: 'Коллекция' },
  { title: 'Коллекция' },
  { title: 'Коллекция' },
];
---

<section class="puk-section" data-puck-component-id={id} data-block="puk">
  <div class="puk-container">
    {(sectionTitle || sectionSubtitle) && (
      <div class="puk-header">
        {sectionTitle && (
          <h2
            class="puk-title"
            data-puck-subsection-parent={id}
            data-puck-subsection-index="100"
            data-puck-subsection-field="heading"
          >{sectionTitle}</h2>
        )}
        {sectionSubtitle && <p class="puk-subtitle">{sectionSubtitle}</p>}
      </div>
    )}

    <div class="puk-grid">
      {hasCurated
        ? selectedCards.map((item, i) => (
            <div
              class="puk-card"
              data-puck-subsection-parent={id}
              data-puck-subsection-index={i}
              data-puck-subsection-field="collections"
            >
              <div class="puk-image-wrapper">
                <BloomPicture
                  src={item.image}
                  alt={item.title}
                  class="puk-image"
                  loading="lazy"
                />
              </div>
              <div class="puk-text">
                <p>{item.title}</p>
              </div>
            </div>
          ))
        : PLACEHOLDER_COLLECTIONS.map((ph) => (
            <div class="puk-card" data-nt="puk-placeholder">
              <div class="puk-image-wrapper puk-image-placeholder" aria-hidden="true"></div>
              <div class="puk-text">
                <p>{ph.title}</p>
              </div>
            </div>
          ))}
    </div>
  </div>
</section>

<style>
  .puk-section {
    width: 100%;
    background: #ffffff;
    padding: 80px 20px;
  }

  .puk-container {
    max-width: 1320px;
    margin: 0 auto;
  }

  .puk-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    margin-bottom: 50px;
    text-align: center;
  }

  .puk-title {
    font-family: 'Comfortaa', system-ui, sans-serif;
    font-size: 32px;
    font-weight: 400;
    line-height: 1.115;
    text-transform: uppercase;
    color: #000000;
    margin: 0;
  }

  .puk-subtitle {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 1.366;
    color: #999999;
    margin: 0;
  }

  .puk-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
    justify-items: center;
  }

  .puk-card {
    display: flex;
    flex-direction: column;
    gap: 25px;
    width: 100%;
    max-width: 430px;
  }

  .puk-image-wrapper {
    width: 100%;
    aspect-ratio: 430 / 500;
    overflow: hidden;
    border-radius: 10px;
  }

  /* Контракт-плейсхолдер «Список коллекций»: пустой rounded-rect
     (#FBFBFB ≈ rgb(var(--color-surface))), без иллюстрации. */
  .puk-image-placeholder {
    background: rgb(var(--color-surface, 251 251 251));
  }

  .puk-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .puk-text {
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .puk-text p {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 1.366;
    color: #000000;
    margin: 0;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .puk-section {
      padding: 60px 20px;
    }

    .puk-title {
      font-size: 28px;
    }

    .puk-subtitle {
      font-size: 20px;
    }

    .puk-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .puk-card {
      max-width: 100%;
    }

    .puk-text p {
      font-size: 20px;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .puk-section {
      padding: 40px 16px;
    }

    .puk-header {
      margin-bottom: 30px;
    }

    .puk-title {
      font-size: 24px;
    }

    .puk-subtitle {
      font-size: 18px;
    }

    .puk-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .puk-card {
      gap: 20px;
    }

    .puk-text p {
      font-size: 18px;
    }
  }

  /* Small Mobile */
  @media (max-width: 480px) {
    .puk-section {
      padding: 30px 12px;
    }

    .puk-title {
      font-size: 20px;
    }

    .puk-subtitle {
      font-size: 16px;
    }

    .puk-text p {
      font-size: 16px;
    }
  }
</style>



