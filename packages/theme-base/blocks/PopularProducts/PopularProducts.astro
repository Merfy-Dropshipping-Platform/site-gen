---
import type { PopularProductsProps } from './PopularProducts.puckConfig';
import { PopularProductsClasses as C } from './PopularProducts.classes';
import { resolveActiveCollection } from './url-filter';
import PopularProductRichCard from './PopularProductRichCard.astro';
import { PLACEHOLDER_ASSETS } from '../../runtime/placeholders';

interface Props extends PopularProductsProps {
  id?: string;
  /**
   * 088 T008 — siteId injected by build pipeline / preview controller so
   * the inline runtime fetch script can hit `/api/sites/<siteId>/storefront-data`
   * without depending on `window.__MERFY_CONFIG__` being available before
   * the script runs. Mirrors Catalog.astro Stage 3 pattern.
   */
  siteId?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  heading: headingProp,
  subtitle: subtitleProp,
  cards = 4,
  columns = 4,
  padding,
  siteId,
} = Astro.props as Props & { subtitle?: string };

// Layout variant: 'minimal' (rose/vanilla/bloom default) keeps existing
// markup; 'rich' (flux per Figma 1:26389) wraps each card in surface bg
// with colour swatches, memory chips, badges, in-card CTA. Set via
// theme.json blockDefaults.PopularProducts.cardVariant.
const cardVariant: 'minimal' | 'rich' =
  raw.cardVariant === 'rich' ? 'rich' : 'minimal';

// 084 vanilla pilot: additive `swatchOverlay` variant. When true, cards
// render a swatch indicator over the image **bottom-right** (per Figma
// 1:19004). Pip count comes from `p.variantSwatches.length` (preferred,
// each entry may carry a `color` hex) or `p.variants.length` (fallback,
// neutral pips). Capped at 5 pips. Hidden entirely when the product has
// no variants — i.e. demo placeholders no longer show 3 neutral pips.
//
// 088 G3 fix: previously rendered 3 neutral pips top-right on every card
// regardless of variant data; per audit Phase 3 it now mirrors Figma —
// bottom-right, real variant count, conditional render.
const swatchOverlayProp = raw.swatchOverlay === true;
const MAX_SWATCH_PIPS = 5;
type SwatchEntry = { color?: string | null };
type SwatchSource = {
  variantSwatches?: unknown;
  variants?: unknown;
  hasVariants?: unknown;
};
function resolveSwatchPips(p: SwatchSource): SwatchEntry[] {
  const fromSwatches = Array.isArray(p.variantSwatches) ? (p.variantSwatches as SwatchEntry[]) : null;
  if (fromSwatches && fromSwatches.length > 0) {
    return fromSwatches.slice(0, MAX_SWATCH_PIPS);
  }
  const variants = Array.isArray(p.variants) ? (p.variants as unknown[]) : null;
  if (variants && variants.length > 0) {
    return variants.slice(0, MAX_SWATCH_PIPS).map(() => ({ color: null }));
  }
  if (p.hasVariants === true) {
    return [{ color: null }];
  }
  return [];
}

// "В корзину" CTA per card. Поддерживаем 3 источника правды:
//   1. raw.quickAddMode (flat select, sidebar Figma 314-34614):
//      'none' / 'standard' / 'cart' (canonical). 'count' = legacy alias 'cart'.
//   2. raw.quickAdd (boolean) — старый flat API.
//   3. productCard.quickAdd ('true'/'false') — legacy nested API.
// quickAddMode имеет высший приоритет (новая каноническая схема, parity с Catalog).
const productCardObj = raw.productCard as { quickAdd?: boolean | string; buttonText?: string } | undefined;
const quickAddModeRaw = raw.quickAddMode as string | undefined;
const quickAddMode =
  quickAddModeRaw === 'count' ? 'cart' : quickAddModeRaw;  // legacy alias → canonical
const quickAddFromMode =
  quickAddMode === 'standard' || quickAddMode === 'cart';
const quickAddRaw = raw.quickAdd ?? productCardObj?.quickAdd;
const quickAddFromLegacy =
  quickAddRaw === true ||
  quickAddRaw === 'true' ||
  (typeof quickAddRaw === 'string' && quickAddRaw.toLowerCase() === 'yes');
const quickAdd = quickAddMode === 'none' ? false : (quickAddFromMode || quickAddFromLegacy);
const quickAddText =
  (typeof raw.quickAddText === 'string' && raw.quickAddText) ||
  productCardObj?.buttonText ||
  (quickAddMode === 'cart' ? 'В КОРЗИНУ' : 'В корзину');

// Constructor legacy schema writes heading as { text } and subtitle as
// { content }; accept both shapes so nothing renders as [object Object].
const heading = (() => {
  if (typeof headingProp === 'string') return headingProp || undefined;
  if (headingProp && typeof headingProp === 'object') {
    const h = headingProp as { text?: string };
    return h.text || undefined;
  }
  return undefined;
})();
const subtitle =
  (typeof subtitleProp === 'string' && subtitleProp) ||
  (() => {
    const t = raw.text;
    if (typeof t === 'string') return t;
    if (t && typeof t === 'object' && typeof (t as { content?: unknown }).content === 'string') {
      return (t as { content: string }).content;
    }
    return undefined;
  })();

// Pupa parity: heading.alignment, heading.size, text.size, productCard.{cardStyle,buttonStyle}, containerColorScheme.
// 084 vanilla pilot: also accept top-level `headingAlignment` so themes can
// set alignment via `blockDefaults.PopularProducts.headingAlignment` without
// being clobbered by a heading object spread merge.
const headingObj = headingProp ?? raw.heading;
const headingAlignment =
  (typeof headingObj === 'object' ? (headingObj as { alignment?: string })?.alignment : undefined)
  ?? (typeof raw.headingAlignment === 'string' ? (raw.headingAlignment as string) : undefined);
// Figma 314-34614: top-level `headingSize` имеет приоритет, fallback на legacy heading.size.
const headingSize =
  (typeof raw.headingSize === 'string' ? (raw.headingSize as string) : undefined)
  ?? (typeof headingObj === 'object' ? (headingObj as { size?: string })?.size : undefined);
const textSize = (() => {
  if (typeof raw.textSize === 'string') return raw.textSize as string;
  const t = raw.text;
  if (t && typeof t === 'object') return (t as { size?: string }).size;
  return undefined;
})();
// Default to `text-center` when prop is unset so pre-084 themes
// (rose/satin/bloom/flux) keep their centered headings. Vanilla
// theme overrides via `blockDefaults.PopularProducts.heading.alignment`.
const headingAlignClass =
  headingAlignment === 'left' ? 'text-left' :
  headingAlignment === 'right' ? 'text-right' :
  headingAlignment === 'center' ? 'text-center' :
  'text-center';
const headingSizeClass =
  headingSize === 'large' ? 'text-3xl md:text-4xl' :
  headingSize === 'medium' ? 'text-2xl md:text-3xl' :
  headingSize === 'small' ? 'text-xl md:text-2xl' : '';
const textSizeClass =
  textSize === 'large' ? 'text-lg md:text-xl' :
  textSize === 'medium' ? 'text-base md:text-lg' :
  textSize === 'small' ? 'text-sm' : '';
const containerColorScheme = raw.containerColorScheme as string | undefined;
const containerSchemeClass = containerColorScheme ? `color-scheme-${String(containerColorScheme).replace('scheme-', '')}` : '';

// productCard columns override.
const productCardCols = productCardObj && typeof productCardObj === 'object' && 'columns' in productCardObj && typeof (productCardObj as any).columns === 'number'
  ? (productCardObj as any).columns as number
  : columns;

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
// Responsive grid (mobile-first):
//   <640: 1, ≥640 (sm): min(N,2), ≥768 (md): min(N,3), ≥1024 (lg): N
// Маркеры для Tailwind v4 JIT: grid-cols-1 sm:grid-cols-1 sm:grid-cols-2 md:grid-cols-1
// md:grid-cols-2 md:grid-cols-3 lg:grid-cols-1 lg:grid-cols-2 lg:grid-cols-3 lg:grid-cols-4
// lg:grid-cols-5 lg:grid-cols-6
const LG_GRID: Record<number, string> = {
  1: 'lg:grid-cols-1', 2: 'lg:grid-cols-2', 3: 'lg:grid-cols-3',
  4: 'lg:grid-cols-4', 5: 'lg:grid-cols-5', 6: 'lg:grid-cols-6',
};
const MD_GRID: Record<number, string> = { 1: 'md:grid-cols-1', 2: 'md:grid-cols-2', 3: 'md:grid-cols-3' };
const SM_GRID: Record<number, string> = { 1: 'sm:grid-cols-1', 2: 'sm:grid-cols-2' };
// Эталон rose.merfy.ru — mobile уже grid-cols-2 (НЕ 1). Pixel-perfect parity:
// 2 (mobile) → 3 (md, columns≥3) → N (lg/xl, columns).
const _pcols = Math.max(1, Math.min(6, productCardCols));
const gridResponsiveClass = [
  _pcols >= 2 ? 'grid-cols-2' : 'grid-cols-1',
  MD_GRID[Math.min(_pcols, 3)],
  LG_GRID[_pcols],
].filter(Boolean).join(' ');
const colorSchemeRaw = typeof raw.colorScheme === 'string' ? raw.colorScheme : undefined;
const schemeClass = colorSchemeRaw ? `color-scheme-${colorSchemeRaw.replace('scheme-', '')}` : '';
// Try import products.json (build pipeline writes scaffold dir from product service).
// Fallback к DEMO_PRODUCTS если products.json missing/empty (seed site без real products).
type RealProduct = {
  id?: string;
  name?: string;
  price?: string | number;
  oldPrice?: string | number;
  image?: string;
  href?: string;
  hasVariants?: boolean;
  variants?: unknown[];
  variantSwatches?: Array<{ color?: string | null }>;
};
let realProducts: RealProduct[] = [];
try {
  const productsData = await import('../data/products.json');
  realProducts = (productsData.default ?? productsData) as RealProduct[];
} catch {
  realProducts = [];
}
// Preview path (no products.json baked, but siteId provided): pull
// products from sites svc storefront-data so SSR has real data and
// the JS hydration step doesn't have to overwrite SSR markup.
// Mirrors Product.astro's preview SSR fetch.
// Коллекции для SSR-фильтра «Выбор коллекции»: на live приходят из
// build-time collections.json; в превью его нет — берём из storefront-data
// (endpoint отдаёт нормализованную форму с productIds).
let previewCollections: Array<{ id?: string; name?: string; slug?: string; productIds?: string[] }> = [];
if (realProducts.length === 0 && siteId) {
  try {
    const internalBase = (import.meta as unknown as { env?: { SITES_INTERNAL_BASE?: string } }).env?.SITES_INTERNAL_BASE
      ?? 'http://localhost:3114';
    const res = await fetch(`${internalBase}/api/sites/${siteId}/storefront-data`).catch(() => null);
    if (res && res.ok) {
      const data = (await res.json()) as { products?: Array<Record<string, unknown>>; collections?: Array<Record<string, unknown>> };
      if (Array.isArray(data.collections)) {
        previewCollections = data.collections as typeof previewCollections;
      }
      if (Array.isArray(data.products)) {
        realProducts = data.products.map((p) => ({
          id: typeof p.id === 'string' ? p.id : undefined,
          name: typeof p.name === 'string' ? p.name : (typeof p.title === 'string' ? p.title : undefined),
          price: (p.price ?? p.basePrice) as string | number | undefined,
          oldPrice: (p.compareAtPrice ?? p.oldPrice) as string | number | undefined,
          image: typeof p.image === 'string' ? p.image : (Array.isArray(p.images) && typeof p.images[0] === 'string' ? p.images[0] as string : undefined),
          href: typeof p.slug === 'string' ? `/product/${p.slug}` : '/catalog',
          hasVariants: !!p.hasVariants,
          variants: Array.isArray(p.variants) && p.variants.length > 0
            ? p.variants
            : (Array.isArray(p.variantCombinations) ? p.variantCombinations : []),
          variantSwatches: Array.isArray(p.variantSwatches) ? p.variantSwatches as Array<{ color?: string | null }> : [],
        }));
      }
    }
  } catch {
    // swallow — fall through to DEMO_PRODUCTS
  }
}

// Filter by collection. URL `?collection=` query overrides block.props.collection
// (allows /catalog?collection=URBAN deep-linking like rose reference). Falls back
// to block prop when no URL query.
const urlCollection = Astro.url.searchParams.get('collection');
const blockCollection = typeof raw.collection === 'string' ? raw.collection : undefined;
const collectionRef = resolveActiveCollection(urlCollection, blockCollection);
if (collectionRef && realProducts.length > 0) {
  let ssrCollections: Array<{ id?: string; name?: string; slug?: string; productIds?: string[] }> = [];
  try {
    const collectionsData = await import('../data/collections.json');
    ssrCollections = ((collectionsData as { default?: unknown }).default ?? collectionsData) as typeof ssrCollections;
  } catch {
    // collections.json отсутствует (превью) — фоллбек на storefront-data
    ssrCollections = previewCollections;
  }
  const matched = ssrCollections.find((c) => c.name === collectionRef || c.id === collectionRef || c.slug === collectionRef);
  if (matched?.productIds?.length) {
    const idSet = new Set(matched.productIds);
    const filtered = realProducts.filter((p) => p.id && idSet.has(p.id));
    if (filtered.length > 0) realProducts = filtered;
  }
}

// Demo product illustrations per Figma 1:32992 (Platform-Constructor-Landing).
// 4 цветные курточки (синяя/жёлтая/красная/зелёная) — placeholder-карточки
// для seed-сайтов без реальных товаров. Assets живут в
// packages/theme-base/public/placeholders/sweater-{color}.png и попадают
// на live через `/placeholders/sweater-{color}.png` URL (copyPublic в
// assemble-from-packages.ts).
const DEMO_PRODUCTS = [
  { title: 'Товар', price: '2 500 ₽', oldPrice: '', badgeNew: false, badgeSale: '', image: PLACEHOLDER_ASSETS.sweater.blue },
  { title: 'Товар', price: '2 500 ₽', oldPrice: '', badgeNew: false, badgeSale: '', image: PLACEHOLDER_ASSETS.sweater.yellow },
  { title: 'Товар', price: '2 500 ₽', oldPrice: '', badgeNew: false, badgeSale: '', image: PLACEHOLDER_ASSETS.sweater.red },
  { title: 'Товар', price: '2 500 ₽', oldPrice: '', badgeNew: false, badgeSale: '', image: PLACEHOLDER_ASSETS.sweater.green },
];

const formatPrice = (v: unknown): string => {
  if (typeof v === 'number') return `${v.toLocaleString('ru-RU')} ₽`;
  if (typeof v === 'string' && v.trim()) return v.trim();
  return '';
};

// Curated-модель (Shopify): секция показывает товары ТОЛЬКО когда мерчант явно
// выбрал коллекцию. Нет выбора (collectionRef пуст) → заглушки (DEMO_PRODUCTS),
// даже если у магазина есть товары — секция не авто-подхватывает весь каталог.
// Inline-script ниже тоже не подменяет grid, когда коллекция не выбрана.
const productList = collectionRef && realProducts.length > 0
  ? realProducts.slice(0, Math.min(cards, realProducts.length)).map((p) => ({
      id: p.id,
      title: p.name || 'Товар',
      price: formatPrice(p.price),
      oldPrice: formatPrice(p.oldPrice),
      badgeNew: false,
      badgeSale: '',
      image: p.image || '',
      href: p.href || '/catalog',
      // 088 G3 fix — forward variant signals to SSG card so swatch overlay
      // resolves real pip count from build-time products.json.
      hasVariants: p.hasVariants ?? false,
      variants: Array.isArray(p.variants) ? p.variants : [],
      variantSwatches: Array.isArray(p.variantSwatches) ? p.variantSwatches : [],
    }))
  : DEMO_PRODUCTS.slice(0, Math.min(cards, DEMO_PRODUCTS.length)).map((p) => ({
      ...p,
      // Демо-cards без real productId — id остаётся undefined и кнопка
      // add-to-cart blocked в click handler (PopularProducts inline-script
      // bail если pid отсутствует).
      id: undefined as string | undefined,
      href: '/catalog',
      hasVariants: false as boolean,
      variants: [] as unknown[],
      variantSwatches: [] as Array<{ color?: string | null }>,
    }));
const demo = productList;

// Bottom "Смотреть ещё" CTA. Accept top-level viewAll object.
const viewAllObj = raw.viewAll as { show?: boolean | string; text?: string; href?: string } | undefined;
const viewAllShow =
  viewAllObj?.show === true ||
  viewAllObj?.show === 'true' ||
  (typeof viewAllObj?.show === 'string' && viewAllObj.show.toLowerCase() === 'yes');
const viewAllText = (viewAllObj?.text && String(viewAllObj.text)) || 'Смотреть ещё';
const viewAllHref = (viewAllObj?.href && String(viewAllObj.href)) || '/catalog';
const viewAllCtaClass = (C as Record<string, string>).viewAllCta;
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-block="popular-products"
  data-site-id={siteId}
  style={paddingStyle}
>
  <div class:list={[C.container, containerSchemeClass]}>
    {(heading || subtitle) && (
      <div class={(C as Record<string, string>).headerGroup ?? 'flex w-full justify-center'}>
        <div class={(C as Record<string, string>).headerInner ?? 'flex max-w-[90vw] flex-col items-center gap-2'}>
          {heading && (
            <h2 class:list={[C.heading, headingSizeClass]} data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">{heading}</h2>
          )}
          {subtitle && (
            <p class:list={[C.subtitle, textSizeClass]} data-puck-subsection-parent={id} data-puck-subsection-index="101" data-puck-subsection-field="text">{subtitle}</p>
          )}
        </div>
      </div>
    )}
    <div class:list={[C.grid, gridResponsiveClass]} data-pop-grid data-card-variant={cardVariant}>
      {cardVariant === 'rich' ? demo.map((p, i) => {
        // Per-card data extraction: swatches → colors row; first non-color
        // option group → memory chips; auto sale% from price diff; manual
        // badgeNew preserved. NB: avoid TS generics (<...>) inside Astro
        // frontmatter expressions — the compiler mistakes them for JSX.
        const variantsArr = Array.isArray(p.variants) ? p.variants : [];
        // Russian colour-name → hex map (extend as needed; falls back to
        // muted-grey square for unknown values). NB: keep this as a plain
        // object literal (NO TS generic annotation like `Record<...>`) —
        // SWC inside Astro JSX expressions parses `<...>` as JSX and breaks
        // the const declaration, surfacing as "Missing initializer".
        const COLOR_HEX = {
          'чёрный': '#000', 'черный': '#000', 'black': '#000',
          'белый': '#fff', 'white': '#fff',
          'серебро': '#c0c0c0', 'серебряный': '#c0c0c0', 'silver': '#c0c0c0',
          'серый': '#888', 'gray': '#888', 'grey': '#888',
          'красный': '#e00', 'red': '#e00',
          'синий': '#33396d', 'blue': '#33396d',
          'зелёный': '#3eb489', 'зеленый': '#3eb489', 'green': '#3eb489',
          'жёлтый': '#f6dc58', 'желтый': '#f6dc58', 'yellow': '#f6dc58',
          'коричневый': '#8b4513', 'brown': '#8b4513',
        };
        // Prefer explicit variantSwatches; otherwise extract colour options
        // from the first variant group whose key matches Цвет/Color.
        // When variantSwatches has entries but `color` is null (option exists
        // in DB but merchant didn't fill swatchHex yet) — fall back to looking
        // up the option's `value` in COLOR_HEX so well-known names render.
        let colors = (p.variantSwatches ?? []).slice(0, 4).map(function (s) {
          if (s && s.color) return { color: s.color, available: true };
          const name = s && (s as any).value
            ? String((s as any).value).toLowerCase()
            : null;
          const fallback = name ? (COLOR_HEX as any)[name] || null : null;
          return { color: fallback, available: true };
        });
        if (colors.length === 0) {
          const colorMap = new Map();
          for (const v of variantsArr) {
            const opts = v && (v as any).options;
            if (!opts) continue;
            for (const [k, val] of Object.entries(opts)) {
              if (!k.toLowerCase().includes('цвет') && !k.toLowerCase().includes('color')) continue;
              const valStr = String(val);
              const prev = colorMap.get(valStr) || false;
              colorMap.set(valStr, prev || (v as any).available !== false);
            }
          }
          colors = Array.from(colorMap.entries()).slice(0, 4).map(function (entry) {
            const key = String(entry[0]).toLowerCase();
            const lookup = (COLOR_HEX as any)[key] || null;
            return { color: lookup, available: entry[1] };
          });
        }
        const memorySet = new Map();
        for (const v of variantsArr) {
          const opts = v && (v as any).options;
          if (!opts) continue;
          for (const [k, val] of Object.entries(opts)) {
            if (k.toLowerCase().includes('цвет') || k.toLowerCase().includes('color')) continue;
            const key = String(val);
            const prev = memorySet.get(key) || false;
            memorySet.set(key, prev || (v as any).available !== false);
          }
        }
        const memoryChips = Array.from(memorySet.entries()).slice(0, 5).map(function (entry) {
          return { value: entry[0], available: entry[1] };
        });
        const badges = [];
        if (p.badgeNew) badges.push({ label: 'Новинка' });
        // Auto-derive sale percent from old/current price (numeric only).
        const cur = parseFloat(String(p.price).replace(/[^\d.]/g,''));
        const oldNum = parseFloat(String(p.oldPrice ?? '').replace(/[^\d.]/g,''));
        if (Number.isFinite(cur) && Number.isFinite(oldNum) && oldNum > cur && oldNum > 0) {
          const pct = Math.round(((oldNum - cur) / oldNum) * 100);
          if (pct > 0) badges.push({ label: `${pct}%` });
        } else if (typeof p.badgeSale === 'string' && p.badgeSale) {
          badges.push({ label: p.badgeSale });
        }
        return (
          <PopularProductRichCard
            href={p.href}
            image={p.image}
            title={p.title}
            price={p.price}
            oldPrice={p.oldPrice}
            colors={colors}
            memoryChips={memoryChips}
            badges={badges}
            ctaLabel={quickAddText}
            cardIndex={i}
            productId={p.id}
          />
        );
      }) : demo.map((p, i) => {
        const pips = swatchOverlayProp ? resolveSwatchPips(p) : [];
        return (
        <div
          class={C.card}
          aria-label="Товар"
          data-product-index={i}
        >
          <div class={C.cardMedia} aria-hidden="true">
            {p.badgeNew && <span class={C.cardBadgeNew}>Новинка</span>}
            {p.badgeSale && <span class={p.badgeNew ? C.cardBadgeSale : C.cardBadgeNew}>{p.badgeSale}</span>}
            {swatchOverlayProp && pips.length > 0 && (
              <span class={C.swatchOverlay.container} data-swatch-overlay aria-hidden="true">
                {pips.map((pip) => (
                  <span
                    class={C.swatchOverlay.dot}
                    style={pip.color ? `background-color:${pip.color};` : undefined}
                  ></span>
                ))}
              </span>
            )}
            {p.image ? (
              <img src={p.image} alt={p.title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
            ) : (
              <img src={PLACEHOLDER_ASSETS.sweater.blue} alt={p.title} class="absolute inset-0 w-full h-full object-contain p-[15%]" loading="lazy" />
            )}
          </div>
          <div class="flex flex-col gap-1 items-start w-full">
            <div class={C.cardTitle}>{p.title}</div>
            <div class={C.cardPriceRow}>
              <div class={C.cardPrice}>{p.price}</div>
              {p.oldPrice && <div class={C.cardOldPrice}>{p.oldPrice}</div>}
            </div>
            {quickAdd && (
              <button type="button" data-popular-cta data-product-id={p.id} class={C.cardCta}>{quickAddText}</button>
            )}
          </div>
        </div>
        );
      })}
    </div>
    {viewAllShow && viewAllCtaClass && (
      <a href={viewAllHref} class={viewAllCtaClass}>{viewAllText}</a>
    )}
  </div>
</section>

<script
  is:inline
  define:vars={{
    siteId: siteId ?? '',
    apiBase: 'https://gateway.merfy.ru/api',
    cardCount: Math.max(1, Math.min(24, Number(cards) || 4)),
    collection: collectionRef ?? null,
    quickAdd,
    quickAddText,
    swatchOverlay: swatchOverlayProp,
    cardClass: (C as Record<string, string>).card,
    cardMediaClass: (C as Record<string, string>).cardMedia,
    cardTitleClass: (C as Record<string, string>).cardTitle,
    cardPriceRowClass: (C as Record<string, string>).cardPriceRow,
    cardPriceClass: (C as Record<string, string>).cardPrice,
    cardOldPriceClass: (C as Record<string, string>).cardOldPrice,
    cardCtaClass: (C as Record<string, string>).cardCta,
    swatchContainerClass: C.swatchOverlay.container,
    swatchDotClass: C.swatchOverlay.dot,
    maxSwatchPips: MAX_SWATCH_PIPS,
    // Sweater placeholder URL для client-side cardHtml fallback (когда у
    // товара нет картинки). Тот же asset что Astro server рендерит —
    // единая декорация на оба пути.
    placeholderImageUrl: PLACEHOLDER_ASSETS.sweater.blue,
  }}
>
  // 088 T008 — runtime fetch (mirror Catalog.astro Stage 3 pattern).
  // SSG renders placeholder cards (graceful default); this script swaps the
  // grid with real product cards in BOTH live storefront and constructor
  // preview iframe — so конструктор ≡ live for PopularProducts.
  (function () {
    // Resolve effective siteId: explicit prop wins (set by build pipeline /
    // preview controller), fall back to window.__MERFY_CONFIG__.shopId so
    // older builds where the page template doesn't pass siteId still hydrate.
    var effectiveSiteId = siteId
      || (typeof window !== 'undefined' && window.__MERFY_CONFIG__ && (window.__MERFY_CONFIG__.shopId || window.__MERFY_CONFIG__.siteId))
      || (typeof window !== 'undefined' && window.__MERFY__ && window.__MERFY__.siteId)
      || '';
    // Hostname fallback: <12hex>.merfy.ru → first 12 hex chars are siteId prefix.
    if (!effectiveSiteId && typeof window !== 'undefined' && window.location) {
      var host = window.location.hostname || '';
      var m = host.match(/^([0-9a-f]{12})\.merfy\.ru$/i);
      if (m) effectiveSiteId = m[1];
    }
    if (!effectiveSiteId) return;

    // Find THIS section (in case multiple PopularProducts blocks exist on page,
    // each script invocation targets the nearest unhydrated section).
    var sections = document.querySelectorAll('section[data-block="popular-products"]');
    var root = null;
    for (var i = 0; i < sections.length; i++) {
      if (!sections[i].hasAttribute('data-pop-hydrated')) {
        root = sections[i];
        break;
      }
    }
    if (!root) return;
    root.setAttribute('data-pop-hydrated', 'true');

    var grid = root.querySelector('[data-pop-grid]');
    if (!grid) return;

    function escAttr(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function fmtPrice(p) {
      var num = typeof p === 'number' ? p : parseFloat(p);
      if (!Number.isFinite(num)) return '';
      var rubles = Math.round(num); // цена в рублях как есть (без мутации/÷100)
      return rubles.toLocaleString('ru-RU') + ' ₽';
    }
    function getImg(p) {
      if (Array.isArray(p.images) && p.images[0]) {
        return typeof p.images[0] === 'string' ? p.images[0] : (p.images[0].url || '');
      }
      return p.image || '';
    }

    // 088 G3 fix — swatch pips per Figma 1:19004. Position is bottom-right
    // (handled via CSS in classes); pip count and colors derive from real
    // product data (`variantSwatches[]` preferred, falls back to
    // `variants.length`). Returns empty string when product has no
    // variants — overlay must NOT render at all on placeholder cards.
    function resolveSwatchPipsRuntime(p) {
      var max = typeof maxSwatchPips === 'number' ? maxSwatchPips : 5;
      if (Array.isArray(p.variantSwatches) && p.variantSwatches.length > 0) {
        return p.variantSwatches.slice(0, max).map(function (sw) {
          return { color: sw && typeof sw.color === 'string' ? sw.color : null };
        });
      }
      if (Array.isArray(p.variants) && p.variants.length > 0) {
        return p.variants.slice(0, max).map(function () {
          return { color: null };
        });
      }
      if (p.hasVariants === true) {
        return [{ color: null }];
      }
      return [];
    }

    function swatchOverlayHtml(p) {
      if (!swatchOverlay) return '';
      var pips = resolveSwatchPipsRuntime(p);
      if (pips.length === 0) return '';
      var dotsHtml = pips.map(function (pip) {
        var styleAttr = pip.color
          ? ' style="background-color:' + escAttr(pip.color) + ';"'
          : '';
        return '<span class="' + swatchDotClass + '"' + styleAttr + '></span>';
      }).join('');
      return (
        '<span class="' + swatchContainerClass + '" data-swatch-overlay aria-hidden="true">' +
          dotsHtml +
        '</span>'
      );
    }

    function cardHtml(p) {
      var title = p.title || p.name || 'Товар';
      var price = fmtPrice(p.basePrice != null ? p.basePrice : p.price);
      var compare = p.compareAtPrice ? fmtPrice(p.compareAtPrice) : (p.oldPrice ? fmtPrice(p.oldPrice) : '');
      var img = getImg(p);
      var handle = p.handle || p.slug || p.id || '';
      var href = handle ? '/product/' + encodeURIComponent(handle) : '/catalog';

      var mediaInner = img
        ? '<img src="' + escAttr(img) + '" alt="' + escAttr(title) + '" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />'
        : '<img src="' + escAttr(placeholderImageUrl) + '" alt="' + escAttr(title) + '" class="absolute inset-0 w-full h-full object-contain p-[15%]" loading="lazy" />';

      // CTA — отдельный <button> с data-popular-cta (вне <a> wrapper —
      // button-in-anchor invalid HTML). Click handler в inline script ниже
      // делает cartStore.addItem(productId) → совпадает с Catalog quickAdd.
      var ctaHtml = quickAdd
        ? '<button type="button" data-popular-cta data-product-id="' + escAttr(p.id) + '" class="' + cardCtaClass + '">' + escAttr(quickAddText) + '</button>'
        : '';

      var oldPriceHtml = compare
        ? '<div class="' + cardOldPriceClass + '">' + escAttr(compare) + '</div>'
        : '';

      var pipsHtml = swatchOverlayHtml(p);

      // <article> снаружи + <a> wrap image+title+price (navigation) + кнопка
      // CTA снаружи <a> чтобы клик по ней не триггерил переход на /product.
      return (
        '<article data-product-id="' + escAttr(p.id) + '" data-product-handle="' + escAttr(handle) + '" class="' + cardClass + '" aria-label="' + escAttr(title) + '">' +
          '<a href="' + escAttr(href) + '" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:12px;">' +
            '<div class="' + cardMediaClass + '" aria-hidden="true">' + mediaInner + pipsHtml + '</div>' +
            '<div class="flex flex-col gap-1 items-start w-full">' +
              '<div class="' + cardTitleClass + '">' + escAttr(title) + '</div>' +
              '<div class="' + cardPriceRowClass + '">' +
                '<div class="' + cardPriceClass + '">' + escAttr(price) + '</div>' +
                oldPriceHtml +
              '</div>' +
            '</div>' +
          '</a>' +
          ctaHtml +
        '</article>'
      );
    }

    function applyCollectionFilter(products, collections, ref) {
      if (!ref || !Array.isArray(collections) || collections.length === 0) return products;
      var matched = collections.find(function (c) {
        return c && (c.id === ref || c.name === ref || c.slug === ref || c.handle === ref || c.title === ref);
      });
      if (!matched || !Array.isArray(matched.productIds) || matched.productIds.length === 0) return products;
      var idSet = new Set(matched.productIds);
      var filtered = products.filter(function (p) { return p.id && idSet.has(p.id); });
      return filtered.length > 0 ? filtered : products;
    }

    // CTA «В корзину» click — добавляет товар в корзину. Работает и для
    // minimal-variant (button data-popular-cta) и для rich-variant (button
    // data-popular-cta внутри RichCard). event.preventDefault() блокирует
    // переход на /product/<handle> от parent <a>. data-product-id берётся
    // с самой кнопки (заполнено и в minimal cardHtml, и в RichCard).
    grid.addEventListener('click', function (ev) {
      var btn = ev.target && ev.target.closest && ev.target.closest('[data-popular-cta]');
      if (!btn) return;
      ev.preventDefault();
      ev.stopPropagation();
      var pid = btn.getAttribute('data-product-id');
      if (!pid) {
        var article = btn.closest('[data-product-id]');
        pid = article ? article.getAttribute('data-product-id') : null;
      }
      if (!pid || !window.cartStore || typeof window.cartStore.addItem !== 'function') return;
      window.cartStore.addItem(pid, null, 1);
      var orig = btn.textContent;
      btn.textContent = '✓ Добавлено';
      setTimeout(function () { btn.textContent = orig; }, 1500);
    });

    // Rich variant rendered fully SSR (Astro fetched products itself);
    // skip JS-side rebuild to avoid clobbering rich card markup with
    // minimal cardHtml template.
    if (grid.getAttribute('data-card-variant') === 'rich') return;

    // Curated-модель: секция без выбранной коллекции остаётся с SSR-заглушками —
    // не подменяем их реальными товарами (пустой выбор = моки, не весь каталог).
    if (!collection) return;

    fetch(apiBase + '/sites/' + effectiveSiteId + '/storefront-data', { credentials: 'omit' })
      .catch(function () { return null; })
      .then(function (r) { return r && r.ok ? r.json() : null; })
      .then(function (data) {
        if (!data) return;
        var products = data.products || (data.data && data.data.products) || [];
        var collections = data.collections || (data.data && data.data.collections) || [];
        if (!Array.isArray(products) || products.length === 0) return;

        var filtered = applyCollectionFilter(products, collections, collection);
        var slice = filtered.slice(0, cardCount);
        if (slice.length === 0) return;

        grid.innerHTML = slice.map(cardHtml).join('');
      })
      .catch(function () { /* silent — placeholders stay */ });
  })();
</script>
