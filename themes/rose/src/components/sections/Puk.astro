---
// Puk — тестовая/отладочная секция-витрина товаров (грид карточек, манера
// PopularProducts). Пустое состояние = ПЛЕЙСХОЛДЕР по контракту Figma 1:19335
// (как theme-base DEMO), НЕ мок-демо верстальщика «пук 1/2/3».
//
// Гейт (паритет PopularProducts/Popular.astro): секция показывает реальные
// карточки ТОЛЬКО когда мерчант явно выбрал коллекцию / передал товары
// (collection / productIds / items). Нет выбора → курточки-плейсхолдеры
// (blue→yellow→red→green, /placeholders/sweater-<color>.png, object-contain),
// подпись «Товар», цена «2 500 ₽». Реальный SSR-рендер при наличии данных
// НЕ ломаем — он идёт по той же карточной разметке.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Заголовок/подзаголовок: при наличии — берём из пропсов конструктора
// (union heading.text / heading; text.content / subtitle). Пустое состояние:
// Figma 1:19335 PopularProducts — ДОСЛОВНЫЙ заголовок «Коллекция товаров»
// (паритет Popular.astro), без хелпер-подзаголовка. Когда мерчант задал свой
// heading/text — рендерим ЕГО (fallback срабатывает только при пустых данных).
// Мок-строки верстальщика («АКЦИЯ ПУКНИ» / «ПУК ПУК ПУК») не показываем.
const sectionTitle =
  (p.heading?.text ?? (typeof p.heading === 'string' ? p.heading : undefined)) || 'Коллекция товаров';
const sectionSubtitle =
  (p.text?.content ?? p.subtitle?.content ?? (typeof p.subtitle === 'string' ? p.subtitle : undefined)) || '';

// Курточки-плейсхолдеры (Figma 1:19335): циклом blue→yellow→red→green.
// URL `/placeholders/sweater-<color>.png` доступен на сайте (copyPublic из
// theme-base public; rose уже использует тот же путь в RoseProductDetail).
const SWEATER_COLORS = ['blue', 'yellow', 'red', 'green'] as const;
const sweaterAsset = (i: number) =>
  `/placeholders/sweater-${SWEATER_COLORS[i % SWEATER_COLORS.length]}.svg`;

// Дефолт 4 карточки (паритет PopularProducts cards=4). Уважаем cards, если
// задан (2..24).
const cardsN =
  typeof p.cards === 'number' && p.cards > 0 ? Math.max(1, Math.min(24, Math.round(p.cards))) : 4;

// Гейт реальных данных. Источники правды (как у curated-секций):
//   - collection (collectionPicker, id/slug),
//   - productIds (явный выбор товаров),
//   - items (готовый массив карточек с image/title/price).
const collectionRef =
  typeof p.collection === 'string' && p.collection.trim() ? p.collection.trim() : undefined;
const productIds = Array.isArray(p.productIds) ? p.productIds.filter(Boolean) : [];
const realItems = Array.isArray(p.items)
  ? p.items.filter((it: any) => it && (it.image || it.title))
  : [];

const formatPrice = (v: unknown): string => {
  if (typeof v === 'number') return `${v.toLocaleString('ru-RU')} ₽`;
  if (typeof v === 'string' && v.trim()) return v.trim();
  return '';
};

// SSR-фетч реальных товаров выбранной коллекции (Figma-цель: коллекция выбрана →
// реальные товары ПРЯМО в статике, чтобы их видело и ПРЕВЬЮ конструктора — Astro
// Container не исполняет клиентскую гидрацию). Зеркалит rose Popular.astro:
// p.siteId инжектит рендер-пайплайн (preview.service / build); при выбранной
// коллекции читаем /api/sites/<id>/storefront-data, фильтруем products по
// productIds коллекции, мапим в карточку. Нет коллекции / siteId / ошибка / пусто
// → realProducts пуст → секция рендерит плейсхолдер-куртки.
const siteId = typeof p.siteId === 'string' ? p.siteId : '';
let realProducts: Array<{ image: string; title: string; price: string }> = [];
if ((collectionRef || productIds.length > 0) && siteId) {
  try {
    const base = (import.meta as any).env?.SITES_INTERNAL_BASE ?? 'http://localhost:3114';
    const res = await fetch(`${base}/api/sites/${siteId}/storefront-data`).catch(() => null);
    if (res && res.ok) {
      const data: any = await res.json();
      const all: any[] = Array.isArray(data?.products) ? data.products : [];
      const cols: any[] = Array.isArray(data?.collections) ? data.collections : [];
      const matched = collectionRef
        ? cols.find(
            (c) =>
              c &&
              (c.id === collectionRef ||
                c.slug === collectionRef ||
                c.name === collectionRef ||
                c.handle === collectionRef),
          )
        : null;
      // Источник id: явный выбор товаров (productIds) приоритетнее → точечный набор;
      // иначе productIds выбранной коллекции; иначе весь каталог (как Popular).
      const ids = productIds.length > 0
        ? new Set(productIds)
        : matched && Array.isArray(matched.productIds) && matched.productIds.length
          ? new Set(matched.productIds)
          : null;
      const picked = (ids ? all.filter((pr) => pr?.id && ids.has(pr.id)) : all).slice(0, cardsN);
      realProducts = picked.map((pr) => {
        const img =
          Array.isArray(pr?.images) && pr.images[0]
            ? typeof pr.images[0] === 'string'
              ? pr.images[0]
              : (pr.images[0]?.url ?? '')
            : (pr?.image ?? '');
        return {
          image: String(img ?? ''),
          title: String(pr?.name ?? pr?.title ?? 'Товар'),
          price: formatPrice(pr?.basePrice ?? pr?.price),
        };
      });
    }
  } catch {
    realProducts = [];
  }
}

// hasRealData: реальные карточки рендерятся когда есть SSR-результат фетча
// (выбранная коллекция отдала товары) ИЛИ передан готовый items-массив.
const hasRealData = realProducts.length > 0 || realItems.length > 0;

// Карточки на рендер. Реальные данные → как есть (image/title/price), плейсхолдер
// → курточки + «Товар» / «2 500 ₽».
type Card = { image: string; title: string; price: string; objectContain: boolean };
const cards: Card[] = hasRealData
  ? (realProducts.length > 0 ? realProducts : realItems.slice(0, cardsN).map((it: any) => ({
      image: typeof it.image === 'string' ? it.image : '',
      title: (typeof it.title === 'string' && it.title) || 'Товар',
      price: formatPrice(it.price),
    }))
    ).map((it) => ({
      image: it.image,
      title: it.title,
      price: it.price,
      objectContain: false,
    }))
  : Array.from({ length: cardsN }, (_v, i) => ({
      image: sweaterAsset(i),
      title: 'Товар',
      price: '2 500 ₽',
      objectContain: true,
    }));
---

<section
  class="puk-section"
  data-puck-component-id={id}
  data-collection={collectionRef}
  data-puck-placeholder={hasRealData ? undefined : 'true'}
>
  <div class="puk-container">
    {(sectionTitle || sectionSubtitle) && (
      <div class="puk-header">
        {sectionTitle && <h2 class="puk-title">{sectionTitle}</h2>}
        {sectionSubtitle && <p class="puk-subtitle">{sectionSubtitle}</p>}
      </div>
    )}

    <div class="puk-grid">
      {cards.map((item) => (
        <div class="puk-card">
          <div class="puk-image-wrapper">
            {item.image ? (
              <img
                src={item.image}
                alt={item.title}
                class:list={['puk-image', item.objectContain && 'puk-image--contain']}
                decoding="async"
                loading="lazy"
              />
            ) : (
              <div class="puk-image-empty" aria-hidden="true"></div>
            )}
          </div>
          <div class="puk-text">
            <p>{item.title}</p>
            {item.price && <p class="puk-price">{item.price}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .puk-section {
    width: 100%;
    background: rgb(var(--color-bg, 255 255 255));
    padding: 80px 20px;
  }

  .puk-container {
    max-width: 1320px;
    margin: 0 auto;
  }

  .puk-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-bottom: 50px;
    text-align: center;
  }

  .puk-title {
    font-family: 'Comfortaa', system-ui, sans-serif;
    font-size: 20px !important;
    font-weight: 400;
    line-height: 1 !important;
    letter-spacing: normal;
    text-transform: uppercase;
    color: rgb(var(--color-text, 0 0 0));
    margin: 0;
  }

  .puk-subtitle {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 16px !important;
    font-weight: 400;
    line-height: 1 !important;
    letter-spacing: normal;
    color: rgb(var(--color-text-muted, 153 153 153));
    margin: 0;
  }

  .puk-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
    justify-items: center;
  }

  .puk-card {
    display: flex;
    flex-direction: column;
    gap: 25px;
    width: 100%;
    max-width: 430px;
  }

  .puk-image-wrapper {
    width: 100%;
    aspect-ratio: 430 / 500;
    overflow: hidden;
    border-radius: var(--radius-media, 8px);
  }

  .puk-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Плейсхолдер-куртка: вписываем целиком с воздухом (как theme-base DEMO),
     surface-фон по токену темы (Figma 1:19335 — пустые surface-карточки). */
  .puk-image--contain {
    object-fit: contain;
    padding: 15%;
    background: rgb(var(--color-surface, 251 251 251));
  }

  /* Пустой surface-rect плейсхолдера (нет картинки у реального товара). */
  .puk-image-empty {
    width: 100%;
    height: 100%;
    background: rgb(var(--color-surface, 251 251 251));
  }

  .puk-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 4px;
  }

  .puk-text p {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 1.366;
    color: rgb(var(--color-text, 0 0 0));
    margin: 0;
  }

  .puk-price {
    font-size: 18px !important;
    color: rgb(var(--color-text, 0 0 0));
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .puk-section {
      padding: 60px 20px;
    }

    .puk-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .puk-card {
      max-width: 100%;
    }

    .puk-text p {
      font-size: 20px;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .puk-section {
      padding: 40px 16px;
    }

    .puk-header {
      margin-bottom: 30px;
    }

    .puk-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .puk-card {
      gap: 20px;
    }

    .puk-text p {
      font-size: 18px;
    }
  }

  /* Small Mobile */
  @media (max-width: 480px) {
    .puk-section {
      padding: 30px 12px;
    }

    .puk-text p {
      font-size: 16px;
    }
  }
</style>



