---
// Фаза B (chrome): новая канон-секция PromoBanner в манере satin (themes/satin/MANNER.md §8).
// Схема полей = packages/theme-base/blocks/PromoBanner/PromoBanner.puckConfig.ts:
// text, link {text, href} (+ legacy linkText/linkUrl), size (thin/small/medium/large),
// textTransform (none/uppercase), colorScheme (обёртку даёт композитор), padding {top,bottom}.
// Тело = инлайн-полоса объявления верстальщика (Header.astro:43-45) дословно: вся полоса —
// одна ссылка без хвоста. Подчёркнутый хвост-ссылка — паттерн legacy
// header/PromoBanner.astro:17-20 (сам компонент страницами не используется, не трогаем),
// рендерится ТОЛЬКО при непустом link.text.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Figma 1:19335 — пустое состояние секции «Панель объявлений»: пока мерчант НЕ
// задал текст объявления, секция показывает ДОСЛОВНЫЙ плейсхолдер на surface-полосе
// («Добавь текст в объявление» + ссылка «Перейти»), а НЕ дефолт-контент верстальщика
// (маркетинг-полосу «Бесплатная доставка…»). PromoBanner — информационная полоса
// (нет товаров/коллекций/картинок для гейта), поэтому единственные «данные» секции —
// сам проп text. Когда text ЗАДАН (мерчант/ревизия/puck-default) — рендер реального
// текста на чёрной полосе верстальщика без изменений (эталоны rose/bloom PromoBanner.astro).
const rawText = typeof p.text === "string" ? p.text.trim() : "";
const hasText = rawText.length > 0;
const text = hasText ? p.text : "";

// Канон link {text, href} + legacy linkText/linkUrl. Дефолт href = литерал /catalog
// (вся полоса верстальщика ведёт в каталог). В пустом состоянии label ссылки по
// умолчанию = «Перейти» (Figma 1:19335).
const linkText =
	(typeof p.link?.text === "string" && p.link.text.trim() ? p.link.text : undefined) ??
	(typeof p.linkText === "string" && p.linkText.trim() ? p.linkText : undefined);
const placeholderLinkText = linkText ?? "Перейти";
const linkHref =
	p.link?.href ?? p.linkUrl ?? (typeof p.link === "string" ? p.link : undefined) ?? "/catalog";

// Канон «Размер текста» (Figma 648:57318) — меняет И ШРИФТ, И высоту полосы:
//   Маленький: h32 / 12px · Средний: h40 / 14px · Большой: h48 / 16px.
// Дефолт (нет пропа) = large (48/16) — флекс-центрирование лестницей шагом 8px:
// small → min-h-8 (32px), medium → min-h-10 (40px), large → min-h-12 (48px).
// Цвета чёрной полосы → токены с пиксель-фоллбеком §7: bg 0_0_0, text 255_255_255.
const size = typeof p.size === "string" ? p.size : "large";
const SIZE_MAP: Record<string, { mh: string; text: string }> = {
	small: { mh: "min-h-8", text: "text-[12px]" },
	medium: { mh: "min-h-10", text: "text-[14px]" },
	large: { mh: "min-h-12", text: "text-[16px]" },
};
const sz = SIZE_MAP[size] ?? SIZE_MAP.large;
const rootCls = `flex ${sz.mh} w-full items-center justify-center bg-[rgb(var(--color-bg,0_0_0))] py-2 text-center`;

// Канон textTransform: 'uppercase' (canon-default) И отсутствие = литерал верстальщика
// uppercase; явный 'none' снимает капс. Типографика полосы — Arsenal 400 tracking-[0.04em]
// (MANNER.md §1, H:43); размер шрифта от «Размер текста» (sz.text: 12/14/16px).
const typoCls =
	p.textTransform === "none"
		? `font-manrope ${sz.text} font-normal tracking-[0.04em] text-[rgb(var(--color-text,255_255_255))]`
		: `font-manrope ${sz.text} font-normal uppercase tracking-[0.04em] text-[rgb(var(--color-text,255_255_255))]`;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе; {12,12} =
// canon-default коэрсера → трактуем как литерал py-2 (паттерн bloom PromoBanner: isCanonPad).
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const isCanonPad = pad && Number(pad.top) === 12 && Number(pad.bottom) === 12;
const paddingStyle =
	pad && !isCanonPad
		? `padding-top:${Number(pad.top) || 0}px;padding-bottom:${Number(pad.bottom) || 0}px;`
		: undefined;
---

{
	hasText ? (
		/* Текст объявления задан мерчантом → чёрная полоса верстальщика дословно
		   (классы/токены rootCls + typoCls байт-в-байт, поведение не меняется). */
		<div
			class={rootCls}
			role="region"
			aria-live="polite"
			data-satin-announcement
			data-puck-component-id={id}
			style={paddingStyle}
		>
			{linkText ? (
				<p
					class={typoCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="text"
				>
					{text}
					<a
						href={linkHref}
						class="ml-1 underline decoration-1 underline-offset-2 transition-opacity hover:opacity-80"
					>
						{linkText}
					</a>
				</p>
			) : (
				<a
					href={linkHref}
					class={`block ${typoCls} transition-opacity hover:opacity-80`}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="text"
				>
					{text}
				</a>
			)}
		</div>
	) : (
		/* Пустое состояние (Figma 1:19335): дословный плейсхолдер «Добавь текст в
		   объявление. Перейти» на surface-полосе темы (НЕ чёрная полоса верстальщика
		   и НЕ дефолт-акция «Бесплатная доставка…»). Эталоны rose/bloom PromoBanner.astro. */
		<div
			class="flex min-h-12 w-full items-center justify-center overflow-hidden bg-[rgb(var(--color-surface,245_245_245))] px-4 py-2 text-center md:px-20 xl:px-[300px] 2xl:px-[680px]"
			role="region"
			aria-live="polite"
			data-satin-announcement
			data-puck-component-id={id}
			style={paddingStyle}
		>
			<p
				class="max-w-full text-center font-manrope text-[11px] font-normal tracking-[0.04em] text-[rgb(var(--color-text,0_0_0))] md:text-[14px]"
				data-puck-subsection-parent={id}
				data-puck-subsection-index="100"
				data-puck-subsection-field="text"
			>
				<span class="whitespace-pre-wrap">Добавь текст в объявление.</span>{" "}
				<a
					href={linkHref}
					class="underline decoration-1 underline-offset-2 transition-opacity hover:opacity-80"
				>
					{placeholderLinkText}
				</a>
			</p>
		</div>
	)
}
