---
interface Props {
	title?: string;
	body?: string;
}

const {
	title = "Одежда, в которой не нужно стараться выглядеть хорошо",
	body = "Мы делаем вещи, которые работают на вас, а не наоборот. Хлопок и лён, которые приятно носить в жару. Крой, который не сковывает и не растягивается после третьей стирки. Палитра, где любой верх подходит к любому низу — без мучений перед зеркалом. Каждая вещь проходит три этапа примерки на реальных людях до того, как попадает в каталог. Без логомании, без кричащих принтов, без вещей-однодневок. Только базовый гардероб, к которому хочется возвращаться.",
} = Astro.props;
---

<section class="satin-pad w-full bg-white py-12 md:py-16" aria-label={title}>
	<div class="satin-container flex flex-col gap-4">
		<h2 class="font-logo text-[20px] font-normal uppercase leading-[1.15] text-[#000000]">{title}</h2>
		<p class="satin-copy md:text-[20px]">{body}</p>
	</div>
</section>
