---
import Layout from "../layouts/Layout.astro";
import SatinProductCard from "../components/products/SatinProductCard.astro";
import NtFilterSidebar from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtFilterSidebar.astro";
import NtFilterPanel from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtFilterPanel.astro";
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { catalogProducts } from "../data/products";

const collection = Astro.url.searchParams.get("collection");
const products = collection ? catalogProducts.filter((product) => product.collection === collection) : catalogProducts.slice(0, 6);
const totalCount = products.length;
---

<Layout title="Каталог" description="Каталог Satin — коллекции, хиты, новинки">
	{/* Фон секции и все цвета зоны фильтров — из токенов цветовых схем конструктора
	    (rgb(var(--color-*))) с фоллбеками к прежним хардкодам: без схем вид
	    не меняется ни на пиксель, на тёмных/цветных схемах нет белых подложек. */}
	<section
		class="satin-pad w-full bg-[rgb(var(--color-bg,255_255_255))] py-12 md:py-16"
		aria-labelledby="catalog-title"
		data-catalog-layout="top"
	>
		{/* Раскладка каталога из настройки конструктора: платформа (превью и билд)
		    инжектит window.__MERFY_CATALOG_LAYOUT__. Скрипт стоит сразу после
		    открывающего тега секции — выбор применяется до рендера вариантов,
		    без мигания. Если глобала нет — остаётся родной вид темы (top). */}
		<script is:inline>
			var l = window.__MERFY_CATALOG_LAYOUT__;
			if (l === "top" || l === "side") {
				document.currentScript.parentElement.setAttribute("data-catalog-layout", l);
			}
		</script>
		<div class="satin-container flex flex-col gap-8">
			<header class="flex flex-col gap-2">
				<h1
					id="catalog-title"
					class="font-logo text-[20px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]"
				>
					Каталог
				</h1>
				<p class="font-manrope text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]">
					Здесь начинается персональный стиль
				</p>
			</header>

			{/* Раскладка top: фильтры/сортировка строкой над гридом (родной вид темы). */}
			<div class="flex flex-col gap-6" data-catalog-variant="top">
				<div class="flex flex-wrap items-center justify-between gap-3" data-nt="catalog-filters">
					<div class="flex flex-wrap items-start gap-3">
						<details class="group relative">
							<summary class="flex h-8 min-w-[120px] cursor-pointer list-none items-center justify-between gap-2 bg-[rgb(var(--color-bg,255_255_255))] px-0 font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span>Наличие</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-6" class="transition-transform group-open:rotate-180" />
							</summary>
							<div class="absolute left-0 top-full z-10 mt-1 w-full">
								<NtFilterPanel panel="stock" />
							</div>
						</details>

						<details class="group relative">
							<summary class="flex h-8 min-w-[120px] cursor-pointer list-none items-center justify-between gap-2 bg-[rgb(var(--color-bg,255_255_255))] px-0 font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span>Стоимость</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-6" class="transition-transform group-open:rotate-180" />
							</summary>
							<div class="absolute left-0 top-full z-10 mt-1 w-full">
								<NtFilterPanel panel="price" />
							</div>
						</details>

						<details class="group relative">
							<summary class="flex h-8 min-w-[90px] cursor-pointer list-none items-center justify-between gap-2 bg-[rgb(var(--color-bg,255_255_255))] px-0 font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span>Цвет</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-6" class="transition-transform group-open:rotate-180" />
							</summary>
							<div class="absolute left-0 top-full z-10 mt-1 w-full">
								<NtFilterPanel panel="color" />
							</div>
						</details>

						{/* Фильтр по коллекциям: скрыт на demo-сборке, гидрация показывает
						    его при наличии коллекций магазина и уважает ?collection= из
						    ссылок тайлов Collections. Манера = details-дропдауны выше,
						    панель = манера NtFilterPanel. */}
						<details class="group relative" data-nt="catalog-collections-filter" style="display:none;">
							<summary class="flex h-8 min-w-[120px] cursor-pointer list-none items-center justify-between gap-2 bg-[rgb(var(--color-bg,255_255_255))] px-0 font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span data-collections-label>Коллекции</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-6" class="transition-transform group-open:rotate-180" />
							</summary>
							{/* Открытая панель 1:1 с NtFilterPanel соседних дропдаунов (180px,
							    min-h 97, центрирование, рамка #F5F5F5): тот же набор классов +
							    маркер data-nt="filter-panel", чтобы токен-переопределения ниже
							    красили её и DS-панели одним правилом. */}
							<div class="absolute left-0 top-full z-10 mt-1 w-full">
								<div
									class="flex min-h-[97px] w-[180px] flex-col justify-center gap-2 rounded-[6px] border border-[#F5F5F5] bg-[#FFFFFF] p-3 font-manrope text-[14px] font-normal leading-[100%]"
									data-nt="filter-panel"
								>
									<ul data-collections-options class="m-0 flex list-none flex-col gap-2 p-0"></ul>
								</div>
							</div>
						</details>
					</div>

					<details class="group relative">
						<summary class="flex h-8 min-w-[150px] cursor-pointer list-none items-center justify-end gap-2 bg-[rgb(var(--color-bg,255_255_255))] px-0 font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
							<span>По популярности</span>
							<NtIcon name="dropdown-chevron" sizeClass="size-6" />
						</summary>
						<div class="absolute right-0 top-full z-10 mt-1 w-[180px]">
							<NtFilterPanel panel="sort" />
						</div>
					</details>
				</div>

				<ul
					class="grid auto-rows-fr grid-cols-2 gap-x-4 gap-y-10 sm:grid-cols-3"
					role="list"
					data-nt="catalog-grid"
				>
					{products.map((product) => (
						<li data-product-id={product.id}>
							<SatinProductCard product={product} />
						</li>
					))}
				</ul>

				<div class="flex flex-wrap items-center justify-between gap-4">
					<button
						type="button"
						data-action="load-more"
						class="satin-button satin-button-md satin-button-light"
					>
						Смотреть ещё
					</button>
					<span class="font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-muted,153_153_153))]" data-nt="catalog-count">
						{totalCount} товаров
					</span>
				</div>
			</div>

			{/* Раскладка side: левый сайдбар с фильтрами (включается настройкой конструктора). */}
			<div class="flex flex-col gap-8 lg:flex-row lg:gap-10" data-catalog-variant="side">
				{/* Колонка сайдбара: DS-компонент + своя секция «Коллекции» рядом
				    (NtFilterSidebar не трогаем; aside сам ужимается через max-w-full). */}
				<div class="hidden w-[172px] shrink-0 flex-col gap-4 lg:flex xl:w-[294px]">
					<NtFilterSidebar />

					{/* Фильтр по коллекциям в манере секций сайдбара: скрыт на demo-сборке,
					    гидрация показывает его при наличии коллекций магазина; пункты
					    (radio-вид как у NtRadioField) рисует initCollectionsFilter.
					    Структура секции 1:1 с секциями NtFilterSidebar: rounded-[8px] p-3
					    gap-3, заголовок 16px font-normal, БЕЗ собственной подложки —
					    у DS-секций фон задаёт aside (см. токен-переопределение ниже). */}
					<div
						class="flex flex-col gap-3 rounded-[8px] p-3 font-manrope"
						data-nt="catalog-collections-filter"
						data-cf-view="side"
						style="display:none;"
					>
						<p class="text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))]">Коллекции</p>
						<ul data-collections-options class="m-0 flex list-none flex-col gap-3 p-0"></ul>
					</div>
				</div>

				<div class="flex flex-1 flex-col gap-8">
					<ul
						class="grid auto-rows-fr grid-cols-2 gap-x-4 gap-y-10 sm:grid-cols-3"
						role="list"
						data-nt="catalog-grid"
					>
						{products.map((product) => (
							<li data-product-id={product.id}>
								<SatinProductCard product={product} />
							</li>
						))}
					</ul>

					<div class="flex flex-wrap items-center justify-between gap-4">
						<button
							type="button"
							data-action="load-more"
							class="satin-button satin-button-light"
						>
							Смотреть ещё
						</button>
						<span class="font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-muted,153_153_153))]" data-nt="catalog-count">
							{totalCount} товаров
						</span>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style is:global>
	/* Переключение раскладок каталога: активна та, что в data-catalog-layout
	   на секции (родной top; side включается конструктором через
	   __MERFY_CATALOG_LAYOUT__). Неактивный вариант полностью скрыт. */
	[data-catalog-layout="top"] [data-catalog-variant="side"] {
		display: none;
	}
	[data-catalog-layout="side"] [data-catalog-variant="top"] {
		display: none;
	}

	/* ── Цвета DS-компонентов фильтров из токенов цветовых схем ──────────────
	   NtFilterSidebar / NtFilterPanel / NtRadioField / NtFilterPriceRows не
	   редактируем (design-systems read-only) — переопределяем снаружи по их
	   стабильным data-nt-атрибутам и структуре label>input+span, скоупленно
	   в раскладки каталога. Фоллбеки = текущие хардкоды DS (#FFFFFF/#000000/
	   #999999/#F5F5F5): без активной схемы вид прежний, на тёмных/цветных
	   схемах — никаких белых подложек. Эти правила вне @layer, поэтому
	   побеждают tailwind-утилиты DS независимо от специфичности. */

	/* side: плоскость сайдбара = фон страницы (манера satin «без плиты») */
	[data-catalog-variant="side"] [data-nt="filter-sidebar"] {
		background-color: rgb(var(--color-bg, 255 255 255));
	}
	/* side: заголовки секций сайдбара («Сортировать»/«Наличие»/«Стоимость»/«Цвет») */
	[data-catalog-variant="side"] [data-nt="filter-sidebar"] > div > p {
		color: rgb(var(--color-text, 0 0 0));
	}
	/* side: радио NtRadioField — ободок, точка, подпись, focus-кольцо */
	[data-catalog-variant="side"] [data-nt="radio-field"] input + span {
		border-color: rgb(var(--color-muted, 153 153 153));
	}
	[data-catalog-variant="side"] [data-nt="radio-field"] input + span::after {
		background-color: rgb(var(--color-text, 0 0 0));
	}
	[data-catalog-variant="side"] [data-nt="radio-field"] input:checked + span {
		border-color: rgb(var(--color-text, 0 0 0));
	}
	[data-catalog-variant="side"] [data-nt="radio-field"] input:focus-visible + span {
		outline-color: rgb(var(--color-text, 0 0 0));
	}
	[data-catalog-variant="side"] [data-nt="radio-field"] > span:last-child {
		color: rgb(var(--color-muted, 153 153 153));
	}
	[data-catalog-variant="side"] [data-nt="radio-field"] input:checked ~ span:last-child {
		color: rgb(var(--color-text, 0 0 0));
	}
	/* обе раскладки: строки «от/до» стоимости (подчёркивание + текст) */
	[data-catalog-variant="side"] [data-nt="filter-price-rows"] > div,
	[data-catalog-variant="top"] [data-nt="filter-price-rows"] > div {
		border-color: rgb(var(--color-muted, 153 153 153));
		color: rgb(var(--color-muted, 153 153 153));
	}
	/* top: в panel-варианте строка «от» активная (чёрная в DS) */
	[data-catalog-variant="top"] [data-nt="filter-price-rows"][data-nt-variant="panel"] > div:first-child {
		border-color: rgb(var(--color-text, 0 0 0));
		color: rgb(var(--color-text, 0 0 0));
	}
	/* top: открытые панели дропдаунов (DS NtFilterPanel + панель «Коллекции» —
	   у неё тот же data-nt). Рамка: rgb(text/4%) на белом = #F5F5F5 (как в DS),
	   на тёмной схеме — тонкий светлый волосок вместо хардкод-светлой рамки. */
	[data-catalog-variant="top"] [data-nt="filter-panel"] {
		background-color: rgb(var(--color-surface, 255 255 255));
		border-color: rgb(var(--color-text, 0 0 0) / 4%);
	}
	[data-catalog-variant="top"] [data-nt="filter-panel"] > p {
		color: rgb(var(--color-muted, 153 153 153));
	}
	[data-catalog-variant="top"] [data-nt="filter-panel"] > p:first-child {
		color: rgb(var(--color-text, 0 0 0));
	}
	/* кнопка «Смотреть ещё» каталога: satin-button-light хардкодит --satin-black —
	   в зоне каталога ведём от токена текста (фоллбек тот же чёрный). */
	[data-catalog-layout] .satin-button-light {
		color: rgb(var(--color-text, 0 0 0));
		border-color: rgb(var(--color-text, 0 0 0));
	}
</style>

{/* ⚠️ ГОЧА #5: хвостовые <script> (load-more disabler + filter-dropdowns +
    module storefront-hydrate) УДАЛЕНЫ. Каталог теперь — Puck-блок
    packages/theme-satin/blocks/Catalog/Catalog.astro: на live его рендер
    пересаживается в dist/catalog/index.html (composeContentPagesIntoDist), а
    composeV2Page сохраняет хвост body (всё после </footer>) дословно — старые
    скрипты этой страницы конфликтовали бы с is:inline-клиентом блока (дубль
    renderCatalog/load-more/initCollectionsFilter). Эта страница остаётся как
    SSG-шелл (head + Layout-бандлы), её тело перезаписывается блоком. */}
