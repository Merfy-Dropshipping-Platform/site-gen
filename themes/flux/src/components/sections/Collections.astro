---
// ОЖИВЛЕНИЕ (контракт flux Popular / rose T13): полная конструкторная схема
// theme-base Collections.puckConfig поверх ВЁРСТКИ ВЕРСТАЛЬЩИКОВ (репо
// flux-theme Collections.astro: простой <h2> font-roboto-flex uppercase
// text-[19px] md:text-[23px], grid grid-cols-2 md:grid-cols-4, плитка
// aspect-square rounded-12, название text-[16px] md:text-[19px] font-light).
// НЕ DS-компонент NtSectionHeading (он рендерил Comfortaa/Manrope мимо манеры
// flux). Канон-дефолты конструктора (headingSize 'medium' → эталон 19/23,
// subtitleSize 'small', imageView 'portrait' + flux blockDefault variant 'tile'
// → aspect-square эталона, columns 3) дают пиксель верстальщика; цвета → токены
// с пиксель-фоллбеком родных литералов (MANNER.md §7). Скролл-анимаций нет —
// манера flux статична (MANNER.md §6).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Иконка-плейсхолдер пустого медиа-бокса (паритет rose Collections + flux ProductCard):
// внятная image-иконка по центру surface-плитки вместо пустого серого бокса.
const PH_MEDIA_ICON =
	'<span class="flex h-full w-full items-center justify-center text-[rgb(var(--color-muted,153_153_153))]"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg></span>';
// Figma 1:19335 — ПУСТОЕ состояние секции «Список коллекций»: дословный заголовок
// «Список коллекций» (без подзаголовка), а НЕ дефолт-копирайт верстальщика
// («Категории»). Эталон — rose Collections.astro. Мерчант задал свой
// heading/subtitle → его и рендерим (?? срабатывает только при пустых данных;
// пустая строка subtitle скрывает <p>).
const sectionTitle =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title ?? "Список коллекций";
const sectionSubtitle =
	(typeof p.subtitle === "string" ? p.subtitle : undefined) ?? "";

// Шапка секции = ВЁРСТКА ВЕРСТАЛЬЩИКОВ (эталон Collections.astro): простой <h2>
// font-roboto-flex uppercase, дефолт text-[19px] md:text-[23px]. headingSize —
// ступени small/medium/large на базе эталонных размеров (19/23): канон-дефолт
// конструктора 'medium' = эталон, small меньше, large крупнее (НЕ 38/46).
// subtitleSize: канон-дефолт 'small' = 14/16, medium/large крупнее. Цвет —
// токены (color-heading/color-muted) с фоллбеком чёрный/серый → colorScheme
// перекрашивает, без схемы пиксель эталона (MANNER.md §7).
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[16px] md:text-[19px]"
		: headingSize === "large"
			? "text-[23px] md:text-[29px]"
			: "text-[19px] md:text-[23px]"; // medium (canon-default) + absent → эталон 19/23
const subtitleSize = p.subtitleSize ?? p.subtitle?.size;
const subtitleSizeCls =
	subtitleSize === "medium"
		? "text-[16px] md:text-[19px]"
		: subtitleSize === "large"
			? "text-[19px] md:text-[23px]"
			: "text-[14px] md:text-[16px]"; // small (canon-default) + absent
const headingCls = `font-roboto-flex font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))] ${headingSizeCls}`;
const subtitleCls = `font-roboto-flex font-normal leading-normal text-[rgb(var(--color-muted,153_153_153))] ${subtitleSizeCls}`;
// Канон titleAlignment (как rose): дефолт/left = эталон (h2 слева); center/right
// двигают заголовок и подзаголовок перекрытиями на обёртке шапки (flex-col).
const titleAlignCls =
	p.titleAlignment === "center"
		? " items-center text-center"
		: p.titleAlignment === "right"
			? " items-end text-right"
			: "";
const headWrapCls = `flex flex-col gap-2${titleAlignCls}`;

// Канон variant (flux blockDefault 'tile', Figma 1:26298 + репо Collections.astro):
// квадратная плитка (aspect-square — ЭТАЛОН верстальщиков, НЕ 430/500) + font-light
// названия. 'standard' → легаси-портрет 430/500 (rose-вид).
const variant = p.variant === "standard" ? "standard" : "tile";
const isTile = variant === "tile";
const nameWeightCls = isTile ? "font-light" : "font-normal";
// Канон imageView (настройка как rose): square / канон-дефолт (tile) → aspect-square
// (репо); 'wide' → 16/9; 'portrait' → 430/500 только для легаси standard. Конструктор
// шлёт imageView='portrait' по дефолту, но flux-tile → square (эталон верстальщиков).
const tileAspect =
	p.gridAspect === "1:1" || p.imageView === "square"
		? "aspect-square"
		: p.imageView === "wide"
			? "aspect-[16/9]"
			: isTile
				? "aspect-square"
				: "aspect-[430/500]";
// Канон cardCaptionStyle: 'default'/отсутствие = обычный регистр подписи; 'uppercase' — капсом.
const captionCase = p.cardCaptionStyle === "uppercase" ? " uppercase" : "";
// Название коллекции = эталон верстальщиков: font-roboto-flex text-[16px]
// md:text-[19px] font-light (tile). Хук .flux-collection-name + токен цвета (схема).
const nameCls = `flux-collection-name font-roboto-flex text-[16px] ${nameWeightCls} leading-normal text-[rgb(var(--color-text,0_0_0))] md:text-[19px]${captionCase}`;

// Канон columns 1-6 (канон-дефолт конструктора 3). Применяются с md (768px) через
// CSS-переменную --cols + media-query в <style> ниже (моб = 2 колонки — эталон
// верстальщиков grid-cols-2). Tailwind-arbitrary md:grid-cols-[repeat(var(--cols))]
// в flux-компиляторе ненадёжен — прецедент Popular: var + media-query, не класс.
const colsN = typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : 3;
// Вёрстка верстальщиков: grid grid-cols-2 gap-4 md:grid-cols-4. Моб = 2 колонки;
// с md (768px) grid-template-columns задаёт <style> по --cols (слайдер «Колонки»
// перебивает md:grid-cols-4).
const gridCls = "grid grid-cols-2 gap-4 md:grid-cols-4";
const gridStyle = `--cols:${colsN}`;

// Канон collections[] (≤10): плитки коллекций из пропса при непустом массиве.
// Иначе — плейсхолдер пустого состояния (PLACEHOLDER_COLLECTIONS, ниже). SSR
// рендерит сохранённые поля item, резолв collectionId → имя/обложка делает
// гидрация ниже (data-collection-ref): live — /data/collections.json, превью —
// storefront-data; паритет theme-base (имя коллекции перебивает ручной
// heading, обложка — только при пустой своей).
const cardLinkBase =
	typeof p.cardLinkBase === "string" && p.cardLinkBase.trim() ? p.cardLinkBase : "/catalog?collection=";
const propCollections = (Array.isArray(p.collections) ? p.collections : [])
	.filter((c: any) => c && typeof c === "object")
	.slice(0, 10)
	.map((c: any, i: number) => {
		const collectionId =
			typeof c.collectionId === "string" && c.collectionId.trim() ? c.collectionId.trim() : null;
		return {
			collectionId,
			name:
				(typeof c.heading === "string" && c.heading) ||
				(typeof c.name === "string" && c.name) ||
				"Коллекция",
			// Плейсхолдер пустого состояния (Figma 1:19335, паритет rose T15):
			// карточка без выбранной картинки = ПУСТАЯ surface-плитка (НЕ мок-фото
			// верстальщика). На live гидрация (data-collection-ref) подставит реальное
			// фото коллекции по collectionId; SSR-гард {c.image ? img : icon} держит
			// surface с иконкой-плейсхолдером пустой.
			image: typeof c.image === "string" && c.image ? c.image : "",
			hasOwnImage: !!(typeof c.image === "string" && c.image),
			href: collectionId ? `${cardLinkBase}${collectionId}` : "#",
		};
	});
const usePropCollections = propCollections.length > 0;

// SSR-резолв реальных коллекций по collectionId (Figma-цель: коллекция ВЫБРАНА →
// реальное имя/обложка ПРЯМО в статике, чтобы их видело и ПРЕВЬЮ конструктора —
// Astro Container не исполняет клиентскую module-гидрацию ниже). Эталон —
// rose Collections.astro / flux Popular.astro (siteId инжектит рендер-пайплайн
// preview.service / build). Нет siteId / выбранных collectionId / ошибка →
// resolved пуст → остаётся SSR (heading/обложка из пропса), а живая гидрация
// ниже освежит данные на live. Паритет theme-base resolveManual: имя коллекции
// перебивает ручной heading, обложка подставляется только при пустой своей.
const siteId = typeof p.siteId === "string" ? p.siteId : "";
const wantResolve = usePropCollections && propCollections.some((c) => c.collectionId);
const resolvedCols = new Map<string, { name?: string; image?: string }>();
if (wantResolve && siteId) {
	try {
		const base = (import.meta as any).env?.SITES_INTERNAL_BASE ?? "http://localhost:3114";
		const res = await fetch(`${base}/api/sites/${siteId}/storefront-data`).catch(() => null);
		if (res && res.ok) {
			const data: any = await res.json();
			const cols: any[] = Array.isArray(data?.collections) ? data.collections : [];
			for (const c of propCollections) {
				if (!c.collectionId) continue;
				const m = cols.find(
					(x) =>
						x &&
						(x.id === c.collectionId ||
							x.slug === c.collectionId ||
							x.name === c.collectionId ||
							x.handle === c.collectionId),
				);
				if (!m) continue;
				const cover =
					(typeof m.image === "string" && m.image) ||
					(Array.isArray(m.images) && typeof m.images[0] === "string" ? m.images[0] : "");
				resolvedCols.set(c.collectionId, {
					name: typeof m.name === "string" ? m.name : undefined,
					image: cover || undefined,
				});
			}
		}
	} catch {
		/* нет данных — остаётся SSR из пропса, гидрация освежит на live */
	}
}
// Применяем резолв к карточкам пропса: реальное имя перебивает ручной heading,
// обложка — только если мерчант не загрузил свою.
const resolvedCollections = propCollections.map((c) => {
	const r = c.collectionId ? resolvedCols.get(c.collectionId) : undefined;
	if (!r) return c;
	return {
		...c,
		name: r.name || c.name,
		image: c.hasOwnImage ? c.image : r.image || c.image,
	};
});

// Плейсхолдер пустого состояния (Figma 1:19335, контракт theme-base Collections
// DEMO_COLLECTIONS): без ручного выбора — 3 карточки с пустым rounded-rect
// (bg #FBFBFB / rgb(var(--color-surface)) + иконка-плейсхолдер) и подписью
// «Коллекция». НЕ мок-демо верстальщика. Реальные коллекции магазина при пустом
// пикере подтягивает autofillCollections (hydration ниже).
const PLACEHOLDER_COLLECTIONS = [
	{ name: "Коллекция" },
	{ name: "Коллекция" },
	{ name: "Коллекция" },
];

// Контейнер = flux-container эталона (как Header/Footer/Popular flux: mx-auto
// max-w-[1920px] px-4 md:px-20 2xl:px-80) + flex flex-col gap-8 (канон
// верстальщиков). Вертикаль py-10 md:py-16 (эталон); при заданном padding
// (настройка) py-классы убираются — inline-стиль ставит padding-top/bottom
// (паттерн Popular/Footer flux, чтобы не было двойного отступа).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
const containerCls = paddingStyle
	? "mx-auto flex w-full max-w-[1920px] flex-col gap-8 px-4 md:px-20 2xl:px-80"
	: "mx-auto flex w-full max-w-[1920px] flex-col gap-8 px-4 py-10 md:px-20 md:py-16 2xl:px-80";
---

<section
	id="collections"
	class="w-full bg-[rgb(var(--color-bg,255_255_255))]"
	aria-labelledby="collections-title"
	data-puck-component-id={id}
>
	<div class={containerCls} style={paddingStyle}>
		<div
			class={headWrapCls}
			data-puck-subsection-parent={id}
			data-puck-subsection-index="100"
			data-puck-subsection-field="heading"
			data-reveal
		>
			<h2 id="collections-title" class={headingCls}>{sectionTitle}</h2>
			{sectionSubtitle && <p class={subtitleCls}>{sectionSubtitle}</p>}
		</div>

		<ul
			class={gridCls}
			role="list"
			data-nt="collections-grid"
			data-cols={String(colsN)}
			style={gridStyle}
			data-collections-autofill={!usePropCollections ? "" : undefined}
		>
			{usePropCollections ? resolvedCollections.map((c, i) => (
				<li>
					<a
						href={c.href}
						class="group flex flex-col gap-4 transition-transform duration-300 hover:-translate-y-1"
						aria-label={c.name}
						data-nt="flux-collection-card"
						data-collection-ref={c.collectionId ?? undefined}
						data-own-image={c.hasOwnImage ? "true" : undefined}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="collections"
					>
						<div
							class={`${tileAspect} w-full overflow-hidden rounded-[12px] bg-[rgb(var(--color-surface,245_245_245))]`}
							aria-hidden={c.image ? undefined : "true"}
						>
							{c.image ? (
								<img
									src={c.image}
									alt={c.name}
									loading="lazy"
									class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
								/>
							) : (
								<Fragment set:html={PH_MEDIA_ICON} />
							)}
						</div>
						<h3 class={nameCls}>{c.name}</h3>
					</a>
				</li>
			)) : PLACEHOLDER_COLLECTIONS.map((c) => (
				<li>
					<div
						class="group flex flex-col gap-4"
						data-nt="flux-collection-card-placeholder"
						aria-label={c.name}
					>
						<div
							class={`${tileAspect} w-full overflow-hidden rounded-[12px] bg-[rgb(var(--color-surface,251_251_251))]`}
							aria-hidden="true"
						>
							<Fragment set:html={PH_MEDIA_ICON} />
						</div>
						<h3 class={nameCls}>{c.name}</h3>
					</div>
				</li>
			))}
		</ul>
	</div>
</section>

<script>
	import { loadRealCollections, findCollection, escapeHtml } from "../../lib/storefront-hydrate";

	// Иконка-плейсхолдер пустого медиа-бокса (паритет SSR PH_MEDIA_ICON выше):
	// hoisted-<script> компилируется esbuild'ом отдельным модулем и НЕ видит
	// frontmatter-конст — потому строку SVG дублируем здесь (иначе автоподстановка
	// рендерила бы undefined вместо иконки в плитке без обложки).
	const PH_MEDIA_ICON =
		'<span class="flex h-full w-full items-center justify-center text-[rgb(var(--color-muted,153_153_153))]"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg></span>';

	// Резолв collectionId → имя/обложка на плитках (data-collection-ref).
	// Паритет theme-base resolveManual: имя коллекции перебивает ручной heading;
	// обложка коллекции подставляется, только если мерчант не загрузил свою
	// (data-own-image). Без данных (demo-сборка) — no-op, SSG остаётся.
	const hydrateCollectionTiles = async () => {
		const tiles = Array.from(
			document.querySelectorAll<HTMLElement>('[data-nt="flux-collection-card"][data-collection-ref]'),
		);
		if (tiles.length === 0) return;
		const collections = await loadRealCollections();
		if (!collections) return;
		for (const tile of tiles) {
			const col = findCollection(collections, tile.getAttribute("data-collection-ref"));
			if (!col) continue;
			if (col.name) {
				const h3 = tile.querySelector(".flux-collection-name");
				if (h3 && h3.textContent !== col.name) h3.textContent = col.name;
				tile.setAttribute("aria-label", col.name);
			}
			const cover = col.image || (Array.isArray(col.images) ? col.images[0] : "");
			if (cover && tile.getAttribute("data-own-image") !== "true") {
				const img = tile.querySelector("img");
				if (img && img.getAttribute("src") !== cover) {
					img.setAttribute("src", cover);
					if (col.name) img.setAttribute("alt", col.name);
				}
			}
		}
	};

	// АВТОПОДСТАНОВКА: пустой пикер (SSR = плейсхолдеры «Коллекция») → реальные
	// коллекции магазина из /data/collections.json (live) / storefront-data (превью).
	// Явный выбор в пикере имеет приоритет (грид не помечен data-collections-autofill).
	// Реальных нет (demo-сборка без collections.json) → no-op, плейсхолдеры остаются.
	// Разметка плитки = эталон верстальщиков (aspect-square, font-roboto-flex
	// text-[16px] md:text-[19px] font-light). Обложка: своя картинка коллекции,
	// иначе иконка-плейсхолдер PH_MEDIA_ICON (контракт Figma 1:19335 / rose-эталон —
	// у секции «Список коллекций» нет мок-ассета; паритет SSR-гарда {c.image ? img : icon}).
	const autofillCollections = async () => {
		const grids = Array.from(document.querySelectorAll<HTMLElement>("ul[data-collections-autofill]"));
		if (grids.length === 0) return;
		const collections = await loadRealCollections();
		if (!collections || collections.length === 0) return;
		const visible = collections.filter((c) => c && c.slug !== "general").slice(0, 6);
		if (visible.length === 0) return;
		const html = visible
			.map((c) => {
				const name = escapeHtml(c.name || "Коллекция");
				const ref = c.slug || c.id || "";
				const href = "/catalog?collection=" + encodeURIComponent(ref);
				const cover = c.image || (Array.isArray(c.images) ? c.images[0] : "");
				const media = cover
					? `<img src="${escapeHtml(cover)}" alt="${name}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]" />`
					: PH_MEDIA_ICON;
				return `<li><a href="${href}" class="group flex flex-col gap-4 transition-transform duration-300 hover:-translate-y-1" aria-label="${name}" data-nt="flux-collection-card">
			<div class="aspect-square w-full overflow-hidden rounded-[12px] bg-[rgb(var(--color-surface,245_245_245))]"${cover ? "" : ' aria-hidden="true"'}>${media}</div>
			<h3 class="flux-collection-name font-roboto-flex text-[16px] font-light leading-normal text-[rgb(var(--color-text,0_0_0))] md:text-[19px]">${name}</h3>
		</a></li>`;
			})
			.join("");
		for (const grid of grids) grid.innerHTML = html;
	};

	hydrateCollectionTiles();
	autofillCollections();
	document.addEventListener("astro:page-load", () => {
		hydrateCollectionTiles();
		autofillCollections();
	});
</script>

<style is:global>
	/* Слайдер «Колонки» (1-6) → grid-template-columns с md (768px) и выше.
	   --cols ставится inline на сетке (data-cols — хук). Селектор с двумя
	   атрибутами (0,2,0) бьёт tailwind .md:grid-cols-4 (0,1,0) без !important. */
	@media (min-width: 768px) {
		[data-nt="collections-grid"][data-cols] {
			grid-template-columns: repeat(var(--cols, 3), minmax(0, 1fr));
		}
	}
</style>
