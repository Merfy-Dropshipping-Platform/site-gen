---
// D-028 (авторитетно): верстка Bloom = НОРМАТИВ. Порт РЕ-ПРОФИЛИРОВАЛ секцию
// «Коллекции» в навигационную сетку плиток-коллекций (collectionPicker → ссылки
// /catalog?collection=) — это регрессия относительно верстки. Здесь секция
// возвращена к НОРМАТИВНОМУ назначению верстальщика: СЕТКА КАРТОЧЕК ТОВАРА
// (src/components/sections/../.. → /tmp/bloom-theme-ref/.../Collections.astro):
// заголовок «Сейчас в тренде», 6 реальных товаров (catalogProducts.slice(0,6))
// через BloomProductCard (картинка + имя + цена + свотчи/размеры + pill
// «В корзину»), без подзаголовка. Рендер карточек переиспользует ту же
// разметку, что PopularProducts порта (BloomProductCard SSR + renderCardHtml
// на гидрации) — чтобы «Коллекции» и «Коллекция товаров» рисовали товары
// единообразно.
//
// Секция остаётся Puck-редактируемой: сохранён section chrome верстальщика
// (заголовок #e38e9f Urbanist 18/md:20 uppercase, контейнер max-w-[1320px],
// паддинги, 1→sm:2→lg:3 сетка + gaps), + редактируемые поля (заголовок/размер,
// текст/размер, колонки, отступы, цветовая схема, выбор коллекции-источника
// товаров). Дефолт и назначение — сетка товаров.
import BloomProductCard from "../products/BloomProductCard.astro";
import { catalogProducts } from "../../data/products";

const p = Astro.props as Record<string, any>;
const id = p.id;

// Заголовок секции: дефолт верстальщика «Сейчас в тренде». aiText пишет плоскую
// строку; nested {text} — legacy-фолбэк. title — ещё один legacy-алиас.
const sectionTitle =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title ?? "Сейчас в тренде";
// Подзаголовка у верстальщика НЕТ (только заголовок + карточки). Рендерим <p>
// ТОЛЬКО когда мерчант задал непустой текст. aiText → плоская строка; nested
// {content} — legacy-фолбэк.
const sectionSubtitle =
	(typeof p.subtitle === "string" ? p.subtitle : p.subtitle?.content) &&
	String(typeof p.subtitle === "string" ? p.subtitle : p.subtitle?.content).trim()
		? String(typeof p.subtitle === "string" ? p.subtitle : p.subtitle?.content)
		: undefined;

// Канон cards (2-24): сколько товаров показать. 6 = срез верстальщика (и
// отсутствие пропа) → дефолт-ветка. Носитель гидрации — data-cards на гриде.
const cardsN =
	typeof p.cards === "number" && p.cards > 0 ? Math.max(2, Math.min(24, Math.round(p.cards))) : 6;

// Канон headingSize: 'medium'/отсутствие = заголовок верстальщика дословно
// (18/md:20 uppercase #e38e9f, токен с пиксель-фоллбеком). Лестница: small
// 15/17, large 22/24 — как было в порте (стиль заголовка не меняем).
const headingCls =
	p.headingSize === "small"
		? "font-urbanist text-[15px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[17px]"
		: p.headingSize === "large"
			? "font-urbanist text-[22px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[24px]"
			: "font-urbanist text-[18px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[20px]";
// Канон subtitleSize: 'small'/отсутствие = body-роль манеры (Inter 300 16px,
// muted); medium ≈1.2× (19), large ≈1.44× (23).
const subtitleCls =
	p.subtitleSize === "medium"
		? "font-inter text-[19px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
		: p.subtitleSize === "large"
			? "font-inter text-[23px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
			: "font-inter text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]";
// Обёртке заголовка класс нужен только при подзаголовке (flex-col gap-2); дефолт
// = прежний `<div data-animate>` без class байт-в-байт (заголовок верстальщика).
const headWrapCls = sectionSubtitle ? "flex flex-col gap-2" : undefined;

// Канон imageView square/portrait/wide (+legacy alias adaptive→wide) — aspect
// карточного медиа. 'square'/отсутствие = 1/1 (aspect-square карточки
// верстальщика); portrait → 430/500, wide → 16/9. Прокидываем inline
// aspect-ratio КАЖДОЙ карточке (BloomProductCard aspectRatio / гидрация
// renderCardHtml) + data-card-aspect на гриде (паритет Popular).
const cardAspectRatio =
	p.imageView === "portrait"
		? "430/500"
		: p.imageView === "wide" || p.imageView === "adaptive"
			? "16/9"
			: "1/1";

// Канон columns 1-6: 3 (canon-default = lg:grid-cols-3 верстальщика) и
// отсутствие → дефолт-ветка (1→sm:2→lg:3). Заданное значение применяется c sm:
// раньше — только с lg, потому на sm-md (640-1023px) залипало 2 и слайдер
// игнорировался. Моб (<sm) всегда 1 (как верстальщик).
const colsRaw =
	typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : undefined;
const cols = colsRaw && colsRaw !== 3 ? colsRaw : undefined;
const gridBase =
	"grid w-full grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3 lg:gap-x-[16px] lg:gap-y-10";
const gridCls = cols
	? "grid w-full grid-cols-1 gap-10 sm:grid-cols-[repeat(var(--cols),minmax(0,1fr))] lg:gap-x-[16px] lg:gap-y-10"
	: gridBase;
const gridStyle = cols ? `--cols:${cols}` : undefined;

// Канон collection (collectionPicker, id или slug) — ИСТОЧНИК товаров секции.
// Носитель — data-collection на гриде; фильтрацию делает гидрация ниже
// (resolveCollectionProducts). Пусто → SSG-демо (catalogProducts верстальщика).
const collectionRef =
	typeof p.collection === "string" && p.collection.trim() ? p.collection.trim() : undefined;

// SSG-дефолт: 6 реальных demo-товаров верстальщика (catalogProducts). При
// публикации конкретного сайта клиентская гидрация (ниже) подменяет их
// реальными товарами (или товарами выбранной коллекции). Первые 3 — priority.
const demoProducts = catalogProducts.slice(0, cardsN);

// SSR-фетч реальных товаров ВЫБРАННОЙ коллекции (Figma-цель: коллекция выбрана →
// реальные товары ПРЯМО в статике, чтобы их видело и ПРЕВЬЮ конструктора — Astro
// Container не исполняет клиентскую module-гидрацию ниже). Паритет Popular.astro.
// siteId инжектит рендер-пайплайн (preview.service / build). Нет коллекции /
// siteId / ошибка → realProducts пуст → секция рендерит demo-товары верстальщика.
const siteId = typeof p.siteId === "string" ? p.siteId : "";
const fmtPrice = (v: unknown): string => {
	const n = typeof v === "number" ? v : parseFloat(String(v ?? ""));
	return Number.isFinite(n) ? `${Math.round(n).toLocaleString("ru-RU")} ₽` : "";
};
let realProducts: any[] = [];
if (collectionRef && siteId) {
	try {
		const base = (import.meta as any).env?.SITES_INTERNAL_BASE ?? "http://localhost:3114";
		const res = await fetch(`${base}/api/sites/${siteId}/storefront-data`).catch(() => null);
		if (res && res.ok) {
			const data: any = await res.json();
			const all: any[] = Array.isArray(data?.products) ? data.products : [];
			const cols: any[] = Array.isArray(data?.collections) ? data.collections : [];
			const matched = cols.find(
				(c) =>
					c &&
					(c.id === collectionRef ||
						c.slug === collectionRef ||
						c.name === collectionRef ||
						c.handle === collectionRef),
			);
			const ids =
				matched && Array.isArray(matched.productIds) && matched.productIds.length
					? new Set(matched.productIds)
					: null;
			const picked = (ids ? all.filter((pr) => pr?.id && ids.has(pr.id)) : all).slice(0, cardsN);
			realProducts = picked.map((pr) => {
				const img =
					Array.isArray(pr?.images) && pr.images[0]
						? typeof pr.images[0] === "string"
							? pr.images[0]
							: (pr.images[0]?.url ?? "")
						: (pr?.image ?? "");
				return {
					id: String(pr?.id ?? ""),
					name: String(pr?.name ?? pr?.title ?? "Товар"),
					image: String(img ?? ""),
					price: fmtPrice(pr?.basePrice ?? pr?.price),
					oldPrice: fmtPrice(pr?.compareAtPrice ?? pr?.oldPrice),
					discount: !!(pr?.compareAtPrice || pr?.oldPrice),
					// BloomProductCard читает colors.length / inStock напрямую — без них
					// SSR падает. storefront-data их не несёт → дефолты: без свотчей, в
					// наличии (как реальный сайт).
					colors: [] as string[],
					inStock: pr?.inStock !== false,
					volume: typeof pr?.volume === "string" ? pr.volume : undefined,
				};
			});
		}
	} catch {
		realProducts = [];
	}
}
const products = realProducts.length > 0 ? realProducts : demoProducts;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id="collections"
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-20 pt-20 md:px-20 md:pb-[120px] md:pt-[120px] 2xl:px-[300px]"
	aria-labelledby="collections-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-10">
		<div
			data-animate
			class={headWrapCls}
			data-puck-subsection-parent={id}
			data-puck-subsection-index="100"
			data-puck-subsection-field="heading"
		>
			<h2 id="collections-title" class={headingCls}>
				{sectionTitle}
			</h2>
			{sectionSubtitle && <p class={subtitleCls}>{sectionSubtitle}</p>}
		</div>

		<ul
			class={gridCls}
			role="list"
			data-animate
			data-animate-delay="0.1s"
			data-nt="collections-grid"
			data-cards={cardsN !== 6 ? String(cardsN) : undefined}
			data-card-aspect={cardAspectRatio}
			data-collection={collectionRef}
			style={gridStyle}
		>
			{products.map((product: any, index: number) => (
				<li data-product-id={product.id}>
					<BloomProductCard product={product} priority={index < 3} aspectRatio={cardAspectRatio} />
				</li>
			))}
		</ul>
	</div>
</section>

<script>
	import { loadRealProducts, loadRealCollections, resolveCollectionProducts, renderCardHtml, escapeHtml } from "../../lib/storefront-hydrate";

	// Реальные товары (Option B, паритет Popular): первые N из /data/products.json
	// (N = data-cards грида, дефолт 6 — срез верстальщика). Выбранная коллекция
	// (data-collection) → фильтр по товарам коллекции. Demo-сборка → no-op
	// (остаётся SSG-разметка demo-товаров верстальщика).
	const hydrateCollections = async () => {
		const grids = Array.from(document.querySelectorAll<HTMLElement>('[data-nt="collections-grid"]'));
		if (grids.length === 0) return;
		const products = await loadRealProducts();
		if (!products) return;
		const needCollections = grids.some((g) => g.getAttribute("data-collection"));
		const collections = needCollections ? await loadRealCollections() : null;
		for (const grid of grids) {
			const limitRaw = Number(grid.getAttribute("data-cards"));
			const limit = Number.isFinite(limitRaw) && limitRaw > 0 ? limitRaw : 6;
			const cardAspect = grid.getAttribute("data-card-aspect") || "1/1";
			const collectionRef = grid.getAttribute("data-collection");
			// Выбрана коллекция → её товары; иначе — первые N всего каталога магазина.
			const pool = collectionRef
				? resolveCollectionProducts(products, collections, collectionRef)
				: products;
			if (pool.length === 0) continue;
			const items = pool.slice(0, limit);
			grid.innerHTML = items
				.map((pr) => `<li data-product-id="${escapeHtml(pr.id)}">${renderCardHtml(pr, cardAspect)}</li>`)
				.join("");
		}
	};

	hydrateCollections();
	document.addEventListener("astro:page-load", hydrateCollections);
</script>
