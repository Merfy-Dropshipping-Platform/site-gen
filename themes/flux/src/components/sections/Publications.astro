---
import FluxPicture from "../img/FluxPicture.astro";

// Фаза B (flux, группа misc): новая канон-секция Publications в манере flux
// (см. themes/flux/MANNER.md §4/§9/§11; rose-эталона НЕТ — эталон процесса
// bloom Publications). Схема полей = packages/theme-base/blocks/Publications/
// Publications.puckConfig.ts.
// ПУСТОЕ СОСТОЯНИЕ (нет реальных публикаций) = ПЛЕЙСХОЛДЕР по контракту Figma
// 1:19335 (3 колонки: пустой image-rect surface + «Колонна» + нейтральный
// текст), НЕ мок-демо верстальщика (обзоры гаджетов + /images/4x/Товар_N.png).
// Когда у магазина есть реальные публикации (SSR fetch /api/sites/<id>/
// publications → fallback publications.json) — рендерим их без изменений
// (Shopify-модель, как theme-base PopularProducts/Collections/MultiColumns:
// пустое = заглушка, данные = реальный контент). Платформенный резолв по
// publicationType остаётся data-атрибутом на гриде.
// Карточки «голые» (без подложек, §4): медиа rounded-8 на surface c hover-zoom,
// подписи Manrope/Roboto Flex. Скролл-анимаций в манере flux нет (§6) — без
// data-animate.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading (string | { text, alignment, size }); canon-default «Публикации».
// Роль = внутренний h2 (contacts.astro:40; cart.astro:76), токен heading
// с фоллбеком чёрного верстальщика.
const heading = typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Публикации");
// Лестница §9 внутреннего h2 (дефолт роли — large): отсутствие пропа и large =
// литерал 24/md:28; medium 20/24, small 17/20.
const headingSize = p.headingSize ?? p.heading?.size;
const headingSizeCls =
	headingSize === "small"
		? "text-[17px] md:text-[20px]"
		: headingSize === "medium"
			? "text-[20px] md:text-[24px]"
			: "text-[24px] md:text-[28px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-comfortaa ${headingSizeCls} font-normal uppercase leading-[1.115] text-[rgb(var(--color-heading,0_0_0))]${headingAlignCls}`;

// Канон columnsCount (slider 1-6) приоритетнее hidden columns (1-4); дефолт 3 =
// лестница грида коллекций верстальщика (Collections.astro:19: 1 → sm:2 → lg:3,
// gap-6); иное значение — CSS-var на lg-брейкпоинте.
const columnsRaw =
	typeof p.columnsCount === "number" ? p.columnsCount : typeof p.columns === "number" ? p.columns : 3;
const columns = Math.max(1, Math.min(6, Math.round(columnsRaw) || 3));
const gridCls =
	columns === 3
		? "grid w-full grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
		: "grid w-full grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-[repeat(var(--pub-cols),minmax(0,1fr))]";
const gridStyle = columns === 3 ? undefined : `--pub-cols:${columns};`;

// Канон cardsCount (slider 1-12) приоритетнее hidden cards (1-4); дефолт 3 карточки.
const cardsRaw =
	typeof p.cardsCount === "number" ? p.cardsCount : typeof p.cards === "number" ? p.cards : 3;
const cards = Math.max(1, Math.min(12, Math.round(cardsRaw) || 3));

// Канон showDateTime (toggle) / legacy dateTime.enabled (hidden) — дата
// рендерится только при true/'true'.
const showDate = String(p.showDateTime ?? p.dateTime?.enabled ?? "false") === "true";

// Канон publicationType (pagePicker) — data-атрибут на гриде для платформенного
// резолва публикаций.
const publicationType =
	typeof p.publicationType === "string" && p.publicationType ? p.publicationType : undefined;

// Реальные публикации: SSR fetch storefront-data (gateway → sites-service) c
// fallback на build-time publications.json (паттерн canonical theme-base
// Publications.astro и bloom-порта). siteId инжектит build pipeline / preview
// controller.
type RawPublication = {
	id: string;
	title?: string;
	slug?: string;
	excerpt?: string;
	coverImageUrl?: string | null;
	publishedAt?: string | null;
};
const siteIdFromRoot = typeof p.siteId === "string" ? p.siteId : "";
let realPublications: RawPublication[] = [];
if (siteIdFromRoot) {
	try {
		const internalBase =
			(import.meta as unknown as { env?: { SITES_INTERNAL_BASE?: string } }).env?.SITES_INTERNAL_BASE ??
			"http://localhost:3114";
		const res = await fetch(`${internalBase}/api/sites/${siteIdFromRoot}/publications`).catch(() => null);
		if (res && res.ok) {
			const data = (await res.json()) as { publications?: RawPublication[] };
			realPublications = data.publications ?? [];
		}
	} catch {
		/* swallow */
	}
}
try {
	if (realPublications.length === 0) {
		const pubData = await import("../data/publications.json");
		realPublications = ((pubData as { default?: RawPublication[] }).default ??
			(pubData as unknown as RawPublication[])) as RawPublication[];
	}
} catch {
	/* swallow — publications.json отсутствует */
}

function formatPubDate(iso: string | null | undefined): string {
	if (!iso) return "";
	try {
		return new Intl.DateTimeFormat("ru-RU", { day: "numeric", month: "long", year: "numeric" }).format(
			new Date(iso),
		);
	} catch {
		return "";
	}
}

// Гейт пустого состояния (Shopify-модель): есть реальные публикации → рендерим
// их; нет — ПЛЕЙСХОЛДЕР по контракту Figma 1:19335 (3 колонки: пустой image-rect
// surface + «Колонна» + нейтральный текст), НЕ мок-демо верстальщика.
const hasRealPublications = realPublications.length > 0;
// Текст-болванка колонок в нейтральном тоне публикаций (как theme-base
// MultiColumns: «Сочетай текст…»); не привязан к товарам/гаджетам.
const PLACEHOLDER_TEXT = "Поделись новостями бренда, гайдами и историями в этом блоке.";
type PubItem = { title: string; date: string; image: string; slug?: string; isPlaceholder: boolean };
const items: PubItem[] = hasRealPublications
	? realPublications.slice(0, cards).map((pub) => ({
			title: pub.title ?? "",
			date: formatPubDate(pub.publishedAt),
			image: pub.coverImageUrl ?? "",
			slug: pub.slug,
			isPlaceholder: false,
		}))
	: Array.from({ length: cards }, () => ({
			title: "Колонна",
			date: "",
			image: "",
			isPlaceholder: true,
		}));

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-16 pt-16 md:px-20 md:pb-24 md:pt-24 2xl:px-80"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-8 md:gap-12">
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}

		<div class={gridCls} style={gridStyle} data-publication-type={publicationType}>
			{
				items.map((item, i) => {
					const href = item.slug ? `/publication/${item.slug}` : undefined;
					const Wrapper = href ? "a" : "article";
					return (
						<Wrapper class="group flex flex-col gap-3 md:gap-4" href={href} data-publication-index={i}>
							{/* Медиа: реальная обложка → FluxPicture; пустое состояние
							   (плейсхолдер или публикация без обложки) → пустой
							   image-rect surface (контракт Figma 1:19335). */}
							<div class="aspect-[4/3] w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))]">
								{item.image && (
									<FluxPicture
										src={item.image}
										alt={item.title}
										width="800"
										height="600"
										loading="lazy"
										class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
									/>
								)}
							</div>
							<div class="flex flex-col gap-1">
								{showDate && !item.isPlaceholder && item.date && (
									<span class="font-roboto-flex text-[12px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] md:text-[14px]">
										{item.date}
									</span>
								)}
								<span class="font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]">
									{item.title}
								</span>
								{item.isPlaceholder && (
									<p class="font-roboto-flex text-[12px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] md:text-[14px]">
										{PLACEHOLDER_TEXT}
									</p>
								)}
							</div>
						</Wrapper>
					);
				})
			}
		</div>
	</div>
</section>
