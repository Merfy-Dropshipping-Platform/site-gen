---
// Канон-секция Slideshow в манере flux (см. themes/flux/MANNER.md). Полотно =
// Hero flux (full-bleed фото; заголовок Roboto Flex uppercase §1; текст Roboto
// Flex 300; чёрная CTA героя §3 / outlined-вариант); 9-grid позиция слайда как
// Hero; навигация — currentColor + активный маркер #FA5109 (акцент §7). Шрифт
// ВЕЗДЕ Roboto Flex (Hero на фото — единственный заголовок темы на Roboto Flex,
// не Comfortaa; §1). Переключение — простой fade (анимаций сверх нет, MANNER §6).
// Параметры скрипту — ТОЛЬКО data-атрибуты (define:vars компилятором секций не
// поддерживается); идемпотентность — data-slideshow-hydrated; реинициализация —
// astro:page-load (его шлёт превью-агент после hot-replace).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон slides[] 1-5 (item: imageUrl|image, heading(string|{text,size}),
// subtitle, text{content,size}, ctaText/ctaUrl | button{text,link}, container,
// position, alignment, colorScheme).
//
// Figma 1:19335 — ПУСТОЕ состояние секции «Слайд-шоу». Пока мерчант НЕ добавил
// слайды (slides пуст), секция показывает ДОСЛОВНЫЙ Figma-плейсхолдер: один
// слайд с дизайн-ассетом /placeholders/landscape-slideshow.png + заголовок
// «Слайд-шоу» + хелпер «Добавь несколько изображений с информацией о своём
// бренде» + кнопка «Кнопка» + точки навигации. Это НЕ дефолт-контент верстальщика
// (прежние 2 слайда-болванки удалены). Когда слайды ЗАДАНЫ — рендерим их.
const PLACEHOLDER_SLIDE_IMAGE = "/placeholders/landscape-slideshow.png";
const PLACEHOLDER_SLIDES = [
	{
		id: "slide-placeholder",
		// Figma 1236-42150: imageUrl пуст → маппинг ниже пометит слайд как isPromptCard,
		// сам подставит PLACEHOLDER_SLIDE_IMAGE фоном и включит белую карточку (boxed).
		imageUrl: "",
		heading: "Слайд-шоу",
		subtitle: "Добавь несколько изображений с информацией о своём бренде",
		ctaText: "Кнопка",
		ctaUrl: "/catalog",
	},
];
const hasSlides = Array.isArray(p.slides) && p.slides.length > 0;
const rawSlides = hasSlides ? p.slides : PLACEHOLDER_SLIDES;

// Заголовок слайда — лестница Hero flux (§9, база-литерал 20/24 = Hero large,
// Hero.astro:94). defaultItemProps пишет heading.size='medium' → medium И
// отсутствие = база 20/24; small ≈0.85× (17/20), large ≈1.2× (24/28). Roboto
// Flex uppercase. ЦВЕТ вынесен в рендер (мобила-стек, паритет rose): база — тёмный
// токен схемы (текст на подложке/карточке снизу), md:белый — ТОЛЬКО на десктоп-
// оверлее поверх фото. Здесь только font+size+вес+регистр (без color-класса).
const slideHeadingCls = (s: string | undefined) =>
	s === "small"
		? "font-roboto-flex text-[17px] font-normal uppercase leading-normal md:text-[20px]"
		: s === "large"
			? "font-roboto-flex text-[24px] font-normal uppercase leading-normal md:text-[28px]"
			: "font-roboto-flex text-[20px] font-normal uppercase leading-normal md:text-[24px]";
// Текст слайда — параллельная лестница Hero-подзаголовка (§9, база-литерал 14/16
// = Hero large, Hero.astro:101). medium И отсутствие = 14/16; small 12/14, large
// 16/18. Roboto Flex 300 (font-light). ЦВЕТ — в рендере (как заголовок).
const slideTextCls = (s: string | undefined) =>
	s === "small"
		? "font-roboto-flex text-[12px] font-light leading-normal md:text-[14px]"
		: s === "large"
			? "font-roboto-flex text-[16px] font-light leading-normal md:text-[18px]"
			: "font-roboto-flex text-[14px] font-light leading-normal md:text-[16px]";

// Per-slide раскладка = мини-Hero (паттерн Hero.astro / rose Slideshow). Каждый
// слайд несёт position (РАЗМЕЩЕНИЕ блока по сетке 3×3) + alignment (выравнивание
// КОНТЕНТА внутри блока, независимо) + container (плашка-подложка boxed).
//   Позиция: вертикаль top / center(=середина) / bottom; горизонталь left/center/
//   right. defaultItemProps пишет position:'center' → дефолтный слайд = середина-
//   центр. Пустой проп (legacy) = низ. Legacy left/right → center-left/center-right.
// Контейнер слайда — flex-col (как Hero.astro:325 / rose): vJustify = вертикаль
// (justify-* по main-axis), hItems = горизонталь (items-* по cross-axis).
const slideLayoutCls = (s: any) => {
	const posRaw = typeof s.position === "string" && s.position ? s.position : "";
	// legacy одиночные left/right (без вертикали) → середина по вертикали.
	const norm = posRaw === "left" ? "center-left" : posRaw === "right" ? "center-right" : posRaw;
	const vPos = norm.startsWith("top")
		? "top"
		: norm.startsWith("bottom")
			? "bottom"
			: norm === "center" || norm.startsWith("center")
				? "middle"
				: ""; // пусто = дефолт верстальщика (низ)
	const hPos = norm.endsWith("left") ? "left" : norm.endsWith("right") ? "right" : "center";
	const vJustifyCls =
		vPos === "top" ? "justify-start" : vPos === "middle" ? "justify-center" : "justify-end";
	const hItemsCls =
		hPos === "left" || (!norm && p.contentAlign === "left")
			? "items-start"
			: hPos === "right"
				? "items-end"
				: "items-center";
	// alignment — НЕЗАВИСИМОЕ выравнивание контента внутри блока (items + text-align).
	const alignItemsCls =
		s.alignment === "left" ? "items-start" : s.alignment === "right" ? "items-end" : "items-center";
	const textAlignCls =
		s.alignment === "left" ? "text-left" : s.alignment === "right" ? "text-right" : "text-center";
	return { vJustifyCls, hItemsCls, alignItemsCls, textAlignCls };
};

// Канон overlay 0-100 — «Затемнение» PER-SLIDE (паритет rose). Читаем s.overlay с
// fallback на section-level p.overlay (backward-compat со старыми данными, где
// overlay был в секции). Хелпер объявлен ВЫШЕ маппинга slides (используется в нём).
const slideOverlayN = (s: any) => Math.max(0, Math.min(100, Number(s.overlay ?? p.overlay) || 0));
const slides = rawSlides.slice(0, 5).map((s: any, i: number) => {
	const ctaText =
		(typeof s.ctaText === "string" && s.ctaText.trim() ? s.ctaText : undefined) ??
		(typeof s.button?.text === "string" && s.button.text.trim() ? s.button.text : undefined);
	// Figma node 1236-42150 (пустое/дефолтное состояние секции): слайд БЕЗ картинки
	// мерчанта = дизайн-подсказка — фото-плейсхолдер landscape-slideshow.png ФОНОМ +
	// белая карточка (boxed) по ЦЕНТРУ полотна (заголовок/подзаголовок/кнопка). Слайд
	// С фото мерчанта — full-bleed как раньше (boxed управляется флагом «Контейнер»).
	const merchantImage =
		(typeof s.imageUrl === "string" && s.imageUrl.trim()) ||
		(typeof s.image === "string" && s.image.trim()) ||
		"";
	const isPromptCard = !merchantImage;
	// Карточка-подсказка включена по умолчанию (Figma), но тумблер «Контейнер: Скрыть»
	// (container==='false') её выключает — тогда слайд без фото = пустая surface-карточка
	// (прежнее поведение). undefined/'true' → карточка.
	const promptBoxed = isPromptCard && String(s.container) !== "false";
	const layout = slideLayoutCls(s);
	return {
		// Figma: карточка-подсказка сидит на фото-плейсхолдере. Выключенная подсказка и
		// реальный слайд без фото → пустая surface (bg-surface, рендер ниже).
		image: merchantImage || (promptBoxed ? PLACEHOLDER_SLIDE_IMAGE : ""),
		heading: typeof s.heading === "string" ? s.heading : (s.heading?.text ?? ""),
		headingCls: slideHeadingCls(typeof s.heading === "object" ? s.heading?.size : undefined),
		subtitle:
			(typeof s.subtitle === "string" && s.subtitle.trim() ? s.subtitle : undefined) ??
			(typeof s.text?.content === "string" && s.text.content.trim() ? s.text.content : undefined),
		textCls: slideTextCls(typeof s.text === "object" ? s.text?.size : undefined),
		ctaText,
		ctaHref:
			(typeof s.ctaUrl === "string" && s.ctaUrl ? s.ctaUrl : undefined) ??
			s.button?.link?.href ??
			(typeof s.button?.link === "string" && s.button.link ? s.button.link : undefined) ??
			"/catalog",
		// Подсказка → карточка (если не выключена тумблером). Реальный слайд с фото → по «Контейнеру».
		boxed: isPromptCard ? promptBoxed : String(s.container ?? "false") === "true",
		schemeCls:
			typeof s.colorScheme === "string" && s.colorScheme
				? ` color-scheme-${String(s.colorScheme).replace("scheme-", "")}`
				: "",
		// Карточка-подсказка центрируется по полотну (Figma: карточка в середине), реальный
		// слайд размещается по своей position (сетка 3×3).
		...(promptBoxed
			? { ...layout, vJustifyCls: "justify-center", hItemsCls: "items-center" }
			: layout),
		overlayN: slideOverlayN(s),
		active: i === 0,
	};
});

// Канон interval (slider 1-20 c, схема до 60) / autoplay: canon-defaults 5 / true.
const intervalMs = String(
	(typeof p.interval === "number" && p.interval >= 1 && p.interval <= 60 ? p.interval : 5) * 1000,
);
const autoplay = p.autoplay === false || p.autoplay === "false" ? "false" : "true";

// Канон size (s/m/l) — высота полотна. МОБИЛА = СТЕК (паритет Hero/rose Slideshow):
// min-h ТОЛЬКО на md+ (на мобиле высота полотна = активный слайд: медиа aspect-[4/3]
// + карточка снизу, в потоке). Раньше высота была clamp с полом 500px и держалась на
// мобиле → полотно было выше стек-контента → карточка «съезжала» вниз с пустотой
// сверху. Десктоп-оверлей: min-h держит высоту фона (все слайды md:absolute), кап
// min(svh,px) — форма манеры flux (пол clamp снят, floor на мобиле не нужен).
const heightCls =
	p.size === "small"
		? "md:min-h-[min(64svh,864px)]"
		: p.size === "large"
			? "md:min-h-[min(92svh,1242px)]"
			: "md:min-h-[min(80svh,1080px)]";

// Канон imagePosition: fullscreen (canon-default; полотно во всю ширину секции,
// как герой) | contained (+legacy left/right) — внутри контейнера манеры с полями
// главной (§2) и радиусом медиа. imageFullBleed=true возвращает full-bleed.
const contained =
	(p.imagePosition === "contained" || p.imagePosition === "left" || p.imagePosition === "right") &&
	p.imageFullBleed !== true &&
	p.imageFullBleed !== "true";

// Мобила = full-bleed стек (медиа во всю ширину + карточка снизу, паритет Hero/rose):
// боковые поля/радиус манеры «в окне» — ТОЛЬКО с md+ (иначе на мобиле рамка + внутренняя
// карточка = «контейнер в контейнере» + двойные боковые отступы). Десктоп-окно (§2)
// цело: max-w-1920 + px-20 2xl:px-80 + вертикальное дыхание py-16, внутри рамка
// max-w-1320 со скруглением медиа. fullscreen = full-bleed во всю ширину секции.
const wrapperCls = contained
	? "mx-auto w-full max-w-[1920px] md:px-20 md:py-16 2xl:px-80"
	: "w-full";
const frameCls = contained ? " max-w-[1320px] md:rounded-[var(--radius-media,8px)]" : "";

// Канон overlay 0-100 — «Затемнение» PER-SLIDE (хелпер slideOverlayN объявлен ВЫШЕ,
// перед маппингом slides, т.к. используется в нём; overlayN теперь поле слайда).

// Канон pagination: 'numbers' (отсутствие = numbers) | dots | counter | lines | none.
const pagination =
	p.pagination === "numbers" ||
	p.pagination === "counter" ||
	p.pagination === "lines" ||
	p.pagination === "none" ||
	p.pagination === "dots"
		? p.pagination
		: "numbers";

// Канон buttonStyle: solid (canon-default) = CTA героя flux дословно — ЧЁРНАЯ
// заливка h-14, белый текст, Roboto Flex uppercase (Hero.astro:198, MANNER §3);
// outlined = чёрный контур того же языка (Hero.astro:197). active:scale в манере
// не используется; чёрная CTA читается и на фото, и на светлой плашке boxed.
const ctaCls =
	p.buttonStyle === "outlined"
		? "inline-flex h-14 w-fit items-center justify-center rounded-[var(--radius-button,6px)] border border-black px-4 font-roboto-flex text-[16px] font-normal uppercase leading-none text-black transition-colors hover:bg-black/5"
		: "inline-flex h-14 w-fit items-center justify-center rounded-[var(--radius-button,6px)] bg-black px-4 font-roboto-flex text-[16px] font-normal uppercase leading-none text-white transition-opacity hover:opacity-90";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
// Стек-секция (мобила): верхний «Отступ» применяется ТОЛЬКО на десктопе (md:pt), на
// мобиле pt=0 — медиа встык под предыдущей секцией (убрать промежуток над медиа,
// паритет Hero/rose). Нижний паддинг (pb) — на всех ширинах.
const paddingVars = p.padding
	? `--ss-pt:${p.padding.top}px;--ss-pb:${p.padding.bottom}px;`
	: undefined;
---

<section
	class="relative w-full overflow-hidden bg-[rgb(var(--color-bg,255_255_255))] pb-[var(--ss-pb,0px)] md:pt-[var(--ss-pt,0px)]"
	data-puck-component-id={id}
	data-flux-slideshow
	data-interval={intervalMs}
	data-autoplay={autoplay}
	style={paddingVars}
>
	<div class={wrapperCls}>
		<div
			class={`relative mx-auto w-full overflow-hidden ${heightCls}${frameCls}`}
		>
			{
				slides.map((s, i) => (
					<div
						data-slide
						class={`transition-opacity duration-500 ease-out relative md:!absolute md:inset-0 md:!block ${s.active ? "opacity-100" : "hidden pointer-events-none opacity-0"}${s.schemeCls}`}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="slides"
					>
						{/* МЕДИА — мобила: блок 4/3 сверху (стек как Hero «Изображение»);
						    десктоп: absolute на весь слайд (оверлей под текстом). Затемнение —
						    ВНУТРИ медиа-обёртки (скоуп на фото, не на карточку снизу, иначе на
						    мобиле затемняли бы и текстовый блок). */}
						<div class="relative z-0 aspect-[4/3] w-full md:absolute md:inset-0 md:aspect-auto">
							{s.image ? (
								<img src={s.image} alt={s.heading || "Слайд"} loading={i === 0 ? "eager" : "lazy"} class="!absolute inset-0 !h-full !w-full object-cover object-center" />
							) : (
								<div class="absolute inset-0 bg-[rgb(var(--color-surface,245_245_245))]" aria-hidden="true" />
							)}
							{s.overlayN > 0 && s.image && (
								<div class="pointer-events-none absolute inset-0 bg-black" style={`opacity:${s.overlayN / 100}`} aria-hidden="true" />
							)}
						</div>
						{/* КОНТЕНТ — мобила: блок ПОД медиа (стек); десктоп: absolute-оверлей
						    поверх фото (сетка 3×3 через vJustify/hItems). «Контейнер» ON →
						    карточка (boxed ниже) = единственный контейнер, обёртка прозрачная
						    (гаттер+зазор), иначе «контейнер внутри контейнера». «Контейнер» OFF
						    → обёртка = подложка (фон схемы) под медиа. Текст на мобиле всегда
						    тёмный (на подложке снизу), белый — только десктоп-оверлей поверх фото. */}
						<div class={`relative z-10 flex w-full flex-col ${s.hItemsCls} ${s.vJustifyCls} ${s.boxed ? "px-4 pt-4 pb-8" : "bg-[rgb(var(--color-bg,255_255_255))] px-4 py-10 md:px-20 md:py-10 2xl:px-80"} md:absolute md:inset-0 md:bg-transparent`}>
							<div
								class={`flex w-full max-w-[432px] flex-col gap-6 ${s.alignItemsCls} ${s.textAlignCls}${s.boxed ? " rounded-[var(--radius-card,8px)] bg-[rgb(var(--color-bg,255_255_255))]/95 p-6 shadow-sm md:p-8 [&_h2]:!text-[rgb(var(--color-heading,0_0_0))] [&_p]:!text-[rgb(var(--color-text,0_0_0))]" : ""}`}
							>
								<div class={`flex flex-col gap-2 ${s.alignItemsCls} ${s.textAlignCls}`}>
									{s.heading && (
										<h2 class={`${s.headingCls} text-[rgb(var(--color-heading,0_0_0))]${s.image && !s.boxed ? " md:text-white" : ""}`}>{s.heading}</h2>
									)}
									{s.subtitle && (
										<p class={`${s.textCls} text-[rgb(var(--color-text,0_0_0))]${s.image && !s.boxed ? " md:text-white" : ""}`}>{s.subtitle}</p>
									)}
								</div>
								{s.ctaText && (
									<a href={s.ctaHref} class={ctaCls}>
										{s.ctaText}
									</a>
								)}
							</div>
						</div>
					</div>
				))
			}

			{
				slides.length > 1 && (
					<>
						{/* Боковые круглые стрелки — только для точек/линий/счётчика. Для «Числа»
						    (canon-default, Figma node 1236-42150) навигация инлайн внутри пагинации:
						    ← 1 2 3 → (стрелки-шевроны вокруг чисел по центру снизу). */}
						{pagination !== "numbers" && (
							<>
								<button
									type="button"
									data-slide-prev
									aria-label="Предыдущий слайд"
									class="absolute left-4 top-1/2 z-20 flex size-10 -translate-y-1/2 items-center justify-center !rounded-full !bg-white/80 !text-black transition-opacity hover:opacity-90"
								>
									<svg class="size-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
										<path d="M15 7l-6 5 6 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
									</svg>
								</button>
								<button
									type="button"
									data-slide-next
									aria-label="Следующий слайд"
									class="absolute right-4 top-1/2 z-20 flex size-10 -translate-y-1/2 items-center justify-center !rounded-full !bg-white/80 !text-black transition-opacity hover:opacity-90"
								>
									<svg class="size-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
										<path d="M9 7l6 5-6 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
									</svg>
								</button>
							</>
						)}
						{pagination !== "none" && (
							<div
								class={`relative z-20 mx-auto mt-5 flex w-fit items-center rounded-full bg-black/35 px-4 py-2 md:absolute md:bottom-5 md:left-1/2 md:mx-0 md:mt-0 md:w-auto md:-translate-x-1/2 md:rounded-none md:bg-transparent md:px-0 md:py-0 ${pagination === "numbers" ? "gap-4" : "gap-2"}`}
							>
								{pagination === "dots" &&
									slides.map((_, i) => (
										<button
											type="button"
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											aria-label={`Слайд ${i + 1}`}
											class="size-2 !rounded-full !bg-white/50 transition-colors data-[active=true]:!bg-[rgb(var(--color-accent,250_81_9))]"
										/>
									))}
								{pagination === "lines" &&
									slides.map((_, i) => (
										<button
											type="button"
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											aria-label={`Слайд ${i + 1}`}
											class="h-0.5 w-6 !bg-white/50 transition-colors data-[active=true]:!bg-[rgb(var(--color-accent,250_81_9))]"
										/>
									))}
								{/* Figma node 1236-42150: ← 1 2 3 → — стрелки-шевроны по краям +
								    числа (активное = акцент #FA5109, неактивные white/60) по центру
								    снизу. Шеврон-стрелки = data-slide-prev/next (навигация числами). */}
								{pagination === "numbers" && (
									<>
										<button
											type="button"
											data-slide-prev
											aria-label="Предыдущий слайд"
											class="flex size-6 items-center justify-center !text-white/70 transition-opacity hover:opacity-100"
										>
											<svg class="size-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
												<path d="M15 7l-6 5 6 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
											</svg>
										</button>
										{slides.map((_, i) => (
											<button
												type="button"
												data-slide-dot
												data-active={i === 0 ? "true" : "false"}
												aria-label={`Слайд ${i + 1}`}
												class="font-roboto-flex text-[16px] font-normal leading-none !text-white/60 transition-colors data-[active=true]:!text-[rgb(var(--color-accent,250_81_9))]"
											>
												{i + 1}
											</button>
										))}
										<button
											type="button"
											data-slide-next
											aria-label="Следующий слайд"
											class="flex size-6 items-center justify-center !text-white/70 transition-opacity hover:opacity-100"
										>
											<svg class="size-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
												<path d="M9 7l6 5-6 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
											</svg>
										</button>
									</>
								)}
								{pagination === "counter" &&
									slides.map((_, i) => (
										<span
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											class="font-roboto-flex text-[14px] font-normal leading-none text-white data-[active=false]:hidden"
										>
											{i + 1} / {slides.length}
										</span>
									))}
							</div>
						)}
					</>
				)
			}

			{/* Figma node 1236-42150 — пустое состояние: декоративная пагинация ← 1 2 3 →
			    поверх слайда-плейсхолдера (реальных слайдов для пролистывания нет, поэтому
			    статичная, без data-slide-*). Активное «1» = акцент #FA5109, «2 3» — white/60;
			    стрелки-шевроны white/70. Зеркалит рабочую numbers-пагинацию выше. На мобиле
			    в потоке под медиа (пилюля), на десктопе absolute по центру снизу. */}
			{
				!hasSlides && (
					<div class="relative z-20 mx-auto mt-5 flex w-fit items-center gap-4 rounded-full bg-black/35 px-4 py-2 md:absolute md:bottom-5 md:left-1/2 md:mx-0 md:mt-0 md:w-auto md:-translate-x-1/2 md:rounded-none md:bg-transparent md:px-0 md:py-0" aria-hidden="true">
						<span class="flex size-6 items-center justify-center text-white/70">
							<svg class="size-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<path d="M15 7l-6 5 6 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</span>
						<span class="font-roboto-flex text-[16px] font-normal leading-none text-[rgb(var(--color-accent,250_81_9))]">1</span>
						<span class="font-roboto-flex text-[16px] font-normal leading-none text-white/60">2</span>
						<span class="font-roboto-flex text-[16px] font-normal leading-none text-white/60">3</span>
						<span class="flex size-6 items-center justify-center text-white/70">
							<svg class="size-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<path d="M9 7l6 5-6 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</span>
					</div>
				)
			}
		</div>
	</div>
</section>

<script is:inline>
	(function () {
		function initOne(root) {
			if (root.dataset.slideshowHydrated === "true") return;
			root.dataset.slideshowHydrated = "true";
			var interval = parseInt(root.dataset.interval || "5000", 10);
			var autoplay = root.dataset.autoplay !== "false";
			var slides = root.querySelectorAll("[data-slide]");
			var dots = root.querySelectorAll("[data-slide-dot]");
			if (slides.length < 2) return;
			var idx = 0,
				timer = null;
			// Простой fade (transition-opacity на слайде) — каскадных анимаций
			// в манере flux нет (MANNER §6). Мобила-стек: неактивный слайд убирается
			// из потока (classList hidden), десктоп держит все слайды absolute поверх
			// друг друга через md:!block (crossfade оверлея, паритет rose).
			function show(n) {
				idx = (n + slides.length) % slides.length;
				for (var j = 0; j < slides.length; j++) {
					slides[j].style.opacity = j === idx ? "1" : "0";
					slides[j].style.pointerEvents = j === idx ? "auto" : "none";
					if (j === idx) slides[j].classList.remove("hidden");
					else slides[j].classList.add("hidden");
				}
				for (var k = 0; k < dots.length; k++) {
					dots[k].setAttribute("data-active", k === idx ? "true" : "false");
				}
			}
			function restart() {
				if (timer) clearInterval(timer);
				if (autoplay)
					timer = setInterval(function () {
						show(idx + 1);
					}, interval);
			}
			root.querySelectorAll("[data-slide-prev]").forEach(function (b) {
				b.addEventListener("click", function () {
					show(idx - 1);
					restart();
				});
			});
			root.querySelectorAll("[data-slide-next]").forEach(function (b) {
				b.addEventListener("click", function () {
					show(idx + 1);
					restart();
				});
			});
			dots.forEach(function (d, i) {
				d.addEventListener("click", function () {
					show(i);
					restart();
				});
			});
			show(0);
			restart();
		}
		function initAll() {
			var roots = document.querySelectorAll("[data-flux-slideshow]");
			for (var k = 0; k < roots.length; k++) initOne(roots[k]);
		}
		initAll();
		// Hot-replace превью вставляет секцию заново (новый узел без флага) и
		// шлёт astro:page-load — реинициализация подхватит свежий слайдер.
		document.addEventListener("astro:page-load", initAll);
	})();
</script>
