---
import Layout from '../layouts/Layout.astro';
import AuthShell from '../components/auth/AuthShell.astro';
import AuthInput from '../components/auth/AuthInput.astro';
import PasswordField from '../components/auth/PasswordField.astro';
import AuthButton from '../components/auth/AuthButton.astro';
import AuthSecondaryLink from '../components/auth/AuthSecondaryLink.astro';

const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";
---
<Layout title="Восстановление пароля">
  <script is:inline define:vars={{ shopId, apiUrl }}>
    window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
      shopId: shopId || "",
      apiUrl: apiUrl || "https://gateway.merfy.ru/api",
    };
  </script>

  <!-- 1. email -->
  <div id="mode-email" class="contents">
    <AuthShell title="Восстановление аккаунта" description="Мы отправим вам код подтверждения на этот e-mail">
      <form id="email-form" class="w-full flex flex-col gap-6" novalidate>
        <AuthInput label="E-mail" type="email" name="email" id="forgot-email" placeholder="example@merfy.ru" required autocomplete="email" />
        <div class="auth-helper-error hidden text-center" id="email-error" role="alert"></div>
      </form>
      <div class="w-full flex flex-col items-center gap-8">
        <AuthButton id="btn-email-continue" form="email-form" loadingLabel="Отправка...">Продолжить</AuthButton>
        <AuthSecondaryLink href="/login" variant="muted">Вернуться назад</AuthSecondaryLink>
      </div>
    </AuthShell>
  </div>

  <!-- 2. OTP (vanilla) -->
  <div id="mode-otp" class="hidden contents">
    <AuthShell title="Восстановление аккаунта" description="Введите код подтверждения с вашего e-mail">
      <div class="w-full flex flex-col items-center gap-20">
        <div class="flex items-center justify-center gap-3" id="otp-group" role="group" aria-label="Код подтверждения">
          <input class="auth-otp-cell" data-otp-cell inputmode="numeric" maxlength="1" autocomplete="one-time-code" data-filled="false" aria-label="Цифра 1" />
          <input class="auth-otp-cell" data-otp-cell inputmode="numeric" maxlength="1" data-filled="false" aria-label="Цифра 2" />
          <input class="auth-otp-cell" data-otp-cell inputmode="numeric" maxlength="1" data-filled="false" aria-label="Цифра 3" />
          <input class="auth-otp-cell" data-otp-cell inputmode="numeric" maxlength="1" data-filled="false" aria-label="Цифра 4" />
        </div>
        <button type="button" class="account-text-link" id="otp-resend" disabled>Отправить код повторно <span id="otp-resend-timer"></span></button>
      </div>
      <div class="w-full flex flex-col items-center gap-8">
        <div class="auth-helper-error hidden text-center" id="otp-error" role="alert"></div>
        <AuthButton id="btn-otp-continue" type="button" loadingLabel="Проверка...">Продолжить</AuthButton>
        <AuthSecondaryLink href="#" id="otp-back" variant="muted">Вернуться назад</AuthSecondaryLink>
      </div>
    </AuthShell>
  </div>

  <!-- 3. new password -->
  <div id="mode-new-password" class="hidden contents">
    <AuthShell title="Новый пароль">
      <form id="new-password-form" class="w-full flex flex-col gap-6" novalidate>
        <PasswordField label="Новый пароль" name="password" id="new-password" placeholder="Минимум 8 символов" required minlength={8} autocomplete="new-password" />
        <PasswordField label="Подтвердите пароль" name="confirmPassword" id="new-confirm" placeholder="Повторите пароль" required minlength={8} autocomplete="new-password" />
        <div class="auth-helper-error hidden text-center" id="new-password-error" role="alert"></div>
      </form>
      <div class="w-full flex flex-col items-center gap-8">
        <AuthButton id="btn-new-password" form="new-password-form" loadingLabel="Сохранение...">Сменить пароль</AuthButton>
        <AuthSecondaryLink href="/login" variant="muted">Вернуться ко входу</AuthSecondaryLink>
      </div>
    </AuthShell>
  </div>

  <!-- legacy token-link (?token=) -->
  <div id="mode-legacy-token" class="hidden contents">
    <AuthShell title="Новый пароль">
      <form id="legacy-form" class="w-full flex flex-col gap-6" novalidate>
        <PasswordField label="Новый пароль" name="password" id="legacy-password" placeholder="Минимум 8 символов" required minlength={8} autocomplete="new-password" />
        <PasswordField label="Подтвердите пароль" name="confirmPassword" id="legacy-confirm" placeholder="Повторите пароль" required minlength={8} autocomplete="new-password" />
        <div class="auth-helper-error hidden text-center" id="legacy-error" role="alert"></div>
      </form>
      <div class="w-full flex flex-col items-center gap-8">
        <AuthButton id="btn-legacy" form="legacy-form" loadingLabel="Сохранение...">Сменить пароль</AuthButton>
        <AuthSecondaryLink href="/login" variant="muted">Вернуться ко входу</AuthSecondaryLink>
      </div>
    </AuthShell>
  </div>

  <script>
    import { navTo, requestResetOTP, verifyResetOTP, resendResetOTP, setNewPassword, resetPassword } from '../lib/auth';

    function initResetPage() {
      const modeEmail = document.getElementById('mode-email');
      if (!modeEmail || modeEmail.dataset.bound === 'true') return;
      modeEmail.dataset.bound = 'true';

      const params = new URLSearchParams(window.location.search);
      const legacyToken = params.get('token');
      const modes = ['mode-email', 'mode-otp', 'mode-new-password', 'mode-legacy-token'].map((id) => document.getElementById(id)!);
      const show = (id: string) => modes.forEach((m) => m.classList.toggle('hidden', m.id !== id));

      if (legacyToken) { show('mode-legacy-token'); setupLegacy(legacyToken); return; }

      const step = params.get('step');
      const emailParam = params.get('email');
      if (step === 'otp' && emailParam) { sessionStorage.setItem('resetEmail', emailParam); show('mode-otp'); setupOtp(emailParam); }
      else if (step === 'new-password' && sessionStorage.getItem('resetCredential')) { show('mode-new-password'); setupNewPassword(sessionStorage.getItem('resetCredential')!); }
      else { show('mode-email'); setupEmail(); }
    }

    // ── step 1: email ──
    function setupEmail() {
      const form = document.getElementById('email-form') as HTMLFormElement;
      const errorEl = document.getElementById('email-error')!;
      const btn = document.getElementById('btn-email-continue') as HTMLButtonElement;
      const loadingEl = btn.querySelector('[data-loading]')!;
      const textEl = btn.querySelector('[data-button-text]')!;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorEl.classList.add('hidden');
        const input = document.getElementById('forgot-email') as HTMLInputElement;
        const email = input.value.trim();
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          input.setAttribute('data-error', 'true');
          errorEl.textContent = 'Введите корректный e-mail';
          errorEl.classList.remove('hidden');
          return;
        }
        input.setAttribute('data-error', 'false');
        loadingEl.classList.remove('hidden'); textEl.classList.add('hidden'); btn.disabled = true;
        try {
          await requestResetOTP({ email });
          sessionStorage.setItem('resetEmail', email);
          window.location.search = '?step=otp&email=' + encodeURIComponent(email);
        } catch (err: any) {
          errorEl.textContent = err?.error?.code === 'RATE_LIMIT_EXCEEDED' ? 'Слишком много запросов. Попробуйте позже' : 'Не удалось отправить код. Попробуйте позже';
          errorEl.classList.remove('hidden');
          loadingEl.classList.add('hidden'); textEl.classList.remove('hidden'); btn.disabled = false;
        }
      });
    }

    // ── step 2: OTP (vanilla) ──
    function setupOtp(email: string) {
      const group = document.getElementById('otp-group')!;
      const cells = Array.from(group.querySelectorAll<HTMLInputElement>('[data-otp-cell]'));
      const errorEl = document.getElementById('otp-error')!;
      const btn = document.getElementById('btn-otp-continue') as HTMLButtonElement;
      const loadingEl = btn.querySelector('[data-loading]')!;
      const textEl = btn.querySelector('[data-button-text]')!;
      const resendBtn = document.getElementById('otp-resend') as HTMLButtonElement;
      const resendTimerEl = document.getElementById('otp-resend-timer')!;
      let submitting = false;
      const code = () => cells.map((c) => c.value).join('');
      const setErr = (on: boolean) => cells.forEach((c) => (c.style.borderColor = on ? '#FCA5A5' : ''));

      cells.forEach((cell, i) => {
        cell.addEventListener('input', () => {
          errorEl.classList.add('hidden'); setErr(false);
          cell.value = cell.value.replace(/\D/g, '').slice(0, 1);
          cell.dataset.filled = cell.value ? 'true' : 'false';
          if (cell.value && i < cells.length - 1) cells[i + 1].focus();
          if (code().length === 4 && !submitting) submit();
        });
        cell.addEventListener('keydown', (e) => { if (e.key === 'Backspace' && !cell.value && i > 0) cells[i - 1].focus(); });
        cell.addEventListener('paste', (e) => {
          e.preventDefault();
          const ds = (e.clipboardData?.getData('text') || '').replace(/\D/g, '').slice(0, 4);
          ds.split('').forEach((d, j) => { if (cells[j]) { cells[j].value = d; cells[j].dataset.filled = 'true'; } });
          if (ds.length) cells[Math.min(ds.length, 3)].focus();
          if (ds.length === 4 && !submitting) submit();
        });
      });

      async function submit() {
        errorEl.classList.add('hidden');
        if (code().length !== 4) { errorEl.textContent = 'Введите все 4 цифры'; errorEl.classList.remove('hidden'); return; }
        submitting = true;
        loadingEl.classList.remove('hidden'); textEl.classList.add('hidden'); btn.disabled = true;
        try {
          const result: any = await verifyResetOTP({ email, code: code() });
          if (result.success && result.data?.resetCredential) {
            sessionStorage.setItem('resetCredential', result.data.resetCredential);
            window.location.search = '?step=new-password';
            return;
          }
          throw result;
        } catch (err: any) {
          const c = err?.error?.code || err?.code;
          let msg = 'Неверный код';
          if (c === 'OTP_EXPIRED') msg = 'Код устарел. Запросите новый';
          else if (c === 'OTP_INVALIDATED') msg = 'Слишком много неверных попыток. Запросите новый код';
          else if (err?.error?.attemptsRemaining !== undefined) msg = 'Неверный код. Осталось попыток: ' + err.error.attemptsRemaining;
          errorEl.textContent = msg; errorEl.classList.remove('hidden'); setErr(true);
        } finally {
          submitting = false;
          loadingEl.classList.add('hidden'); textEl.classList.remove('hidden'); btn.disabled = false;
        }
      }
      btn.addEventListener('click', (e) => { e.preventDefault(); if (!submitting) submit(); });
      document.getElementById('otp-back')!.addEventListener('click', (e) => { e.preventDefault(); sessionStorage.removeItem('resetEmail'); window.location.search = ''; });

      let timer = 0; let handle: number | undefined;
      const tick = () => { if (timer <= 0) { resendBtn.disabled = false; resendTimerEl.textContent = ''; if (handle) clearInterval(handle); return; } resendTimerEl.textContent = `(${timer})`; timer -= 1; };
      const startTimer = (s: number) => { timer = s; resendBtn.disabled = true; if (handle) clearInterval(handle); tick(); handle = window.setInterval(tick, 1000); };
      resendBtn.addEventListener('click', async () => { errorEl.classList.add('hidden'); try { await resendResetOTP({ email }); startTimer(60); } catch { errorEl.textContent = 'Не удалось отправить код повторно'; errorEl.classList.remove('hidden'); } });
      cells[0]?.focus(); startTimer(60);
    }

    // ── step 3: new password ──
    function setupNewPassword(credential: string) {
      const form = document.getElementById('new-password-form') as HTMLFormElement;
      const errorEl = document.getElementById('new-password-error')!;
      const btn = document.getElementById('btn-new-password') as HTMLButtonElement;
      const loadingEl = btn.querySelector('[data-loading]')!;
      const textEl = btn.querySelector('[data-button-text]')!;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorEl.classList.add('hidden');
        const pass = (document.getElementById('new-password') as HTMLInputElement);
        const conf = (document.getElementById('new-confirm') as HTMLInputElement);
        pass.setAttribute('data-error', 'false'); conf.setAttribute('data-error', 'false');
        if (!pass.value || pass.value.length < 8) { pass.setAttribute('data-error', 'true'); errorEl.textContent = 'Пароль должен быть не менее 8 символов'; errorEl.classList.remove('hidden'); return; }
        if (pass.value !== conf.value) { conf.setAttribute('data-error', 'true'); errorEl.textContent = 'Пароли не совпадают'; errorEl.classList.remove('hidden'); return; }
        loadingEl.classList.remove('hidden'); textEl.classList.add('hidden'); btn.disabled = true;
        try {
          const result = await setNewPassword({ resetCredential: credential, password: pass.value });
          if (result.success) { sessionStorage.removeItem('resetCredential'); sessionStorage.removeItem('resetEmail'); navTo('/login'); return; }
          throw result;
        } catch (err: any) {
          const c = err?.error?.code || err?.code;
          let msg = 'Не удалось сменить пароль';
          if (c === 'CREDENTIAL_EXPIRED' || c === 'CREDENTIAL_INVALID') { msg = 'Сессия восстановления истекла. Запросите новый код'; sessionStorage.removeItem('resetCredential'); }
          else if (c === 'PASSWORD_TOO_SHORT') msg = 'Пароль должен быть не менее 8 символов';
          errorEl.textContent = msg; errorEl.classList.remove('hidden');
          loadingEl.classList.add('hidden'); textEl.classList.remove('hidden'); btn.disabled = false;
        }
      });
    }

    // ── legacy token-link ──
    function setupLegacy(token: string) {
      const form = document.getElementById('legacy-form') as HTMLFormElement;
      const errorEl = document.getElementById('legacy-error')!;
      const btn = document.getElementById('btn-legacy') as HTMLButtonElement;
      const loadingEl = btn.querySelector('[data-loading]')!;
      const textEl = btn.querySelector('[data-button-text]')!;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorEl.classList.add('hidden');
        const password = (document.getElementById('legacy-password') as HTMLInputElement).value;
        const confirm = (document.getElementById('legacy-confirm') as HTMLInputElement).value;
        if (password !== confirm) { errorEl.textContent = 'Пароли не совпадают'; errorEl.classList.remove('hidden'); return; }
        if (password.length < 8) { errorEl.textContent = 'Пароль должен быть не менее 8 символов'; errorEl.classList.remove('hidden'); return; }
        loadingEl.classList.remove('hidden'); textEl.classList.add('hidden'); btn.disabled = true;
        try {
          const result = await resetPassword({ token, password });
          if (result.success) { navTo('/account'); return; }
          throw result;
        } catch (err: any) {
          errorEl.textContent = (err?.error === 'TOKEN_EXPIRED' || err?.code === 'TOKEN_EXPIRED') ? 'Ссылка устарела. Запросите новую.' : 'Не удалось сменить пароль';
          errorEl.classList.remove('hidden');
          loadingEl.classList.add('hidden'); textEl.classList.remove('hidden'); btn.disabled = false;
        }
      });
    }

    initResetPage();
    document.addEventListener('astro:page-load', initResetPage);
  </script>
</Layout>
