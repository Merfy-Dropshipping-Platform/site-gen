---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import products from '../../data/products.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  const productList = products || [];
  return productList.map((product: any) => ({
    params: { id: product.slug ?? product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};

// Brand name from site branding
const brandName = (siteConfig as any)?.branding?.shopName || '';

// Images: support both formats
const productImages: string[] = Array.isArray(product?.images)
  ? product.images.filter(Boolean)
  : product?.image
    ? [product.image]
    : [];
const mainImage = productImages[0] || null;
const hasMultipleImages = productImages.length > 1;

// Variants from products.json (added by build pipeline)
const productVariants: Array<{ id: string; title: string; price: string; available: boolean; options?: Record<string, string> }> =
  Array.isArray(product?.variants) ? product.variants : [];
const hasVariants = product?.hasVariants === true && productVariants.length > 0;

// Extract variant groups from options: { "Цвет": ["Черный", "Оливковый", ...], "Размер": ["S", "M", ...] }
interface VariantGroup {
  key: string;
  values: Array<{ value: string; available: boolean }>;
}
const variantGroups: VariantGroup[] = [];
if (hasVariants) {
  const groupMap = new Map<string, Map<string, boolean>>();
  for (const v of productVariants) {
    if (v.options) {
      for (const [key, value] of Object.entries(v.options)) {
        if (!groupMap.has(key)) groupMap.set(key, new Map());
        const valMap = groupMap.get(key)!;
        // A value is available if ANY variant with that value is available
        if (!valMap.has(value) || v.available) {
          valMap.set(value, valMap.get(value) || v.available);
        }
      }
    }
  }
  for (const [key, valMap] of groupMap) {
    variantGroups.push({
      key,
      values: Array.from(valMap.entries()).map(([value, available]) => ({ value, available })),
    });
  }
}

// JSON for JS interactivity
const imagesJson = JSON.stringify(productImages);
const variantsJson = JSON.stringify(productVariants);

// SEO meta tags with fallback logic (T054/T055)
const shopTitle = meta?.title ?? 'Мой магазин';
const rawMetaTitle = product?.metaTitle;
const rawMetaDescription = product?.metaDescription;
const productName = product?.name ?? 'Товар';
const productDescription = product?.description ?? '';

// Title: metaTitle (if non-empty) -> product name
const seoTitle = (rawMetaTitle && rawMetaTitle.trim())
  ? rawMetaTitle.trim()
  : productName;

// Description: metaDescription (if non-empty, as-is) -> truncated product description (160 chars) -> ""
const seoDescription = (rawMetaDescription && rawMetaDescription.trim())
  ? rawMetaDescription.trim()
  : (productDescription && productDescription.trim())
    ? productDescription.trim().slice(0, 160)
    : '';

// Page title includes shop name suffix
const pageTitle = `${seoTitle} — ${shopTitle}`;
---
<BaseLayout
  title={pageTitle}
  description={seoDescription}
  ogTitle={seoTitle}
  ogDescription={seoDescription}
  ogImage={mainImage ?? undefined}
>
  <Header {...headerProps} />

  <main class="flex-1 w-full" style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));">
    <div class="max-w-[768px] mx-auto px-4 sm:px-6 py-[75px]">

      <div class="flex flex-col lg:flex-row gap-[50px]">
        <!-- Image gallery (left column — 400px on desktop) -->
        <div class="w-full lg:w-[400px] lg:shrink-0">
          <!-- Main image -->
          <div
            class="overflow-hidden w-full aspect-square flex items-center justify-center cursor-pointer"
            style="border-radius: 10px; background: rgb(var(--color-foreground) / 0.03);"
            id="main-image-container"
            data-images={imagesJson}
          >
            {mainImage ? (
              <img
                id="main-product-image"
                src={mainImage}
                alt={product?.name ?? 'Товар'}
                class="w-full h-full object-cover"
                loading="eager"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center" style="color: rgb(var(--color-muted));">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21,15 16,10 5,21"/>
                </svg>
              </div>
            )}
          </div>

          <!-- Thumbnails: 2-column grid on desktop, horizontal scroll on mobile -->
          {hasMultipleImages && (
            <div class="flex gap-3 mt-5 overflow-x-auto lg:grid lg:grid-cols-2 lg:gap-5 lg:overflow-visible" id="thumbnail-strip">
              {productImages.slice(1).map((img: string, i: number) => (
                <button
                  type="button"
                  class="thumb-btn overflow-hidden flex-shrink-0 w-[120px] h-[120px] lg:w-full lg:h-auto lg:aspect-square flex items-center justify-center cursor-pointer border-2 border-transparent transition-colors"
                  style="border-radius: 10px; background: rgb(var(--color-foreground) / 0.03);"
                  data-index={i + 1}
                  data-src={img}
                >
                  <img src={img} alt={`${product?.name} — фото ${i + 2}`} class="w-full h-full object-cover" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Product info (right column — 318px on desktop) -->
        <div class="flex flex-col w-full lg:w-[318px]" id="product-info">
          <!-- Brand name -->
          {brandName && (
            <span class="font-body" style="font-size: 16px; line-height: 22px; color: rgb(var(--color-muted));">
              {brandName}
            </span>
          )}

          <!-- Product name -->
          <h1 class="font-body uppercase" style="font-size: 32px; line-height: 44px; color: rgb(var(--color-foreground)); margin: 0;">
            {product?.name}
          </h1>

          <!-- Price -->
          <div class="flex items-center gap-[15px] mt-[5px]">
            <span class="font-body" id="price-display" style="font-size: 24px; line-height: 33px; color: rgb(var(--color-foreground));">
              {product?.price ?? '0 ₽'}
            </span>
            {(product?.oldPrice) && (
              <span class="font-body line-through" id="old-price-display" style="font-size: 16px; line-height: 22px; font-weight: 500; color: rgb(var(--color-muted));">
                {product.oldPrice}
              </span>
            )}
          </div>

          <!-- Variant groups -->
          {hasVariants && variantGroups.length > 0 && (
            <div id="variants-container" data-variants={variantsJson} class="flex flex-col gap-[25px] mt-[25px]">
              {variantGroups.map((group, gi) => (
                <div class="flex flex-col gap-[15px]" data-group-key={group.key}>
                  <span class="font-body" style="font-size: 20px; line-height: 27px; color: rgb(var(--color-muted));">
                    {group.key}
                  </span>
                  <div class="flex flex-wrap gap-[10px]">
                    {group.values.map((opt, oi) => (
                      <button
                        type="button"
                        class="variant-pill font-body cursor-pointer transition-colors"
                        style={`
                          height: 40px;
                          padding: 10px;
                          font-size: 16px;
                          line-height: 22px;
                          border-radius: 8px;
                          ${!opt.available
                            ? 'background: rgba(153,153,153,0.05); border: 1px solid rgb(var(--color-muted)); color: rgb(var(--color-muted)); text-decoration: line-through; cursor: not-allowed;'
                            : gi === 0 && oi === 0
                              ? 'background: rgb(var(--color-foreground)); border: 1px solid rgb(var(--color-foreground)); color: rgb(var(--color-background));'
                              : 'background: transparent; border: 1px solid rgb(var(--color-foreground)); color: rgb(var(--color-foreground));'
                          }
                        `}
                        data-group={group.key}
                        data-value={opt.value}
                        data-available={String(opt.available)}
                        disabled={!opt.available}
                      >
                        {opt.value}
                      </button>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          )}

          <!-- Fallback: flat variant list if no options map -->
          {hasVariants && variantGroups.length === 0 && (
            <div class="flex flex-wrap gap-[10px] mt-[25px]" id="variants-container-flat">
              {productVariants.map((v, i) => (
                <button
                  type="button"
                  class="variant-btn font-body cursor-pointer transition-colors"
                  style={`
                    height: 40px;
                    padding: 10px;
                    font-size: 16px;
                    line-height: 22px;
                    border-radius: 8px;
                    ${!v.available
                      ? 'background: rgba(153,153,153,0.05); border: 1px solid rgb(var(--color-muted)); color: rgb(var(--color-muted)); text-decoration: line-through; cursor: not-allowed;'
                      : i === 0
                        ? 'background: rgb(var(--color-foreground)); border: 1px solid rgb(var(--color-foreground)); color: rgb(var(--color-background));'
                        : 'background: transparent; border: 1px solid rgb(var(--color-foreground)); color: rgb(var(--color-foreground));'
                    }
                  `}
                  data-variant-id={v.id}
                  data-price={v.price}
                  data-available={String(v.available)}
                  disabled={!v.available}
                >
                  {v.title}
                </button>
              ))}
            </div>
          )}

          <!-- Quantity -->
          <div class="flex flex-col gap-[15px] mt-[25px]">
            <span class="font-body" style="font-size: 20px; line-height: 27px; color: rgb(var(--color-muted));">
              Количество
            </span>
            <div class="flex items-center gap-[5px]">
              <button type="button" id="qty-minus" class="w-[40px] h-[40px] flex items-center justify-center cursor-pointer" style="border-radius: 8px; border: 1px solid rgb(var(--color-foreground)); background: rgb(var(--color-background)); color: rgb(var(--color-foreground));">
                <svg width="20" height="20" viewBox="0 0 32 32" fill="none"><path d="M8 16H24" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              </button>
              <div class="w-[40px] h-[40px] flex items-center justify-center" style="border-radius: 10px; background: rgb(var(--color-background));">
                <span id="qty-display" class="font-body" style="font-size: 16px; line-height: 22px; color: rgb(var(--color-foreground));">
                  1
                </span>
              </div>
              <button type="button" id="qty-plus" class="w-[40px] h-[40px] flex items-center justify-center cursor-pointer" style="border-radius: 8px; border: 1px solid rgb(var(--color-foreground)); background: rgb(var(--color-background)); color: rgb(var(--color-foreground));">
                <svg width="20" height="20" viewBox="0 0 32 32" fill="none"><path d="M16 8V24M8 16H24" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              </button>
            </div>
          </div>

          <!-- Cart buttons -->
          <div class="flex flex-col gap-[15px] mt-[25px]">
            <button
              type="button"
              id="add-to-cart-btn"
              class="w-full flex items-center justify-center font-body cursor-pointer transition-colors"
              style="height: 60px; font-size: 20px; line-height: 27px; border-radius: 10px; background: transparent; border: 1px solid rgb(var(--color-foreground)); color: rgb(var(--color-foreground));"
              data-product-id={product?.id}
              data-product-slug={product?.slug ?? product?.id}
            >
              Добавить в корзину
            </button>
            <button
              type="button"
              id="buy-now-btn"
              class="w-full flex items-center justify-center font-body cursor-pointer transition-colors border-0"
              style="height: 60px; font-size: 20px; line-height: 27px; border-radius: 10px; background: rgb(var(--color-foreground)); color: rgb(var(--color-background));"
              data-product-id={product?.id}
              data-product-slug={product?.slug ?? product?.id}
            >
              Купить сейчас
            </button>
          </div>

          <!-- Description -->
          {product?.description && (
            <div class="flex flex-col gap-[15px] mt-[25px]">
              <h2 class="font-body uppercase" style="font-size: 20px; line-height: 27px; color: rgb(var(--color-foreground)); margin: 0;">
                Описание
              </h2>
              <p class="font-body whitespace-pre-line" style="font-size: 16px; line-height: 22px; color: rgb(var(--color-muted)); margin: 0;">
                {product.description}
              </p>
            </div>
          )}

          <!-- Share -->
          <button type="button" id="share-btn" class="flex items-center gap-[15px] mt-[25px] bg-transparent p-0 border-0 cursor-pointer hover:opacity-80 transition-opacity" style="color: rgb(var(--color-foreground));">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 6L12 3M12 3L15 6M12 3V13M7.00023 10C6.06835 10 5.60241 10 5.23486 10.1522C4.74481 10.3552 4.35523 10.7448 4.15224 11.2349C4 11.6024 4 12.0681 4 13V17.8C4 18.9201 4 19.4798 4.21799 19.9076C4.40973 20.2839 4.71547 20.5905 5.0918 20.7822C5.5192 21 6.07899 21 7.19691 21H16.8036C17.9215 21 18.4805 21 18.9079 20.7822C19.2842 20.5905 19.5905 20.2839 19.7822 19.9076C20 19.4802 20 18.921 20 17.8031V13C20 12.0681 19.9999 11.6024 19.8477 11.2349C19.6447 10.7448 19.2554 10.3552 18.7654 10.1522C18.3978 10 17.9319 10 17 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="font-body" style="font-size: 16px; line-height: 22px;">Поделиться</span>
          </button>
        </div>
      </div>
    </div>
  </main>

  <Footer {...footerProps} />
</BaseLayout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/css/glightbox.min.css" />
<script src="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/js/glightbox.min.js" defer></script>
<script src="/scripts/product-detail.js" defer></script>
