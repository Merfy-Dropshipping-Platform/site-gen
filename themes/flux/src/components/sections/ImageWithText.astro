---
// Секция ImageWithText («Изображение с текстом») в манере flux. Секции нет у
// верстальщика flux (всего 4, MANNER §10) — дизайним в ЕДИНОМ flux-языке: ВСЯ
// секция на font-roboto-flex (заголовок/текст/кнопка); прежний дрейф на
// comfortaa/manrope (наследие разошедшегося product-grid порта) УДАЛЁН. Эталон
// процесса/типографики — flux MainText.astro (заголовок roboto-flex uppercase
// 19/23, тело roboto-flex 300 16/19, чёрная CTA h-14). Медиа — flux-манера §4
// (rounded на медиа, surface #F5F5F5, мягкий hover-zoom). Скролл-анимаций НЕТ —
// манера flux статична (MANNER §6).
//
// НАСТРОЙКИ = паритет rose ImageWithText (themes/rose/.../ImageWithText.astro):
// те же поля heading/headingSize/text/textSize/image/imagePosition/button/
// buttonStyle/alignment/size/width/padding/colorScheme (+ hidden ctaPosition/
// textStyle/containerColorScheme). Схема — packages/theme-base/blocks/
// ImageWithText/ImageWithText.puckConfig.ts. Ступени размеров — НА БАЗЕ
// flux-размеров (19/23 заголовок, 16/19 текст), НЕ раздутые. colorScheme
// навешивается обёрткой composeV2Page; фон секции = bg-токен с белым фоллбеком.
const p = Astro.props as Record<string, any>;
const id = p.id;

// heading: string | { text, alignment, size }; text: string | { content, size }.
// Figma 1:19335 — ПУСТОЕ состояние секции «Изображение с текстом»: дословные
// плейсхолдеры «Изображение с текстом» / «Покажи и расскажи о своем товаре в одном
// блоке» / кнопка «Кнопка» (НЕ дефолт-копирайт верстальщика). Мерчант задал свой
// heading/text/button → его и рендерим (ветки union ниже сохраняются). Эталон —
// rose ImageWithText.astro.
const heading =
	(typeof p.heading === "string" ? p.heading : p.heading?.text)?.trim() || "Изображение с текстом";
const text =
	(typeof p.text === "string" ? p.text : p.text?.content)?.trim() ||
	"Покажи и расскажи о своем товаре в одном блоке";

// Канон headingSize (heading.size сабпанели приоритетнее legacy headingSize).
// База flux = 19/md:23 (эталон MainText/Popular/Collections). 'medium'
// (canon-default) и отсутствие = база; small ступень ниже, large выше. Заголовок —
// roboto-flex uppercase, цвет = heading-токен с чёрным фоллбеком (§7) → colorScheme
// перекрашивает.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[16px] md:text-[19px]"
		: headingSize === "large"
			? "text-[23px] md:text-[29px]"
			: "text-[19px] md:text-[23px]"; // medium (canon-default) + absent
const headingCls = `font-roboto-flex font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))] ${headingSizeCls}`;

// Канон textSize (text.size сабпанели приоритетнее legacy textSize). База flux =
// 16/md:19 (паритет MainText/Popular textSize medium). 'medium' (canon-default) и
// отсутствие = база; small ниже, large выше. Тело — roboto-flex 300 (font-light),
// читаемый leading; цвет = text-токен с чёрным фоллбеком (§7).
const textSize = p.textSize ?? p.text?.size;
const textSizeCls =
	textSize === "small"
		? "text-[14px] md:text-[16px]"
		: textSize === "large"
			? "text-[19px] md:text-[23px]"
			: "text-[16px] md:text-[19px]"; // medium (canon-default) + absent
const textCls = `font-roboto-flex font-light leading-relaxed text-[rgb(var(--color-text,0_0_0))] ${textSizeCls}`;

// Канон textStyle (hidden, 084): italic → курсив заголовка и текста.
const italicCls = p.textStyle === "italic" ? " italic" : "";

// Bug-2 (паритет rose): «Выравнивание» — секция-уровневый проп (Figma 1:17086),
// применяется к заголовку + тексту + кнопке. Back-compat: старые ревизии хранили
// выравнивание в заголовке → fallback headingAlignment / heading.alignment.
// Выравнивание = text-align (flux-колонка flex-col items-stretch, дети тянутся на
// всю ширину → визуальное выравнивание через text-* + !important поверх токенов).
const sectionAlignment = p.alignment ?? p.headingAlignment ?? p.heading?.alignment;
const alignCls =
	sectionAlignment === "center"
		? " !text-center"
		: sectionAlignment === "right"
			? " !text-right"
			: "";

// Канон image {url, alt} + legacy flat imageUrl / image-as-string. Плейсхолдер
// (Figma 1:19335, контракт картиночных секций): без выбранной картинки = дизайн-
// ассет /placeholders/landscape-iwt.png (раздаётся на каждой теме из
// packages/theme-base/public/placeholders, copyPublic), а НЕ мок-фото верстальщика
// и НЕ пустой surface-rect — картинка показывается ВСЕГДА.
const imageUrl =
	(typeof p.image?.url === "string" && p.image.url.trim() ? p.image.url : undefined) ??
	(typeof p.imageUrl === "string" && p.imageUrl.trim() ? p.imageUrl : undefined) ??
	(typeof p.image === "string" && p.image.trim() ? p.image : undefined) ??
	"/placeholders/landscape-iwt.png";
const imageAlt = typeof p.image?.alt === "string" && p.image.alt.trim() ? p.image.alt : heading;

// Канон imagePosition: 'left' (canon-default) и отсутствие = картинка слева, текст
// справа; 'right' — lg:order-зеркало. На мобиле картинка всегда сверху (медиа
// первым в DOM).
const imageRight = p.imagePosition === "right";

// Канон size (s/m/l) — аспект медиа лестницей манеры §4 (паритет rose): small =
// широкая плитка галереи 429/309, medium (canon-default) = высокая плитка 429/444,
// large = карточная вертикаль коллекции 430/500. Литералы flux (Gallery /
// FluxCollectionCard).
const aspectCls =
	p.size === "small"
		? "aspect-[429/309]"
		: p.size === "large"
			? "aspect-[430/500]"
			: "aspect-[429/444]";

// Канон width (s/m/l/full): large/отсутствие = 1320 (контентный контейнер манеры
// §2), medium 1080, small 780, full — без лимита (поля секции остаются).
const widthCls =
	p.width === "small"
		? "max-w-[780px]"
		: p.width === "medium"
			? "max-w-[1080px]"
			: p.width === "full"
				? "max-w-none"
				: "max-w-[1320px]";

// Канон containerColorScheme (hidden, 084): класс схемы на внутреннем контейнере.
const containerSchemeCls =
	typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";

// Кнопка: canon button {text, href|link}. Мерчант задал текст → его; пусто →
// дословный Figma-плейсхолдер «Кнопка» (1:19335). Кнопка рендерится всегда (часть
// дизайна пустого состояния), как «Кнопка» в MainText/Hero плейсхолдерах (эталон
// rose ImageWithText.astro).
const btnText =
	typeof p.button?.text === "string" && p.button.text.trim() ? p.button.text : "Кнопка";
const btnHref =
	(typeof p.button?.href === "string" && p.button.href ? p.button.href : undefined) ??
	p.button?.link?.href ??
	(typeof p.button?.link === "string" && p.button.link ? p.button.link : undefined) ??
	"/catalog";

// Канон buttonStyle: solid/отсутствие = чёрная CTA манеры flux (эталон Hero/
// MainText: h-14 rounded-6 px-4 roboto-flex 16 uppercase leading-none,
// hover:opacity-90; в схемах flux чёрная кнопка = кнопка-2, MANNER §7). outlined =
// бордер/текст цвета заливки на прозрачном. active:scale в манере flux НЕ
// используется (§3).
const btnBase =
	"inline-flex h-14 items-center justify-center rounded-[var(--radius-button,6px)] px-4 font-roboto-flex text-[16px] font-normal uppercase leading-none transition-opacity hover:opacity-90";
const btnCls =
	p.buttonStyle === "outlined"
		? `${btnBase} border border-solid border-[rgb(var(--color-button-2-bg,0_0_0))] bg-transparent text-[rgb(var(--color-button-2-bg,0_0_0))]`
		: `${btnBase} bg-[rgb(var(--color-button-2-bg,0_0_0))] text-[rgb(var(--color-button-2-text,255_255_255))]`;

// Канон ctaPosition (hidden, 084): inline (default) | bottom-pinned → кнопка
// прижимается к нижней кромке текстовой колонки (mt-auto, колонка h-full).
const bottomPinned = p.ctaPosition === "bottom-pinned";

// Канон padding {top,bottom} — inline-override вертикали ТОЛЬКО при заданном пропе
// (паттерн MainText/Popular): тогда py-классы контейнера снимаются, чтобы не было
// двойного отступа. Иначе эталонная вертикаль py-10 md:py-16.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

// Контейнер = flux-эталон (носитель темы как Header/Footer/MainText: mx-auto
// max-w-[1920px] px-4 md:px-20 2xl:px-80). Вертикаль py-10 md:py-16 (канон); при
// заданном padding (настройка) py-классы убираются — inline-стиль ставит
// padding-top/bottom.
const containerCls = paddingStyle
	? "mx-auto w-full max-w-[1920px] px-4 md:px-20 2xl:px-80"
	: "mx-auto w-full max-w-[1920px] px-4 py-10 md:px-20 md:py-16 2xl:px-80";

const titleId = id ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
>
	<div class={containerCls} style={paddingStyle}>
		{/* Контентный грид: ширина widthCls (настройка «Ширина»), 2 колонки на lg.
		    Ритм неравномерный — зазор колонок gap-6 md:gap-8 lg:gap-10 (манера flux). */}
		<div class={`mx-auto grid w-full ${widthCls} grid-cols-1 gap-6 md:gap-8 lg:grid-cols-2 lg:items-center lg:gap-10${containerSchemeCls}`}>
			<div
				class={`group relative w-full overflow-hidden rounded-[12px] bg-[rgb(var(--color-surface,245_245_245))] ${aspectCls}${imageRight ? " lg:order-2" : ""}`}
				data-puck-subsection-parent={id}
				data-puck-subsection-index="100"
				data-puck-subsection-field="image"
			>
				{imageUrl && (
					<img
						src={imageUrl}
						alt={imageAlt}
						loading="lazy"
						class="absolute inset-0 size-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.02]"
					/>
				)}
			</div>

			{/* h-full только при bottom-pinned (иначе ломает lg:items-center грида). */}
			<div class={`flex w-full flex-col gap-6 md:gap-8${bottomPinned ? " h-full" : ""}${imageRight ? " lg:order-1" : ""}`}>
				{/* Внутренняя группа [заголовок+текст] gap-2 md:gap-4, группа↔кнопка
				    gap-6 md:gap-8 (внешний gap колонки) — ритм flux (эталон MainText). */}
				<div class="flex w-full flex-col gap-2 md:gap-4">
					<h2
						id={titleId}
						class={headingCls + alignCls + italicCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="101"
						data-puck-subsection-field="heading"
					>
						{heading}
					</h2>
					<div
						class={textCls + alignCls + italicCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="102"
						data-puck-subsection-field="text"
						set:html={text}
					/>
				</div>
				{
					btnText && (
						<div class={(bottomPinned ? "mt-auto" : "mt-2") + alignCls}>
							<a
								href={btnHref}
								class={btnCls}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="103"
								data-puck-subsection-field="button"
							>
								{btnText}
							</a>
						</div>
					)
				}
			</div>
		</div>
	</div>
</section>
