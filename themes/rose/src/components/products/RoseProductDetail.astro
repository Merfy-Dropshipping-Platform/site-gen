				var selected = Object.assign({}, firstAvailable.options || {});

				function applyCombo() {
					var combo = findCombination(combos, selected);
					var priceVal = combo && combo.price ? combo.price : p.price;
					setText("[data-pdp-price]", formatPrice(priceVal));
					// Старая цена комбинации (если есть).
					var comboOld = formatPrice((combo && combo.compareAtPrice) || p.oldPrice || p.compareAtPrice || null);
					var oEl = section.querySelector("[data-pdp-oldprice]");
					if (oEl) { oEl.textContent = comboOld; oEl.hidden = !comboOld; }
					var available = combo
						? combo.available !== false && (combo.quantity == null || combo.quantity > 0)
						: false;
					for (var c = 0; c < ctas.length; c++) {
						var b = section.querySelector(ctas[c]);
						if (!b) continue;
						b.setAttribute("data-price", formatPrice(priceVal));
						b.setAttribute("data-old-price", comboOld);
						b.setAttribute("data-variant-combination-id", (combo && combo.id) || "");
						b.setAttribute("data-variant-color", pick(combo && combo.options, COLOR_KEYS));
						b.setAttribute("data-variant-size", pick(combo && combo.options, SIZE_KEYS));
					}
					var addEl = section.querySelector("[data-add-to-cart]");
					if (addEl) {
						addEl.disabled = !available;
						addEl.classList.toggle("opacity-50", !available);
						addEl.classList.toggle("pointer-events-none", !available);
						addEl.textContent = available ? "Добавить в корзину" : "Нет в наличии";
					}
					// Свап галереи под выбранный вариант: медиа опции (цвет) при
					// наличии, иначе медиа товара. Чинит баг «фото не меняется».
					var vImgs = variantImagesFor(selected);
					applyGallery(vImgs && vImgs.length ? vImgs : productGalleryImages);
				}

				variantsEl.hidden = false;
				variantsEl.innerHTML = renderVariantGroupsHtml(groups, selected);
				applyCombo();

				variantsEl.onclick = function (e) {
					var btn = e.target.closest("[data-variant-value]");
					if (!btn) return;
					var groupEl = btn.closest("[data-pdp-variant-group]");
					var group = groupEl && groupEl.getAttribute("data-pdp-variant-group");
					var value = btn.getAttribute("data-variant-value");
					if (!group || value == null) return;
					selected[group] = value;
					variantsEl.innerHTML = renderVariantGroupsHtml(groups, selected);
					applyCombo();
				};
			} else if (variantsEl) {
				// Невариативный реальный товар — demo color-row убираем.
				variantsEl.hidden = true;
				variantsEl.innerHTML = "";
			}
		}

		// ─── UI: количество (±), миниатюры, поделиться, купить сейчас ───
		function syncQtyToCtas(qty) {
			var section = document.querySelector("[data-pdp-section]");
			if (!section) return;
			var ctas = section.querySelectorAll("[data-add-to-cart], [data-action='buy-now']");
			for (var i = 0; i < ctas.length; i++) ctas[i].setAttribute("data-quantity", String(qty));
		}

		function initRoseProductUi() {
			var section = document.querySelector("[data-pdp-section]");
			if (!section) return;
			// Идемпотентность при View Transitions (astro:page-load): не вешаем
			// обработчики повторно на ту же секцию.
			if (section.getAttribute("data-pdp-ui-bound") === "1") return;
			section.setAttribute("data-pdp-ui-bound", "1");

			// Количество (±). Делегируем на секцию — миниатюры/варианты перерисовывают
			// свой innerHTML, но counter статичен, поэтому прямые слушатели ок.
			var qtyInput = section.querySelector("[data-pdp-qty-value]");
			var dec = section.querySelector("[data-action='qty-dec']");
			var inc = section.querySelector("[data-action='qty-inc']");
			if (dec && qtyInput) {
				dec.addEventListener("click", function () {
					var next = Math.max(1, Number(qtyInput.value || 1) - 1);
					qtyInput.value = String(next);
					syncQtyToCtas(next);
				});
			}
			if (inc && qtyInput) {
				inc.addEventListener("click", function () {
					var next = Number(qtyInput.value || 1) + 1;
					qtyInput.value = String(next);
					syncQtyToCtas(next);
				});
			}
			if (qtyInput) {
				qtyInput.addEventListener("input", function () {
					var value = Math.max(1, Number(qtyInput.value || 1));
					qtyInput.value = String(value);
					syncQtyToCtas(value);
				});
			}

			// Миниатюры: делегат на секцию (innerHTML миниатюр перерисовывается
			// гидрацией) — свапаем главное фото + синкаем data-image на CTA.
			section.addEventListener("click", function (ev) {
				var thumb = ev.target.closest("[data-pdp-thumb]");
				if (!thumb || !section.contains(thumb)) return;
				var img = thumb.getAttribute("data-image");
				var mainEl = section.querySelector("[data-pdp-main]");
				if (mainEl && img) {
					mainEl.src = img;
					var pic = mainEl.closest("picture");
					var s = pic && pic.querySelector("source");
					if (s) s.removeAttribute("srcset");
				}
				var add = section.querySelector("[data-add-to-cart]");
				var buy = section.querySelector("[data-action='buy-now']");
				if (add) add.setAttribute("data-image", img || "");
				if (buy) buy.setAttribute("data-image", img || "");
			});

			// Поделиться.
			var shareBtn = section.querySelector("[data-action='share']");
			if (shareBtn) {
				shareBtn.addEventListener("click", async function () {
					try {
						if (navigator.share) {
							await navigator.share({ title: document.title, url: location.href });
						} else if (navigator.clipboard) {
							await navigator.clipboard.writeText(location.href);
							var span = shareBtn.querySelector("span");
							if (span) {
								var orig = span.textContent;
								span.textContent = "Ссылка скопирована!";
								setTimeout(function () { span.textContent = orig; }, 1500);
							}
						}
					} catch (e) { /* пользователь отменил */ }
				});
			}

			// «Купить сейчас» = ЭКСПРЕСС: оформляем ТОЛЬКО выбранный товар, корзину
			// покупателя (nt-cart) НЕ трогаем. Передаём товар в /checkout через URL
			// (?buynow=<id>&v=<combo>&q=<qty>); checkout-sync соберёт серверную корзину
			// из этих параметров, а не из nt-cart. Так повторный buy-now всегда даёт
			// именно нажатый товар, а накопленная корзина сохраняется нетронутой.
			// На превью конструктора этот hard-nav перехватывает nav-агент iframe.
			var buyBtn = section.querySelector("[data-action='buy-now']");
			if (buyBtn) {
				buyBtn.addEventListener("click", function () {
					if (buyBtn.disabled) return;
					var add = section.querySelector("[data-add-to-cart]");
					if (!add || add.disabled) return;
					var pid = add.getAttribute("data-product-id") || "";
					if (!pid) return;
					var vci = add.getAttribute("data-variant-combination-id") || "";
					var qty = add.getAttribute("data-quantity") || "1";
					window.location.href =
						"/checkout?buynow=" + encodeURIComponent(pid) +
						(vci ? "&v=" + encodeURIComponent(vci) : "") +
						"&q=" + encodeURIComponent(qty);
				});
			}
		}

		function bootProduct() {
			hydrateProductPage();
			initRoseProductUi();
		}

		bootProduct();
		document.addEventListener("astro:page-load", bootProduct);
	})();
</script>
