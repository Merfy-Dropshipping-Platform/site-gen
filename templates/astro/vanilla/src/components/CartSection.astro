---
interface Props {
  colorScheme?: string;
  padding?: { top?: number; bottom?: number };
}

const { colorScheme, padding } = Astro.props;
const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';
const padTop = padding?.top ?? 75;
const padBottom = padding?.bottom ?? 75;
---

<section class={schemeClass} style={`padding-top: ${padTop}px; padding-bottom: ${padBottom}px; background: rgb(var(--color-background)); color: rgb(var(--color-foreground));`}>
  <div class="max-w-[768px] mx-auto px-4 sm:px-6">

    <h2 class="font-heading uppercase" style="font-size: 24px; line-height: 27px; color: rgb(var(--color-foreground)); margin: 0 0 25px 0;">
      Корзина
    </h2>

    <div id="cart-page-empty" style="display: none;">
      <div class="flex flex-col items-center py-16 gap-4">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="color: rgb(var(--color-muted));">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <p class="font-body" style="font-size: 20px; line-height: 27px; color: rgb(var(--color-muted));">
          Корзина пуста
        </p>
        <a href="/catalog" class="font-body" style="font-size: 16px; line-height: 22px; color: rgb(var(--color-foreground)); text-decoration: underline;">
          Перейти в каталог
        </a>
      </div>
    </div>

    <div id="cart-page-content" style="display: none;">
      <div id="cart-page-items" class="flex flex-col" style="gap: 50px;"></div>

      <div class="flex flex-col items-end mt-[50px]" style="gap: 25px;">
        <p class="font-body" style="font-size: 16px; line-height: 22px; color: rgb(var(--color-muted)); text-align: right; margin: 0; max-width: 318px;">
          Налоги, скидки и стоимость доставки рассчитываются при оформлении заказа.
        </p>
        <div class="flex items-center" style="gap: 15px;">
          <span class="font-body" style="font-size: 20px; line-height: 27px; color: rgb(var(--color-foreground));">
            Итого
          </span>
          <span id="cart-page-total" class="font-body" style="font-size: 20px; line-height: 27px; color: rgb(var(--color-foreground));">
            0 ₽
          </span>
        </div>
        <a href="/checkout" class="flex items-center justify-center font-body cursor-pointer transition-colors border-0 no-underline" style="width: 195px; height: 60px; font-size: 20px; line-height: 27px; border-radius: 0; background: rgb(var(--color-foreground)); color: rgb(var(--color-background));">
          Оформить заказ
        </a>
      </div>
    </div>

  </div>
</section>
