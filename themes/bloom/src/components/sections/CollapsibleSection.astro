---
// Фаза B (bloom, группа misc): новая канон-секция CollapsibleSection в манере
// bloom (см. themes/bloom/MANNER.md; процесс-эталон — rose T16). Схема полей =
// packages/theme-base/blocks/CollapsibleSection/CollapsibleSection.puckConfig.ts.
// Секции нет у верстальщика — нативный <details>/<summary> (Container-safe, без
// JS): заголовок = секционная роль §1 (Urbanist 18/20 uppercase, акцент), вопрос
// Inter 16 400, ответ Inter 16 light muted, разделители = рамка манеры #F5F5F5
// (низ шапки H:49); chevron — /icons/dropdown-chevron.svg с group-open-поворотом
// (tailwind-классы, без <style>-блока).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading: string | { text, alignment, size }. Figma 1:19335 — ПУСТОЕ
// состояние секции «Сворачиваемый раздел»: дословный заголовок-плейсхолдер
// «Сворачиваемый раздел» (а НЕ дефолт-копирайт верстальщика «Часто задаваемые
// вопросы»). Роль = заголовок секции (Collections.astro:18), цвет — токен с
// пиксель-фоллбеком акцента #E38E9F. Мерчант задал свой heading → его и рендерим.
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Сворачиваемый раздел");
// Лестница §9 (база-литерал 18/md:20 = canon-default medium): small 15/17, large 22/24.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[15px] md:text-[17px]"
		: headingSize === "large"
			? "text-[22px] md:text-[24px]"
			: "text-[18px] md:text-[20px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-urbanist ${headingSizeCls} font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))]${headingAlignCls}`;

// Канон sections[] 1-10 {heading, content} (+ pupa items[] {title, content}).
// Curated-модель (как theme-base PopularProducts/Collections): секция показывает
// реальные пункты ТОЛЬКО когда мерчант их добавил. Гейт = наличие sections/items
// в пропах. Пусто → Figma 1:19335 ПУСТОЕ состояние: дословный ряд-плейсхолдер
// «Раздел» + хелпер-текст «Ответь на самые популярные вопросы клиентов» (а НЕ
// мок-вопросы верстальщика). Паттерн пустого состояния как Collections/MultiRows:
// один DEMO-ряд + лейбл/хелпер, без интерактивного <details>. content — set:html.
const PLACEHOLDER_SECTIONS = [
	{ heading: "Раздел", content: "Ответь на самые популярные вопросы клиентов" },
];
const realSections =
	Array.isArray(p.sections) && p.sections.length
		? p.sections
		: Array.isArray(p.items) && p.items.length
			? p.items
			: null;
const hasRealSections = realSections !== null;
const isPlaceholder = !hasRealSections;
const rawSections = hasRealSections ? realSections : PLACEHOLDER_SECTIONS;
const sections = rawSections.slice(0, 10).map((s: any) => ({
	heading:
		(typeof s.heading === "string" && s.heading) || (typeof s.title === "string" && s.title) || "",
	content: typeof s.content === "string" ? s.content : "",
}));

// Канон containerEnabled (toggle; legacy container.enabled). ИСПРАВЛЕНИЕ канона
// (Nikita): «контейнер» = surface-бокс манеры §4 (surface #F5F5F5, радиус карточки
// 12px) НА КАЖДЫЙ вопрос (<li>), а НЕ общий бокс вокруг всего списка. Canon-default
// отсутствует → false = голый список (border-divider верстальщика).
const containerEnabled = String(p.containerEnabled ?? p.container?.enabled ?? "false") === "true";
// Канон Nikita: класс схемы контейнера — ТОЛЬКО при ВКЛ и вешается на ОБЁРТКУ
// СПИСКА (<ul>), НЕ на внешний div с заголовком. При ВЫКЛ → основная (секционная) схема.
const containerSchemeCls =
	containerEnabled && typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";
// listWrapCls на <ul> = ТОЛЬКО класс схемы (без бокса); бокс ушёл на каждый <li>.
const listWrapCls = containerSchemeCls.trim();
// Per-element surface-бокс на КАЖДЫЙ вопрос при ВКЛ (px — горизонтальный паддинг,
// вертикальный даёт py-5 внутри); при ВЫКЛ — border-divider верстальщика (current).
const liBoxCls = containerEnabled
	? "rounded-[var(--radius-card,12px)] bg-[rgb(var(--color-surface,245_245_245))] px-6"
	: "border-b border-solid border-[rgb(var(--color-border,245_245_245))] first:border-t";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-20 pt-20 md:px-20 md:pb-[120px] md:pt-[120px] 2xl:px-[300px]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-10">
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-animate
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
					set:html={heading}
				/>
			)
		}
		<div data-animate data-animate-delay="0.1s">
			<ul class={`flex w-full flex-col${containerEnabled ? " gap-4" : ""}${listWrapCls ? ` ${listWrapCls}` : ""}`} role="list">
				{
					sections.map((s, i) => (
						<li
							class={liBoxCls}
							data-puck-subsection-parent={hasRealSections ? id : undefined}
							data-puck-subsection-index={hasRealSections ? i : undefined}
							data-puck-subsection-field={hasRealSections ? "sections" : undefined}
						>
							{isPlaceholder ? (
								/* Figma 1:19335 ПУСТОЕ состояние: дословный ряд-плейсхолдер —
								   лейбл «Раздел» (роль вопроса) + хелпер-текст «Ответь на самые
								   популярные вопросы клиентов». Без интерактивного <details>:
								   реального ответа нет, помощь видна сразу (паттерн пустого
								   состояния Collections/MultiRows). Шеврон сохранён для вида. */
								<div class="flex w-full flex-col gap-2 py-5">
									<div class="flex w-full items-center justify-between gap-4 font-inter text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))]">
										<span class="min-w-0 flex-1 break-words">{s.heading}</span>
										<img
											src="/icons/dropdown-chevron.svg"
											alt=""
											width="10"
											height="6"
											aria-hidden="true"
											class="shrink-0 rotate-180"
										/>
									</div>
									<p class="font-inter text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]">{s.content}</p>
								</div>
							) : (
								<details class="group">
									<summary class="cursor-pointer list-none py-5 [&::-webkit-details-marker]:hidden">
										<div class="flex w-full items-center justify-between gap-4 font-inter text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70">
											<span class="min-w-0 flex-1 break-words" set:html={s.heading} />
											<img
												src="/icons/dropdown-chevron.svg"
												alt=""
												width="10"
												height="6"
												aria-hidden="true"
												class="shrink-0 transition-transform duration-300 group-open:rotate-180"
											/>
										</div>
									</summary>
									<div
										class="pb-5 font-inter text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
										set:html={s.content}
									/>
								</details>
							)}
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
