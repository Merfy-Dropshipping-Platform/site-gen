---
// CheckoutDeliveryMethod — vanilla Astro + inline script.
// Карточки доставки генерируются от реальной логистики (merfy-logistics-service,
// orders релеит ответ as-is):
//   POST /api/store/carts/<cartId>/delivery/calculate?store_id=<shopId>
//   body: { cityFiasId, postalCode? }
//   → { deliveryOptions[], pickupPoints[] }
// Слушает событие `checkout:address-changed` из CheckoutDeliveryForm.
import type { CheckoutDeliveryMethodProps } from './CheckoutDeliveryMethod.puckConfig';
import { CheckoutDeliveryMethodClasses as C } from './CheckoutDeliveryMethod.classes';

interface Props extends CheckoutDeliveryMethodProps { id?: string; }
const {
  id,
  heading,
  cdekEnabled,
  cdekDoorLabel,
  cdekPvzLabel,
  pickupEnabled,
  pickupLabel,
  freeShippingThresholdCents,
  padding,
} = Astro.props as Props;
const paddingStyle = padding ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;` : '';
---
<section
  class={C.root}
  data-puck-component-id={id}
  data-checkout-delivery-method
  data-cdek-enabled={String(cdekEnabled)}
  data-cdek-door-label={cdekDoorLabel}
  data-cdek-pvz-label={cdekPvzLabel}
  data-pickup-enabled={String(pickupEnabled)}
  data-pickup-label={pickupLabel}
  data-free-shipping-threshold={freeShippingThresholdCents != null ? String(freeShippingThresholdCents) : ''}
  style={paddingStyle}
>
  <h2 class={C.heading}>{heading}</h2>

  {/* Empty state — пока город не выбран. */}
  <div
    data-checkout-delivery-empty
    class="py-4 text-[length:var(--size-small)] [font-family:var(--font-body)] text-[rgb(var(--color-muted))]"
  >
    Заполните адрес доставки чтобы увидеть варианты.
  </div>

  {/* Loading state — пока идёт fetch к логистике. */}
  <div
    data-checkout-delivery-loading
    class="py-4 text-[length:var(--size-small)] [font-family:var(--font-body)] text-[rgb(var(--color-muted))]"
    hidden
  >
    Считаем варианты доставки…
  </div>

  {/* Error state — CDEK ответил ошибкой / нет тарифов. */}
  <div
    data-checkout-delivery-error
    class="py-4 text-[length:var(--size-small)] [font-family:var(--font-body)] text-[rgb(var(--color-error))]"
    hidden
  ></div>

  {/* Live cards — заполняется inline-script'ом из ответа логистики. */}
  <div class={C.list} data-checkout-delivery-list hidden></div>

  {/* CDEK ПВЗ/постамат picker — раскрывается под выбранной cdek_pickup карточкой.
      Сиблинг списка (НЕ внутри [data-checkout-delivery-list]): render() перетирает
      innerHTML списка на каждом пересчёте и снёс бы пикер. */}
  <div data-cdek-pvz-picker hidden></div>
</section>

<script is:inline define:vars={{ blockId: id }}>
  (function () {
    // Spec 102 — свой корень через общий примитив ([data-checkout-delivery-method]
    // стоит на корневом <section>); внутренние элементы — section.querySelector.
    var section = window.__merfyRoot(blockId) || document.querySelector('[data-checkout-delivery-method]'); // merfy-root-allow: page-singleton (один на странице), id undefined на live composed-странице
    if (!section) return;

    var listEl = section.querySelector('[data-checkout-delivery-list]');
    var emptyEl = section.querySelector('[data-checkout-delivery-empty]');
    var loadingEl = section.querySelector('[data-checkout-delivery-loading]');
    var errorEl = section.querySelector('[data-checkout-delivery-error]');

    var pickupEnabled = section.getAttribute('data-pickup-enabled') === 'true';
    var pickupLabel = section.getAttribute('data-pickup-label') || 'Самовывоз';
    var cdekDoorLabel = section.getAttribute('data-cdek-door-label') || 'Курьер до двери';
    var cdekPvzLabel = section.getAttribute('data-cdek-pvz-label') || 'До пункта выдачи';
    var freeThresholdRaw = section.getAttribute('data-free-shipping-threshold') || '';
    var freeShippingThreshold = freeThresholdRaw ? parseInt(freeThresholdRaw, 10) : null;

    // ── CDEK ПВЗ-picker state ──────────────────────────────────────────────
    // Раскрывается под выбранной cdek_pickup карточкой. Точки тянем из того же
    // gateway-эндпоинта, что и rose React-чекаут (/delivery/pickup-points).
    var pickerEl = section.querySelector('[data-cdek-pvz-picker]');
    var pvzCache = {};            // fiasId → точки (кэш на сессию)
    var pvzPoints = null;         // текущие точки (null = ещё грузим/loading)
    var pvzError = false;
    var pvzQuery = '';
    var selectedPvzCode = null;
    var selectedPvzAddress = null;
    var lastOpt = null;           // последняя выбранная опция доставки (для re-emit при выборе точки)
    var pvzListenersBound = false;
    var pvzFias = null;           // город, для которого загружены/выбраны точки (смена → сброс выбора)
    var selectedPickupKind = null; // 'PVZ'|'POSTAMAT' выбранного тарифа — фильтр точек

    // Lazy — конфиг инжектится ПОСЛЕ блоков. Считываем при каждом вызове.
    function getApiBase() {
      return (window.__MERFY_CONFIG__ && window.__MERFY_CONFIG__.apiUrl) || 'https://gateway.merfy.ru/api';
    }
    function getShopId() {
      return (window.__MERFY_CONFIG__ && window.__MERFY_CONFIG__.shopId) || '';
    }

    var OPTION_CLS = 'flex items-center gap-3 px-3 py-4 border border-[rgb(var(--color-input-border))] rounded-[var(--radius-input)] cursor-pointer transition-colors hover:border-[rgb(var(--color-text)/.4)]';
    var OPTION_SELECTED_CLS = 'border-[rgb(var(--color-text))]';
    var BODY_CLS = 'flex-1 flex flex-col min-w-0';
    var LABEL_CLS = '[font-family:var(--font-body)] text-[length:var(--size-small)] text-[rgb(var(--color-text))]';
    var META_CLS = 'mt-0.5 text-[length:var(--size-tiny)] text-[rgb(var(--color-muted))]';
    var PRICE_CLS = '[font-family:var(--font-body)] text-[length:var(--size-tiny)] text-[rgb(var(--color-text))] flex-shrink-0';
    // Radio button (паритет с CheckoutPayment): outer circle + inner dot когда selected
    var RADIO_OUTER_BASE = 'flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full border';
    var RADIO_OUTER_SELECTED = 'bg-[rgb(var(--color-text))] border-[rgb(var(--color-text))]';
    var RADIO_OUTER_UNSELECTED = 'border-[rgb(var(--color-input-border))]';
    var RADIO_DOT = 'block w-2 h-2 rounded-full bg-[rgb(var(--color-bg))]';

    // ── PVZ-picker classes (только rgb(var(--color-*)) — без сырых hex/rgb) ──
    var PVZ_BOX_CLS = 'mt-2 flex flex-col gap-2 border border-[rgb(var(--color-input-border))] rounded-[var(--radius-input)] bg-[rgb(var(--color-bg))] p-3';
    var PVZ_SEARCH_CLS = 'w-full h-10 px-3 [font-family:var(--font-body)] text-[length:var(--size-small)] text-[rgb(var(--color-text))] bg-[rgb(var(--color-bg))] border border-[rgb(var(--color-input-border))] rounded-[var(--radius-input)] outline-none focus:border-[rgb(var(--color-text)/.4)]';
    var PVZ_LIST_CLS = 'max-h-[240px] overflow-y-auto flex flex-col';
    var PVZ_ROW_CLS = 'w-full text-left px-3 py-2 flex flex-col gap-0.5 rounded-[var(--radius-input)] cursor-pointer transition-colors hover:bg-[rgb(var(--color-text)/.04)]';
    var PVZ_ROW_SEL_CLS = 'w-full text-left px-3 py-2 flex flex-col gap-0.5 rounded-[var(--radius-input)] cursor-pointer bg-[rgb(var(--color-text)/.06)] outline outline-1 outline-[rgb(var(--color-text))]';
    var PVZ_ROW_ADDR_CLS = 'flex-1 [font-family:var(--font-body)] text-[length:var(--size-small)] text-[rgb(var(--color-text))]';
    var PVZ_BADGE_CLS = 'flex-shrink-0 text-[length:var(--size-tiny)] text-[rgb(var(--color-muted))] uppercase tracking-wider';
    var PVZ_TIME_CLS = 'text-[length:var(--size-tiny)] text-[rgb(var(--color-muted))]';
    var PVZ_MSG_CLS = 'px-3 py-2 text-[length:var(--size-small)] text-[rgb(var(--color-muted))]';
    var PVZ_RETRY_CLS = 'underline underline-offset-2 hover:no-underline text-[rgb(var(--color-error))]';

    function fmt(cents) {
      if (!cents && cents !== 0) return '0 ₽';
      return new Intl.NumberFormat('ru-RU', { style: 'currency', currency: 'RUB', minimumFractionDigits: 0 }).format(cents / 100);
    }

    function esc(s) {
      return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    function cartTotalCents() {
      if (window.cartStore && typeof window.cartStore.getTotal === 'function') {
        return window.cartStore.getTotal();
      }
      return 0;
    }

    function showEmpty(reason) {
      emptyEl && (emptyEl.hidden = false);
      // Если передан reason — оверайдим текст для лучшего UX (вместо общего
      // "Заполните адрес доставки..." показываем конкретику: cart пуст или
      // адрес неполный)
      if (emptyEl && reason) emptyEl.textContent = reason;
      loadingEl && (loadingEl.hidden = true);
      errorEl && (errorEl.hidden = true);
      listEl && (listEl.hidden = true);
    }
    function showLoading() {
      emptyEl && (emptyEl.hidden = true);
      loadingEl && (loadingEl.hidden = false);
      errorEl && (errorEl.hidden = true);
      listEl && (listEl.hidden = true);
    }
    function showError(msg) {
      emptyEl && (emptyEl.hidden = true);
      loadingEl && (loadingEl.hidden = true);
      if (errorEl) { errorEl.hidden = false; errorEl.textContent = msg || 'Не удалось рассчитать доставку'; }
      listEl && (listEl.hidden = true);
    }
    function showList() {
      emptyEl && (emptyEl.hidden = true);
      loadingEl && (loadingEl.hidden = true);
      errorEl && (errorEl.hidden = true);
      listEl && (listEl.hidden = false);
    }

    // ── CDEK ПВЗ-picker ────────────────────────────────────────────────────
    // GET /store/carts/:id/delivery/pickup-points?store_id&cityFiasId — тот же
    // эндпоинт, что и rose React-чекаут. Точка = {code,name,address,workTime,type}.
    async function fetchPickupPoints(fias) {
      var cartId = (typeof localStorage !== 'undefined' && localStorage.getItem('merfy:cartId')) || '';
      var shopId = getShopId();
      if (!fias || !cartId || !shopId) return [];
      var url = getApiBase() + '/store/carts/' + encodeURIComponent(cartId)
        + '/delivery/pickup-points?store_id=' + encodeURIComponent(shopId)
        + '&cityFiasId=' + encodeURIComponent(fias);
      var res = await fetch(url, { credentials: 'include' });
      if (!res.ok) throw new Error('http ' + res.status);
      var json = await res.json().catch(function () { return null; });
      return (json && Array.isArray(json.data)) ? json.data : [];
    }

    // Подпись типа точки для пустого состояния/плейсхолдера.
    function pvzKindLabel(plural) {
      return selectedPickupKind === 'POSTAMAT'
        ? (plural ? 'постаматов' : 'постамата')
        : (plural ? 'пунктов выдачи' : 'пункта выдачи');
    }
    // Точки только нужного тарифу типа (ПВЗ-тариф → ПВЗ, постамат → постамат).
    // Без kind (старый бэк/неизвестный тариф) — все точки (обратная совместимость).
    function kindFilteredPoints() {
      if (!pvzPoints) return pvzPoints; // null → null (loading)
      return selectedPickupKind
        ? pvzPoints.filter(function (p) { return p.type === selectedPickupKind; })
        : pvzPoints;
    }

    // loading / error+retry / empty / shell(input+list)
    function renderPvzState() {
      if (!pickerEl) return;
      if (pvzError) {
        pickerEl.innerHTML = '<div class="' + PVZ_MSG_CLS + '">Не удалось загрузить пункты выдачи. '
          + '<button type="button" data-pvz-retry class="' + PVZ_RETRY_CLS + '">Повторить</button></div>';
        return;
      }
      if (pvzPoints === null) {
        pickerEl.innerHTML = '<div class="' + PVZ_MSG_CLS + '">Загружаем пункты выдачи…</div>';
        return;
      }
      var pool = kindFilteredPoints();
      if (!pool || pool.length === 0) {
        pickerEl.innerHTML = '<div class="' + PVZ_MSG_CLS + '">Нет доступных ' + pvzKindLabel(true) + ' в этом городе.</div>';
        return;
      }
      pickerEl.innerHTML = '<div class="' + PVZ_BOX_CLS + '">'
        + '<input type="text" data-pvz-search value="' + esc(pvzQuery) + '" placeholder="Поиск ' + pvzKindLabel(false) + '…" class="' + PVZ_SEARCH_CLS + '" />'
        + '<div data-pvz-list class="' + PVZ_LIST_CLS + '"></div>'
        + '</div>';
      renderPvzRows();
    }

    // Только список (search-input не перерисовываем — иначе теряется фокус при вводе).
    function renderPvzRows() {
      var listC = pickerEl && pickerEl.querySelector('[data-pvz-list]');
      if (!listC) return;
      var q = pvzQuery.trim().toLowerCase();
      var sorted = (kindFilteredPoints() || []).slice().sort(function (a, b) {
        // ПВЗ перед постаматами, затем по адресу
        if (a.type !== b.type) return a.type === 'POSTAMAT' ? 1 : -1;
        return String(a.address || '').localeCompare(String(b.address || ''), 'ru');
      });
      var filtered = q ? sorted.filter(function (p) {
        return String(p.address || '').toLowerCase().indexOf(q) >= 0
          || String(p.name || '').toLowerCase().indexOf(q) >= 0
          || String(p.code || '').toLowerCase().indexOf(q) >= 0;
      }) : sorted;
      if (filtered.length === 0) {
        listC.innerHTML = '<div class="' + PVZ_MSG_CLS + '">Ничего не найдено</div>';
        return;
      }
      listC.innerHTML = filtered.map(function (p) {
        var sel = selectedPvzCode === p.code;
        var badge = p.type === 'POSTAMAT' ? 'постамат' : 'пвз';
        return '<button type="button" data-pvz-row data-pvz-code="' + esc(p.code) + '" data-pvz-address="' + esc(p.address) + '" class="' + (sel ? PVZ_ROW_SEL_CLS : PVZ_ROW_CLS) + '">'
          + '<span class="flex items-center gap-2">'
          + '<span class="' + PVZ_ROW_ADDR_CLS + '">' + esc(p.address) + '</span>'
          + '<span class="' + PVZ_BADGE_CLS + '">' + esc(badge) + '</span>'
          + '</span>'
          + (p.workTime ? '<span class="' + PVZ_TIME_CLS + '">' + esc(p.workTime) + '</span>' : '')
          + '</button>';
      }).join('');
    }

    // Делегируем input(поиск) / click(выбор точки, retry) на host пикера (Spec 102).
    function ensurePvzListeners() {
      if (pvzListenersBound || !pickerEl) return;
      pvzListenersBound = true;
      pickerEl.addEventListener('input', function (e) {
        var s = e.target.closest && e.target.closest('[data-pvz-search]');
        if (!s) return;
        pvzQuery = s.value || '';
        renderPvzRows();
      });
      pickerEl.addEventListener('click', function (e) {
        var retry = e.target.closest && e.target.closest('[data-pvz-retry]');
        if (retry) {
          var fias = section.getAttribute('data-last-fias-id') || '';
          delete pvzCache[fias];
          openPickerFor(fias);
          return;
        }
        var row = e.target.closest && e.target.closest('[data-pvz-row]');
        if (!row) return;
        selectedPvzCode = row.getAttribute('data-pvz-code') || null;
        selectedPvzAddress = row.getAttribute('data-pvz-address') || null;
        renderPvzRows(); // обновить подсветку выбранной строки
        // re-emit без повторного syncPicker (пикер уже открыт) → enable кнопки оплаты
        if (lastOpt) emitSelection(lastOpt);
      });
    }

    async function openPickerFor(fias) {
      if (!pickerEl) return;
      ensurePvzListeners();
      if (fias !== pvzFias) {
        // Город сменился → точка из старого города больше не валидна (СДЭК
        // отклонит). Сбрасываем выбор и поиск; guard снова заблокирует оплату,
        // пока покупатель не выберет точку в новом городе.
        pvzFias = fias;
        selectedPvzCode = null;
        selectedPvzAddress = null;
        pvzQuery = '';
      }
      if (!fias) { pvzPoints = []; pvzError = false; renderPvzState(); return; }
      if (pvzCache[fias]) { pvzPoints = pvzCache[fias]; pvzError = false; renderPvzState(); return; }
      pvzPoints = null; pvzError = false; renderPvzState(); // loading
      try {
        var list = await fetchPickupPoints(fias);
        pvzCache[fias] = list;
        pvzPoints = list; pvzError = false;
      } catch (e) {
        pvzError = true;
      }
      renderPvzState();
    }

    // Показать/скрыть пикер под выбранной опцией доставки.
    function syncPicker(opt) {
      if (!pickerEl) return;
      if (opt && opt.type === 'cdek_pickup') {
        var newKind = opt.pickupPointKind || null; // ПВЗ-тариф → ПВЗ, постамат → постамат
        // Сменился тип точки тарифа (ПВЗ↔постамат) в том же городе → ранее
        // выбранная точка другого типа невалидна (СДЭК отклонит). Сбрасываем,
        // чтобы guard снова заблокировал оплату до выбора точки нужного типа.
        // Сравнение (а не безусловный сброс) сохраняет выбор при ре-рендере того
        // же типа (cart:updated / повторный авто-селект той же опции).
        if (newKind !== selectedPickupKind) {
          selectedPvzCode = null;
          selectedPvzAddress = null;
        }
        selectedPickupKind = newKind;
        pickerEl.hidden = false;
        openPickerFor(section.getAttribute('data-last-fias-id') || '');
      } else {
        pickerEl.hidden = true;
        // ушли с pickup-метода → сбрасываем точку, чтобы не уехал устаревший код
        selectedPvzCode = null;
        selectedPvzAddress = null;
        selectedPickupKind = null;
      }
    }

    /**
     * Собирает массив option'ов из ответа логистики + локальных флагов.
     * Доставкой владеет merfy-logistics-service: ответ — дженерик
     *   { deliveryOptions: [{id,name,type:'OWN'|'PARTNER',price,minDays,maxDays,
     *      description,cdekTariffCode,deliveryMode:'door'|'pickup'}], pickupPoints[] }
     * type карточки: 'self_pickup' | 'cdek_door' | 'cdek_pickup' | 'custom'
     */
    function buildOptions(data, addressKnown) {
      var options = [];
      var subtotal = cartTotalCents();
      var freeShipping = freeShippingThreshold != null && subtotal >= freeShippingThreshold;

      var deliveryOptions = (data && Array.isArray(data.deliveryOptions)) ? data.deliveryOptions : [];
      var pickupPoints = (data && Array.isArray(data.pickupPoints)) ? data.pickupPoints : [];

      // Самовывоз из магазина — точки самовывоза из логистики.
      // Адрес-независим (как OWN): бэк отдаёт pickupPoints при isPickupEnabled
      // без города, поэтому показываем и без адреса. Одна карточка на КАЖДУЮ
      // точку (у магазина их может быть несколько); выбранную тащим в заказ по id.
      if (pickupEnabled && pickupPoints.length > 0) {
        var multiPickup = pickupPoints.length > 1;
        for (var pi = 0; pi < pickupPoints.length; pi++) {
          var pp = pickupPoints[pi];
          if (!pp) continue;
          // При нескольких точках уточняем подпись городом/адресом, чтобы и
          // покупатель, и заказ (cdekTariffName=label) различали точки.
          var pickupName = multiPickup
            ? pickupLabel + ' — ' + (pp.city || pp.address || ('точка ' + (pi + 1)))
            : pickupLabel;
          options.push({
            type: 'self_pickup',
            tariffCode: null,
            pickupPointId: pp.id || null,
            label: pickupName,
            meta: pp.address || 'Заберите из нашего магазина',
            priceCents: 0,
          });
        }
      }

      // Опции доставки: PARTNER (CDEK) → дверь/ПВЗ, OWN → свой тариф магазина.
      for (var i = 0; i < deliveryOptions.length; i++) {
        var o = deliveryOptions[i];
        var priceCents = Math.round((o.price || 0) * 100);
        var period = (o.minDays != null && o.maxDays != null)
          ? 'от ' + o.minDays + ' до ' + o.maxDays + ' рабочих дней'
          : (o.description || '');

        if (o.type === 'PARTNER') {
          // CDEK (PARTNER) — адрес-зависимая служба. Без адреса не показываем,
          // появится сама после ввода адреса (checkout:address-changed).
          if (!addressKnown) continue;
          var isDoor = o.deliveryMode === 'door';
          // Заголовок карточки — настройка темы (cdekDoorLabel / cdekPvzLabel),
          // срок/описание — meta.
          options.push({
            type: isDoor ? 'cdek_door' : 'cdek_pickup',
            tariffCode: (o.cdekTariffCode != null ? o.cdekTariffCode : null),
            label: isDoor ? cdekDoorLabel : cdekPvzLabel,
            meta: period,
            priceCents: priceCents,
            periodMin: o.minDays,
            periodMax: o.maxDays,
            // Тип точки тарифа (ПВЗ/постамат) — пикер по нему фильтрует список.
            pickupPointKind: o.pickupPointKind || null,
          });
        } else {
          // OWN — собственный тариф магазина (бывшие customProfiles).
          options.push({
            type: 'custom',
            tariffCode: null,
            customTariffId: o.id,
            label: o.name,
            meta: o.description || period,
            priceCents: priceCents,
          });
        }
      }

      // Free shipping override — если cart total >= threshold, все платные → бесплатно.
      if (freeShipping) {
        for (var k = 0; k < options.length; k++) {
          if (options[k].priceCents > 0) {
            options[k].priceCents = 0;
            options[k].freeShipping = true;
          }
        }
      }

      // Сортировка: бесплатные первыми, потом по цене.
      options.sort(function (a, b) { return a.priceCents - b.priceCents; });
      return options;
    }

    function render(data, addressKnown) {
      var options = buildOptions(data, addressKnown);
      if (options.length === 0) {
        if (!addressKnown) {
          // Без адреса показывать нечего (у магазина нет OWN-тарифов) — оставшиеся
          // методы адрес-зависимы и появятся после ввода адреса. Block-level empty.
          showEmpty('Заполните адрес доставки чтобы увидеть варианты.');
          return;
        }
        showError(data && data.cdekError ? data.cdekError : 'Нет доступных вариантов доставки для этого адреса');
        return;
      }

      listEl.innerHTML = options.map(function (opt, idx) {
        // Без адреса — показ без предвыбора (ни одна карточка не selected).
        var selected = addressKnown && idx === 0;
        var cls = OPTION_CLS + (selected ? ' ' + OPTION_SELECTED_CLS : '');
        var priceText = opt.priceCents === 0 ? 'Бесплатно' : fmt(opt.priceCents);
        var radioOuterCls = RADIO_OUTER_BASE + ' ' + (selected ? RADIO_OUTER_SELECTED : RADIO_OUTER_UNSELECTED);
        return '<label class="' + cls + '"'
          + ' data-delivery-option'
          + ' data-delivery-type="' + esc(opt.type) + '"'
          + ' data-delivery-tariff-code="' + esc(opt.tariffCode == null ? '' : String(opt.tariffCode)) + '"'
          + ' data-delivery-custom-id="' + esc(opt.customTariffId || '') + '"'
          + ' data-delivery-pickup-id="' + esc(opt.pickupPointId || '') + '"'
          + ' data-delivery-price-cents="' + esc(String(opt.priceCents)) + '"'
          + ' data-delivery-period-min="' + esc(opt.periodMin != null ? String(opt.periodMin) : '') + '"'
          + ' data-delivery-period-max="' + esc(opt.periodMax != null ? String(opt.periodMax) : '') + '"'
          + ' data-delivery-pvz-kind="' + esc(opt.pickupPointKind || '') + '"'
          + (selected ? ' data-selected="true"' : '')
          + '>'
          + '<input type="radio" name="deliveryOption" value="' + esc(opt.type) + '"' + (selected ? ' checked' : '') + ' class="sr-only" data-delivery-radio />'
          + '<span class="' + radioOuterCls + '" data-delivery-radio-dot>'
          + (selected ? '<span class="' + RADIO_DOT + '"></span>' : '')
          + '</span>'
          + '<div class="' + BODY_CLS + '">'
          + '<span class="' + LABEL_CLS + '" data-delivery-label>' + esc(opt.label) + '</span>'
          + (opt.meta ? '<span class="' + META_CLS + '">' + esc(opt.meta) + '</span>' : '')
          + '</div>'
          + '<span class="' + PRICE_CLS + '">' + priceText + '</span>'
          + '</label>';
      }).join('');
      showList();

      // По умолчанию выбран первый — диспатчим событие чтобы Totals обновился.
      // Без адреса предвыбора нет: показываем карточки, но Totals не трогаем,
      // пока пользователь сам не выберет метод.
      if (addressKnown) dispatchSelection(options[0]);
    }

    // Только отправка события (без управления пикером) — для re-emit при выборе
    // точки, когда пикер уже открыт. pickupPointCode непуст только для cdek_pickup
    // и только когда точка реально выбрана.
    function emitSelection(opt) {
      var isPvz = opt.type === 'cdek_pickup';
      document.dispatchEvent(new CustomEvent('checkout:delivery-changed', {
        detail: {
          type: opt.type,
          tariffCode: opt.tariffCode,
          customTariffId: opt.customTariffId || null,
          pickupPointId: opt.pickupPointId || null,
          costCents: opt.priceCents,
          periodMin: opt.periodMin || null,
          periodMax: opt.periodMax || null,
          label: opt.label,
          pickupPointCode: isPvz ? selectedPvzCode : null,
          pickupPointAddress: isPvz ? selectedPvzAddress : null,
        },
      }));
    }

    function dispatchSelection(opt) {
      lastOpt = opt;
      syncPicker(opt);
      emitSelection(opt);
    }

    // Click handler — переключение selected состояния (radio + border)
    listEl.addEventListener('click', function (e) {
      var card = e.target.closest && e.target.closest('[data-delivery-option]');
      if (!card) return;

      var cards = listEl.querySelectorAll('[data-delivery-option]');
      for (var i = 0; i < cards.length; i++) {
        var c = cards[i];
        c.classList.remove('border-[rgb(var(--color-text))]');
        c.removeAttribute('data-selected');
        // снять radio dot + reset outer circle
        var dotEl = c.querySelector('[data-delivery-radio-dot]');
        if (dotEl) {
          dotEl.className = RADIO_OUTER_BASE + ' ' + RADIO_OUTER_UNSELECTED;
          dotEl.innerHTML = '';
        }
        // uncheck input
        var ri = c.querySelector('[data-delivery-radio]');
        if (ri) ri.checked = false;
      }
      // selected — добавляем border + radio dot + check input
      card.classList.add('border-[rgb(var(--color-text))]');
      card.setAttribute('data-selected', 'true');
      var newDot = card.querySelector('[data-delivery-radio-dot]');
      if (newDot) {
        newDot.className = RADIO_OUTER_BASE + ' ' + RADIO_OUTER_SELECTED;
        newDot.innerHTML = '<span class="' + RADIO_DOT + '"></span>';
      }
      var newRadio = card.querySelector('[data-delivery-radio]');
      if (newRadio) newRadio.checked = true;

      var labelEl = card.querySelector('[data-delivery-label]');
      dispatchSelection({
        type: card.getAttribute('data-delivery-type') || '',
        tariffCode: card.getAttribute('data-delivery-tariff-code') ? parseInt(card.getAttribute('data-delivery-tariff-code'), 10) : null,
        customTariffId: card.getAttribute('data-delivery-custom-id') || null,
        pickupPointId: card.getAttribute('data-delivery-pickup-id') || null,
        priceCents: parseInt(card.getAttribute('data-delivery-price-cents') || '0', 10),
        periodMin: card.getAttribute('data-delivery-period-min') ? parseInt(card.getAttribute('data-delivery-period-min'), 10) : null,
        periodMax: card.getAttribute('data-delivery-period-max') ? parseInt(card.getAttribute('data-delivery-period-max'), 10) : null,
        label: labelEl ? labelEl.textContent : '',
        pickupPointKind: card.getAttribute('data-delivery-pvz-kind') || null,
      });
    });

    var calcInFlight = null;

    // Last-resort fallback: получить postal_code по cityFiasId через DaData.
    // Гарантирует что в logistics всегда уходит postal — без него BadRequest.
    async function resolvePostalFromFiasId(fiasId) {
      try {
        var cfg = window.__MERFY_CONFIG__ || {};
        var token = window.__DADATA_TOKEN__ || cfg.dadataToken;
        if (!token || !fiasId) return '';
        var res = await fetch('https://suggestions.dadata.ru/suggestions/api/4_1/rs/findById/address', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: 'Token ' + token,
            Accept: 'application/json',
          },
          body: JSON.stringify({ query: fiasId }),
        });
        var json = await res.json();
        var first = json && json.suggestions && json.suggestions[0];
        return (first && first.data && first.data.postal_code) || '';
      } catch (e) {
        return '';
      }
    }

    async function recalculate(addr) {
      var cityFiasId = (addr && addr.cityFiasId) || '';
      var postalCode = (addr && addr.postalCode) || '';
      var cartId = (typeof localStorage !== 'undefined' && localStorage.getItem('merfy:cartId')) || '';
      var shopId = getShopId();
      var apiBase = getApiBase();

      if (!shopId) {
        showEmpty('Магазин не определён');
        return;
      }
      if (!cartId) {
        showEmpty('Добавьте товар в корзину чтобы рассчитать доставку');
        return;
      }

      // addressKnown=false → запрос всё равно уходит (gateway принимает запрос
      // без cityFiasId/postalCode), но рендерим ТОЛЬКО OWN-карточки без предвыбора.
      // Адрес-зависимые службы (CDEK/самовывоз) появятся после ввода адреса.
      var addressKnown = !!cityFiasId;

      // Last-resort: если postal не пришёл от формы — резолвим по fiasId.
      // Покрывает кеш браузера / autofill / случаи когда city click отработал
      // но postal field остался пустым. Без cityFiasId (address-less) резолвить
      // нечего — пропускаем, чтобы не делать пустой DaData-запрос и сразу показать OWN.
      if (cityFiasId && !postalCode) {
        showLoading();
        postalCode = await resolvePostalFromFiasId(cityFiasId);
        if (postalCode) {
          // Заполняем поле "Индекс" если оно пустое — для UX consistency
          var pInputEl = document.querySelector('[data-checkout-field="postalCode"] input'); // merfy-root-allow: cross-block, поле CheckoutDeliveryForm, page-singleton checkout
          if (pInputEl && !pInputEl.value) pInputEl.value = postalCode;
        }
      }

      showLoading();
      var url = apiBase + '/store/carts/' + encodeURIComponent(cartId) + '/delivery/calculate?store_id=' + encodeURIComponent(shopId);
      // Без адреса шлём пустой body — gateway DTO принимает запрос без
      // cityFiasId/postalCode (оба @IsOptional) и logistic вернёт OWN-варианты.
      var body = {};
      if (cityFiasId) body.cityFiasId = cityFiasId;
      if (postalCode) body.postalCode = postalCode;

      if (calcInFlight && calcInFlight.abort) {
        try { calcInFlight.abort(); } catch (e) {}
      }
      var controller = (typeof AbortController !== 'undefined') ? new AbortController() : null;
      calcInFlight = controller;

      // Retry: logistics периодически возвращает {success:true, deliveryOptions:[]}
      // на свежие cart'ы — eventual consistency на стороне calc. Воспроизведено
      // E2E: race разрешается за ~10-30 секунд после создания cart.
      // Пробуем с увеличивающимися задержками; loading-state видим весь retry.
      var attempts = [0, 2000, 5000, 10000];
      var lastJson = null;
      for (var i = 0; i < attempts.length; i++) {
        if (i > 0) await new Promise(function (r) { setTimeout(r, attempts[i]); });
        try {
          var res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
            credentials: 'include',
            signal: controller ? controller.signal : undefined,
          });
          lastJson = await res.json();
          if (lastJson && lastJson.success) {
            var data = lastJson.data || {};
            var options = (data.deliveryOptions && data.deliveryOptions.length) || 0;
            var points = (data.pickupPoints && data.pickupPoints.length) || 0;
            // cdekError не прячет OWN: при запросе без адреса CDEK всегда падает,
            // но OWN-варианты уже в deliveryOptions. Фатальной ошибку считаем
            // только если адрес введён И нет ни одной видимой опции (render сам
            // покажет cdekError при addressKnown && options.length === 0).
            if (data.cdekError && addressKnown && options === 0 && points === 0) {
              showError(data.cdekError);
              return;
            }
            // Если что-то пришло — отрисуем; иначе — следующая попытка.
            // Без адреса достаточно дождаться OWN (deliveryOptions).
            if (options > 0 || points > 0) {
              render(data, addressKnown);
              return;
            }
          } else {
            // не-success — сразу показываем error без retry
            showError((lastJson && (lastJson.error || lastJson.message)) || 'Не удалось рассчитать доставку');
            return;
          }
        } catch (e) {
          if (e && e.name === 'AbortError') return;
          // На сетевую ошибку тоже retry — но только если это не последняя попытка
          if (i === attempts.length - 1) {
            showError('Сервис доставки недоступен');
            return;
          }
        }
      }

      // Все попытки вернули пустые опции — рендерим (render сам покажет error
      // при addressKnown, либо вернёт empty-state без адреса).
      render((lastJson && lastJson.data) || {}, addressKnown);
    }

    document.addEventListener('checkout:address-changed', function (e) {
      recalculate(e && e.detail);
    });
    // Cart updates — пересчитать free shipping threshold + актуальные веса.
    // cart:updated прилетает ПОСЛЕ того, как страница создала серверную корзину
    // (rose: cartStore.syncToServer на загрузке) — значит cartId/конфиг уже готовы.
    document.addEventListener('cart:updated', function () {
      var lastFiasId = section.getAttribute('data-last-fias-id') || '';
      var lastPostal = section.getAttribute('data-last-postal') || '';
      if (lastFiasId) {
        recalculate({ cityFiasId: lastFiasId, postalCode: lastPostal });
      } else if (getShopId() && (typeof localStorage !== 'undefined' && localStorage.getItem('merfy:cartId'))) {
        // Адрес ещё не вводили, но корзина готова → показываем адрес-независимые
        // опции (OWN + самовывоз) сразу, не дожидаясь ввода города.
        recalculate(null);
      }
    });

    // Запомним последний адрес для cart:updated триггера
    document.addEventListener('checkout:address-changed', function (e) {
      if (e && e.detail) {
        section.setAttribute('data-last-fias-id', e.detail.cityFiasId || '');
        section.setAttribute('data-last-postal', e.detail.postalCode || '');
      }
    });

    // Первый расчёт без ожидания checkout:address-changed — чтобы OWN-доставка и
    // самовывоз показались сразу. ВАЖНО про тайминг: конфиг (__MERFY_CONFIG__)
    // инжектится ПОСЛЕ блоков, а серверная корзина (merfy:cartId) на rose создаётся
    // асинхронно уже после загрузки — поэтому СИНХРОННО здесь вызывать нельзя.
    // Делаем отложенно (после DOMContentLoaded); если cartId ещё не готов — добьёт
    // обработчик cart:updated выше (событие прилетит после syncToServer).
    function initialDeliveryRender() {
      if (!getShopId()) return;
      var cid = (typeof localStorage !== 'undefined' && localStorage.getItem('merfy:cartId')) || '';
      if (cid) recalculate(null);
    }
    if (typeof document !== 'undefined' && document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () { setTimeout(initialDeliveryRender, 300); });
    } else {
      setTimeout(initialDeliveryRender, 300);
    }
  })();
</script>
