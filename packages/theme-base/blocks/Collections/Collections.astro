---
import type { CollectionsProps } from './Collections.puckConfig';
import { CollectionsClasses as C } from './Collections.classes';

interface Props extends CollectionsProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  heading: headingProp,
  subtitle: subtitleProp,
  collections = [],
  columns: columnsProp,
  colorScheme,
  padding,
} = Astro.props as Props & { subtitle?: string };

// Constructor legacy schema uses title/titleSize/subtitleSize/columnsCount/imageView.
// Normalise both shapes so sites edited via the constructor render correctly.
const heading =
  (typeof headingProp === 'string' && headingProp) ||
  (typeof raw.title === 'string' ? raw.title : undefined);
const subtitle =
  (typeof subtitleProp === 'string' && subtitleProp) ||
  (typeof raw.subtitle === 'string' ? raw.subtitle : undefined);
const columns = typeof columnsProp === 'number'
  ? columnsProp
  : (typeof raw.columnsCount === 'number' ? raw.columnsCount : 3);

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
const gridTemplateCols = `grid-template-columns: repeat(${columns}, minmax(0, 1fr));`;
const schemeClass = colorScheme ? `color-scheme-${String(colorScheme).replace('scheme-', '')}` : '';

// imageView → aspect-ratio for tiles (falls back to portrait 430/500 for
// parity with legacy vanilla template).
const imageViewProp =
  typeof raw.imageView === 'string' &&
  ['square', 'portrait', 'wide'].includes(raw.imageView)
    ? (raw.imageView as 'square' | 'portrait' | 'wide')
    : 'portrait';
const aspectMap: Record<string, string> = {
  square: '1 / 1',
  portrait: '430 / 500',
  wide: '16 / 9',
};
const tileAspect = aspectMap[imageViewProp];
// When the merchant hasn't wired real collections, show demo tiles so the
// preview matches Figma reference (3 collection cards). Real collections
// take precedence as soon as they exist.
const DEMO_COLLECTIONS = [
  { heading: 'Коллекция RIVIERA', image: '' },
  { heading: 'Коллекция URBAN', image: '' },
  { heading: 'Коллекция FUTURISM', image: '' },
];
const hasRealCollections = (collections ?? []).length > 0;
const effectiveCollections = hasRealCollections
  ? collections
  : DEMO_COLLECTIONS.slice(0, columns).map((c, i) => ({
      id: `demo-${i}`, heading: c.heading, image: c.image, collectionId: null,
    }));
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  style={paddingStyle}
>
  <div class={C.container}>
    {heading && <h2 class={C.heading}>{heading}</h2>}
    {subtitle && <p class={C.subtitle}>{subtitle}</p>}
    <div class={C.grid} style={gridTemplateCols}>
      {effectiveCollections.map((item, i) => (
        <a
          href={item.collectionId ? `/collection/${item.collectionId}` : '#'}
          class={C.card}
          data-puck-subsection-parent={hasRealCollections ? id : undefined}
          data-puck-subsection-index={hasRealCollections ? i : undefined}
          data-puck-subsection-field={hasRealCollections ? 'collections' : undefined}
        >
          {item.image ? (
            <img src={item.image} alt={item.heading} class={C.image} loading="lazy" style={`aspect-ratio: ${tileAspect};`} />
          ) : (
            <div class="w-full rounded-[var(--radius-media)] bg-[rgb(var(--color-surface))]" style={`aspect-ratio: ${tileAspect};`} aria-hidden="true"></div>
          )}
          <h3 class={C.cardHeading}>{item.heading}</h3>
          {item.description && <p class={C.cardDescription}>{item.description}</p>}
        </a>
      ))}
    </div>
  </div>
</section>
