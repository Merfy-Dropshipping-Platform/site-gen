---
/**
 * LogoMark — рендер логотипа Header. 3-way switch:
 *
 *   1. logo === '/logo.svg' (theme seed)
 *      → CSS mask-image из themed /logo.svg, цвет = currentColor через
 *        rgb(var(--color-heading)). Работает на light/dark schemes —
 *        в отличие от <img src=*.svg> где fill="currentColor" не
 *        наследуется (SVG грузится в изолированном context).
 *
 *   2. logo — иная непустая строка (URL/base64 — мерчант загрузил)
 *      → <img>. Отдаётся как есть.
 *
 *   3. logo === '' (пусто)
 *      → text fallback: siteTitle в font-heading.
 *
 * --------------------------------------------------------------------
 * ПРАВИЛО ДЛЯ SUB-COMPONENTS HEADER (LogoMark / NavLinkItem /
 * MobileMenuItem и будущих): **НЕ выделяются hover-overlay'ем** в
 * превью конструктора. Реализуется одним из двух способов:
 *
 *   (a) Не добавлять `data-puck-subsection-parent` атрибут.
 *       useSubsectionClickHandler (constructor) ищет ближайший
 *       subsection-parent через closest() — без этого атрибута
 *       overlay не рисуется.
 *
 *   (b) Для root-element подкомпонента, который НЕ должен ловить
 *       mouseover вообще (логотип/декорации): добавить
 *       `pointer-events:none` через class. mouseover/click проходят
 *       насквозь к родительскому интерактивному элементу (<a>/<button>).
 *
 * LogoMark использует (b) через `C.logoMask` / `C.logoText` / `C.logoImg`
 * — в каждом из этих классов добавлен `pointer-events-none`.
 *
 * Если в будущем sub-component должен быть кликабелен (как NavLinkItem)
 * — использовать только правило (a). pointer-events:none убрать.
 * --------------------------------------------------------------------
 */
import { HeaderClasses as C } from './Header.classes';

interface Props {
  logo: string;
  siteTitle: string;
}

const { logo, siteTitle } = Astro.props as Props;
// Theme-seed: `/logo.svg` (БД) или абсолютный URL `https://<host>/logo.svg`
// (preview.service rewriteAssetUrl переписывает relative → absolute для
// iframe). Матчим оба варианта чтобы mask-icon рендерился везде.
const isThemeLogo = typeof logo === 'string' && /(^|\/)logo\.svg(\?|#|$)/.test(logo);
const isCustomLogo = typeof logo === 'string' && logo.length > 0 && !isThemeLogo;
---
{isThemeLogo && (
  <span class={C.logoMask} role="img" aria-label={siteTitle || 'Logo'}></span>
)}
{isCustomLogo && (
  <img src={logo} alt={siteTitle} class={C.logoImg} />
)}
{!isThemeLogo && !isCustomLogo && (
  <span class={C.logoText}>{siteTitle}</span>
)}
