---
import type { CheckoutHeaderProps } from './CheckoutHeader.puckConfig';
import { CheckoutHeaderClasses as C } from './CheckoutHeader.classes';

interface Props extends CheckoutHeaderProps {
  id?: string;
}

const {
  id,
  siteTitle,
  logoMode,
  logoImage,
  rightIcon,
  accountLink,
  padding,
} = Astro.props as Props;

const paddingStyle = padding ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;` : '';
---
<header
  class={C.root}
  data-puck-component-id={id}
  data-checkout-section="header"
  style={paddingStyle}
>
  <div class={C.container}>
    <a href="/" class={C.brand} aria-label={siteTitle}>
      {logoMode === 'image' && logoImage ? (
        <img src={logoImage} alt={siteTitle} class={C.brandImage} />
      ) : (
        siteTitle
      )}
    </a>
    {rightIcon === 'account' && (
      <a href={accountLink} class={C.iconRight} aria-label="Личный кабинет">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-2a8 8 0 0 1 16 0v2"/></svg>
      </a>
    )}
    {rightIcon === 'back' && (
      <a href="/cart" class={C.iconRight} aria-label="Назад в корзину">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </a>
    )}
  </div>
</header>
