{
  "name": "vanilla",
  "label": "Vanilla — Decor & Interior",
  "version": "1.0.0",
  "category": "decor",
  "description": "Olive green theme for decor and interior stores with Arsenal/Bitter fonts",
  "author": "Merfy",
  "features": {
    "variants": true,
    "collections": true,
    "sizeGuide": false,
    "colorSwatches": true,
    "filterSidebar": true,
    "newsletter": true,
    "wishlist": false,
    "blog": true,
    "rss": true
  },
  "pages": ["index", "product", "collection", "cart", "blog"],
  "settings_schema": [
    {
      "name": "colors",
      "settings": [
        { "id": "color_primary", "type": "color", "label": "Primary color", "default": "#26311c" },
        { "id": "color_background", "type": "color", "label": "Background", "default": "#eeeeee" },
        { "id": "color_foreground", "type": "color", "label": "Text", "default": "#26311c" },
        { "id": "color_border", "type": "color", "label": "Border", "default": "#c8c8c8" },
        { "id": "color_button", "type": "color", "label": "Button", "default": "#3a4530" },
        { "id": "color_button_text", "type": "color", "label": "Button text", "default": "#ffffff" }
      ]
    },
    {
      "name": "typography",
      "settings": [
        { "id": "font_heading", "type": "font", "label": "Heading font", "default": "Bitter" },
        { "id": "font_body", "type": "font", "label": "Body font", "default": "Arsenal" }
      ]
    },
    {
      "name": "layout",
      "settings": [
        { "id": "radius_button", "type": "range", "label": "Button radius", "default": "0" },
        { "id": "radius_card", "type": "range", "label": "Card radius", "default": "0" },
        { "id": "page_width", "type": "text", "label": "Page width", "default": "1280px" }
      ]
    }
  ],
  "color_schemes": [
    {
      "id": 1,
      "name": "Dark olive",
      "background": "#26311c",
      "foreground": "#ffffff",
      "primary": "#eeeeee",
      "border": "#445037"
    },
    {
      "id": 2,
      "name": "Medium olive",
      "background": "#3a4530",
      "foreground": "#ffffff",
      "primary": "#eeeeee",
      "border": "#505c41"
    },
    {
      "id": 3,
      "name": "Light gray",
      "background": "#eeeeee",
      "foreground": "#26311c",
      "primary": "#3a4530",
      "border": "#c8c8c8"
    },
    {
      "id": 4,
      "name": "White",
      "background": "#ffffff",
      "foreground": "#26311c",
      "primary": "#3a4530",
      "border": "#dcdcd7"
    }
  ]
}
