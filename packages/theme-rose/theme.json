{
  "$schema": "https://merfy.ru/schemas/theme-manifest.v2.json",
  "id": "rose",
  "name": "Rose",
  "version": "1.0.0",
  "extends": "@merfy/theme-base@workspace:*",
  "category": "fashion",
  "description": "Elegant rose theme — Merfy flagship storefront template (fashion & lifestyle)",
  "author": "Merfy",
  "tokens": "./tokens.json",
  "defaults": {
    "--font-heading": "'Comfortaa', sans-serif",
    "--font-body": "'Manrope', sans-serif",
    "--weight-heading": "400",
    "--weight-body": "400",
    "--container-max-width": "1920px",
    "--header-container-px-2xl": "280px",
    "--radius-button": "6px",
    "--radius-input": "4px",
    "--radius-card": "8px",
    "--radius-media": "8px",
    "--radius-field": "4px",
    "--size-hero-heading": "40px",
    "--size-hero-button-h": "48px",
    "--size-section-heading": "20px",
    "--size-nav-link": "16px",
    "--size-newsletter-form-w": "430px",
    "--size-logo-width": "24px",
    "--size-card-border": "1px",
    "--spacing-section-y": "120px",
    "--spacing-grid-col-gap": "16px",
    "--spacing-grid-row-gap": "40px",
    "--button-style": "solid",
    "--footer-layout": "3-column",
    "--contact-form-layout": "wide",
    "--cart-type": "drawer",
    "--card-style": "standard",
    "--card-alignment": "left",
    "--text-transform-heading": "uppercase",
    "--color-error": "255 148 148",
    "--color-input-bg": "255 255 255",
    "--color-input-border": "153 153 153",
    "--color-input-label": "153 153 153",
    "--color-input-placeholder": "153 153 153",
    "--color-link": "0 0 0",
    "--color-accent-fg": "255 255 255",
    "--color-accent-2": "58 58 58",
    "--color-border": "153 153 153",
    "--checkout-form-col-w": "652px",
    "--checkout-summary-col-w": "884px",
    "--checkout-gap": "84px",
    "--checkout-side-pad": "300px",
    "--size-checkout-brand": "24px",
    "--size-checkout-brand-image": "32px",
    "--size-h2": "20px",
    "--size-h3": "16px",
    "--size-body": "16px",
    "--size-small": "14px",
    "--size-tiny": "12px",
    "--header-nav-link-font-size": "14px",
    "--header-nav-link-font-size-lg": "16px",
    "--header-nav-link-padding-bottom": "4px",
    "--header-action-search-opacity-hover": "0.8",
    "--header-cart-badge-min-width": "16px",
    "--header-cart-badge-height": "16px",
    "--header-action-profile-opacity-hover": "0.8",
    "--footer-container-padding-x-sm": "20px",
    "--footer-container-padding-x-md": "40px",
    "--footer-container-padding-x-lg": "64px",
    "--footer-container-padding-x-xl": "80px",
    "--footer-newsletter-form-max-width": "430px",
    "--footer-newsletter-form-height": "56px",
    "--footer-newsletter-form-border-radius": "4px",
    "--footer-newsletter-input-font-size": "16px",
    "--footer-main-grid-gap": "40px",
    "--footer-column-root-gap": "12px",
    "--footer-copyright-bar-height": "64px",
    "--footer-copyright-text-font-size": "14px",
    "--hero-content-column-gap": "24px",
    "--hero-content-column-gap-sm": "40px",
    "--hero-header-gap": "8px",
    "--hero-header-gap-sm": "12px",
    "--hero-header-gap-md": "16px",
    "--hero-title-size": "clamp(20px, 5vw, 40px)",
    "--hero-subtitle-font-size": "clamp(14px, 1.8vw, 20px)",
    "--hero-subtitle-padding-x": "4px",
    "--hero-cta-button-height": "clamp(40px, 5vw, 52px)",
    "--hero-cta-button-min-height": "clamp(40px, 5vw, 52px)",
    "--hero-cta-button-min-width": "clamp(120px, 15vw, 160px)",
    "--hero-cta-button-padding-x": "clamp(12px, 2vw, 24px)",
    "--hero-cta-button-padding-y": "10px",
    "--hero-cta-button-font-size": "clamp(14px, 1.2vw, 16px)",
    "--hero-cta-button-opacity-hover": "0.9",
    "--popular-products-card-gap": "20px",
    "--popular-products-card-media-border-radius": "8px",
    "--popular-products-card-badge-border-radius": "4px",
    "--popular-products-card-badge-font-size": "12px",
    "--gallery-item-primary-border-radius": "8px",
    "--gallery-item-small-gap": "16px",
    "--gallery-card-media-border-radius": "8px",
    "--gallery-card-label-font-size": "16px",
    "--gallery-card-price-font-size": "16px"
  },
  "blockDefaults": {
    "PromoBanner": {
      "text": "Скидка 10% на общую сумму заказа от 9 000₽",
      "link": {
        "text": "Перейти",
        "href": "/catalog"
      },
      "colorScheme": "scheme-4"
    },
    "Hero": {
      "heading": {
        "text": "Rose",
        "size": "large"
      },
      "text": {
        "content": "Там, где классика встречается с характером",
        "size": "large"
      },
      "primaryButton": {
        "text": "В каталог",
        "link": {
          "href": "/catalog"
        }
      },
      "backgroundImage": "/images/Главный_экран.png",
      "colorScheme": "scheme-4"
    },
    "Collections": {
      "heading": "Коллекции, которые становятся любимыми",
      "subtitle": "Вдохновение для каждого дня — актуальные коллекции сумок, созданные, чтобы радовать и удивлять."
    },
    "PopularProducts": {
      "heading": {
        "text": "Главные хиты"
      },
      "text": {
        "content": "Найдите стиль на каждый случай — коллекции, которые помогают выразить себя вне времени и трендов."
      }
    },
    "Gallery": {
      "heading": {
        "text": "Снова в наличии!"
      },
      "text": {
        "content": "Сравнивайте, находите своё — от культовых моделей до свежих решений для особенных моментов"
      }
    },
    "ContactForm": {
      "heading": {
        "text": "Контакты"
      }
    },
    "Header": {
      "siteTitle": "Rose",
      "logoPosition": "center-left",
      "padding": {
        "top": 24,
        "bottom": 24
      },
      "navigationLinks": [
        {
          "label": "Главная",
          "href": "/"
        },
        {
          "label": "Каталог",
          "href": "/catalog"
        },
        {
          "label": "О нас",
          "href": "/about"
        },
        {
          "label": "Контакты",
          "href": "/contacts"
        }
      ]
    },
    "Footer": {
      "siteTitle": "Rose",
      "phone": "+7 (000) 000-00-00",
      "variant": "3-col",
      "newsletter": {
        "enabled": true,
        "heading": "Подпишитесь на нашу рассылку",
        "description": "Введите электронную почту и получайте информацию нашего бренда",
        "placeholder": "rose@example.ru"
      },
      "navigationColumn": {
        "links": [
          {
            "label": "Главная",
            "href": "/"
          },
          {
            "label": "Каталог",
            "href": "/catalog"
          },
          {
            "label": "Контакты",
            "href": "/contacts"
          }
        ]
      },
      "informationColumn": {
        "links": [
          {
            "label": "Политика доставки",
            "href": "/legal/delivery"
          },
          {
            "label": "Политика возврата",
            "href": "/legal/return"
          },
          {
            "label": "Условия обслуживания",
            "href": "/legal/terms"
          },
          {
            "label": "Политика конфиденциальности",
            "href": "/legal/privacy"
          }
        ]
      },
      "socialColumn": {
        "email": "rose@example.ru",
        "socialLinks": [
          {
            "platform": "vk",
            "href": "#"
          },
          {
            "platform": "youtube",
            "href": "#"
          },
          {
            "platform": "dzen",
            "href": "#"
          },
          {
            "platform": "tiktok",
            "href": "#"
          },
          {
            "platform": "telegram",
            "href": "#"
          }
        ]
      },
      "copyright": {
        "poweredBy": "Powered by Merfy",
        "showYear": true
      },
      "padding": {
        "top": 80,
        "bottom": 80
      }
    },
    "Product": {
      "visualConfig": {
        "gallery": {
          "variant": "wrap-large",
          "showDiscountBadge": true
        },
        "variantsType": "chips",
        "counter": {
          "variant": "inline"
        },
        "showDescription": true
      }
    },
    "MainText": {
      "colorScheme": "scheme-1"
    },
    "ImageWithText": {
      "colorScheme": "scheme-1"
    },
    "MultiColumns": {
      "colorScheme": "scheme-1"
    },
    "MultiRows": {
      "colorScheme": "scheme-1"
    },
    "CollapsibleSection": {
      "colorScheme": "scheme-1"
    },
    "Newsletter": {
      "colorScheme": "scheme-1"
    },
    "Slideshow": {
      "colorScheme": "scheme-1"
    }
  },
  "colorSchemes": [
    {
      "id": "scheme-1",
      "name": "1",
      "tokens": {
        "--color-bg": "255 255 255",
        "--color-surface": "245 245 245",
        "--color-heading": "0 0 0",
        "--color-text": "0 0 0",
        "--color-muted": "153 153 153",
        "--color-primary": "0 0 0",
        "--color-accent": "0 0 0",
        "--color-button-bg": "0 0 0",
        "--color-button-text": "255 255 255",
        "--color-button-border": "0 0 0",
        "--color-button-secondary-bg": "255 255 255",
        "--color-button-secondary-text": "0 0 0",
        "--color-button-secondary-border": "0 0 0",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "0 0 0"
      }
    },
    {
      "$comment": "Scheme-2 is Light in Figma (sections use white background with dark text). Previous 'Dark' was wrong — all seed sites save scheme-2 for PopularProducts/Collections/ContactForm/Footer and they must stay light.",
      "id": "scheme-2",
      "name": "2",
      "tokens": {
        "--color-bg": "255 255 255",
        "--color-surface": "245 245 245",
        "--color-heading": "18 18 18",
        "--color-text": "18 18 18",
        "--color-muted": "153 153 153",
        "--color-primary": "0 0 0",
        "--color-accent": "0 0 0",
        "--color-button-bg": "0 0 0",
        "--color-button-text": "255 255 255",
        "--color-button-border": "0 0 0",
        "--color-button-secondary-bg": "255 255 255",
        "--color-button-secondary-text": "0 0 0",
        "--color-button-secondary-border": "0 0 0",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "0 0 0"
      }
    },
    {
      "id": "scheme-3",
      "name": "3",
      "tokens": {
        "--color-bg": "245 240 235",
        "--color-surface": "230 225 220",
        "--color-heading": "26 26 26",
        "--color-text": "26 26 26",
        "--color-muted": "153 153 153",
        "--color-primary": "0 0 0",
        "--color-accent": "0 0 0",
        "--color-button-bg": "0 0 0",
        "--color-button-text": "245 240 235",
        "--color-button-border": "0 0 0",
        "--color-button-secondary-bg": "245 240 235",
        "--color-button-secondary-text": "26 26 26",
        "--color-button-secondary-border": "26 26 26",
        "--color-button-2-bg": "245 240 235",
        "--color-button-2-text": "26 26 26",
        "--color-button-2-border": "26 26 26"
      }
    },
    {
      "id": "scheme-4",
      "name": "4",
      "tokens": {
        "--color-bg": "0 0 0",
        "--color-surface": "26 26 26",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "163 163 163",
        "--color-primary": "255 255 255",
        "--color-accent": "255 255 255",
        "--color-button-bg": "255 255 255",
        "--color-button-text": "0 0 0",
        "--color-button-border": "255 255 255",
        "--color-button-secondary-bg": "0 0 0",
        "--color-button-secondary-text": "255 255 255",
        "--color-button-secondary-border": "255 255 255",
        "--color-button-2-bg": "0 0 0",
        "--color-button-2-text": "255 255 255",
        "--color-button-2-border": "255 255 255"
      }
    },
    {
      "$comment": "Scheme-5 — светло-серый монохром из фактической палитры верстальщика: фон #F5F5F5 (плейсхолдер медиа RoseCollectionCard/Gallery), белая поверхность, родные чёрные текст и кнопки, muted #999999.",
      "id": "scheme-5",
      "name": "5",
      "tokens": {
        "--color-bg": "245 245 245",
        "--color-surface": "255 255 255",
        "--color-heading": "0 0 0",
        "--color-text": "0 0 0",
        "--color-muted": "153 153 153",
        "--color-primary": "0 0 0",
        "--color-accent": "0 0 0",
        "--color-button-bg": "0 0 0",
        "--color-button-text": "245 245 245",
        "--color-button-border": "0 0 0",
        "--color-button-secondary-bg": "245 245 245",
        "--color-button-secondary-text": "0 0 0",
        "--color-button-secondary-border": "0 0 0",
        "--color-button-2-bg": "245 245 245",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "0 0 0"
      }
    }
  ],
  "blocks": {
    "Hero": {
      "variant": "overlay"
    },
    "PopularProducts": {},
    "Collections": {},
    "Product": {},
    "Newsletter": {},
    "ContactForm": {}
  },
  "features": {
    "newsletter": true,
    "cart-drawer": true,
    "otp-auth": true,
    "wishlist": false,
    "color-swatches": true,
    "filter-sidebar": true,
    "puckDrivenPages": true
  },
  "fonts": [
    {
      "family": "Comfortaa",
      "weights": [
        400,
        500,
        600,
        700
      ],
      "source": "google"
    },
    {
      "family": "Manrope",
      "weights": [
        400,
        500,
        600,
        700
      ],
      "source": "google"
    }
  ],
  "manifestVersion": "2.0",
  "pages": [
    {
      "id": "home",
      "name": "Главная страница",
      "slug": "/",
      "role": "system",
      "contentFile": "pages/home.json",
      "isHome": true
    },
    {
      "id": "page-about",
      "name": "О нас",
      "slug": "/about",
      "role": "system",
      "contentFile": "pages/about.json"
    },
    {
      "id": "page-contacts",
      "name": "Контакты",
      "slug": "/contacts",
      "role": "system",
      "contentFile": "pages/contacts.json"
    },
    {
      "id": "page-catalog",
      "name": "Коллекции",
      "slug": "/catalog",
      "role": "system",
      "contentFile": "pages/catalog.json"
    },
    {
      "id": "page-collection",
      "name": "Страница коллекции",
      "slug": "/collections/preview",
      "role": "system",
      "contentFile": "pages/collection.json"
    },
    {
      "id": "page-cart",
      "name": "Корзина",
      "slug": "/cart",
      "role": "system",
      "contentFile": "pages/cart.json"
    },
    {
      "id": "page-product",
      "name": "Товар",
      "slug": "/product",
      "role": "system",
      "contentFile": "pages/product.json"
    },
    {
      "id": "page-checkout",
      "name": "Оформление заказа",
      "slug": "/checkout",
      "role": "system",
      "contentFile": "pages/checkout.json"
    }
  ]
}
