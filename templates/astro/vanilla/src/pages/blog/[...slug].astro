---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import publications from '../../data/publications.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  const list = publications || [];
  return list.map((pub: any) => ({
    params: { slug: pub.slug },
    props: { publication: pub },
  }));
}

const { publication } = Astro.props;
const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};
---
<BaseLayout title={`${publication?.title ?? 'Публикация'} — ${meta?.title ?? 'Мой магазин'}`} description={publication?.excerpt}>
  <Header {...headerProps} />

  <main class="flex-1 w-full" style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));">
    <article class="max-w-[800px] mx-auto px-4 sm:px-6" style="padding-top: 120px; padding-bottom: 120px;">
      <nav class="mb-[40px] font-body text-[14px]" style="color: #444444;">
        <a href="/" class="hover:opacity-80 transition-opacity" style="color: #444444;">Главная</a>
        <span class="mx-1">/</span>
        <a href="/blog/" class="hover:opacity-80 transition-opacity" style="color: #444444;">Блог</a>
        <span class="mx-1">/</span>
        <span style="color: rgb(var(--color-foreground));">{publication?.title}</span>
      </nav>

      {publication?.dateFormatted && (
        <time class="text-[14px] font-body block mb-4" style="color: #444444;">
          {publication.dateFormatted}
        </time>
      )}

      <h1 class="font-heading italic text-[20px] sm:text-[24px] font-normal leading-[1.2] mb-6" style="color: rgb(var(--color-foreground));">
        {publication?.title}
      </h1>

      {publication?.coverImageUrl && publication.coverImageUrl !== '/images/placeholder.png' && (
        <div class="mb-8 overflow-hidden" style="border-radius: var(--radius-card, 0px);">
          <img
            src={publication.coverImageUrl}
            alt={publication.title}
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>
      )}

      <div class="publication-content font-body text-[16px] leading-relaxed" set:html={publication?.content ?? ''} style="color: rgb(var(--color-foreground));" />

      <div class="mt-12 pt-8" style="border-top: 1px solid rgb(var(--color-foreground) / 0.1);">
        <a href="/blog/" class="text-[14px] font-body font-normal transition-opacity hover:opacity-80" style="color: rgb(var(--color-foreground));">
          &larr; Все статьи
        </a>
      </div>
    </article>
  </main>

  <Footer {...footerProps} />
</BaseLayout>

<style>
  .publication-content h2 { font-size: 1.25rem; font-weight: normal; font-style: italic; margin: 1.5em 0 0.75em; font-family: var(--font-heading, 'Bitter', serif); }
  .publication-content h3 { font-size: 1.1rem; font-weight: normal; font-style: italic; margin: 1.25em 0 0.5em; font-family: var(--font-heading, 'Bitter', serif); }
  .publication-content h4 { font-size: 1rem; font-weight: normal; font-style: italic; margin: 1em 0 0.5em; font-family: var(--font-heading, 'Bitter', serif); }
  .publication-content p { margin: 0.75em 0; color: #444444; }
  .publication-content ul, .publication-content ol { margin: 0.75em 0; padding-left: 1.5em; color: #444444; }
  .publication-content li { margin: 0.25em 0; }
  .publication-content a { text-decoration: underline; opacity: 0.85; }
  .publication-content a:hover { opacity: 1; }
  .publication-content img { max-width: 100%; height: auto; border-radius: var(--radius-card, 0px); margin: 1em 0; }
  .publication-content blockquote { border-left: 3px solid rgb(var(--color-foreground) / 0.2); padding-left: 1em; margin: 1em 0; color: #444444; }
</style>
