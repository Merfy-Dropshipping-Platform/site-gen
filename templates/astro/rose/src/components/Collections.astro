---
import CollectionCardItem from './shared/CollectionCardItem.astro';

interface Props {
  title?: string;
  subtitle?: string;
  titleSize?: string;
  subtitleSize?: string;
  dataSource?: string;
  collections?: Array<{ name: string; image: string; slug?: string }>;
  columnsCount?: number;
  imageView?: string;
  colorScheme?: string;
  padding?: { top?: number; bottom?: number };
}

const {
  title = 'Снова в продаже',
  subtitle = 'Стиль для каждой ситуации - найдите свой в каталоге.',
  titleSize = 'small',
  subtitleSize = 'small',
  dataSource = 'auto',
  collections = [],
  columnsCount = 3,
  imageView = 'portrait',
  colorScheme,
  padding = { top: 80, bottom: 80 },
} = Astro.props;
const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';

const headingFS: Record<string, { base: string; sm: string; md: string }> = {
  small: { base: '1.125rem', sm: '1.25rem', md: '1.5rem' },
  medium: { base: '1.25rem', sm: '1.5rem', md: '2rem' },
  large: { base: '1.5rem', sm: '1.875rem', md: '2.5rem' },
};
const textFS: Record<string, { base: string; sm: string; md: string }> = {
  small: { base: '0.75rem', sm: '0.875rem', md: '1rem' },
  medium: { base: '0.875rem', sm: '1rem', md: '1.25rem' },
  large: { base: '1rem', sm: '1.125rem', md: '1.5rem' },
};
const hfs = headingFS[titleSize] || headingFS.small;
const tfs = textFS[subtitleSize] || textFS.small;

const aspectMap: Record<string, string> = {
  portrait: '430/500',
  square: '1/1',
  wide: '16/9',
};

let collectionsData = collections || [];

if (dataSource === 'auto' || collectionsData.length === 0) {
  try {
    const imported = await import('../data/collections.json');
    collectionsData = imported.default || [];
  } catch {
    collectionsData = [];
  }
}

const cols = columnsCount || 3;
const aspect = aspectMap[imageView] || aspectMap.portrait;
---

<section id="collections" class={`w-full scroll-mt-16 sm:scroll-mt-20 ${schemeClass}`} style={`background: rgb(var(--color-background)); color: rgb(var(--color-foreground)); padding: ${padding?.top || 80}px 0 ${padding?.bottom || 80}px;`}>
  <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 md:px-8 lg:px-10 xl:px-12">
    <div class="flex flex-col items-center gap-2 sm:gap-3 md:gap-4 lg:gap-[5px] mb-8 sm:mb-10 md:mb-12 lg:mb-16 xl:mb-20">
      <h2 class="font-normal uppercase text-center font-heading text-theme-foreground collections-heading" style={`--fs-base:${hfs.base};--fs-sm:${hfs.sm};--fs-md:${hfs.md};`}>
        {title}
      </h2>
      {subtitle && (
        <p class="font-normal text-center px-2 sm:px-4 font-body text-theme-foreground collections-subtitle" style={`--ts-base:${tfs.base};--ts-sm:${tfs.sm};--ts-md:${tfs.md};`}>
          {subtitle}
        </p>
      )}
    </div>

    {collectionsData.length > 0 && (
    <div class="grid collections-grid" role="list">
      {collectionsData.map((collection, index) => (
        <CollectionCardItem
          name={collection.name}
          image={collection.image}
          slug={collection.slug}
          aspect={aspect}
          eager={index < 2}
        />
      ))}
    </div>
    )}
  </div>
</section>

<style define:vars={{ cols }}>
  .collections-grid {
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }
  .collections-heading { font-size: var(--fs-base); line-height: 1.115; }
  .collections-subtitle { font-size: var(--ts-base); line-height: 1.366; }
  @media (min-width: 640px) {
    .collections-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
    .collections-heading { font-size: var(--fs-sm); }
    .collections-subtitle { font-size: var(--ts-sm); }
  }
  @media (min-width: 1024px) {
    .collections-grid {
      grid-template-columns: repeat(var(--cols), 1fr);
      gap: 2.5rem;
    }
    .collections-heading { font-size: var(--fs-md); }
    .collections-subtitle { font-size: var(--ts-md); }
  }
</style>
