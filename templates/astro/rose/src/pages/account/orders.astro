---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};
---
<BaseLayout title={`Активные заказы — ${meta?.title ?? 'Мой сайт'}`}>
  <Header {...headerProps} />

  <main class="account-page-container">
    <a href="/account" class="account-back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Вернуться назад
    </a>

    <div class="account-title">
      <h1>Активные заказы</h1>
      <span class="account-subtitle" id="orders-email"></span>
    </div>

    <div id="orders-loading" style="color: rgb(var(--color-text-muted)); font-family: var(--font-body);">Загрузка...</div>

    <div id="orders-empty" class="hidden" style="font-family: var(--font-body); color: rgb(var(--color-text-muted));">
      У вас пока нет заказов
    </div>

    <div id="orders-list" class="hidden"></div>
  </main>

  <Footer {...footerProps} />

  <script is:inline src="/scripts/customer-store.js"></script>
  <script is:inline src="/scripts/customer-auth.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', async function() {
      if (!window.CustomerStore || !window.CustomerStore.isLoggedIn()) {
        window.location.href = '/login?redirect=/account/orders';
        return;
      }

      var loadingEl = document.getElementById('orders-loading');
      var emptyEl = document.getElementById('orders-empty');
      var listEl = document.getElementById('orders-list');
      var emailEl = document.getElementById('orders-email');

      try {
        var meResult = await window.CustomerAuth.me();
        if (meResult.success && meResult.data) {
          var customer = meResult.data.customer || meResult.data;
          emailEl.textContent = customer.email || '';
        }
      } catch (e) {}

      try {
        var config = window.__MERFY_CONFIG__ || {};
        var apiUrl = config.apiUrl || '';
        var storeId = config.shopId || config.storeId || config.siteId || '';
        var token = window.CustomerStore.getToken();

        var url = apiUrl + '/store/orders?skip=0&take=50';
        if (storeId) url += '&store_id=' + encodeURIComponent(storeId);

        var resp = await fetch(url, {
          headers: { 'Authorization': 'Bearer ' + token },
        });
        var result = await resp.json();

        loadingEl.classList.add('hidden');

        var orders = Array.isArray(result.data) ? result.data : result.data?.items;
        if (!result.success || !orders?.length) {
          emptyEl.classList.remove('hidden');
          return;
        }
        listEl.classList.remove('hidden');
        listEl.style.display = 'flex';
        listEl.style.flexDirection = 'column';
        listEl.style.gap = '1.5rem';

        orders.forEach(function(order) {
          var date = new Date(order.createdAt).toLocaleDateString('ru-RU', {
            day: '2-digit', month: '2-digit', year: '2-digit',
          });

          var row = document.createElement('div');
          row.className = 'account-order-row';
          row.innerHTML =
            '<div class="order-info">' +
              '<span class="order-number">Заказ №' + order.orderNumber + '</span>' +
              '<span class="order-date">от ' + date + '</span>' +
            '</div>' +
            '<a href="/account/order?n=' + encodeURIComponent(order.orderNumber) + '" class="account-button">Перейти</a>';
          listEl.appendChild(row);
        });
      } catch (err) {
        loadingEl.textContent = 'Не удалось загрузить заказы';
      }
    });
  </script>
</BaseLayout>
