---
import type { HeroProps } from './Hero.puckConfig';
import { HeroClasses as C } from './Hero.classes';

interface Props extends HeroProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  title,
  subtitle,
  image,
  images,
  cta,
  variant: variantProp,
  contentPosition: contentPositionProp,
  colorScheme,
  padding,
  size,
  overlay: overlayRaw,
} = raw as Props & {
  size?: 'small' | 'medium' | 'large';
  overlay?: number;
  [k: string]: unknown;
};
const schemeClass = typeof colorScheme === 'string' && colorScheme
  ? `color-scheme-${colorScheme.replace('scheme-', '')}`
  : '';

// Legacy constructor schema passes heading/text as nested objects (heading.text, text.content)
// plus backgroundImage + primaryButton.link.href. Normalise both shapes so any revision works.
const heading = raw.heading as { text?: string } | string | undefined;
const textObj = raw.text as { content?: string } | string | undefined;
const primaryButton = raw.primaryButton as
  | { text?: string; link?: { href?: string } | string }
  | undefined;
const secondaryButton = raw.secondaryButton as
  | { text?: string; link?: { href?: string } | string }
  | undefined;
// Pupa parity: backgroundImages = { url1, url2 } as imagePair. Fall back to flat backgroundImage/2.
const bgPair = raw.backgroundImages as { url1?: string; url2?: string } | undefined;
const backgroundImage = (bgPair?.url1) || (typeof raw.backgroundImage === 'string' ? raw.backgroundImage : '');
const backgroundImage2 = (bgPair?.url2) || (typeof raw.backgroundImage2 === 'string' ? (raw.backgroundImage2 as string) : '');

// Constructor writes heading as { text, size } via Hero puckConfig. Prefer
// heading.text when present so merchant edits in the constructor "Текст"
// field win over the legacy default `title` prop. Fall back to legacy title
// when heading.text is empty.
const resolvedTitle =
  (typeof heading === 'string' ? heading : heading?.text) ||
  (typeof title === 'string' && title) ||
  '';
const resolvedSubtitle =
  (typeof subtitle === 'string' && subtitle) ||
  (typeof textObj === 'string' ? textObj : textObj?.content) ||
  '';

// 091 — heading.size / text.size управляют CSS-var'ами `--hero-heading-size`
// и `--hero-text-size` на root section. Base classes C.title / C.subtitle
// читают их через var(...) с fallback'ом. Никаких !important / class overrides
// — single source of truth: data → CSS var → token cascade.
const resolvedHeadingSize: 'small' | 'medium' | 'large' =
  (typeof heading === 'object' && heading && typeof heading.size === 'string'
    ? (heading.size as 'small' | 'medium' | 'large')
    : 'medium');
const resolvedTextSize: 'small' | 'medium' | 'large' =
  (typeof textObj === 'object' && textObj && typeof (textObj as { size?: unknown }).size === 'string'
    ? ((textObj as { size: string }).size as 'small' | 'medium' | 'large')
    : 'medium');

// Heading: multiplier к --size-hero-heading (тема задаёт base).
// Text: фиксированные размеры (тема может через --hero-text-size override'нуть).
const headingSizeVar = {
  small:  'calc(var(--size-hero-heading) * 0.75)',
  medium: 'var(--size-hero-heading)',
  large:  'calc(var(--size-hero-heading) * 1.5)',
}[resolvedHeadingSize];

const textSizeVar = {
  small:  '14px',
  medium: '16px',
  large:  '20px',
}[resolvedTextSize];

const sizeVarsStyle = `--hero-heading-size:${headingSizeVar};--hero-text-size:${textSizeVar};`;
const primaryLink = typeof primaryButton?.link === 'object'
  ? primaryButton.link?.href
  : primaryButton?.link;
const resolvedCta = cta ?? (primaryButton?.text
  ? { text: primaryButton.text, href: primaryLink ?? '#' }
  : undefined);
const secondaryLink = typeof secondaryButton?.link === 'object'
  ? secondaryButton.link?.href
  : secondaryButton?.link;
const resolvedSecondaryCta = secondaryButton?.text
  ? { text: secondaryButton.text, href: secondaryLink ?? '#' }
  : undefined;

// Determine variant: explicit prop wins, else if any background image → overlay.
const variant = (variantProp as HeroProps['variant'])
  ?? (backgroundImage ? 'overlay' : 'centered');

const innerClass = C.inner[variant];
const imageClass = C.image[variant];

// Position имеет 9 значений (top-* / center-* / bottom-*). hAlign/vAlign
// таблицы в Hero.classes.ts покрывают все 9.
type ContentPos =
  | 'top-left' | 'top-center' | 'top-right'
  | 'center-left' | 'center' | 'center-right'
  | 'bottom-left' | 'bottom-center' | 'bottom-right';
const positionRaw =
  typeof raw.position === 'string' ? (raw.position as string) :
  typeof contentPositionProp === 'string' ? (contentPositionProp as string) : 'center';
const VALID_POSITIONS: ReadonlyArray<ContentPos> = [
  'top-left', 'top-center', 'top-right',
  'center-left', 'center', 'center-right',
  'bottom-left', 'bottom-center', 'bottom-right',
];
const contentPositionMapped: ContentPos = (VALID_POSITIONS as readonly string[]).includes(positionRaw)
  ? (positionRaw as ContentPos)
  : 'center';
// Применяем hAlign/vAlign для всех variants (centered/overlay/split etc),
// а не только для 'overlay'. Раньше vAlign работал только в overlay, и
// для default 'centered' (когда нет фонового изображения) позиция всегда
// schлопывалась в center. Теперь Позиция влияет везде.
const hAlignClass = C.hAlign[contentPositionMapped];
const vAlignClass = C.vAlign[contentPositionMapped];

// Pupa parity: alignment field controls text-align inside content.
// Default = 'text-center' (per Figma 2:16517 — heading + subtitle + button
// центрированы). Будущая настройка в sidebar позволит сменить на left/right.
const alignmentRaw = typeof raw.alignment === 'string' ? raw.alignment : '';
const alignmentClass =
  alignmentRaw === 'left' ? 'text-left' :
  alignmentRaw === 'right' ? 'text-right' :
  'text-center';

// Pupa parity: container='false' → no max-width wrapping (full bleed).
const containerEnabled = raw.container !== 'false';
const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';

// Hero min-height by size, matching 072 live templates.
const heightVars = {
  small:  '--h-base:280px;--h-sm:320px;--h-md:360px;--h-lg:400px;--h-xl:440px;--h-xxl:480px;',
  medium: '--h-base:340px;--h-sm:400px;--h-md:480px;--h-lg:560px;--h-xl:640px;--h-xxl:720px;',
  large:  '--h-base:400px;--h-sm:500px;--h-md:600px;--h-lg:700px;--h-xl:800px;--h-xxl:1080px;',
}[size ?? 'medium'];

// Затемнение = полупрозрачный чёрный over фон. Раньше использовался
// rgb(var(--color-foreground) / N) — но в некоторых color-схемах
// --color-foreground = белый/светлый, overlay становился невидим.
// Теперь жёстко чёрный — slider реально затемняет картинку на любой схеме.
const overlayPct = typeof overlayRaw === 'number' ? overlayRaw / 100 : 0;
const overlayStyle = `background-color: rgb(0 0 0 / ${overlayPct});`;

// Normalise image reference across shapes preview coercer may pass through.
const imageUrlFromObj =
  typeof image === 'string'
    ? image
    : image && typeof (image as { url?: unknown }).url === 'string'
      ? (image as { url: string }).url
      : '';
const imageUrl = imageUrlFromObj || backgroundImage;
const imageAlt =
  image && typeof (image as { alt?: unknown }).alt === 'string'
    ? (image as { alt: string }).alt
    : '';

// grid-4: take up to 4 images from `images[]`; fall back to duplicating the
// single `image` prop so previews never look broken before the merchant
// configures all 4 slots.
type ImageShape = { url: string; alt: string };
const gridFallback: ImageShape = { url: imageUrl, alt: imageAlt };
const realImagesCount =
  variant === 'grid-4' && Array.isArray(images) && images.length > 0
    ? Math.min(images.length, 4)
    : 0;
const gridImages: ImageShape[] =
  variant === 'grid-4'
    ? (Array.isArray(images) && images.length > 0
        ? images.slice(0, 4).map((i) => ({
            url: typeof i === 'string' ? i : ((i as ImageShape)?.url ?? ''),
            alt: typeof i === 'string' ? '' : ((i as ImageShape)?.alt ?? ''),
          }))
        : [gridFallback, gridFallback, gridFallback, gridFallback])
    : [];
// Pad to exactly 4 tiles (empty tiles render as placeholder background)
while (gridImages.length < 4 && variant === 'grid-4') {
  gridImages.push(gridFallback);
}

// 084 vanilla pilot: additive carousel mode.
// Default 'single' preserves pre-edit rose render byte-for-byte.
// 'carousel' enables slides[] + pagination + autoplay (ported from Slideshow).
const rawSlides = Array.isArray((Astro.props as any).slides)
  ? ((Astro.props as any).slides as any[])
  : [];
const effectiveMode =
  (Astro.props as any).mode === 'carousel' && rawSlides.length > 0
    ? 'carousel'
    : 'single';
const heroPagination = (Astro.props as any).pagination ?? 'numbers';
const heroAutoplay = (Astro.props as any).autoplay === true;
const heroInterval = typeof (Astro.props as any).interval === 'number'
  ? (Astro.props as any).interval
  : 5;
const heroImageFullBleed = (Astro.props as any).imageFullBleed === true;
const heroButtonStyle =
  (Astro.props as any).buttonStyle === 'outlined' ? 'outlined' : 'solid';
const heroButtonStyleClass = heroButtonStyle === 'outlined'
  ? C.buttonStyleOutlined
  : C.buttonStyleSolid;
---
{effectiveMode === 'single' && variant === 'split-bloom' && (
  <section
    class:list={[C.root, schemeClass]}
    data-puck-component-id={id}
    data-variant="split-bloom"
    style={`${paddingStyle} ${sizeVarsStyle}`}
  >
    <div class={C.inner['split-bloom']}>
      <div class={C.splitBloomTextCol}>
        {resolvedTitle && (
          <h1 class={C.splitBloomKicker} data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">{resolvedTitle}</h1>
        )}
        {resolvedSubtitle && (
          <p class={C.splitBloomSubtitle} data-puck-subsection-parent={id} data-puck-subsection-index="101" data-puck-subsection-field="text">{resolvedSubtitle}</p>
        )}
        {(resolvedCta?.text || resolvedSecondaryCta?.text) && (
          <div class="flex flex-wrap gap-3">
            {resolvedCta?.text && (
              <a href={resolvedCta.href} class={C.splitBloomCta} data-puck-subsection-parent={id} data-puck-subsection-index="102" data-puck-subsection-field="primaryButton">{resolvedCta.text}</a>
            )}
            {resolvedSecondaryCta?.text && (
              <a href={resolvedSecondaryCta.href} class:list={[C.splitBloomCta, 'opacity-90 underline']} data-puck-subsection-parent={id} data-puck-subsection-index="103" data-puck-subsection-field="secondaryButton">{resolvedSecondaryCta.text}</a>
            )}
          </div>
        )}
      </div>
      <div class={C.splitBloomImageCol}>
        {imageUrl && (
          <img src={imageUrl} alt={imageAlt} class={C.image['split-bloom']} />
        )}
      </div>
    </div>
  </section>
)}

{effectiveMode === 'single' && variant !== 'split-bloom' && (
<section
  class:list={[C.root, 'min-h-[var(--h-base)] sm:min-h-[var(--h-sm)] md:min-h-[var(--h-md)] lg:min-h-[var(--h-lg)] xl:min-h-[var(--h-xl)] 2xl:min-h-[var(--h-xxl)]', schemeClass]}
  data-puck-component-id={id}
  data-variant={variant}
  style={`${paddingStyle} ${heightVars} ${sizeVarsStyle}`}
>
  {variant === 'overlay' && imageUrl && (
    <>
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat"
        style={`background-image: url('${imageUrl}');`}
        aria-hidden="true"
      />
      <div class="absolute inset-0" style={overlayStyle} aria-hidden="true" />
    </>
  )}
  {variant === 'centered' && imageUrl && (
    <>
      <img src={imageUrl} alt={imageAlt} class={imageClass} />
      {/* Затемнение поверх фона. Применяется для centered тоже — раньше
          overlay-слой рендерился только в variant='overlay', sidebar slider
          «Затемнение» для default centered ничего не делал. */}
      <div class="absolute inset-0 -z-[5]" style={overlayStyle} aria-hidden="true" />
    </>
  )}
  <div class:list={[C.container, innerClass, vAlignClass, 'relative z-10']} style="min-height: inherit;">
    <div class:list={[
      'flex flex-col gap-4 sm:gap-5 md:gap-6 lg:gap-5 xl:gap-[25px] w-full px-4 sm:px-6 md:px-8',
      variant === 'split'
        ? 'items-start text-left max-w-xl'
        : [hAlignClass, variant === 'overlay' ? 'max-w-7xl' : 'max-w-7xl']
    ]}>
      <header class="flex flex-col gap-1 sm:gap-2 md:gap-3 lg:gap-4 xl:gap-[5px]">
        {variant === 'split' && resolvedSubtitle && (
          <p class={C.subtitle} data-puck-subsection-parent={id} data-puck-subsection-index="101" data-puck-subsection-field="text">{resolvedSubtitle}</p>
        )}
        {resolvedTitle && (
          <h1 class={C.title} data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">{resolvedTitle}</h1>
        )}
        {variant !== 'split' && resolvedSubtitle && (
          <p class={C.subtitle} data-puck-subsection-parent={id} data-puck-subsection-index="101" data-puck-subsection-field="text">{resolvedSubtitle}</p>
        )}
      </header>
      {variant === 'grid-4' && (
        <div class={C.gridContainer} role="group" aria-label="Hero image grid">
          {gridImages.map((img, i) => (
            <div
              class={C.gridTile}
              data-puck-subsection-parent={i < realImagesCount ? id : undefined}
              data-puck-subsection-index={i < realImagesCount ? i : undefined}
              data-puck-subsection-field={i < realImagesCount ? 'images' : undefined}
            >
              {img.url ? (
                <img
                  src={img.url}
                  alt={img.alt || `Hero image ${i + 1}`}
                  class="absolute inset-0 w-full h-full object-cover"
                  loading={i < 2 ? 'eager' : 'lazy'}
                />
              ) : (
                <span class="sr-only">Пустой слот изображения</span>
              )}
            </div>
          ))}
        </div>
      )}
      {(resolvedCta?.text || resolvedSecondaryCta?.text) && (
        <div class:list={[
          'flex flex-wrap gap-[25px]',
          variant === 'split'
            ? 'justify-start'
            : contentPositionMapped === 'bottom-left'
              ? 'justify-start'
              : contentPositionMapped === 'bottom-right'
                ? 'justify-end'
                : 'justify-center',
          alignmentClass === 'text-left' ? 'justify-start' :
          alignmentClass === 'text-right' ? 'justify-end' :
          alignmentClass === 'text-center' ? 'justify-center' : '',
        ]}>
          {resolvedCta?.text && (
            <a href={resolvedCta.href} class={C.ctaButton} data-puck-subsection-parent={id} data-puck-subsection-index="102" data-puck-subsection-field="primaryButton">{resolvedCta.text}</a>
          )}
          {resolvedSecondaryCta?.text && (
            <a href={resolvedSecondaryCta.href} class:list={[C.ctaButton, 'opacity-90 underline-offset-2']} data-puck-subsection-parent={id} data-puck-subsection-index="103" data-puck-subsection-field="secondaryButton">{resolvedSecondaryCta.text}</a>
          )}
        </div>
      )}
    </div>
    {variant === 'split' && imageUrl && (
      <img src={imageUrl} alt={imageAlt} class={imageClass} />
    )}
  </div>
</section>
)}

{effectiveMode === 'carousel' && (
  <section
    class:list={[C.root, schemeClass]}
    data-puck-component-id={id}
    data-variant="carousel"
    style={`${paddingStyle} ${sizeVarsStyle}`}
  >
    <div class={C.carouselRoot} data-merfy-hero-carousel
         data-autoplay={String(heroAutoplay)}
         data-interval={heroInterval}>
      {rawSlides.map((slide, idx) => {
        // 084 vanilla pilot: legacy-prop-normalizer collapses {text, size}
        // and {content, size} envelopes to bare strings. Handle both shapes.
        const slideHeadingText =
          typeof slide.heading === 'object' ? slide.heading?.text :
          typeof slide.heading === 'string' ? slide.heading :
          '';
        const slideTextContent =
          typeof slide.text === 'object' ? slide.text?.content :
          typeof slide.text === 'string' ? slide.text :
          '';
        const slideButtonText = slide.buttonText ?? '';
        const slideButtonLink =
          typeof slide.buttonLink === 'string' ? slide.buttonLink : '#';
        return (
        <div class:list={[C.slide, idx === 0 ? '' : C.slideHidden]}
             data-slide-id={slide.id}
             data-slide-index={idx}
             data-puck-subsection-parent={id}
             data-puck-subsection-index={idx}
             data-puck-subsection-field="slides">
          {slide.imageUrl && (
            <img src={slide.imageUrl}
                 alt={slideHeadingText ?? ''}
                 class:list={['absolute inset-0 -z-10 object-cover w-full h-full',
                              heroImageFullBleed && C.imageFullBleed]} />
          )}
          <div class="relative z-10 max-w-[var(--container-max-width)] mx-auto px-[300px] flex flex-col gap-8 items-start">
            <div class="flex flex-col gap-1 items-start">
              {slideHeadingText && (
                <h1 class="[font-family:var(--font-heading)] italic text-[length:var(--size-hero-heading)] text-[rgb(var(--color-heading))] font-normal">
                  {slideHeadingText}
                </h1>
              )}
              {slideTextContent && (
                <p class="[font-family:var(--font-body)] italic text-[16px] text-[rgb(var(--color-text)/0.95)]">
                  {slideTextContent}
                </p>
              )}
            </div>
            {slideButtonText && (
              <a href={slideButtonLink}
                 class:list={[
                   'inline-flex items-center justify-center h-[var(--size-hero-button-h,48px)] rounded-[var(--radius-button)] px-4 border bg-[rgb(var(--color-button-bg))] border-[rgb(var(--color-button-border))] text-[rgb(var(--color-button-text))] [font-family:var(--font-body)] text-[16px] uppercase',
                   heroButtonStyleClass,
                 ]}>
                {slideButtonText}
              </a>
            )}
          </div>
        </div>
        );
      })}
      {heroPagination !== 'none' && rawSlides.length > 1 && (
        <div class={C.pagination}>
          <button class={C.carouselArrow} data-pagination-prev aria-label="Previous">←</button>
          {rawSlides.map((_, idx) => (
            <button class:list={[C.paginationButton, idx === 0 && C.paginationButtonActive]}
                    data-pagination-index={idx}
                    type="button">{idx + 1}</button>
          ))}
          <button class={C.carouselArrow} data-pagination-next aria-label="Next">→</button>
        </div>
      )}
    </div>
  </section>
  <script>
    import '../../runtime/hero-carousel';
  </script>
)}
