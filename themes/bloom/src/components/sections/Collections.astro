---
// ОЖИВЛЕНИЕ (Фаза B, контракт rose Collections T13): конструкторная схема
// theme-base Collections.puckConfig поверх разметки верстальщика. Тело +
// плейсхолдер verbatim (страницы зовут <Collections /> без пропсов — дефолты
// дают прежний рендер). Канон-дефолты конструктора (headingSize medium /
// subtitleSize small / titleAlignment 'left' и gridAspect '1:1' из blockDefaults
// bloom / columns 3) → пиксель верстальщика; дефолтная ветка каждого
// тернарника = прежняя строка классов байт-в-байт (цвета → токены с
// пиксель-фоллбеком родных литералов, MANNER.md §7).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Figma 1:19335 — ПУСТОЕ состояние секции «Список коллекций»: дословный заголовок
// «Список коллекций» (без подзаголовка), а НЕ дефолт-копирайт верстальщика
// («Сейчас в тренде»). Мерчант задал свой heading/title → его и рендерим.
const sectionTitle =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title ?? "Список коллекций";
// Подзаголовка у верстальщика НЕТ — рендер ТОЛЬКО при непустом пропе.
const sectionSubtitle =
	typeof p.subtitle === "string" && p.subtitle.trim() ? p.subtitle : undefined;

// КОНТРАКТ-ПЛЕЙСХОЛДЕР (Figma 1:19335 / theme-base Collections.astro
// DEMO_COLLECTIONS): пустой пикер → НЕ мок-товары верстальщика, а 3 пустые
// квадратные карточки (gray fill = rgb(var(--color-surface)) ≈ #FBFBFB) с
// лейблом «Коллекция» под каждой. Реальные коллекции магазина подменяют их
// гидрацией autofillCollections (ниже) — паритет PopularProducts DEMO_PRODUCTS.
const DEMO_COLLECTIONS = [
	{ name: "Коллекция" },
	{ name: "Коллекция" },
	{ name: "Коллекция" },
];

// Канон headingSize: 'medium' (canon-default) и отсутствие = роль «заголовок
// секции» верстальщика дословно (18/md:20). Лестница §9: small 15/17, large 22/24.
const headingCls =
	p.headingSize === "small"
		? "font-urbanist text-[15px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[17px]"
		: p.headingSize === "large"
			? "font-urbanist text-[22px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[24px]"
			: "font-urbanist text-[18px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[20px]";
// Канон subtitleSize: 'small' (canon-default) и отсутствие = body-роль манеры
// (Inter 300 16px, muted §1); medium ≈1.2× (19), large ≈1.44× (23) — ряд rose.
const subtitleCls =
	p.subtitleSize === "medium"
		? "font-inter text-[19px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
		: p.subtitleSize === "large"
			? "font-inter text-[23px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
			: "font-inter text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]";
// Канон titleAlignment: 'left' (canon-default из blockDefaults) и отсутствие =
// литерал верстальщика (заголовок слева, без класса). Двигают только center/right.
const titleAlignCls =
	p.titleAlignment === "center" ? "text-center" : p.titleAlignment === "right" ? "text-right" : "";
// Обёртке заголовка класс нужен только при выравнивании или подзаголовке
// (дефолт = прежний `<div data-animate>` без class байт-в-байт).
const headWrapCls =
	[titleAlignCls, sectionSubtitle ? "flex flex-col gap-2" : ""].filter(Boolean).join(" ") ||
	undefined;

// Канон columns 1-6: 3 (canon-default = lg:grid-cols-3 верстальщика) и
// отсутствие → дефолт-ветка (1→sm:2→lg:3). Заданное значение применяется уже
// с sm: раньше — только с lg, потому на sm-md (640-1023px) залипало 2 и слайдер
// игнорировался. Моб (<sm) всегда 1.
const colsRaw =
	typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : undefined;
const cols = colsRaw && colsRaw !== 3 ? colsRaw : undefined;
const gridBase =
	"grid w-full grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3 lg:gap-x-[16px] lg:gap-y-10";
const gridCls = cols
	? "grid w-full grid-cols-1 gap-10 sm:grid-cols-[repeat(var(--cols),minmax(0,1fr))] lg:gap-x-[16px] lg:gap-y-10"
	: gridBase;
const gridStyle = cols ? `--cols:${cols}` : undefined;

// Канон imageView square/portrait/wide — «Вид изображения» плиток коллекций
// (класс НА самой медиа-плитке li>a>div, не override-утилита). 'square'/отсутствие
// = квадрат манеры (aspect-square §4); 'portrait' → 430/500, 'wide' → 16/9.
// Паритет rose Collections: настройку ведёт imageView. Раньше тернар гейтил на
// legacy blockDefaults `gridAspect:'1:1'` ПЕРВЫМ — а он присутствует ВСЕГДА
// (дефолт темы), поэтому imageView (portrait/wide) до веток не доходил и был
// МЁРТВ (плитки всегда aspect-square). gridAspect'1:1' теперь = синоним square.
const tileAspect =
	p.imageView === "portrait"
		? "aspect-[430/500]"
		: p.imageView === "wide"
			? "aspect-[16/9]"
			: p.gridAspect === "portrait"
				? "aspect-[430/500]"
				: p.gridAspect === "wide"
					? "aspect-[16/9]"
					: "aspect-square";
// Канон cardCaptionStyle: 'uppercase' (canon-default из blockDefaults) и
// отсутствие = подпись uppercase; 'default' — обычный регистр.
const captionCase = p.cardCaptionStyle === "default" ? "" : " uppercase";

// Канон collections[] (≤10): плитки коллекций из пропса при непустом массиве
// (название/картинка/ссылка по shape схемы; без картинки — пустая surface-плитка
// как канон-плейсхолдер). Иначе — пустое состояние (Figma 1:19335): плейсхолдер-
// плитки DEMO_COLLECTIONS, НЕ мок-демо верстальщика. SSR рендерит сохранённые поля
// item; резолв collectionId→имя/обложка делает SSR-фетч (ниже) + живая гидрация
// (data-collection-ref): live — /data/collections.json, превью — storefront-data;
// паритет theme-base (имя коллекции перебивает ручной heading, обложка — при пустой своей).
const cardLinkBase =
	typeof p.cardLinkBase === "string" && p.cardLinkBase.trim() ? p.cardLinkBase : "/catalog?collection=";
const propCollections = (Array.isArray(p.collections) ? p.collections : [])
	.filter((c: any) => c && typeof c === "object")
	.slice(0, 10)
	.map((c: any, i: number) => {
		const collectionId =
			typeof c.collectionId === "string" && c.collectionId.trim() ? c.collectionId.trim() : null;
		return {
			collectionId,
			name:
				(typeof c.heading === "string" && c.heading) ||
				(typeof c.name === "string" && c.name) ||
				"Коллекция",
			// Плейсхолдер пустого состояния (Figma 1:19335): карточка без выбранной
			// картинки = ПУСТАЯ surface-плитка (НЕ мок-фото верстальщика). На live/SSR
			// (data-collection-ref / SSR-резолв ниже) подставится реальное фото коллекции.
			image: typeof c.image === "string" && c.image ? c.image : "",
			hasOwnImage: !!(typeof c.image === "string" && c.image),
			href: collectionId ? `${cardLinkBase}${collectionId}` : "#",
		};
	});
const usePropCollections = propCollections.length > 0;

// SSR-резолв реальных коллекций по collectionId (Figma-цель: коллекция ВЫБРАНА →
// реальное имя/обложка ПРЯМО в статике, чтобы их видело и ПРЕВЬЮ конструктора —
// Astro Container не исполняет клиентскую module-гидрацию ниже). Эталон —
// rose Collections.astro / rose Popular.astro (siteId инжектит рендер-пайплайн
// preview.service / build). Нет siteId / выбранных collectionId / ошибка →
// resolved пуст → остаётся SSR (heading/обложка из пропса), живая гидрация ниже
// освежит данные на live. Паритет theme-base resolveManual: имя коллекции
// перебивает ручной heading, обложка — только при пустой своей (hasOwnImage).
const siteId = typeof p.siteId === "string" ? p.siteId : "";
const wantResolve = usePropCollections && propCollections.some((c) => c.collectionId);
const resolvedCols = new Map<string, { name?: string; image?: string }>();
if (wantResolve && siteId) {
	try {
		const base = (import.meta as any).env?.SITES_INTERNAL_BASE ?? "http://localhost:3114";
		const res = await fetch(`${base}/api/sites/${siteId}/storefront-data`).catch(() => null);
		if (res && res.ok) {
			const data: any = await res.json();
			const cols: any[] = Array.isArray(data?.collections) ? data.collections : [];
			for (const c of propCollections) {
				if (!c.collectionId) continue;
				const m = cols.find(
					(x) =>
						x &&
						(x.id === c.collectionId ||
							x.slug === c.collectionId ||
							x.name === c.collectionId ||
							x.handle === c.collectionId),
				);
				if (!m) continue;
				const cover =
					(typeof m.image === "string" && m.image) ||
					(Array.isArray(m.images) && typeof m.images[0] === "string" ? m.images[0] : "");
				resolvedCols.set(c.collectionId, {
					name: typeof m.name === "string" ? m.name : undefined,
					image: cover || undefined,
				});
			}
		}
	} catch {
		/* нет данных — остаётся SSR из пропса, гидрация освежит на live */
	}
}
// Применяем резолв к карточкам пропса: реальное имя перебивает ручной heading,
// обложка — только если мерчант не загрузил свою.
const resolvedCollections = propCollections.map((c) => {
	const r = c.collectionId ? resolvedCols.get(c.collectionId) : undefined;
	if (!r) return c;
	return {
		...c,
		name: r.name || c.name,
		image: c.hasOwnImage ? c.image : r.image || c.image,
	};
});

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id="collections"
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-20 pt-20 md:px-20 md:pb-[120px] md:pt-[120px] 2xl:px-[300px]"
	aria-labelledby="collections-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-10">
		<div
			data-animate
			class={headWrapCls}
			data-puck-subsection-parent={id}
			data-puck-subsection-index="100"
			data-puck-subsection-field="heading"
		>
			<h2 id="collections-title" class={headingCls}>
				{sectionTitle}
			</h2>
			{sectionSubtitle && <p class={subtitleCls}>{sectionSubtitle}</p>}
		</div>

		<ul class={gridCls} role="list" data-animate data-animate-delay="0.1s" style={gridStyle} data-collections-autofill={!usePropCollections ? "" : undefined}>
			{usePropCollections ? resolvedCollections.map((c, i) => (
				<li>
					<a
						href={c.href}
						class="group flex w-full cursor-pointer flex-col gap-4"
						aria-label={c.name}
						data-nt="bloom-collection-card"
						data-collection-ref={c.collectionId ?? undefined}
						data-own-image={c.hasOwnImage ? "true" : undefined}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="collections"
					>
						<div
							class={`${tileAspect} w-full overflow-hidden rounded-[var(--radius-media,12px)] bg-[rgb(var(--color-surface,245_245_245))]`}
							aria-hidden={c.image ? undefined : "true"}
						>
							{c.image && (
								<img
									src={c.image}
									alt={c.name}
									loading="lazy"
									class="!h-full !w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.05]"
								/>
							)}
						</div>
						<h3
							class={`bloom-collection-name w-full text-left font-inter text-[16px] font-light leading-none text-[rgb(var(--color-text,0_0_0))] transition-opacity group-hover:opacity-70 max-sm:text-[12px]${captionCase}`}
						>
							{c.name}
						</h3>
					</a>
				</li>
			)) : DEMO_COLLECTIONS.map((c) => (
				<li>
					<a
						href="#"
						class="group flex w-full cursor-pointer flex-col gap-4"
						aria-label={c.name}
						data-nt="bloom-collection-card"
					>
						<div
							class={`${tileAspect} w-full overflow-hidden rounded-[var(--radius-media,12px)] bg-[rgb(var(--color-surface,251_251_251))]`}
							aria-hidden="true"
						></div>
						<h3
							class={`bloom-collection-name w-full text-left font-inter text-[16px] font-light leading-none text-[rgb(var(--color-text,0_0_0))] transition-opacity group-hover:opacity-70 max-sm:text-[12px]${captionCase}`}
						>
							{c.name}
						</h3>
					</a>
				</li>
			))}
		</ul>
	</div>
</section>

<script>
	import { loadRealCollections, findCollection, escapeHtml } from "../../lib/storefront-hydrate";

	// Резолв collectionId→имя/обложка на плитках (data-collection-ref).
	// Паритет theme-base resolveManual: имя коллекции перебивает ручной heading;
	// обложка коллекции подставляется, только если мерчант не загрузил свою
	// (data-own-image). Без данных (demo-сборка) — no-op, SSG остаётся.
	const hydrateCollectionTiles = async () => {
		const tiles = Array.from(
			document.querySelectorAll<HTMLElement>('[data-nt="bloom-collection-card"][data-collection-ref]'),
		);
		if (tiles.length === 0) return;
		const collections = await loadRealCollections();
		if (!collections) return;
		for (const tile of tiles) {
			const col = findCollection(collections, tile.getAttribute("data-collection-ref"));
			if (!col) continue;
			if (col.name) {
				const h3 = tile.querySelector(".bloom-collection-name");
				if (h3 && h3.textContent !== col.name) h3.textContent = col.name;
				tile.setAttribute("aria-label", col.name);
			}
			const cover = col.image || (Array.isArray(col.images) ? col.images[0] : "");
			if (cover && tile.getAttribute("data-own-image") !== "true") {
				const img = tile.querySelector("img");
				if (img && img.getAttribute("src") !== cover) {
					img.setAttribute("src", cover);
					if (col.name) img.setAttribute("alt", col.name);
				}
			}
		}
	};

	// АВТОПОДСТАНОВКА: пустой пикер (SSR = плейсхолдер-карточки «Коллекция») →
	// реальные коллекции магазина из /data/collections.json (live) / storefront-data
	// (превью). Явный выбор в пикере имеет приоритет (грид не помечен
	// data-collections-autofill). Реальных нет (demo-сборка без collections.json) →
	// no-op, плейсхолдер остаётся (контракт-заглушка Figma 1:19335, НЕ мок-фото
	// верстальщика). Разметка плитки = propCollections-ветка bloom (canon-default при
	// пустом пикере: gridAspect '1:1' → aspect-square, cardCaptionStyle 'uppercase').
	// Обложка: своя картинка коллекции, иначе ПУСТАЯ surface-плитка (паритет rose
	// Collections — не дизайнерский мок верстальщика).
	const autofillCollections = async () => {
		const grids = Array.from(document.querySelectorAll<HTMLElement>("ul[data-collections-autofill]"));
		if (grids.length === 0) return;
		const collections = await loadRealCollections();
		if (!collections || collections.length === 0) return;
		const visible = collections.filter((c) => c && c.slug !== "general").slice(0, 6);
		if (visible.length === 0) return;
		const html = visible
			.map((c) => {
				const name = escapeHtml(c.name || "Коллекция");
				const ref = c.slug || c.id || "";
				const href = "/catalog?collection=" + encodeURIComponent(ref);
				const cover = c.image || (Array.isArray(c.images) ? c.images[0] : "") || "";
				const media = cover
					? `<img src="${escapeHtml(cover)}" alt="${name}" loading="lazy" class="!h-full !w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.05]" />`
					: "";
				return `<li><a href="${href}" class="group flex w-full cursor-pointer flex-col gap-4" aria-label="${name}" data-nt="bloom-collection-card">
			<div class="aspect-square w-full overflow-hidden rounded-[var(--radius-media,12px)] bg-[rgb(var(--color-surface,245_245_245))]">${media}</div>
			<h3 class="bloom-collection-name w-full text-left font-inter text-[16px] font-light leading-none text-[rgb(var(--color-text,0_0_0))] transition-opacity group-hover:opacity-70 max-sm:text-[12px] uppercase">${name}</h3>
		</a></li>`;
			})
			.join("");
		for (const grid of grids) grid.innerHTML = html;
	};

	hydrateCollectionTiles();
	autofillCollections();
	document.addEventListener("astro:page-load", () => {
		hydrateCollectionTiles();
		autofillCollections();
	});
</script>
