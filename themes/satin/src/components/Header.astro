---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { SITE_TITLE } from "../consts";
import { catalogProducts } from "../data/products";

const searchIndex = catalogProducts.map((p) => ({
	id: p.id,
	name: p.name,
	price: p.price,
	image: p.image,
	href: `/products/${p.id}`,
}));

interface NavLink {
	label: string;
	href: string;
	mega?: boolean;
	match?: (pathname: string) => boolean;
}

const nav: NavLink[] = [
	{ label: "Коллекции", href: "/catalog", mega: true, match: (p) => p === "/" || p.startsWith("/catalog") || p.startsWith("/products") },
	{ label: "История", href: "/about", match: (p) => p.startsWith("/about") },
	{ label: "Контакты", href: "/contacts" },
];

// Mega-menu (Коллекции hover) — mirrors the Figma "List" dropdown.
const womenCats = ["Верхняя одежда", "Джемперы и кардиганы", "Худи и свитшоты", "Футболки и топы", "Джинсы и брюки", "Костюмы", "Аксессуары"];
const menCats = ["Верхняя одежда", "Джемперы и кардиганы", "Худи и свитшоты", "Футболки и поло", "Джинсы и шорты", "Костюмы", "Аксессуары"];
const socials = [
	{ name: "social-telegram", href: "https://t.me/", label: "Telegram" },
	{ name: "social-tiktok", href: "https://tiktok.com/", label: "TikTok" },
	{ name: "social-vk", href: "https://vk.com/", label: "VK" },
	{ name: "social-youtube", href: "https://youtube.com/", label: "YouTube" },
	{ name: "social-yandex-dzen", href: "https://dzen.ru/", label: "Дзен" },
];

const pathname = Astro.url.pathname;
const isActive = (link: NavLink) => (link.match ? link.match(pathname) : pathname === link.href);
---

<div class="sticky top-0 z-50 w-full">
	<a href="/catalog" class="block bg-black py-2 text-center font-manrope text-[11px] font-normal uppercase tracking-[0.04em] text-white transition-opacity hover:opacity-80 md:text-[14px]">
		Скидка 10% на общую сумму заказа от 9 000₽. Перейти
	</a>

	<header class="relative w-full border-b border-[#DDDDDD] bg-white" data-nt="satin-header">
		<!-- Mobile Header: 375px - 440px -->
		<div class="relative z-[60] flex h-14 items-center justify-between bg-white px-4 md:hidden">
			<button
				type="button"
				id="satin-burger-btn"
				class="flex h-10 w-10 items-center justify-center transition-opacity hover:opacity-70"
				aria-label="Меню"
				aria-expanded="false"
				aria-controls="satin-burger"
			>
				<span class="burger-icon" data-icon="open">
					<NtIcon name="menu-burger" sizeClass="size-6" />
				</span>
				<span class="burger-icon hidden" data-icon="close">
					<NtIcon name="menu-close" sizeClass="size-6" />
				</span>
			</button>
			<a href="/" class="font-logo text-lg font-normal uppercase leading-none text-[#000000] hover:opacity-80">{SITE_TITLE}</a>
			<div class="flex items-center gap-4">
				<a href="#" data-action="toggle-search" class="flex h-6 w-6 items-center justify-center" aria-label="Поиск">
					<NtIcon name="search-sm" sizeClass="size-6" />
				</a>
				<button type="button" data-cart-open class="relative flex h-6 w-6 items-center justify-center" aria-label="Корзина">
					<NtIcon name="cart-sm" sizeClass="size-6" />
					<span data-cart-count data-empty="true" class="absolute -right-2 -top-2 inline-flex h-4 min-w-4 items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
				</button>
			</div>
		</div>

		<!-- Desktop Header: 768px+ -->
		<div class="satin-pad relative mx-auto hidden h-16 w-full max-w-[1920px] items-center justify-between md:flex">
			<nav class="flex items-center gap-8" aria-label="Основная навигация">
				{nav.map((link) => {
					const active = isActive(link);
					return (
						<a
							href={link.href}
							aria-current={active ? "page" : undefined}
							data-mega-trigger={link.mega ? "" : undefined}
							aria-haspopup={link.mega ? "true" : undefined}
							aria-expanded={link.mega ? "false" : undefined}
							class:list={[
								"group/mega relative inline-flex items-center gap-1 pb-1 font-manrope text-[16px] font-normal uppercase leading-normal text-[#000000] transition-opacity hover:opacity-70",
								active && "after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-[#000000] after:content-['']",
							]}
						>
							{link.label}
							{link.mega && (
								<NtIcon
									name="dropdown-chevron"
									sizeClass="size-4"
									class="satin-mega-caret transition-transform duration-150"
								/>
							)}
						</a>
					);
				})}
			</nav>

			<a href="/" class="font-logo absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-[22px] font-normal uppercase leading-none text-[#000000] hover:opacity-90">{SITE_TITLE}</a>

			<div class="flex items-center gap-5">
				<button type="button" data-action="toggle-search" class="flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Поиск">
					<NtIcon name="search-lg" sizeClass="size-6" />
				</button>
				<a href="/catalog" class="flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Избранное">
					<NtIcon name="favourite" sizeClass="size-6" />
				</a>
				<button type="button" data-cart-open class="relative flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Корзина">
					<NtIcon name="cart" sizeClass="size-6" />
					<span data-cart-count data-empty="true" class="absolute right-0 top-0 inline-flex h-4 min-w-4 items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
				</button>
			</div>
		</div>

		<!-- Mega-menu (desktop) — opens on Коллекции hover/focus -->
		<div
			data-mega-panel
			class="invisible absolute inset-x-0 top-full z-50 hidden opacity-0 transition-opacity duration-150 data-[open=true]:visible data-[open=true]:opacity-100 md:block"
		>
			<div class="satin-pad mx-auto w-full max-w-[1920px]">
				<div class="grid grid-cols-4 bg-[#F5F5F5] p-4">
					<div class="flex flex-col gap-3">
						<span class="font-manrope text-[16px] font-normal uppercase leading-normal text-[#000000]">Для неё и для него</span>
						<a href="/catalog" class="font-manrope text-[14px] font-light uppercase leading-normal text-[#999999] transition-opacity hover:opacity-70">Смотреть всё</a>
					</div>
					<div class="flex flex-col gap-3">
						<a href="/catalog?collection=Женское" class="font-manrope text-[16px] font-normal uppercase leading-normal text-[#000000] transition-opacity hover:opacity-70">Женская коллекция</a>
						<ul class="flex flex-col gap-2" role="list">
							{womenCats.map((cat) => (
								<li><a href="/catalog?collection=Женское" class="font-manrope text-[14px] font-light uppercase leading-normal text-[#999999] transition-opacity hover:opacity-70">{cat}</a></li>
							))}
						</ul>
					</div>
					<div class="flex flex-col gap-3">
						<a href="/catalog?collection=Мужское" class="font-manrope text-[16px] font-normal uppercase leading-normal text-[#000000] transition-opacity hover:opacity-70">Мужская коллекция</a>
						<ul class="flex flex-col gap-2" role="list">
							{menCats.map((cat) => (
								<li><a href="/catalog?collection=Мужское" class="font-manrope text-[14px] font-light uppercase leading-normal text-[#999999] transition-opacity hover:opacity-70">{cat}</a></li>
							))}
						</ul>
					</div>
					<div class="flex items-start gap-2 justify-self-end">
						{socials.map((s) => (
							<a href={s.href} target="_blank" rel="noopener noreferrer" class="flex h-6 w-6 items-center justify-center transition-opacity hover:opacity-70" aria-label={s.label}>
								<NtIcon name={s.name} sizeClass="size-6" />
							</a>
						))}
					</div>
				</div>
			</div>
		</div>

		<!-- Search Panel -->
		<div data-search-panel class="satin-pad hidden w-full border-t border-[#DDDDDD] bg-white py-4" hidden>
			<form role="search" action="/catalog" method="get" class="satin-container flex h-10 items-center justify-between gap-2 border border-[#DDDDDD] bg-white pl-3 pr-1">
				<input type="search" name="q" placeholder="Поиск..." aria-label="Поиск" autocomplete="off" class="min-w-0 flex-1 bg-transparent font-manrope text-sm font-light leading-normal text-[#000000] placeholder:text-[#999999] outline-none" />
				<button type="submit" class="flex h-8 shrink-0 items-center justify-center bg-[#000000] px-4 font-manrope text-[12px] font-normal uppercase leading-normal text-white transition-opacity hover:opacity-95">Найти</button>
			</form>
			<div data-search-results role="listbox" aria-label="Подсказки поиска" class="satin-container mt-1 hidden flex-col border border-[#DDDDDD] bg-white"></div>
		</div>
	</header>

	<!-- Mobile Burger Menu -->
	<div id="satin-burger" class="fixed inset-x-0 top-[56px] bottom-0 z-[55] hidden w-full overflow-y-auto bg-white px-4 pt-4 pb-8 md:hidden" role="dialog" aria-modal="true" aria-label="Меню">
		<div class="flex items-center gap-2">
			<form class="flex h-10 min-h-10 flex-1 items-center justify-between border border-[#DDDDDD] bg-white pl-3 pr-2" role="search" action="/catalog" method="get">
				<input type="search" name="q" placeholder="Поиск" autocomplete="off" class="min-w-0 flex-1 bg-transparent font-manrope text-xs font-normal leading-normal text-[#000000] placeholder:text-[#999999] outline-none" />
				<button type="submit" class="flex h-6 w-6 shrink-0 items-center justify-center" aria-label="Найти">
					<NtIcon name="search-sm" sizeClass="size-6" />
				</button>
			</form>
			<a href="/auth/sign-in" class="flex h-10 w-10 shrink-0 items-center justify-center bg-[#000000]" aria-label="Профиль">
				<NtIcon name="user" sizeClass="size-6" />
			</a>
		</div>
		<div data-search-results role="listbox" aria-label="Подсказки поиска" class="mt-2 hidden flex-col border border-[#DDDDDD] bg-white"></div>

		<nav class="mt-8 flex flex-col gap-4" aria-label="Основное меню">
			{nav.map((link) => {
				const active = isActive(link);
				return (
					<div class="flex flex-col gap-1.5">
						<a href={link.href} class:list={["font-manrope text-xs font-normal uppercase leading-normal", active ? "text-[#000000]" : "text-[#606060]"]}>{link.label}</a>
						{active && <div class="h-0.5 w-12 bg-[#000000]" aria-hidden="true"></div>}
					</div>
				);
			})}
			<a href="/cart" class="font-manrope text-xs font-normal uppercase leading-normal text-[#606060]">Корзина</a>
			<a href="/auth/sign-up" class="font-manrope text-xs font-normal uppercase leading-normal text-[#606060]">Регистрация</a>
		</nav>
	</div>
</div>

<script>
	const burgerBtn = document.getElementById("satin-burger-btn");
	const burger = document.getElementById("satin-burger");

	const setBurger = (open: boolean) => {
		if (!burger || !burgerBtn) return;
		burger.classList.toggle("hidden", !open);
		burgerBtn.setAttribute("aria-expanded", String(open));
		burgerBtn.querySelectorAll<HTMLElement>(".burger-icon").forEach((el) => {
			const key = el.dataset.icon;
			if (key === "open") el.classList.toggle("hidden", open);
			else el.classList.toggle("hidden", !open);
		});
		document.body.style.overflow = open ? "hidden" : "";
	};

	burgerBtn?.addEventListener("click", () => {
		const isHidden = burger?.classList.contains("hidden");
		setBurger(Boolean(isHidden));
	});

	burger?.querySelectorAll("a").forEach((a) => {
		a.addEventListener("click", () => setBurger(false));
	});

	// Mega-menu (Коллекции) — open on hover/focus, close with a small grace delay
	const megaTrigger = document.querySelector<HTMLElement>("[data-mega-trigger]");
	const megaPanel = document.querySelector<HTMLElement>("[data-mega-panel]");
	if (megaTrigger && megaPanel) {
		let closeTimer: ReturnType<typeof setTimeout> | undefined;
		const openMega = () => {
			clearTimeout(closeTimer);
			megaPanel.dataset.open = "true";
			megaPanel.classList.remove("hidden");
			megaTrigger.setAttribute("aria-expanded", "true");
		};
		const closeMega = () => {
			closeTimer = setTimeout(() => {
				megaPanel.dataset.open = "false";
				megaTrigger.setAttribute("aria-expanded", "false");
			}, 140);
		};
		megaTrigger.addEventListener("mouseenter", openMega);
		megaTrigger.addEventListener("focus", openMega);
		megaTrigger.addEventListener("mouseleave", closeMega);
		megaPanel.addEventListener("mouseenter", openMega);
		megaPanel.addEventListener("mouseleave", closeMega);
		megaTrigger.addEventListener("blur", closeMega);
		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape") {
				megaPanel.dataset.open = "false";
				megaTrigger.setAttribute("aria-expanded", "false");
			}
		});
	}

	document.querySelectorAll<HTMLElement>("[data-action='toggle-search']").forEach((el) => {
		el.addEventListener("click", (event) => {
			event.preventDefault();
			const panel = document.querySelector<HTMLElement>("[data-search-panel]");
			if (!panel) return;
			const hidden = panel.hasAttribute("hidden");
			if (hidden) {
				panel.removeAttribute("hidden");
				panel.classList.remove("hidden");
				panel.classList.add("block");
				panel.querySelector<HTMLInputElement>("input[type='search']")?.focus();
			} else {
				panel.setAttribute("hidden", "");
				panel.classList.add("hidden");
				panel.classList.remove("block");
			}
		});
	});
</script>
<script type="application/json" data-search-index set:html={JSON.stringify(searchIndex).replace(/<\//g, "<\\/")}></script>
