---
interface Props {
	title: string;
	subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="flex flex-col items-center gap-2 sm:gap-3 md:gap-4 mb-8 sm:mb-10 md:mb-12 lg:mb-16">
	<h2 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-normal text-black uppercase leading-tight text-center font-comfortaa">
		{title}
	</h2>
	{subtitle && (
		<p class="text-sm sm:text-base md:text-lg lg:text-xl font-light text-[#606060] leading-normal text-center px-2 sm:px-4 font-manrope">
			{subtitle}
		</p>
	)}
</div>
