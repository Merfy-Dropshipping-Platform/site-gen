---
// Product — Puck-managed SSR card. Mirrors the live ProductIsland visual
// structure (image gallery + info block) so the constructor preview matches
// what the user sees on the live storefront. When `siteId` is injected by
// the preview pipeline, an inline client script fetches the chosen product
// (or first available) from the storefront API and replaces placeholder
// values with real data.
//
// On live SSG bundles each theme's `/product/[id].astro` page intercepts
// Product blocks before they reach this file and mounts the interactive
// React island directly with `productId` from URL params. So this file is
// only rendered in preview pipelines and as a graceful fallback.
import type { ProductProps } from './Product.puckConfig';

interface Props extends ProductProps {
  id?: string;
  siteId?: string;
}

const {
  id,
  siteId,
  productId,
  layout = 'two-columns',
  size,
  photoPosition = 'left',
  zoomMode,
  text,
  title,
  price,
  variants,
  quantity,
  buttons,
  description,
  share,
  badge,
  colorScheme,
  padding,
} = Astro.props as Props;

const paddingStyle = padding
  ? `padding-top:${padding.top ?? 80}px; padding-bottom:${padding.bottom ?? 80}px;`
  : 'padding-top:80px; padding-bottom:80px;';

const schemeClass =
  typeof colorScheme === 'string' && colorScheme
    ? `color-scheme-${colorScheme.replace('scheme-', '')}`
    : '';

const apiBase = 'https://gateway.merfy.ru/api';

const textContent = text?.content ?? badge?.text ?? '';
const priceVisible = price?.show !== 'false' && price?.show !== false;
const quantityVisible = quantity?.enabled !== 'false' && quantity?.enabled !== false;
const addBtnText = buttons?.addToCart?.text ?? 'В КОРЗИНУ';
const buyBtnText = buttons?.buyNow?.text ?? 'КУПИТЬ';
const shareText = share?.text ?? 'Поделиться';
const descContent = description?.content ?? '';

const photoOnLeft = photoPosition !== 'right';

// Layout variants drive grid template / image stacking.
const effectiveLayout = layout ?? 'two-columns';
const isStacked = effectiveLayout === 'stacked';
const isCarousel = effectiveLayout === 'carousel';
const isThumbnail = effectiveLayout === 'thumbnail';
const isSplit = effectiveLayout === 'split';
// 'two-columns' (default) and 'split' both side-by-side; 'split' = 50/50.
const galleryWidth = isSplit ? '1fr' : '435px';
const gridTemplate = isStacked
  ? '1fr'
  : photoOnLeft
    ? `${galleryWidth} 1fr`
    : `1fr ${galleryWidth}`;
// Block size scales container max-width and font-size baseline.
const effectiveSize = size ?? 'medium';
const blockMaxWidth = effectiveSize === 'small' ? '960px' : effectiveSize === 'large' ? '1440px' : '1280px';
const titleFontSize = effectiveSize === 'small' ? '20px' : effectiveSize === 'large' ? '28px' : '24px';
const heroAspect = isStacked ? '4/3' : '1/1';

// Variants visual style: 'button' (pill buttons, default) vs 'list' (vertical rows).
const variantsStyle = variants?.style ?? 'button';
const variantsShape = variants?.shape ?? 'circle';
const variantsRadius =
  variantsShape === 'square' ? '4px' : variantsShape === 'none' ? '0' : '999px';

// Zoom mode: hover (CSS scale on hover) vs click (lightbox via JS) vs none.
const zoomEffective = zoomMode ?? 'hover';
---
<section
  class:list={[schemeClass]}
  data-puck-component-id={id}
  data-block="product"
  data-site-id={siteId}
  data-api-base={apiBase}
  data-product-id={productId}
  data-layout={effectiveLayout}
  data-size={effectiveSize}
  data-zoom={zoomEffective}
  data-variants-style={variantsStyle}
  data-variants-radius={variantsRadius}
  style={`background:rgb(var(--color-bg, 255 255 255));color:rgb(var(--color-text, 0 0 0));${paddingStyle}`}
>
  <div style={`max-width:${blockMaxWidth};margin:0 auto;padding-left:24px;padding-right:24px;`}>
    <div style={`display:grid;grid-template-columns:${gridTemplate};gap:${isStacked ? '24px' : '80px'};align-items:start;`}>
      {/* Images gallery */}
      <div data-product-images style={`order:${photoOnLeft || isStacked ? 0 : 1};display:flex;flex-direction:column;gap:11px;`}>
        <div data-product-hero style={`aspect-ratio:${heroAspect};background:rgba(0,0,0,0.05);border-radius:4px;overflow:hidden;${zoomEffective === 'hover' ? 'transition:transform 0.3s ease;' : ''}${zoomEffective === 'click' ? 'cursor:zoom-in;' : ''}`}>
          {/* Hero image filled by inline JS */}
        </div>
        <div data-product-thumbs style={`display:none;grid-template-columns:repeat(${isCarousel ? 4 : isThumbnail ? 2 : 3},1fr);gap:11px;${isCarousel ? 'overflow-x:auto;' : ''}`}></div>
      </div>

      {/* Info block — Figma node 1:21380 */}
      <div style={`order:${photoOnLeft ? 1 : 0};display:flex;flex-direction:column;gap:14px;`}>
        <div
          data-puck-subsection-parent={id}
          data-puck-subsection-index="100"
          data-puck-subsection-field="text"
          data-product-text
          style={`font-size:13px;color:rgb(var(--color-muted, 153 153 153));text-transform:uppercase;letter-spacing:0.05em;cursor:pointer;${textContent ? '' : 'display:none;'}`}
        >{textContent}</div>

        <h1
          data-puck-subsection-parent={id}
          data-puck-subsection-index="101"
          data-puck-subsection-field="title"
          data-product-title
          style={`font-size:${title?.size === 'large' ? '32px' : title?.size === 'small' ? '18px' : titleFontSize};font-weight:400;line-height:1.1;margin:0;color:rgb(var(--color-heading, 0 0 0));font-family:var(--font-heading);cursor:pointer;`}
        ></h1>

        {priceVisible && (
          <div
            data-puck-subsection-parent={id}
            data-puck-subsection-index="102"
            data-puck-subsection-field="price"
            data-product-price
            style="display:none;gap:8px;align-items:baseline;font-size:18px;color:rgb(var(--color-heading, 0 0 0));cursor:pointer;"
          >
            <span data-product-price-current></span>
            <span data-product-price-compare style="text-decoration:line-through;color:rgb(var(--color-muted, 153 153 153));font-size:14px;display:none;"></span>
          </div>
        )}

        <div
          data-puck-subsection-parent={id}
          data-puck-subsection-index="103"
          data-puck-subsection-field="variants"
          data-product-variants
          style="display:none;gap:8px;flex-wrap:wrap;cursor:pointer;"
        ></div>

        {quantityVisible && (
          <div
            data-puck-subsection-parent={id}
            data-puck-subsection-index="104"
            data-puck-subsection-field="quantity"
            data-product-quantity
            style="display:flex;align-items:center;gap:12px;cursor:pointer;"
          >
            <span style="font-size:14px;color:rgb(var(--color-muted, 153 153 153));">Количество:</span>
            <div style="display:flex;align-items:center;border:1px solid rgba(0,0,0,0.15);border-radius:4px;">
              <button type="button" data-product-qty-minus style="padding:4px 10px;background:transparent;border:0;cursor:pointer;font-size:16px;">−</button>
              <span data-product-qty style="padding:4px 12px;font-size:14px;min-width:24px;text-align:center;">1</span>
              <button type="button" data-product-qty-plus style="padding:4px 10px;background:transparent;border:0;cursor:pointer;font-size:16px;">+</button>
            </div>
          </div>
        )}

        <div
          data-puck-subsection-parent={id}
          data-puck-subsection-index="105"
          data-puck-subsection-field="buttons"
          data-product-buttons
          style="display:flex;flex-direction:column;gap:8px;cursor:pointer;"
        >
          <button type="button" data-product-add-to-cart style="padding:14px;border:1px solid rgb(var(--color-text, 0 0 0));background:transparent;color:rgb(var(--color-text, 0 0 0));border-radius:4px;font-size:14px;cursor:pointer;text-transform:uppercase;letter-spacing:0.04em;">{addBtnText}</button>
          <button type="button" data-product-buy-now style="padding:14px;background:rgb(var(--color-text, 0 0 0));color:rgb(var(--color-bg, 255 255 255));border:0;border-radius:4px;font-size:14px;cursor:pointer;text-transform:uppercase;letter-spacing:0.04em;">{buyBtnText}</button>
        </div>

        <div
          data-puck-subsection-parent={id}
          data-puck-subsection-index="106"
          data-puck-subsection-field="description"
          data-product-description
          style={`font-size:${description?.size === 'large' ? '16px' : description?.size === 'small' ? '12px' : '14px'};color:rgb(var(--color-text, 0 0 0));line-height:1.5;cursor:pointer;${descContent ? '' : 'display:none;'}`}
        >
          <div style="font-weight:500;margin-bottom:6px;">Описание</div>
          <p data-product-description-content style="margin:0;">{descContent}</p>
        </div>

        <div
          data-puck-subsection-parent={id}
          data-puck-subsection-index="107"
          data-puck-subsection-field="share"
          style="display:inline-flex;align-items:center;gap:6px;font-size:13px;color:rgb(var(--color-muted, 153 153 153));cursor:pointer;"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          <span>{shareText}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ siteId, apiBase, productId }}>
  // Mirror live storefront in constructor preview: fetch real product
  // (chosen via productId picker, falling back to first available) and
  // populate hero image, thumbs, title, price.
  (function () {
    if (!siteId) return;
    const root = document.querySelector('section[data-block="product"]');
    if (!root) return;
    const heroEl = root.querySelector('[data-product-hero]');
    const thumbsEl = root.querySelector('[data-product-thumbs]');
    const titleEl = root.querySelector('[data-product-title]');
    const priceWrap = root.querySelector('[data-product-price]');
    const priceCur = root.querySelector('[data-product-price-current]');
    const priceCmp = root.querySelector('[data-product-price-compare]');
    const variantsEl = root.querySelector('[data-product-variants]');
    const descWrap = root.querySelector('[data-product-description]');
    const descEl = root.querySelector('[data-product-description-content]');
    if (!heroEl || !titleEl) return;

    function fmtPrice(p) {
      const num = typeof p === 'number' ? p : parseFloat(p);
      if (!Number.isFinite(num)) return '';
      const rubles = num > 1000000 ? Math.round(num / 100) : Math.round(num);
      return rubles.toLocaleString('ru-RU') + ' ₽';
    }

    function escAttr(s) {
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function applyProduct(p) {
      if (!p) return;
      const imgs = (Array.isArray(p.images) ? p.images : [])
        .map((it) => (typeof it === 'string' ? it : (it && it.url) || null))
        .filter(Boolean);
      const hero = imgs[0];
      if (hero && heroEl) {
        heroEl.innerHTML =
          '<img src="' + escAttr(hero) +
          '" alt="' + escAttr(p.title || p.name || '') +
          '" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />';
      }
      if (thumbsEl) {
        const thumbs = imgs.slice(1, 4);
        if (thumbs.length === 0) {
          thumbsEl.style.display = 'none';
          thumbsEl.innerHTML = '';
        } else {
          thumbsEl.style.display = 'grid';
          thumbsEl.innerHTML = thumbs
            .map(function (src) {
              return (
                '<div style="aspect-ratio:1/1;border-radius:4px;overflow:hidden;background:rgba(0,0,0,0.05);"><img src="' +
                escAttr(src) +
                '" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>'
              );
            })
            .join('');
        }
      }
      titleEl.textContent = p.title || p.name || '';
      // Price: show only if real price exists
      const priceVal = fmtPrice(p.basePrice ?? p.price);
      if (priceCur) priceCur.textContent = priceVal;
      if (priceWrap) priceWrap.style.display = priceVal ? 'flex' : 'none';
      if (priceCmp) {
        if (p.compareAtPrice) {
          priceCmp.textContent = fmtPrice(p.compareAtPrice);
          priceCmp.style.display = 'inline';
        } else {
          priceCmp.style.display = 'none';
        }
      }
      // Description: show only if real description exists (don't override with empty)
      if (descEl && p.description) {
        descEl.textContent = p.description;
        if (descWrap) descWrap.style.display = '';
      } else if (descWrap && !descEl?.textContent) {
        descWrap.style.display = 'none';
      }
      // Variants: build pills (button-style) or rows (list-style) from
      // product.variants[]. Shape (radius) and style come from data-* attrs
      // set by Astro frontmatter so revision props drive the visual.
      const productVariantsArr = Array.isArray(p.variants) ? p.variants.filter((v) => v && v.title) : [];
      let selectedVariantIdx = 0;
      function renderVariants() {
        if (!variantsEl) return;
        const styleMode = root.getAttribute('data-variants-style') || 'button';
        const radius = root.getAttribute('data-variants-radius') || '999px';
        if (productVariantsArr.length === 0) {
          variantsEl.style.display = 'none';
          return;
        }
        if (styleMode === 'list') {
          variantsEl.style.display = 'flex';
          variantsEl.style.flexDirection = 'column';
          variantsEl.style.gap = '4px';
          variantsEl.innerHTML = productVariantsArr
            .map(function (v, i) {
              const selected = i === selectedVariantIdx;
              return (
                '<label data-variant-row data-variant-idx="' + i + '" style="display:flex;align-items:center;gap:10px;padding:8px 10px;cursor:pointer;border:1px solid ' +
                (selected ? 'rgb(var(--color-text, 0 0 0))' : 'rgba(0,0,0,0.12)') +
                ';border-radius:' + radius + ';font-size:14px;">' +
                '<input type="radio" name="variant"' + (selected ? ' checked' : '') + ' style="margin:0;pointer-events:none;" />' +
                '<span>' + escAttr(v.title) + '</span>' +
                '</label>'
              );
            })
            .join('');
        } else {
          variantsEl.style.display = 'flex';
          variantsEl.style.flexDirection = 'row';
          variantsEl.style.gap = '8px';
          variantsEl.innerHTML = productVariantsArr
            .map(function (v, i) {
              const selected = i === selectedVariantIdx;
              const bg = selected ? 'rgb(var(--color-text, 0 0 0))' : 'transparent';
              const fg = selected ? 'rgb(var(--color-bg, 255 255 255))' : 'rgb(var(--color-text, 0 0 0))';
              const border = selected
                ? '1px solid rgb(var(--color-text, 0 0 0))'
                : '1px solid rgba(0,0,0,0.15)';
              return (
                '<button type="button" data-variant-pill data-variant-idx="' + i + '" style="padding:6px 14px;border:' +
                border +
                ';background:' +
                bg +
                ';color:' +
                fg +
                ';border-radius:' + radius + ';font-size:13px;cursor:pointer;">' +
                escAttr(v.title) +
                '</button>'
              );
            })
            .join('');
        }
      }
      renderVariants();
      // Variant click → select & re-render + update price
      if (variantsEl) {
        variantsEl.addEventListener('click', function (ev) {
          const target = ev.target.closest('[data-variant-idx]');
          if (!target) return;
          const idx = Number(target.getAttribute('data-variant-idx'));
          if (Number.isFinite(idx) && idx >= 0 && idx < productVariantsArr.length) {
            selectedVariantIdx = idx;
            renderVariants();
            // Update displayed price from variant
            const v = productVariantsArr[idx];
            if (priceCur && v && v.price != null) {
              priceCur.textContent = fmtPrice(v.price);
              if (priceWrap) priceWrap.style.display = 'flex';
            }
          }
        });
      }

      // Thumbnail click → swap hero image
      if (thumbsEl) {
        thumbsEl.addEventListener('click', function (ev) {
          const thumbDiv = ev.target.closest('div[style*="border-radius"]');
          const img = thumbDiv?.querySelector('img');
          const heroImg = heroEl?.querySelector('img');
          if (img && heroImg && img.src) heroImg.src = img.src;
        });
      }
    }

    // Quantity +/- handlers
    const qtyEl = root.querySelector('[data-product-qty]');
    const qtyMinus = root.querySelector('[data-product-qty-minus]');
    const qtyPlus = root.querySelector('[data-product-qty-plus]');
    let currentQty = 1;
    if (qtyMinus && qtyEl) {
      qtyMinus.addEventListener('click', function () {
        if (currentQty > 1) currentQty--;
        qtyEl.textContent = String(currentQty);
      });
    }
    if (qtyPlus && qtyEl) {
      qtyPlus.addEventListener('click', function () {
        currentQty++;
        qtyEl.textContent = String(currentQty);
      });
    }

    // Add to cart / Buy now / Share
    function getActiveVariantId() {
      const variants = Array.isArray(window.__productData?.variants) ? window.__productData.variants : [];
      const v = variants[window.__productData?.selectedVariantIdx ?? 0];
      return v?.id ?? null;
    }
    const addBtn = root.querySelector('[data-product-add-to-cart]');
    const buyBtn = root.querySelector('[data-product-buy-now]');
    if (addBtn) {
      addBtn.addEventListener('click', function () {
        const cs = window.cartStore;
        if (cs && typeof cs.addItem === 'function') {
          const variantId = getActiveVariantId();
          cs.addItem(productId, variantId, currentQty);
          addBtn.textContent = 'Добавлено!';
          setTimeout(function () { addBtn.textContent = (root.querySelector('[data-product-add-to-cart]')?.dataset?.label) || 'В КОРЗИНУ'; }, 1500);
        } else {
          // Preview mode (no cart-store) — just visual feedback
          const orig = addBtn.textContent;
          addBtn.textContent = 'Добавлено в корзину ✓';
          addBtn.style.background = 'rgb(var(--color-text, 0 0 0))';
          addBtn.style.color = 'rgb(var(--color-bg, 255 255 255))';
          setTimeout(function () {
            addBtn.textContent = orig;
            addBtn.style.background = 'transparent';
            addBtn.style.color = 'rgb(var(--color-text, 0 0 0))';
          }, 1500);
        }
      });
    }
    if (buyBtn) {
      buyBtn.addEventListener('click', function () {
        if (window.cartStore && typeof window.cartStore.addItem === 'function') {
          window.cartStore.addItem(productId, getActiveVariantId(), currentQty);
          window.location.href = '/checkout';
        } else {
          // Preview mode
          buyBtn.textContent = 'Переход к оплате...';
          setTimeout(function () { buyBtn.textContent = 'КУПИТЬ'; }, 1500);
        }
      });
    }
    const shareBtn = root.querySelector('[data-puck-subsection-field="share"]');
    if (shareBtn) {
      shareBtn.addEventListener('click', function () {
        const url = window.location.href;
        const title = titleEl?.textContent || '';
        if (navigator.share) {
          navigator.share({ title: title, url: url }).catch(function () {});
        } else if (navigator.clipboard) {
          navigator.clipboard.writeText(url);
          const span = shareBtn.querySelector('span');
          if (span) {
            const orig = span.textContent;
            span.textContent = 'Ссылка скопирована!';
            setTimeout(function () { span.textContent = orig; }, 1500);
          }
        }
      });
    }

    // Zoom: hover scales hero image, click opens fullscreen overlay.
    const zoomMode = root.getAttribute('data-zoom') || 'hover';
    if (heroEl && zoomMode === 'hover') {
      heroEl.addEventListener('mouseenter', function () {
        const img = heroEl.querySelector('img');
        if (img) img.style.transform = 'scale(1.05)';
      });
      heroEl.addEventListener('mouseleave', function () {
        const img = heroEl.querySelector('img');
        if (img) img.style.transform = '';
      });
      const img = heroEl.querySelector('img');
      if (img) img.style.transition = 'transform 0.3s ease';
    } else if (heroEl && zoomMode === 'click') {
      heroEl.addEventListener('click', function () {
        const img = heroEl.querySelector('img');
        if (!img) return;
        const overlay = document.createElement('div');
        overlay.style.cssText =
          'position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;display:flex;align-items:center;justify-content:center;cursor:zoom-out;';
        overlay.innerHTML =
          '<img src="' + img.src + '" style="max-width:90vw;max-height:90vh;object-fit:contain;" />';
        overlay.addEventListener('click', function () { overlay.remove(); });
        document.body.appendChild(overlay);
      });
    }

    const qs = productId ? '?product=' + encodeURIComponent(productId) : '';
    fetch(apiBase + '/sites/' + siteId + '/storefront-data' + qs, { credentials: 'omit' })
      .catch(() => null)
      .then((r) => (r && r.ok ? r.json() : null))
      .then((data) => {
        if (!data) return;
        const single = data.product;
        const list = data.products || (data.data && data.data.products) || [];
        applyProduct(single || list[0]);
      })
      .catch(() => {});
  })();
</script>
