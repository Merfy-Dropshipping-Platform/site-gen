---
import type { CheckoutLayoutProps } from './CheckoutLayout.puckConfig';
import { CheckoutLayoutClasses as C } from './CheckoutLayout.classes';

interface Props extends CheckoutLayoutProps {
  id?: string;
}

const {
  id,
  summaryPosition,
  formColumnWidth,
  summaryColumnWidth,
  gap,
  padding,
} = Astro.props as Props;

// Figma 1:13398 (Rose 1920): form 652, gap 84, summary 884, side-pad 300.
// Grid template uses minmax(min, fixed) per column so on tight viewports
// (1280-1440) columns shrink to their min and avoid horizontal scroll;
// on 1920+ they reach the design widths and side-pad 1fr columns absorb
// extra space so summary stays full-bleed to right.
const cssVars = [
  `--checkout-form-col-w:${formColumnWidth}px`,
  `--checkout-summary-col-w:${summaryColumnWidth}px`,
  `--checkout-gap:${gap}px`,
].join('; ');
// Per Figma 1:13398 — page top → header (80h) → form area top:144 (i.e. 64
// below header). The form column itself supplies the 64 via pt-16, so we
// drop padding-top here and only honour padding-bottom from saved props.
const paddingStyle = padding ? `padding-bottom:${padding.bottom}px;` : '';
const inlineStyle = `${paddingStyle}; ${cssVars}`;
const gridClass = summaryPosition === 'bottom' ? C.gridSummaryBottom : C.grid;
---
<section
  class={C.root}
  data-puck-component-id={id}
  data-checkout-slot="layout"
  data-summary-position={summaryPosition}
  style={inlineStyle}
>
  <div class={gridClass}>
    <div class={C.formColumn} data-checkout-column="form">
      <slot name="form" />
    </div>
    <div class={C.summaryColumn} data-checkout-column="summary">
      <slot name="summary" />
    </div>
  </div>
</section>
