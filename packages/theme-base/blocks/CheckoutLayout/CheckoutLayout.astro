---
import type { CheckoutLayoutProps } from './CheckoutLayout.puckConfig';
import { CheckoutLayoutClasses as C } from './CheckoutLayout.classes';

interface Props extends CheckoutLayoutProps {
  id?: string;
}

const {
  id,
  summaryPosition,
  formColumnWidth,
  summaryColumnWidth,
  gap,
  padding,
} = Astro.props as Props;

// Figma 1:13398 design hints (1920px desktop): form 652px, summary 884px.
// On real-world viewports (1280–1920) we constrain inside max-w-1440 with
// reasonable side-pad (clamp). Removes the 300px-each-side that pushed the
// content past viewport edge and caused horizontal scroll on 1440 monitors.
const cssVars = [
  `--checkout-form-col-w:${formColumnWidth}px`,
  `--checkout-summary-col-w:${summaryColumnWidth}px`,
  `--checkout-gap:${gap}px`,
  `--checkout-side-pad:clamp(16px, 4vw, 80px)`,
].join('; ');
const paddingStyle = padding ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;` : '';
const inlineStyle = `${paddingStyle}; ${cssVars}`;
const gridClass = summaryPosition === 'bottom' ? C.gridSummaryBottom : C.grid;
---
<section
  class={C.root}
  data-puck-component-id={id}
  data-checkout-slot="layout"
  data-summary-position={summaryPosition}
  style={inlineStyle}
>
  <div class={gridClass}>
    <div class={C.formColumn} data-checkout-column="form">
      <slot name="form" />
    </div>
    <div class={C.summaryColumn} data-checkout-column="summary">
      <slot name="summary" />
    </div>
  </div>
</section>
