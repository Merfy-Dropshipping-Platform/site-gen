node_modules
dist/
dist/astro-blocks/
!templates/**/dist/
*.log
.env
.env.local
.DS_Store

# Build artifacts (stored in MinIO, not git)
.astro-builds/
artifacts/

# Astro cache (themes/<name>/.astro, etc.)
.astro/

# Drizzle backups
drizzle_backup/

# Playwright visual-diff ephemeral outputs (keep committed snapshots, ignore per-run results)
packages/theme-*/test-results/
packages/theme-*/playwright-report/

# Compiled Tailwind CSS used by visual snapshots (rebuilt on each run)
packages/theme-*/__snapshots__/tailwind-compiled.css
visual-diff-report/
visual-diff-report-*

# Phase 2c — developer's local Figma reference (gitignored, personal workspace)
docs/figma-snapshots/
.figma-cache/

# Migration backups from migrate-block-to-tokens.mjs (timestamped .bak.<ms>)
*.bak.[0-9]*

# Theme structural-conformance local evidence (JSON/Markdown reports).
# The TRACKED inventory (conformance/inventory/) and baselines
# (conformance/baselines/) are intentionally NOT ignored.
conformance-results/
