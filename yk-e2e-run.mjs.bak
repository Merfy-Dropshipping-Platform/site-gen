/**
 * E2E прохождение чекаута на новом тестовом шопе с YooKassa виджетом.
 *
 * Сайт:  https://cd1136c1724e.merfy.ru
 * Shop:  78ea7210-f2d4-4b44-a55b-74183f387b27
 * Тест-товар: 5a4afd20-48ec-4ddd-80b4-a0af3cfec81d (1₽)
 *
 * Скрипт:
 *  1) Главная → каталог → товар → корзина → /checkout
 *  2) Заполняет формы фейк-данными
 *  3) На шаге оплаты ОСТАНАВЛИВАЕТСЯ — карту пользователь введёт вручную.
 *  4) Все шаги — скриншот в /tmp/yk-e2e/NN-step.png + лог.
 */
import { chromium } from 'playwright';
import fs from 'fs';

const OUT = '/tmp/yk-e2e';
fs.mkdirSync(OUT, { recursive: true });

const SITE = 'https://cd1136c1724e.merfy.ru';
const SHOP_ID = '78ea7210-f2d4-4b44-a55b-74183f387b27';
const TEST_PRODUCT_ID = '5a4afd20-48ec-4ddd-80b4-a0af3cfec81d';

const log = (...a) => {
  const line = `[${new Date().toISOString()}] ${a.join(' ')}`;
  console.log(line);
  fs.appendFileSync(`${OUT}/run.log`, line + '\n');
};

let stepCounter = 0;
async function snap(page, label) {
  stepCounter++;
  const n = String(stepCounter).padStart(2, '0');
  const file = `${OUT}/${n}-${label.replace(/[^\w-]/g, '_')}.png`;
  await page.screenshot({ path: file, fullPage: true }).catch((e) => log('screenshot fail:', e.message));
  log(`📸 ${file}`);
  return file;
}

// Pre-create cart via API to avoid flaky homepage→catalog navigation
async function preCreateCart() {
  log('=== Pre-creating cart via API ===');
  const r1 = await fetch(`https://gateway.merfy.ru/api/store/carts`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ store_id: SHOP_ID }),
  });
  const c = await r1.json();
  const cartId = c?.cart?.id;
  if (!cartId) throw new Error('no cart id: ' + JSON.stringify(c));
  log('cartId:', cartId);

  const r2 = await fetch(`https://gateway.merfy.ru/api/store/carts/${cartId}/items`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ product_id: TEST_PRODUCT_ID, quantity: 1 }),
  });
  const it = await r2.json();
  log('item added:', it?.item?.id || it?.message);
  return cartId;
}

(async () => {
  log('starting E2E');
  const browser = await chromium.launch({ headless: true });
  const ctx = await browser.newContext({
    viewport: { width: 1280, height: 900 },
    locale: 'ru-RU',
  });
  const page = await ctx.newPage();

  // Capture console + network errors
  page.on('console', (msg) => {
    const t = msg.type();
    if (t === 'error' || t === 'warning') log(`console[${t}]:`, msg.text().slice(0, 300));
  });
  page.on('pageerror', (err) => log('pageerror:', err.message));
  page.on('requestfailed', (req) => log('request_failed:', req.url(), req.failure()?.errorText));
  page.on('response', (res) => {
    const url = res.url();
    if (res.status() >= 400 && (url.includes('/api/') || url.includes('yoomoney'))) {
      log(`http_${res.status()}:`, url);
    }
  });

  const cartId = await preCreateCart();

  try {
    // Step 1: homepage
    log('=== STEP 1: Homepage ===');
    await page.goto(SITE + '/', { waitUntil: 'domcontentloaded', timeout: 30000 });
    await page.waitForLoadState('networkidle', { timeout: 15000 }).catch(() => log('  networkidle timeout (continuing)'));
    await snap(page, 'home');

    // Step 2: catalog
    log('=== STEP 2: Catalog ===');
    await page.goto(SITE + '/catalog', { waitUntil: 'domcontentloaded', timeout: 30000 });
    await page.waitForLoadState('networkidle', { timeout: 20000 }).catch(() => log('  networkidle timeout'));
    // Wait for products to render via CatalogIsland
    await page.waitForTimeout(3000);
    await snap(page, 'catalog');
    const productLinks = await page.$$eval('a[href*="/products/"], a[href*="/product/"]', (as) =>
      as.map((a) => ({ href: a.href, text: (a.textContent || '').trim().slice(0, 50) }))
    );
    log('product links found:', productLinks.length);
    productLinks.slice(0, 5).forEach((p, i) => log(`  [${i}] ${p.href} | ${p.text}`));

    // Step 3: open cheap test product
    log('=== STEP 3: Product page ===');
    // Find link to cheap product by id slug or text
    let targetLink = productLinks.find((p) => p.href.includes('testovyj-tovar') || p.href.includes(TEST_PRODUCT_ID));
    if (!targetLink && productLinks[0]) targetLink = productLinks[0];
    if (!targetLink) {
      log('NO product links — cannot navigate to product page');
    } else {
      await page.goto(targetLink.href, { waitUntil: 'domcontentloaded', timeout: 30000 });
      await page.waitForLoadState('networkidle', { timeout: 15000 }).catch(() => {});
      await page.waitForTimeout(1500);
      await snap(page, 'product');
    }

    // Inject cartId into localStorage for /cart page
    await page.evaluate((id) => {
      try {
        localStorage.setItem('merfy:cartId', id);
      } catch {}
    }, cartId);
    log('injected cartId into localStorage');

    // Step 4: cart
    log('=== STEP 4: Cart ===');
    await page.goto(SITE + '/cart', { waitUntil: 'domcontentloaded', timeout: 30000 });
    await page.waitForLoadState('networkidle', { timeout: 15000 }).catch(() => {});
    await page.waitForTimeout(2000);
    await snap(page, 'cart');

    // Step 5: checkout
    log('=== STEP 5: Checkout ===');
    await page.goto(SITE + '/checkout', { waitUntil: 'domcontentloaded', timeout: 30000 });
    await page.waitForLoadState('networkidle', { timeout: 20000 }).catch(() => {});
    await page.waitForTimeout(4000);
    await snap(page, 'checkout-initial');

    // Step 6: Fill contact form
    log('=== STEP 6: Fill contact ===');
    const tryFill = async (selectors, value, label) => {
      for (const sel of selectors) {
        const el = await page.$(sel);
        if (el) {
          await el.fill(value).catch(() => {});
          log(`  filled ${label} via ${sel}`);
          return true;
        }
      }
      log(`  ❌ ${label}: no selector matched (${selectors.join(', ')})`);
      return false;
    };
    await tryFill(
      ['input[name="email"]', 'input[type="email"]', 'input[autocomplete="email"]', 'input[placeholder*="mail" i]', 'input[placeholder*="почт" i]'],
      'merfy-yookassa-2026@mail.ru',
      'email'
    );
    await tryFill(
      ['input[name="phone"]', 'input[type="tel"]', 'input[autocomplete*="tel"]', 'input[placeholder*="телефон" i]'],
      '+79001234567',
      'phone'
    );
    await tryFill(
      ['input[name="firstName"]', 'input[autocomplete="given-name"]', 'input[placeholder*="имя" i]'],
      'Тест',
      'firstName'
    );
    await tryFill(
      ['input[name="lastName"]', 'input[autocomplete="family-name"]', 'input[placeholder*="фамил" i]'],
      'Тестов',
      'lastName'
    );
    await page.waitForTimeout(500);
    await snap(page, 'contact-filled');

    // Step 7: Fill delivery
    log('=== STEP 7: Fill delivery ===');
    await tryFill(
      ['input[name="city"]', 'input[autocomplete="address-level2"]', 'input[placeholder*="город" i]'],
      'Москва',
      'city'
    );
    await page.waitForTimeout(800);
    await tryFill(
      ['input[name="street"]', 'input[autocomplete="street-address"]', 'input[placeholder*="улиц" i]'],
      'Тверская',
      'street'
    );
    await tryFill(
      ['input[name="building"]', 'input[autocomplete="address-line2"]', 'input[placeholder*="дом" i]'],
      '1',
      'building'
    );
    await page.waitForTimeout(500);
    await snap(page, 'delivery-filled');

    // Step 8: Select delivery method (first available)
    log('=== STEP 8: Select delivery method ===');
    const deliveryRadios = await page.$$('label:has(input[type="radio"])');
    log(`  found ${deliveryRadios.length} radio labels total on page`);
    // Try clicking pickup or first delivery radio
    const pickupLabel = await page.$('label:has-text("Самовывоз"), label:has-text("Пункт выдачи"), label:has-text("PVZ")');
    if (pickupLabel) {
      await pickupLabel.click().catch((e) => log('  pickup click fail:', e.message));
      log('  clicked pickup');
    }
    await page.waitForTimeout(1000);

    // Step 9: Select bank_card payment
    log('=== STEP 9: Select bank_card payment ===');
    const bankCardLabel = await page.$('label:has-text("Банковская карта"), label:has-text("Картой"), label:has-text("Card")');
    if (bankCardLabel) {
      await bankCardLabel.click().catch((e) => log('  bank_card click fail:', e.message));
      log('  clicked bank_card');
    } else {
      log('  ❌ bank_card label not found');
    }
    await page.waitForTimeout(2500); // wait for YooKassa SDK to load
    await snap(page, 'payment-bank-card-selected');

    // Step 10: Verify YooKassa widget loaded
    log('=== STEP 10: YooKassa widget check ===');
    const sdkLoaded = await page.evaluate(() =>
      typeof window.YooMoneyCheckoutUI !== 'undefined'
    );
    log(`  window.YooMoneyCheckoutUI loaded: ${sdkLoaded}`);
    const cardForm = await page.$('input[autocomplete="cc-number"], input[placeholder*="карт" i]');
    log(`  card-number input present: ${Boolean(cardForm)}`);
    await snap(page, 'yookassa-widget-ready');

    log('=== STOP — пользователь вводит карту вручную ===');
    log('🎯 Скрипт остановлен на шаге оплаты. Виджет должен быть виден.');
    log('🎯 Дальше: пользователь сам вводит реальную карту → оплачивает → возврат на /checkout/result');
  } catch (e) {
    log('💥 EXCEPTION:', e.message);
    log(e.stack);
    await snap(page, 'CRASH');
  } finally {
    await browser.close();
  }
  log('done.');
})();
