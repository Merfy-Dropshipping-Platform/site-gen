---
// Секция «Puk» — НЕ каноническая секция конструктора (не регистрируется в
// puckConfig). Пустое состояние per Figma 1:19335 — ПЛЕЙСХОЛДЕР по контракту
// (эталон theme-base PopularProducts.astro DEMO_PRODUCTS), НЕ мок-демо
// верстальщика «АКЦИЯ ПУКНИ» с pukItems.
//
// Гейт как у PopularProducts: реальные данные (выбранная коллекция/товары)
// рендерятся как есть; когда выбора НЕТ — N карточек-плейсхолдеров с цветной
// курткой циклом blue→yellow→red→green, подпись «Товар», цена «2 500 ₽».
import FluxPicture from "../img/FluxPicture.astro";

const p = Astro.props as Record<string, any>;
const id = p.id;

const heading =
  (typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title ?? undefined;
const subtitle =
  (typeof p.text === "string" ? p.text : p.text?.content) ??
  (typeof p.subtitle === "string" ? p.subtitle : p.subtitle?.content) ??
  undefined;

// Количество карточек-плейсхолдеров (дефолт 4 — паритет PopularProducts).
const cardsN =
  typeof p.cards === "number" && p.cards > 0
    ? Math.max(1, Math.min(24, Math.round(p.cards)))
    : 4;

// Ассеты курток-плейсхолдеров: лежат в packages/theme-base/public/placeholders/
// и копируются в корень сайта (доступны как /placeholders/sweater-<color>.png).
// Паритет с FluxProductDetail.astro / storefront-hydrate.ts (root-relative URL).
const SWEATERS = [
  "/placeholders/sweater-blue.png",
  "/placeholders/sweater-yellow.png",
  "/placeholders/sweater-red.png",
  "/placeholders/sweater-green.png",
];

// Гейт по реальным данным: когда мерчант выбрал коллекцию И есть реальные
// товары (массив items в пропах) — рендер реальных карточек БЕЗ изменений.
// Иначе — плейсхолдер-куртки циклом по цветам (НЕ мок-товары верстальщика).
type RealItem = { id?: string; title?: string; image?: string; price?: string };
const collectionRef =
  typeof p.collection === "string" && p.collection.trim() ? p.collection.trim() : undefined;
const realItems: RealItem[] = Array.isArray(p.items) ? (p.items as RealItem[]) : [];
const hasRealData = !!collectionRef && realItems.length > 0;

const cards = hasRealData
  ? realItems.slice(0, cardsN).map((it) => ({
      title: it.title || "Товар",
      price: (typeof it.price === "string" && it.price.trim()) || "",
      image: it.image || SWEATERS[0],
      isPlaceholder: false,
    }))
  : Array.from({ length: cardsN }, (_, i) => ({
      title: "Товар",
      price: "2 500 ₽",
      image: SWEATERS[i % SWEATERS.length],
      isPlaceholder: true,
    }));
---

<section
  class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-16 pt-16 md:px-20 md:pb-24 md:pt-24 2xl:px-80"
  data-puck-component-id={id}
>
  <div class="mx-auto w-full max-w-[1320px]">
    {(heading || subtitle) && (
      <div class="mb-12 flex flex-col items-center gap-1 text-center md:mb-16">
        {heading && (
          <h2 class="font-comfortaa text-[24px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))] md:text-[28px]">
            {heading}
          </h2>
        )}
        {subtitle && (
          <p class="font-roboto-flex text-[18px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] md:text-[20px]">
            {subtitle}
          </p>
        )}
      </div>
    )}

    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:gap-6 lg:grid-cols-4">
      {cards.map((card) => (
        <div class="flex flex-col gap-4 md:gap-5">
          <div class="aspect-[318/444] w-full overflow-hidden rounded-[8px] bg-[rgb(var(--color-surface,251_251_251))]">
            {card.isPlaceholder ? (
              // Плейсхолдер-куртка: сырой <img>, НЕ FluxPicture — у ассетов
              // /placeholders/sweater-*.png НЕТ соимённого .webp, а <picture>
              // не откатывается на <img> при 404 webp-source (баг корзины).
              <img
                src={card.image}
                alt={card.title}
                class="h-full w-full object-contain p-[15%]"
                loading="lazy"
              />
            ) : (
              <FluxPicture
                src={card.image}
                alt={card.title}
                class="h-full w-full object-cover transition-transform duration-300 hover:scale-105"
                loading="lazy"
              />
            )}
          </div>
          <div class="flex flex-col items-start gap-1">
            <p class="font-manrope text-[18px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[20px]">
              {card.title}
            </p>
            {card.price && (
              <p class="font-manrope text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] md:text-[18px]">
                {card.price}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
