---
import Layout from "../layouts/Layout.astro";
import SatinProductCard from "../components/products/SatinProductCard.astro";
import NtFilterSidebar from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtFilterSidebar.astro";
import NtFilterPanel from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtFilterPanel.astro";
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { catalogProducts } from "../data/products";

const layout = (Astro.url.searchParams.get("layout") ?? "row") === "sidebar" ? "sidebar" : "row";
const collection = Astro.url.searchParams.get("collection");
const products = collection ? catalogProducts.filter((product) => product.collection === collection) : catalogProducts.slice(0, 6);
const totalCount = products.length;
---

<Layout title="Каталог" description="Каталог Satin — коллекции, хиты, новинки">
	<section
		class="satin-pad w-full bg-white py-12 md:py-16"
		aria-labelledby="catalog-title"
	>
		<div class="satin-container flex flex-col gap-8">
			<header class="flex flex-col gap-2">
				<h1
					id="catalog-title"
					class="font-logo text-[20px] font-normal uppercase leading-[1.15] text-[#000000]"
				>
					Каталог
				</h1>
				<p class="font-manrope text-[16px] font-light leading-normal text-[#999999]">
					Здесь начинается персональный стиль
				</p>
			</header>

			{layout === "row" ? (
				<div class="flex flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-3" data-nt="catalog-filters">
						<div class="flex flex-wrap items-start gap-3">
							<details class="group relative">
								<summary class="flex h-8 min-w-[120px] cursor-pointer list-none items-center justify-between gap-2 bg-white px-0 font-manrope text-[16px] font-normal uppercase leading-normal text-[#000000] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
									<span>Наличие</span>
									<NtIcon name="dropdown-chevron" sizeClass="size-6" class="transition-transform group-open:rotate-180" />
								</summary>
								<div class="absolute left-0 top-full z-10 mt-1 w-full">
									<NtFilterPanel panel="stock" />
								</div>
							</details>

							<details class="group relative">
								<summary class="flex h-8 min-w-[120px] cursor-pointer list-none items-center justify-between gap-2 bg-white px-0 font-manrope text-[16px] font-normal uppercase leading-normal text-[#000000] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
									<span>Стоимость</span>
									<NtIcon name="dropdown-chevron" sizeClass="size-6" class="transition-transform group-open:rotate-180" />
								</summary>
								<div class="absolute left-0 top-full z-10 mt-1 w-full">
									<NtFilterPanel panel="price" />
								</div>
							</details>

							<details class="group relative">
								<summary class="flex h-8 min-w-[90px] cursor-pointer list-none items-center justify-between gap-2 bg-white px-0 font-manrope text-[16px] font-normal uppercase leading-normal text-[#000000] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
									<span>Цвет</span>
									<NtIcon name="dropdown-chevron" sizeClass="size-6" class="transition-transform group-open:rotate-180" />
								</summary>
								<div class="absolute left-0 top-full z-10 mt-1 w-full">
									<NtFilterPanel panel="color" />
								</div>
							</details>

							{/* Фильтр по коллекциям: скрыт на demo-сборке, гидрация показывает
							    его при наличии коллекций магазина и уважает ?collection= из
							    ссылок тайлов Collections. Манера = details-дропдауны выше,
							    панель = манера NtFilterPanel. */}
							<details class="group relative" data-nt="catalog-collections-filter" style="display:none;">
								<summary class="flex h-8 min-w-[120px] cursor-pointer list-none items-center justify-between gap-2 bg-white px-0 font-manrope text-[16px] font-normal uppercase leading-normal text-[#000000] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
									<span data-collections-label>Коллекции</span>
									<NtIcon name="dropdown-chevron" sizeClass="size-6" class="transition-transform group-open:rotate-180" />
								</summary>
								<div class="absolute left-0 top-full z-10 mt-1">
									<div class="flex w-[200px] flex-col gap-2 rounded-[6px] border border-[#F5F5F5] bg-[#FFFFFF] p-3 font-manrope text-[14px] font-normal leading-[100%]">
										<ul data-collections-options class="m-0 flex list-none flex-col gap-2 p-0"></ul>
									</div>
								</div>
							</details>
						</div>

						<details class="group relative">
							<summary class="flex h-8 min-w-[150px] cursor-pointer list-none items-center justify-end gap-2 bg-white px-0 font-manrope text-[16px] font-normal uppercase leading-normal text-[#000000] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span>По популярности</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-6" />
							</summary>
							<div class="absolute right-0 top-full z-10 mt-1 w-[180px]">
								<NtFilterPanel panel="sort" />
							</div>
						</details>
					</div>

					<ul
						class="grid grid-cols-2 gap-x-4 gap-y-10 sm:grid-cols-3"
						role="list"
						data-nt="catalog-grid"
					>
						{products.map((product) => (
							<li data-product-id={product.id}>
								<SatinProductCard product={product} />
							</li>
						))}
					</ul>

					<div class="flex flex-wrap items-center justify-between gap-4">
						<button
							type="button"
							data-action="load-more"
							class="satin-button satin-button-md satin-button-light"
						>
							Смотреть ещё
						</button>
						<span class="font-manrope text-[16px] font-normal uppercase leading-normal text-[#999999]" data-nt="catalog-count">
							{totalCount} товаров
						</span>
					</div>
				</div>
			) : (
				<div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
					<NtFilterSidebar class="hidden w-[172px] shrink-0 lg:flex xl:w-[294px]" />

					<div class="flex flex-1 flex-col gap-8">
						<ul
							class="grid grid-cols-2 gap-x-4 gap-y-10 sm:grid-cols-3"
							role="list"
							data-nt="catalog-grid"
						>
							{products.map((product) => (
								<li data-product-id={product.id}>
									<SatinProductCard product={product} />
								</li>
							))}
						</ul>

						<div class="flex flex-wrap items-center justify-between gap-4">
							<button
								type="button"
								data-action="load-more"
								class="satin-button satin-button-light"
							>
								Смотреть ещё
							</button>
							<span class="font-manrope text-[16px] font-normal uppercase leading-normal text-[#999999]" data-nt="catalog-count">
								{totalCount} товаров
							</span>
						</div>
					</div>
				</div>
			)}
		</div>
	</section>
</Layout>

<script>
	document.addEventListener("click", (event) => {
		const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-action='load-more']");
		if (!button) return;
		button.disabled = true;
		button.textContent = "Больше товаров нет";
		button.classList.add("opacity-60", "pointer-events-none");
	});

	// Catalog filter dropdowns — only one open at a time, close on outside click.
	const filterBar = document.querySelector("[data-nt='catalog-filters']");
	if (filterBar) {
		const dropdowns = Array.from(filterBar.querySelectorAll<HTMLDetailsElement>("details"));
		dropdowns.forEach((dropdown) => {
			dropdown.addEventListener("toggle", () => {
				if (!dropdown.open) return;
				dropdowns.forEach((other) => {
					if (other !== dropdown) other.open = false;
				});
			});
		});
		document.addEventListener("click", (event) => {
			if (!filterBar.contains(event.target as Node)) {
				dropdowns.forEach((dropdown) => (dropdown.open = false));
			}
		});
	}
</script>

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		filterByCollection,
		renderCardHtml,
		escapeHtml,
		updateCount,
		type RealCollection,
	} from "../lib/storefront-hydrate";

	// Реальные товары (Option B): на published-сайте /data/products.json реальный →
	// перерисовываем demo-grid. На demo-сборке loadRealProducts() вернёт null → no-op.
	// Фильтр по коллекциям: ?collection= (slug/id из ссылок тайлов) + дропдаун
	// «Коллекции» (заполняется из collections.json/storefront-data).
	let catalogCollections: RealCollection[] | null = null;

	function currentCollectionRef(): string | null {
		return new URLSearchParams(window.location.search).get("collection");
	}

	async function renderCatalog() {
		const products = await loadRealProducts();
		if (!products) return; // demo-сборка
		const ref = currentCollectionRef();
		const items = ref ? filterByCollection(products, catalogCollections, ref) : products;
		const html = items
			.map((p) => `<li data-product-id="${escapeHtml(p.id)}">${renderCardHtml(p)}</li>`)
			.join("");
		for (const grid of Array.from(document.querySelectorAll('[data-nt="catalog-grid"]'))) {
			grid.innerHTML = html;
		}
		updateCount('[data-nt="catalog-count"]', items.length);
	}

	async function initCollectionsFilter() {
		const box = document.querySelector<HTMLElement>('[data-nt="catalog-collections-filter"]');
		const list = box?.querySelector<HTMLElement>("[data-collections-options]");
		if (!box || !list) return;
		if (box.getAttribute("data-cf-hydrated") === "true") return; // идемпотентность astro:page-load
		catalogCollections = await loadRealCollections();
		if (!catalogCollections || catalogCollections.length === 0) return;
		box.setAttribute("data-cf-hydrated", "true");
		box.style.display = "";
		const label = box.querySelector<HTMLElement>("[data-collections-label]");
		const ref = currentCollectionRef();
		const current = ref
			? catalogCollections.find((c) => c.id === ref || c.slug === ref || c.name === ref) ?? null
			: null;
		if (label && current?.name) label.textContent = current.name;
		// Манера пунктов = списки NtFilterPanel: активный чёрный, остальные #999999.
		const optionHtml = (value: string, name: string, active: boolean) =>
			`<li><button type="button" data-collection-option="${escapeHtml(value)}" class="w-full cursor-pointer text-left font-manrope text-[14px] font-normal leading-[100%] transition-colors hover:text-[#000000] ${active ? "text-[#000000]" : "text-[#999999]"}">${escapeHtml(name)}</button></li>`;
		list.innerHTML =
			optionHtml("", "Все", !current) +
			catalogCollections
				.map((c) => optionHtml(c.slug ?? c.id, c.name ?? "Коллекция", !!current && current.id === c.id))
				.join("");
		list.addEventListener("click", (ev) => {
			const btn = (ev.target as HTMLElement).closest<HTMLElement>("[data-collection-option]");
			if (!btn) return;
			const value = btn.getAttribute("data-collection-option") ?? "";
			const params = new URLSearchParams(window.location.search);
			if (value) params.set("collection", value);
			else params.delete("collection");
			const qs = params.toString();
			window.history.replaceState({}, "", window.location.pathname + (qs ? `?${qs}` : ""));
			const col = catalogCollections?.find((c) => (c.slug ?? c.id) === value) ?? null;
			if (label) label.textContent = col?.name ?? "Коллекции";
			for (const b of Array.from(list.querySelectorAll("[data-collection-option]"))) {
				const on = b === btn;
				b.classList.toggle("text-[#000000]", on);
				b.classList.toggle("text-[#999999]", !on);
			}
			box.removeAttribute("open");
			renderCatalog();
		});
	}

	async function hydrateCatalog() {
		await initCollectionsFilter();
		await renderCatalog();
	}

	hydrateCatalog();
	document.addEventListener("astro:page-load", hydrateCatalog);
</script>
