---
// 080 Phase 6 — Puck-managed checkout page.
//
// Reads pagesData.checkout (seeded by migrateCheckoutPage at revision-read
// time) and renders the 11 Checkout* blocks. Each block emits
// data-checkout-slot — the CheckoutFlow Island finds them at runtime and
// Portals interactive React content into each placeholder.
//
// Live URL: /checkout-puck (canary) — flipped to /checkout via per-site
// feature flag `features.checkoutPuckManaged` in Phase 8.

import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/data.json';
import siteConfig from '../data/site-config.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import CheckoutHeader from '@merfy/theme-base/blocks/CheckoutHeader/CheckoutHeader.astro';
import CheckoutSummaryToggle from '@merfy/theme-base/blocks/CheckoutSummaryToggle/CheckoutSummaryToggle.astro';
import CheckoutLayout from '@merfy/theme-base/blocks/CheckoutLayout/CheckoutLayout.astro';
import CheckoutContactForm from '@merfy/theme-base/blocks/CheckoutContactForm/CheckoutContactForm.astro';
import CheckoutDeliveryForm from '@merfy/theme-base/blocks/CheckoutDeliveryForm/CheckoutDeliveryForm.astro';
import CheckoutDeliveryMethod from '@merfy/theme-base/blocks/CheckoutDeliveryMethod/CheckoutDeliveryMethod.astro';
import CheckoutPayment from '@merfy/theme-base/blocks/CheckoutPayment/CheckoutPayment.astro';
import CheckoutOrderSummary from '@merfy/theme-base/blocks/CheckoutOrderSummary/CheckoutOrderSummary.astro';
import CheckoutTotals from '@merfy/theme-base/blocks/CheckoutTotals/CheckoutTotals.astro';
import CheckoutSubmit from '@merfy/theme-base/blocks/CheckoutSubmit/CheckoutSubmit.astro';
import CheckoutTerms from '@merfy/theme-base/blocks/CheckoutTerms/CheckoutTerms.astro';

const meta = (data as any)?.meta ?? {};
const homeBlocks = (data as any)?.content ?? [];
const checkoutPage = (data as any)?.pagesData?.checkout ?? { content: [] };

const headerBlock = checkoutPage.content.find((b: any) => b.type === 'CheckoutHeader');
const homeHeaderBlock = homeBlocks.find((b: any) => b.type === 'Header');
const homeFooterBlock = homeBlocks.find((b: any) => b.type === 'Footer');

// Filter blocks by slot kind for layout column placement.
type Block = { type: string; props: Record<string, any> };
const formSlotTypes = new Set([
  'CheckoutContactForm',
  'CheckoutDeliveryForm',
  'CheckoutDeliveryMethod',
  'CheckoutPayment',
  'CheckoutSubmit',
  'CheckoutTerms',
]);
const summarySlotTypes = new Set(['CheckoutOrderSummary', 'CheckoutTotals']);

const blocksByType = (types: Set<string>) =>
  (checkoutPage.content as Block[]).filter((b) => types.has(b.type));

const layoutBlock = (checkoutPage.content as Block[]).find((b) => b.type === 'CheckoutLayout');
const summaryToggleBlock = (checkoutPage.content as Block[]).find((b) => b.type === 'CheckoutSummaryToggle');
const formBlocks = blocksByType(formSlotTypes);
const summaryBlocks = blocksByType(summarySlotTypes);

function renderBlock(b: Block) {
  switch (b.type) {
    case 'CheckoutContactForm':
      return CheckoutContactForm;
    case 'CheckoutDeliveryForm':
      return CheckoutDeliveryForm;
    case 'CheckoutDeliveryMethod':
      return CheckoutDeliveryMethod;
    case 'CheckoutPayment':
      return CheckoutPayment;
    case 'CheckoutOrderSummary':
      return CheckoutOrderSummary;
    case 'CheckoutTotals':
      return CheckoutTotals;
    case 'CheckoutSubmit':
      return CheckoutSubmit;
    case 'CheckoutTerms':
      return CheckoutTerms;
    default:
      return null;
  }
}
---
<BaseLayout title={`Оформление заказа — ${meta?.title ?? 'Мой сайт'}`}>
  {headerBlock ? <CheckoutHeader {...headerBlock.props} /> : homeHeaderBlock && <Header {...homeHeaderBlock.props} />}

  <main class="flex-1 w-full" style="background: rgb(var(--color-bg)); color: rgb(var(--color-text));">
    {summaryToggleBlock && <CheckoutSummaryToggle {...summaryToggleBlock.props} />}

    {layoutBlock ? (
      <CheckoutLayout {...layoutBlock.props}>
        <Fragment slot="form">
          {formBlocks.map((b) => {
            const Comp = renderBlock(b);
            return Comp ? <Comp {...b.props} /> : null;
          })}
        </Fragment>
        <Fragment slot="summary">
          {summaryBlocks.map((b) => {
            const Comp = renderBlock(b);
            return Comp ? <Comp {...b.props} /> : null;
          })}
        </Fragment>
      </CheckoutLayout>
    ) : (
      <div class="mx-auto max-w-[var(--container-max-width)] px-4 flex flex-col gap-6">
        {formBlocks.concat(summaryBlocks).map((b) => {
          const Comp = renderBlock(b);
          return Comp ? <Comp {...b.props} /> : null;
        })}
      </div>
    )}
  </main>

  {!headerBlock && homeFooterBlock && <Footer {...homeFooterBlock.props} />}

  <div id="checkout-island" style="display:contents"></div>

  <script is:inline define:vars={{ shopId: meta?.shopId, apiUrl: meta?.apiUrl, dadataToken: (meta as any)?.dadataToken || '' }}>
    window.__MERFY_CONFIG__ = {
      shopId: shopId || '',
      apiUrl: apiUrl || 'https://gateway.merfy.ru/api',
    };
    if (dadataToken) {
      window.__DADATA_TOKEN__ = dadataToken;
    }
  </script>
  <script type="module" src="/scripts/checkout-island.js"></script>
</BaseLayout>
