---
import data from '../data/data.json';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'My Store', description } = Astro.props;
const favicons = (data?.meta as any)?.favicons ?? {};
---
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {favicons.universal ? (
      <link rel="icon" href={favicons.universal} />
    ) : (
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    )}
    {favicons.dark && (
      <link rel="icon" href={favicons.dark} media="(prefers-color-scheme: dark)" />
    )}
    {favicons.light && (
      <link rel="icon" href={favicons.light} media="(prefers-color-scheme: light)" />
    )}
    {favicons.apple && (
      <link rel="apple-touch-icon" href={favicons.apple} />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
