            {/* Actions */}
            <div class="flex items-center gap-[24px]">
              {showSearch && (
                <button aria-label="Поиск" class:list={['hidden md:flex w-8 h-8 items-center justify-center hover:opacity-70 transition-opacity', !textColor && 'text-theme-foreground']} style={textStyle}>
