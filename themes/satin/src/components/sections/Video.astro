---
// Фаза B (satin, группа misc): новая канон-секция Video в манере satin
// (themes/satin/MANNER.md §2/§4; у верстальщика секции нет — процесс-прецедент
// bloom Video). Схема полей = packages/theme-base/blocks/Video/Video.puckConfig.ts.
// Медиа в контейнере 1320 на surface-подложке БЕЗ скругления (радиус-токен
// с нулевым фоллбеком); только utility-классы с токенами.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон videoUrl + pupa video{url, coverImage}. blob:-URL — временные ObjectURL
// вкладки конструктора, на live дадут 404 — отбрасываем (паттерн theme-base/bloom).
const rawVideoUrl =
	typeof p.video?.url === "string" ? p.video.url : typeof p.videoUrl === "string" ? p.videoUrl : "";
const videoUrl = rawVideoUrl.startsWith("blob:") ? "" : rawVideoUrl;
// Канон poster (+ video.coverImage). Рендерится ТОЛЬКО как постер реального
// видео мерчанта — в пустом состоянии постер-кампанию не подставляем.
const poster =
	(typeof p.video?.coverImage === "string" && p.video.coverImage ? p.video.coverImage : undefined) ??
	(typeof p.poster === "string" && p.poster ? p.poster : undefined);

// КОНТРАКТ ПЛЕЙСХОЛДЕРОВ (Figma 1:19335 — пустое состояние секции «Видео»:
// пустой image-rect + Play-иконка по центру). ЗАМЕНЯЕТ мок-демо верстальщика
// (дизайнерское фото кампании /images/4x/Главный_экран.png + без play-кнопки).
// Эталон: theme-base Video.astro (empty-state media-slot) + satin Slideshow/
// ImageWithText (светлый rect surface вместо кампании). Гейт = наличие реального
// видео мерчанта (videoUrl непустой). Нет видео → ПЛЕЙСХОЛДЕР: дизайн-ассет
// landscape-video.png + Play-иконка (контракт картиночных секций, правило 2 —
// картинка показывается ВСЕГДА, НЕ пустой surface-rect; эталон theme-base
// Video.astro: poster || PLACEHOLDER_ASSETS.landscape.video). Реальное видео — как было.
const isPlaceholder = !videoUrl;
const PLACEHOLDER_VIDEO_IMAGE = "/placeholders/landscape-video.png";

// Канон heading + pupa content.heading{text, alignment, enabled, size} — рендер
// при непустом тексте и enabled !== 'false'. Роль = заголовок секции §1
// (font-logo 20 uppercase leading-[1.15], токен heading 0_0_0).
// ВАЖНО: пустая top-level строка (heading:"") НЕ должна короткозамыкать ?? —
// иначе legacy `content.heading.text` (куда старый конструктор писал заголовок)
// игнорился бы и реальный заголовок ревизии подменялся плейсхолдером «Видео»
// (тот же баг, что гардит theme-base/flux Video). Пустую строку = отсутствие.
const headingTop = typeof p.heading === "string" ? (p.heading.trim() ? p.heading : undefined) : p.heading;
const headingRaw = headingTop ?? p.content?.heading;
const headingTextRaw =
	typeof headingRaw === "string" ? headingRaw : ((headingRaw?.text as string | undefined) ?? "");
// Figma 1:19335 — ДОСЛОВНЫЙ плейсхолдер пустого состояния секции «Видео»:
// заголовок «Видео» (+ пустой image-rect с Play-иконкой ниже). Дефолт-заголовок
// показываем, когда мерчант НЕ задал свой текст (паритет эталона rose Popular —
// ?? fallback срабатывает только при пустых данных). Свой заголовок мерчанта
// рендерим как есть. Явно отключённый заголовок (enabled === 'false') скрывает
// его даже в пустом состоянии.
const headingText = headingTextRaw.trim() ? headingTextRaw : "Видео";
const headingEnabled = String(p.content?.heading?.enabled ?? "true") !== "false";
const showHeading = Boolean(headingText.trim()) && headingEnabled;
// Канон headingSize («Размер заголовка», кегль <h2>) + дубли heading.size /
// content.heading.size. Секционный `size` теперь = ВЫСОТА блока (не кегль) —
// исключён из цепочки. Лестница §9 «Заголовок секции»: small 17,
// medium 20 (литерал роли), large 24.
const headingSize =
	(typeof headingRaw === "object" ? headingRaw?.size : undefined) ??
	p.content?.heading?.size;
const headingSizeCls =
	headingSize === "small" ? "text-[17px]" : headingSize === "large" ? "text-[24px]" : "text-[20px]";
const headingAlignment =
	p.headingAlignment ??
	(typeof headingRaw === "object" ? headingRaw?.alignment : undefined) ??
	p.content?.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-logo ${headingSizeCls} font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]${headingAlignCls}`;

// Канон subheading «Подзаголовок» (как rose/theme-base) — string | {text} +
// content.subheading.{text,enabled}. Рендер ТОЛЬКО при непустом тексте И
// enabled !== 'false' (default-preserving; дефолт пустой → ничего). Стиль —
// satin body font-light muted (§1), выравнивание общее с заголовком.
const subEnvelope = p.content?.subheading as { text?: string; enabled?: string } | undefined;
const subEnabled = String(subEnvelope?.enabled ?? "true") !== "false";
const subheadingText = (() => {
	if (!subEnabled) return "";
	const s = p.subheading ?? subEnvelope;
	if (typeof s === "string") return s.trim();
	if (s && typeof s === "object") return String((s as { text?: string }).text ?? "").trim();
	return "";
})();
const subheadingCls = `font-manrope text-[14px] font-light leading-[1.5] text-[rgb(var(--color-muted,153_153_153))]${headingAlignCls}`;

// Канон position contained|fullscreen + align container|fullbleed + padded.
// Canon-default ветка = контейнер 1320 в полях .satin-pad; fullscreen/fullbleed
// → полотно во всю ширину без клампа (align приоритетнее position — паттерн
// theme-base); padded=false убирает горизонтальные поля, сохраняя контейнер.
const alignProp = p.align === "fullbleed" || p.align === "container" ? p.align : undefined;
const positionProp = typeof p.position === "string" ? p.position : "contained";
const fullBleed = alignProp ? alignProp === "fullbleed" : positionProp === "fullscreen";
const padded = !(p.padded === false || p.padded === "false");
// Вертикаль-стандарт §2 (py-10 md:py-14), фон — токен bg.
const sectionCls = fullBleed
	? "w-full bg-[rgb(var(--color-bg,255_255_255))] py-10 md:py-14"
	: padded
		? "satin-pad w-full bg-[rgb(var(--color-bg,255_255_255))] py-10 md:py-14"
		: "w-full bg-[rgb(var(--color-bg,255_255_255))] py-10 md:py-14";
const containerCls = fullBleed
	? "flex w-full flex-col gap-8"
	: "satin-container flex w-full flex-col gap-8";
// На full-bleed полотне заголовок остаётся в полях секции (.satin-pad).
const headingWrapCls = fullBleed ? "satin-pad" : undefined;
// Медиа: aspect-video на surface; скругление — токен с нулевым фоллбеком (§4:
// углы прямые везде); на full-bleed радиус не применяется. Фоллбек surface =
// 251_251_251 (#FBFBFB-паритет контракта пустого состояния, как satin Slideshow/
// ImageWithText); при заданном --color-surface темы выигрывает он.
const mediaCls = fullBleed
	? "relative aspect-video w-full overflow-hidden bg-[rgb(var(--color-surface,251_251_251))]"
	: "relative aspect-video w-full overflow-hidden rounded-[var(--radius-media,0px)] bg-[rgb(var(--color-surface,251_251_251))]";

// Канон overlay 0-100 (число или строка) — слой поверх медиа; клики проходят
// сквозь (controls видео остаются доступны).
const overlayN = Math.max(0, Math.min(100, Number(p.overlay) || 0));

// «Размер» (секционный size) — ВЫСОТА медиа-плитки (канон Hero). small короче
// (21:9), large выше (4:3); medium/absent = базовый aspect-video (без override).
const mediaHeightStyle =
	p.size === "small" ? "aspect-ratio:21/9" : p.size === "large" ? "aspect-ratio:4/3" : undefined;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && showHeading ? `${id}-title` : undefined;
---

<section class={sectionCls} aria-labelledby={titleId} data-puck-component-id={id} style={paddingStyle}>
	<div class={containerCls}>
		{
			(showHeading || subheadingText) && (
				<div class={headingWrapCls}>
					{showHeading && (
						<h2
							id={titleId}
							class={headingCls}
							data-puck-subsection-parent={id}
							data-puck-subsection-index="100"
							data-puck-subsection-field="heading"
						>
							{headingText}
						</h2>
					)}
					{subheadingText && <p class={`${subheadingCls} mt-2`}>{subheadingText}</p>}
				</div>
			)
		}

		<div class={mediaCls} style={mediaHeightStyle} aria-hidden={isPlaceholder ? "true" : undefined}>
			{
				videoUrl ? (
					<video
						src={videoUrl}
						poster={poster}
						controls
						playsinline
						preload="metadata"
						class="absolute inset-0 size-full object-cover"
					/>
				) : (
					/* Пустое состояние = ПЛЕЙСХОЛДЕР по контракту: дизайн-ассет
					   landscape-video.png (правило 2 — картинка показывается ВСЕГДА,
					   НЕ пустой surface-rect) + Play-иконка по центру. Без мок-кампании
					   /images/4x/Главный_экран.png. */
					<Fragment>
						<img
							src={PLACEHOLDER_VIDEO_IMAGE}
							alt=""
							loading="lazy"
							class="absolute inset-0 size-full object-cover"
							aria-hidden="true"
						/>
						<span class="pointer-events-none absolute inset-0 z-[1] flex items-center justify-center">
						<svg
							width="64"
							height="64"
							viewBox="0 0 64 64"
							fill="none"
							xmlns="http://www.w3.org/2000/svg"
							class="text-[rgb(var(--color-heading,0_0_0))] opacity-[0.55]"
							aria-hidden="true"
						>
							<circle cx="32" cy="32" r="32" fill="currentColor" />
							<path d="M26 22L42 32L26 42V22Z" fill="rgb(var(--color-bg,255 255 255))" />
						</svg>
					</span>
					</Fragment>
				)
			}
			{
				overlayN > 0 && (
					<div
						class="pointer-events-none absolute inset-0 z-[1] bg-black"
						style={`opacity:${overlayN / 100}`}
					/>
				)
			}
		</div>
	</div>
</section>
