---
// Figma 1:19335 — ПУСТОЕ СОСТОЯНИЕ секции «Видео» (заменяет мок-демо
// верстальщика). Контракт пустого состояния: пустой image-rect (surface) +
// Play-иконка по центру. Гейт = наличие реального видео (videoUrl / video.url):
//   • БЕЗ видео → ПЛЕЙСХОЛДЕР: rect bg-surface + центральная Play-иконка (НЕ
//     автоплей дизайнерского ролика /images/Video.mp4 + /images/Video.webp).
//   • С видео → автоплей <video> + Play-overlay в манере §1 — рендер реальных
//     данных НЕ ТРОГАЕТСЯ.
// Тёмное полотно №1 (#26311C), медиа aspect-[1319/742] на медиа-подложке без
// радиуса; схема полей = packages/theme-base/blocks/Video/Video.puckConfig.ts.
// Цвета → токены темы rgb(var(--color-*)) с пиксель-фоллбеком (MANNER §7).
// Эталон контракта пустого состояния — packages/theme-base/blocks/Video/Video.astro.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Figma 1:19335 — ПУСТОЕ СОСТОЯНИЕ (заменяет мок-демо верстальщика). Гейт =
// наличие реального видео (канон videoUrl / pupa video.url). БЕЗ выбора видео
// → ПЛЕЙСХОЛДЕР по контракту: пустой image-rect (#FBFBFB / surface) + Play-
// иконка по центру (НЕ автоплей мок-ролика /images/Video.mp4 верстальщика).
// blob:-URL — временные ObjectURL вкладки конструктора, на live дадут 404 →
// отбрасываем в плейсхолдер-ветку. Дефолт пустой → плейсхолдер.
const rawVideoUrl =
	typeof p.video?.url === "string"
		? p.video.url
		: typeof p.videoUrl === "string"
			? p.videoUrl
			: "";
const videoUrl = rawVideoUrl.startsWith("blob:") ? "" : rawVideoUrl;
// Дизайн-ассет картиночного плейсхолдера видео (Figma 1:19335) — раздаётся на
// каждой теме как /placeholders/landscape-video.png. Контракт картиночных секций:
// картинка показывается ВСЕГДА (НЕ пустой surface-rect, НЕ мок-ролик верстальщика).
const PLACEHOLDER_VIDEO_IMAGE = "/placeholders/landscape-video.png";
// Канон poster (+ pupa video.coverImage) — обложка реального видео. Пустое
// состояние (нет видео и нет своей обложки) → дизайн-ассет landscape-video.png
// под Play-иконкой (НЕ чистый surface-rect и НЕ мок /images/Video.webp).
const merchantPoster =
	(typeof p.video?.coverImage === "string" && p.video.coverImage
		? p.video.coverImage
		: undefined) ??
	(typeof p.poster === "string" && p.poster ? p.poster : undefined);

// Канон heading + pupa content.heading{text, alignment, enabled, size} — рендер
// при непустом тексте и enabled !== 'false'; у верстальщика бэнд БЕЗ заголовка →
// canon-default пуст. Роль = Bitter italic 20 white на тёмном полотне (§1).
const headingRaw = p.heading ?? p.content?.heading;
const headingText =
	typeof headingRaw === "string" ? headingRaw : ((headingRaw?.text as string | undefined) ?? "");
const headingEnabled = String(p.content?.heading?.enabled ?? "true") !== "false";
const showHeading = Boolean(headingText.trim()) && headingEnabled;
// Канон headingSize («Размер заголовка», кегль <h2>) + дубли heading.size /
// content.heading.size. Секционный `size` теперь = ВЫСОТА блока (не кегль) —
// исключён из цепочки. Лестница §9 (база-литерал 20 = medium): small 17, large 24.
const headingSize =
	p.headingSize ??
	(typeof headingRaw === "object" ? headingRaw?.size : undefined) ??
	p.content?.heading?.size;
const headingSizeCls =
	headingSize === "small" ? "text-[17px]" : headingSize === "large" ? "text-[24px]" : "text-[20px]";
const headingAlignment =
	p.headingAlignment ??
	(typeof headingRaw === "object" ? headingRaw?.alignment : undefined) ??
	p.content?.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-vanilla-bitter ${headingSizeCls} font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,255_255_255))]${headingAlignCls}`;

// Канон subheading (видимый aiText «Подзаголовок», Figma-борд Video) — порт логики
// theme-base Video.astro:41-52. Зеркалит heading: top-level string `subheading` ИЛИ
// legacy-конверт content.subheading.{text,enabled}. Рендер ТОЛЬКО при непустом тексте
// и enabled !== 'false'; дефолт пустой → ничего (default-preserving). Раньше vanilla
// рендерил лишь heading → поле было мёртвым. Стиль — приглушённый body манеры (Arsenal)
// под белым Bitter-заголовком, наследует выравнивание заголовка (headingAlignCls).
const subContentEnvelope =
	p.content && typeof p.content === "object" ? p.content.subheading : undefined;
const subheadingEnabled = !(subContentEnvelope && subContentEnvelope.enabled === "false");
const subheadingRaw = p.subheading ?? subContentEnvelope;
const subheading = !subheadingEnabled
	? undefined
	: typeof subheadingRaw === "string"
		? subheadingRaw.trim() || undefined
		: subheadingRaw && typeof subheadingRaw === "object"
			? String(subheadingRaw.text ?? "").trim() || undefined
			: undefined;
const subheadingCls = `mt-3 font-vanilla-arsenal text-base font-normal leading-[1.45] text-[rgb(var(--color-text,240_240_240))]${headingAlignCls}`;

// Канон position contained|fullscreen + padded (blockDefaults темы true) + align
// container|fullbleed (blockDefaults 'container'; align приоритетнее position —
// паттерн theme-base). Canon-default ветка = ЛИТЕРАЛ бэнда Gal:54-59: полотно
// vanilla-pad #26311C py-16 lg:py-20, контейнер 1280; fullbleed/fullscreen — во
// всю ширину без полей и клампа; padded=false убирает поля, сохраняя кламп.
const alignProp = p.align === "fullbleed" || p.align === "container" ? p.align : undefined;
const positionProp = typeof p.position === "string" ? p.position : "contained";
const fullBleed = alignProp ? alignProp === "fullbleed" : positionProp === "fullscreen";
const padded = !(p.padded === false || p.padded === "false");
const sectionCls =
	fullBleed || !padded
		? "w-full bg-[rgb(var(--color-bg,38_49_28))] py-16 lg:py-20"
		: "vanilla-pad w-full bg-[rgb(var(--color-bg,38_49_28))] py-16 lg:py-20";
const containerCls = fullBleed
	? "flex w-full flex-col gap-10"
	: "mx-auto flex w-full max-w-[1280px] flex-col gap-10";
// На full-bleed полотне заголовок остаётся в полях секции.
const headingWrapCls = fullBleed ? "vanilla-pad" : undefined;

// Канон overlay 0-100 (hidden) — слой поверх медиа; клики проходят сквозь.
const overlayN = Math.max(0, Math.min(100, Number(p.overlay) || 0));

// «Размер» (секционный size) — ВЫСОТА медиа-плитки (канон Hero). small короче
// (21:9), large выше (4:3); medium/absent — базовый 1319/742 (без inline-override,
// default-preserving). Inline aspect-ratio перебивает класс плитки.
const mediaHeightStyle =
	p.size === "small" ? "aspect-ratio:21/9" : p.size === "large" ? "aspect-ratio:4/3" : undefined;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && showHeading ? `${id}-title` : undefined;
---

<section class={sectionCls} aria-labelledby={titleId} data-puck-component-id={id} style={paddingStyle}>
	<div class={containerCls}>
		{
			(showHeading || subheading) && (
				<div class={headingWrapCls} data-animate>
					{showHeading && (
						<h2
							id={titleId}
							class={headingCls}
							data-puck-subsection-parent={id}
							data-puck-subsection-index="100"
							data-puck-subsection-field="heading"
						>
							{headingText}
						</h2>
					)}
					{subheading && <p class={subheadingCls}>{subheading}</p>}
				</div>
			)
		}

		<div
			class="relative aspect-[1319/742] w-full overflow-hidden bg-[rgb(var(--color-surface,236_235_231))]"
			style={mediaHeightStyle}
			data-animate
			data-animate-delay="0.1s"
			data-puck-subsection-parent={id}
			data-puck-subsection-index="101"
			data-puck-subsection-field="videoUrl"
		>
			{/* С видео → реальный автоплей-ролик (рендер реальных данных не трогаем).
			    БЕЗ видео → пустое состояние: голый rect bg-surface (контракт Figma
			    1:19335). poster-img показываем ТОЛЬКО если мерчант задал обложку,
			    иначе чистый rect без подложки-картинки. */}
			{
				videoUrl ? (
					<video
						class="pointer-events-none absolute inset-0 size-full max-w-none object-cover"
						src={videoUrl}
						poster={merchantPoster}
						autoplay
						muted
						loop
						playsinline
						preload="auto"
						disablepictureinpicture
						aria-hidden="true"
						tabindex="-1"
					/>
				) : (
					<img
						src={merchantPoster ?? PLACEHOLDER_VIDEO_IMAGE}
						alt=""
						aria-hidden="true"
						loading="lazy"
						class="absolute inset-0 size-full max-w-none object-cover"
					/>
				)
			}
			{/* Play-иконка по центру. С видео — белая поверх ролика (как было).
			    БЕЗ видео (пустой плейсхолдер) — обводка токеном heading (тёмная на
			    светлом surface, читается в любой схеме) per контракт «пустой image-
			    rect + Play-иконка по центру». */}
			{
				<svg
					width="44"
					height="44"
					viewBox="0 0 44 44"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					aria-hidden="true"
					class="pointer-events-none absolute left-1/2 top-1/2 size-11 -translate-x-1/2 -translate-y-1/2"
				>
					<path
						d="M9.16772 31.7784V12.2228C9.16772 10.6103 9.16772 9.8031 9.50706 9.32599C9.80323 8.90958 10.2597 8.63618 10.7665 8.57081C11.347 8.49595 12.0589 8.87564 13.4807 9.63394L31.814 19.4117L31.8207 19.4147C33.392 20.2527 34.178 20.6719 34.4358 21.2306C34.6607 21.718 34.6607 22.2806 34.4358 22.7681C34.1776 23.3276 33.3898 23.7485 31.814 24.5889L13.4807 34.3666C12.0579 35.1255 11.3472 35.5037 10.7665 35.4288C10.2597 35.3634 9.80323 35.0901 9.50706 34.6737C9.16772 34.1966 9.16772 33.3909 9.16772 31.7784Z"
						stroke="white"
						stroke-width="3"
						stroke-linecap="round"
						stroke-linejoin="round"
					/>
				</svg>
			}
			{
				overlayN > 0 && (
					<div
						class="pointer-events-none absolute inset-0 bg-black"
						style={`opacity:${overlayN / 100}`}
					/>
				)
			}
		</div>
	</div>
</section>
