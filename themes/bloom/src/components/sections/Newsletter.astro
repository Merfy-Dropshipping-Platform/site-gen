---
// Фаза B (bloom, группа misc): канон-секция Newsletter в манере bloom
// (см. themes/bloom/MANNER.md; процесс-эталон — rose T17 Newsletter). Схема
// полей = packages/theme-base/blocks/Newsletter/Newsletter.puckConfig.ts.
// Манера/верстка взяты из блока подписки подвала верстальщика (Footer.astro:36-79,
// перенесён КОПИЕЙ — подвал не тронут): заголовок Urbanist 20 light uppercase,
// подзаголовок Inter 16 light muted, pill-форма h-10 с внутренней кнопкой; сетка §2.
// Пустое (некурированное) состояние секции рендерит Figma-плейсхолдер 1:19335
// («Подпишитесь на нашу рассылку» + input «email@example.com» + кнопка), а НЕ
// мок-демо литералы подвала верстальщика. Значения, заданные мерчантом, выигрывают.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading: string | { text, alignment, size }. Пустое состояние секции
// (мерчант не задал заголовок) = Figma-плейсхолдер 1:19335 «Подпишитесь на нашу
// рассылку» — НЕ мок-демо подвала верстальщика «ПОДПИШИТЕСЬ НА РАССЫЛКУ» (F:46).
// Когда мерчант вводит свой заголовок — он выигрывает (фоллбек ниже не используется).
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Подпишитесь на нашу рассылку");
// Лестница §9 от базы-литерала 20 (medium): small ≈0.7× = 14, large ≈1.2× = 24.
const headingSize = p.heading?.size ?? p.headingSize;
const headingCls =
	headingSize === "small"
		? "font-urbanist text-[14px] font-light uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))]"
		: headingSize === "large"
			? "font-urbanist text-[24px] font-light uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))]"
			: "font-urbanist text-[20px] font-light uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))]";

// Канон description (string) + text {content,size} (pupa-дубль). Пустое состояние =
// ДОСЛОВНЫЙ Figma-плейсхолдер 1:19335 «Узнавайте первыми о новых коллекциях и
// эксклюзивных предложениях.», НЕ мок-демо подвала верстальщика «Подпишитесь на
// наши акции и новости» (F:48-50) и НЕ прежний дефолт-копирайт «Будь в курсе…».
// Манера bloom: Inter 16 light muted. Лестница body §9: small 14, large 19.
// Свой текст мерчанта выигрывает (?? fallback срабатывает лишь при пустых данных).
const description =
	(typeof p.description === "string" && p.description.trim() ? p.description : undefined) ??
	(typeof p.text?.content === "string" && p.text.content.trim() ? p.text.content : undefined) ??
	"Узнавайте первыми о новых коллекциях и эксклюзивных предложениях.";
const descSize = p.text?.size;
const descSizeCls =
	descSize === "small" ? " !text-[14px]" : descSize === "large" ? " !text-[19px]" : "";

// Канон placeholder/buttonText: пустое состояние = ДОСЛОВНЫЙ Figma-плейсхолдер
// 1:19335 (input «email@example.com» + кнопка-лейбл «Кнопка»), НЕ литералы подвала
// верстальщика «example@bloom.ru» / «Отправить» (F:21-22, F:70) и НЕ прежний
// дефолт «Подписаться». Свои значения мерчанта выигрывают (fallback лишь при пустых).
const placeholder =
	typeof p.placeholder === "string" && p.placeholder.trim() ? p.placeholder : "email@example.com";
const buttonText =
	typeof p.buttonText === "string" && p.buttonText.trim() ? p.buttonText : "Кнопка";

// Канон formLayout: canon-default 'inline-submit' (blockDefaults темы, совпадает
// с отсутствием пропа) = форма подвала VERBATIM (pill h-10, внутренняя кнопка
// h-8 на розовой поверхности); 'stacked' = поле + розовый pill-CTA h-12 манеры §3.
const inlineSubmit = p.formLayout !== "stacked";

// «Согласие на рассылку» (toggle 'true'/'false', default 'false'): при 'true'
// блок heading+description СКРЫВАЕТСЯ (форма остаётся); 'false' — заголовок и
// текст видны. Конструктор пишет проп из хардкод-тумблера панели Newsletter.
const hideHeading = p.agreement === "true";

// Канон position/alignment: canon-default 'left' (blockDefaults) = литерал
// подвала — заголовок слева, форма max-w-[318px] справа, двухколонная
// lg-раскладка блока (F:38) сохраняется. Явные center/right складывают блок
// в одну колонку и двигают её по контейнеру.
// alignment живёт в под-панели «Заголовок» (heading.alignment); top-level
// p.alignment скрыт (type:'hidden') — читаем его лишь как fallback (как rose T17).
// «Выравнивание» (position) рулит И блоком (posCls), И содержимым (alignCls), И
// stacked-кнопкой (selfCls). left = фирменная 2-колоночная раскладка подвала
// (заголовок + форма рядом на lg); center/right складывают в одну колонку и
// выравнивают всё содержимое. Раньше alignCls читал heading.alignment, который
// конструктор не пишет → текст/кнопка застревали слева = «только часть».
const position = p.position === "center" || p.position === "right" ? p.position : "left";
const isDefaultLayout = position === "left";
const posCls = position === "center" ? "mx-auto" : position === "right" ? "ml-auto" : "mr-auto";
const alignCls =
	position === "center"
		? "items-center text-center"
		: position === "right"
			? "items-end text-right"
			: "items-start text-left";
const selfCls = position === "center" ? "self-center" : position === "right" ? "self-end" : "self-start";
const wrapCls = isDefaultLayout
	? "flex w-full flex-col gap-6 lg:flex-row lg:items-start lg:justify-between"
	: `flex w-full max-w-[430px] flex-col gap-6 ${posCls} ${alignCls}`;
const textBlockCls = isDefaultLayout ? "flex flex-col gap-2" : "flex w-full flex-col gap-2";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && !hideHeading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-20 pt-20 md:px-20 md:pb-[120px] md:pt-[120px] 2xl:px-[300px]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto w-full max-w-[1320px]" data-animate>
		<div class={wrapCls}>
			{
				!hideHeading && (
					<div class={textBlockCls}>
						<h2
							id={titleId}
							class={headingCls}
							data-puck-subsection-parent={id}
							data-puck-subsection-index="100"
							data-puck-subsection-field="heading"
						>
							{heading}
						</h2>
						<p
							class={`font-inter text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]${descSizeCls}`}
							data-puck-subsection-parent={id}
							data-puck-subsection-index="101"
							data-puck-subsection-field="text"
						>
							{description}
						</p>
					</div>
				)
			}

			<div class="flex w-full max-w-[318px] flex-col gap-2 lg:shrink-0">
				{
					inlineSubmit ? (
						<form
							class="flex h-10 w-full items-center gap-2 rounded-full border border-[rgb(var(--color-input-border,255_212_229))] bg-white pl-4 pr-1 transition-colors focus-within:border-[#E38E9F]"
							data-newsletter-form
							data-puck-subsection-parent={id}
							data-puck-subsection-index="997"
							data-puck-subsection-field="placeholder"
						>
							<input
								type="email"
								name="email"
								required
								placeholder={placeholder}
								aria-label="Email"
								class="min-w-0 flex-1 bg-transparent font-inter text-[14px] font-light leading-normal text-black outline-none placeholder:text-[#FFD4E5]"
							/>
							<button
								type="submit"
								class="inline-flex h-8 shrink-0 items-center justify-center rounded-full bg-[#FDF4F6] px-4 font-inter text-[12px] font-light leading-normal text-[#E38E9F] transition-opacity hover:opacity-80 active:scale-95"
							>
								{buttonText}
							</button>
						</form>
					) : (
						<form
							class="flex w-full flex-col gap-4"
							data-newsletter-form
							data-puck-subsection-parent={id}
							data-puck-subsection-index="997"
							data-puck-subsection-field="placeholder"
						>
							<input
								type="email"
								name="email"
								required
								placeholder={placeholder}
								aria-label="Email"
								class="h-10 w-full rounded-full border border-[rgb(var(--color-input-border,255_212_229))] bg-white px-4 font-inter text-[14px] font-light leading-normal text-black outline-none transition-colors placeholder:text-[#FFD4E5] focus-visible:border-[#E38E9F]"
							/>
							<button
								type="submit"
								class={`inline-flex h-12 w-auto items-center justify-center ${selfCls} rounded-[var(--radius-button,100px)] bg-[rgb(var(--color-button-bg,227_142_159))] px-6 font-inter text-[16px] font-light leading-normal text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-90 active:scale-95`}
							>
								{buttonText}
							</button>
						</form>
					)
				}
				<p
					data-newsletter-status
					role="status"
					class="hidden font-inter text-[14px] font-light leading-normal text-[#E38E9F]"
				></p>
			</div>
		</div>
	</div>
</section>
