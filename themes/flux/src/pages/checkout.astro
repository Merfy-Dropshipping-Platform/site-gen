---
// Checkout page (flux theme, Live Per-Theme Checkout).
//
// Composes the SHARED theme-base mega-blocks CheckoutForm + CheckoutSummary.
// Those blocks carry ALL live logic via inline scripts (DaData autocomplete in
// CheckoutDeliveryForm, СДЭК delivery in CheckoutDeliveryMethod, YooKassa in
// CheckoutPayment, submit-chain in CheckoutSubmit). They are token-driven, so
// they inherit flux's colors. NO checkout-JS is rewritten here.
//
// Import mechanism: DIRECT relative import from packages/theme-base/blocks/.
// The block tree is fully self-contained (only sibling .astro + .classes value
// imports + type-only .puckConfig imports), so a relative path resolves the
// whole tree. astro.config.mjs adds vite.server.fs.allow = [workspaceRoot] so
// Vite can read files outside the themes/flux project root.
//
// Plumbing: the block inline-scripts need window.cartStore + window.__MERFY_CONFIG__
// (+ optional window.__DADATA_TOKEN__). themes/flux's native NtCart system does
// NOT expose window.cartStore, so we load the templates' cart-api.js + cart-store.js
// (copied into public/scripts/) and inject config on this page only — keeping the
// rest of the flux theme on its native cart.
import Layout from "../layouts/Layout.astro";
import CheckoutForm from "../../../../packages/theme-base/blocks/CheckoutForm/CheckoutForm.astro";
import CheckoutSummary from "../../../../packages/theme-base/blocks/CheckoutSummary/CheckoutSummary.astro";

// Pilot defaults. In production build.service.ts string-patches shopId and
// injects DADATA_API_KEY; here we hardcode the apiUrl and leave shopId/dadataToken
// to be patched at build/deploy time (the injection script below reads them).
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";
const dadataToken = "";
---
<Layout title="Оформление заказа" description="Оформление заказа" header="checkout">
  {/* Figma 1:13398 — checkout is always the light scheme regardless of theme default. */}
  <div class="color-scheme-2">
    <main class="flex-1 w-full" style="background: rgb(var(--color-bg)); color: rgb(var(--color-text));">
      {/* Figma 1:19998 — form col 434px, summary col 589px, gap ~56px. */}
      <div class="mx-auto max-w-[1280px] px-4 lg:px-6 xl:px-0 py-12 grid grid-cols-1 lg:grid-cols-2 lg:gap-x-8 xl:grid-cols-[434px_589px] xl:gap-x-[56px] gap-y-8">
        <div data-checkout-column="form" class="min-w-0">
          <CheckoutForm />
        </div>
        <div data-checkout-column="summary" class="min-w-0">
          <CheckoutSummary />
        </div>
      </div>
    </main>
  </div>

  {/* --- Live checkout plumbing (checkout page only) --- */}
  {/* Config injection (templates pattern). build.service.ts patches shopId +
      DADATA_API_KEY at deploy; for the local pilot the script just has to exist. */}
  <script is:inline define:vars={{ shopId, apiUrl, dadataToken }}>
    // НЕ клоббер: превью (preview.controller.injectPreviewGlobals) может выставить
    // window.__MERFY_CONFIG__.checkout ДО этого скрипта. Создаём объект при
    // отсутствии и лишь дозаполняем shopId/apiUrl, сохраняя .checkout.
    window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {};
    if (!window.__MERFY_CONFIG__.shopId) window.__MERFY_CONFIG__.shopId = shopId || "";
    if (!window.__MERFY_CONFIG__.apiUrl)
      window.__MERFY_CONFIG__.apiUrl = apiUrl || "https://gateway.merfy.ru/api";
    if (dadataToken) {
      window.__DADATA_TOKEN__ = dadataToken;
    }
  </script>
  {/* Рантайм-канал настроек чекаута (Фаза 4a): без ребилда тянем per-store
      настройки формы из gateway и публикуем на window.__MERFY_CONFIG__.checkout
      + событие `checkout:config-ready`. Отказоустойчиво: любой сбой / пустой
      shopId → дефолты (полная форма), событие ВСЁ РАВНО диспатчится (консюмеры
      формы разблокируются). Превью проставляет .checkout сервер-сайд → fetch
      пропускается. is:inline обязателен (как у соседних checkout-скриптов).
      No-flash: настройки тянутся в рантайме, поэтому не-дефолтные магазины на миг
      видят дефолт-форму до `checkout:config-ready`. Принято намеренно; в будущем
      можно повесить лоадер / придержать конфиг-зависимые поля скрытыми до
      события, чтобы убрать мигание (Фаза 4a, no-flash вариант B). */}
  <script is:inline>
    (function () {
      var cfg = (window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {});
      function fire() {
        try {
          document.dispatchEvent(new CustomEvent("checkout:config-ready"));
        } catch (e) {}
      }
      function apply(s) {
        s = s || {};
        cfg.checkout = {
          contactMethod: s.contactMethod === "email" ? "email" : "email-phone",
          customerNameMode:
            s.customerNameMode === "surname" || s.customerNameMode === "name"
              ? s.customerNameMode
              : "name-surname",
          addressRequired: s.addressRequired === false ? false : true,
        };
        fire();
      }
      // Превью уже проставило cfg.checkout сервер-сайд — чтим его, без fetch.
      if (cfg.checkout) {
        fire();
        return;
      }
      var shopId = cfg.shopId;
      var apiUrl = cfg.apiUrl || "https://gateway.merfy.ru/api";
      if (!shopId) {
        apply(null);
        return;
      }
      try {
        fetch(apiUrl + "/public/sites/" + encodeURIComponent(shopId) + "/settings", {
          headers: { Accept: "application/json" },
        })
          .then(function (r) {
            return r && r.ok ? r.json() : null;
          })
          .then(function (j) {
            apply(j && j.settings);
          })
          .catch(function () {
            apply(null);
          });
      } catch (e) {
        apply(null);
      }
    })();
  </script>
  {/* `is:inline` is REQUIRED — without it Astro bundles these through Vite, can't
      resolve `/scripts/...` (public dir) and SILENTLY drops the tag, leaving
      window.cartStore undefined → empty checkout. cart-store.js imports cart-api.js,
      so both are loaded as ES modules. */}
  <script is:inline type="module" src="/scripts/cart-api.js"></script>
  <script is:inline type="module" src="/scripts/cart-store.js"></script>
  <script is:inline>
    // Чекаут наполняет серверную корзину (cartStore) из nt-cart (flux:cart:v1) —
    // источника истины того, что в корзине у пользователя. Товар виден при ЛЮБОМ
    // входе: «Купить сейчас»→/checkout, корзина→/checkout, прямой /checkout. Всё в
    // try/catch: при сбое деградирует к cartStore.init() (прежнее поведение).
    document.addEventListener("DOMContentLoaded", function () {
      var cs = window.cartStore;
      if (!cs) return;
      function fallbackInit() { try { if (cs.init) cs.init(); } catch (e) {} }
      var lines = [];
      // Express «Купить сейчас»: товар лежит в sessionStorage (НЕ в URL, НЕ в корзине
      // покупателя). Есть — оформляем ТОЛЬКО его; иначе — корзину (flux:cart:v1).
      var bn = null;
      try { bn = JSON.parse(sessionStorage.getItem("flux:buynow") || "null"); } catch (e) { bn = null; }
      if (bn && bn.productId) {
        lines = [{ productId: bn.productId, variant: { variantCombinationId: bn.variantCombinationId || null, color: bn.variantColor || undefined, size: bn.variantSize || undefined }, quantity: bn.quantity || 1 }];
      } else {
        try { lines = JSON.parse(localStorage.getItem("flux:cart:v1") || "[]"); } catch (e) { lines = []; }
      }
      if (!Array.isArray(lines) || !lines.length || !cs.clear || !cs.addItem) { fallbackInit(); return; }
      // Опции варианта (Цвет/Размер) строки корзины → сервер пере-матчит вариант по
      // ним, если variantCombinationId устарел (ресед пересоздал комбинации).
      function optsFromVariant(v) {
        var o = {};
        if (!v) return o;
        if (v.color) o["Цвет"] = v.color;
        if (v.size) o["Размер"] = v.size;
        return o;
      }
      (async function () {
        try {
          await cs.clear();
          for (var i = 0; i < lines.length; i++) {
            var l = lines[i];
            var opts = optsFromVariant(l.variant);
            try { await cs.addItem(l.productId, (l.variant && l.variant.variantCombinationId) || null, l.quantity, Object.keys(opts).length ? opts : null); } catch (e) {}
          }
        } catch (e) { fallbackInit(); return; }
        try { document.dispatchEvent(new CustomEvent("cart:updated")); } catch (e) {}
      })();
    });
  </script>
</Layout>
