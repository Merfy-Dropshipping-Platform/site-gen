---
// Страница корзины — ШЕЛЛ для системы контент-страниц (page-cart kind:content).
// Логика корзины вынесена в Puck-секцию CartSection
// (themes/rose/src/components/sections/CartSection.astro). composeContentPagesIntoDist
// пересаживает секции ревизии page-cart в <main> этого шелла (дефолт [CartSection]
// приходит из packages/theme-rose/pages/cart.json через lazy-seed). Корзину теперь
// можно двигать/настраивать и добавлять вокруг другие секции, как на главной.
import Layout from "../layouts/Layout.astro";
---

<Layout title="Корзина" description="Ваша корзина — Rose">
	<section class="mx-auto w-full max-w-[1320px] px-4 py-16 sm:px-5 md:px-10 lg:px-16 xl:px-20 2xl:px-[280px]">
		<!-- Секция «Корзина» (+ добавленные секции) вставляются composeContentPagesIntoDist -->
	</section>
</Layout>
