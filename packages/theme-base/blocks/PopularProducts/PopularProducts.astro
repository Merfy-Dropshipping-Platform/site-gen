---
import type { PopularProductsProps } from './PopularProducts.puckConfig';
import { PopularProductsClasses as C } from './PopularProducts.classes';

interface Props extends PopularProductsProps {
  id?: string;
}

const {
  id,
  heading,
  subtitle,
  cards = 4,
  columns = 4,
  colorScheme = 1,
  padding,
} = Astro.props as Props & { subtitle?: string };

const scheme = `color-scheme-${colorScheme}`;
const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
const gridTemplateCols = `grid-template-columns: repeat(${columns}, minmax(0, 1fr));`;
const placeholders = Array.from({ length: cards }, (_, i) => i);
// NOTE: Real product data is hydrated in Phase 1c via constructor rewire.
// For now we render `cards` skeleton placeholders.
---
<section
  class:list={[C.root, scheme]}
  data-puck-component-id={id}
  data-block="popular-products"
  style={paddingStyle}
>
  <div class={C.container}>
    {heading && <h2 class={C.heading}>{heading}</h2>}
    {subtitle && <p class={C.subtitle}>{subtitle}</p>}
    <div class={C.grid} style={gridTemplateCols}>
      {placeholders.map((i) => (
        <div
          class={C.placeholderCard}
          aria-label="Product placeholder"
          data-product-index={i}
        >
          <div class={C.placeholderMedia}></div>
          <div class={C.placeholderBody}>
            <div class={C.placeholderTitle}></div>
            <div class={C.placeholderPrice}></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
