---
interface Props {
  heading?: { text?: string; size?: 'small' | 'medium' | 'large' };
  text?: { content?: string; size?: 'small' | 'medium' | 'large' };
  form?: { placeholder?: string; buttonText?: string };
  colorScheme?: string;
  padding?: { top?: number; bottom?: number };
}

const { heading, text, form, colorScheme, padding } = Astro.props;
const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';
const headingText = heading?.text ?? 'Подпишитесь на нашу рассылку';
const textContent = text?.content ?? '';
const placeholder = form?.placeholder ?? 'E-mail';
const buttonText = form?.buttonText ?? 'Отправить';
const padTop = padding?.top ?? 120;
const padBottom = padding?.bottom ?? 120;
---

<section
  class={`newsletter-section w-full ${schemeClass}`}
  style={`padding-top: ${padTop}px; padding-bottom: ${padBottom}px; background: rgb(var(--color-background)); color: rgb(var(--color-foreground));`}
>
  <div class="newsletter-inner">
    <div class="flex flex-col gap-[8px]">
      <h2 class="font-heading italic font-normal text-[20px] leading-[1.2]" style="color: rgb(var(--color-foreground));">
        {headingText}
      </h2>
      {textContent && (
        <p class="text-[16px] italic font-body leading-[1.25]" style="color: rgb(var(--color-foreground) / 0.7);">
          {textContent}
        </p>
      )}
    </div>
    <form
      class="newsletter-form"
      action="#"
      method="POST"
    >
      <input
        type="email"
        name="email"
        placeholder={placeholder}
        required
        class="newsletter-input font-body focus:outline-none"
        style="color: rgb(var(--color-foreground)); border: none; background: transparent;"
      />
      <button
        type="submit"
        class="newsletter-btn font-body cursor-pointer transition-opacity hover:opacity-80 whitespace-nowrap"
      >
        {buttonText}
      </button>
    </form>
  </div>
</section>

<style>
  .newsletter-inner {
    width: 100%;
    padding-left: 20px;
    padding-right: 20px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 40px;
    box-sizing: border-box;
  }

  .newsletter-form {
    width: 652px;
    max-width: 100%;
    height: 56px;
    display: flex;
    align-items: center;
    border: 1px solid rgb(var(--color-foreground));
    border-radius: 0;
    box-sizing: border-box;
  }

  .newsletter-input {
    flex: 1;
    height: 100%;
    padding-left: 16px;
    padding-right: 12px;
    font-size: 16px;
    line-height: 1.25;
    color: rgb(var(--color-foreground));
  }

  .newsletter-input::placeholder {
    color: rgb(var(--color-foreground) / 0.5);
    font-family: var(--font-body, 'Arsenal', sans-serif);
    font-size: 16px;
    font-style: normal;
  }

  .newsletter-btn {
    height: 32px;
    padding: 0 8px;
    margin-right: 12px;
    font-size: 12px;
    font-weight: 400;
    text-transform: uppercase;
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    border: none;
    border-radius: 0;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .newsletter-inner {
      max-width: 1320px;
      margin: 0 auto;
      padding-left: 20px;
      padding-right: 20px;
    }
  }
  @media (min-width: 1920px) {
    .newsletter-inner {
      max-width: none;
      margin: 0;
      padding-left: var(--content-padding, 300px);
      padding-right: var(--content-padding, 300px);
    }
  }

  @media (max-width: 767px) {
    .newsletter-form {
      width: 100%;
    }
  }
</style>
