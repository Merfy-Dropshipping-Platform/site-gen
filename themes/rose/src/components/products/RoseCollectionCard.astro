---
import type { Collection } from "../../data/collections";
import RosePicture from "../img/RosePicture.astro";

interface Props {
	collection: Collection;
	priority?: boolean;
}

const { collection, priority = false } = Astro.props;
const href = `/catalog?collection=${encodeURIComponent(collection.name)}`;
---

<a
	href={href}
	class="group flex w-full cursor-pointer flex-col gap-5"
	aria-label={collection.name}
	data-nt="rose-collection-card"
>
	<div class="aspect-[430/500] w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))]">
		<RosePicture
			src={collection.image}
			alt={collection.name}
			width="430"
			height="500"
			loading="eager"
			fetchpriority={priority ? "high" : undefined}
			class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.08]"
		/>
	</div>
	<h3
		class="rose-collection-name w-full text-left font-manrope !text-[16px] font-normal !leading-none tracking-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity group-hover:opacity-70"
	>
		{collection.name}
	</h3>
</a>

<style>
	/* Figma 375: подпись карточки коллекции — Manrope 12, выравнивание по левому краю */
	@media (max-width: 639.98px) {
		.rose-collection-name {
			font-size: 12px !important;
		}
	}
</style>
