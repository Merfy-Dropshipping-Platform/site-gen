---
import RoseNtIcon from "./icons/RoseNtIcon.astro";
import { withBase } from "../lib/with-base";
import { SITE_TITLE } from "../consts";

const today = new Date();

// Live-конфиг подписки: shopId патчит build.service (patchShopIdInDist) → siteId
// на деплое (заменяет `const shopId = ""` в HTML); apiUrl — публичный gateway.
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";

const navColumn = [
	{ label: "Главная", href: "/" },
	{ label: "Каталог", href: "/catalog" },
	{ label: "Контакты", href: "/contacts" },
];

// Правовые ссылки футера приходят из build (site_policy) только для заполненных
// политик — без хардкод-фолбэка (раньше вели на несуществующие /legal/*).

// ОЖИВЛЕНИЕ: канон-схема Footer (Фаза 2: телефон/email/название; T12: полная
// канон-схема — newsletter.enabled, колонки, socialLinks, copyright, bottomStrip,
// padding). Дефолтные ветки = прежним строкам байт-в-байт; новые элементы
// (заголовки колонок) не рендерятся без пропсов.
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустая строка (canon default Puck / коэрсер) не должна ронять «Rose Theme».
const siteTitle = typeof p.siteTitle === "string" && p.siteTitle.trim() ? p.siteTitle : SITE_TITLE;
// Телефон/почта футера — ТОЛЬКО при настроенных контактах (build пишет их из
// «Информация о компании»). Без данных — пусто, ссылки tel:/mailto: не рендерятся.
const phone = typeof p.phone === "string" && p.phone.trim() ? p.phone.trim() : "";
const emailPlaceholder = `example@${SITE_TITLE.toLowerCase()}.merfy`;
const rawEmail = p.socialColumn?.email ?? p.email ?? "";
const email = typeof rawEmail === "string" ? rawEmail.trim() : "";
// Платёжные бейджи — только при подключённой кассе (build ставит paymentEnabled).
const paymentEnabled = p.paymentEnabled === true || p.paymentEnabled === "true";
// «Информация о компании» (адрес/часы/ИНН/любая инфа) — build кладёт сюда поля
// КРОМЕ телефона/почты. Выводим label/value в контакт-колонке.
const contactFields: Array<{ label: string; value: string }> = Array.isArray(p.socialColumn?.contactFields)
	? p.socialColumn.contactFields.filter((f: any) => f && typeof f.value === "string" && f.value.trim())
	: [];

// Канон newsletter.enabled — скрыть блок подписки ТОЛЬКО при явном false/'false'
// (булево может прийти строкой). Отсутствие пропа и rose
// blockDefaults.Footer.newsletter.enabled=true → блок показан = пиксель.
const newsletterEnabled = !(
	p.newsletter &&
	(p.newsletter.enabled === false || p.newsletter.enabled === "false")
);

// Оживление полей панели: заголовок/текст рассылки из пропов (Figma 314-34558 «Заголовок»/
// «Текст»), fallback на литералы верстальщика → без правок футер байт-в-байт как раньше.
const newsletterHeadingText =
	typeof p.heading?.text === "string" && p.heading.text.trim() ? p.heading.text : "Подпишитесь на нашу рассылку";
const newsletterText =
	typeof p.text?.content === "string" && p.text.content.trim()
		? p.text.content
		: "Получайте информацию от нашего бренда";
// item 1 — выравнивание блока рассылки, ОДНО значение на десктоп И адаптив. Классы
// ЛИТЕРАЛАМИ (Tailwind JIT scan). Дефолт left (раньше был захардкожен text-left + @media center).
const _AL_ITEMS: Record<string, string> = { left: "items-start", center: "items-center", right: "items-end" };
const _AL_TEXT: Record<string, string> = { left: "text-left", center: "text-center", right: "text-right" };
const _ca = ["left", "center", "right"].includes(p.contentAlign) ? p.contentAlign : "left";
const nlSectionAlignCls = _AL_ITEMS[_ca];
const nlCopyAlignCls = `${_AL_ITEMS[_ca]} ${_AL_TEXT[_ca]}`;
// «Выравнивание» центрирует ГРУППУ колонок (ЦЕНТРИРОВАННЫЙ БЛОК, равные поля по краям —
// юзер выбрал этот вариант). center → секция justify-center + узкий равный gap (колонки
// вместе по центру), контент внутри колонок остаётся СЛЕВА (естественно). left (дефолт) =
// нав слева / контакты справа (justify-between, текущий); right = группа к правому краю.
// Классы литералами (Tailwind JIT).
const colsJustifyCls = _ca === "center" ? "lg:justify-center lg:gap-24" : _ca === "right" ? "lg:justify-end" : "lg:justify-between";
const navInfoGapCls = _ca === "center" ? "sm:gap-24" : "sm:gap-[200px]";
// center = центрированный блок колонок И контент ВНУТРИ блоков по центру (юзер: «когда по
// центру, и контент блоков был по центру»). right = к правому краю. left (дефолт) = слева/справа.
const colInnerCls = _ca === "center" ? "items-center text-center" : _ca === "right" ? "items-end text-right" : "";
const contactGroupCls = _ca === "center" ? "items-center text-center" : _ca === "right" ? "items-end text-right" : "lg:items-end lg:text-right";
const contactTextCls = _ca === "center" ? "text-center" : _ca === "right" ? "text-right" : "lg:text-right";
const contactJustifyCls = _ca === "center" ? "justify-center" : _ca === "right" ? "justify-end" : "lg:justify-end";

// Канон-колонки {title, links:[{label,href}]}: ссылки из пропсов с fallback на
// литералы верстальщика; заголовок колонки — НОВЫЙ элемент, рендерится только
// при непустом title из пропсов (в вёрстке верстальщика заголовков колонок нет).
const coerceColumnLinks = (
	col: any,
	fallback: Array<{ label: string; href: string }>,
): Array<{ label: string; href: string }> =>
	Array.isArray(col?.links) && col.links.length > 0
		? col.links.map((l: any) => ({ label: String(l?.label ?? ""), href: String(l?.href ?? "/") }))
		: fallback;
const navLinks = coerceColumnLinks(p.navigationColumn, navColumn);
const infoLinks = coerceColumnLinks(p.informationColumn, []);
const columnTitle = (col: any): string | undefined =>
	typeof col?.title === "string" && col.title.trim() ? col.title : undefined;
const navColTitle = columnTitle(p.navigationColumn);
const infoColTitle = columnTitle(p.informationColumn);
const columnTitleCls =
	"font-manrope !text-[16px] font-normal !leading-none tracking-normal text-[rgb(var(--color-text,0_0_0))]";

type SocialIconName = "social-vk" | "social-youtube" | "social-yandex-dzen" | "social-tiktok" | "social-telegram";

type SocialLink = { platform: string; href: string; icon: SocialIconName };

// Канон socialColumn.socialLinks (enum платформ) → иконы/лейблы верстальщика;
// fallback = литеральный набор верстальщика дословно.
const SOCIAL_PLATFORMS: Record<string, { label: string; icon: SocialIconName }> = {
	vk: { label: "VK", icon: "social-vk" },
	youtube: { label: "YouTube", icon: "social-youtube" },
	dzen: { label: "YandexDzen", icon: "social-yandex-dzen" },
	tiktok: { label: "TikTok", icon: "social-tiktok" },
	telegram: { label: "Telegram", icon: "social-telegram" },
};
// Соцсети — ТОЛЬКО настроенные в Theme Settings (непустой href ≠ "#"). Без
// фолбэка defaultSocials: пустой набор → ряд иконок не рендерится вовсе.
const socials: SocialLink[] = Array.isArray(p.socialColumn?.socialLinks)
	? p.socialColumn.socialLinks
			.map((s: any): SocialLink | null => {
				const meta = SOCIAL_PLATFORMS[String(s?.platform ?? "")];
				const href = String(s?.href ?? "").trim();
				return meta && href && href !== "#" ? { platform: meta.label, href, icon: meta.icon } : null;
			})
			.filter((s: SocialLink | null): s is SocialLink => s !== null)
	: [];

// Канон copyright {companyName, poweredBy, showYear} (+ legacy-строка целиком).
// Дефолтная сборка = литерал верстальщика байт-в-байт:
// «© {год} {siteTitle} Theme Все права защищены. Powered by Merfy».
const copyrightProp = p.copyright;
const copyrightOverride =
	typeof copyrightProp === "string" && copyrightProp.trim() ? copyrightProp : undefined;
const copyrightObj = copyrightProp && typeof copyrightProp === "object" ? copyrightProp : {};
const showYear = !(copyrightObj.showYear === false || copyrightObj.showYear === "false");
const companyPart =
	typeof copyrightObj.companyName === "string" && copyrightObj.companyName.trim()
		? copyrightObj.companyName
		: `${siteTitle} Theme`;
const poweredBy =
	typeof copyrightObj.poweredBy === "string" ? copyrightObj.poweredBy : "Powered by Merfy";
const copyrightText =
	copyrightOverride ??
	`© ${showYear ? `${today.getFullYear()} ` : ""}${companyPart} Все права защищены.${poweredBy ? ` ${poweredBy}` : ""}`;

// Канон bottomStrip {enabled, text} — носитель в rose = чёрная копирайт-полоса
// (отдельной полосы у верстальщика нет). enabled false/'false' → полоса скрыта;
// непустой text перебивает собранный копирайт. Отсутствие = текущий рендер.
const strip = p.bottomStrip && typeof p.bottomStrip === "object" ? p.bottomStrip : undefined;
const bottomStripVisible = !(strip && (strip.enabled === false || strip.enabled === "false"));
const stripText =
	typeof strip?.text === "string" && strip.text.trim() ? strip.text : copyrightText;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при пропе, на носителе
// отступов верстальщика (внутренний контейнер pt-20 pb-20). При rose
// blockDefaults {80,80} (и впрыске коэрсера {80,80}) рендер пиксель-идентичен:
// padding 80px == pt-20/pb-20.
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const footerPadStyle = pad
	? `padding-top:${Number(pad.top) || 0}px;padding-bottom:${Number(pad.bottom) || 0}px;`
	: undefined;
const footerContainerCls = pad
	? "mx-auto w-full max-w-[1920px] px-4 sm:px-5 md:px-10 lg:px-16 xl:px-20 2xl:px-[280px]"
	: "mx-auto w-full max-w-[1920px] px-4 pb-20 pt-20 sm:px-5 md:px-10 lg:px-16 xl:px-20 2xl:px-[280px]";

// Применяем СВОЮ colorScheme на <footer> (как base Footer.astro). Иначе hot-render
// одиночного блока в превью конструктора (без scheme-обёртки композитора) берёт :root
// = тёмный BASE_DEFAULT → ЧЁРНЫЙ футер. На live обёртка композитора даёт ту же схему —
// дубль безвреден. Пустой проп → :root (как раньше).
const footerSchemeClass =
	typeof p.colorScheme === "string" && p.colorScheme
		? `color-scheme-${String(p.colorScheme).replace("scheme-", "")}`
		: "";
---

<footer class:list={["w-full bg-[rgb(var(--color-bg,255_255_255))]", footerSchemeClass]} data-puck-component-id={id}>
	<div class={footerContainerCls} style={footerPadStyle}>
		<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-20">
			{newsletterEnabled && (
			<section class={`flex w-full flex-col gap-5 ${nlSectionAlignCls}`} aria-labelledby="newsletter-heading">
				<div class={`flex max-w-[1320px] flex-col gap-2 ${nlCopyAlignCls}`}>
					<h2
						id="newsletter-heading"
						class="rose-title !font-bold w-full min-w-0 max-lg:whitespace-normal lg:whitespace-nowrap !text-[clamp(14px,2.2vw,20px)]"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="100"
						data-puck-subsection-field="newsletter"
					>
						{newsletterHeadingText}
					</h2>
					<p class="font-manrope !text-[16px] font-normal !leading-none tracking-normal text-[rgb(var(--color-muted,153_153_153))]">
						{newsletterText}
					</p>
				</div>

				<form
					class="flex h-14 w-full max-w-[var(--size-newsletter-form-w,430px)] items-center gap-2 rounded-[var(--radius-input,4px)] border border-[rgb(var(--color-input-border,153_153_153))] bg-white pl-[18px] pr-4 transition-colors focus-within:border-[#000000]"
					data-newsletter-form
					data-puck-subsection-parent={id}
					data-puck-subsection-index="997"
					data-puck-subsection-field="newsletter"
				>
					<input
						type="email"
						name="email"
						required
						placeholder={emailPlaceholder}
						aria-label="Email"
						class="min-w-0 flex-1 bg-transparent font-manrope text-[16px] font-normal leading-none text-[#000000] placeholder:text-[#999999] outline-none"
					/>
					<button
						type="submit"
						aria-label="Подписаться"
						class="flex size-9 shrink-0 items-center justify-center font-manrope text-[16px] font-normal leading-none text-[#000000] active:scale-95"
					>
						<span aria-hidden="true" class="block translate-y-px">→</span>
					</button>
				</form>
				<p
					data-newsletter-status
					role="status"
					class="hidden max-w-[430px] font-manrope text-[14px] font-normal leading-none text-[#4AD300]"
				></p>
			</section>
			)}

			<section
				class={`flex w-full flex-col gap-10 lg:flex-row lg:items-start ${colsJustifyCls}`}
				aria-label="Навигация по сайту"
			>
				<div class={`flex flex-col gap-10 sm:flex-row ${navInfoGapCls}`}>
					<ul
						class={`flex flex-col gap-3 ${colInnerCls}`}
						role="list"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="996"
						data-puck-subsection-field="navigationColumn"
					>
						{navColTitle && (
							<li>
								<h3 class={columnTitleCls}>{navColTitle}</h3>
							</li>
						)}
						{navLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="font-manrope !text-[16px] font-normal !leading-none tracking-normal text-[rgb(var(--color-muted,153_153_153))] transition-colors hover:text-[#000000] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#71C0FF]"
								>
									{link.label}
								</a>
							</li>
						))}
					</ul>

					{(infoColTitle || infoLinks.length > 0) && (
					<ul
						class={`flex flex-col gap-3 ${colInnerCls}`}
						role="list"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="995"
						data-puck-subsection-field="informationColumn"
					>
						{infoColTitle && (
							<li>
								<h3 class={columnTitleCls}>{infoColTitle}</h3>
							</li>
						)}
						{infoLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="font-manrope !text-[16px] font-normal !leading-none tracking-normal text-[rgb(var(--color-muted,153_153_153))] transition-colors hover:text-[#000000] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#71C0FF]"
								>
									{link.label}
								</a>
							</li>
						))}
					</ul>
					)}
				</div>

				<div
					class={`flex flex-col gap-6 lg:max-w-[min(100%,430px)] ${contactGroupCls}`}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="994"
					data-puck-subsection-field="socialColumn"
				>
					{(phone || email || contactFields.length > 0) && (
					<div class="flex flex-col gap-3">
						{phone && (
						<a
							href={`tel:${phone.replace(/[^+\d]/g, "")}`}
							class={`font-manrope !text-[16px] font-normal !leading-none tracking-normal text-[rgb(var(--color-muted,153_153_153))] transition-colors hover:text-[#000000] ${contactTextCls}`}
						>
							{phone}
						</a>
						)}
						{email && (
						<a
							href={`mailto:${email}`}
							class={`font-manrope !text-[16px] font-normal !leading-none tracking-normal text-[rgb(var(--color-muted,153_153_153))] transition-colors hover:text-[#000000] ${contactTextCls}`}
						>
							{email}
						</a>
						)}
						{contactFields.map((f) => (
						<div class={`font-manrope !text-[16px] font-normal !leading-none tracking-normal text-[rgb(var(--color-muted,153_153_153))] ${contactTextCls}`}>
							<span class="text-[rgb(var(--color-text,0_0_0))]">{f.label}:</span> {f.value}
						</div>
						))}
					</div>
					)}
					{socials.length > 0 && (
					<div class={`flex flex-wrap items-center gap-2 ${contactJustifyCls}`}>
						{socials.map((s) => (
							<a
								href={s.href}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={s.platform}
								class="flex size-6 items-center justify-center text-[rgb(var(--color-text,0_0_0))] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#71C0FF]"
							>
								<RoseNtIcon name={s.icon} sizeClass="size-6" />
							</a>
						))}
					</div>
					)}
					{paymentEnabled && (
					<div class={`flex flex-wrap items-center gap-3 ${contactJustifyCls}`} aria-label="Способы оплаты">
						<img src={withBase("/icons/MasterCard.svg")} alt="Mastercard" class="h-6 w-auto shrink-0" decoding="async" />
						<img src={withBase("/icons/Visa.png")} alt="Visa" class="h-6 w-auto shrink-0" decoding="async" />
						<img src={withBase("/icons/MIR.png")} alt="МИР" class="h-6 w-auto shrink-0" decoding="async" />
					</div>
					)}
				</div>
			</section>
		</div>
	</div>

	{bottomStripVisible && (
		<div
			class="flex h-16 w-full items-center justify-center bg-[rgb(var(--color-heading,0_0_0))] px-4"
			data-puck-subsection-parent={id}
			data-puck-subsection-index="993"
			data-puck-subsection-field="copyright"
		>
			<p class="text-center font-manrope text-[14px] font-normal leading-none text-[rgb(var(--color-bg,255_255_255))]">
				{stripText}
			</p>
		</div>
	)}
</footer>

<style>
	/* Figma 375 для мобильного:
	   - заголовок «Подпишитесь на нашу рассылку» — Comfortaa 14 (clamp уже выдаёт 14 на 375), text-center.
	   - подзаголовок рассылки — Manrope 12, text-center.
	   - ссылки навигации/инфо/контактов — Manrope 12–14, text-center.
	   - колонки навигации/контактов центрируются как блоки. */
	@media (max-width: 639.98px) {

		:global(#newsletter-heading) {
			font-weight: 400 !important;
		}

		:global([aria-labelledby="newsletter-heading"] > div:first-child > p) {
			font-size: 12px !important;
			line-height: 1 !important;
		}

		:global([data-newsletter-form]) {
			height: 40px !important;
			min-height: 40px !important;
		}

		/* Выравнивание колонок/формы на мобиле контролирует «Выравнивание» (contentAlign),
		   как на десктопе — принудительное @media-центрирование убрано (юзер: «на мобилу
		   так же как на десктоп»). Остались только размеры шрифта. */
		:global([aria-label="Навигация по сайту"] a) {
			font-size: 14px !important;
		}
	}
</style>

<script is:inline define:vars={{ shopId, apiUrl }}>
	// Реальная отправка подписки на gateway (раньше форма только показывала
	// фейковое «Спасибо» без запроса). store_id берём из пропатченного shopId
	// (на деплое) либо из window.__MERFY_SITE_ID__ (превью конструктора).
	(function () {
		window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
			shopId: shopId || "",
			apiUrl: apiUrl || "https://gateway.merfy.ru/api",
		};
		var cfg = window.__MERFY_CONFIG__;
		var base = String(cfg.apiUrl || "https://gateway.merfy.ru/api").replace(/\/+$/, "");
		var storeId = cfg.shopId || window.__MERFY_SITE_ID__ || "";

		function wire(form) {
			if (!form || form.__merfyNewsletterWired) return;
			form.__merfyNewsletterWired = true;
			var section = form.closest("section") || document;
			var status = section.querySelector("[data-newsletter-status]");
			var btn = form.querySelector('button[type="submit"]');

			function show(msg, isError) {
				if (!status) return;
				status.textContent = msg;
				status.style.color = isError ? "#E11D48" : "";
				status.classList.remove("hidden");
			}

			form.addEventListener("submit", function (event) {
				event.preventDefault();
				var input = form.querySelector('input[type="email"]');
				var email = input ? String(input.value || "").trim() : "";
				if (!email) return;
				if (btn) btn.disabled = true;
				show("Отправляем…", false);

				fetch(base + "/storefront/newsletter/subscribe", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ store_id: storeId, email: email }),
				})
					.then(function (res) {
						return res
							.json()
							.catch(function () { return {}; })
							.then(function (data) { return { ok: res.ok, code: res.status, data: data }; });
					})
					.then(function (r) {
						if (r.ok) {
							show(
								r.data && r.data.alreadySubscribed
									? "Вы уже подписаны на рассылку."
									: "Спасибо! Мы отправим вам приветственное письмо.",
								false,
							);
							form.reset();
						} else if (r.code === 429) {
							show("Слишком много попыток. Попробуйте позже.", true);
						} else {
							show("Не удалось подписаться. Попробуйте позже.", true);
						}
					})
					.catch(function () {
						show("Не удалось подписаться. Проверьте соединение.", true);
					})
					.finally(function () {
						if (btn) btn.disabled = false;
					});
			});
		}

		function init() {
			var forms = document.querySelectorAll("[data-newsletter-form]");
			for (var i = 0; i < forms.length; i++) wire(forms[i]);
		}
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", init);
		} else {
			init();
		}
	})();
</script>
