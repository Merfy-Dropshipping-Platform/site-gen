---
/**
 * BloomProductCard (порт из themes/bloom/src/components/products/BloomProductCard.astro).
 *
 * Тип Product заинлайнен (минимальный shape витрины) вместо импорта
 * ../../data/products — block-папка override-темы автономна (компилятор превью
 * не резолвит пути за пределы папки). BloomPicture — sibling (./).
 *
 * Bloom-специфика vs RoseProductCard (родная вёрстка верстальщика bloom):
 *   • медиа — aspect-square (НЕ портрет 318/444), скругление --radius-media:12px,
 *     фон surface (#F5F5F5);
 *   • типографика name/price/oldprice — font-inter font-light (НЕ font-manrope);
 *   • кнопка quickAdd — pill (--radius-button:100px) с заливкой accent/button-bg
 *     (родной bloom #e38e9f).
 *
 * Prop-контракт зеркалит RoseProductCard (cardAspectClass/showQuickAdd/btn*),
 * чтобы client renderCardHtml в Catalog.astro оставался в parity (SSG↔гидрация).
 */
import BloomPicture from "./BloomPicture.astro";

interface Product {
  name: string;
  price: string;
  oldPrice?: string;
  image: string;
  id?: string;
  discount?: boolean;
}

interface Props {
  product: Product;
  priority?: boolean;
  /** Вид изображения карточки (Tailwind aspect-класс). Дефолт — родной bloom
      квадрат. Передаётся из Catalog.astro (настройка «Вид изображения»),
      зеркалит client renderCardHtml для parity. */
  cardAspectClass?: string;
  /** «Контейнер» карточки (настройка cardBackground). true → контент в подложке
      surface с внутр. отступом 12px (фото/заголовок/кнопка авто-инсетятся, кнопка
      НЕ край-в-край); false (дефолт) → флеш-вид (full-bleed фото, full-width
      кнопка). Зеркалит client renderCardHtml для parity. */
  cardContainerOn?: boolean;
  /** Быстрое действие: кнопка под карточкой (none → нет; иначе текст). */
  showQuickAdd?: boolean;
  quickAddText?: string;
  /** Inline-стили кнопки quickAdd по «Стилю кнопки» (primary/secondary/link). */
  btnStyle?: string;
  btnBg?: string;
  btnFg?: string;
  btnBorder?: string;
}

const {
  product,
  priority = false,
  cardAspectClass = "aspect-square",
  cardContainerOn = false,
  showQuickAdd = false,
  quickAddText = "В КОРЗИНУ",
  btnStyle = "primary",
  btnBg = "rgb(var(--color-button-bg,207 122 139))",
  btnFg = "rgb(var(--color-button-text,255 255 255))",
  btnBorder = "none",
} = Astro.props as Props;
const href = `/products/${product.id}`;
const showSaleBadge = product.discount === true;
// «Контейнер» карточки (настройка cardBackground). Зеркалит client
// renderCardHtml (CARD_CONTAINER_STYLE) в Catalog.astro — parity SSG↔гидрация.
// true → подложка surface + радиус + padding 12px; <article> = flex-col с w-full
// детьми, поэтому padding авто-инсетит фото/заголовок/кнопку (кнопка становится
// full-width контента, НЕ край-в-край карточки). false (дефолт) → флеш-вид.
const cardContainerStyle = cardContainerOn
  ? "background:rgb(var(--color-surface,247 247 249));border-radius:var(--radius-card,12px);padding:12px;"
  : undefined;
// Стиль кнопки quickAdd (зеркалит client renderCardHtml). Bloom = pill
// (--radius-button:100px). link → текст-ссылка.
const quickBtnStyle =
  `width:100%;height:48px;padding:0 16px;border-radius:var(--radius-button,100px);` +
  `font-family:var(--font-body,'Inter',sans-serif);font-weight:300;font-size:16px;cursor:pointer;` +
  `display:flex;align-items:center;justify-content:center;line-height:1;` +
  `background:${btnBg};color:${btnFg};border:${btnBorder};` +
  (btnStyle === "link" ? "text-decoration:underline;background:transparent;" : "");

// Outline-сердце избранного (SSR-дефолт). Геометрия = универсальный heart-path (тот
// же, что rose public/icons/favourite.svg) и зеркалит wishlist.ts heartSvg(false).
// Инлайн (НЕ <img> NtIcon) — чтобы глобальный делегат initWishlistUI мог переключать
// fill на filled. На SSG нет window → рисуем outline; делегат поставит filled на
// page-load если товар в избранном. SVG-строка автономна (block-папка override-темы
// не резолвит импорты наружу).
const defaultHeartSvg =
  '<svg viewBox="0 0 17.4 15.4" width="100%" height="100%" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="display:block">' +
  '<path d="M7.428 14.2615C5.172 12.5239 0.7 8.55212 0.7 4.97729C0.7 2.61547 2.384 0.7 4.7 0.7C5.9 0.7 7.1 1.11175 8.7 2.75876C10.3 1.11175 11.5 0.7 12.7 0.7C15.016 0.7 16.7 2.61547 16.7 4.97729C16.7 8.5513 12.228 12.5239 9.972 14.2615C9.212 14.8462 8.188 14.8462 7.428 14.2615Z" ' +
  'fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>' +
  "</svg>";
---

<article
  class="group flex w-full flex-col gap-4"
  data-nt="bloom-product-card"
  aria-label={product.name}
  style={cardContainerStyle}
>
  {/* Обёртка медиа: relative-родитель для overlay-сердца избранного. Сердце —
      sibling <a> (НЕ внутри: button-in-anchor невалиден + клик по сердцу не должен
      открывать товар). aspect-класс несёт сам <a>; обёртка только позиционирует. */}
  <div class="relative w-full">
  <a
    href={href}
    class:list={[cardAspectClass, "relative block w-full overflow-hidden rounded-[var(--radius-media,12px)] bg-[rgb(var(--color-surface,245_245_245))]"]}
    aria-label={product.name}
  >
    {product.image ? (
      <BloomPicture
        src={product.image}
        alt={product.name}
        width="600"
        height="600"
        loading="eager"
        fetchpriority={priority ? "high" : undefined}
        class="h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-105"
        data-img-primary={product.image}
      />
    ) : (
      /* Товар без фото: surface-плейсхолдер вместо <img> (битой иконки).
         Цвета только токенами; разметку зеркалит CARD_MEDIA_FALLBACK_HTML
         в Catalog.astro client — менять синхронно. */
      <div
        class="absolute inset-0 flex items-center justify-center"
        style="background:rgb(var(--color-surface,245 245 245))"
        aria-hidden="true"
      >
        <svg
          class="size-10"
          style="color:rgb(var(--color-muted,153 153 153))"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="3" width="18" height="18" rx="2"></rect>
          <circle cx="9" cy="9" r="2"></circle>
          <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
        </svg>
      </div>
    )}
    {showSaleBadge && (
      <span
        class="absolute left-2 top-2 inline-flex h-6 items-center rounded-[16px] bg-[rgb(var(--color-accent,227_142_159))] px-1.5 font-inter text-[12px] font-normal leading-none !text-white"
      >
        Скидка
      </span>
    )}
  </a>
    {/* Сердце избранного (overlay top-right). data-product-id ловит глобальный
        делегат initWishlistUI: toggle + перерисовка состояния (filled/outline +
        aria-pressed). Начальное состояние ставит делегат на page-load (SSG рендер
        без window — рисуем outline-сердце по умолчанию). z-20 поверх фото/бейджа.
        Скруглённая bloom-кнопка (rounded-full) — манера темы. */}
    <button
      type="button"
      data-wishlist-toggle
      data-product-id={product.id}
      aria-pressed="false"
      aria-label="В избранное"
      class="absolute right-2 top-2 z-20 flex size-9 items-center justify-center rounded-full bg-white/90 text-[rgb(var(--color-text,0_0_0))] shadow-[0_2px_8px_rgba(0,0,0,0.10)] backdrop-blur-sm transition-opacity hover:opacity-80"
    >
      <span data-wishlist-icon class="block size-[18px]" set:html={defaultHeartSvg}></span>
    </button>
  </div>
  <div class="flex w-full flex-col gap-2 text-left">
    <a
      href={href}
      class="bloom-product-name block w-full font-inter text-[16px] font-light leading-none text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70"
    >
      {product.name}
    </a>
    <div class="flex w-full flex-wrap items-baseline gap-2">
      <span class="bloom-product-price font-inter text-[16px] font-light leading-none text-[rgb(var(--color-text,0_0_0))]">
        {product.price}
      </span>
      {product.oldPrice && (
        <span class="bloom-product-oldprice font-inter text-[16px] font-light leading-none text-[rgb(var(--color-muted,153_153_153))] line-through">
          {product.oldPrice}
        </span>
      )}
    </div>
  </div>
  {/* Быстрое действие (настройка «Быстрое добавление»). Кнопка СНАРУЖИ <a>
      (button-in-anchor — невалидный HTML). Зеркалит client renderCardHtml. */}
  {showQuickAdd && (
    <button type="button" data-quick-add-id={product.id} style={quickBtnStyle}>
      {quickAddText}
    </button>
  )}
</article>

<style>
  /* Figma 375: name/price — Inter 12 на узких экранах */
  @media (max-width: 639.98px) {
    .bloom-product-name,
    .bloom-product-price,
    .bloom-product-oldprice {
      font-size: 12px !important;
    }
  }
</style>
