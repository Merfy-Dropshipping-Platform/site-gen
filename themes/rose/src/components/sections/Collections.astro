---
import NtSectionHeading from "../ui/RoseSectionHeading.astro";
import { resolveRoseHeadingSize, roseHeadingStyle } from "../../lib/heading-size";

// ОЖИВЛЕНИЕ: конструкторная схема Collections (heading/subtitle). Тело + данные verbatim.
// T13: полная канон-схема (headingSize/subtitleSize/titleAlignment/columns/imageView/
// collections[]/cardLinkBase/padding). Дефолтные ветки тернарников = прежние строки
// классов байт-в-байт; канон-дефолты конструктора (medium/small/center/3/square) →
// пиксель верстальщика (прецедент T11 'center').
const p = Astro.props as Record<string, any>;
const id = p.id;
// Figma 1:19335 — ПУСТОЕ состояние секции «Список коллекций»: дословный заголовок
// «Список коллекций» (без подзаголовка), а НЕ дефолт-копирайт верстальщика
// («Коллекции, которые становятся любимыми» / «Вдохновение для каждого дня…»).
// Мерчант задал свой heading/subtitle → его и рендерим.
const sectionTitle = p.heading ?? "Список коллекций";
const sectionSubtitle = p.subtitle ?? "";

// Канон headingSize: top-level приоритетнее legacy heading.size. Локальные
// inline-переменные гарантированно попадают в compiled CSS bridge.
const headingSize = resolveRoseHeadingSize(p.headingSize, p.heading?.size, "top-level");
const headingSizeStyle = roseHeadingStyle("collections", headingSize);
// Канон subtitleSize: 'small' (canon-default) и отсутствие = 16px верстальщика.
// Desktop — утилита [&_p]:!text-[ (работает на десктопе); мобиле — через
// --size-section-text-m (её читает #collections-title ~ p в <style> ниже),
// иначе ID-правило держало 12px и слайдер на мобиле игнорировался.
const subtitleSizeCls =
	p.subtitleSize === "medium"
		? " [&_p]:!text-[19px] [--size-section-text-m:19px]"
		: p.subtitleSize === "large"
			? " [&_p]:!text-[23px] [--size-section-text-m:23px]"
			: "";
// Канон titleAlignment: 'center'/отсутствие = строка верстальщика байт-в-байт.
const headWrapBase = `flex w-full justify-center md:justify-center${subtitleSizeCls}`;
const headWrapCls =
	p.titleAlignment === "left"
		? `flex w-full justify-start [&_[data-nt=section-heading]]:items-start [&_h2]:!text-left [&_p]:!text-left${subtitleSizeCls}`
		: p.titleAlignment === "right"
			? `flex w-full justify-end [&_[data-nt=section-heading]]:items-end [&_h2]:!text-right [&_p]:!text-right${subtitleSizeCls}`
			: headWrapBase;

// Канон columns 1-6: 3 (canon-default = md:grid-cols-3 верстальщика) и отсутствие →
// дефолт-ветка; иное значение → inline-var на гриде, действует с lg (md-лестница
// верстальщика 1→3 сохраняется).
const colsRaw = typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : undefined;
const cols = colsRaw && colsRaw !== 3 ? colsRaw : undefined;
// Канон imageView: 'portrait' (== литерал верстальщика 430/500, canon-default,
// поле скрыто в панели) → дефолт-ветка (вид НЕ меняется); 'square' → 1:1;
// 'wide' → 16/9. Перекрытие — на li>a>div (prop-карточки) и li>div>div
// (плейсхолдер-плитки пустого состояния), специфичность > базового
// aspect-[430/500].
const tileAspectCls =
	p.imageView === "wide"
		? " [&_li>a>div]:aspect-[16/9] [&_li>div>div]:aspect-[16/9]"
		: p.imageView === "square"
			? " [&_li>a>div]:aspect-[1/1] [&_li>div>div]:aspect-[1/1]"
			: "";
// Gap-лестница верстальщика — едина для всех. Колонки: дефолт (3/пусто) =
// лестница верстальщика 1→3 (моб→планшет+); заданное значение применяется уже
// с ПЛАНШЕТА (md), а не только с lg. Раньше md жёстко держал grid-cols-3 →
// на планшете (768-1023px) и в превью конструктора слайдер игнорировался и
// показывал 3 при любом выборе. Моб (<md) всегда 1 — узкие карточки.
const gridGap = "grid grid-cols-1 gap-6 sm:gap-5 md:gap-5 lg:gap-6";
const gridColsCls = cols
	? "md:grid-cols-[repeat(var(--cols),minmax(0,1fr))]"
	: "md:grid-cols-3";
const gridCls = `${gridGap} ${gridColsCls}${tileAspectCls}`;
const gridStyle = cols ? `--cols:${cols}` : undefined;

// Канон collections[] (≤10): карточки из пропса при непустом массиве (название/
// картинка/ссылка по shape схемы; плоский <img> как в гидрации; без картинки —
// surface-плитка как канон-плейсхолдер). Иначе — пустое состояние (Figma 1:19335):
// плейсхолдер-плитки DEMO_COLLECTIONS ниже, НЕ мок-демо верстальщика.
// SSR рендерит сохранённые поля item,
// резолв collectionId→имя/обложка делает гидрация ниже (data-collection-ref):
// live — /data/collections.json, превью — storefront-data; паритет theme-base
// (имя коллекции перебивает ручной heading, обложка — при пустой своей).
const cardLinkBase =
	typeof p.cardLinkBase === "string" && p.cardLinkBase.trim() ? p.cardLinkBase : "/catalog?collection=";
const propCollections = (Array.isArray(p.collections) ? p.collections : [])
	.filter((c: any) => c && typeof c === "object")
	.slice(0, 10)
	.map((c: any, i: number) => {
		const collectionId =
			typeof c.collectionId === "string" && c.collectionId.trim() ? c.collectionId.trim() : null;
		return {
			collectionId,
			name:
				(typeof c.heading === "string" && c.heading) ||
				(typeof c.name === "string" && c.name) ||
				"Коллекция",
			// Плейсхолдер пустого состояния (Figma 1:19335): карточка без выбранной
			// картинки = ПУСТАЯ surface-плитка (НЕ мок-фото верстальщика). На live
			// гидрация (data-collection-ref) подставит реальное фото коллекции.
			image:
				typeof c.image === "string" && c.image
					? c.image
					: "",
			hasOwnImage: !!(typeof c.image === "string" && c.image),
			href: collectionId ? `${cardLinkBase}${collectionId}` : "#",
		};
	});
const usePropCollections = propCollections.length > 0;

// SSR-резолв реальных коллекций по collectionId (Figma-цель: коллекция ВЫБРАНА →
// реальное имя/обложка ПРЯМО в статике, чтобы их видело и ПРЕВЬЮ конструктора —
// Astro Container не исполняет клиентскую module-гидрацию ниже). Эталон —
// rose Popular.astro (siteId инжектит рендер-пайплайн preview.service / build).
// Нет siteId / выбранных collectionId / ошибка → resolved пуст → остаётся SSR
// (heading/обложка из пропса), а живая гидрация ниже освежит данные на live.
// Паритет theme-base resolveManual: имя коллекции перебивает ручной heading,
// обложка коллекции подставляется только при пустой своей (hasOwnImage).
const siteId = typeof p.siteId === "string" ? p.siteId : "";
const wantResolve = usePropCollections && propCollections.some((c) => c.collectionId);
const resolvedCols = new Map<string, { name?: string; image?: string }>();
if (wantResolve && siteId) {
	try {
		const base = (import.meta as any).env?.SITES_INTERNAL_BASE ?? "http://localhost:3114";
		const res = await fetch(`${base}/api/sites/${siteId}/storefront-data`).catch(() => null);
		if (res && res.ok) {
			const data: any = await res.json();
			const cols: any[] = Array.isArray(data?.collections) ? data.collections : [];
			for (const c of propCollections) {
				if (!c.collectionId) continue;
				const m = cols.find(
					(x) =>
						x &&
						(x.id === c.collectionId ||
							x.slug === c.collectionId ||
							x.name === c.collectionId ||
							x.handle === c.collectionId),
				);
				if (!m) continue;
				const cover =
					(typeof m.image === "string" && m.image) ||
					(Array.isArray(m.images) && typeof m.images[0] === "string" ? m.images[0] : "");
				resolvedCols.set(c.collectionId, {
					name: typeof m.name === "string" ? m.name : undefined,
					image: cover || undefined,
				});
			}
		}
	} catch {
		/* нет данных — остаётся SSR из пропса, гидрация освежит на live */
	}
}
// Применяем резолв к карточкам пропса: реальное имя перебивает ручной heading,
// обложка — только если мерчант не загрузил свою.
const resolvedCollections = propCollections.map((c) => {
	const r = c.collectionId ? resolvedCols.get(c.collectionId) : undefined;
	if (!r) return c;
	return {
		...c,
		name: r.name || c.name,
		image: c.hasOwnImage ? c.image : r.image || c.image,
	};
});

// Канон пустого состояния (Figma 1:19335, паритет theme-base DEMO_COLLECTIONS):
// без ручного выбора — 3 ПЛЕЙСХОЛДЕР-карточки (пустая surface-плитка #FBFBFB +
// подпись «Коллекция»), НЕ мок-демо верстальщика (RIVIERA/URBAN/FUTURISM из
// data/collections.ts). При наличии реальных коллекций магазина JS-autofill
// (data-collections-autofill ниже) подменяет их живыми данными.
const DEMO_COLLECTIONS = [
	{ name: "Коллекция" },
	{ name: "Коллекция" },
	{ name: "Коллекция" },
];

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id="collections"
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-14 pt-14 sm:px-5 sm:pb-16 sm:pt-16 md:px-10 md:pb-[100px] md:pt-[100px] lg:px-16 lg:pb-[120px] lg:pt-[120px] xl:px-20 xl:pb-[140px] xl:pt-[140px] 2xl:px-[280px]"
	aria-labelledby="collections-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-8 md:gap-10">
		<div class={headWrapCls} style={headingSizeStyle} data-animate data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">
			<NtSectionHeading variant="rose" titleId="collections-title" title={sectionTitle} subtitle={sectionSubtitle} />
		</div>

		<ul
			data-animate
			data-animate-delay="0.1s"
			class={gridCls}
			role="list"
			style={gridStyle}
			data-collections-autofill={!usePropCollections ? "" : undefined}
		>
			{usePropCollections ? resolvedCollections.map((c, i) => (
				<li>
					<a
						href={c.href}
						class="group flex w-full cursor-pointer flex-col gap-5"
						aria-label={c.name}
						data-nt="rose-collection-card"
						data-collection-ref={c.collectionId ?? undefined}
						data-own-image={c.hasOwnImage ? "true" : undefined}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="collections"
					>
						<div class="aspect-[430/500] w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))]" aria-hidden={c.image ? undefined : "true"}>
							{c.image && (
								<img
									src={c.image}
									alt={c.name}
									loading="lazy"
									class="!h-full !w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.08]"
								/>
							)}
						</div>
						<h3 class="rose-collection-name w-full text-left font-manrope !text-[16px] font-normal !leading-none tracking-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity group-hover:opacity-70 max-sm:!text-[12px]">
							{c.name}
						</h3>
					</a>
				</li>
			)) : DEMO_COLLECTIONS.map((collection) => (
				<li>
					<div
							class="group flex w-full flex-col gap-5"
							aria-label={collection.name}
							data-nt="rose-collection-card"
						>
							<div class="aspect-[430/500] w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,251_251_251))]" aria-hidden="true"></div>
							<h3 class="rose-collection-name w-full text-left font-manrope !text-[16px] font-normal !leading-none tracking-normal text-[rgb(var(--color-text,0_0_0))] max-sm:!text-[12px]">
								{collection.name}
							</h3>
						</div>
				</li>
			))}
		</ul>
	</div>
</section>

<script>
	import { loadRealCollections, findCollection, escapeHtml } from "../../lib/storefront-hydrate";

	// Резолв collectionId→имя/обложка на карточках (data-collection-ref).
	// Паритет theme-base resolveManual: имя коллекции перебивает ручной heading;
	// обложка коллекции подставляется, только если мерчант не загрузил свою
	// (data-own-image). Без данных (demo-сборка) — no-op, SSG остаётся.
	const hydrateCollectionTiles = async () => {
		const tiles = Array.from(
			document.querySelectorAll<HTMLElement>('[data-nt="rose-collection-card"][data-collection-ref]'),
		);
		if (tiles.length === 0) return;
		const collections = await loadRealCollections();
		if (!collections) return;
		for (const tile of tiles) {
			const col = findCollection(collections, tile.getAttribute("data-collection-ref"));
			if (!col) continue;
			if (col.name) {
				const h3 = tile.querySelector(".rose-collection-name");
				if (h3 && h3.textContent !== col.name) h3.textContent = col.name;
				tile.setAttribute("aria-label", col.name);
			}
			const cover = col.image || (Array.isArray(col.images) ? col.images[0] : "");
			if (cover && tile.getAttribute("data-own-image") !== "true") {
				const img = tile.querySelector("img");
				if (img && img.getAttribute("src") !== cover) {
					img.setAttribute("src", cover);
					if (col.name) img.setAttribute("alt", col.name);
				}
			}
		}
	};

	// АВТОПОДСТАНОВКА: пустой пикер (SSR = плейсхолдер-плитки «Коллекция») → реальные
	// коллекции магазина из /data/collections.json (live) / storefront-data (превью).
	// Прежде показывались фейк-демо FUTURISM/RIVIERA/URBAN, что вводило в заблуждение
	// («магазин показывает несуществующие коллекции»). Коллекций мало (curated по сути
	// сохраняется: явный выбор в пикере имеет приоритет), потому подставляем все ≤6.
	// Реальных нет (demo-сборка без collections.json) → no-op, плейсхолдеры остаются.
	// Обложка: ТОЛЬКО своя картинка коллекции; без неё — пустая surface-плитка
	// (контракт Figma 1:19335), а НЕ мок-путь /images/Коллекция_N.webp (нет в dist).
	const autofillCollections = async () => {
		const grids = Array.from(document.querySelectorAll<HTMLElement>("ul[data-collections-autofill]"));
		if (grids.length === 0) return;
		const collections = await loadRealCollections();
		if (!collections || collections.length === 0) return;
		const visible = collections.filter((c) => c && c.slug !== "general").slice(0, 6);
		if (visible.length === 0) return;
		const html = visible
			.map((c) => {
				const name = escapeHtml(c.name || "Коллекция");
				const ref = c.slug || c.id || "";
				const href = "/catalog?collection=" + encodeURIComponent(ref);
				// Обложка ТОЛЬКО своя картинка коллекции; нет своей → пустая surface-плитка
				// (контракт Figma 1:19335, гард как у SSR-карточки), а НЕ мок-путь верстальщика
				// /images/Коллекция_N.webp — таких файлов нет в dist (битый <img>).
				const cover = c.image || (Array.isArray(c.images) ? c.images[0] : "");
				// Картинка только при наличии своей обложки (гард как у SSR-карточки),
				// иначе пустая surface-плитка #FBFBFB без <img> — контракт пустого состояния.
				const media = cover
					? `<img src="${escapeHtml(cover)}" alt="${name}" loading="lazy" class="!h-full !w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.08]" />`
					: "";
				const surfaceBg = cover ? "245_245_245" : "251_251_251";
				return `<li><a href="${href}" class="group flex w-full cursor-pointer flex-col gap-5" aria-label="${name}" data-nt="rose-collection-card">
		<div class="aspect-[430/500] w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,${surfaceBg}))]"${cover ? "" : ' aria-hidden="true"'}>${media}</div>
		<h3 class="rose-collection-name w-full text-left font-manrope !text-[16px] font-normal !leading-none tracking-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity group-hover:opacity-70 max-sm:!text-[12px]">${name}</h3>
	</a></li>`;
			})
			.join("");
		for (const grid of grids) grid.innerHTML = html;
	};

	hydrateCollectionTiles();
	autofillCollections();
	document.addEventListener("astro:page-load", () => {
		hydrateCollectionTiles();
		autofillCollections();
	});
</script>

<style>
	/* NtSectionHeading из DS не пробрасывает class на h2/p — размер заголовка читаем
	   из локальной переменной на обёртке. ID-правило перебивает утилиту !text-[20px] на h2. */
	:global(#collections-title) {
		font-size: var(--collections-heading-size, 20px) !important;
	}

	/* Figma 375: section title Comfortaa 14, subtitle Manrope 12. NtSectionHeading не пробрасывает class на h2/p. */
	@media (max-width: 639.98px) {
		:global(#collections-title) {
			font-size: var(--collections-heading-size-mobile, 14px) !important;
			line-height: 1 !important;
		}

		:global(#collections-title ~ p) {
			font-size: var(--size-section-text-m, 12px) !important;
			line-height: 1.4 !important;
			max-width: 100% !important;
			width: 100% !important;
			padding-inline: 0 !important;
		}

		/* Растягиваем контейнер NtSectionHeading на всю доступную ширину */
		:global([data-nt="section-heading"]) {
			max-width: 100% !important;
			width: 100% !important;
		}
	}
</style>
