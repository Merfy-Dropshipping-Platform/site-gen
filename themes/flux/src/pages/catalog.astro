---
import Layout from "../layouts/Layout.astro";
import FluxProductCard from "../components/products/FluxProductCard.astro";
import NtFilterSidebar from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtFilterSidebar.astro";
import NtFilterPanel from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtFilterPanel.astro";
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { catalogProducts } from "../data/products";

const totalCount = catalogProducts.length;
---

<Layout title="Каталог" description="Каталог Flux — коллекции, хиты, новинки">
	<section
		class="w-full bg-white px-4 pb-[80px] pt-10 md:px-20 md:pb-[120px] md:pt-16 2xl:px-[300px]"
		aria-labelledby="catalog-title"
		data-catalog-layout="top"
	>
		{/* Раскладку каталога выбирает настройка конструктора: платформа (превью
		    и билд) инжектит window.__MERFY_CATALOG_LAYOUT__. Скрипт стоит ДО
		    рендера вариантов, чтобы переключение прошло без мигания; нет
		    глобала → остаётся родной вид flux ('top'). */}
		<script is:inline>var l=window.__MERFY_CATALOG_LAYOUT__; if(l==='top'||l==='side'){document.currentScript.parentElement.setAttribute('data-catalog-layout',l);}</script>
		<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-10">
			<header class="flex flex-col gap-2">
				<h1
					id="catalog-title"
					class="font-comfortaa text-[28px] font-normal uppercase leading-[1.115] text-[#000000] md:text-[32px] lg:text-[36px]"
				>
					КАТАЛОГ
				</h1>
				<p class="font-manrope text-[16px] font-light leading-[1.366] text-[#999999] md:text-[18px] lg:text-[20px]">
					Следующее поколение уже с вами
				</p>
			</header>

			{/* Раскладка 'top' — фильтры/сортировка строкой над гридом (родной вид flux). */}
			<div class="flex flex-col gap-6" data-catalog-variant="top">
				<div class="flex flex-wrap items-center justify-between gap-3" data-nt="catalog-filters">
					<div class="flex flex-wrap items-start gap-3">
						<details class="relative">
							<summary class="flex h-10 min-w-[180px] cursor-pointer list-none items-center justify-between gap-2 rounded-[6px] border border-[rgb(var(--color-muted,153_153_153)/0.1)] bg-[rgb(var(--color-surface,255_255_255))] px-3 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span>Наличие</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-5" class="transition-transform group-open:rotate-180" />
							</summary>
							<div class="absolute left-0 top-full z-10 mt-1 w-full">
								<NtFilterPanel panel="stock" />
							</div>
						</details>

						<details class="relative">
							<summary class="flex h-10 min-w-[180px] cursor-pointer list-none items-center justify-between gap-2 rounded-[6px] border border-[rgb(var(--color-muted,153_153_153)/0.1)] bg-[rgb(var(--color-surface,255_255_255))] px-3 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span>Стоимость</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-5" class="transition-transform group-open:rotate-180" />
							</summary>
							<div class="absolute left-0 top-full z-10 mt-1 w-full">
								<NtFilterPanel panel="price" />
							</div>
						</details>

						<details class="relative">
							<summary class="flex h-10 min-w-[180px] cursor-pointer list-none items-center justify-between gap-2 rounded-[6px] border border-[rgb(var(--color-muted,153_153_153)/0.1)] bg-[rgb(var(--color-surface,255_255_255))] px-3 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span>Цвет</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-5" class="transition-transform group-open:rotate-180" />
							</summary>
							<div class="absolute left-0 top-full z-10 mt-1 w-full">
								<NtFilterPanel panel="color" />
							</div>
						</details>

						{/* Фильтр по коллекциям: скрыт на demo-сборке, гидрация показывает
						    его при наличии коллекций магазина и уважает ?collection= из
						    ссылок тайлов Collections. Манера = бордерные details-кнопки выше,
						    панель опций — в стиле NtFilterPanel. */}
						<details class="relative" data-nt="catalog-collections-filter" style="display:none;">
							<summary class="flex h-10 min-w-[180px] cursor-pointer list-none items-center justify-between gap-2 rounded-[6px] border border-[rgb(var(--color-muted,153_153_153)/0.1)] bg-[rgb(var(--color-surface,255_255_255))] px-3 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span data-collections-label>Коллекции</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-5" class="transition-transform group-open:rotate-180" />
							</summary>
							<div class="absolute left-0 top-full z-10 mt-1 w-full">
								<ul data-collections-options class="m-0 flex w-full list-none flex-col gap-2 rounded-[6px] border border-[rgb(var(--color-muted,153_153_153)/0.1)] bg-[rgb(var(--color-surface,255_255_255))] p-3 font-manrope text-[14px] font-normal leading-normal"></ul>
							</div>
						</details>
					</div>

					<details class="relative">
						<summary class="flex h-10 min-w-[180px] cursor-pointer list-none items-center justify-end gap-2 rounded-[6px] bg-[rgb(var(--color-surface,255_255_255))] px-3 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
							<span>По популярности</span>
							<NtIcon name="dropdown-chevron" sizeClass="size-5" />
						</summary>
						<div class="absolute right-0 top-full z-10 mt-1 w-[180px]">
							<NtFilterPanel panel="sort" />
						</div>
					</details>
				</div>

				<ul
					class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4"
					role="list"
					data-nt="catalog-grid"
				>
					{catalogProducts.map((product) => (
						<li data-product-id={product.id}>
							<FluxProductCard product={product} />
						</li>
					))}
				</ul>

				<div class="flex flex-wrap items-center justify-between gap-4">
					<button
						type="button"
						data-action="load-more"
						class="inline-flex h-12 items-center justify-center rounded-[6px] bg-[#000000] px-4 font-manrope text-[14px] font-normal leading-normal text-white transition-opacity hover:opacity-95 md:text-[16px]"
					>
						Смотреть ещё
					</button>
					<span class="font-manrope text-[14px] font-normal leading-normal text-[#999999]" data-nt="catalog-count">
						{totalCount} товаров
					</span>
				</div>
			</div>

			{/* Раскладка 'side' — левый сайдбар с фильтрами; включается настройкой
			    конструктора (data-catalog-layout="side" на section). */}
			<div class="flex flex-col gap-8 lg:flex-row lg:gap-10" data-catalog-variant="side">
				<div class="hidden w-[172px] shrink-0 flex-col gap-4 lg:flex xl:w-[294px]">
					<NtFilterSidebar class="hidden w-[172px] shrink-0 lg:flex xl:w-[294px]" />

					{/* Коллекции 1:1 с секциями NtFilterSidebar: тот же контейнер
					    (p-3/gap-3/rounded-8, без подложки), тот же заголовок 16px и
					    строки-радио в манере NtRadioField (кружок рисует гидрация +
					    <style is:global> ниже); сам DS-компонент не трогаем — секция
					    рядом с ним. Скрыта на demo-сборке, гидрация показывает при
					    наличии коллекций. */}
					<div
						data-nt="catalog-collections-filter"
						style="display:none;"
						class="flex w-full flex-col gap-3 rounded-[8px] p-3 font-manrope"
					>
						<p class="text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))]">Коллекции</p>
						<ul data-collections-options class="m-0 flex w-full list-none flex-col gap-3 p-0 font-manrope text-[16px] font-normal leading-normal"></ul>
					</div>
				</div>

				<div class="flex flex-1 flex-col gap-8">
					<ul
						class="grid grid-cols-2 gap-4 sm:grid-cols-3"
						role="list"
						data-nt="catalog-grid"
					>
						{catalogProducts.map((product) => (
							<li data-product-id={product.id}>
								<FluxProductCard product={product} />
							</li>
						))}
					</ul>

					<div class="flex flex-wrap items-center justify-between gap-4">
						<button
							type="button"
							data-action="load-more"
							class="inline-flex h-12 items-center justify-center rounded-[6px] bg-[#000000] px-4 font-manrope text-[14px] font-normal leading-normal text-white transition-opacity hover:opacity-95 md:text-[16px]"
						>
							Смотреть ещё
						</button>
						<span class="font-manrope text-[14px] font-normal leading-normal text-[#999999]" data-nt="catalog-count">
							{totalCount} товаров
						</span>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style is:global>
	/* Переключение раскладок каталога: в HTML запечены обе, видимой остаётся
	   только активная по data-catalog-layout на section. */
	[data-catalog-layout="top"] [data-catalog-variant="side"] {
		display: none;
	}
	[data-catalog-layout="side"] [data-catalog-variant="top"] {
		display: none;
	}

	/* ——— Токены цветовых схем в зонах фильтров ———
	   DS-компоненты (node_modules) не правим — переопределяем снаружи по
	   стабильным data-атрибутам/структуре из исходников DS. Фоллбеки = родные
	   цвета flux (#000 / #999 / #FFF / #F5F5F5 ≈ muted 10% на белом), поэтому
	   без схемы вид не меняется ни на пиксель. */

	/* Top-вид: открытые панели NtFilterPanel — поверхность и бордер на токенах. */
	[data-catalog-variant="top"] [data-nt="filter-panel"] {
		background-color: rgb(var(--color-surface, 255 255 255));
		border-color: rgb(var(--color-muted, 153 153 153) / 0.1);
	}
	/* Опции панелей: первая (активная) — основной цвет текста, остальные приглушены. */
	[data-catalog-variant="top"] [data-nt="filter-panel"] > p {
		color: rgb(var(--color-muted, 153 153 153));
	}
	[data-catalog-variant="top"] [data-nt="filter-panel"] > p:first-of-type {
		color: rgb(var(--color-text, 0 0 0));
	}
	/* Строки «от/до» панели «Стоимость»: верхняя — основной цвет, нижняя — приглушённый. */
	[data-catalog-variant="top"] [data-nt="filter-price-rows"] > div:first-child {
		color: rgb(var(--color-text, 0 0 0));
		border-color: rgb(var(--color-text, 0 0 0));
	}
	[data-catalog-variant="top"] [data-nt="filter-price-rows"] > div:last-child {
		color: rgb(var(--color-muted, 153 153 153));
		border-color: rgb(var(--color-muted, 153 153 153));
	}

	/* Side-вид: DS-сайдбар рисует собственную белую подложку (bg-[#FFFFFF] на
	   aside) — снимаем, чтобы фильтры лежали прямо на фоне страницы. */
	[data-catalog-variant="side"] [data-nt="filter-sidebar"] {
		background: transparent;
	}
	/* Заголовки секций сайдбара. */
	[data-catalog-variant="side"] [data-nt="filter-sidebar"] > div > p {
		color: rgb(var(--color-text, 0 0 0));
	}
	/* Радио NtRadioField: кружок, точка и подпись на токенах. */
	[data-catalog-variant="side"] [data-nt="radio-field"] > span[aria-hidden="true"] {
		border-color: rgb(var(--color-muted, 153 153 153));
	}
	[data-catalog-variant="side"] [data-nt="radio-field"] > span[aria-hidden="true"]::after {
		background-color: rgb(var(--color-text, 0 0 0));
	}
	[data-catalog-variant="side"] [data-nt="radio-field"] > input:checked + span[aria-hidden="true"] {
		border-color: rgb(var(--color-text, 0 0 0));
	}
	[data-catalog-variant="side"] [data-nt="radio-field"] > input:focus-visible + span[aria-hidden="true"] {
		outline-color: rgb(var(--color-text, 0 0 0));
	}
	[data-catalog-variant="side"] [data-nt="radio-field"] > span:not([aria-hidden]) {
		color: rgb(var(--color-muted, 153 153 153));
	}
	[data-catalog-variant="side"] [data-nt="radio-field"] > input:checked ~ span:not([aria-hidden]) {
		color: rgb(var(--color-text, 0 0 0));
	}
	/* Строки «от/до» в сайдбаре: обе приглушённые (как в DS). */
	[data-catalog-variant="side"] [data-nt="filter-price-rows"] > div {
		color: rgb(var(--color-muted, 153 153 153));
		border-color: rgb(var(--color-muted, 153 153 153));
	}

	/* Опции «Коллекции» (заполняет гидрация в обеих раскладках): активная и
	   hover — основной цвет, остальные приглушённые — как опции NtFilterPanel. */
	[data-catalog-variant] [data-collection-option] {
		color: rgb(var(--color-muted, 153 153 153));
	}
	[data-catalog-variant] [data-collection-option]:hover,
	[data-catalog-variant] [data-collection-option][data-active] {
		color: rgb(var(--color-text, 0 0 0));
	}
	/* Радио-кружок опций в сайдбаре — 1:1 с NtRadioField (24px, бордер 2px,
	   точка 10px; неактивный — muted, активный — основной цвет). */
	[data-catalog-variant="side"] [data-collection-option] [data-radio-dot] {
		position: relative;
		display: flex;
		width: 24px;
		height: 24px;
		flex-shrink: 0;
		align-items: center;
		justify-content: center;
		border: 2px solid rgb(var(--color-muted, 153 153 153));
		border-radius: 9999px;
	}
	[data-catalog-variant="side"] [data-collection-option] [data-radio-dot]::after {
		content: "";
		position: absolute;
		width: 10px;
		height: 10px;
		border-radius: 9999px;
		background-color: rgb(var(--color-text, 0 0 0));
		opacity: 0;
	}
	[data-catalog-variant="side"] [data-collection-option][data-active] [data-radio-dot] {
		border-color: rgb(var(--color-text, 0 0 0));
	}
	[data-catalog-variant="side"] [data-collection-option][data-active] [data-radio-dot]::after {
		opacity: 1;
	}
</style>

<script>
	document.addEventListener("click", (event) => {
		const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-action='load-more']");
		if (!button) return;
		button.disabled = true;
		button.textContent = "Больше товаров нет";
		button.classList.add("opacity-60", "pointer-events-none");
	});
</script>

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		filterByCollection,
		renderCardHtml,
		escapeHtml,
		updateCount,
		type RealCollection,
	} from "../lib/storefront-hydrate";

	// Реальные товары (Option B): на published-сайте /data/products.json реальный →
	// перерисовываем demo-grid. На demo-сборке loadRealProducts() вернёт null → no-op.
	// Фильтр по коллекциям: ?collection= (slug/id из ссылок тайлов) + контейнеры
	// «Коллекции» обеих раскладок (дропдаун в row, секция в сайдбаре) —
	// заполняются из collections.json/storefront-data.
	let catalogCollections: RealCollection[] | null = null;

	function currentCollectionRef(): string | null {
		return new URLSearchParams(window.location.search).get("collection");
	}

	async function renderCatalog() {
		const products = await loadRealProducts();
		if (!products) return; // demo-сборка
		const ref = currentCollectionRef();
		const items = ref ? filterByCollection(products, catalogCollections, ref) : products;
		const html = items
			.map((p) => `<li data-product-id="${escapeHtml(p.id)}">${renderCardHtml(p)}</li>`)
			.join("");
		for (const grid of Array.from(document.querySelectorAll('[data-nt="catalog-grid"]'))) {
			grid.innerHTML = html;
		}
		updateCount('[data-nt="catalog-count"]', items.length);
	}

	async function initCollectionsFilter() {
		// Контейнеры обеих раскладок (row-дропдаун + секция сайдбара); каждый
		// гидрируем один раз — идемпотентность astro:page-load через data-cf-hydrated.
		const boxes = Array.from(
			document.querySelectorAll<HTMLElement>('[data-nt="catalog-collections-filter"]'),
		).filter((box) => box.getAttribute("data-cf-hydrated") !== "true");
		if (boxes.length === 0) return;
		catalogCollections = await loadRealCollections();
		if (!catalogCollections || catalogCollections.length === 0) return;
		const collections = catalogCollections;
		const ref = currentCollectionRef();
		const current = ref
			? collections.find((c) => c.id === ref || c.slug === ref || c.name === ref) ?? null
			: null;
		// Опции в манере темы: top-дропдаун — текстовые строки как в NtFilterPanel,
		// сайдбар — строки с радио-кружком 1:1 с NtRadioField. Активность хранится
		// в data-active; цвета и кружок — в <style is:global> на токенах схем.
		const optionHtml = (value: string, name: string, active: boolean, radio: boolean) =>
			`<li><button type="button" data-collection-option="${escapeHtml(value)}"${active ? " data-active" : ""} class="${radio ? "flex w-full cursor-pointer items-center gap-2 text-left transition-colors" : "w-full cursor-pointer text-left transition-colors"}">${radio ? '<span data-radio-dot aria-hidden="true"></span>' : ""}<span>${escapeHtml(name)}</span></button></li>`;
		// Выбор в любом контейнере синхронизирует активную опцию и подпись
		// дропдауна во ВСЕХ контейнерах (label есть только в row-дропдауне).
		const syncActive = (value: string, name: string | null) => {
			for (const box of boxes) {
				const label = box.querySelector<HTMLElement>("[data-collections-label]");
				if (label) label.textContent = name ?? "Коллекции";
				for (const b of Array.from(box.querySelectorAll<HTMLElement>("[data-collection-option]"))) {
					const on = (b.getAttribute("data-collection-option") ?? "") === value;
					if (on) b.setAttribute("data-active", "");
					else b.removeAttribute("data-active");
				}
			}
		};
		for (const box of boxes) {
			const list = box.querySelector<HTMLElement>("[data-collections-options]");
			if (!list) continue;
			box.setAttribute("data-cf-hydrated", "true");
			box.style.display = "";
			const label = box.querySelector<HTMLElement>("[data-collections-label]");
			if (label && current?.name) label.textContent = current.name;
			// Радио-вид — только в секции сайдбара (side-раскладка).
			const radio = box.closest('[data-catalog-variant="side"]') !== null;
			list.innerHTML =
				optionHtml("", "Все", !current, radio) +
				collections
					.map((c) => optionHtml(c.slug ?? c.id, c.name ?? "Коллекция", !!current && current.id === c.id, radio))
					.join("");
			list.addEventListener("click", (ev) => {
				const btn = (ev.target as HTMLElement).closest<HTMLElement>("[data-collection-option]");
				if (!btn) return;
				const value = btn.getAttribute("data-collection-option") ?? "";
				const params = new URLSearchParams(window.location.search);
				if (value) params.set("collection", value);
				else params.delete("collection");
				const qs = params.toString();
				window.history.replaceState({}, "", window.location.pathname + (qs ? `?${qs}` : ""));
				const col = collections.find((c) => (c.slug ?? c.id) === value) ?? null;
				syncActive(value, col?.name ?? null);
				box.removeAttribute("open"); // закрыть row-дропдаун; для секции сайдбара no-op
				renderCatalog();
			});
		}
	}

	async function hydrateCatalog() {
		await initCollectionsFilter();
		await renderCatalog();
	}

	hydrateCatalog();
	document.addEventListener("astro:page-load", hydrateCatalog);
</script>
