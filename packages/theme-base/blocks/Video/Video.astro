---
import type { VideoProps } from './Video.puckConfig';
import { VideoClasses as C } from './Video.classes';

interface Props extends VideoProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  padding,
} = Astro.props as Props;

// Accept legacy {text,size} heading envelope.
const heading = (() => {
  const h = raw.heading ?? (raw.content as { heading?: unknown } | undefined)?.heading;
  if (typeof h === 'string') return h || undefined;
  if (h && typeof h === 'object') {
    const o = h as { text?: string };
    return o.text || undefined;
  }
  return undefined;
})();

// Merchant uploads go through the constructor which currently writes
// video props as { video: { url, coverImage } } — older revisions used a
// top-level `videoUrl` string. Accept both shapes. Critical: reject
// `blob:` URLs (transient ObjectURLs created in the constructor's
// browser tab — they do not survive the page closing, so live storefront
// would 404). Falls back to the placeholder so merchant sees "Видео
// появится здесь" instead of a broken video element.
const videoObj = raw.video as { url?: string; coverImage?: string } | undefined;
const rawVideoUrl = typeof videoObj?.url === 'string'
  ? videoObj.url
  : typeof raw.videoUrl === 'string'
    ? (raw.videoUrl as string)
    : '';
const videoUrl = rawVideoUrl.startsWith('blob:') ? '' : rawVideoUrl;
const poster = (videoObj?.coverImage as string | undefined) ?? (raw.poster as string | undefined) ?? undefined;

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
const colorSchemeRaw = typeof raw.colorScheme === 'string' ? raw.colorScheme : undefined;
const schemeClass = colorSchemeRaw ? `color-scheme-${colorSchemeRaw.replace('scheme-', '')}` : '';

// `position=fullscreen` removes the container clamp so video spans the
// viewport. Default contained → merchants get Figma-style padded video.
const positionProp = typeof raw.position === 'string' ? raw.position : 'contained';

// Pupa parity: size, overlay, content.heading.{alignment,enabled,size}.
const sizeProp = typeof raw.size === 'string' ? raw.size : 'medium';
const overlayPctRaw = typeof raw.overlay === 'number' ? raw.overlay : 0;
const overlayPct = overlayPctRaw / 100;
const overlayStyle = overlayPctRaw > 0
  ? `background-color: rgb(var(--color-foreground) / ${overlayPct});`
  : '';

const contentObj = raw.content as { heading?: { text?: string; alignment?: string; enabled?: string; size?: string } } | undefined;
const headingAlignment = contentObj?.heading?.alignment;
const headingEnabled = contentObj?.heading?.enabled !== 'false';
const headingSize = contentObj?.heading?.size;
const headingAlignClass =
  headingAlignment === 'left' ? 'text-left' :
  headingAlignment === 'right' ? 'text-right' :
  headingAlignment === 'center' ? 'text-center' : '';
const headingSizeClass =
  headingSize === 'large' ? 'text-3xl md:text-4xl' :
  headingSize === 'medium' ? 'text-2xl md:text-3xl' :
  headingSize === 'small' ? 'text-xl md:text-2xl' : '';

const sizeClass =
  sizeProp === 'small' ? 'aspect-[16/8]' :
  sizeProp === 'medium' ? 'aspect-video' :
  sizeProp === 'large' ? 'aspect-[16/10]' : '';
// 084 vanilla pilot: additive `align` and `padded` variants. When set,
// they take precedence over the legacy `position` prop. Defaults preserve
// pre-084 behaviour: `align` falls back to position-derived clamp,
// `padded` only applies when explicitly false (no extra classes).
const alignProp =
  raw.align === 'fullbleed' || raw.align === 'container'
    ? (raw.align as 'fullbleed' | 'container')
    : undefined;
const paddedProp = typeof raw.padded === 'boolean' ? raw.padded : undefined;
const containerClass = alignProp
  ? C.align[alignProp]
  : positionProp === 'fullscreen'
    ? 'w-full'
    : C.container;

// Detect provider by URL. Return { kind, embedUrl } or null for self-hosted.
type Kind = 'youtube' | 'vimeo' | 'file';
function parseVideo(url: string): { kind: Kind; embedUrl: string } {
  if (!url) return { kind: 'file', embedUrl: '' };

  // YouTube: youtube.com/watch?v=<ID> or youtu.be/<ID>
  const ytMatch =
    url.match(/youtu\.be\/([A-Za-z0-9_-]{6,})/) ||
    url.match(/youtube\.com\/watch\?v=([A-Za-z0-9_-]{6,})/) ||
    url.match(/youtube\.com\/embed\/([A-Za-z0-9_-]{6,})/);
  if (ytMatch) {
    return { kind: 'youtube', embedUrl: `https://www.youtube.com/embed/${ytMatch[1]}` };
  }

  // Vimeo: vimeo.com/<ID>
  const vmMatch =
    url.match(/vimeo\.com\/(?:video\/)?(\d{6,})/) ||
    url.match(/player\.vimeo\.com\/video\/(\d{6,})/);
  if (vmMatch) {
    return { kind: 'vimeo', embedUrl: `https://player.vimeo.com/video/${vmMatch[1]}` };
  }

  return { kind: 'file', embedUrl: url };
}

const video = parseVideo(videoUrl);
---
{/*
  Live media slot: the inner player is hydrated at runtime from
  /api/sites/<siteId>/blocks/<blockId>/media so merchant uploads take
  effect without a rebuild or new revision. A build-time `videoUrl`
  (from revision props) still renders immediately as a fallback — useful
  for legacy revisions where no live slot exists yet.
*/}
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-media-slot="video"
  data-media-block-id={id}
  style={paddingStyle}
>
  <div class={containerClass}>
    {heading && <h2 class={C.heading}>{heading}</h2>}
    <div class={C.media} data-media-target>
      {video.kind === 'youtube' && (
        <iframe
          class={C.iframe}
          src={video.embedUrl}
          loading="lazy"
          allowfullscreen
          allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        ></iframe>
      )}
      {video.kind === 'vimeo' && (
        <iframe
          class={C.iframe}
          src={video.embedUrl}
          loading="lazy"
          allowfullscreen
          allow="autoplay; fullscreen; picture-in-picture"
        ></iframe>
      )}
      {video.kind === 'file' && video.embedUrl && (
        <>
          <video
            class={C.video}
            src={video.embedUrl}
            poster={poster}
            controls
            preload="metadata"
            playsinline
            data-media-video
          ></video>
          {/* 084 vanilla pilot: 44×44 white play overlay centered absolutely
              per Figma 1:18989. Native browser play indicator sits bottom-
              center which looked like "broken arc / spinner" off-center.
              Overlay shows when paused, hides on play. Click triggers play. */}
          <button
            type="button"
            class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-11 h-11 flex items-center justify-center text-white pointer-events-auto z-10 transition-opacity"
            aria-label="Воспроизвести видео"
            data-media-play-overlay
          >
            <svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
              <circle cx="22" cy="22" r="21" stroke="currentColor" stroke-width="1.5"/>
              <path d="M18 14L30 22L18 30Z" fill="currentColor"/>
            </svg>
          </button>
          <script is:inline>
            (() => {
              const wraps = document.querySelectorAll('[data-media-target]');
              wraps.forEach((wrap) => {
                const v = wrap.querySelector('video[data-media-video]');
                const btn = wrap.querySelector('[data-media-play-overlay]');
                if (!v || !btn) return;
                const hide = () => { btn.style.opacity = '0'; btn.style.pointerEvents = 'none'; };
                const show = () => { btn.style.opacity = '1'; btn.style.pointerEvents = 'auto'; };
                btn.addEventListener('click', (e) => { e.preventDefault(); v.play().catch(() => {}); });
                v.addEventListener('play', hide);
                v.addEventListener('pause', show);
                v.addEventListener('ended', show);
              });
            })();
          </script>
        </>
      )}
      {!video.embedUrl && (
        <div class={C.placeholder} aria-hidden="true" data-media-placeholder>
          <div class={C.placeholderIcon}>
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M8 5v14l11-7L8 5z"/>
            </svg>
          </div>
          <div class={C.placeholderText}>
            {rawVideoUrl.startsWith('blob:')
              ? 'Загрузите видео заново — предыдущая ссылка устарела'
              : 'Видео появится здесь'}
          </div>
        </div>
      )}
    </div>
  </div>
</section>
<script type="module" is:inline define:vars={{ blockId: id }}>
  // Live media hydrator: asks the sites API for the current URL for this
  // block and swaps the <video src>/placeholder in place. Runs once on
  // load; merchant uploading a new file in the constructor updates the
  // slot, and the next visit/refresh picks it up without any rebuild.
  (async function hydrateMediaSlot() {
    if (!blockId) return;
    const section = document.querySelector(
      `section[data-media-slot="video"][data-media-block-id="${blockId}"]`
    );
    if (!section) return;
    const target = section.querySelector('[data-media-target]');
    if (!target) return;
    // Derive siteId from the current hostname prefix. Storefronts are
    // served at <shortId>.merfy.ru where the short id matches the
    // site.tenantId-derived slug. The API accepts the site UUID, so we
    // need to resolve short → UUID first via /api/sites/resolve.
    // Optimization: the server already knows the site at render time —
    // expose it on window.__MERFY__ if present, fall back to the resolver.
    const siteId = (window.__MERFY__ && window.__MERFY__.siteId) || null;
    if (!siteId) return;
    try {
      const res = await fetch(
        `https://gateway.merfy.ru/api/sites/${siteId}/blocks/${encodeURIComponent(blockId)}/media`,
        { credentials: 'omit' }
      );
      if (!res.ok) return;
      const data = await res.json();
      if (!data || typeof data.url !== 'string' || !data.url) return;
      const existingVideo = target.querySelector('video[data-media-video]');
      if (existingVideo) {
        if (existingVideo.getAttribute('src') !== data.url) {
          existingVideo.setAttribute('src', data.url);
          existingVideo.load();
        }
        return;
      }
      // Replace placeholder with a real <video>.
      target.innerHTML = '';
      const v = document.createElement('video');
      v.className = 'absolute inset-0 h-full w-full object-cover';
      v.setAttribute('data-media-video', '');
      v.setAttribute('controls', '');
      v.setAttribute('preload', 'metadata');
      v.src = data.url;
      if (data.coverImage) v.poster = data.coverImage;
      target.appendChild(v);
    } catch { /* network — leave fallback */ }
  })();
</script>
