---
import type { CheckoutSubmitProps } from './CheckoutSubmit.puckConfig';
import { CheckoutSubmitClasses as C } from './CheckoutSubmit.classes';

interface Props extends CheckoutSubmitProps { id?: string; }
const { id, buttonText, buttonStyle, loadingText, successRedirectUrl, padding } = Astro.props as Props;
const paddingStyle = padding ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;` : '';
const cls = buttonStyle === 'outline' ? C.buttonOutline : buttonStyle === 'gradient' ? C.buttonGradient : C.buttonFill;
const initialLabel = buttonText.replace('{total}', '—');
---
<section
  class={C.root}
  data-puck-component-id={id}
  data-block="checkout-submit"
  style={paddingStyle}
>
  <div data-checkout-submit-error role="alert" hidden style="color:rgb(220 38 38);font-size:14px;margin-bottom:8px;"></div>
  <button type="button" class={cls} data-checkout-submit disabled>
    {initialLabel}
  </button>
</section>

<script is:inline define:vars={{ buttonText, loadingText, successRedirectUrl, blockId: id }}>
  (function () {
    // Spec 102 — свой корень через общий примитив ([data-block="checkout-submit"]
    // стоит на корневом <section>); button/error — section.querySelector. Поля
    // других чекаут-блоков читаются через document (cross-block, см. merfy-root-allow).
    var section = window.__merfyRoot(blockId) || document.querySelector('[data-block="checkout-submit"]'); // merfy-root-allow: page-singleton (один на странице), id undefined на live composed-странице
    if (!section) return;
    var button = section.querySelector('[data-checkout-submit]');
    var errorEl = section.querySelector('[data-checkout-submit-error]');
    if (!button) return;

    var state = {
      deliveryMethod: null,
      paymentMethod: 'bank_card',
      submitting: false,
      discountCents: 0,
    };

    function getApiBase() {
      return (window.__MERFY_CONFIG__ && window.__MERFY_CONFIG__.apiUrl) || 'https://gateway.merfy.ru/api';
    }
    function getShopId() {
      return (window.__MERFY_CONFIG__ && window.__MERFY_CONFIG__.shopId) || '';
    }
    function getCartId() {
      return (typeof localStorage !== 'undefined' && localStorage.getItem('merfy:cartId')) || '';
    }
    function getCartItems() {
      return (window.cartStore && typeof window.cartStore.getItems === 'function') ? window.cartStore.getItems() : [];
    }
    function getSubtotalCents() {
      var items = getCartItems();
      return items.reduce(function (sum, it) { return sum + (it.unitPriceCents || it.priceCents || 0) * (it.quantity || 1); }, 0);
    }
    function getDeliveryCents() {
      return state.deliveryMethod ? (state.deliveryMethod.costCents || 0) : 0;
    }
    function getDiscountCents() {
      return state.discountCents || 0;
    }
    function getTotalCents() {
      // Итог со скидкой: max(0, subtotal − discount + delivery).
      return Math.max(0, getSubtotalCents() - getDiscountCents() + getDeliveryCents());
    }
    function fmtRub(cents) {
      var rub = Math.round(cents / 100);
      return rub.toLocaleString('ru-RU') + '₽';
    }
    function getField(name) {
      var el = document.querySelector('[data-checkout-field="' + name + '"] input'); // merfy-root-allow: cross-block, поля Contact/Delivery форм, page-singleton checkout
      return el ? (el.value || '').trim() : '';
    }
    function getFiasId() {
      var f = document.querySelector('[data-checkout-delivery]'); // merfy-root-allow: cross-block, секция CheckoutDeliveryForm, page-singleton checkout
      return f ? (f.getAttribute('data-selected-city-fias-id') || '') : '';
    }

    function canSubmit() {
      if (state.submitting) return false;
      var items = getCartItems();
      if (items.length === 0) return false;
      if (!getShopId()) return false;
      if (!getField('email') || !getField('phone')) return false;
      if (!getField('city') || !getField('address')) return false;
      if (!state.deliveryMethod) return false;
      if (!state.paymentMethod) return false;
      return true;
    }

    function refresh() {
      var label = buttonText.replace('{total}', fmtRub(getTotalCents()));
      button.textContent = state.submitting ? loadingText : label;
      button.disabled = !canSubmit();
    }

    document.addEventListener('cart:updated', refresh);
    document.addEventListener('checkout:address-changed', refresh);
    document.addEventListener('checkout:discount-applied', function (e) {
      // Кнопка «Оформить — {total}» должна показывать сумму со скидкой.
      state.discountCents = (e && e.detail && e.detail.discountCents) || 0;
      refresh();
    });
    document.addEventListener('checkout:delivery-changed', function (e) {
      var d = e && e.detail;
      if (!d) return;
      state.deliveryMethod = {
        type: d.type,
        label: d.label,
        costCents: d.costCents || 0,
        tariffCode: d.tariffCode != null ? d.tariffCode : null,
        customTariffId: d.customTariffId || null,
        pickupPointId: d.pickupPointId || null,
        periodMin: d.periodMin != null ? d.periodMin : null,
        periodMax: d.periodMax != null ? d.periodMax : null,
      };
      refresh();
    });
    document.addEventListener('checkout:payment-method-changed', function (e) {
      var m = e && e.detail && e.detail.method;
      if (m) { state.paymentMethod = m; refresh(); }
    });

    ['email','phone','firstName','lastName','fullName','city','postalCode','address'].forEach(function (f) {
      var el = document.querySelector('[data-checkout-field="' + f + '"] input'); // merfy-root-allow: cross-block, поля Contact/Delivery форм, page-singleton checkout
      if (!el) return;
      el.addEventListener('input', refresh);
      el.addEventListener('change', refresh);
    });

    function showError(msg) {
      if (errorEl) { errorEl.hidden = false; errorEl.textContent = msg; }
    }
    function clearError() {
      if (errorEl) { errorEl.hidden = true; errorEl.textContent = ''; }
    }

    button.addEventListener('click', async function (e) {
      e.preventDefault();
      if (!canSubmit()) return;
      clearError();
      state.submitting = true;
      refresh();

      try {
        var apiBase = getApiBase();
        var cartId = (window.cartStore && window.cartStore.syncToServer) ? await window.cartStore.syncToServer() : getCartId();
        if (!cartId) throw new Error('Корзина пуста. Добавьте товары.');

        // Переприменить промокод на пересозданной корзине (rose: syncToServer
        // очищает merfy:cartId и пересоздаёт корзину → промокод, применённый до
        // сабмита, потерян). Если код протух к моменту оплаты — ПРЕРЫВАЕМ
        // оформление (не списываем полную сумму молча).
        var promoCode = (typeof sessionStorage !== 'undefined' && sessionStorage.getItem('merfy:promoCode')) || '';
        if (promoCode) {
          var promoRes = await fetch(apiBase + '/orders/cart/' + cartId + '/promo', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ promoCode: promoCode }),
          });
          if (!promoRes.ok) {
            var promoJson = await promoRes.json().catch(function () { return null; });
            var promoMsg = (promoJson && (typeof promoJson.message === 'string' ? promoJson.message
              : (Array.isArray(promoJson.message) ? promoJson.message[0] : promoJson.error)))
              || 'Промокод больше недействителен — обновите заказ';
            throw new Error(promoMsg);
          }
        }

        var paymentToken = null;
        if (state.paymentMethod === 'bank_card' && typeof window.__checkoutTokenizeCard === 'function') {
          paymentToken = await window.__checkoutTokenizeCard();
        }

        var firstName = getField('firstName');
        var lastName = getField('lastName');
        var fullName = getField('fullName') || (firstName + ' ' + lastName).trim();
        var email = getField('email');
        var phone = getField('phone');

        // 1. PATCH cart с customer info (backend ищет на самой записи cart)
        await fetch(apiBase + '/orders/cart/' + cartId + '/customer', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email: email, phone: phone, name: fullName }),
        });

        // 2. PATCH cart с address (backend DTO ожидает street/building/apartment
        // ОТДЕЛЬНО, не fullAddress). Структурированный адрес сохранён в
        // data-addr-* атрибутах после выбора DaData address suggestion.
        var deliveryForm = document.querySelector('[data-checkout-delivery]'); // merfy-root-allow: cross-block, читает data-addr-* CheckoutDeliveryForm, page-singleton checkout
        var addrStreet = deliveryForm ? (deliveryForm.getAttribute('data-addr-street') || '') : '';
        var addrBuilding = deliveryForm ? (deliveryForm.getAttribute('data-addr-building') || '') : '';
        var addrApartment = deliveryForm ? (deliveryForm.getAttribute('data-addr-apartment') || '') : '';
        var addrFull = getField('address');
        // Fallback parse если juzер ввёл руками: "ул X, д Y, кв Z"
        if (!addrStreet && addrFull) {
          var parts = addrFull.split(',').map(function (s) { return s.trim(); });
          addrStreet = parts[0] || '';
          addrBuilding = parts[1] || '';
          addrApartment = parts[2] || '';
        }
        await fetch(apiBase + '/orders/cart/' + cartId + '/address', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            country: getField('country') || 'Россия',
            city: getField('city'),
            street: addrStreet,
            building: addrBuilding,
            apartment: addrApartment,
            postalCode: getField('postalCode'),
          }),
        });

        // 3. POST checkout (теперь cart содержит customerEmail/Phone)
        var checkoutBody = {
          metadata: {
            paymentMethod: state.paymentMethod,
            deliveryAddress: {
              country: getField('country') || 'Россия',
              city: getField('city'),
              fullAddress: getField('address'),
              postalCode: getField('postalCode'),
              fiasId: getFiasId(),
              firstName: firstName,
              lastName: lastName,
              fullName: fullName,
            },
            deliveryMethod: state.deliveryMethod,
            contactEmail: email,
            contactPhone: phone,
            customerName: fullName,
          },
        };
        var checkoutRes = await fetch(apiBase + '/orders/cart/' + cartId + '/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(checkoutBody),
        });
        var checkoutJson = await checkoutRes.json();
        // Cart not found (404) → cart устарел (paid/cancelled). Сбрасываем cartId
        // чтобы next add-to-cart создал новый, и просим юзера пересобрать заказ.
        if (checkoutRes.status === 404) {
          try { localStorage.removeItem('merfy:cartId'); } catch (e) {}
          throw new Error('Корзина устарела. Вернитесь в каталог и добавьте товары заново.');
        }
        var orderId = checkoutJson && checkoutJson.data && (checkoutJson.data.orderId || checkoutJson.data.id);
        if (!checkoutRes.ok || !orderId) {
          throw new Error((checkoutJson && (checkoutJson.error || checkoutJson.message)) || 'Не удалось оформить заказ');
        }

        var paymentBody = {
          returnUrl: window.location.origin + successRedirectUrl + '?orderId=' + orderId,
          paymentMethod: state.paymentMethod, // 'bank_card' | 'sbp' | ...
        };
        if (paymentToken) paymentBody.paymentToken = paymentToken;

        var paymentRes = await fetch(apiBase + '/orders/' + orderId + '/create-payment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(paymentBody),
        });
        var paymentJson = await paymentRes.json();
        var confirmationUrl = paymentJson && paymentJson.data && paymentJson.data.confirmationUrl;
        if (!paymentRes.ok || !confirmationUrl) {
          throw new Error((paymentJson && (paymentJson.error || paymentJson.message)) || 'Ошибка платежа');
        }

        try {
          localStorage.setItem('merfy:lastOrderId', orderId);
          // Удаляем оба ключа — иначе stale items без cartId создают
          // зомби-cart на /checkout (сводка показывает item, но
          // delivery quote видит cartId=null → 'Добавьте товар').
          localStorage.removeItem('merfy:cartId');
          localStorage.removeItem('merfy:cartItems');
          // Промокод применён к заказу — очищаем, чтобы не переприменялся к
          // следующей корзине.
          if (typeof sessionStorage !== 'undefined') sessionStorage.removeItem('merfy:promoCode');
        } catch (e) {}
        window.location.href = confirmationUrl;
      } catch (err) {
        state.submitting = false;
        refresh();
        showError(err && err.message ? err.message : 'Не удалось оформить заказ');
      }
    });

    refresh();
  })();
</script>
