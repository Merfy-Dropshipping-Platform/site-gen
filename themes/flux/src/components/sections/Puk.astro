---
// Секция «Puk» = «Основной текст» / CTA верстальщиков flux (репо flux-theme
// src/components/sections/Puk.astro, Figma 905:19320). ВЁРСТКА — дословный канон
// репо: заголовок Roboto Flex uppercase 19/md:23 #000, абзац Roboto Flex light
// 16 #999, чёрная CTA h-14 rounded-6 px-4 uppercase #fff. Шрифт ВСЕЙ секции —
// font-roboto-flex (репо целиком roboto-flex; прежние comfortaa/manrope — наследие
// разошедшегося product-grid порта, удалены). Рендерится в демо темы
// (pages/index.astro <Puk/>).
//
// НАСТРОЙКИ — как канон-CTA темы (эталон flux MainText.astro): читаем поля
// heading/text/button(+ legacy cta)/headingSize/textSize/buttonStyle/padding —
// «применяй как другие flux-секции» (паттерн Popular/Collections). Цвета → токены
// с пиксель-фоллбеком родных литералов репо (MANNER §7) → colorScheme перекрашивает
// (навешивается обёрткой composeV2Page). headingSize/textSize — ступени small/
// medium(=эталон)/large на базе эталонных размеров (19/23, 16). Пустое состояние =
// дефолт-контент верстальщика (title/paragraph/cta репо).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Заголовок: string | { text, size } (канон-union). Пусто → дефолт верстальщика.
const heading =
	typeof p.heading === "string"
		? p.heading
		: (p.heading?.text ?? "Следующее поколение уже с вами!");
// Ступени headingSize (эталон 19/md:23; паритет Collections.astro): medium/
// отсутствие = эталон, small меньше, large крупнее. top-level hidden приоритетнее
// heading.size сабпанели.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[16px] md:text-[19px]"
		: headingSize === "large"
			? "text-[23px] md:text-[29px]"
			: "text-[19px] md:text-[23px]"; // medium (эталон) + absent
const headingCls = `font-roboto-flex font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))] ${headingSizeCls}`;

// Текст-абзац: string | { content, size }. Пусто → дефолт верстальщика.
const text =
	typeof p.text === "string"
		? p.text
		: (p.text?.content ??
			"Они здесь. Устройства, которые изменят завтра, уже сегодня в нашем потоке новинок. Смотрите, тестируйте, погружайтесь в будущее, которое стало реальностью. Только в Flux.");
// Ступени textSize (эталон 16; паритет rose MainText): medium/отсутствие = 16,
// small 14, large 19. Тело — Roboto Flex light, мут-цвет (#999 фоллбек).
const textSize = p.textSize ?? p.text?.size;
const textSizeCls =
	textSize === "small" ? "text-[14px]" : textSize === "large" ? "text-[19px]" : "text-[16px]";
const textCls = `max-w-[1320px] font-roboto-flex font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] ${textSizeCls}`;

// Кнопка: canon-сабпанель button {text, link} приоритетнее legacy hidden cta.
// Пустой текст ЗАДАННОГО пропа скрывает кнопку; ничего не задано → дефолт
// верстальщика «Смотреть новинки» → /catalog.
const btnProvided = p.button !== undefined || p.cta !== undefined;
const btnTextProp =
	(typeof p.button?.text === "string" && p.button.text.trim() ? p.button.text : undefined) ??
	(typeof p.cta?.text === "string" && p.cta.text.trim() ? p.cta.text : undefined);
const btnText = btnTextProp ?? (btnProvided ? undefined : "Смотреть новинки");
const btnHref =
	p.button?.link?.href ??
	(typeof p.button?.link === "string" && p.button.link ? p.button.link : undefined) ??
	(typeof p.cta?.href === "string" && p.cta.href ? p.cta.href : undefined) ??
	(typeof p.cta?.link === "string" && p.cta.link ? p.cta.link : undefined) ??
	"/catalog";
// buttonStyle: solid (default) = чёрная CTA репо дословно (h-14 rounded-6 px-4
// uppercase, roboto-flex 16, hover:opacity-90); в схемах flux чёрная = кнопка-2
// (MANNER §7). outlined = бордер/текст цвета заливки на прозрачном.
const btnBase =
	"inline-flex h-14 items-center justify-center rounded-[var(--radius-button,6px)] px-4 font-roboto-flex text-[16px] font-normal uppercase leading-none transition-opacity hover:opacity-90";
const btnCls =
	p.buttonStyle === "outlined"
		? `${btnBase} border border-solid border-[rgb(var(--color-button-2-bg,0_0_0))] bg-transparent text-[rgb(var(--color-button-2-bg,0_0_0))]`
		: `${btnBase} bg-[rgb(var(--color-button-2-bg,0_0_0))] text-[rgb(var(--color-button-2-text,255_255_255))]`;

// Канон padding {top,bottom} — inline-override вертикали ТОЛЬКО при заданном пропе
// (иначе эталонные py-10 md:py-16 на контейнере). colorScheme — обёрткой
// composeV2Page; фон секции = bg-токен с пиксель-фоллбеком #FBFBFB репо.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id ? `${id}-title` : "cta-title";
---

<section
	class="w-full bg-[rgb(var(--color-bg,251_251_251))]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
>
	<div
		class="flux-container flex flex-col items-start gap-10 py-10 md:py-16"
		data-reveal
		style={paddingStyle}
	>
		<div class="flex flex-col gap-2">
			<h2
				id={titleId}
				class={headingCls}
				data-puck-subsection-parent={id}
				data-puck-subsection-index="100"
				data-puck-subsection-field="heading"
			>
				{heading}
			</h2>
			<p
				class={textCls}
				data-puck-subsection-parent={id}
				data-puck-subsection-index="101"
				data-puck-subsection-field="text"
				set:html={text}
			/>
		</div>

		{
			btnText && (
				<a
					href={btnHref}
					class={btnCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="button"
				>
					{btnText}
				</a>
			)
		}
	</div>
</section>
