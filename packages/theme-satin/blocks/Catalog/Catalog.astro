---
// Satin Catalog — Puck-bound block. Mounts the pupa-branch CatalogIsland
// (sidebar filters + grid + pagination) inside the standard Satin section
// chrome (1320px container, 40px gutters, configurable padding/scheme).
//
// CatalogIsland lives under templates/astro/satin/src/components/react/.
// During build, assemble-from-packages flattens block .astro files into
// `outputDir/src/components/<BlockName>.astro`. From that location the React
// island sits at `./react/CatalogIsland.tsx`, so we import it via that
// relative path (NOT `../../components/react/...` which would point one level
// above outputDir/src and fail to resolve).
import CatalogIsland from './react/CatalogIsland';
import { CatalogClasses as C } from './Catalog.classes';
import type { CatalogProps } from './Catalog.puckConfig';

interface Props extends CatalogProps {
  id?: string;
}

const {
  id,
  collectionSlug,
  showCollectionFilter = 'true',
  padding,
  colorScheme,
} = Astro.props as Props;

const showColl =
  showCollectionFilter === true ||
  showCollectionFilter === 'true';

const paddingStyle = padding
  ? `padding-top:${padding.top ?? 40}px; padding-bottom:${padding.bottom ?? 80}px;`
  : 'padding-top:40px; padding-bottom:80px;';
const schemeRaw = typeof colorScheme === 'string' ? colorScheme : undefined;
const schemeClass = schemeRaw ? `color-scheme-${schemeRaw.replace('scheme-', '')}` : '';
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-block="catalog"
  style={paddingStyle}
>
  <div class={C.container}>
    <CatalogIsland
      client:only="react"
      collectionSlug={collectionSlug}
      showCollectionFilter={showColl}
    />
  </div>
</section>
