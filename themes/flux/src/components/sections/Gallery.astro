---
import NtSectionHeading from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtSectionHeading.astro";

// ОЖИВЛЕНИЕ (Фаза B, контракт bloom Gallery): конструкторная схема theme-base
// Gallery.puckConfig поверх разметки верстальщика. Тело + demo-данные verbatim
// (страницы зовут <Gallery /> без пропсов — дефолт-ветка даёт прежний рендер,
// Gallery.astro:12-84 дословно). Подзаголовок у flux в литерале ЕСТЬ
// (инверсия bloom) — рендерится и дефолтом. Канон-дефолты конструктора
// (headingSize/textSize medium → у flux размер шапки задаёт DS-литерал,
// imagePosition left) → пиксель верстальщика; цвета → токены с
// пиксель-фоллбеком родных литералов (MANNER.md §7). Скролл-анимаций нет —
// манера flux статична (MANNER.md §6).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустое состояние (Figma 1:19335, контракт Gallery) — ДОСЛОВНЫЙ плейсхолдер:
// заголовок «Галерея», БЕЗ подзаголовка (в контракте Gallery подзаголовка нет →
// дефолт пуст). Дефолт-текст верстальщика («Вдохновение в деталях» + болванка
// «Технологии, которые приятно держать в руках…») заменён на Figma-текст.
// Заданный мерчантом heading/text/subtitle рендерится как есть (?? fallback
// срабатывает только при пустых данных); пустой subtitle → NtSectionHeading его
// не выводит.
const sectionTitle =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title ?? "Галерея";
const sectionSubtitle =
	(typeof p.text === "string" ? p.text : p.text?.content) ??
	(typeof p.subtitle === "string" ? p.subtitle : undefined) ??
	"";

// Шапка — DS-компонент NtSectionHeading: размеры через перекрытия на обёртке
// (лестница §9). Дефолт ('medium' canon-default трактуем как DS-литерал
// 20/24/32 + 14/18/24, прецедент bloom «canon-default → пиксель верстальщика»);
// large → 46px (small оставляет литерал — меньше базы DS не уходим).
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls = headingSize === "large" ? " [&_h2]:!text-[46px]" : "";
const textSize = p.textSize ?? p.text?.size;
const textSizeCls = textSize === "large" ? " [&_p]:!text-[35px]" : "";
// Схемы flux включают ТЁМНЫЕ (scheme-1 bg 0 0 0) — хардкоды DS-шапки
// (#000000/#999999) всегда перекрываются токенами; фоллбеки = литералы DS →
// без схемы пиксель не меняется (MANNER.md §7).
const headColorCls =
	" [&_h2]:!text-[rgb(var(--color-heading,0_0_0))] [&_p]:!text-[rgb(var(--color-muted,153_153_153))]";
const headWrapCls = [headingSizeCls, textSizeCls, headColorCls].join("").trim();

// Канон imagePosition left/right: 'left' (canon-default) и отсутствие =
// большая квадратная плитка слева (литерал lg:grid-cols-[1fr_429px]);
// 'right' — зеркало: шаблон колонок переворачивается + lg:order.
const mirror = p.imagePosition === "right";
const gridColsCls = mirror ? "lg:grid-cols-[429px_1fr]" : "lg:grid-cols-[1fr_429px]";
const heroOrderCls = mirror ? " lg:order-2" : "";
const sideOrderCls = mirror ? " lg:order-1" : "";

// Канон items[] (≤3, типы image/product/collection): плитки из пропсов с
// fallback на разметку верстальщика ДОСЛОВНО. SSR рендерит канон-плейсхолдеры
// («Товар» 2 500 ₽ / «Выбери коллекцию»); резолв productId/collectionId →
// имя/цена/картинка/href делает гидрация ниже (data-gallery-product/
// -collection): live — /data/{products,collections}.json, превью —
// storefront-data.
type GalleryTile = {
	kind: "image" | "product" | "collection";
	url: string;
	alt: string;
	label: string;
	price: string;
	href: string;
	ref: string | null;
};
const galleryTiles: GalleryTile[] = (Array.isArray(p.items) ? p.items : [])
	.filter((x: any) => x && typeof x === "object")
	.slice(0, 3)
	.map((it: any): GalleryTile => {
		if (it.type === "product") {
			const pid = typeof it.productId === "string" && it.productId ? it.productId : null;
			return {
				kind: "product",
				url: "",
				alt: "Товар",
				label: "Товар",
				price: "2 500 ₽",
				href: pid ? `/product?id=${encodeURIComponent(pid)}` : "/catalog",
				ref: pid,
			};
		}
		if (it.type === "collection") {
			const cid = typeof it.collectionId === "string" && it.collectionId ? it.collectionId : null;
			return {
				kind: "collection",
				url: "",
				alt: "Коллекция",
				label: "Выбери коллекцию",
				price: "",
				href: cid ? `/catalog?collection=${encodeURIComponent(cid)}` : "/catalog",
				ref: cid,
			};
		}
		return {
			kind: "image",
			url: typeof it.url === "string" ? it.url : "",
			alt: typeof it.alt === "string" ? it.alt : "",
			label: "",
			price: "",
			href: "/catalog",
			ref: null,
		};
	});
// ПЛЕЙСХОЛДЕР пустой плитки (Figma 1:19335, контракт theme-base Gallery):
// НЕ фото верстальщика, а нейтральная заглушка по типу плитки.
//  • product (любой) и collection С ВЫБОРОМ → куртка-плейсхолдер blue
//    (/placeholders/sweater-blue.svg; build-пайплайн копирует ассет из
//    packages/theme-base/public по скану .astro, assemble-from-packages.ts:376).
//    Этот <img> служит И визуальным плейсхолдером, И целью гидрации: когда товар/
//    коллекция ВЫБРАНЫ, скрипт ниже (data-gallery-product / -collection)
//    подменяет src/alt реальной картинкой — поведение «данные выбраны» цело.
//  • collection без выбора и image без url → пустой image-rect (фон
//    --color-surface, без <img>) + лейбл «Выбери коллекцию».
// Полностью пустое состояние секции (нет items) рендерит ниже фикс-плейсхолдер:
// большая плитка = /placeholders/landscape-gallery.png, карточка-товар = sweater
// blue + «Товар»/«2 500 ₽», карточка-коллекция = пустая surface + «Выбери коллекцию».
const SWEATER_BLUE = "/placeholders/sweater-blue.svg";
galleryTiles.forEach((t) => {
	if (t.url) return;
	if (t.kind === "product") t.url = SWEATER_BLUE;
	else if (t.kind === "collection" && t.ref) t.url = SWEATER_BLUE;
});
const useItems = galleryTiles.length > 0;
const heroTile = useItems ? galleryTiles[0] : undefined;
const sideTiles = useItems ? galleryTiles.slice(1) : [];

// Аспекты и ховеры правой колонки — по позициям литерала верстальщика:
// плитка 1 — 429/444 (scale-105 300ms), плитка 2 — 429/309 (scale-[1.03] 500ms).
const SIDE_ASPECTS = ["aspect-[429/444]", "aspect-[429/309]"];
const SIDE_HOVERS = [
	"transition-transform duration-300 group-hover:scale-105",
	"transition-transform duration-500 ease-out group-hover:scale-[1.03]",
];

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---
<section
	id="gallery"
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-16 pt-16 md:px-20 md:pb-24 md:pt-24 2xl:px-80"
	aria-labelledby="gallery-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-8 md:gap-12">
		<div
			class={headWrapCls}
			data-puck-subsection-parent={id}
			data-puck-subsection-index="100"
			data-puck-subsection-field="heading"
			data-reveal
		>
			<NtSectionHeading titleId="gallery-title" title={sectionTitle} subtitle={sectionSubtitle} />
		</div>

		<div class={`grid grid-cols-1 gap-6 ${gridColsCls} md:gap-8`}>
			{heroTile ? (
				<a
					href={heroTile.href}
					class={`group relative block aspect-square w-full min-h-0 overflow-hidden bg-[rgb(var(--color-surface,245_245_245))] rounded-[var(--radius-media,8px)]${heroOrderCls}`}
					aria-label={heroTile.alt || heroTile.label || "Перейти в каталог"}
					data-gallery-product={heroTile.kind === "product" ? (heroTile.ref ?? undefined) : undefined}
					data-gallery-collection={heroTile.kind === "collection" ? (heroTile.ref ?? undefined) : undefined}
					data-puck-subsection-parent={id}
					data-puck-subsection-index={0}
					data-puck-subsection-field="items"
				>
					{heroTile.url && (
						<img
							src={heroTile.url}
							alt={heroTile.alt}
							loading="lazy"
							class="absolute inset-0 size-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.02]"
						/>
					)}
				</a>
			) : (
				/* Пустое состояние (Figma 1:19335, контракт картиночных секций):
				   большая левая плитка = дизайн-ассет /placeholders/landscape-
				   gallery.png (картинка показывается ВСЕГДА, НЕ пустой surface).
				   Сырой <img> (у плейсхолдера нет соимённого .webp). */
				<div
					class={`relative block aspect-square w-full min-h-0 overflow-hidden bg-[rgb(var(--color-surface,245_245_245))] rounded-[var(--radius-media,8px)]${heroOrderCls}`}
					aria-hidden="true"
				>
					<img
						src="/placeholders/landscape-gallery.png"
						alt=""
						aria-hidden="true"
						loading="lazy"
						class="absolute inset-0 size-full object-cover"
					/>
				</div>
			)}

			{useItems ? sideTiles.length > 0 && (
				<div class={`flex flex-col gap-6 md:gap-8${sideOrderCls}`}>
					{sideTiles.map((tile, i) => (
						<a
							href={tile.href}
							class="group flex flex-col gap-4"
							aria-label={tile.label || tile.alt || "Изображение"}
							data-gallery-product={tile.kind === "product" ? (tile.ref ?? undefined) : undefined}
							data-gallery-collection={tile.kind === "collection" ? (tile.ref ?? undefined) : undefined}
							data-puck-subsection-parent={id}
							data-puck-subsection-index={i + 1}
							data-puck-subsection-field="items"
						>
							<div
								class={`relative ${SIDE_ASPECTS[i] ?? SIDE_ASPECTS[0]} w-full min-h-0 overflow-hidden bg-[rgb(var(--color-surface,245_245_245))] rounded-[var(--radius-media,8px)]`}
							>
								{tile.url && (
									<img
										src={tile.url}
										alt={tile.alt || tile.label}
										loading="lazy"
										class={`absolute inset-0 size-full max-w-none object-cover object-center ${SIDE_HOVERS[i] ?? SIDE_HOVERS[0]}`}
									/>
								)}
							</div>
							{(tile.label || tile.price) && (
								<div class="flex flex-col gap-1">
									{tile.label && (
										<h3
											class={
												tile.kind === "collection"
													? "gallery-collection-title font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]"
													: "gallery-product-title font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]"
											}
										>
											{tile.label}
										</h3>
									)}
									{tile.price && (
										<span class="gallery-product-price font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]">
											{tile.price}
										</span>
									)}
								</div>
							)}
						</a>
					))}
				</div>
			) : (
				<div class={`flex flex-col gap-6 md:gap-8${sideOrderCls}`}>
					{/* ПЛЕЙСХОЛДЕР пустого состояния (Figma 1:19335, контракт theme-base
					    Gallery): карточка-товар (куртка blue + «Товар» / «2 500 ₽») +
					    карточка-коллекция (пустой image-rect + «Выбери коллекцию») вместо
					    мок-товаров верстальщика («M Phone 17» / «Ноутбуки»). */}
					<div class="flex flex-col gap-4" aria-label="Товар">
						<div class="relative aspect-[429/444] w-full min-h-0 overflow-hidden bg-[rgb(var(--color-surface,245_245_245))] rounded-[var(--radius-media,8px)]">
							<img
								src="/placeholders/sweater-blue.svg"
								alt="Товар"
								loading="lazy"
								class="absolute inset-0 size-full object-contain object-center p-[15%]"
							/>
						</div>
						<div class="flex flex-col gap-1">
							<h3 class="font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]">
								Товар
							</h3>
							<span class="font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]">
								2 500 ₽
							</span>
						</div>
					</div>

					<div class="flex flex-col gap-4" aria-label="Выбери коллекцию">
						<div
							class="relative aspect-[429/309] w-full min-h-0 overflow-hidden bg-[rgb(var(--color-surface,245_245_245))] rounded-[var(--radius-media,8px)]"
							aria-hidden="true"
						/>
						<h3 class="font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]">
							Выбери коллекцию
						</h3>
					</div>
				</div>
			)}
		</div>
	</div>
</section>

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		findCollection,
		formatPrice,
		productHref,
		productImage,
	} from "../../lib/storefront-hydrate";

	// Резолв выбранных в конструкторе товара/коллекции на плитках галереи
	// (data-gallery-product / data-gallery-collection). SSR несёт
	// канон-плейсхолдеры; здесь подставляем имя/цену/картинку/ссылку реальной
	// сущности. Без данных (demo-сборка) — no-op.
	const hydrateGalleryTiles = async () => {
		const prodTiles = Array.from(document.querySelectorAll<HTMLElement>("[data-gallery-product]"));
		const colTiles = Array.from(document.querySelectorAll<HTMLElement>("[data-gallery-collection]"));
		if (prodTiles.length === 0 && colTiles.length === 0) return;
		const [products, collections] = await Promise.all([
			prodTiles.length ? loadRealProducts() : Promise.resolve(null),
			colTiles.length ? loadRealCollections() : Promise.resolve(null),
		]);
		for (const tile of prodTiles) {
			const ref = tile.getAttribute("data-gallery-product");
			const product = products?.find((x) => x.id === ref || x.slug === ref) ?? null;
			if (!product) continue;
			const title = tile.querySelector(".gallery-product-title");
			if (title && product.name) title.textContent = product.name;
			const price = tile.querySelector(".gallery-product-price");
			if (price) price.textContent = formatPrice(product.price);
			const img = tile.querySelector("img");
			const cover = productImage(product);
			if (img && cover) {
				img.setAttribute("src", cover);
				if (product.name) img.setAttribute("alt", product.name);
			}
			tile.setAttribute("href", productHref(product));
			if (product.name) tile.setAttribute("aria-label", product.name);
		}
		for (const tile of colTiles) {
			const col = findCollection(collections, tile.getAttribute("data-gallery-collection"));
			if (!col) continue;
			const title = tile.querySelector(".gallery-collection-title");
			if (title && col.name) title.textContent = col.name;
			const cover = col.image || (Array.isArray(col.images) ? col.images[0] : "");
			const img = tile.querySelector("img");
			if (img && cover) {
				img.setAttribute("src", cover);
				if (col.name) img.setAttribute("alt", col.name);
			}
			if (col.name) tile.setAttribute("aria-label", col.name);
			if (col.slug) tile.setAttribute("href", `/catalog?collection=${encodeURIComponent(col.slug)}`);
		}
	};

	hydrateGalleryTiles();
	document.addEventListener("astro:page-load", hydrateGalleryTiles);
</script>
