---
import type { Product } from "../../types/product";
import { getProductCardCarouselImages } from "../../data/imageAssets";
import VanillaPicture from "../img/VanillaPicture.astro";

interface Props {
	product: Product & { gallery?: string[] };
	priority?: boolean;
}

const { product, priority = false } = Astro.props;
const href = `/products/${product.id}`;

const swatchColors: Record<string, string> = {
	olive: "var(--vanilla-announcement-bg)",
	white: "var(--vanilla-surface)",
	gray: "var(--vanilla-surface)",
};

const colors = product.colors ?? [];
const hasPhoto =
	(typeof product.image === "string" && product.image.trim().length > 0) ||
	(Array.isArray(product.gallery) && product.gallery.some((g) => typeof g === "string" && g.trim().length > 0));
const carouselImages = getProductCardCarouselImages(product.image, product.gallery);
const defaultSlide = 1;

// Outline-сердце vanilla (геометрия favourite.svg, как в wishlist.astro/wishlist.ts).
// SSR-рендер всегда outline + aria-pressed="false"; глобальный делегат initWishlistUI
// (Layout) перекрасит залитым на astro:page-load, если товар уже в избранном.
const wishlistOutlineSvg =
	'<svg viewBox="0 0 17.4 15.4" width="100%" height="100%" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="display:block">' +
	'<path d="M7.428 14.2615C5.172 12.5239 0.7 8.55212 0.7 4.97729C0.7 2.61547 2.384 0.7 4.7 0.7C5.9 0.7 7.1 1.11175 8.7 2.75876C10.3 1.11175 11.5 0.7 12.7 0.7C15.016 0.7 16.7 2.61547 16.7 4.97729C16.7 8.5513 12.228 12.5239 9.972 14.2615C9.212 14.8462 8.188 14.8462 7.428 14.2615Z" ' +
	'fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>' +
	"</svg>";
---

<article
	class="group flex flex-col gap-3"
	data-nt="vanilla-product-card"
	aria-label={product.name}
>
	<div class="relative w-full">
	<a
		href={href}
		class="relative block aspect-square w-full overflow-hidden bg-[var(--vanilla-card)]"
		aria-label={product.name}
	>
		<div
			class="absolute inset-0 transition-transform duration-300 group-hover:scale-105"
			data-product-card-media
		>
			{hasPhoto && carouselImages.map((src, index) => (
				<div
					class:list={[
						"absolute inset-0 transition-opacity duration-300 ease-out",
						index === defaultSlide ? "opacity-100" : "pointer-events-none opacity-0",
					]}
					data-card-slide={index}
					aria-hidden={index === defaultSlide ? "false" : "true"}
				>
					<VanillaPicture
						src={src}
						alt={product.name}
						width="429"
						height="429"
						loading={priority && index === defaultSlide ? "eager" : "lazy"}
						fetchpriority={priority && index === defaultSlide ? "high" : undefined}
						class="h-full w-full object-cover"
					/>
				</div>
			))}
			{!hasPhoto && (
				<div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
					<svg class="size-10" style="color:rgb(var(--color-muted,153 153 153))" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path></svg>
				</div>
			)}

			<div class="absolute inset-0 z-10 flex" aria-hidden="true">
				<div class="h-full w-1/3" data-card-zone="0" />
				<div class="h-full w-1/3" data-card-zone="1" />
				<div class="h-full w-1/3" data-card-zone="2" />
			</div>
		</div>

		{product.discount && (
			<span
				class="absolute left-2 top-2 z-20 inline-flex h-6 min-w-12 items-center justify-center bg-[var(--vanilla-announcement-bg)] px-2 font-vanilla-arsenal text-[12px] font-normal leading-none text-center text-white"
			>
				Скидка
			</span>
		)}
		{colors.length > 0 && (
			<div
				class="absolute bottom-2 right-2 z-20 inline-flex items-center gap-0.5 bg-white p-0.5"
				aria-hidden="true"
				data-nt="variant-selector"
			>
				{colors.map((color) => (
					<span
						class="size-2 shrink-0 rounded-[1px]"
						style={`background-color: ${swatchColors[color] ?? swatchColors.olive}`}
					/>
				))}
			</div>
		)}
	</a>
		<button
			type="button"
			data-wishlist-toggle
			data-product-id={product.id}
			aria-pressed="false"
			aria-label="В избранное"
			class="absolute right-2 top-2 z-20 flex size-9 items-center justify-center bg-white text-[var(--vanilla-dark)] shadow-[0_2px_8px_rgba(0,0,0,0.10)] transition-opacity hover:opacity-80"
		>
			<span data-wishlist-icon class="block size-[18px]" set:html={wishlistOutlineSvg} />
		</button>
	</div>
	<div class="flex flex-col gap-1">
		<a
			href={href}
			class="font-vanilla-arsenal text-base font-normal uppercase leading-none text-black transition-opacity hover:opacity-70"
		>
			{product.name}
		</a>
		<div class="flex flex-wrap items-baseline gap-2">
			<span class="font-vanilla-arsenal text-base font-normal leading-none text-black">
				{product.price}
			</span>
			{product.oldPrice && (
				<span class="font-vanilla-arsenal text-[14px] font-normal leading-none text-[#444444] line-through">
					{product.oldPrice}
				</span>
			)}
		</div>
	</div>
</article>

<script>
	const DEFAULT_SLIDE = 1;

	const setActiveSlide = (media: HTMLElement, index: number) => {
		const slides = media.querySelectorAll<HTMLElement>("[data-card-slide]");
		slides.forEach((slide, i) => {
			const active = i === index;
			slide.classList.toggle("opacity-100", active);
			slide.classList.toggle("opacity-0", !active);
			slide.classList.toggle("pointer-events-none", !active);
			slide.setAttribute("aria-hidden", active ? "false" : "true");
		});
	};

	document.querySelectorAll<HTMLElement>("[data-product-card-media]").forEach((media) => {
		if (media.dataset.cardCarouselBound === "true") return;
		media.dataset.cardCarouselBound = "true";

		const zones = media.querySelectorAll<HTMLElement>("[data-card-zone]");

		zones.forEach((zone) => {
			zone.addEventListener("mouseenter", () => {
				const index = Number(zone.dataset.cardZone);
				if (Number.isNaN(index)) return;
				setActiveSlide(media, index);
			});
		});

		media.addEventListener("mouseleave", () => {
			setActiveSlide(media, DEFAULT_SLIDE);
		});
	});
</script>
