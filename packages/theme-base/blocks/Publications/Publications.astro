---
import {
  clampPublicationCount,
  filterPublicationsByType,
  resolvePublicationsDateTime,
  resolvePublicationsType,
  type PublicationsProps,
} from './Publications.puckConfig';
import { PublicationsClasses as C } from './Publications.classes';
import { PLACEHOLDER_ASSETS } from '../../runtime/placeholders';
import { sanitizeInline } from '../../runtime/rich-text';

interface Props extends PublicationsProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  columns = 3,
  cards = 3,
  padding,
} = Astro.props as Props;

// Accept legacy {text,size} heading envelope.
const headingText = (() => {
  const h = raw.heading;
  if (typeof h === 'string') return h || undefined;
  if (h && typeof h === 'object') {
    const o = h as { text?: string };
    return o.text || undefined;
  }
  return undefined;
})();

// SSR fetch publications from storefront-data endpoint (gateway → sites-service).
type RawPublication = {
  id: string;
  title?: string;
  slug?: string;
  excerpt?: string;
  category?: string;
  coverImageUrl?: string | null;
  publishedAt?: string | null;
};
type Article = { id?: string; date: string; title: string; excerpt: string; image?: string; slug?: string };

function formatDate(iso: string | null | undefined): string {
  if (!iso) return '';
  try {
    return new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(iso));
  } catch {
    return '';
  }
}

const siteIdFromRoot = typeof raw.siteId === 'string' ? raw.siteId : '';
let realPublications: RawPublication[] = [];
if (siteIdFromRoot) {
  try {
    const internalBase = (import.meta as unknown as { env?: { SITES_INTERNAL_BASE?: string } }).env?.SITES_INTERNAL_BASE
      ?? 'http://localhost:3114';
    const res = await fetch(`${internalBase}/api/sites/${siteIdFromRoot}/publications`).catch(() => null);
    if (res && res.ok) {
      const data = (await res.json()) as { publications?: RawPublication[] };
      realPublications = data.publications ?? [];
    }
  } catch {/* swallow */}
}
try {
  if (realPublications.length === 0) {
    const pubData = await import('../data/publications.json');
    realPublications = ((pubData as { default?: RawPublication[] }).default ?? (pubData as unknown as RawPublication[])) as RawPublication[];
  }
} catch {/* swallow — publications.json absent */}

// Placeholder articles (Figma 1:19531 reference cards) when no real
// publications exist yet — keeps preview alive for seed sites.
const DEMO_ARTICLES: Article[] = [
  { date: '15 марта 2025', title: 'Новая коллекция весна 2025', excerpt: 'Рассказываем о вдохновении и ключевых силуэтах новой коллекции.' },
  { date: '28 февраля 2025', title: 'Как ухаживать за кожаными изделиями', excerpt: 'Простые правила, чтобы ваши вещи служили долгие годы.' },
  { date: '10 февраля 2025', title: 'История бренда: от идеи до магазина', excerpt: 'Путь от первой сумки, сшитой вручную, до собственной коллекции.' },
  { date: '25 января 2025', title: 'Тренды аксессуаров 2025', excerpt: 'Обзор ключевых трендов сезона — от цветов до фактур.' },
];

const hasRealPublications = realPublications.length > 0;
const filteredPublications = filterPublicationsByType(realPublications, resolvePublicationsType(raw));
const items: Article[] = (hasRealPublications
  ? filteredPublications.map((p) => ({
      id: p.id,
      slug: p.slug,
      date: formatDate(p.publishedAt),
      title: p.title ?? '',
      excerpt: p.excerpt ?? '',
      image: p.coverImageUrl ?? undefined,
    }))
  : DEMO_ARTICLES
);

// Pupa parity: cardsCount, columnsCount, headingAlignment, headingSize, dateTime.enabled, colorScheme.
const cardsResolved = clampPublicationCount(raw.cardsCount, cards);
const columnsResolved = clampPublicationCount(raw.columnsCount, columns);
const headingObj = raw.heading;
const headingAlignment =
  (typeof headingObj === 'object' ? (headingObj as { alignment?: string })?.alignment : undefined) ??
  (typeof raw.headingAlignment === 'string' ? raw.headingAlignment : undefined);
const headingSize =
  (typeof headingObj === 'object' ? (headingObj as { size?: string })?.size : undefined) ??
  (typeof raw.headingSize === 'string' ? raw.headingSize : undefined);
const dateTimeEnabled = resolvePublicationsDateTime(raw);
const colorScheme = raw.colorScheme as string | undefined;
const schemeClass = colorScheme ? `color-scheme-${String(colorScheme).replace('scheme-', '')}` : '';
const headingAlignClass =
  headingAlignment === 'left' ? 'text-left' :
  headingAlignment === 'right' ? 'text-right' :
  headingAlignment === 'center' ? 'text-center' : '';
// Размер заголовка через блок-приватную CSS-var --pub-heading-size
// (дефолт-fallback в Publications.classes.ts = 14px eyebrow). Берём
// приватную var, а НЕ глобальную --size-section-heading: последняя
// эмитится в :root со значением 20px (base-defaults), её fallback 14px
// не сработал бы и дефолт-eyebrow поехал бы на 20px. medium/дефолт →
// ничего → 14px; small ~12px, large ~17px. Не используем
// text-2xl/3xl/4xl — они конфликтовали с фикс-размером на одном <h2>
// (победитель зависел от порядка в CSS).
const headingSizeClass =
  headingSize === 'large' ? '[--pub-heading-size:17px]' :
  headingSize === 'small' ? '[--pub-heading-size:12px]' : '';

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';

// Самодостаточность блока (rose-баг «выцветший текст»): дист темы
// верстальщика может не сканировать packages/theme-base/** Tailwind'ом —
// тогда utility-классы цвета/фона из Publications.classes.ts не попадают
// в CSS темы, текст наследует цвет страницы, а фоны не красятся.
// Reveal-анимаций в блоке нет — дело только в недоставленных утилитах.
// Поэтому критичные цвет/фон/раскладку дублируем inline через те же
// CSS-переменные: схемы (.color-scheme-N задаёт только --color-*)
// продолжают работать — var() резолвится на самом элементе. Классы
// остаются прогрессив-энхансментом; значения держать в синхроне с
// Publications.classes.ts.
const rootGuardStyle = 'background-color:rgb(var(--color-bg));color:rgb(var(--color-text));';
const headingGuardStyle = 'color:rgb(var(--color-heading));';
const dateGuardStyle = 'color:rgb(var(--color-text) / 0.5);';
const titleGuardStyle = 'color:rgb(var(--color-heading));';
const excerptGuardStyle = 'color:rgb(var(--color-text) / 0.7);';
const linkGuardStyle = 'color:rgb(var(--color-heading));text-decoration-line:underline;text-underline-offset:4px;';
// Медиа-бокс: гарантированные пропорции + surface-фон, чтобы при битой
// обложке (onerror прячет <img>) оставалась аккуратная плашка-сюрфейс,
// а не схлопнутая/прозрачная дыра.
const mediaBoxGuardStyle = 'aspect-ratio:4/3;background-color:rgb(var(--color-surface));';
const mediaImgGuardStyle = 'display:block;width:100%;height:100%;object-fit:cover;';
// Сетка БЕЗ grid-template-columns в inline (раньше был хардкод repeat(N) на всех
// ширинах → на мобиле N колонок, текст ломался по слогам). Колонки задаём
// адаптивно через <style is:inline> ниже (мобилка 1 → планшет min(2,N) → desktop N).
const gridGuardStyle =
  `display:grid;column-gap:var(--spacing-grid-col-gap);row-gap:var(--spacing-grid-row-gap);`;
// Адаптив колонок. Инлайн <style set:html> (как tokensCss в BaseLayout) выводит
// глобальный CSS as-is — не зависит от Tailwind-скана дист-темы (логика *GuardStyle).
// repeat() требует ЦЕЛОЕ число (min()/var() как счётчик ненадёжны) → считаем тут.
const pubDesktopCols = columnsResolved;
const pubTabletCols = Math.min(2, columnsResolved);
const pubGridSel = id
  ? `[data-puck-component-id="${id}"] [data-pub-grid]`
  : `[data-pub-grid]`;
const pubGridResponsiveCss =
  `${pubGridSel}{grid-template-columns:repeat(1,minmax(0,1fr))}` +
  `@media(min-width:640px){${pubGridSel}{grid-template-columns:repeat(${pubTabletCols},minmax(0,1fr))}}` +
  `@media(min-width:1024px){${pubGridSel}{grid-template-columns:repeat(${pubDesktopCols},minmax(0,1fr))}}`;
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-block="publications"
  style={`${rootGuardStyle}${paddingStyle}`}
>
  <div class={C.container}>
    {headingText && (
      <h2 class:list={[C.heading, headingAlignClass, headingSizeClass]} style={headingGuardStyle} data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading"><Fragment set:html={sanitizeInline(headingText)} /></h2>
    )}
    <style set:html={pubGridResponsiveCss}></style>
    <div class={C.grid} data-pub-grid style={gridGuardStyle}>
      {items.slice(0, cardsResolved).map((item, i) => {
        const href = item.slug ? `/publication/${item.slug}` : '#';
        const Wrapper = item.slug ? 'a' : 'article';
        return (
          <Wrapper class={C.card} href={item.slug ? href : undefined} data-article-index={i}>
            <div class={C.cardMedia} style={mediaBoxGuardStyle}>
              {item.image ? (
                <img src={item.image} alt={item.title} class={C.cardMediaImg} style={mediaImgGuardStyle} loading="lazy" onerror="this.style.display='none'" />
              ) : (
                <img src={PLACEHOLDER_ASSETS.publicationCard} alt="" class={C.cardMediaImg} style={mediaImgGuardStyle} aria-hidden="true" loading="lazy" onerror="this.style.display='none'" />
              )}
            </div>
            <div class={C.cardBody}>
              <div class={C.cardTitle} style={titleGuardStyle}>{item.title}</div>
              {dateTimeEnabled && item.date && <div class={C.cardDate} style={dateGuardStyle}>{item.date}</div>}
              {item.excerpt && <div class={C.cardExcerpt} style={excerptGuardStyle}>{item.excerpt}</div>}
              <span class={C.cardLink} style={linkGuardStyle}>Подробнее</span>
            </div>
          </Wrapper>
        );
      })}
    </div>
  </div>
</section>
