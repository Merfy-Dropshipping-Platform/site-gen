---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { withBase } from "../lib/with-base";
import { SITE_TITLE } from "../consts";

// Live-конфиг подписки: shopId патчит build.service (patchShopIdInDist) → siteId
// на деплое (заменяет `const shopId = ""` в HTML); apiUrl — публичный gateway.
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";

const today = new Date();

// Дефолтные ссылки навигации = литерал верстальщика flux-theme/src/components/Footer.astro (F:7-12).
const navColumnDefault = [
	{ label: "Смартфоны", href: "/catalog?collection=Смартфоны" },
	{ label: "Наушники", href: "/catalog?collection=Наушники" },
	{ label: "Ноутбуки", href: "/catalog?collection=Ноутбуки" },
	{ label: "Аксессуары", href: "/catalog?collection=Аксессуары" },
];

// ВЁРСТКА = flux-theme/src/components/Footer.astro (verstal'shchik) точь-в-точь:
//   Roboto Flex (копирайт — Inter, фикс-роль Figma flux); newsletter «Подпишитесь на нашу
//   рассылку»; 3 колонки НАВИГАЦИЯ / ИНФОРМАЦИЯ / СОЦИАЛЬНЫЕ СЕТИ (flex, по 318px,
//   justify-between); чёрная копирайт-полоса 80/100px.
// НАСТРОЙКИ = как оживлены в rose Footer (themes/rose/.../Footer.astro): siteTitle, phone,
//   email/socialColumn.email, newsletter(enabled/heading/description/placeholder),
//   navigationColumn, informationColumn, socialColumn(socialLinks/contactFields), copyright,
//   bottomStrip, padding, paymentEnabled, colorScheme — rgb(var(--color-*)) с пиксель-фоллбеком.
// Демо-данные репо (хардкод /legal/*, flux@example.ru, фейк-соцсети) НЕ хардкодим — по rose
//   их заполняет build (site_policy / контакты) и Theme Settings; info/social-колонки
//   гейтятся по контенту (пустое состояние = колонка скрыта, без битых ссылок/фейк-данных).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустая строка (canon default Puck / коэрсер) не должна ронять «Flux».
const siteTitle = typeof p.siteTitle === "string" && p.siteTitle.trim() ? p.siteTitle : SITE_TITLE;
const phone = typeof p.phone === "string" && p.phone.trim() ? p.phone.trim() : "";
const rawEmail = p.socialColumn?.email ?? p.email ?? "";
const email = typeof rawEmail === "string" ? rawEmail.trim() : "";

// Платёжные бейджи — только при подключённой кассе (build ставит paymentEnabled).
const paymentEnabled = p.paymentEnabled === true || p.paymentEnabled === "true";

// «Информация о компании» (адрес/часы/ИНН/любая инфа) — build кладёт сюда поля КРОМЕ
// телефона/почты. Выводим label/value в социальной колонке.
const contactFields: Array<{ label: string; value: string }> = Array.isArray(p.socialColumn?.contactFields)
	? p.socialColumn.contactFields.filter((f: any) => f && typeof f.value === "string" && f.value.trim())
	: [];

// newsletter.enabled — скрыть блок ТОЛЬКО при явном false/'false' (булево может прийти
// строкой). blockDefaults flux {enabled:true, heading/description/placeholder} == литералу
// верстальщика → проп-с-фолбэком на литерал даёт пиксель без canon-стриппинга.
const newsletterEnabled = !(
	p.newsletter && (p.newsletter.enabled === false || p.newsletter.enabled === "false")
);
const nlHeading =
	typeof p.newsletter?.heading === "string" && p.newsletter.heading.trim()
		? p.newsletter.heading
		: "Подпишитесь на нашу рассылку";
const nlDescription =
	typeof p.newsletter?.description === "string" && p.newsletter.description.trim()
		? p.newsletter.description
		: "Введите электронную почту и получайте информацию нашего бренда";
const nlPlaceholder =
	typeof p.newsletter?.placeholder === "string" && p.newsletter.placeholder.trim()
		? p.newsletter.placeholder
		: "flux@example.ru";

// Канон-колонки {title, links[]}: ссылки из пропсов с fallback на литерал верстальщика.
// blockDefaults flux nav (href '/catalog') трактуем как «не задано» → литерал верстальщика
// (href '/catalog?collection=…') — правило canon-default → пиксель.
const coerceColumnLinks = (
	col: any,
	fallback: Array<{ label: string; href: string }>,
): Array<{ label: string; href: string }> =>
	Array.isArray(col?.links) && col.links.length > 0
		? col.links.map((l: any) => ({ label: String(l?.label ?? ""), href: String(l?.href ?? "/") }))
		: fallback;
const isCanonColumn = (
	links: Array<{ label: string; href: string }>,
	canon: Array<[string, string]>,
): boolean =>
	links.length === canon.length &&
	canon.every(([label, href], i) => links[i]?.label === label && links[i]?.href === href);
const CANON_NAV: Array<[string, string]> = [
	["Смартфоны", "/catalog"],
	["Наушники", "/catalog"],
	["Ноутбуки", "/catalog"],
	["Аксессуары", "/catalog"],
];
const navLinksRaw = coerceColumnLinks(p.navigationColumn, navColumnDefault);
const navLinks = isCanonColumn(navLinksRaw, CANON_NAV) ? navColumnDefault : navLinksRaw;
const infoLinks = coerceColumnLinks(p.informationColumn, []);

// Заголовки колонок: дефолт = литерал верстальщика (репо ВСЕГДА показывает «Навигация» /
// «Информация» / «Социальные сети»). Непустой title пропа перебивает.
const columnTitleOf = (col: any): string | undefined =>
	typeof col?.title === "string" && col.title.trim() ? col.title : undefined;
const navColTitle = columnTitleOf(p.navigationColumn) ?? "Навигация";
const infoColTitle = columnTitleOf(p.informationColumn) ?? "Информация";
const socialColTitle = columnTitleOf(p.socialColumn) ?? "Социальные сети";

const columnTitleCls =
	"font-roboto-flex text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))]";
// Ссылка футера (нав/инфо/email/телефон): Roboto Flex 16 light, muted → hover чёрный
// (репо #cccccc→black; токенизировано в --color-muted/--color-text для colorScheme как rose).
const linkCls =
	"font-roboto-flex text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] transition-colors hover:text-[rgb(var(--color-text,0_0_0))]";

// socialColumn.socialLinks (enum платформ) → подписи + NtIcon-глифы верстальщика; пустой
// массив → пусто (без фейк-демо, как rose). Порядок верстальщика: Telegram VK YouTube Дзен TikTok.
const SOCIAL_PLATFORMS: Record<string, { platform: string; icon: string }> = {
	telegram: { platform: "Telegram", icon: "social-telegram" },
	vk: { platform: "VK", icon: "social-vk" },
	youtube: { platform: "YouTube", icon: "social-youtube" },
	dzen: { platform: "Дзен", icon: "social-yandex-dzen" },
	tiktok: { platform: "TikTok", icon: "social-tiktok" },
};
const socials = (Array.isArray(p.socialColumn?.socialLinks) ? p.socialColumn.socialLinks : [])
	.map((s: any) => {
		const meta = SOCIAL_PLATFORMS[String(s?.platform ?? "")];
		const href = String(s?.href ?? "").trim();
		return meta && href && href !== "#" ? { ...meta, href } : null;
	})
	.filter((s: any) => s !== null);

// Социальная колонка показывается ТОЛЬКО при контенте (контакты/соцсети/оплата) — rose-стиль
// пустого состояния (без одинокого заголовка и фейк-данных верстальщика).
const socialColumnHasContent =
	Boolean(phone) || Boolean(email) || contactFields.length > 0 || socials.length > 0 || paymentEnabled;

// copyright {companyName, poweredBy, showYear} (+ legacy-строка целиком). Дефолт = литерал
// чёрной полосы верстальщика байт-в-байт: «© {год} {siteTitle} Theme Все права защищены.
// Powered by Merfy» (F:142) — формула rose (без точки после companyPart).
const copyrightProp = p.copyright;
const copyrightOverride =
	typeof copyrightProp === "string" && copyrightProp.trim() ? copyrightProp : undefined;
const copyrightObj = copyrightProp && typeof copyrightProp === "object" ? copyrightProp : {};
const showYear = !(copyrightObj.showYear === false || copyrightObj.showYear === "false");
const companyPart =
	typeof copyrightObj.companyName === "string" && copyrightObj.companyName.trim()
		? copyrightObj.companyName
		: `${siteTitle} Theme`;
const poweredBy =
	typeof copyrightObj.poweredBy === "string" ? copyrightObj.poweredBy.trim() : "Powered by Merfy";
const copyrightText =
	copyrightOverride ??
	`© ${showYear ? `${today.getFullYear()} ` : ""}${companyPart} Все права защищены.${poweredBy ? ` ${poweredBy}` : ""}`;

// bottomStrip {enabled, text} — чёрная копирайт-полоса = носитель (отдельной полосы у
// верстальщика нет). enabled false/'false' скрывает; непустой text перебивает собранный copyright.
const strip = p.bottomStrip && typeof p.bottomStrip === "object" ? p.bottomStrip : undefined;
const bottomStripVisible = !(strip && (strip.enabled === false || strip.enabled === "false"));
const stripText = typeof strip?.text === "string" && strip.text.trim() ? strip.text : copyrightText;

// padding {top,bottom} — inline-стиль ТОЛЬКО при не-canon пропе. canon {64,64} (theme.json
// flux, впрыск коэрсера) → литерал py-12 md:py-16 верстальщика (правило canon-default → пиксель).
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const isCanonPad = pad && Number(pad.top) === 64 && Number(pad.bottom) === 64;
const footerPadStyle =
	pad && !isCanonPad
		? `padding-top:${Number(pad.top) || 0}px;padding-bottom:${Number(pad.bottom) || 0}px;`
		: undefined;
// flux-container эталона = mx-auto max-w-[1920px] px-4 md:px-20 2xl:px-80 (носитель темы).
const footerContainerCls = footerPadStyle
	? "mx-auto flex w-full max-w-[1920px] flex-col gap-10 px-4 md:px-20 2xl:px-80"
	: "mx-auto flex w-full max-w-[1920px] flex-col gap-10 px-4 py-12 md:px-20 md:py-16 2xl:px-80";

// «Выравнивание» (contentAlign, canon default 'left') — ОЖИВЛЕНИЕ по rose Footer. Управляет
// раскладкой групп колонок И контентом ВНУТРИ колонок И блоком рассылки ОДНИМ значением на
// десктоп И адаптив (rose-фиксы c60f6206/80f57884: без md:-split для выравнивания — на мобиле
// как на десктопе). Классы ЛИТЕРАЛАМИ (Tailwind JIT scan). Дефолт left = прежний рендер
// (nav/info слева, соцколонка справа = md:justify-between + md:items-end).
const _AL_ITEMS: Record<string, string> = { left: "items-start", center: "items-center", right: "items-end" };
const _AL_TEXT: Record<string, string> = { left: "text-left", center: "text-center", right: "text-right" };
const _ca = ["left", "center", "right"].includes(p.contentAlign) ? p.contentAlign : "left";
// Блок рассылки: секция (items-*) + текстовая группа (items-* + text-*), одно значение везде.
const nlSectionAlignCls = _AL_ITEMS[_ca];
const nlCopyAlignCls = `${_AL_ITEMS[_ca]} ${_AL_TEXT[_ca]}`;
// Раскладка ГРУППЫ колонок (section nav/info + соцколонка). center = центрированный блок
// (justify-center + узкий gap), right = к правому краю, left (дефолт) = space-between (текущий).
const colsJustifyCls =
	_ca === "center" ? "md:justify-center md:gap-24" : _ca === "right" ? "md:justify-end" : "md:justify-between";
// Внутренняя группа nav+info: center сжимает межколоночный зазор (иначе block не «центрирован»).
const navInfoGapCls = _ca === "center" ? "sm:gap-24" : "sm:gap-4";
// Контент ВНУТРИ колонок nav/info (заголовок+ссылки): center по центру, right к правому краю,
// left (дефолт) без переопределения = как у верстальщика (по левому краю).
const colInnerCls = _ca === "center" ? "items-center text-center" : _ca === "right" ? "items-end text-right" : "";
// Соцколонка: у верстальщика была md:items-end (справа при 3-колоночной раскладке). По rose
// default 'left' держит контактный блок СПРАВА (contactGroupCls=lg:items-end): left = нав слева /
// контакты справа. center → по центру, right → к правому краю. Для center/right — ЕДИНОЕ значение
// (без md:-split, выравнивание на мобиле = как на десктопе); для left — оставляем md:items-end
// (мобила = левый край в потоке, десктоп = справа, как у верстальщика).
const socialColCls =
	_ca === "center" ? "items-center" : _ca === "right" ? "items-end" : "md:items-end";
const socialInnerCls =
	_ca === "center" ? "items-center" : _ca === "right" ? "items-end" : "items-start md:items-end";
// Контактный текст (тел/почта/поля): center по центру, right вправо, left = md:text-right (как верстальщик).
const contactTextCls = _ca === "center" ? "text-center" : _ca === "right" ? "text-right" : "md:text-right";
const contactColCls =
	_ca === "center" ? "items-center" : _ca === "right" ? "items-end" : "md:items-end";
const paymentJustifyCls =
	_ca === "center" ? "justify-center" : _ca === "right" ? "justify-end" : "md:justify-end";

// Применяем СВОЮ colorScheme на <footer> (как base/rose Footer.astro). Иначе hot-render
// одиночного блока в превью конструктора (без scheme-обёртки композитора) берёт :root
// = тёмный BASE_DEFAULT → ЧЁРНЫЙ футер. На live обёртка композитора даёт ту же схему —
// дубль безвреден. Пустой проп → :root (как раньше).
const footerSchemeClass =
	typeof p.colorScheme === "string" && p.colorScheme
		? `color-scheme-${String(p.colorScheme).replace("scheme-", "")}`
		: "";
---

<footer class:list={["w-full bg-[rgb(var(--color-bg,255_255_255))]", footerSchemeClass]} data-puck-component-id={id}>
	<div class={footerContainerCls} style={footerPadStyle}>
		<!-- Newsletter «Подпишитесь на нашу рассылку» -->
		{newsletterEnabled && (
		<section class={`flex w-full flex-col gap-6 ${nlSectionAlignCls}`} aria-labelledby="newsletter-heading">
			<div class={`flex flex-col gap-2 ${nlCopyAlignCls}`}>
				<h2
					id="newsletter-heading"
					class="font-roboto-flex text-[18px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))] md:text-[20px]"
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="newsletter"
				>
					{nlHeading}
				</h2>
				<p class="font-roboto-flex text-[14px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] md:text-[16px]">
					{nlDescription}
				</p>
			</div>

			<form
				class="flex h-14 w-full max-w-[652px] items-center justify-between gap-2 rounded-[var(--radius-input,8px)] border border-[rgb(var(--color-surface,245_245_245))] bg-white px-4 md:h-16"
				data-newsletter-form
				data-puck-subsection-parent={id}
				data-puck-subsection-index="997"
				data-puck-subsection-field="newsletter"
			>
				<input
					type="email"
					name="email"
					required
					placeholder={nlPlaceholder}
					aria-label="Email"
					class="min-w-0 flex-1 bg-transparent font-roboto-flex text-[16px] font-light leading-normal text-[#000000] placeholder:text-[#999999] outline-none md:text-[20px]"
				/>
				<button
					type="submit"
					aria-label="Подписаться"
					class="flex size-8 shrink-0 items-center justify-center transition-opacity hover:opacity-80"
				>
					<NtIcon name="arrow-right" sizeClass="size-8" />
				</button>
			</form>
			<p
				data-newsletter-status
				role="status"
				class="hidden font-roboto-flex text-[12px] font-light text-[#4AD300] md:text-[14px]"
			></p>
		</section>
		)}

		<!-- Links: НАВИГАЦИЯ / ИНФОРМАЦИЯ / СОЦИАЛЬНЫЕ СЕТИ -->
		<section
			class={`flex w-full flex-col gap-10 md:flex-row md:items-start ${colsJustifyCls}`}
			aria-label="Навигация по сайту"
		>
			<div class={`flex flex-col gap-10 sm:flex-row ${navInfoGapCls}`}>
				<div
					class={`flex flex-col gap-4 md:w-[318px] ${colInnerCls}`}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="996"
					data-puck-subsection-field="navigationColumn"
				>
					{navColTitle && <h3 class={columnTitleCls}>{navColTitle}</h3>}
					<ul class="flex flex-col gap-3" role="list">
						{navLinks.map((link) => (
							<li>
								<a href={link.href} class={linkCls}>
									{link.label}
								</a>
							</li>
						))}
					</ul>
				</div>

				{infoLinks.length > 0 && (
				<div
					class={`flex flex-col gap-4 md:w-[318px] ${colInnerCls}`}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="995"
					data-puck-subsection-field="informationColumn"
				>
					{infoColTitle && <h3 class={columnTitleCls}>{infoColTitle}</h3>}
					<ul class="flex flex-col gap-3" role="list">
						{infoLinks.map((link) => (
							<li>
								<a href={link.href} class={linkCls}>
									{link.label}
								</a>
							</li>
						))}
					</ul>
				</div>
				)}
			</div>

			{socialColumnHasContent && (
			<div
				class={`flex flex-col gap-4 md:w-[318px] ${socialColCls}`}
				data-puck-subsection-parent={id}
				data-puck-subsection-index="994"
				data-puck-subsection-field="socialColumn"
			>
				{socialColTitle && <h3 class={columnTitleCls}>{socialColTitle}</h3>}
				<div class={`flex flex-1 flex-col gap-6 ${socialInnerCls}`}>
					{(phone || email || contactFields.length > 0) && (
					<div class={`flex flex-col gap-3 ${contactColCls}`}>
						{phone && (
						<a href={`tel:${phone.replace(/[^+\d]/g, "")}`} class={`${linkCls} ${contactTextCls}`}>
							{phone}
						</a>
						)}
						{email && (
						<a href={`mailto:${email}`} class={`${linkCls} ${contactTextCls}`}>
							{email}
						</a>
						)}
						{contactFields.map((f) => (
						<div class={`font-roboto-flex text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] ${contactTextCls}`}>
							<span class="text-[rgb(var(--color-heading,0_0_0))]">{f.label}:</span> {f.value}
						</div>
						))}
					</div>
					)}
					{socials.length > 0 && (
					<div class="flex items-center gap-4">
						{socials.map((s: any) => (
							<a
								href={s.href}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={s.platform}
								class="flex size-6 items-center justify-center transition-opacity hover:opacity-70"
							>
								<NtIcon name={s.icon as any} sizeClass="size-6" />
							</a>
						))}
					</div>
					)}
					{paymentEnabled && (
					<div class={`flex flex-wrap items-center gap-3 ${paymentJustifyCls}`} aria-label="Способы оплаты">
						<img src={withBase("/icons/MasterCard.svg")} alt="Mastercard" class="h-6 w-auto shrink-0" decoding="async" />
						<img src={withBase("/icons/Visa.png")} alt="Visa" class="h-6 w-auto shrink-0" decoding="async" />
						<img src={withBase("/icons/MIR.png")} alt="МИР" class="h-6 w-auto shrink-0" decoding="async" />
					</div>
					)}
				</div>
			</div>
			)}
		</section>
	</div>

	<!-- Copyright — чёрная полоса (Inter, фикс-роль Figma flux) -->
	{bottomStripVisible && (
		<div
			class="flex h-[80px] w-full items-center justify-center bg-[rgb(var(--color-heading,0_0_0))] md:h-[100px]"
			data-puck-subsection-parent={id}
			data-puck-subsection-index="992"
			data-puck-subsection-field="bottomStrip"
		>
			<p
				class="px-4 text-center font-inter text-[14px] font-light leading-normal text-[rgb(var(--color-bg,255_255_255))] md:text-[20px]"
				data-puck-subsection-parent={id}
				data-puck-subsection-index="993"
				data-puck-subsection-field="copyright"
			>
				{stripText}
			</p>
		</div>
	)}
</footer>

<script is:inline define:vars={{ shopId, apiUrl }}>
	// Реальная отправка подписки на gateway (была demo-заглушка — фейковое «Спасибо» без
	// запроса). store_id — из пропатченного shopId (деплой) либо window.__MERFY_SITE_ID__
	// (превью). Гард __merfyNewsletterWired исключает двойную привязку, если на странице
	// есть и эта форма, и секция Newsletter; статус ищем в пределах своей секции.
	(function () {
		window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
			shopId: shopId || "",
			apiUrl: apiUrl || "https://gateway.merfy.ru/api",
		};
		var cfg = window.__MERFY_CONFIG__;
		var base = String(cfg.apiUrl || "https://gateway.merfy.ru/api").replace(/\/+$/, "");
		var storeId = cfg.shopId || window.__MERFY_SITE_ID__ || "";

		function wire(form) {
			if (!form || form.__merfyNewsletterWired) return;
			form.__merfyNewsletterWired = true;
			var section = form.closest("section") || document;
			var status = section.querySelector("[data-newsletter-status]");
			var btn = form.querySelector('button[type="submit"]');

			function show(msg, isError) {
				if (!status) return;
				status.textContent = msg;
				status.style.color = isError ? "#E11D48" : "";
				status.classList.remove("hidden");
			}

			form.addEventListener("submit", function (event) {
				event.preventDefault();
				var input = form.querySelector('input[type="email"]');
				var email = input ? String(input.value || "").trim() : "";
				if (!email) return;
				if (btn) btn.disabled = true;
				show("Отправляем…", false);

				fetch(base + "/storefront/newsletter/subscribe", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ store_id: storeId, email: email }),
				})
					.then(function (res) {
						return res
							.json()
							.catch(function () { return {}; })
							.then(function (data) { return { ok: res.ok, code: res.status, data: data }; });
					})
					.then(function (r) {
						if (r.ok) {
							show(
								r.data && r.data.alreadySubscribed
									? "Вы уже подписаны на рассылку."
									: "Спасибо! Мы отправим вам приветственное письмо.",
								false,
							);
							form.reset();
						} else if (r.code === 429) {
							show("Слишком много попыток. Попробуйте позже.", true);
						} else {
							show("Не удалось подписаться. Попробуйте позже.", true);
						}
					})
					.catch(function () {
						show("Не удалось подписаться. Проверьте соединение.", true);
					})
					.finally(function () {
						if (btn) btn.disabled = false;
					});
			});
		}

		function init() {
			var forms = document.querySelectorAll("[data-newsletter-form]");
			for (var i = 0; i < forms.length; i++) wire(forms[i]);
		}
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", init);
		} else {
			init();
		}
	})();
</script>
