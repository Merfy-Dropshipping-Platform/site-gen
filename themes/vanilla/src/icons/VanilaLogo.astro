---
/**
 * Вордмарк «Vanila» — SVG из Figma (футер/хедер, 89×28, #FFFFFF).
 *
 * `?url`-импорт заменён на public-путь (паттерн VanilaFooterLogo): Vite-импорты
 * не резолвятся при компиляции канон-секций (Container API, Фаза B), а
 * `public/icons/Vanila.svg` доступен и статическому билду, и live-композиции.
 */
import { withBase } from "../lib/with-base";

interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<img
	src={withBase("/icons/Vanila.svg")}
	alt=""
	width="89"
	height="28"
	loading="eager"
	decoding="async"
	draggable={false}
	aria-hidden="true"
	class:list={["block shrink-0 object-contain object-center", className]}
/>
