---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { SITE_TITLE } from "../consts";
import { catalogProducts } from "../data/products";

const searchIndex = catalogProducts.map((p) => ({
	id: p.id,
	name: p.name,
	price: p.price,
	image: p.image,
	href: `/products/${p.id}`,
}));

interface NavLink {
	label: string;
	href: string;
	mega?: boolean;
	match?: (pathname: string) => boolean;
}

const defaultNav: NavLink[] = [
	{ label: "Коллекции", href: "/catalog", mega: true, match: (p) => p === "/" || p.startsWith("/catalog") || p.startsWith("/products") },
	{ label: "История", href: "/about", match: (p) => p.startsWith("/about") },
	{ label: "Контакты", href: "/contacts" },
];

// Mega-menu (Коллекции hover) — mirrors the Figma "List" dropdown.
const womenCats = ["Верхняя одежда", "Джемперы и кардиганы", "Худи и свитшоты", "Футболки и топы", "Джинсы и брюки", "Костюмы", "Аксессуары"];
const menCats = ["Верхняя одежда", "Джемперы и кардиганы", "Худи и свитшоты", "Футболки и поло", "Джинсы и шорты", "Костюмы", "Аксессуары"];
const socials = [
	{ name: "social-telegram", href: "https://t.me/", label: "Telegram" },
	{ name: "social-tiktok", href: "https://tiktok.com/", label: "TikTok" },
	{ name: "social-vk", href: "https://vk.com/", label: "VK" },
	{ name: "social-youtube", href: "https://youtube.com/", label: "YouTube" },
	{ name: "social-yandex-dzen", href: "https://dzen.ru/", label: "Дзен" },
];

// ОЖИВЛЕНИЕ (Фаза B, объём rose/bloom Header): канон-схема theme-base Header.puckConfig —
// siteTitle, navigationLinks, logo, logoPosition, stickiness, padding. Тело ниже —
// verbatim верстальщика; дефолтные ветки тернарников = прежним строкам байт-в-байт
// (цвета → токены с пиксель-фоллбеком MANNER.md §7).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустая строка (впрыск коэрсера live-пути) не должна гасить название магазина.
const siteTitle = typeof p.siteTitle === "string" && p.siteTitle.trim() ? p.siteTitle : SITE_TITLE;
const navFromProps = Array.isArray(p.navigationLinks) && p.navigationLinks.length > 0;
const nav: NavLink[] = navFromProps
	? p.navigationLinks.map((l: any) => ({ label: l.label ?? l.text ?? "", href: l.href ?? l.link ?? "/" }))
	: defaultNav;
// Мега-меню живёт на хардкод-рубриках womenCats/menCats и data-mega-trigger
// дефолт-навигации — при заданном пропе navigationLinks его НЕ рендерим.
const showMega = !navFromProps;

// Канон logo (URL картинки; панель «Логотип» пишет в props.logo): непустая строка →
// <img> ВЫСОТОЙ var(--size-logo-width) (семантика канона: слайдер «Размер» задаёт
// высоту лого) в mobile И desktop. Дефолт = ТЕКСТОВЫЙ лого Kelly Slab верстальщика
// (desktop 22px / mobile text-lg), фоллбек токена = родные 22px.
const logo = typeof p.logo === "string" && p.logo.trim() ? p.logo : undefined;
const logoImgCls = "h-[var(--size-logo-width,22px)] w-auto max-w-[160px] object-contain";

// Канон logoPosition: 4 значения (center-left / center-absolute / top-left / top-center).
// 'center-absolute' / отсутствие / неизвестное значение → ЛИТЕРАЛ верстальщика —
// лого абсолютным центром desktop-строки (designer default сатина).
// 'center-left' («Слева») → лого первым слева перед навигацией.
// 'top-left' / 'top-center' → двустрочный макет (isTwoRow = true).
const logoPosition = typeof p.logoPosition === "string" ? p.logoPosition : "";
const logoLeft = logoPosition === "center-left";
const isTwoRow = logoPosition === "top-left" || logoPosition === "top-center";

// Single-row: лого-класс зависит от logoLeft (center-left vs center-absolute default).
const desktopLogoCls = logoLeft
	? "order-first font-logo text-[22px] font-normal uppercase leading-none text-[rgb(var(--color-heading,0_0_0))] hover:opacity-90"
	: "font-logo absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-[22px] font-normal uppercase leading-none text-[rgb(var(--color-heading,0_0_0))] hover:opacity-90";
const desktopIconsCls = logoLeft ? "ml-auto flex items-center gap-5" : "flex items-center gap-5";

// Канон stickiness: литерал верстальщика УЖЕ sticky top-0 z-50 (H:42) — 'none' /
// 'always' / отсутствие → sticky остаётся (правило canon-default → пиксель).
// 'scroll-up' → прячем при скролле вниз, показываем при скролле вверх: is:inline
// скрипт через data-атрибут (компилятор секций не умеет define:vars),
// идемпотентность через data-hydrated.
const stickiness = typeof p.stickiness === "string" ? p.stickiness : "";
const rootCls =
	stickiness === "scroll-up"
		? "sticky top-0 z-50 w-full transition-transform duration-300"
		: "sticky top-0 z-50 w-full";
const SCROLL_UP_JS = [
	"(function(){",
	"var root=document.querySelector('[data-satin-sticky=\"scroll-up\"]');",
	"if(!root||root.getAttribute('data-hydrated')==='true')return;",
	"root.setAttribute('data-hydrated','true');",
	"var last=window.scrollY;",
	"window.addEventListener('scroll',function(){",
	"var y=window.scrollY;",
	"if(y>last&&y>root.offsetHeight){root.style.transform='translateY(-100%)';}else{root.style.transform='';}",
	"last=y;",
	"},{passive:true});",
	"})();",
].join("");

// Канон padding {top,bottom} — clamp ≤64 на носителе отступов верстальщика
// (desktop-строка h-16 фиксированная; мобильная строка h-14 не трогаем).
// {12,12} = canon-default puckConfig (его впрыскивает коэрсер; в theme.json satin
// override'а нет) → ЛИТЕРАЛ h-16; inline-стиль только при ином значении.
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const isCanonPad = pad && Number(pad.top) === 12 && Number(pad.bottom) === 12;
const headerPad =
	pad && !isCanonPad
		? { top: Math.min(Number(pad.top) || 0, 64), bottom: Math.min(Number(pad.bottom) || 0, 64) }
		: undefined;
const headerPadStyle = headerPad
	? `padding-top:${headerPad.top}px;padding-bottom:${headerPad.bottom}px;`
	: undefined;
// Single-row container (center-left / center-absolute).
const desktopRowCls = [
	"satin-pad relative mx-auto hidden",
	headerPad ? "" : "h-16",
	"w-full max-w-[1920px] items-center",
	logoLeft ? "gap-8" : "justify-between",
	"md:flex",
]
	.filter(Boolean)
	.join(" ");

// Канон menuType: 'dropdown' (по умолчанию) / 'mega-menu' (Расширенное) / 'sidebar' (Боковое).
// Для mega-menu добавляем uppercase + tracking к десктопным ссылкам нав-меню.
// Для sidebar — десктопный inline-nav скрыт, показывается hamburger → правая шторка.
const menuType = typeof p.menuType === "string" ? p.menuType : "dropdown";
const isMegaMenu = menuType === "mega-menu";
const isSidebar = menuType === "sidebar";
const megaLinkCls = isMegaMenu ? "uppercase tracking-[0.06em] font-medium" : "";

// Канон menuColorScheme: опциональная отдельная цветовая схема для десктопного <nav>.
// При задании — добавляем класс color-scheme-<X> к обёртке <nav>.
const menuColorScheme = typeof p.menuColorScheme === "string" ? p.menuColorScheme : "";
const menuSchemeClass = menuColorScheme ? `color-scheme-${menuColorScheme.replace("scheme-", "")}` : "";

const pathname = Astro.url.pathname;
const isActive = (link: NavLink) => (link.match ? link.match(pathname) : pathname === link.href);
---

<div class={rootCls} data-puck-component-id={id} data-satin-sticky={stickiness === "scroll-up" ? "scroll-up" : undefined}>
	{
		/* Встроенная полоса объявления — ТОЛЬКО статик-режим (без props.id):
		   в канон-композиции полоса = отдельная секция PromoBanner, иначе дубль. */
		!id && (
			<a href="/catalog" class="block bg-black py-2 text-center font-manrope text-[11px] font-normal uppercase tracking-[0.04em] text-white transition-opacity hover:opacity-80 md:text-[14px]">
				Скидка 10% на общую сумму заказа от 9 000₽. Перейти
			</a>
		)
	}

	<header class="relative w-full border-b border-[rgb(var(--color-text,0_0_0)/13%)] bg-[rgb(var(--color-bg,255_255_255))]" data-nt="satin-header">
		<!-- Mobile Header: 375px - 440px -->
		<div class="relative z-[60] flex h-14 items-center justify-between bg-[rgb(var(--color-bg,255_255_255))] px-4 md:hidden">
			<button
				type="button"
				id="satin-burger-btn"
				data-burger-toggle
				class="flex h-10 w-10 items-center justify-center transition-opacity hover:opacity-70"
				aria-label="Меню"
				aria-expanded="false"
				aria-controls="satin-burger"
			>
				<span class="burger-icon" data-icon="open">
					<NtIcon name="menu-burger" sizeClass="size-6" />
				</span>
				<span class="burger-icon hidden" data-icon="close">
					<NtIcon name="menu-close" sizeClass="size-6" />
				</span>
			</button>
			<a href="/" class="font-logo text-lg font-normal uppercase leading-none text-[rgb(var(--color-heading,0_0_0))] hover:opacity-80">
				{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
			</a>
			<div class="flex items-center gap-4">
				<a href="#" data-action="toggle-search" class="flex h-6 w-6 items-center justify-center" aria-label="Поиск">
					<NtIcon name="search-sm" sizeClass="size-6" />
				</a>
				<a href="/wishlist" class="relative flex h-6 w-6 items-center justify-center transition-opacity hover:opacity-80" aria-label="Избранное">
					<NtIcon name="favourite" sizeClass="size-6" />
					<span data-wishlist-count data-empty="true" class="absolute -right-2 -top-2 inline-flex h-4 min-w-4 items-center justify-center bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
				</a>
				<button type="button" data-cart-open class="relative flex h-6 w-6 items-center justify-center" aria-label="Корзина">
					<NtIcon name="cart-sm" sizeClass="size-6" />
					<span data-cart-count data-empty="true" class="absolute -right-2 -top-2 inline-flex h-4 min-w-4 items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
				</button>
			</div>
		</div>

		<!-- Desktop Header: 768px+ -->
		<div class="hidden w-full md:block">
			{isTwoRow ? (
				/* ── TWO-ROW LAYOUTS: top-left / top-center ── */
				<div
					class={[
						"satin-pad mx-auto flex w-full max-w-[1920px] flex-col",
						headerPad ? "" : "py-4",
					].filter(Boolean).join(" ")}
					style={headerPadStyle}
				>
					{logoPosition === "top-left" ? (
						/* top-left: Row1=[logo LEFT + actions RIGHT], Row2=[nav LEFT] */
						<>
							<div class="flex w-full items-center justify-between">
								<a
									href="/"
									class="font-logo text-[22px] font-normal uppercase leading-none text-[rgb(var(--color-heading,0_0_0))] hover:opacity-90"
								>
									{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
								</a>
								<div class="flex items-center gap-5">
									<button type="button" data-action="toggle-search" class="flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Поиск">
										<NtIcon name="search-lg" sizeClass="size-8" />
									</button>
									<a href="/wishlist" class="relative flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Избранное">
										<NtIcon name="favourite" sizeClass="size-8" />
										<span data-wishlist-count data-empty="true" class="absolute -right-1.5 -top-1.5 inline-flex h-4 min-w-4 items-center justify-center bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
									</a>
									<button type="button" data-cart-open class="relative flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Корзина">
										<NtIcon name="cart" sizeClass="size-8" />
										<span data-cart-count data-empty="true" class="absolute right-0 top-0 inline-flex h-4 min-w-4 items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
									</button>
									{isSidebar && (
										<button
											type="button"
											data-burger-toggle
											class="flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80"
											aria-label="Меню"
											aria-expanded="false"
											aria-controls="satin-burger"
										>
											<span class="burger-icon" data-icon="open">
												<NtIcon name="menu-burger" sizeClass="size-6" />
											</span>
											<span class="burger-icon hidden" data-icon="close">
												<NtIcon name="menu-close" sizeClass="size-6" />
											</span>
										</button>
									)}
								</div>
							</div>
							<nav
								class:list={["mt-3 flex w-full items-center justify-center gap-8", menuSchemeClass, isSidebar && "md:!hidden"]}
								aria-label="Основная навигация"
								data-puck-subsection-parent={id}
								data-puck-subsection-index="997"
								data-puck-subsection-field="navigationLinks"
							>
								{nav.map((link) => {
									const active = isActive(link);
									return (
										<a
											href={link.href}
											aria-current={active ? "page" : undefined}
											data-mega-trigger={link.mega ? "" : undefined}
											aria-haspopup={link.mega ? "true" : undefined}
											aria-expanded={link.mega ? "false" : undefined}
											class:list={[
												"group/mega relative inline-flex items-center gap-1 pb-1 font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70",
												active && "after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-[rgb(var(--color-text,0_0_0))] after:content-['']",
												megaLinkCls,
											]}
										>
											{link.label}
											{link.mega && (
												<NtIcon
													name="dropdown-chevron"
													sizeClass="size-4"
													class="satin-mega-caret transition-transform duration-150"
												/>
											)}
										</a>
									);
								})}
							</nav>
						</>
					) : (
						/* top-center: Row1=[search LEFT | logo CENTER | cart+favourite+user RIGHT], Row2=[nav CENTER] */
						<>
							<div class="grid w-full grid-cols-[1fr_auto_1fr] items-center">
								<div class="flex items-center">
									<button type="button" data-action="toggle-search" class="flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Поиск">
										<NtIcon name="search-lg" sizeClass="size-8" />
									</button>
								</div>
								<div class="flex items-center justify-center">
									<a
										href="/"
										class="font-logo text-[22px] font-normal uppercase leading-none text-[rgb(var(--color-heading,0_0_0))] hover:opacity-90"
									>
										{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
									</a>
								</div>
								<div class="flex items-center justify-end gap-5">
									<a href="/wishlist" class="relative flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Избранное">
										<NtIcon name="favourite" sizeClass="size-8" />
										<span data-wishlist-count data-empty="true" class="absolute -right-1.5 -top-1.5 inline-flex h-4 min-w-4 items-center justify-center bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
									</a>
									<button type="button" data-cart-open class="relative flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Корзина">
										<NtIcon name="cart" sizeClass="size-8" />
										<span data-cart-count data-empty="true" class="absolute right-0 top-0 inline-flex h-4 min-w-4 items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
									</button>
									{isSidebar && (
										<button
											type="button"
											data-burger-toggle
											class="flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80"
											aria-label="Меню"
											aria-expanded="false"
											aria-controls="satin-burger"
										>
											<span class="burger-icon" data-icon="open">
												<NtIcon name="menu-burger" sizeClass="size-6" />
											</span>
											<span class="burger-icon hidden" data-icon="close">
												<NtIcon name="menu-close" sizeClass="size-6" />
											</span>
										</button>
									)}
								</div>
							</div>
							<nav
								class:list={["mt-3 flex w-full items-center justify-center gap-8", menuSchemeClass, isSidebar && "md:!hidden"]}
								aria-label="Основная навигация"
								data-puck-subsection-parent={id}
								data-puck-subsection-index="997"
								data-puck-subsection-field="navigationLinks"
							>
								{nav.map((link) => {
									const active = isActive(link);
									return (
										<a
											href={link.href}
											aria-current={active ? "page" : undefined}
											data-mega-trigger={link.mega ? "" : undefined}
											aria-haspopup={link.mega ? "true" : undefined}
											aria-expanded={link.mega ? "false" : undefined}
											class:list={[
												"group/mega relative inline-flex items-center gap-1 pb-1 font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70",
												active && "after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-[rgb(var(--color-text,0_0_0))] after:content-['']",
												megaLinkCls,
											]}
										>
											{link.label}
											{link.mega && (
												<NtIcon
													name="dropdown-chevron"
													sizeClass="size-4"
													class="satin-mega-caret transition-transform duration-150"
												/>
											)}
										</a>
									);
								})}
							</nav>
						</>
					)}
				</div>
			) : (
				/* ── SINGLE-ROW LAYOUTS: center-left / center-absolute ── */
				<div class={desktopRowCls} style={headerPadStyle}>
					<nav
						class:list={["flex items-center gap-8", menuSchemeClass, isSidebar && "md:!hidden"]}
						aria-label="Основная навигация"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="997"
						data-puck-subsection-field="navigationLinks"
					>
						{nav.map((link) => {
							const active = isActive(link);
							return (
								<a
									href={link.href}
									aria-current={active ? "page" : undefined}
									data-mega-trigger={link.mega ? "" : undefined}
									aria-haspopup={link.mega ? "true" : undefined}
									aria-expanded={link.mega ? "false" : undefined}
									class:list={[
										"group/mega relative inline-flex items-center gap-1 pb-1 font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70",
										active && "after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-[rgb(var(--color-text,0_0_0))] after:content-['']",
										megaLinkCls,
									]}
								>
									{link.label}
									{link.mega && (
										<NtIcon
											name="dropdown-chevron"
											sizeClass="size-4"
											class="satin-mega-caret transition-transform duration-150"
										/>
									)}
								</a>
							);
						})}
					</nav>

					<a href="/" class={desktopLogoCls}>
						{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
					</a>

					<div class={desktopIconsCls}>
						<button type="button" data-action="toggle-search" class="flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Поиск">
							<NtIcon name="search-lg" sizeClass="size-8" />
						</button>
						<a href="/wishlist" class="relative flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Избранное">
							<NtIcon name="favourite" sizeClass="size-8" />
							<span data-wishlist-count data-empty="true" class="absolute -right-1.5 -top-1.5 inline-flex h-4 min-w-4 items-center justify-center bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
						</a>
						<button type="button" data-cart-open class="relative flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80" aria-label="Корзина">
							<NtIcon name="cart" sizeClass="size-8" />
							<span data-cart-count data-empty="true" class="absolute right-0 top-0 inline-flex h-4 min-w-4 items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
						</button>
						{isSidebar && (
							<button
								type="button"
								data-burger-toggle
								class="flex h-8 w-8 items-center justify-center transition-opacity hover:opacity-80"
								aria-label="Меню"
								aria-expanded="false"
								aria-controls="satin-burger"
							>
								<span class="burger-icon" data-icon="open">
									<NtIcon name="menu-burger" sizeClass="size-6" />
								</span>
								<span class="burger-icon hidden" data-icon="close">
									<NtIcon name="menu-close" sizeClass="size-6" />
								</span>
							</button>
						)}
					</div>
				</div>
			)}
		</div>

		<!-- Mega-menu (desktop) — opens on Коллекции hover/focus -->
		{showMega && (
			<div
				data-mega-panel
				class="invisible absolute inset-x-0 top-full z-50 hidden opacity-0 transition-opacity duration-150 data-[open=true]:visible data-[open=true]:opacity-100 md:block"
			>
				<div class="satin-pad mx-auto w-full max-w-[1920px]">
					<div class="grid grid-cols-4 bg-[rgb(var(--color-surface,245_245_245))] p-4">
						<div class="flex flex-col gap-3">
							<span class="font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))]">Для неё и для него</span>
							<a href="/catalog" class="font-manrope text-[14px] font-light uppercase leading-normal text-[#999999] transition-opacity hover:opacity-70">Смотреть всё</a>
						</div>
						<div class="flex flex-col gap-3">
							<a href="/catalog?collection=Женское" class="font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70">Женская коллекция</a>
							<ul class="flex flex-col gap-2" role="list">
								{womenCats.map((cat) => (
									<li><a href="/catalog?collection=Женское" class="font-manrope text-[14px] font-light uppercase leading-normal text-[#999999] transition-opacity hover:opacity-70">{cat}</a></li>
								))}
							</ul>
						</div>
						<div class="flex flex-col gap-3">
							<a href="/catalog?collection=Мужское" class="font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70">Мужская коллекция</a>
							<ul class="flex flex-col gap-2" role="list">
								{menCats.map((cat) => (
									<li><a href="/catalog?collection=Мужское" class="font-manrope text-[14px] font-light uppercase leading-normal text-[#999999] transition-opacity hover:opacity-70">{cat}</a></li>
								))}
							</ul>
						</div>
						<div class="flex items-start gap-2 justify-self-end">
							{socials.map((s) => (
								<a href={s.href} target="_blank" rel="noopener noreferrer" class="flex h-6 w-6 items-center justify-center transition-opacity hover:opacity-70" aria-label={s.label}>
									<NtIcon name={s.name} sizeClass="size-6" />
								</a>
							))}
						</div>
					</div>
				</div>
			</div>
		)}

		<!-- Search Panel -->
		<div data-search-panel class="satin-pad hidden w-full border-t border-[#DDDDDD] bg-[rgb(var(--color-bg,255_255_255))] py-4" hidden>
			<form role="search" action="/catalog" method="get" class="satin-container flex h-10 items-center justify-between gap-2 border border-[#DDDDDD] bg-white pl-3 pr-1">
				<input type="search" name="q" placeholder="Поиск..." aria-label="Поиск" autocomplete="off" class="min-w-0 flex-1 bg-transparent font-manrope text-sm font-light leading-normal text-[#000000] placeholder:text-[#999999] outline-none" />
				<button type="submit" class="flex h-8 shrink-0 items-center justify-center bg-[#000000] px-4 font-manrope text-[12px] font-normal uppercase leading-normal text-white transition-opacity hover:opacity-95">Найти</button>
			</form>
			<div data-search-results role="listbox" aria-label="Подсказки поиска" class="satin-container mt-1 hidden flex-col border border-[#DDDDDD] bg-white"></div>
		</div>
	</header>

	<!-- Mobile Burger Menu / Desktop Sidebar Drawer -->
	<div
		id="satin-burger"
		class:list={[
			"fixed z-[55] hidden overflow-y-auto bg-[rgb(var(--color-bg,255_255_255))]",
			isSidebar
				? "inset-y-0 right-0 bottom-0 w-[360px] max-w-[90vw] px-6 pt-6 pb-8"
				: "inset-x-0 top-[56px] bottom-0 w-full px-4 pt-4 pb-8 md:hidden",
		]}
		role="dialog"
		aria-modal="true"
		aria-label="Меню"
	>
		{isSidebar ? (
			/* Sidebar drawer: logo + cart at top */
			<div class="flex items-center justify-between">
				<a
					href="/"
					class="font-logo text-[length:var(--size-logo-width,22px)] font-normal uppercase leading-none text-[rgb(var(--color-heading,0_0_0))] hover:opacity-90"
				>
					{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
				</a>
				<div class="flex items-center gap-4">
					<a
						href="/wishlist"
						class="relative flex h-8 w-8 shrink-0 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Избранное"
					>
						<NtIcon name="favourite" sizeClass="size-6" />
						<span data-wishlist-count data-empty="true" class="absolute -right-1.5 -top-1.5 inline-flex h-4 min-w-4 items-center justify-center bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
					</a>
					<button
						type="button"
						data-cart-open
						class="relative flex h-8 w-8 shrink-0 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Корзина"
					>
						<NtIcon name="cart" sizeClass="size-6" />
						<span data-cart-count data-empty="true" class="absolute right-0 top-0 inline-flex h-4 min-w-4 items-center justify-center bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden">0</span>
					</button>
				</div>
			</div>
		) : (
			/* Mobile drawer: search + profile */
			<>
				<div class="flex items-center gap-2">
					<form class="flex h-10 min-h-10 flex-1 items-center justify-between border border-[#DDDDDD] bg-white pl-3 pr-2" role="search" action="/catalog" method="get">
						<input type="search" name="q" placeholder="Поиск" autocomplete="off" class="min-w-0 flex-1 bg-transparent font-manrope text-xs font-normal leading-normal text-[#000000] placeholder:text-[#999999] outline-none" />
						<button type="submit" class="flex h-6 w-6 shrink-0 items-center justify-center" aria-label="Найти">
							<NtIcon name="search-sm" sizeClass="size-6" />
						</button>
					</form>
					<a href="/login" data-auth-link class="flex h-10 w-10 shrink-0 items-center justify-center bg-[#000000]" aria-label="Профиль">
						<NtIcon name="user" sizeClass="size-6" />
					</a>
				</div>
				<div data-search-results role="listbox" aria-label="Подсказки поиска" class="mt-2 hidden flex-col border border-[#DDDDDD] bg-white"></div>
			</>
		)}

		<nav class:list={["flex flex-col gap-4", isSidebar ? "mt-10" : "mt-8"]} aria-label="Основное меню">
			{nav.map((link) => {
				const active = isActive(link);
				return (
					<div class="flex flex-col gap-1.5">
						<a href={link.href} class:list={["font-manrope text-xs font-normal uppercase leading-normal", active ? "text-[rgb(var(--color-text,0_0_0))]" : "text-[#606060]"]}>{link.label}</a>
						{active && <div class="h-0.5 w-12 bg-[rgb(var(--color-text,0_0_0))]" aria-hidden="true"></div>}
					</div>
				);
			})}
			<a href="/cart" class="font-manrope text-xs font-normal uppercase leading-normal text-[#606060]">Корзина</a>
			<a href="/auth/sign-up" class="font-manrope text-xs font-normal uppercase leading-normal text-[#606060]">Регистрация</a>
		</nav>
	</div>

	{stickiness === "scroll-up" && <script is:inline set:html={SCROLL_UP_JS} />}
</div>

<script>
	const burger = document.getElementById("satin-burger");

	const isSidebarDrawer = () => burger ? burger.classList.contains("inset-y-0") : false;

	const syncBurgerButtonIcons = (open: boolean) => {
		// Update ALL burger toggle buttons (mobile #satin-burger-btn + desktop [data-burger-toggle])
		document.querySelectorAll<HTMLElement>("[data-burger-toggle]").forEach((btn) => {
			btn.setAttribute("aria-expanded", String(open));
			btn.querySelectorAll<HTMLElement>(".burger-icon").forEach((el) => {
				const key = el.dataset.icon;
				if (key === "open") el.classList.toggle("hidden", open);
				else el.classList.toggle("hidden", !open);
			});
		});
	};

	const setBurger = (open: boolean) => {
		if (!burger) return;
		burger.classList.toggle("hidden", !open);
		syncBurgerButtonIcons(open);
		document.body.style.overflow = open ? "hidden" : "";
	};

	let delegateBound = false;
	const bindDelegatedClicks = () => {
		if (delegateBound) return;
		delegateBound = true;
		document.addEventListener("click", (event: MouseEvent) => {
			const el = event.target instanceof Element ? event.target : null;
			if (!el) return;
			if (el.closest("[data-burger-toggle]")) {
				event.preventDefault();
				setBurger(burger?.classList.contains("hidden") ?? false);
				return;
			}
			if (el.closest("#satin-burger a[href]")) {
				setBurger(false);
			}
		});
	};

	const syncBurgerAfterNavigation = () => {
		document.body.style.overflow = "";
		if (burger) burger.classList.add("hidden");
		syncBurgerButtonIcons(false);
	};

	bindDelegatedClicks();
	document.addEventListener("astro:page-load", syncBurgerAfterNavigation);
	syncBurgerAfterNavigation();

	// Mega-menu (Коллекции) — open on hover/focus, close with a small grace delay
	const megaTrigger = document.querySelector<HTMLElement>("[data-mega-trigger]");
	const megaPanel = document.querySelector<HTMLElement>("[data-mega-panel]");
	if (megaTrigger && megaPanel) {
		let closeTimer: ReturnType<typeof setTimeout> | undefined;
		const openMega = () => {
			clearTimeout(closeTimer);
			megaPanel.dataset.open = "true";
			megaPanel.classList.remove("hidden");
			megaTrigger.setAttribute("aria-expanded", "true");
		};
		const closeMega = () => {
			closeTimer = setTimeout(() => {
				megaPanel.dataset.open = "false";
				megaTrigger.setAttribute("aria-expanded", "false");
			}, 140);
		};
		megaTrigger.addEventListener("mouseenter", openMega);
		megaTrigger.addEventListener("focus", openMega);
		megaTrigger.addEventListener("mouseleave", closeMega);
		megaPanel.addEventListener("mouseenter", openMega);
		megaPanel.addEventListener("mouseleave", closeMega);
		megaTrigger.addEventListener("blur", closeMega);
		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape") {
				megaPanel.dataset.open = "false";
				megaTrigger.setAttribute("aria-expanded", "false");
			}
		});
	}

	document.querySelectorAll<HTMLElement>("[data-action='toggle-search']").forEach((el) => {
		el.addEventListener("click", (event) => {
			event.preventDefault();
			const panel = document.querySelector<HTMLElement>("[data-search-panel]");
			if (!panel) return;
			const hidden = panel.hasAttribute("hidden");
			if (hidden) {
				panel.removeAttribute("hidden");
				panel.classList.remove("hidden");
				panel.classList.add("block");
				panel.querySelector<HTMLInputElement>("input[type='search']")?.focus();
			} else {
				panel.setAttribute("hidden", "");
				panel.classList.add("hidden");
				panel.classList.remove("block");
			}
		});
	});
</script>
<script type="application/json" data-search-index set:html={JSON.stringify(searchIndex).replace(/<\//g, "<\\/")}></script>
