---
import type { MainTextProps } from './MainText.puckConfig';
import { MainTextClasses as C } from './MainText.classes';

interface Props extends MainTextProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  alignment: alignmentProp,
  cta: ctaProp,
  padding,
} = Astro.props as Props & { alignment?: string };

// Constructor legacy schema wraps heading as { text, size } and text as
// { content, size }. Accept both shapes so merchant revisions written by
// the constructor don't render as "[object Object]".
const readText = (v: unknown): string | undefined => {
  if (typeof v === 'string') return v || undefined;
  if (v && typeof v === 'object') {
    const o = v as { text?: string; content?: string };
    return o.text ?? o.content ?? undefined;
  }
  return undefined;
};
const heading = readText(raw.heading);
const text = readText(raw.text);
const alignment = (alignmentProp as 'left' | 'center' | 'right' | undefined)
  ?? (raw.align as 'left' | 'center' | 'right' | undefined)
  ?? (raw.position as 'left' | 'center' | 'right' | undefined)
  ?? 'center';

// Heading size: plain prop OR nested heading.size (legacy). Falls back to
// small (existing var-based size) for backwards-compatibility.
type HeadingSize = 'small' | 'medium' | 'large';
const readHeadingSize = (): HeadingSize => {
  const direct = raw.headingSize;
  if (direct === 'small' || direct === 'medium' || direct === 'large') return direct;
  if (raw.heading && typeof raw.heading === 'object') {
    const size = (raw.heading as { size?: string }).size;
    if (size === 'small' || size === 'medium' || size === 'large') return size;
  }
  return 'small';
};
const headingSize = readHeadingSize();
const headingSizeClass = C.headingSize[headingSize];

type CtaVariant = 'primary' | 'black' | 'white';
const readCta = (v: unknown): { text: string; href: string; variant: CtaVariant } | undefined => {
  if (!v || typeof v !== 'object') return undefined;
  const o = v as { text?: string; href?: string; variant?: string };
  const ctaText = typeof o.text === 'string' ? o.text.trim() : '';
  const ctaHref = typeof o.href === 'string' ? o.href.trim() : '';
  if (!ctaText || !ctaHref) return undefined;
  const variant: CtaVariant =
    o.variant === 'black' || o.variant === 'white' ? o.variant : 'primary';
  return { text: ctaText, href: ctaHref, variant };
};
const cta = readCta(ctaProp);

// 084 vanilla pilot: additive `buttonStyle` variant.
const buttonStyleProp =
  raw.buttonStyle === 'outlined' || raw.buttonStyle === 'solid'
    ? (raw.buttonStyle as 'outlined' | 'solid')
    : 'solid';
const buttonStyleClass = C.buttonStyle[buttonStyleProp];

// 084 vanilla pilot Stage 2 Task 6: `textStyle` propagation. `italic`
// applies italic to heading + body (vanilla home Figma 1:18984 demands
// Bitter Italic + Arsenal Italic).
const textStyleProp =
  raw.textStyle === 'italic' || raw.textStyle === 'normal'
    ? (raw.textStyle as 'italic' | 'normal')
    : 'normal';
const textStyleClass = C.textStyle[textStyleProp];

const alignClass = C.align[alignment];
const ctaAlignClass = C.ctaWrapAlign[alignment];
const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
const colorSchemeRaw = typeof raw.colorScheme === 'string' ? raw.colorScheme : undefined;
const schemeClass = colorSchemeRaw ? `color-scheme-${colorSchemeRaw.replace('scheme-', '')}` : '';
// NOTE: `text` supports basic HTML (<b>, <i>) via set:html.
// Constructor inputs should sanitize HTML before persisting to DB to prevent XSS.
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-alignment={alignment}
  style={paddingStyle}
>
  <div class:list={[C.container, alignClass, textStyleClass]}>
    {heading && (
      <h2 class:list={[C.heading, headingSizeClass, textStyleClass]} data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">{heading}</h2>
    )}
    {text && (
      <div class:list={[C.text, textStyleClass]} data-puck-subsection-parent={id} data-puck-subsection-index="101" data-puck-subsection-field="text" set:html={text} />
    )}
    {cta && (
      <div class:list={[C.ctaWrap, ctaAlignClass]}>
        <a href={cta.href} class:list={[C.cta[cta.variant], buttonStyleClass]} data-puck-subsection-parent={id} data-puck-subsection-index="102" data-puck-subsection-field="cta">{cta.text}</a>
      </div>
    )}
  </div>
</section>
