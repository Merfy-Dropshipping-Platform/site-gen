---
import RoseNtIcon from "./icons/RoseNtIcon.astro";
import NavItem from "./NavItem.astro";
import { SITE_TITLE } from "../consts";

interface NavLink {
	label: string;
	href: string;
	submenu?: NavLink[];
	match?: (pathname: string) => boolean;
}

const defaultNav: NavLink[] = [
	{ label: "Главная", href: "/", match: (p) => p === "/" },
	{ label: "Каталог", href: "/catalog", match: (p) => p.startsWith("/catalog") || p.startsWith("/products") },
	{ label: "Контакты", href: "/contacts", match: (p) => p.startsWith("/contacts") },
];

// ОЖИВЛЕНИЕ: канон-схема Header (siteTitle, navigationLinks — Фаза 2;
// logo, logoPosition, stickiness, padding — T12). Дефолтные ветки тернарников =
// прежним строкам классов байт-в-байт; новые элементы не рендерятся без пропсов.
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустая строка (впрыск коэрсера live-пути) не должна гасить текстовый логотип.
const siteTitle = typeof p.siteTitle === "string" && p.siteTitle.trim() ? p.siteTitle : SITE_TITLE;
// Рекурсивно сохраняем submenu (до 3 уровней) — иначе вложенные меню теряются.
const mapNavLink = (l: any): NavLink => ({
	label: l.label ?? l.text ?? "",
	href: l.href ?? l.link ?? "/",
	submenu: Array.isArray(l.submenu) ? l.submenu.map(mapNavLink) : undefined,
});
const nav: NavLink[] = Array.isArray(p.navigationLinks) && p.navigationLinks.length > 0
	? p.navigationLinks.map(mapNavLink)
	: defaultNav;

// Канон logo (URL картинки; панель «Логотип» пишет в props.logo через
// applyBrandLogoToAllHeaders): непустая строка → <img> вместо текстового
// логотипа в desktop И mobile. Высота = --size-logo-width (семантика канона
// theme-base Header.classes.ts:71 — слайдер «Размер» задаёт ВЫСОТУ лого).
// Дефолтный плейсхолдер «/logo.svg» (и его rewrite до https://<slug>.merfy.ru/logo.svg)
// НЕ существует на сторфронте (404) → не рендерим <img> с битой картинкой. Реальные
// загрузки лежат в /branding/<tenant>/<site>/logo-*.svg (pathname НЕ "/logo.svg"),
// поэтому матчим именно pathname. Иначе — текстовый логотип (siteTitle), как у верстальщика.
const rawLogo = typeof p.logo === "string" ? p.logo.trim() : "";
let logoPath = "";
try {
	logoPath = new URL(rawLogo, "https://_merfy_").pathname;
} catch {
	logoPath = rawLogo;
}
const logo = rawLogo && logoPath !== "/logo.svg" ? rawLogo : undefined;
const logoImgCls = "h-[var(--size-logo-width,24px)] w-auto max-w-[160px] object-contain";

// Канон logoPosition: 'top-left' (canon default) / 'center-left' / отсутствие /
// неизвестное значение → строка верстальщика дословно (лого слева); 'top-center'
// и 'center-absolute' → лого absolute по центру строки (nav остаётся слева).
const logoPosition = typeof p.logoPosition === "string" ? p.logoPosition : "";
const logoCentered = logoPosition === "top-center" || logoPosition === "center-absolute";
// «Слева» (center-left): ОДНОрядно — лого слева, nav по ЦЕНТРУ страницы (равные
// flex-1 фланги logo+иконки → nav auto в центре), иконки справа. Эталон «Слева» (фото №2).
const logoLeft = logoPosition === "center-left";
const desktopLogoCls = logoCentered
	? "absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 font-comfortaa text-[length:var(--size-logo-width,24px)] font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-heading,0_0_0))] hover:opacity-90"
	: "shrink-0 font-comfortaa text-[length:var(--size-logo-width,24px)] font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-heading,0_0_0))] hover:opacity-90";

// Канон stickiness none/scroll-up/always (классы канона Header.classes.ts:13-16).
// 'none'/отсутствие = как сейчас (корень без sticky-классов).
const stickiness = typeof p.stickiness === "string" ? p.stickiness : "";
const rootCls =
	stickiness === "always"
		? "sticky top-0 z-50 w-full"
		: stickiness === "scroll-up"
			? "sticky top-0 z-50 w-full transition-transform duration-300"
			: "w-full";
// 'scroll-up': прячем хедер при скролле вниз, показываем при скролле вверх.
// is:inline + set:html (компилятор секций не умеет define:vars), параметры не
// нужны — root ищется по data-rose-sticky; идемпотентность через data-hydrated.
const SCROLL_UP_JS = [
	"(function(){",
	"var root=document.querySelector('[data-rose-sticky=\"scroll-up\"]');",
	"if(!root||root.getAttribute('data-hydrated')==='true')return;",
	"root.setAttribute('data-hydrated','true');",
	"var last=window.scrollY;",
	"window.addEventListener('scroll',function(){",
	"var y=window.scrollY;",
	"if(y>last&&y>root.offsetHeight){root.style.transform='translateY(-100%)';}else{root.style.transform='';}",
	"last=y;",
	"},{passive:true});",
	"})();",
].join("");

// Канон padding {top,bottom} — clamp ≤64 (как theme-base Header.astro:42-43) и
// inline-стиль ТОЛЬКО при заданном пропе на носителе отступов верстальщика
// (desktop-контейнер py-5 lg:py-6; мобильная строка h-11 фиксированная).
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const headerPad = pad
	? { top: Math.min(Number(pad.top) || 0, 64), bottom: Math.min(Number(pad.bottom) || 0, 64) }
	: undefined;
const headerPadStyle = headerPad
	? `padding-top:${headerPad.top}px;padding-bottom:${headerPad.bottom}px;`
	: undefined;
const desktopRowCls = [
	"mx-auto flex max-w-[1920px] items-center justify-between px-4",
	headerPad ? "" : "py-5",
	"sm:px-5 md:px-10 lg:px-16 xl:px-20 2xl:px-[280px]",
	headerPad ? "" : "lg:py-6",
	logoCentered ? "relative" : "",
]
	.filter(Boolean)
	.join(" ");

// Двухрядные раскладки: «Сверху слева» (top-left) и «Сверху в центре» (top-center).
// top-left = лого-слева + иконки-справа (ряд1), nav ПОД лого прижат ВЛЕВО (ряд2,
// justify-start) — эталон дизайнера «Слева сверху» (фото №1). top-center = grid, nav центр.
const isTwoRow = logoPosition === "top-left" || logoPosition === "top-center";

// Канон menuType: 'dropdown' (по умолчанию) / 'mega-menu' (Расширенное) / 'sidebar' (Боковое).
// Для mega-menu добавляем uppercase + tracking к десктопным ссылкам нав-меню.
// Для sidebar — десктопный inline-nav скрыт, показывается hamburger → правая шторка.
const menuType = typeof p.menuType === "string" ? p.menuType : "dropdown";
const isMegaMenu = menuType === "mega-menu";
const isSidebar = menuType === "sidebar";
const megaLinkCls = isMegaMenu ? "uppercase tracking-[0.06em] font-medium" : "";

// Канон menuColorScheme: опциональная отдельная цветовая схема для десктопного <nav>.
// При задании — добавляем класс color-scheme-<X> к обёртке <nav>.
const menuColorScheme = typeof p.menuColorScheme === "string" ? p.menuColorScheme : "";
const menuSchemeClass = menuColorScheme ? `color-scheme-${menuColorScheme.replace("scheme-", "")}` : "";

// Базовый класс десктоп-ссылки nav (общий для всех раскладок). Для mega — uppercase.
const navLinkCls = [
	"font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-all duration-200 hover:opacity-70 lg:text-[length:var(--size-nav-link,16px)]",
	megaLinkCls,
].filter(Boolean).join(" ");

const pathname = Astro.url.pathname;
const isActive = (link: NavLink) => (link.match ? link.match(pathname) : pathname === link.href);
---

<div class={rootCls} data-puck-component-id={id} data-rose-sticky={stickiness === "scroll-up" ? "scroll-up" : undefined}>
	<div class="overflow-visible bg-[rgb(var(--color-bg,255_255_255))]">
		<header class="relative w-full overflow-visible" data-nt="rose-header">
			<div>
				<!-- Mobile -->
				<div class="relative z-[60] flex h-11 items-center justify-between px-4 sm:px-5 md:px-10 lg:hidden">
					<button
						type="button"
						id="rose-burger-btn"
						data-burger-toggle
						class="flex size-5 shrink-0 items-center justify-center transition-opacity hover:opacity-70"
						aria-label="Меню"
						aria-expanded="false"
						aria-controls="rose-burger"
					>
						<span class="burger-icon" data-icon="open">
							<RoseNtIcon name="menu-burger" sizeClass="size-5" />
						</span>
						<span class="burger-icon hidden" data-icon="close">
							<RoseNtIcon name="menu-close" sizeClass="size-5" />
						</span>
					</button>
					<a
						href="/"
						class="font-comfortaa text-[20px] font-normal uppercase leading-none tracking-normal text-rose-primary hover:opacity-80"
					>
						{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
					</a>
					<div class="flex items-center gap-3">
						<a
							href="/wishlist"
							class="relative flex size-6 shrink-0 items-center justify-center transition-opacity hover:opacity-80"
							aria-label="Избранное"
						>
							<RoseNtIcon name="favourite" sizeClass="size-6" />
							<span
								data-wishlist-count
								data-empty="true"
								class="absolute -right-2 -top-2 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-rose-primary px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
							>0</span>
						</a>
						<button
							type="button"
							data-cart-open
							class="relative flex size-6 shrink-0 items-center justify-center"
							aria-label="Корзина"
						>
							<RoseNtIcon name="cart-sm" sizeClass="size-6" />
							<span
								data-cart-count
								data-empty="true"
								class="absolute -right-2 -top-2 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-rose-primary px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
							>0</span>
						</button>
					</div>
				</div>

				<!-- Desktop -->
				<div class="hidden w-full lg:block">
					{isTwoRow ? (
						/* ── TWO-ROW LAYOUTS: top-left / top-center ── */
						<div
							class={[
								"mx-auto flex max-w-[1920px] flex-col px-4",
								headerPad ? "" : "py-5",
								"sm:px-5 md:px-10 lg:px-16 xl:px-20 2xl:px-[280px]",
								headerPad ? "" : "lg:py-6",
							].filter(Boolean).join(" ")}
							style={headerPadStyle}
						>
							{logoPosition === "top-left" ? (
								/* top-left («Сверху слева», фото №1): Row1=[logo LEFT + actions RIGHT], Row2=[nav LEFT, justify-start] */
								<>
									<div class="flex w-full items-center justify-between">
										<a
											href="/"
											class="shrink-0 font-comfortaa text-[length:var(--size-logo-width,24px)] font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-heading,0_0_0))] hover:opacity-90"
										>
											{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
										</a>
										<div class="flex items-center gap-4 lg:gap-6">
											<button
												type="button"
												data-action="toggle-search"
												class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
												aria-label="Поиск"
												aria-expanded="false"
												aria-controls="rose-search-panel"
											>
												<RoseNtIcon name="search-lg" sizeClass="size-6" />
											</button>
											<a
												href="/wishlist"
												class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80"
												aria-label="Избранное"
											>
												<RoseNtIcon name="favourite" sizeClass="size-6" />
												<span
													data-wishlist-count
													data-empty="true"
													class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
												>0</span>
											</a>
											<button
												type="button"
												data-cart-open
												class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80"
												aria-label="Корзина"
											>
												<RoseNtIcon name="cart" sizeClass="size-6" />
												<span
													data-cart-count
													data-empty="true"
													class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
												>0</span>
											</button>
											<a
												href="/login"
												data-auth-link
												class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
												aria-label="Аккаунт"
											>
												<RoseNtIcon name="user" sizeClass="size-6" />
											</a>
											{isSidebar && (
												<button
													type="button"
													data-burger-toggle
													class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
													aria-label="Меню"
													aria-expanded="false"
													aria-controls="rose-burger"
												>
													<span class="burger-icon" data-icon="open">
														<RoseNtIcon name="menu-burger" sizeClass="size-6" />
													</span>
													<span class="burger-icon hidden" data-icon="close">
														<RoseNtIcon name="menu-close" sizeClass="size-6" />
													</span>
												</button>
											)}
										</div>
									</div>
									<nav
										class:list={["mt-3 flex w-full items-center gap-8 lg:gap-12", logoPosition === "top-left" ? "justify-start" : "justify-center", menuSchemeClass, isSidebar && "lg:!hidden"]}
										aria-label="Основная навигация"
										data-puck-subsection-parent={id}
										data-puck-subsection-index="997"
										data-puck-subsection-field="navigationLinks"
									>
										{nav.map((link) => (
									<NavItem link={link} menuType={menuType} linkClass={navLinkCls} active={isActive(link)} />
								))}
									</nav>
								</>
							) : (
								/* top-center: Row1=[search LEFT | logo CENTER | cart+user RIGHT], Row2=[nav CENTER] */
								<>
									<div class="grid w-full grid-cols-[1fr_auto_1fr] items-center">
										<div class="flex items-center">
											<button
												type="button"
												data-action="toggle-search"
												class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
												aria-label="Поиск"
												aria-expanded="false"
												aria-controls="rose-search-panel"
											>
												<RoseNtIcon name="search-lg" sizeClass="size-6" />
											</button>
										</div>
										<div class="flex items-center justify-center">
											<a
												href="/"
												class="font-comfortaa text-[length:var(--size-logo-width,24px)] font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-heading,0_0_0))] hover:opacity-90"
											>
												{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
											</a>
										</div>
										<div class="flex items-center justify-end gap-4 lg:gap-6">
											<a
												href="/wishlist"
												class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80"
												aria-label="Избранное"
											>
												<RoseNtIcon name="favourite" sizeClass="size-6" />
												<span
													data-wishlist-count
													data-empty="true"
													class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
												>0</span>
											</a>
											<button
												type="button"
												data-cart-open
												class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80"
												aria-label="Корзина"
											>
												<RoseNtIcon name="cart" sizeClass="size-6" />
												<span
													data-cart-count
													data-empty="true"
													class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
												>0</span>
											</button>
											<a
												href="/login"
												data-auth-link
												class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
												aria-label="Аккаунт"
											>
												<RoseNtIcon name="user" sizeClass="size-6" />
											</a>
											{isSidebar && (
												<button
													type="button"
													data-burger-toggle
													class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
													aria-label="Меню"
													aria-expanded="false"
													aria-controls="rose-burger"
												>
													<span class="burger-icon" data-icon="open">
														<RoseNtIcon name="menu-burger" sizeClass="size-6" />
													</span>
													<span class="burger-icon hidden" data-icon="close">
														<RoseNtIcon name="menu-close" sizeClass="size-6" />
													</span>
												</button>
											)}
										</div>
									</div>
									<nav
										class:list={["mt-3 flex w-full items-center gap-8 lg:gap-12", logoPosition === "top-left" ? "justify-start" : "justify-center", menuSchemeClass, isSidebar && "lg:!hidden"]}
										aria-label="Основная навигация"
										data-puck-subsection-parent={id}
										data-puck-subsection-index="997"
										data-puck-subsection-field="navigationLinks"
									>
										{nav.map((link) => (
									<NavItem link={link} menuType={menuType} linkClass={navLinkCls} active={isActive(link)} />
								))}
									</nav>
								</>
							)}
						</div>
					) : (
						/* ── SINGLE-ROW LAYOUTS: center-left / center-absolute ── */
						<div class={desktopRowCls} style={headerPadStyle}>
							<a href="/" class:list={[desktopLogoCls, logoLeft && "flex-1"]}>
								{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
							</a>

							<nav
								class:list={["flex items-center gap-8 lg:gap-12", menuSchemeClass, isSidebar && "lg:!hidden"]}
								aria-label="Основная навигация"
								data-puck-subsection-parent={id}
								data-puck-subsection-index="997"
								data-puck-subsection-field="navigationLinks"
							>
								{nav.map((link) => (
									<NavItem link={link} menuType={menuType} linkClass={navLinkCls} active={isActive(link)} />
								))}
							</nav>

							<div class:list={["flex items-center gap-4 lg:gap-6", logoLeft && "flex-1 justify-end"]}>
								<button
									type="button"
									data-action="toggle-search"
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Поиск"
									aria-expanded="false"
									aria-controls="rose-search-panel"
								>
									<RoseNtIcon name="search-lg" sizeClass="size-6" />
								</button>
								<a
									href="/wishlist"
									class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Избранное"
								>
									<RoseNtIcon name="favourite" sizeClass="size-6" />
									<span
										data-wishlist-count
										data-empty="true"
										class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
									>0</span>
								</a>
								<button
									type="button"
									data-cart-open
									class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Корзина"
								>
									<RoseNtIcon name="cart" sizeClass="size-6" />
									<span
										data-cart-count
										data-empty="true"
										class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#000000] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
									>0</span>
								</button>
								<a
									href="/login" data-auth-link
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Аккаунт"
								>
									<RoseNtIcon name="user" sizeClass="size-6" />
								</a>
								{isSidebar && (
									<button
										type="button"
										data-burger-toggle
										class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
										aria-label="Меню"
										aria-expanded="false"
										aria-controls="rose-burger"
									>
										<span class="burger-icon" data-icon="open">
											<RoseNtIcon name="menu-burger" sizeClass="size-6" />
										</span>
										<span class="burger-icon hidden" data-icon="close">
											<RoseNtIcon name="menu-close" sizeClass="size-6" />
										</span>
									</button>
								)}
							</div>
						</div>
					)}
				</div>
			</div>

			<!-- Поиск: выезжает вниз по клику на иконку (макет 1320×48, кнопка #000) -->
			<div
				id="rose-search-panel"
				data-search-panel
				class="pointer-events-none absolute left-0 right-0 top-full z-40 w-full overflow-hidden bg-transparent transition-[max-height] duration-300 ease-in-out"
				style="max-height: 0;"
				aria-hidden="true"
			>
				<div class="px-4 py-2 sm:px-5 md:px-10 lg:px-16 xl:px-20 2xl:px-[280px] lg:py-2">
					<form
						role="search"
						action="/catalog"
						method="get"
						class="pointer-events-auto mx-auto flex h-12 w-full max-w-[1320px] items-center gap-2 rounded-[var(--radius-input,4px)] border border-[#E5E5E5] bg-white pl-3 pr-1 shadow-[0_8px_24px_rgba(0,0,0,0.08)]"
					>
						<input
							id="rose-site-search-input"
							type="search"
							name="q"
							placeholder="Поиск..."
							aria-label="Поиск"
							class="min-h-0 min-w-0 flex-1 bg-transparent py-1 font-manrope text-[16px] font-light leading-normal text-[#000000] placeholder:text-[#999999] outline-none"
						/>
						<button
							type="submit"
							class="flex h-10 shrink-0 items-center justify-center rounded-[4px] border-0 !bg-[rgb(var(--color-button-bg,0_0_0))] px-3 py-2.5 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-90"
						>
							Найти
						</button>
					</form>
				</div>
			</div>
		</header>
	</div>

	<!-- Мобильный бургер / Desktop sidebar drawer -->
	<div
		id="rose-burger"
		class:list={[
			"fixed z-[55] hidden overflow-y-auto bg-white",
			isSidebar
				? "inset-y-0 right-0 bottom-0 w-[360px] max-w-[90vw] px-6 pt-6 pb-8"
				: "inset-x-0 bottom-0 w-full px-4 pt-4 pb-8 sm:px-5 md:px-10 lg:hidden",
		]}
		role="dialog"
		aria-modal="true"
		aria-label="Меню"
	>
		{isSidebar ? (
			/* Sidebar drawer: logo + cart at top (Figma 648:54691) */
			<div class="flex items-center justify-between">
				<a
					href="/"
					class="font-comfortaa text-[length:var(--size-logo-width,24px)] font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-heading,0_0_0))] hover:opacity-90"
				>
					{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
				</a>
				<div class="flex items-center gap-3">
					<a
						href="/wishlist"
						class="relative flex size-10 shrink-0 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Избранное"
					>
						<RoseNtIcon name="favourite" sizeClass="size-6" />
						<span
							data-wishlist-count
							data-empty="true"
							class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-rose-primary px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
						>0</span>
					</a>
					<button
						type="button"
						data-cart-open
						class="relative flex size-10 shrink-0 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Корзина"
					>
						<RoseNtIcon name="cart" sizeClass="size-6" />
						<span
							data-cart-count
							data-empty="true"
							class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-rose-primary px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
						>0</span>
					</button>
				</div>
			</div>
		) : (
			/* Mobile drawer: search + profile */
			<div class="flex items-center gap-2">
				<form
					class="flex h-10 min-h-10 flex-1 items-center justify-between rounded-[var(--radius-input,4px)] border border-gray bg-white pl-3 pr-2"
					role="search"
					action="/catalog"
					method="get"
				>
					<input
						type="search"
						name="q"
						placeholder="Поиск"
						class="min-w-0 flex-1 bg-transparent font-manrope text-[12px] font-normal leading-normal text-rose-primary placeholder:text-gray outline-none"
					/>
					<button type="submit" class="flex size-10 shrink-0 items-center justify-center" aria-label="Найти">
						<RoseNtIcon name="search-sm" sizeClass="size-6" />
					</button>
				</form>
				<a
					href="/login" data-auth-link
					class="flex size-10 shrink-0 items-center justify-center rounded-[4px] bg-rose-primary"
					aria-label="Профиль"
				>
					<RoseNtIcon name="user" sizeClass="size-6" class="brightness-0 invert" />
				</a>
			</div>
		)}

		<nav class="mt-10 flex flex-col items-start gap-5" aria-label="Основное меню">
			{nav.map((link) => {
				const active = isActive(link);
				const subs = Array.isArray(link.submenu)
					? link.submenu.filter((s) => s && typeof s.label === "string" && s.label.trim() !== "")
					: [];
				return (
					<div class="flex w-full flex-col gap-3">
						<a
							href={link.href}
							aria-current={active ? "page" : undefined}
							class:list={[
								"relative inline-flex w-fit pb-1 font-manrope text-[12px] font-normal leading-none transition-colors sm:text-[14px]",
								active &&
									"text-rose-primary after:pointer-events-none after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-rose-primary after:content-['']",
								!active && "text-gray hover:text-rose-primary",
							]}
						>
							{link.label}
						</a>
						{subs.length > 0 && (
							<div class="flex flex-col gap-2 border-l border-gray/40 pl-4">
								{subs.map((c2) => {
									const kids2 = Array.isArray(c2.submenu)
										? c2.submenu.filter((s) => s && typeof s.label === "string" && s.label.trim() !== "")
										: [];
									return (
										<div class="flex flex-col gap-2">
											<a
												href={c2.href}
												class="inline-flex w-fit font-manrope text-[12px] font-normal leading-none text-gray transition-colors hover:text-rose-primary sm:text-[13px]"
											>
												{c2.label}
											</a>
											{kids2.length > 0 && (
												<div class="flex flex-col gap-2 pl-4">
													{kids2.map((k) => (
														<a
															href={k.href}
															class="inline-flex w-fit font-manrope text-[11px] font-normal leading-none text-gray transition-colors hover:text-rose-primary sm:text-[12px]"
														>
															{k.label}
														</a>
													))}
												</div>
											)}
										</div>
									);
								})}
							</div>
						)}
					</div>
				);
			})}
		</nav>
	</div>

	{stickiness === "scroll-up" && <script is:inline set:html={SCROLL_UP_JS} />}
</div>

<script>
	const headerOffsetBelowPromo = () => {
		const promo = document.querySelector<HTMLElement>('[data-nt="promo-banner"]');
		const headerEl = document.querySelector<HTMLElement>('[data-nt="rose-header"]');
		const p = promo?.offsetHeight ?? 48;
		const h = headerEl?.offsetHeight ?? 120;
		return p + h;
	};

	const positionBurger = () => {
		const burger = document.getElementById("rose-burger");
		if (!burger) return;
		burger.style.top = `${headerOffsetBelowPromo()}px`;
	};

	const setSearchOpen = (open: boolean) => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel) return;
		panel.setAttribute("aria-hidden", String(!open));
		if (open) {
			panel.style.maxHeight = `${panel.scrollHeight}px`;
			queueMicrotask(() => {
				panel.querySelector<HTMLInputElement>("input[type='search']")?.focus();
			});
		} else {
			panel.style.maxHeight = "0px";
		}
		document.querySelectorAll<HTMLElement>("[data-action='toggle-search']").forEach((btn) => {
			btn.setAttribute("aria-expanded", String(open));
		});
	};

	const isSearchPanelOpen = () => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel) return false;
		const h = panel.style.maxHeight;
		return Boolean(h && h !== "0px" && h !== "0");
	};

	const syncSearchPanelHeight = () => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel || !isSearchPanelOpen()) return;
		panel.style.maxHeight = `${panel.scrollHeight}px`;
	};

	const syncBurgerButtonIcons = (open: boolean) => {
		// Update ALL burger toggle buttons (mobile #rose-burger-btn + desktop [data-burger-toggle])
		document.querySelectorAll<HTMLElement>("[data-burger-toggle]").forEach((burgerBtn) => {
			burgerBtn.setAttribute("aria-expanded", String(open));
			burgerBtn.querySelectorAll<HTMLElement>(".burger-icon").forEach((el) => {
				const key = el.dataset.icon;
				if (key === "open") el.classList.toggle("hidden", open);
				else el.classList.toggle("hidden", !open);
			});
		});
	};

	const isSidebarDrawer = () => {
		const burger = document.getElementById("rose-burger");
		// Sidebar right-panel has inset-y-0 and a fixed width — detect via right-side positioning
		return burger ? burger.classList.contains("inset-y-0") : false;
	};

	const setBurger = (open: boolean) => {
		const burger = document.getElementById("rose-burger");
		if (!burger) return;
		if (open) setSearchOpen(false);
		burger.classList.toggle("hidden", !open);
		syncBurgerButtonIcons(open);
		document.body.style.overflow = open ? "hidden" : "";
		// positionBurger only for mobile bottom-sheet (not right-side panel)
		if (open && !isSidebarDrawer()) positionBurger();
	};

	/** View Transitions: новый DOM — старые addEventListener на кнопке не живут; плюс снимаем залипший overflow */
	const syncHeaderChromeAfterNavigation = () => {
		document.body.style.overflow = "";
		setSearchOpen(false);
		const burger = document.getElementById("rose-burger");
		if (burger) burger.classList.add("hidden");
		syncBurgerButtonIcons(false);
		if (!isSidebarDrawer()) positionBurger();
	};

	let headerDelegatesBound = false;
	const bindHeaderDelegatedClicks = () => {
		if (headerDelegatesBound) return;
		headerDelegatesBound = true;

		document.addEventListener("click", (event: MouseEvent) => {
			const raw = event.target;
			const el = raw instanceof Element ? raw : null;
			if (!el) return;

			if (el.closest("[data-burger-toggle]")) {
				const burger = document.getElementById("rose-burger");
				if (!burger) return;
				event.preventDefault();
				setBurger(burger.classList.contains("hidden"));
				return;
			}

			if (el.closest("[data-action='toggle-search']")) {
				event.preventDefault();
				event.stopPropagation();
				setSearchOpen(!isSearchPanelOpen());
				return;
			}

			if (el.closest("#rose-burger a[href]")) {
				setBurger(false);
			}
		});

		document.addEventListener("click", (event: MouseEvent) => {
			if (!isSearchPanelOpen()) return;
			const target = event.target;
			if (!(target instanceof Node)) return;
			const panel = document.querySelector<HTMLElement>("[data-search-panel]");
			if (panel?.contains(target)) return;
			const tEl = target instanceof Element ? target : null;
			if (tEl?.closest?.("[data-action='toggle-search']")) return;
			setSearchOpen(false);
		});

		// Боковое/мобильное меню (drawer): клик ВНЕ шторки — закрыть.
		document.addEventListener("click", (event: MouseEvent) => {
			const burger = document.getElementById("rose-burger");
			if (!burger || burger.classList.contains("hidden")) return;
			const target = event.target;
			if (!(target instanceof Node)) return;
			if (burger.contains(target)) return; // клик внутри шторки — игнор
			const tEl = target instanceof Element ? target : null;
			if (tEl?.closest?.("[data-burger-toggle]")) return; // клик по бургеру — это toggle, не закрытие
			setBurger(false);
		});

		window.addEventListener("resize", () => {
			syncSearchPanelHeight();
			positionBurger();
		});
	};

	bindHeaderDelegatedClicks();
	document.addEventListener("astro:page-load", syncHeaderChromeAfterNavigation);
	syncHeaderChromeAfterNavigation();
</script>
