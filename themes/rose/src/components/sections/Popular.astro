---
import NtSectionHeading from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtSectionHeading.astro";
import RoseProductCard from "../products/RoseProductCard.astro";

// ОЖИВЛЕНИЕ: конструкторная схема PopularProducts (heading/subtitle union). Тело + данные verbatim.
// T13: полная канон-схема (cards/columns/headingSize/textSize/imageView/nextPhotoOnHover/
// quickAddMode/quickAddText/buttonStyle/viewAll/padding). Дефолтные ветки тернарников =
// прежние строки байт-в-байт; канон-дефолты конструктора (small/small/square/none/4) и
// впрыск коэрсера cards=4/columns=4 → пиксель верстальщика (прецедент T11 'center').
const p = Astro.props as Record<string, any>;
const id = p.id;
// Figma 1:19335 — ДОСЛОВНЫЙ плейсхолдер пустого состояния PopularProducts:
// заголовок «Коллекция товаров», без хелпер-подзаголовка (только заголовок +
// карточки). Дефолт-текст верстальщика («Главные хиты» + длинный подзаголовок)
// заменён на Figma-текст. Когда мерчант задал свой heading/text/subtitle —
// рендерим ЕГО (?? fallback срабатывает только при пустых данных).
const sectionTitle = p.heading?.text ?? p.heading ?? "Коллекция товаров";
const sectionSubtitle =
	p.text?.content ?? p.subtitle?.content ?? p.subtitle ?? "";

// Канон cards 2-24: лимит N карточек плейсхолдера / реальных товаров (data-cards
// на гриде). Отсутствие → 4 (канон-дефолт конструктора).
const cardsN = typeof p.cards === "number" && p.cards > 0 ? Math.max(1, Math.min(24, Math.round(p.cards))) : 4;

// Figma 1:19335 — пустое состояние секции. Curated-модель (Shopify, паритет
// packages/theme-base/blocks/PopularProducts): пока мерчант НЕ выбрал коллекцию
// (collectionRef пуст), секция показывает ПЛЕЙСХОЛДЕР (цветные куртки-заглушки
// «Товар» / «2 500 ₽»), а НЕ мок-товары верстальщика. Когда коллекция выбрана —
// SSR-фетч (ниже) рендерит РЕАЛЬНЫЕ товары коллекции прямо в статике, а гидрация
// освежает их на live.
// Ассеты: packages/theme-base/public/placeholders/sweater-<color>.png →
// копируются в дист (assemble-from-packages copyPublic / theme-build merge) и
// доступны на сайте как /placeholders/sweater-<color>.png (object-contain).
const PLACEHOLDER_SWEATERS = [
	"/placeholders/sweater-blue.svg",
	"/placeholders/sweater-yellow.svg",
	"/placeholders/sweater-red.svg",
	"/placeholders/sweater-green.svg",
];
const placeholderCards = Array.from({ length: cardsN }, (_, i) => ({
	image: PLACEHOLDER_SWEATERS[i % PLACEHOLDER_SWEATERS.length],
	name: "Товар",
	price: "2 500 ₽",
}));

// Канон headingSize (top-level приоритетнее legacy heading.size): 'small'
// (canon-default) и отсутствие = NtSectionHeading верстальщика дословно (20px);
// medium → 24px, large → 29px (≈канонный ряд small 20 / medium 24, окр. до px).
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "medium"
		? " [&_h2]:!text-[24px]"
		: headingSize === "large"
			? " [&_h2]:!text-[29px]"
			: "";
// Канон textSize (top-level приоритетнее legacy text.size): 'small' (canon-default)
// и отсутствие = 16px верстальщика; medium → 19px, large → 23px.
const textSize = p.textSize ?? p.text?.size;
const textSizeCls =
	textSize === "medium"
		? " [&_p]:!text-[19px]"
		: textSize === "large"
			? " [&_p]:!text-[23px]"
			: "";
const headWrapCls = `flex w-full justify-center${headingSizeCls}${textSizeCls}`;

// Колонки 1-6 (дефолт 4). Применяются с md (768px) и выше через CSS-переменную
// --cols + media-query в <style> ниже (моб = 2 колонки, канон верстальщика).
// Раньше число колонок жило только на lg/xl, а превью конструктора уже lg-ширины:
// дефолт columns=4 спец-кейсился на gridBase (4 только на xl=1280) → превью
// показывало md:grid-cols-3 = 3 («Колонки не применяются»). Переменная + media-
// query работают идентично на live и в превью (Container API) и не зависят от
// генерации Tailwind arbitrary-класса grid-cols-[...].
const colsN = typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : 4;
// Канон imageView square/portrait/wide (+legacy alias adaptive→wide): 'square'
// (canon-default) и отсутствие = литерал верстальщика 318/444 байт-в-байт;
// portrait → 430/500 (канонный портрет), wide → 16/9.
const tileAspectCls =
	p.imageView === "portrait"
		? " [&_li>article>a]:aspect-[430/500]"
		: p.imageView === "wide" || p.imageView === "adaptive"
			? " [&_li>article>a]:aspect-[16/9]"
			: "";
// Моб = 2 колонки (grid-cols-2); с md и выше grid-template-columns задаёт <style>
// по --cols. Гэпы оставляем как у верстальщика.
const gridCls =
	"grid w-full grid-cols-2 gap-x-3 gap-y-8 sm:gap-x-4 sm:gap-y-9 md:gap-x-4 md:gap-y-10 xl:gap-x-5" + tileAspectCls;
const gridStyle = `--cols:${colsN}`;

// Канон quickAddMode none/standard/cart (+legacy alias count→cart): кнопка
// быстрого добавления на карточке (в манере — появляется при hover, в потоке под
// ценой как канон). Клик → механика rose:cart: глобальный обработчик
// [data-add-to-cart] (initCartUI, lib/nt-cart-rose.ts) добавляет строку и
// открывает drawer. Для реальных товаров с вариантами кнопка добавляет ПЕРВУЮ
// доступную комбинацию (combo.id+combo.price) — решение владельца.
const qaModeRaw = p.quickAddMode === "count" ? "cart" : p.quickAddMode;
const quickAddMode = qaModeRaw === "standard" || qaModeRaw === "cart" ? qaModeRaw : undefined;
// Канон quickAddText (default 'В КОРЗИНУ'); без него standard → 'В корзину' (как канон).
const quickAddText =
	(typeof p.quickAddText === "string" && p.quickAddText) ||
	(quickAddMode === "cart" ? "В КОРЗИНУ" : "В корзину");
// Канон buttonStyle link/primary/secondary — стиль кнопки карточки (носитель в rose
// появляется только вместе с quickAdd): primary/отсутствие = кнопка-1, secondary =
// кнопка-2 (манерный образец «Добавить в корзину» PDP), link = текстовая ссылка.
const quickAddCls =
	p.buttonStyle === "secondary"
		? "mt-3 inline-flex h-10 w-full items-center justify-center rounded-[var(--radius-button,6px)] border border-solid border-[rgb(var(--color-button-2-border,0_0_0))] !bg-[rgb(var(--color-button-2-bg,255_255_255))] px-4 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-button-2-text,0_0_0))] opacity-0 transition-opacity hover:opacity-90 focus-visible:opacity-100 group-hover:opacity-100"
		: p.buttonStyle === "link"
			? "mt-3 inline-flex h-10 w-full items-center justify-center px-4 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-text,0_0_0))] underline underline-offset-4 opacity-0 transition-opacity hover:opacity-70 focus-visible:opacity-100 group-hover:opacity-100"
			: "mt-3 inline-flex h-10 w-full items-center justify-center rounded-[var(--radius-button,6px)] !border-0 !bg-[rgb(var(--color-button-bg,0_0_0))] px-4 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-button-text,255_255_255))] opacity-0 transition-opacity hover:opacity-90 focus-visible:opacity-100 group-hover:opacity-100";

// Канон nextPhotoOnHover (toggle, true/'true'): смена фото на вторую картинку
// товара при наведении. Носитель данных: data-image-2 на <li> (demo — gallery[1]
// верстальщика; реальные товары — images[1] из products.json, ставит гидрация).
const nextPhoto = p.nextPhotoOnHover === true || p.nextPhotoOnHover === "true";
// is:inline + set:html (без define:vars — компилятор секций его не умеет);
// идемпотентность data-np-hydrated; без data-image-2 скрипт — no-op без ошибок.
const NEXT_PHOTO_JS = [
	"(function(){",
	"var grids=document.querySelectorAll('[data-nt=\"popular-grid\"][data-next-photo]');",
	"for(var i=0;i<grids.length;i++){(function(g){",
	"if(g.getAttribute('data-np-hydrated')==='true')return;",
	"g.setAttribute('data-np-hydrated','true');",
	"function swap(li,on){",
	"var u=on?li.getAttribute('data-image-2'):null;",
	"var im=li.querySelectorAll('img');",
	"for(var j=0;j<im.length;j++){",
	"if(on){if(!im[j].getAttribute('data-image-1'))im[j].setAttribute('data-image-1',im[j].getAttribute('src')||'');im[j].setAttribute('src',u);}",
	"else{var s1=im[j].getAttribute('data-image-1');if(s1)im[j].setAttribute('src',s1);}",
	"}",
	"var so=li.querySelectorAll('source');",
	"for(var k=0;k<so.length;k++){",
	"if(on){if(!so[k].getAttribute('data-srcset-1'))so[k].setAttribute('data-srcset-1',so[k].getAttribute('srcset')||'');so[k].setAttribute('srcset',u);}",
	"else{var ss=so[k].getAttribute('data-srcset-1');if(ss)so[k].setAttribute('srcset',ss);}",
	"}",
	"}",
	"g.addEventListener('mouseover',function(e){",
	"var t=e.target;if(!t||!t.closest)return;",
	"var li=t.closest('li[data-image-2]');",
	"if(!li||!g.contains(li)||li.getAttribute('data-np-on')==='true')return;",
	"li.setAttribute('data-np-on','true');swap(li,true);",
	"});",
	"g.addEventListener('mouseout',function(e){",
	"var t=e.target;if(!t||!t.closest)return;",
	"var li=t.closest('li[data-image-2]');",
	"if(!li||li.getAttribute('data-np-on')!=='true')return;",
	"var to=e.relatedTarget;if(to&&li.contains(to))return;",
	"li.setAttribute('data-np-on','false');swap(li,false);",
	"});",
	"})(grids[i]);}",
	"})();",
].join("");

// Канон viewAll {show,text,href}: кнопка под гридом — «Смотреть все товары»
// коллекции (Figma 1-33175). По умолчанию ПОКАЗАНА (часть дизайна секции),
// скрыть — viewAll.show === false. Текст по умолчанию «Смотреть все товары»;
// href ведёт на каталог выбранной коллекции (?collection=) либо в общий каталог.
const viewAllRaw = p.viewAll;
const viewAllShow = !(
	viewAllRaw &&
	typeof viewAllRaw === "object" &&
	(viewAllRaw.show === false || viewAllRaw.show === "false")
);
const viewAllText =
	(!!viewAllRaw && typeof viewAllRaw === "object" && typeof viewAllRaw.text === "string" && viewAllRaw.text) ||
	"Смотреть все товары";
const viewAllCollection =
	typeof p.collection === "string" && p.collection.trim() ? p.collection.trim() : "";
const viewAllHref =
	(!!viewAllRaw && typeof viewAllRaw === "object" && typeof viewAllRaw.href === "string" && viewAllRaw.href) ||
	(viewAllCollection ? `/catalog?collection=${encodeURIComponent(viewAllCollection)}` : "/catalog");
// Стиль кнопки «Смотреть все» = единый «Стиль кнопки» секции (buttonStyle, Figma
// 1195-42536): link = текстовая ссылка с подчёркиванием, secondary = кнопка-2
// (бордер), primary/отсутствие = кнопка-1 (заливка). Standalone-CTA (без hover-reveal).
const viewAllBase =
	"inline-flex h-10 min-h-10 items-center justify-center font-manrope text-[14px] font-normal leading-none transition-opacity sm:h-[52px] sm:min-h-[52px] sm:text-[15px] md:text-[16px]";
const viewAllCls =
	p.buttonStyle === "link"
		? `${viewAllBase} px-0 !text-[rgb(var(--color-text,0_0_0))] underline underline-offset-4 hover:opacity-70`
		: p.buttonStyle === "secondary"
			? `${viewAllBase} w-auto min-w-[120px] rounded border border-solid border-[rgb(var(--color-button-2-border,0_0_0))] !bg-[rgb(var(--color-button-2-bg,255_255_255))] px-3 py-2.5 !text-[rgb(var(--color-button-2-text,0_0_0))] hover:opacity-90 sm:min-w-[160px] sm:rounded-[var(--radius-button,6px)] sm:px-6 sm:py-[10px]`
			: `${viewAllBase} w-auto min-w-[120px] rounded !border-0 !bg-[rgb(var(--color-button-bg,0_0_0))] px-3 py-2.5 !text-[rgb(var(--color-button-text,255_255_255))] hover:opacity-90 sm:min-w-[160px] sm:rounded-[var(--radius-button,6px)] sm:px-6 sm:py-[10px]`;

// Канон collection (collectionPicker, id или slug): носитель — data-collection
// на гриде; фильтрацию делает гидрация (filterByCollection: productIds коллекции
// → membership товара → все, паритет theme-base). Demo-сборка без данных — no-op.
const collectionRef =
	typeof p.collection === "string" && p.collection.trim() ? p.collection.trim() : undefined;

// SSR-фетч реальных товаров выбранной коллекции (Figma-цель: коллекция выбрана →
// реальные товары ПРЯМО в статике, чтобы их видело и ПРЕВЬЮ конструктора — Astro
// Container не исполняет клиентскую module-гидрацию ниже). siteId инжектит
// рендер-пайплайн (preview.service / build). Нет коллекции / siteId / ошибка →
// realProducts пуст → секция рендерит плейсхолдер-куртки.
const siteId = typeof p.siteId === "string" ? p.siteId : "";
const fmtPrice = (v: unknown): string => {
	const n = typeof v === "number" ? v : parseFloat(String(v ?? ""));
	return Number.isFinite(n) ? `${Math.round(n).toLocaleString("ru-RU")} ₽` : "";
};
let realProducts: any[] = [];
if (collectionRef && siteId) {
	try {
		const base = (import.meta as any).env?.SITES_INTERNAL_BASE ?? "http://localhost:3114";
		const res = await fetch(`${base}/api/sites/${siteId}/storefront-data`).catch(() => null);
		if (res && res.ok) {
			const data: any = await res.json();
			const all: any[] = Array.isArray(data?.products) ? data.products : [];
			const cols: any[] = Array.isArray(data?.collections) ? data.collections : [];
			const matched = cols.find(
				(c) => c && (c.id === collectionRef || c.slug === collectionRef || c.name === collectionRef || c.handle === collectionRef),
			);
			const ids = matched && Array.isArray(matched.productIds) && matched.productIds.length ? new Set(matched.productIds) : null;
			const picked = (ids ? all.filter((pr) => pr?.id && ids.has(pr.id)) : all).slice(0, cardsN);
			realProducts = picked.map((pr) => {
				const img = Array.isArray(pr?.images) && pr.images[0]
					? (typeof pr.images[0] === "string" ? pr.images[0] : pr.images[0]?.url ?? "")
					: (pr?.image ?? "");
				return {
					id: String(pr?.id ?? ""),
					name: String(pr?.name ?? pr?.title ?? "Товар"),
					image: String(img ?? ""),
					price: fmtPrice(pr?.basePrice ?? pr?.price),
					oldPrice: fmtPrice(pr?.compareAtPrice ?? pr?.oldPrice),
					discount: !!(pr?.compareAtPrice || pr?.oldPrice),
				};
			});
		}
	} catch {
		realProducts = [];
	}
}

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id="popular"
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-14 pt-14 sm:px-5 sm:pb-16 sm:pt-16 md:px-10 md:pb-[100px] md:pt-[100px] lg:px-16 lg:pb-[120px] lg:pt-[120px] xl:px-20 xl:pb-[140px] xl:pt-[140px] 2xl:px-[280px]"
	aria-labelledby="popular-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-8 md:gap-10">
		<div class={headWrapCls} data-animate data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">
			<NtSectionHeading variant="rose" titleId="popular-title" title={sectionTitle} subtitle={sectionSubtitle} />
		</div>

		<ul
			data-animate
			data-animate-delay="0.1s"
			class={gridCls}
			role="list"
			data-nt="popular-grid"
			data-cols={String(colsN)}
			style={gridStyle}
			data-cards={cardsN !== 4 ? String(cardsN) : undefined}
			data-collection={collectionRef}
			data-next-photo={nextPhoto ? "true" : undefined}
			data-quick-add={quickAddMode}
			data-qa-text={quickAddMode ? quickAddText : undefined}
			data-qa-class={quickAddMode ? quickAddCls : undefined}
		>
			{/* SSR-цель (Figma 1:19335): коллекция ВЫБРАНА → реальные товары (фетч в
			    frontmatter, работает и в превью-Container); НЕ выбрана/пусто →
			    плейсхолдер-куртки. data-collection остаётся → клиентская гидрация на
			    live освежает данные. */}
			{realProducts.length > 0 ? realProducts.map((product: any) => (
				<li data-product-id={product.id} class:list={quickAddMode ? ["group"] : undefined} data-image-2={nextPhoto ? product.gallery?.[1] : undefined}>
					<RoseProductCard product={product} />{quickAddMode && (
						<button
							type="button"
							data-add-to-cart
							data-product-id={product.id}
							data-name={product.name}
							data-price={product.price}
							data-old-price={product.oldPrice}
							data-image={product.image}
							class={quickAddCls}
						>
							{quickAddText}
						</button>
					)}
				</li>
			)) : placeholderCards.map((card) => (
				/* Пустое состояние (коллекция не выбрана): плейсхолдер-карточка
				   Figma 1:19335 — куртка-заглушка (object-contain), «Товар»,
				   «2 500 ₽». Без data-product-id / data-add-to-cart — это не
				   реальный товар (add-to-cart недоступен, как в theme-base DEMO). */
				<li>
					<article class="flex w-full flex-col gap-5" aria-label={card.name}>
						<div class="relative block aspect-[318/444] w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,251_251_251))]">
							<img
								src={card.image}
								alt={card.name}
								width="318"
								height="444"
								loading="lazy"
								class="h-full w-full object-contain p-[15%]"
							/>
						</div>
						<div class="flex w-full flex-col gap-1 text-left">
							<span class="rose-product-name block w-full font-manrope text-[14px] font-normal leading-none text-[rgb(var(--color-text,0_0_0))]">
								{card.name}
							</span>
							<span class="rose-product-price font-manrope !text-[16px] font-normal !leading-none text-[rgb(var(--color-text,0_0_0))]">
								{card.price}
							</span>
						</div>
					</article>
				</li>
			))}
		</ul>{viewAllShow && (
			<div class="flex w-full justify-center">
				<a
					href={viewAllHref}
					class={viewAllCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="viewAll"
				>
					{viewAllText}
				</a>
			</div>
		)}
	</div>
</section>{nextPhoto && <script is:inline set:html={NEXT_PHOTO_JS} />}

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		resolveCollectionProducts,
		renderCardHtml,
		escapeHtml,
		productHref,
		productImage,
	} from "../../lib/storefront-hydrate";

	// Реальные товары (Option B): первые N из /data/products.json (N = data-cards
	// грида, дефолт 4 — поведение верстальщика). Demo-сборка → no-op. Канон-поля
	// T13 поверх: data-quick-add/-qa-text/-qa-class → кнопка на гидрированной
	// карточке (товары с вариантами → добавляют первую комбинацию), data-next-photo → data-image-2
	// (вторая картинка товара) для hover-скрипта, data-collection → фильтр по
	// выбранной в конструкторе коллекции (раньше настройка игнорировалась).
	const hydratePopular = async () => {
		const grids = Array.from(document.querySelectorAll<HTMLElement>('[data-nt="popular-grid"]'));
		if (grids.length === 0) return;
		const products = await loadRealProducts();
		if (!products) return;
		const needCollections = grids.some((g) => g.getAttribute("data-collection"));
		const collections = needCollections ? await loadRealCollections() : null;
		for (const grid of grids) {
			const collectionRef = grid.getAttribute("data-collection");
			// Shopify-модель: без явно выбранной коллекции секция оставляет
			// SSR-моки (demo), а не подтягивает весь каталог магазина.
			if (!collectionRef) continue;
			const matched = resolveCollectionProducts(products, collections, collectionRef);
			// Коллекция пуста / не найдена → тоже оставляем моки.
			if (matched.length === 0) continue;
			const limitRaw = Number(grid.getAttribute("data-cards"));
			const limit = Number.isFinite(limitRaw) && limitRaw > 0 ? limitRaw : 4;
			const quickAdd = grid.getAttribute("data-quick-add");
			const qaText = grid.getAttribute("data-qa-text") || "В корзину";
			const qaClass = grid.getAttribute("data-qa-class") || "";
			const wantNextPhoto = grid.hasAttribute("data-next-photo");
			const items = matched.slice(0, limit);
			grid.innerHTML = items
				.map((p) => {
					const img2 =
						wantNextPhoto && Array.isArray(p.images) && p.images[1]
							? ` data-image-2="${escapeHtml(p.images[1])}"`
							: "";
					const liClass = quickAdd ? ' class="group"' : "";
					const hasVariants =
						p.hasVariants === true ||
						(Array.isArray(p.variantCombinations) && p.variantCombinations.length > 0);
					// Решение владельца: карточная «В корзину» для товара с вариантами
						// добавляет ПЕРВУЮ доступную комбинацию (не ведёт на PDP). Без
						// комбинаций (битый товар) — фолбэк на ссылку PDP, чтобы не дать
						// сломанную кнопку (order_items без варианта).
						const firstCombo = hasVariants
							? (p.variantCombinations || []).find((c) => c && c.available !== false) ||
								(p.variantCombinations || [])[0]
							: null;
						const comboOpt = (firstCombo?.options || {}) as Record<string, string>;
						const comboColor = comboOpt["Цвет"] || comboOpt["Color"] || "";
						const comboSize = comboOpt["Размер"] || comboOpt["Size"] || "";
						const qaBtn = quickAdd
							? hasVariants
								? firstCombo
									? `<button type="button" data-add-to-cart data-product-id="${escapeHtml(p.id)}" data-name="${escapeHtml(p.name)}" data-price="${escapeHtml(String(firstCombo.price))}" data-variant-combination-id="${escapeHtml(String(firstCombo.id))}"${comboColor ? ` data-variant-color="${escapeHtml(comboColor)}"` : ""}${comboSize ? ` data-variant-size="${escapeHtml(comboSize)}"` : ""} data-image="${escapeHtml(productImage(p))}" class="${qaClass}">${escapeHtml(qaText)}</button>`
									: `<a href="${escapeHtml(productHref(p))}" class="${qaClass}">${escapeHtml(qaText)}</a>`
								: `<button type="button" data-add-to-cart data-product-id="${escapeHtml(p.id)}" data-name="${escapeHtml(p.name)}" data-price="${escapeHtml(String(p.price))}"${p.oldPrice || p.compareAtPrice ? ` data-old-price="${escapeHtml(String(p.oldPrice || p.compareAtPrice))}"` : ""} data-image="${escapeHtml(productImage(p))}" class="${qaClass}">${escapeHtml(qaText)}</button>`
							: "";
					return `<li data-product-id="${escapeHtml(p.id)}"${liClass}${img2}>${renderCardHtml(p)}${qaBtn}</li>`;
				})
				.join("");
		}
	};

	hydratePopular();
	document.addEventListener("astro:page-load", hydratePopular);
</script>

<style>
	/* Figma 375: section title Comfortaa 14, subtitle Manrope 12. NtSectionHeading не пробрасывает class на h2/p. */
	@media (max-width: 639.98px) {
		:global(#popular-title) {
			font-size: 14px !important;
			line-height: 1 !important;
		}

		:global(#popular-title ~ p) {
			font-size: 12px !important;
			line-height: 1.4 !important;
			max-width: 100% !important;
			width: 100% !important;
			padding-inline: 0 !important;
		}

		:global([data-nt="section-heading"]) {
			max-width: 100% !important;
			width: 100% !important;
		}
	}

	/* Quick-add «В корзину» на карточке = opacity-0 + group-hover:opacity-100
	   (reveal на ховер). На тач-устройствах ховера нет → кнопка недоступна.
	   На таких экранах показываем её всегда (десктоп hover-reveal сохраняется). */
	@media (hover: none) {
		:global([data-nt="popular-grid"] [data-add-to-cart]),
		:global([data-nt="popular-grid"] li.group > a:last-child) {
			opacity: 1 !important;
		}
	}

	/* Слайдер «Колонки» (1-6) → grid-template-columns с md (768px) и выше.
	   --cols ставится inline на сетке (data-cols — хук-маркер). Селектор с двумя
	   атрибутами (специфичность 0,2,0) перебивает tailwind .grid-cols-2 (0,1,0)
	   без !important и независимо от порядка стилей. Оживляет слайдер и в превью
	   конструктора (lg-ширина), и на live. Моб (<768) остаётся 2 колонки. */
	@media (min-width: 768px) {
		:global([data-nt="popular-grid"][data-cols]) {
			grid-template-columns: repeat(var(--cols, 4), minmax(0, 1fr));
		}
	}
</style>
