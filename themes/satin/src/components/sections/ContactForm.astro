---
import NtTextField from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtTextField.astro";

// Фаза B (satin, группа misc): новая канон-секция ContactForm — разметка
// секции «Обратная связь» pages/contacts.astro:46-77 (страница остаётся inline
// и НЕ меняется; эталон процесса — bloom ContactForm). Схема полей =
// packages/theme-base/blocks/ContactForm/ContactForm.puckConfig.ts; манера —
// themes/satin/MANNER.md (§1 заголовок секции, §5 поля, §3 кнопки).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Figma 1:19335 — ДОСЛОВНЫЙ плейсхолдер пустого состояния ContactForm/Contacts:
// заголовок «Контактная форма» (без хелпер-описания). Дефолт-текст верстальщика
// («Обратная связь» contacts.astro:49) заменён на Figma-текст. Когда мерчант
// задал свой heading — рендерим ЕГО (?? fallback срабатывает только при пустых
// данных). font-logo 20 uppercase leading-[1.15], токен heading 0_0_0.
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Контактная форма");
// Лестница §9 «ContactForm заголовок» (база-литерал 20 = medium): small 17, large 24.
const headingSize = p.headingSize ?? p.heading?.size;
const headingSizeCls =
	headingSize === "small" ? "text-[17px]" : headingSize === "large" ? "text-[24px]" : "text-[20px]";
const headingAlignment =
	p.headingAlignment ?? (typeof p.heading === "object" ? p.heading?.alignment : undefined);
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-logo ${headingSizeCls} font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]${headingAlignCls}`;

// Figma 1:19335 — пустое состояние ContactForm НЕ содержит хелпер-описания
// (только заголовок + поля + кнопка). Дефолт-литерал верстальщика («Оставьте
// контакты...» contacts.astro:50) убран → абзац рендерится ТОЛЬКО когда мерчант
// задал непустой description (Arsenal 16 light muted). Явная пустая строка тоже
// скрывает абзац.
const description =
	typeof p.description === "string" && p.description.trim() ? p.description : undefined;

// Flat-пропсы контактов магазина (addresses/phone/email) — блок «Свяжитесь
// с нами» (contacts.astro:12-38, dl-манера: label muted 16 / значение
// font-light 0_0_0) рендерится ТОЛЬКО при непустых пропсах; дефолт-ветка
// канона = одна форма (у страницы свой полный inline-вариант).
const addresses = Array.isArray(p.addresses)
	? p.addresses.filter((a: any) => typeof a === "string" && a.trim())
	: [];
const contactPhone = typeof p.phone === "string" && p.phone.trim() ? p.phone : undefined;
const contactEmail = typeof p.email === "string" && p.email.trim() ? p.email : undefined;
const hasContacts = addresses.length > 0 || Boolean(contactPhone) || Boolean(contactEmail);

// Канон fields {name,email,phone,message} (каждое {enabled,required,label}).
// ОТСУТСТВИЕ объекта = форма страницы ДОСЛОВНО (NtTextField Имя/E-mail/Номер
// телефона + textarea «Ваш вопрос»); частичный объект → фоллбеки = канон-дефолты
// puckConfig (name/email required, phone disabled, message enabled).
const toBool = (v: any, fb: boolean): boolean =>
	typeof v === "boolean" ? v : v === "true" ? true : v === "false" ? false : fb;
// Figma 1:19335 — лейблы полей: «Имя» / «Email» / «Номер телефона» / «Комментарий».
const CANON_FIELDS = {
	name: { enabled: true, required: true, label: "Имя" },
	email: { enabled: true, required: true, label: "Email" },
	phone: { enabled: false, required: false, label: "Номер телефона" },
	message: { enabled: true, required: false, label: "Комментарий" },
};
const fieldsProp =
	p.fields && typeof p.fields === "object" && !Array.isArray(p.fields) ? p.fields : undefined;
const resolveField = (key: "name" | "email" | "phone" | "message") => {
	const def = (CANON_FIELDS as any)[key];
	const f = fieldsProp?.[key];
	return {
		enabled: toBool(f?.enabled, def.enabled),
		required: toBool(f?.required, def.required),
		label: typeof f?.label === "string" ? f.label : def.label,
	};
};
const formFields = fieldsProp
	? {
			name: resolveField("name"),
			email: resolveField("email"),
			phone: resolveField("phone"),
			message: resolveField("message"),
		}
	: undefined;

// Канон buttonText: дефолт = литерал «Отправить» (contacts.astro:71). Роль
// satin-button-md DARK (g:106-126,155-159) пересобрана utility-классами с
// токенами кнопки-1: unlayered .satin-button-dark из global.css перебил бы
// токен-утилиты (background: var(--satin-black)) и сломал смену схемы.
const buttonText =
	typeof p.buttonText === "string" && p.buttonText.trim() ? p.buttonText : "Отправить";
const darkBtnCls =
	"inline-flex min-h-12 w-fit items-center justify-center rounded-[var(--radius-button,0px)] border border-solid border-[rgb(var(--color-button-bg,0_0_0))] bg-[rgb(var(--color-button-bg,0_0_0))] px-6 font-manrope text-[16px] font-normal uppercase leading-none text-[rgb(var(--color-button-text,255_255_255))] transition-opacity duration-[180ms] hover:opacity-[0.78]";

// Классы полей ветки fields — манера NtTextField (h-14, бордер чёрный,
// focus → токен текста) на токенах; радиус полей — rounded-[var(--radius-input,0px)].
const fieldLabelCls = "font-manrope text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))]";
const fieldInputCls =
	"box-border h-14 min-h-[56px] w-full rounded-[var(--radius-input,0px)] border border-solid border-[rgb(var(--color-text,0_0_0))] bg-white px-4 font-manrope text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] outline-none placeholder:text-[rgb(var(--color-muted,153_153_153))] focus-visible:border-[rgb(var(--color-text,0_0_0))]";
// Textarea — литерал страницы (contacts.astro:62-67): min-h-[176px], бордер
// muted, focus → токен текста.
const textareaCls =
	"min-h-[176px] w-full flex-1 rounded-[var(--radius-input,0px)] border border-[rgb(var(--color-muted,153_153_153))] bg-white p-4 font-manrope text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] outline-none placeholder:text-[rgb(var(--color-muted,153_153_153))] focus-visible:border-[rgb(var(--color-text,0_0_0))]";

// Уникальные id внутри секции (страница использует литерал contacts-question —
// канон не должен с ним конфликтовать при соседстве на одной странице).
const questionId = id ? `${id}-question` : "contacts-question";
const fieldId = (key: string) => (id ? `${id}-field-${key}` : `nt-field-${key}`);

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

{/* Секция: просторная вертикаль §2 (py-12 md:py-16), поля .satin-pad, контейнер 1320 gap-8. */}
<section
	class="satin-pad w-full bg-[rgb(var(--color-bg,255_255_255))] py-12 md:py-16"
	aria-labelledby={titleId}
	aria-label={heading ? undefined : "Обратная связь"}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="satin-container flex flex-col gap-8">
		<div class="flex flex-col gap-2">
			{
				heading && (
					<h2
						id={titleId}
						class={headingCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="100"
						data-puck-subsection-field="heading"
					>
						{heading}
					</h2>
				)
			}
			{
				description && (
					<p
						class="font-manrope text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="101"
						data-puck-subsection-field="description"
					>
						{description}
					</p>
				)
			}
		</div>

		{
			hasContacts && (
				<div class="grid grid-cols-1 gap-8 font-manrope text-[16px] leading-normal sm:grid-cols-2 md:max-w-[640px]">
					<div class="flex flex-col gap-10">
						{addresses.map((addr: string, i: number) => (
							<div class="flex flex-col gap-1">
								<span class="text-[rgb(var(--color-muted,153_153_153))]">
									Адрес магазина{addresses.length > 1 ? ` ${i + 1}` : ""}
								</span>
								<span class="font-light text-[rgb(var(--color-text,0_0_0))]">{addr}</span>
							</div>
						))}
					</div>
					<div class="flex flex-col gap-10">
						{contactPhone && (
							<div class="flex flex-col gap-1">
								<span class="text-[rgb(var(--color-muted,153_153_153))]">Номер телефона</span>
								<a
									href={`tel:${contactPhone.replace(/[^+\d]/g, "")}`}
									class="font-light text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70"
								>
									{contactPhone}
								</a>
							</div>
						)}
						{contactEmail && (
							<div class="flex flex-col gap-1">
								<span class="text-[rgb(var(--color-muted,153_153_153))]">E-mail</span>
								<a
									href={`mailto:${contactEmail}`}
									class="font-light text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70"
								>
									{contactEmail}
								</a>
							</div>
						)}
					</div>
				</div>
			)
		}

		<form
			class="grid grid-cols-1 gap-4 lg:grid-cols-[429px_1fr] lg:gap-6"
			data-contacts-form
			novalidate
			data-puck-subsection-parent={id}
			data-puck-subsection-index="102"
			data-puck-subsection-field="fields"
		>
			{
				formFields ? (
					<div class="flex flex-col gap-4">
						{formFields.name.enabled && (
							<div class="flex w-full max-w-[430px] flex-col gap-2" data-nt="text-field">
								<label for={fieldId("name")} class={fieldLabelCls}>
									{formFields.name.label}
									{formFields.name.required && (
										<span class="ml-1 text-[rgb(var(--color-error,255_148_148))]">*</span>
									)}
								</label>
								<input
									id={fieldId("name")}
									name="name"
									type="text"
									autocomplete="name"
									required={formFields.name.required}
									class={fieldInputCls}
								/>
							</div>
						)}
						{formFields.email.enabled && (
							<div class="flex w-full max-w-[430px] flex-col gap-2" data-nt="text-field">
								<label for={fieldId("email")} class={fieldLabelCls}>
									{formFields.email.label}
									{formFields.email.required && (
										<span class="ml-1 text-[rgb(var(--color-error,255_148_148))]">*</span>
									)}
								</label>
								<input
									id={fieldId("email")}
									name="email"
									type="email"
									autocomplete="email"
									required={formFields.email.required}
									class={fieldInputCls}
								/>
							</div>
						)}
						{formFields.phone.enabled && (
							<div class="flex w-full max-w-[430px] flex-col gap-2" data-nt="text-field">
								<label for={fieldId("phone")} class={fieldLabelCls}>
									{formFields.phone.label}
									{formFields.phone.required && (
										<span class="ml-1 text-[rgb(var(--color-error,255_148_148))]">*</span>
									)}
								</label>
								<input
									id={fieldId("phone")}
									name="phone"
									type="tel"
									autocomplete="tel"
									required={formFields.phone.required}
									class={fieldInputCls}
								/>
							</div>
						)}
					</div>
				) : (
					<div class="flex flex-col gap-4">
						<NtTextField label="Имя" name="name" autocomplete="name" id={fieldId("name")} />
						<NtTextField
							label="Email"
							name="email"
							type="email"
							autocomplete="email"
							id={fieldId("email")}
						/>
						<NtTextField
							label="Номер телефона"
							name="phone"
							type="tel"
							autocomplete="tel"
							id={fieldId("phone")}
						/>
					</div>
				)
			}

			{
				formFields ? (
					formFields.message.enabled && (
						<div class="flex flex-col gap-2">
							<label for={questionId} class={fieldLabelCls}>
								{formFields.message.label}
								{formFields.message.required && (
									<span class="ml-1 text-[rgb(var(--color-error,255_148_148))]">*</span>
								)}
							</label>
							<textarea
								id={questionId}
								name="question"
								rows={8}
								required={formFields.message.required}
								class={textareaCls}
							/>
						</div>
					)
				) : (
					<div class="flex flex-col gap-2">
						<label for={questionId} class={fieldLabelCls}>
							Комментарий
						</label>
						<textarea id={questionId} name="question" rows={8} class={textareaCls} />
					</div>
				)
			}

			<div class="lg:col-span-2">
				<button type="submit" class={darkBtnCls}>{buttonText}</button>
			</div>

			<p
				data-contacts-status
				role="status"
				class="hidden font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] lg:col-span-2"
			></p>
		</form>
	</div>
</section>

<script>
	// Сабмит-скрипт страницы (contacts.astro:80-91) c ре-инициализацией по
	// astro:page-load (его шлёт превью-агент после hot-replace); статус ищем
	// внутри своей формы (на странице может быть и inline-форма контактов).
	const bindContactForms = () => {
		document.querySelectorAll<HTMLFormElement>("[data-contacts-form]").forEach((form) => {
			if (form.dataset.contactsBound === "true") return;
			form.dataset.contactsBound = "true";
			form.addEventListener("submit", (event) => {
				event.preventDefault();
				const status = form.querySelector<HTMLElement>("[data-contacts-status]");
				if (status) {
					status.textContent = "Спасибо! Мы свяжемся с вами в ближайшее время.";
					status.classList.remove("hidden");
				}
				form.reset();
			});
		});
	};

	bindContactForms();
	document.addEventListener("astro:page-load", bindContactForms);
</script>
