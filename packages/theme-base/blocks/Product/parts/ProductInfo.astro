---
/**
 * ProductInfo — brand + title primitive.
 *
 * Variants:
 *  - `uppercase-title` (rose, default) — title rendered UPPERCASE.
 *  - `normal-title` (flux) — title kept as-authored (no transform).
 *
 * Brand line is shown when present (non-empty).
 */
interface Props {
  brand?: string | null;
  title: string;
  variant?: 'uppercase-title' | 'normal-title';
}

const { brand, title, variant = 'uppercase-title' } = Astro.props as Props;
const isUpper = variant === 'uppercase-title';
---
<div class="flex flex-col gap-2 w-full" data-product-info>
  {brand && (
    <span class="[font-family:var(--font-body)] text-base text-[rgb(var(--color-muted))]">{brand}</span>
  )}
  <h1
    class:list={[
      '[font-family:var(--font-heading)] text-[20px] leading-tight text-[rgb(var(--color-text))] m-0',
      isUpper ? 'uppercase tracking-wide' : 'normal-case',
    ]}
  >{title}</h1>
</div>
