---
interface Props {
	name: string;
	image: string;
	slug?: string;
	aspect?: string;
	eager?: boolean;
}

const { name, image, slug, aspect = '430/500', eager = false } = Astro.props;
const hasImage = image && !image.includes('placeholder');
const collectionHref = slug ? `/collections/${slug}` : '#';
---

<article class="group cursor-pointer" role="listitem" aria-label={`Коллекция ${name}`}>
	<a href={collectionHref} class="no-underline text-inherit">
		<div class="relative w-full bg-gray-100 overflow-hidden mb-4 sm:mb-5 md:mb-6 lg:mb-8 shadow-sm hover:shadow-lg transition-shadow duration-300" style={`border-radius: var(--card-radius, 10px); aspect-ratio: ${aspect};`}>
			{hasImage ? (
				<img
					src={image}
					alt={`Изображение коллекции ${name}`}
					class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500 ease-out"
					loading={eager ? 'eager' : 'lazy'}
				/>
			) : (
				<div class="w-full h-full flex items-center justify-center bg-gray-100">
					<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300">
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
						<circle cx="8.5" cy="8.5" r="1.5" />
						<polyline points="21 15 16 10 5 21" />
					</svg>
				</div>
			)}
			<div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300"></div>
		</div>
		<div class="px-1 sm:px-2">
			<h3 class="text-lg sm:text-xl md:text-2xl lg:text-[24px] font-normal text-theme-foreground group-hover:opacity-70 transition-colors duration-200 font-body truncate">
				{name}
			</h3>
		</div>
	</a>
</article>
