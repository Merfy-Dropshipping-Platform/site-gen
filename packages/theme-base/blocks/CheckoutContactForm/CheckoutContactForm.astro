---
import type { CheckoutContactFormProps } from './CheckoutContactForm.puckConfig';
import { CheckoutContactFormClasses as C } from './CheckoutContactForm.classes';

interface Props extends CheckoutContactFormProps { id?: string; }
const { id, heading, showAuthLink, authLinkText, authLinkHref, emailLabel, phoneLabel, phoneFormat, padding } = Astro.props as Props;
const paddingStyle = padding ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;` : '';
const propsJson = JSON.stringify({ emailLabel, phoneLabel, phoneFormat, showAuthLink, authLinkText, authLinkHref });
---
<section
  class={C.root}
  data-puck-component-id={id}
  data-checkout-slot="contact"
  data-checkout-props={propsJson}
  style={paddingStyle}
>
  <h2 class={C.heading}>
    <span>{heading}</span>
    {showAuthLink && <a href={authLinkHref} class={C.authLink}>{authLinkText}</a>}
  </h2>
  <div class={C.fields}>
    <div class={C.field} data-checkout-field="email">
      <label class={C.label} for="checkout-email">{emailLabel}</label>
      <input class={C.input} id="checkout-email" name="email" type="email" autocomplete="email" />
    </div>
    <div class={C.field} data-checkout-field="phone" data-format={phoneFormat}>
      <label class={C.label} for="checkout-phone">{phoneLabel}</label>
      <input class={C.input} id="checkout-phone" name="phone" type="tel" autocomplete="tel" />
    </div>
  </div>
</section>
