---
// Фаза B (vanilla): новая канон-секция MultiColumns в манере vanilla (см.
// themes/vanilla/MANNER.md §10: карточек-фич у верстальщика нет — композиция
// из манеры: светлая секция §2 (vanilla-pad, py-20 md:py-28, контейнер 1180
// gap-8), плоские карточки §4 (подложка тона медиа-плейсхолдера #ECEBE7,
// радиус 0), типографика §1 (Bitter italic заголовок секции, Arsenal
// uppercase заголовки колонок), грид в ритме коллекций (1/md:2/xl:3 gap-4).
// Процесс-эталон — bloom MultiColumns. Схема полей = packages/theme-base/
// blocks/MultiColumns/MultiColumns.puckConfig.ts.
// ПУСТОЕ СОСТОЯНИЕ (без columns[]) = ПЛЕЙСХОЛДЕР по контракту Figma 1:19335
// (3 колонки: пустой rect + «Колонна» + нейтральный текст + Кнопка), НЕ
// мок-демо верстальщика. Когда мерчант добавил columns[] — рендер реальных
// данных без изменений (Shopify-модель, как theme-base PopularProducts/
// Collections: пустой выбор = заглушка, выбранное = данные).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading: string | { text, alignment, size } — рендер ТОЛЬКО при
// непустом. Роль = заголовок секции на светлом (Bitter italic 20
// #26311C = 38 49 28, Col:20). Лестница §9: medium/отсутствие = литерал 20,
// small 17, large 24.
// Figma 1:19335 — в ПУСТОМ состоянии (мерчант не задал данные) заголовок секции
// дословный плейсхолдер «Мультиколонны»; задал свой heading → рендерим ЕГО.
const rawHeading = typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "");
const headingSize = p.headingSize ?? p.heading?.size;
const headingSizeCls =
	headingSize === "small" ? "text-[17px]" : headingSize === "large" ? "text-[24px]" : "text-[20px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center" ? " text-center" : headingAlignment === "right" ? " text-right" : "";
const headingCls = `font-vanilla-bitter ${headingSizeCls} font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]${headingAlignCls}`;

// Канон columns[] ≤10 (item: heading|title, text|description, imageUrl|image —
// иконка-квадрат, headingSize/textSize, link {text,href} | flat linkText+link).
// Гейт пустого состояния: НЕТ ручных колонок → ПЛЕЙСХОЛДЕР по контракту
// (Figma 1:19335), НЕ мок-демо верстальщика. Когда мерчант добавил колонки —
// рендерим реальные без изменений (так же, как theme-base PopularProducts/
// Collections: пустой выбор = заглушка, выбранное = данные).
// Контракт Мультиколонн: 3 колонки = пустой rect + «Колонна» +
// «Сочетай текст…» + Кнопка.
const PLACEHOLDER_TEXT = "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.";
const PLACEHOLDER_COLUMNS = [
	{ heading: "Колонна", text: PLACEHOLDER_TEXT, imageUrl: "", link: { text: "Кнопка", href: "/catalog" } },
	{ heading: "Колонна", text: PLACEHOLDER_TEXT, imageUrl: "", link: { text: "Кнопка", href: "/catalog" } },
	{ heading: "Колонна", text: PLACEHOLDER_TEXT, imageUrl: "", link: { text: "Кнопка", href: "/catalog" } },
];
// hasManualColumns: мерчант явно добавил хотя бы одну колонку (Shopify-модель).
const hasManualColumns = Array.isArray(p.columns) && p.columns.length > 0;
// Заголовок секции: мерчант задал свой → ЕГО; пустое состояние → дословный
// Figma-плейсхолдер «Мультиколонны» (контракт 1:19335). Когда мерчант добавил
// колонки, но заголовок не ввёл — уважаем его выбор (без принудительного текста).
const heading = rawHeading || (hasManualColumns ? "" : "Мультиколонны");
const rawColumns = hasManualColumns ? p.columns : PLACEHOLDER_COLUMNS;
const columns = rawColumns.slice(0, 10).map((c: any) => {
	// Ссылка колонки: canon link {text,href} ИЛИ flat-пара linkText + link
	// (string из arrayFields конструктора). Рендер при непустом тексте.
	const linkText =
		(c.link && typeof c.link === "object" && typeof c.link.text === "string" && c.link.text.trim()
			? c.link.text
			: undefined) ?? (typeof c.linkText === "string" && c.linkText.trim() ? c.linkText : undefined);
	const linkHref =
		(c.link && typeof c.link === "object" && typeof c.link.href === "string" && c.link.href
			? c.link.href
			: undefined) ??
		(typeof c.link === "string" && c.link ? c.link : undefined) ??
		"/catalog";
	return {
		heading:
			(typeof c.heading === "string" && c.heading) || (typeof c.title === "string" && c.title) || "",
		text:
			(typeof c.text === "string" && c.text) ||
			(typeof c.description === "string" && c.description) ||
			"",
		image:
			(typeof c.imageUrl === "string" && c.imageUrl.trim()) ||
			(typeof c.image === "string" && c.image.trim()) ||
			"",
		headingSize: c.headingSize,
		textSize: c.textSize,
		link: linkText ? { text: linkText, href: linkHref } : undefined,
		// Пустое состояние: рисуем нейтральный rect-плейсхолдер вместо иконки.
		isPlaceholder: !hasManualColumns,
	};
});

// Канон displayColumns 1-4: canon-default 3 и отсутствие = манера (грид
// коллекций/товаров: 1 → md:2 → xl:3, gap-4); иное значение — мобильная
// лестница 1 → md:2 фиксирована, xl — через CSS-var (паттерн bloom).
const displayColumnsRaw = Number(p.displayColumns);
const displayColumns =
	Number.isFinite(displayColumnsRaw) && displayColumnsRaw >= 1 && displayColumnsRaw <= 4
		? Math.round(displayColumnsRaw)
		: 3;
const gridCls =
	displayColumns === 3
		? "grid w-full grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3"
		: "grid w-full grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-[repeat(var(--cols),minmax(0,1fr))]";
const gridStyle = displayColumns === 3 ? undefined : `--cols:${displayColumns}`;

// Канон width (s/m/l/full): medium (canon-default из theme-base defaults) И
// отсутствие = ПИКСЕЛЬ манеры — контейнер светлых секций 1180 (Col:16);
// small 780, large 1320 (.vanilla-container без сужения), full — без лимита.
const widthCls =
	p.width === "small"
		? "max-w-[780px]"
		: p.width === "large"
			? "max-w-[1320px]"
			: p.width === "full"
				? "max-w-none"
				: "max-w-[1180px]";

// Канон textPosition (radio «Положение колонн»): left/отсутствие = манера
// vanilla (всё слева, items-start); center — колонки по центру.
const centered = p.textPosition === "center";
const colAlignCls = centered ? "items-center text-center" : "items-start text-left";

// Канон containerEnabled ('true' canon-default; legacy background.enabled).
// «Контейнер» в манере vanilla = плоская подложка карточки тона
// медиа-плейсхолдера (#ECEBE7 = 236 235 231) — различимость колонок на
// surface-фоне секции; false — голые колонки прямо на фоне.
const containerEnabled = String(p.containerEnabled ?? p.background?.enabled ?? "true") !== "false";
const cardSurfaceCls = containerEnabled
	? " rounded-[var(--radius-card,0px)] bg-[rgb(var(--color-surface,236_235_231))] px-6 py-8"
	: "";

// Канон containerColorScheme (hidden) — класс схемы на гриде колонок.
const containerSchemeCls =
	typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";

// Канон buttonText/buttonLink (hidden) — общая кнопка под гридом: solid-CTA
// манеры §3 в габаритах «Смотреть ещё» (px-6 sm:px-16, Cat:239), рендер при
// непустом тексте. active:scale НЕ используется (§3).
const btnText = typeof p.buttonText === "string" && p.buttonText.trim() ? p.buttonText : undefined;
const btnHref =
	(typeof p.buttonLink === "string" && p.buttonLink ? p.buttonLink : undefined) ??
	(typeof p.link === "string" && p.link ? p.link : undefined) ??
	"/catalog";

// Ссылки-CTA колонок: текстовые Arsenal uppercase с подчёркиванием (манера
// ссылок на светлом, цвет подписи коллекции #26311C); buttonStyle='solid'
// (render-only, читаем существующие данные) — solid-кнопка манеры §3.
const solidLinks = p.buttonStyle === "solid";
const colLinkCls = solidLinks
	? "inline-flex h-12 min-h-12 items-center justify-center rounded-[var(--radius-button,0px)] bg-[rgb(var(--color-button-bg,58_69_48))] px-4 font-vanilla-arsenal text-base font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-90"
	: "font-vanilla-arsenal text-base font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))] underline underline-offset-4 transition-opacity hover:opacity-70";

// Шкалы per-item размеров (роль «имя товара» Arsenal 16 uppercase, PC:66;
// body-роль §9): заголовок колонки 14/16*/19, текст 14/16*/19.
const itemHeadingCls = (s: string | undefined) =>
	s === "small" ? "text-[14px]" : s === "large" ? "text-[19px]" : "text-base";
const itemTextCls = (s: string | undefined) =>
	s === "small" ? "text-[14px]" : s === "large" ? "text-[19px]" : "text-base";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

// colorScheme навешивает обёрткой composeV2Page; фон секции — токен с
// фоллбеком родного светлого фона (#EEEEEE = 238 238 238, МАННЕРА §7).
const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="vanilla-pad w-full bg-[rgb(var(--color-bg,238_238_238))] py-20 md:py-28"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class={`vanilla-container flex ${widthCls} flex-col gap-8`}>
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-animate
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}
		<ul class={`${gridCls}${containerSchemeCls}`} role="list" style={gridStyle}>
			{
				columns.map((c, index) => (
					<li
						class={`group flex w-full flex-col ${colAlignCls} gap-4${cardSurfaceCls}`}
						data-animate
						data-animate-delay={`${index * 0.08}s`}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={index}
						data-puck-subsection-field="columns"
					>
						{c.image ? (
							<img
								src={c.image}
								alt=""
								width="44"
								height="44"
								loading="lazy"
								decoding="async"
								class="h-11 w-11 rounded-[var(--radius-media,0px)] object-contain transition-transform duration-300 ease-out group-hover:scale-105"
							/>
						) : (
							c.isPlaceholder && (
								<div
									class="h-[120px] w-full rounded-[var(--radius-media,0px)] bg-[rgb(var(--color-surface,236_235_231))]"
									aria-hidden="true"
								/>
							)
						)}
						{c.heading && (
							<h3
								class={`font-vanilla-arsenal ${itemHeadingCls(c.headingSize)} font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]`}
							>
								{c.heading}
							</h3>
						)}
						{c.text && (
							<p
								class={`font-vanilla-arsenal ${itemTextCls(c.textSize)} font-normal leading-[1.45] text-[rgb(var(--color-muted,68_68_68))]`}
								set:html={c.text}
							/>
						)}
						{c.link && (
							<a href={c.link.href} class={colLinkCls}>
								{c.link.text}
							</a>
						)}
					</li>
				))
			}
		</ul>
		{
			btnText && (
				<div class="flex justify-center" data-animate>
					<a
						href={btnHref}
						class="inline-flex h-12 min-h-12 items-center justify-center rounded-[var(--radius-button,0px)] bg-[rgb(var(--color-button-bg,58_69_48))] px-6 font-vanilla-arsenal text-base font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-90 sm:px-16"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="102"
						data-puck-subsection-field="buttonText"
					>
						{btnText}
					</a>
				</div>
			)
		}
	</div>
</section>
