---
import SatinPicture from "../img/SatinPicture.astro";
import { SITE_TITLE } from "../../consts";

// ОЖИВЛЕНИЕ (Фаза B, контракт rose/bloom Hero): канон-схема theme-base Hero.puckConfig
// поверх разметки верстальщика. Тело ниже — verbatim; дефолтные ветки тернарников =
// прежним строкам байт-в-байт (цвета → токены с пиксель-фоллбеком MANNER.md §7).
// ОБЯЗАТЕЛЬНО сохранены legacy flat-пропсы title/subtitle/ctaText/ctaLink/backgroundImage —
// index.astro:17-23 зовёт секцию с ними, их рендер не меняется.
const p = Astro.props as Record<string, any>;
const id = p.id;

// ── Пустое состояние (Figma 1:19335) ────────────────────────────────────────
// Контракт плейсхолдеров: когда мерчант НИЧЕГО не настроил (секция в дефолте),
// рендерим нейтральный ПЛЕЙСХОЛДЕР (пустой image-rect surface-тона + заголовок
// секции + поясняющий текст + кнопка), а НЕ мок-демо верстальщика
// («Там, где классика встречается с характером» + фото кампании). Эталон —
// theme-base PopularProducts/Collections (гейт на наличии данных → DEMO).
// Гейт Hero = заданное мерчантом фоновое изображение ИЛИ собственный текст
// заголовка/кикера. Любой реальный сигнал → рендер реальных данных без изменений
// (фото-половина с SatinPicture, overlay, split — всё как было).
const rawBackgroundImage =
	(typeof p.backgroundImages?.url1 === "string" && p.backgroundImages.url1.trim()
		? p.backgroundImages.url1
		: undefined) ??
	(typeof p.backgroundImage === "string" && p.backgroundImage.trim() ? p.backgroundImage : undefined) ??
	(typeof p.image?.url === "string" && p.image.url.trim() ? p.image.url : undefined);
const hasMerchantTitle = typeof (p.heading?.text ?? p.title) === "string" && String(p.heading?.text ?? p.title).trim();
const hasMerchantSubtitle =
	typeof (p.text?.content ?? p.subtitle) === "string" && String(p.text?.content ?? p.subtitle).trim();
// Реальные данные есть, если задано фоновое фото или собственный текст героя.
const hasData = !!rawBackgroundImage || !!hasMerchantTitle || !!hasMerchantSubtitle;
// Пустое состояние = инверсия hasData. Тогда секция рендерит ДОСЛОВНЫЙ
// Figma-плейсхолдер типа «Изображение» (1:19335): пустой image-rect surface-тона
// + overlay-лейбл «Изображение» + хелпер «Покажи и расскажи о своем товаре в одном
// блоке» + кнопка «Кнопка». Эталон — rose Hero.astro (isEmpty-ветка). НЕ
// split-блок верстальщика с «Заголовок»/«Поясняющий текст».
const isEmpty = !hasData;
// Дословные тексты Figma-плейсхолдера (тип «Изображение»).
const PH_LABEL = "Изображение";
const PH_HELPER = "Покажи и расскажи о своем товаре в одном блоке";
const PH_BUTTON = "Кнопка";
// Контракт картиночных секций (правило 2): в пустом состоянии картинка
// показывается ВСЕГДА — фолбэк = дизайн-ассет landscape-image.png из
// packages/theme-base/public/placeholders (раздаётся на каждой теме как
// /placeholders/landscape-image.png), а НЕ пустой surface-rect и НЕ мок-фото
// героя. Паритет vanilla/rose Hero.astro empty-state.
const PH_IMAGE = "/placeholders/landscape-image.png";

// Лейблы заданного состояния (рендер мерчанта — НЕ трогаем при наличии данных).
const title = hasData ? (p.heading?.text ?? p.title ?? SITE_TITLE) : PH_LABEL;
// Канон text.content — КИКЕР НАД заголовком (порядок верстальщика: subtitle перед h1).
const subtitle = hasData
	? (p.text?.content ?? p.subtitle ?? "Там, где классика встречается с характером")
	: PH_HELPER;
const ctaText = hasData ? (p.primaryButton?.text ?? p.cta?.text ?? p.ctaText ?? "В каталог") : PH_BUTTON;
const ctaLink =
	p.primaryButton?.link?.href ??
	(typeof p.primaryButton?.link === "string" ? p.primaryButton.link : undefined) ??
	p.cta?.href ??
	p.ctaLink ??
	"#collections";
// Фоновое фото рендерим ТОЛЬКО когда мерчант его задал. Пусто → image-rect
// surface-тона (пустое состояние), без демо-фото кампании верстальщика.
const backgroundImage = rawBackgroundImage;
// Канон backgroundImages.url2 (+legacy backgroundImage2): фото-половина делится на
// 2 кадра grid-cols-2 ТОЛЬКО когда второе фото задано; иначе одиночный рендер дословно.
const backgroundImage2 = p.backgroundImages?.url2 ?? p.backgroundImage2;

// ДВА НЕЗАВИСИМЫХ размера у Hero:
//   • p.size — ВЫСОТА фото-половины/текст-колонки (heroHeightCls ниже). НЕ шрифт.
//   • heading.size / text.size — размер ШРИФТА заголовка/кикера (поля «Размер
//     заголовка»/«Размер текста»). Возвращены по решению владельца (откат unify
//     ee611471). font-size берётся ТОЛЬКО из heading.size/text.size, БЕЗ фолбэка на
//     p.size (иначе регулятор высоты снова менял бы кегль). Отсутствие → дефолт-
//     ветка large = ЛИТЕРАЛ верстальщика (MANNER.md §9) байт-в-байт прежнему виду.
//   заголовок: small 18/22 → medium 22/27 → large 26/32 (Kelly Slab uppercase)
//   кикер:     small 11    → medium 14    → large 16    (Arsenal light uppercase)
const headingSize = p.heading?.size;
const headingCls =
	headingSize === "small"
		? "font-logo text-[18px] font-normal uppercase leading-[1.08] text-[rgb(var(--color-heading,0_0_0))] md:text-[22px]"
		: headingSize === "medium"
			? "font-logo text-[22px] font-normal uppercase leading-[1.08] text-[rgb(var(--color-heading,0_0_0))] md:text-[27px]"
			: "font-logo text-[26px] font-normal uppercase leading-[1.08] text-[rgb(var(--color-heading,0_0_0))] md:text-[32px]";
const textSize = p.text?.size;
const subtitleCls =
	textSize === "small"
		? "font-manrope text-[11px] font-light uppercase tracking-[0.04em] text-[rgb(var(--color-muted,153_153_153))]"
		: textSize === "medium"
			? "font-manrope text-[14px] font-light uppercase tracking-[0.04em] text-[rgb(var(--color-muted,153_153_153))]"
			: "font-manrope text-[16px] font-light uppercase tracking-[0.04em] text-[rgb(var(--color-muted,153_153_153))]";
// «Размер» → высота фото-половины/текст-колонки (md:h-*). large (дефолт satin) =
// прежняя h-[680px] байт-в-байт; medium ≈0.82×, small ≈0.64×. Дефолт (p.size не
// задан) = large. Mobile aspect-[375/362] остаётся неизменным (портретный кадр).
const heroSize = p.size === "small" ? "small" : p.size === "medium" ? "medium" : "large";
const heroHeightCls = {
	large: "md:h-[680px]",
	medium: "md:h-[560px]",
	small: "md:h-[440px]",
}[heroSize];

// «Размер» (p.size) масштабирует не только высоту медиа, но и подложку-контейнер
// (max-w/gap/padding) + CTA-кнопку — симметрично (medium ≈0.82×, small ≈0.64×). large =
// прежние satin-значения байт-в-байт. Шрифты заголовка/кикера НЕ трогаем (у них свои
// поля heading.size/text.size).
const panelMaxWCls = {
	large: "max-w-[420px]",
	medium: "max-w-[344px]",
	small: "max-w-[270px]",
}[heroSize];
const panelGapCls = {
	large: "gap-6",
	medium: "gap-5",
	small: "gap-4",
}[heroSize];
const panelPadCls = {
	large: "p-6 md:p-10",
	medium: "p-5 md:p-8",
	small: "p-4 md:p-6",
}[heroSize];
const ctaSizeCls = {
	large: "min-h-12 px-6 text-[16px]",
	medium: "min-h-11 px-5 text-[15px]",
	small: "min-h-10 px-4 text-[14px]",
}[heroSize];

// Кнопки манеры §3 на токенах — реплика .satin-button.satin-button-md (литеральные
// --satin-* тех классов не реагируют на смену схемы, поэтому утилиты с токенами):
// dark = чёрная заливка (кнопка-1: 0_0_0 / 255_255_255), light = контурная (кнопка-2 —
// родная роль satin: бордер/текст 0_0_0 на прозрачном), радиус rounded-[var(--radius-button,0px)].
const BTN_DARK =
	`inline-flex ${ctaSizeCls} w-fit items-center justify-center rounded-[var(--radius-button,0px)] border border-solid border-[rgb(var(--color-button-bg,0_0_0))] bg-[rgb(var(--color-button-bg,0_0_0))] font-manrope font-normal uppercase leading-none text-[rgb(var(--color-button-text,255_255_255))] transition-opacity duration-[180ms] hover:opacity-[0.78]`;
const BTN_LIGHT =
	`inline-flex ${ctaSizeCls} w-fit items-center justify-center rounded-[var(--radius-button,0px)] border border-solid border-[rgb(var(--color-button-2-text,0_0_0))] bg-transparent font-manrope font-normal uppercase leading-none text-[rgb(var(--color-button-2-text,0_0_0))] transition-opacity duration-[180ms] hover:opacity-[0.78]`;
// Канон buttonStyle: solid (canon-default) И отсутствие = dark литерал; outlined = light.
const primaryBtnCls = p.buttonStyle === "outlined" ? BTN_LIGHT : BTN_DARK;
// Канон secondaryButton — рендер ТОЛЬКО при непустом тексте, рядом в ряд gap-3, light.
const secondaryText =
	typeof p.secondaryButton?.text === "string" && p.secondaryButton.text.trim()
		? p.secondaryButton.text
		: undefined;
const secondaryLink =
	p.secondaryButton?.link?.href ??
	(typeof p.secondaryButton?.link === "string" ? p.secondaryButton.link : undefined) ??
	"/catalog";

// Канон overlay 0-100 → чёрный слой на фото-половине (у верстальщика 0 — слоя нет).
const overlayN = Math.max(0, Math.min(100, Number(p.overlay) || 0));

// Канон container (toggle «Контейнер» панели «Изображение») — подложка-плашка
// ТОЛЬКО под текстовым блоком (фон схемы + паддинги + радиус), НЕ затемнение
// всего экрана (это отдельная настройка «Затемнение»/overlay). Паттерн rose Hero
// boxed: на светлой плашке текст героя переключаем на тёмный цвет схемы.
// Дефолт/пусто = 'false' → плашки нет → рендер байт-в-байт прежним строкам.
const boxed = String(p.container ?? "false") === "true";
const boxedCls = boxed
	? ` rounded-[var(--radius-card,0px)] bg-[rgb(var(--color-bg,255_255_255))]/95 ${panelPadCls} shadow-sm [&_h1]:!text-[rgb(var(--color-heading,0_0_0))] [&_p]:!text-[rgb(var(--color-muted,153_153_153))]`
	: "";

// Канон position (видимое поле панели) / contentPosition (legacy, те же 9 значений) —
// РАЗМЕЩЕНИЕ контент-блока по сетке: вертикаль (top/center=середина/bottom) → items-*
// на текст-колонке satin-bleed-left; горизонталь (left/center/right) → размещение блока
// внутри левой половины (mx-auto/ml-auto). Пустой проп = дефолт верстальщика
// (вертикаль СЕРЕДИНА, горизонталь СЛЕВА — байт-в-байт прежним строкам).
// Явное 'center' (По центру) = СЕРЕДИНА (раньше падало в дефолтную ветку — это и был баг).
// Выравнивание (alignment) теперь НЕЗАВИСИМО и отвечает только за выравнивание КОНТЕНТА.
const posRaw =
	typeof p.position === "string" && p.position
		? p.position
		: typeof p.contentPosition === "string"
			? p.contentPosition
			: "";
const vPos = posRaw.startsWith("top")
	? "top"
	: posRaw.startsWith("bottom")
		? "bottom"
		: posRaw === "center" || posRaw.startsWith("center")
			? "middle"
			: ""; // пусто = дефолт (середина)
const hPos = posRaw.endsWith("left") ? "left" : posRaw.endsWith("right") ? "right" : "center";
// vJustifyCls (вертикаль ПОЗИЦИИ) → items-* на flex-колонке; дефолт/пусто = середина.
const vJustifyCls = vPos === "top" ? "items-start" : vPos === "bottom" ? "items-end" : "items-center";
const vPadCls = vPos === "top" || vPos === "bottom" ? "md:py-12" : "md:py-0";
// hItemsCls (горизонталь ПОЗИЦИИ) → размещение блока в половине: пусто/дефолт = слева
// (без margin, байт-в-байт); center = mx-auto; right = ml-auto.
const hItemsCls = posRaw && hPos === "center" ? "mx-auto" : hPos === "right" ? "ml-auto" : "";
// alignment — выравнивание КОНТЕНТА внутри блока (НЕ двигает сам блок — это делает
// Позиция). items-*/text-* выравнивают заголовок/текст/кнопки друг относительно друга.
// Дефолт/пусто = прежняя строка байт-в-байт (без items-*/text-*, слева).
const alignItemsCls = p.alignment === "left" ? "items-start" : p.alignment === "right" ? "items-end" : p.alignment === "center" ? "items-center" : "";
const textAlignCls = p.alignment === "left" ? "text-left" : p.alignment === "right" ? "text-right" : p.alignment === "center" ? "text-center" : "";
const buttonsJustifyCls = p.alignment === "right" ? "justify-end" : p.alignment === "center" ? "justify-center" : "justify-start";
const textColCls =
	`satin-bleed-left order-2 flex ${vJustifyCls} py-12 pr-4 md:order-1 ${heroHeightCls} ${vPadCls} md:pr-0`;
const blockCls =
	[hItemsCls, `flex ${panelMaxWCls} flex-col`, alignItemsCls, panelGapCls, textAlignCls]
		.filter(Boolean)
		.join(" ") + boxedCls;
const rowJustifyCls = buttonsJustifyCls;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T14).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

{
	isEmpty ? (
		/* Пустое состояние (Figma 1:19335, тип «Изображение»): пустой image-rect
		   surface-тона на всю секцию + overlay-лейбл «Изображение» + хелпер-текст +
		   кнопка «Кнопка». Без мок-фото и без split-контента верстальщика
		   («Заголовок»/«Поясняющий текст»). Эталон — rose Hero.astro isEmpty-ветка.
		   Puck-subsection-атрибуты сохранены (heading=100, text=101,
		   primaryButton=102) — блок остаётся выделяемым/редактируемым в конструкторе. */
		<section
			class="relative w-full overflow-hidden bg-[#111111]"
			aria-labelledby="hero-title"
			data-puck-component-id={id}
			style={paddingStyle}
		>
			<div class={`relative aspect-[375/362] w-full md:aspect-auto ${heroHeightCls}`}>
				{/* Контракт картиночной секции (правило 2): дизайн-ассет
				    landscape-image.png показывается ВСЕГДА (object-cover) + штатное
				    затемнение для читаемости overlay-лейбла. НЕ пустой surface-rect.
				    Эталон vanilla/rose Hero.astro empty-state. Плоский <img> (НЕ
				    SatinPicture): у placeholder-PNG нет соимённого .webp, а SatinPicture
				    безусловно эмитит <source srcset=*.webp> → 404 + <picture> не
				    откатывается (баг project_cart_thumb_image_bug). */}
				<img src={PH_IMAGE} alt="" loading="eager" fetchpriority="high" class="absolute inset-0 size-full object-cover object-center" aria-hidden="true" />
				<div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-black/30 to-black/45" aria-hidden="true"></div>
				<div class="absolute inset-0 z-10 flex w-full flex-col items-center justify-center gap-6 px-4 text-center sm:px-5 md:px-10">
					<div class="flex w-full max-w-[540px] flex-col items-center gap-4 text-center md:max-w-[640px]">
						<h1
							id="hero-title"
							class="font-logo text-[26px] font-normal uppercase leading-[1.08] text-white md:text-[32px]"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="100"
							data-puck-subsection-field="heading"
						>
							{PH_LABEL}
						</h1>
						<p
							class="font-manrope text-[16px] font-light uppercase tracking-[0.04em] text-white/80"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="101"
							data-puck-subsection-field="text"
						>
							{PH_HELPER}
						</p>
					</div>
					<a
						href={ctaLink}
						class="inline-flex min-h-12 w-fit items-center justify-center rounded-[var(--radius-button,0px)] border border-solid border-white bg-white px-6 font-manrope text-[16px] font-normal uppercase leading-none text-[#111111] transition-opacity duration-[180ms] hover:opacity-[0.78]"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="102"
						data-puck-subsection-field="primaryButton"
					>
						{PH_BUTTON}
					</a>
				</div>
			</div>
		</section>
	) : (
<section
	class="relative w-full bg-[rgb(var(--color-bg,255_255_255))]"
	aria-labelledby="hero-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto grid w-full max-w-[1920px] grid-cols-1 md:grid-cols-2">
		<div class={textColCls}>
			<div class={blockCls}>
				<div class="flex flex-col gap-4">
					<p
						class={subtitleCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="101"
						data-puck-subsection-field="text"
					>
						{subtitle}
					</p>
					<h1
						id="hero-title"
						class={headingCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="100"
						data-puck-subsection-field="heading"
					>
						{title}
					</h1>
				</div>
				{
					secondaryText ? (
						<div class={`flex w-full flex-row flex-wrap items-center gap-3 ${rowJustifyCls}`}>
							<a
								href={ctaLink}
								class={primaryBtnCls}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="102"
								data-puck-subsection-field="primaryButton"
							>
								{ctaText}
							</a>
							<a
								href={secondaryLink}
								class={BTN_LIGHT}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="103"
								data-puck-subsection-field="secondaryButton"
							>
								{secondaryText}
							</a>
						</div>
					) : (
						<a
							href={ctaLink}
							class={primaryBtnCls}
							data-puck-subsection-parent={id}
							data-puck-subsection-index="102"
							data-puck-subsection-field="primaryButton"
						>
							{ctaText}
						</a>
					)
				}
			</div>
		</div>

		<div
			class:list={[
				`relative order-1 aspect-[375/362] overflow-hidden md:order-2 md:aspect-auto ${heroHeightCls}`,
				// Пустое состояние — пустой image-rect surface-тона темы (Figma 1:19335);
				// с фото — чёрная подложка верстальщика (под object-cover кадрами).
				backgroundImage ? "bg-[#111111]" : "bg-[rgb(var(--color-surface,245_245_245))]",
			]}
		>
			{
				backgroundImage ? (
					backgroundImage2 ? (
						<div class="absolute inset-0 grid grid-cols-2">
							<SatinPicture
								src={backgroundImage}
								alt={title}
								loading="eager"
								fetchpriority="high"
								class="size-full object-cover object-center"
							/>
							<SatinPicture
								src={backgroundImage2}
								alt=""
								loading="eager"
								fetchpriority="high"
								class="size-full object-cover object-center"
							/>
						</div>
					) : (
						<SatinPicture
							src={backgroundImage}
							alt={title}
							loading="eager"
							fetchpriority="high"
							class="absolute inset-0 size-full object-cover object-center"
						/>
					)
				) : null
			}
			{
				backgroundImage && overlayN > 0 && (
					<div
						class="pointer-events-none absolute inset-0 z-[1] bg-black"
						style={`opacity:${overlayN / 100}`}
					/>
				)
			}
		</div>
	</div>
</section>
	)
}
