---
// Фаза B (chrome): новая канон-секция PromoBanner в манере bloom (themes/bloom/MANNER.md §8).
// Схема полей = packages/theme-base/blocks/PromoBanner/PromoBanner.puckConfig.ts:
// text, link {text, href} (+ legacy linkText/linkUrl), size (thin/small/medium/large),
// textTransform (none/uppercase), colorScheme (обёртку даёт композитор), padding {top,bottom}.
// Тело = инлайн-полоса объявления верстальщика (Header.astro:43-47) дословно; в
// канон-композиции Header свою полосу не рендерит (там она только в статик-режиме).
const p = Astro.props as Record<string, any>;
const id = p.id;
const text = p.text ?? "Акция на новую коллекцию. Узнать больше";

// Канон link {text, href} + legacy linkText/linkUrl. Подчёркнутый хвост-ссылка —
// НОВЫЙ элемент (у верстальщика инлайн-полоса без ссылки; классы хвоста — из
// header/PromoBanner.astro:17), рендерится ТОЛЬКО при непустом link.text.
const linkText =
	(typeof p.link?.text === "string" && p.link.text.trim() ? p.link.text : undefined) ??
	(typeof p.linkText === "string" && p.linkText.trim() ? p.linkText : undefined);
const linkHref =
	p.link?.href ?? p.linkUrl ?? (typeof p.link === "string" ? p.link : undefined) ?? "/";

// Канон size: 'thin' (canon-default из theme.json blockDefaults) И отсутствие →
// ЛИТЕРАЛ верстальщика py-2 (полоса ≈33px). Увеличенные варианты — лестница манеры
// шагом 8px: small → min-h-10 (40px), medium → min-h-12 (48px), large → min-h-14
// (56px); текст центрируется флексом. Дефолтная ветка = прежняя строка классов
// байт-в-байт (цвет → токен с пиксель-фоллбеком §7).
const size = p.size;
const rootCls =
	size === "small"
		? "flex min-h-10 w-full items-center justify-center bg-[rgb(var(--color-bg,227_142_159))] py-2 text-center"
		: size === "medium"
			? "flex min-h-12 w-full items-center justify-center bg-[rgb(var(--color-bg,227_142_159))] py-2 text-center"
			: size === "large"
				? "flex min-h-14 w-full items-center justify-center bg-[rgb(var(--color-bg,227_142_159))] py-2 text-center"
				: "w-full bg-[rgb(var(--color-bg,227_142_159))] py-2 text-center";

// Канон textTransform: 'uppercase' (canon-default из blockDefaults) И отсутствие =
// литерал верстальщика uppercase; явный 'none' снимает капс.
const textCls =
	p.textTransform === "none"
		? "font-inter text-[12px] font-normal leading-normal text-[rgb(var(--color-text,255_255_255))]"
		: "font-inter text-[12px] font-normal uppercase leading-normal text-[rgb(var(--color-text,255_255_255))]";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose
// T14). {12,12} = canon-default puckConfig (его впрыскивает коэрсер) → литерал py-2.
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const isCanonPad = pad && Number(pad.top) === 12 && Number(pad.bottom) === 12;
const paddingStyle =
	pad && !isCanonPad
		? `padding-top:${Number(pad.top) || 0}px;padding-bottom:${Number(pad.bottom) || 0}px;`
		: undefined;
---

<div
	class={rootCls}
	role="region"
	aria-live="polite"
	data-bloom-announcement
	data-puck-component-id={id}
	style={paddingStyle}
>
	<p
		class={textCls}
		data-puck-subsection-parent={id}
		data-puck-subsection-index="100"
		data-puck-subsection-field="text"
	>
		{text}
		{
			linkText && (
				<a
					href={linkHref}
					class="ml-1 underline decoration-1 underline-offset-2 transition-opacity hover:opacity-80"
				>
					{linkText}
				</a>
			)
		}
	</p>
</div>
