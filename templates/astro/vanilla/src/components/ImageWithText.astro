---
interface Props {
  image?: string;
  size?: 'small' | 'medium' | 'large';
  width?: 'small' | 'medium' | 'large';
  photoPosition?: 'left' | 'right';
  heading?: { enabled?: string; text?: string };
  text?: { enabled?: string; content?: string };
  button?: { enabled?: string; text?: string; link?: string };
  colorScheme?: string;
  padding?: { top?: number; bottom?: number };
}

const {
  image,
  size = 'medium',
  photoPosition = 'left',
  heading,
  text,
  button,
  colorScheme,
  padding,
} = Astro.props;

const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';

const padTop = padding?.top ?? undefined;
const padBottom = padding?.bottom ?? undefined;
const showHeading = heading?.enabled !== 'false' && heading?.text;
const showText = text?.enabled !== 'false' && text?.content;
const showButton = button?.enabled !== 'false' && button?.text;

const headingSizeMap: Record<string, string> = {
  small: 'text-[16px]',
  medium: 'text-[20px]',
  large: 'text-[28px]',
};
const headingSizeClass = headingSizeMap[size] || headingSizeMap.medium;

const isRight = photoPosition === 'right';

/* Split multi-paragraph text on double newlines */
const textParagraphs = text?.content ? text.content.split(/\n\n+/).filter(Boolean) : [];
---

<section
  class={`iwt-section w-full ${schemeClass}`}
  style={`${padTop !== undefined ? `padding-top: ${padTop}px;` : ''} ${padBottom !== undefined ? `padding-bottom: ${padBottom}px;` : ''} background: rgb(var(--color-background)); color: rgb(var(--color-foreground));`}
>
  <div class={`iwt-container flex flex-col gap-[40px] ${isRight ? 'md:flex-row-reverse' : 'md:flex-row'}`}>
    <!-- Image -->
    <div class="iwt-image-col">
      {image ? (
        <img
          src={image}
          alt={heading?.text ?? ''}
          loading="lazy"
          class="w-full h-full object-cover"
        />
      ) : (
        <div class="w-full h-full min-h-[300px] flex items-center justify-center" style="background: rgb(var(--color-foreground) / 0.03);">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21,15 16,10 5,21"/>
          </svg>
        </div>
      )}
    </div>

    <!-- Content -->
    <div class="iwt-text-col flex flex-col justify-between py-[16px]">
      <div>
        {showHeading && (
          <h2
            class={`${headingSizeClass} font-normal italic leading-[1.2] font-heading`}
            style="color: rgb(var(--color-foreground)); margin-bottom: 12px;"
          >
            {heading!.text}
          </h2>
        )}
        {showText && textParagraphs.length > 1 ? (
          <div class="flex flex-col gap-[12px]">
            {textParagraphs.map((para) => (
              <p
                class="text-[16px] italic leading-[1.25] font-body"
                style="color: rgb(var(--color-foreground) / 0.94); margin: 0;"
              >
                {para}
              </p>
            ))}
          </div>
        ) : showText ? (
          <p class="text-[16px] italic leading-[1.25] font-body" style="color: rgb(var(--color-foreground) / 0.94);">
            {text!.content}
          </p>
        ) : null}
      </div>
      {showButton && (
        <a
          href={button!.link ?? '#'}
          class="inline-flex items-center justify-center h-[48px] px-[16px] text-[16px] font-normal uppercase no-underline hover:opacity-90 transition-colors font-body self-start mt-[40px]"
          style="border: 1.3px solid rgb(var(--color-foreground)); background: transparent; color: rgb(var(--color-foreground)); border-radius: var(--radius-button, 0px);"
        >
          {button!.text}
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .iwt-section {
    padding-top: var(--spacing-section-mobile, 80px);
    padding-bottom: var(--spacing-section-mobile, 80px);
  }
  @media (min-width: 768px) {
    .iwt-section {
      padding-top: var(--spacing-section, 120px);
      padding-bottom: var(--spacing-section, 120px);
    }
  }

  .iwt-container {
    max-width: calc(100% - 40px);
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .iwt-container {
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 20px;
    }
  }
  @media (min-width: 1920px) {
    .iwt-container {
      max-width: none;
      margin: 0;
      padding-left: var(--content-padding, 300px);
      padding-right: var(--content-padding, 300px);
    }
  }

  .iwt-image-col {
    width: 100%;
  }
  @media (min-width: 768px) {
    .iwt-image-col {
      width: 50%;
      flex-shrink: 0;
    }
  }
  @media (min-width: 1440px) {
    .iwt-image-col {
      width: 652px;
      min-width: 652px;
    }
  }

  .iwt-text-col {
    flex: 1;
    min-width: 0;
  }
</style>
