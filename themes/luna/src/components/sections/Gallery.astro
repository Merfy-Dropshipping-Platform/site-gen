---
import LunaPicture from "../img/LunaPicture.astro";
import NtSectionHeading from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtSectionHeading.astro";

const sectionTitle = "Luna journal";
const sectionSubtitle = "Истории, кадры кампаний и вдохновение сезона.";

const posts = [
	{ title: "Свет и объём", image: "/images/4x/Изображение_Галерея.png" },
	{ title: "Новая эра Luna style", image: "/images/4x/Товар_5__2_.png" },
	{ title: "Детали коллекции", image: "/images/4x/Товар_5__3_.png" },
];
---

<section id="gallery" class="w-full bg-white px-4 pb-[80px] pt-[80px] md:px-20 md:pb-[120px] md:pt-[120px] 2xl:px-[300px]" aria-labelledby="gallery-title">
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-10">
		<NtSectionHeading titleId="gallery-title" title={sectionTitle} subtitle={sectionSubtitle} />
		<ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" role="list">
			{posts.map((post) => (
				<li class="border border-[#F5F5F5] bg-white p-2">
					<div class="relative aspect-[430/280] w-full min-h-0">
						<LunaPicture src={post.image} alt={post.title} loading="eager" class="absolute inset-0 size-full object-cover" />
					</div>
					<p class="mt-3 font-manrope text-[14px] font-normal uppercase text-[#000000]">{post.title}</p>
				</li>
			))}
		</ul>
	</div>
</section>

<style>
	#gallery picture img {
		height: 100%;
		width: 100%;
		max-width: none;
	}
</style>
