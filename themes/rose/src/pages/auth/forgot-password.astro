---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Восстановление пароля" description="Восстановление доступа к аккаунту Rose">
	<section class="flex w-full min-h-[calc(100svh-80px)] items-center justify-center bg-white px-4 py-16 sm:px-5 md:px-10 md:py-24 lg:px-16 xl:px-20 2xl:px-[280px]">
		<form class="flex w-full max-w-[430px] flex-col items-center gap-20" data-auth-form novalidate>

			<!-- Заголовок -->
			<div class="flex flex-col items-center gap-3 text-center">
				<p class="rose-auth-title font-comfortaa text-[36px] font-light uppercase leading-none text-[#000000] sm:text-[44px]">
					Восстановление аккаунта
				</p>
				<span class="font-manrope text-[16px] font-normal leading-normal text-[#999999]">
					Мы отправим вам код подтверждения на этот e-mail
				</span>
			</div>

			<!-- Поля -->
			<div class="flex w-full flex-col gap-4">
				<div class="flex flex-col gap-2">
					<label for="email" class="font-manrope text-[16px] font-normal leading-normal text-[#000000]">E-mail</label>
					<input
						id="email"
						name="email"
						type="email"
						autocomplete="email"
						class="rose-input"
					/>
				</div>
			</div>

			<!-- Действия -->
			<div class="flex w-full flex-col items-center gap-10">
				<button type="submit" class="rose-btn-primary">
					Продолжить
				</button>
				<a href="/auth/sign-in" class="font-manrope text-[16px] font-normal leading-normal text-[#999999] transition-colors hover:text-[#000000]">
					Вернуться назад
				</a>
			</div>

		</form>
	</section>
</Layout>

<script>
	document.querySelector<HTMLFormElement>("[data-auth-form]")?.addEventListener("submit", (event) => {
		event.preventDefault();
		alert("Если такой e-mail есть в базе, мы отправили на него инструкции.");
	});
</script>
