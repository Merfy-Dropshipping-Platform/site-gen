---
/**
 * ProductVariants — variant-group selector (Figma 1:21330 «Товар», 314-34673).
 *
 * Единый выбор формы `mode` (поле «Вариации» конструктора). Во ВСЕХ чип-режимах
 * цветные значения = СВОТЧ с реальным назначенным цветом, не-цветовые (размер) =
 * текст-чип; различается только форма:
 *  - 'button'  — скруглённый прямоугольник (--radius-button). Дефолт.
 *  - 'circle'  — круг (rounded-full).
 *  - 'square'  — квадрат (острый угол).
 *  - 'list'    — выпадающий <select> на группу (без свотчей).
 * Тема flux (visual.variantsType='dropdown') тоже форсит dropdown.
 *
 * Чипы несут data-variant-key/value; свотч-чипы дополнительно data-variant-swatch
 * (JS-остров не перетирает их заливку, см. Product.astro hydration).
 */
import type { VariantGroupView, VariantOptionView } from '../Product.types';

interface Props {
  groups: VariantGroupView[];
  type?: 'chips' | 'dropdown';
  /** Legacy single-field (back-compat для старых вызовов/ревизий). */
  mode?: 'button' | 'circle' | 'square' | 'list';
  /** «Стиль»: button (чипы/свотчи в ряд, без лейбла) / list (лейбл + dropdown|свотчи). */
  displayStyle?: 'button' | 'list';
  /** «Вариации»: форма свотча circle/square, либо none. */
  shape?: 'circle' | 'square' | 'none';
}

const {
  groups,
  type = 'chips',
  mode = 'button',
  displayStyle,
  shape,
} = Astro.props as Props;

// Раздельная модель displayStyle×shape. Fallback на legacy `mode` (один enum,
// который коллапсил поля): list→list, circle/square→shape, иначе button/none.
const ds: 'button' | 'list' = displayStyle ?? (mode === 'list' ? 'list' : 'button');
const sh: 'circle' | 'square' | 'none' =
  shape ?? (mode === 'circle' || mode === 'square' ? mode : 'none');

// Figma 1:21387 «Кнопка -- Нет»: при shape='none' значения — ТЕКСТ-КНОПКИ
// (имя цвета текстом; fill=выбран, outline=остальные), БЕЗ свотчей. Свотч
// (реальный назначенный цвет) — ТОЛЬКО при Круг/Квадрат. `isShaped` драйвит
// и свотч-решение, и форму чипа.
const isShaped = sh === 'circle' || sh === 'square';
// Dropdown ТОЛЬКО когда: тема форсит (flux type='dropdown') ИЛИ Список+Нет.
// Список+Круг/Квадрат → свотчи «внутри списка» (лейбл группы сверху + чипы),
// НЕ dropdown (раньше list форсил dropdown и терял форму — это и был баг).
const isDropdown = type === 'dropdown' || (ds === 'list' && !isShaped);
// Список показывает лейбл группы (над dropdown И над свотчами); Кнопка — без лейбла.
const showLabel = ds === 'list';
// Список + Круг/Квадрат → варианты ВЕРТИКАЛЬНЫМ списком строк: у цвета — строка
// со свотчем (реальный цвет платформы) + название; не-цвет (размер) — строка-текст.
// (Кнопка = горизонтальные чипы; Список+Нет = выпадашка.)
const isListShaped = !isDropdown && ds === 'list' && isShaped;
// Форма чипа = shape: Кнопка/Нет = скруглённый прямоугольник (--radius-button),
// Круг = полный круг, Квадрат = острый угол.
const shapeRadius =
  sh === 'circle'
    ? 'rounded-full'
    : sh === 'square'
      ? 'rounded-none'
      : 'rounded-[var(--radius-button)]';

// Карта известных имён цветов → hex. Совпадает с PopularProducts COLOR_HEX.
const COLOR_HEX: Record<string, string> = {
  'чёрный': '#000', 'черный': '#000', 'black': '#000',
  'белый': '#fff', 'white': '#fff',
  'серебро': '#c0c0c0', 'серебряный': '#c0c0c0', 'silver': '#c0c0c0',
  'серый': '#888', 'gray': '#888', 'grey': '#888',
  'красный': '#e00', 'red': '#e00',
  'синий': '#33396d', 'blue': '#33396d',
  'зелёный': '#3eb489', 'зеленый': '#3eb489', 'green': '#3eb489',
  'жёлтый': '#f6dc58', 'желтый': '#f6dc58', 'yellow': '#f6dc58',
  'коричневый': '#8b4513', 'brown': '#8b4513',
  'оранжевый': '#ff7f0e', 'orange': '#ff7f0e',
  'розовый': '#ff69b4', 'pink': '#ff69b4',
  'фиолетовый': '#7b3fa0', 'purple': '#7b3fa0',
  'бежевый': '#f5f0e1', 'beige': '#f5f0e1',
  'голубой': '#5bc0de', 'cyan': '#5bc0de',
};

// Резолв значения опции в CSS-цвет: явный hex/rgb/hsl ИЛИ известное имя.
function resolveColor(value: string): string | null {
  const raw = (value ?? '').trim();
  if (!raw) return null;
  if (/^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$/.test(raw)) return raw;
  if (/^(rgb|rgba|hsl|hsla)\(/i.test(raw)) return raw;
  const named = COLOR_HEX[raw.toLowerCase()];
  return named ?? null;
}

// Текст-чип по mode: «Нет»(button) = текст-КНОПКА по ширине контента (h-12 px-4
// border, rounded по shapeRadius — Figma 1:21387 Button sm Fill/Outline); «Круг»/
// «Квадрат» = узкий чип формы свотча (h-12 min-w-12 border-2, rounded-full/none).
const TEXT_CHIP_BASE = isShaped
  ? 'inline-flex items-center justify-center h-12 min-w-12 px-2 [font-family:var(--font-body)] text-[16px] cursor-pointer transition-colors border-2 border-solid'
  : 'inline-flex items-center justify-center h-12 px-4 [font-family:var(--font-body)] text-[16px] cursor-pointer transition-colors border border-solid';
const SWATCH_CHIP_BASE =
  'relative inline-flex items-center justify-center h-12 w-12 p-0 cursor-pointer transition-colors border-2 border-solid overflow-hidden';

// Стили текст-кнопки. Active ↔ primary button (залита); inactive ↔ обводка
// (secondary); out-of-stock — серая обводка. Все цвета из активной схемы.
function textChipStyle(opt: VariantOptionView, active: boolean): string {
  if (!opt.available) {
    return 'background:rgb(var(--color-text)/0.04); color:rgb(var(--color-muted)); border-color:rgb(var(--color-muted));';
  }
  return active
    ? 'background:rgb(var(--color-button-bg, var(--color-text))); color:rgb(var(--color-button-text, var(--color-bg))); border-color:rgb(var(--color-button-border, var(--color-text)));'
    : 'background:rgb(var(--color-button-secondary-bg, var(--color-bg))); color:rgb(var(--color-button-secondary-text, var(--color-text))); border-color:rgb(var(--color-button-secondary-border, var(--color-text)));';
}

// Стиль обводки свотча (заливка — на внутреннем span). Active — акцентная обводка.
function swatchBorderStyle(opt: VariantOptionView, active: boolean): string {
  if (!opt.available) {
    return 'border-color:rgb(var(--color-muted));';
  }
  return active
    ? 'border-color:rgb(var(--color-button-bg, var(--color-text)));'
    : 'border-color:rgb(var(--color-text)/0.2);';
}
---
{groups.length > 0 && (
  <div
    class:list={['flex flex-col w-full', isDropdown ? 'gap-6' : 'gap-4']}
    data-product-variants
    data-variants-type={type}
    data-variants-mode={mode}
  >
    {groups.map((g) => (
      <div class="w-full flex flex-col gap-3" data-variant-group data-variant-key={g.key}>
        {showLabel && (
          <label
            class="[font-family:var(--font-body)] text-[14px] uppercase text-[rgb(var(--color-text))] tracking-wide shrink-0"
            for={`variant-${g.key}`}
          >{g.key}</label>
        )}

        {isDropdown ? (
          <div class="relative w-full">
            <select
              id={`variant-${g.key}`}
              data-variant-select
              data-variant-key={g.key}
              class="w-full h-14 px-3 pr-10 rounded-[6px] bg-[rgb(var(--color-surface,var(--color-text)/0.04))] [font-family:var(--font-body)] text-[16px] text-[rgb(var(--color-text))] uppercase appearance-none border-0 outline-none cursor-pointer"
            >
              {g.options.map((opt) => (
                <option value={opt.value} disabled={!opt.available}>{opt.value}</option>
              ))}
            </select>
            <svg
              aria-hidden="true"
              class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none w-6 h-6 text-[rgb(var(--color-text))]"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
            >
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </div>
        ) : isListShaped ? (
          /* «Закрытый список» (M$rkul): дропдаун на нативном <details> —
             свёрнут по умолчанию, клик по summary раскрывает список опций со
             свотчами. Закрытое состояние = выбранный вариант (свотч+название
             у цвета, текст у размера); JS-остров обновляет его при выборе и
             закрывает дропдаун. «Цвет из платформы» = opt.swatch (swatchHex). */
          <details class="mfy-variant-dd group/dd relative w-full" data-variant-dd data-variant-key={g.key}>
            <summary
              class="flex items-center gap-3 w-full h-12 px-3 list-none cursor-pointer select-none border-2 border-solid rounded-[var(--radius-button)] bg-[rgb(var(--color-surface,var(--color-bg)))] [font-family:var(--font-body)] text-[16px] text-[rgb(var(--color-text))] [&::-webkit-details-marker]:hidden"
              style="border-color:rgb(var(--color-text)/0.2);"
            >
              {g.options[0] && (g.options[0].swatch ?? resolveColor(g.options[0].value)) && (
                <span class:list={['block h-6 w-6 shrink-0 overflow-hidden border border-[rgb(var(--color-text)/0.15)]', shapeRadius]} data-variant-dd-swatch>
                  <span
                    class:list={['block w-full h-full', shapeRadius]}
                    data-variant-dd-swatch-fill
                    style={`background:${g.options[0].swatch ?? resolveColor(g.options[0].value)};`}
                  />
                </span>
              )}
              <span class="flex-1 text-left" data-variant-dd-label>{g.options[0]?.value}</span>
              <svg aria-hidden="true" class="w-6 h-6 shrink-0 text-[rgb(var(--color-text))] transition-transform group-open/dd:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9" /></svg>
            </summary>
            <ul class="absolute left-0 right-0 top-full z-20 mt-1 flex flex-col gap-1 p-1 m-0 list-none rounded-[var(--radius-button)] border border-[rgb(var(--color-text)/0.12)] bg-[rgb(var(--color-surface,var(--color-bg)))] shadow-[0_8px_24px_rgba(0,0,0,0.12)]">
              {g.options.map((opt, optIdx) => {
                const active = optIdx === 0 && opt.available;
                // «Только для цвета»: реальный цвет платформы (swatchHex, фолбэк
                // имя→hex). null → не-цвет (размер) → строка-текст без свотча.
                const fill = opt.swatch ?? resolveColor(opt.value);
                const hasColor = fill != null;
                return (
                  <li class="w-full">
                    <button
                      type="button"
                      data-variant-chip
                      data-variant-swatch
                      data-variant-dd-option
                      data-variant-key={g.key}
                      data-variant-value={opt.value}
                      data-variant-available={opt.available ? 'true' : 'false'}
                      data-variant-active={active ? 'true' : 'false'}
                      disabled={!opt.available}
                      class:list={[
                        'flex items-center gap-3 w-full h-11 px-2 text-left rounded-[calc(var(--radius-button)*0.75)] [font-family:var(--font-body)] text-[16px] text-[rgb(var(--color-text))] cursor-pointer transition-colors hover:bg-[rgb(var(--color-text)/0.05)] data-[variant-active=true]:bg-[rgb(var(--color-text)/0.08)]',
                        !opt.available ? 'cursor-not-allowed opacity-50 line-through' : '',
                      ]}
                    >
                      {hasColor && (
                        <span class:list={['block h-6 w-6 shrink-0 overflow-hidden border border-[rgb(var(--color-text)/0.15)]', shapeRadius]}>
                          <span class:list={['block w-full h-full', shapeRadius]} data-variant-swatch-fill style={`background:${fill};`} />
                        </span>
                      )}
                      <span class="flex-1">{opt.value}</span>
                    </button>
                  </li>
                );
              })}
            </ul>
          </details>
        ) : (
          <div class="flex flex-wrap gap-2">
            {g.options.map((opt, optIdx) => {
              const active = optIdx === 0 && opt.available;
              // Цвет → свотч (реальный цвет платформы swatchHex, фолбэк имя→hex)
              // во всех чип-режимах; не-цвет (размер) → текст-чип.
              const colorHex = isShaped ? (opt.swatch ?? resolveColor(opt.value)) : null;
              const asSwatch = colorHex != null;

              if (asSwatch) {
                const fill = colorHex as string;
                return (
                  <button
                    type="button"
                    data-variant-chip
                    data-variant-swatch
                    data-variant-key={g.key}
                    data-variant-value={opt.value}
                    data-variant-available={opt.available ? 'true' : 'false'}
                    data-variant-active={active ? 'true' : 'false'}
                    disabled={!opt.available}
                    title={opt.value}
                    aria-label={opt.value}
                    class:list={[
                      SWATCH_CHIP_BASE,
                      shapeRadius,
                      !opt.available ? 'cursor-not-allowed opacity-60' : '',
                    ]}
                    style={swatchBorderStyle(opt, active)}
                  >
                    <span
                      class:list={['block w-full h-full', shapeRadius]}
                      data-variant-swatch-fill
                      style={`background:${fill};`}
                    />
                    {!opt.available && (
                      <span
                        aria-hidden="true"
                        class="absolute inset-0 flex items-center justify-center text-[rgb(var(--color-muted))] text-[20px] leading-none"
                      >×</span>
                    )}
                  </button>
                );
              }

              return (
                <button
                  type="button"
                  data-variant-chip
                  data-variant-key={g.key}
                  data-variant-value={opt.value}
                  data-variant-available={opt.available ? 'true' : 'false'}
                  data-variant-active={active ? 'true' : 'false'}
                  disabled={!opt.available}
                  class:list={[
                    TEXT_CHIP_BASE,
                    shapeRadius,
                    !opt.available ? 'line-through cursor-not-allowed' : '',
                  ]}
                  style={textChipStyle(opt, active)}
                >{opt.value}</button>
              );
            })}
          </div>
        )}
      </div>
    ))}
  </div>
)}
