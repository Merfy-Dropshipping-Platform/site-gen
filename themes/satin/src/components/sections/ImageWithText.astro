---
// Фаза B (satin): канон-секция ImageWithText — адаптация ImageBanner.astro (см.
// themes/satin/MANNER.md §10). Тело верстальщика перенесено КОПИЕЙ —
// ImageBanner.astro не тронут (его использует index.astro:28). Схема полей =
// packages/theme-base/blocks/ImageWithText/ImageWithText.puckConfig.ts.
// Смысловой маппинг: canon heading → title баннера (Kelly Slab 26/32),
// canon text → строка-КИКЕР верстальщика НАД заголовком (ImageBanner.astro:45).
import SatinPicture from "../img/SatinPicture.astro";

const p = Astro.props as Record<string, any>;
const id = p.id;

// КОНТРАКТ ПЛЕЙСХОЛДЕРОВ (Figma 1:19335 — пустое состояние секции, ЗАМЕНЯЕТ
// мок-демо верстальщика). Эталон: theme-base ImageWithText.astro
// (PLACEHOLDER_ASSETS.landscape.iwt / пустой image-rect + заголовок секции +
// поясняющий текст + Кнопка). Гейт = наличие реальных данных у мерчанта:
// своё изображение (image.url), свой заголовок или свой текст. Нет ни одного
// сигнала → пустое состояние = ПЛЕЙСХОЛДЕР (НЕ мок-демо «STYLE'S WEAR…» /
// «Новая мужская коллекция» / /images/4x/Мужская_кампания.png верстальщика).
const rawImageUrl =
	typeof p.image?.url === "string" && p.image.url.trim() ? p.image.url.trim() : undefined;
const rawHeading =
	typeof p.heading === "string"
		? p.heading.trim() || undefined
		: typeof p.heading?.text === "string"
			? p.heading.text.trim() || undefined
			: undefined;
const rawText =
	typeof p.text === "string"
		? p.text.trim() || undefined
		: typeof p.text?.content === "string"
			? p.text.content.trim() || undefined
			: undefined;
const isPlaceholder = !rawImageUrl && !rawHeading && !rawText;

// Лейблы пустого состояния (контракт: заголовок секции + поясняющий текст).
// Контракт картиночных секций (правило 2): фолбэк-картинка пустого состояния =
// дизайн-ассет landscape-iwt.png из packages/theme-base/public/placeholders
// (раздаётся на каждой теме как /placeholders/landscape-iwt.png) — картинка
// показывается ВСЕГДА, НЕ пустой image-rect (#FBFBFB) и НЕ мок-фото кампании.
// Эталон: theme-base ImageWithText.astro (PLACEHOLDER_ASSETS.landscape.iwt) +
// vanilla/rose ImageWithText.astro empty-state.
const PLACEHOLDER_HEADING = "Изображение с текстом";
const PLACEHOLDER_TEXT = "Покажи и расскажи о своем товаре в одном блоке";
const PLACEHOLDER_IMAGE = "/placeholders/landscape-iwt.png";

// Канон heading: string | { text, alignment, size }. С данными — реальный
// заголовок мерчанта; пустое состояние — лейбл-плейсхолдер.
const heading = rawHeading ?? PLACEHOLDER_HEADING;
const headingSize = p.heading?.size ?? p.headingSize;
const headingCls =
	headingSize === "small"
		? "font-logo text-[18px] font-normal uppercase leading-[1.1] text-[rgb(var(--color-heading,0_0_0))] md:text-[22px]"
		: headingSize === "medium"
			? "font-logo text-[22px] font-normal uppercase leading-[1.1] text-[rgb(var(--color-heading,0_0_0))] md:text-[27px]"
			: "font-logo text-[26px] font-normal uppercase leading-[1.1] text-[rgb(var(--color-heading,0_0_0))] md:text-[32px]";
// Канон heading.alignment: отсутствие/center = литерал (текст-половина центрована);
// left/right переопределяют выравнивание заголовка.
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "left" ? " text-left" : headingAlignment === "right" ? " text-right" : "";

// Канон text: string | { content, size } → КИКЕР над заголовком (литеральная
// роль ImageBanner.astro:45: Arsenal 16/md:20 light uppercase tracking-[0.04em]
// muted). С данными — кикер мерчанта; пустое состояние — поясняющий текст-
// плейсхолдер (НЕ мок-кикер «Новая мужская коллекция» верстальщика).
// Лестница §9 «Кикер 16» (canon-носитель large): large/отсутствие = 16/20,
// medium 14/17, small 11/14.
const text = rawText ?? (isPlaceholder ? PLACEHOLDER_TEXT : "");
const textSize = p.textSize ?? p.text?.size;
const textCls =
	textSize === "small"
		? "font-manrope text-[11px] font-light uppercase tracking-[0.04em] text-[rgb(var(--color-muted,153_153_153))] md:text-[14px]"
		: textSize === "medium"
			? "font-manrope text-[14px] font-light uppercase tracking-[0.04em] text-[rgb(var(--color-muted,153_153_153))] md:text-[17px]"
			: "font-manrope text-[16px] font-light uppercase tracking-[0.04em] text-[rgb(var(--color-muted,153_153_153))] md:text-[20px]";

// Канон textStyle (hidden): italic → курсив кикера и заголовка.
const italicCls = p.textStyle === "italic" ? " italic" : "";

// Канон image {url, alt}: с данными — изображение мерчанта (кастомные MinIO-URL
// рендерим плоским <img> — SatinPicture добавил бы фантомный .webp-source 404).
// Пустое состояние (нет своего url) → дизайн-ассет landscape-iwt.png (контракт
// картиночных секций, правило 2 — картинка показывается ВСЕГДА), а НЕ пустой
// image-rect (#FBFBFB) и НЕ мок-фото /images/4x/Мужская_кампания.png верстальщика.
const imageUrl = rawImageUrl ?? (isPlaceholder ? PLACEHOLDER_IMAGE : undefined);
const imageAlt =
	typeof p.image?.alt === "string" && p.image.alt.trim() ? p.image.alt : "";
const isThemeAsset = !!imageUrl && imageUrl.startsWith("/");

// Канон imagePosition: canon-default 'left' (его пишет коэрсер) И отсутствие =
// ЛИТЕРАЛ imageSide='left' (фото СЛЕВА, текст справа — ImageBanner.astro:22);
// 'right' зеркалит md:order (механика imgRight верстальщика).
const imgRight = p.imagePosition === "right";

// Канон size (s/m/l) — высота полотна на md+: medium/отсутствие = литерал
// md:h-[680px] (обе половины, ImageBanner.astro:32,40), small 560, large 760.
// Mobile aspect-[375/362] всегда (литерал).
const mdHeightCls =
	p.size === "small" ? "md:h-[560px]" : p.size === "large" ? "md:h-[760px]" : "md:h-[680px]";

// Канон width (s/m/l/full): full/отсутствие = литерал-полотно max-w-[1920px];
// лестница контейнеров манеры: large 1320, medium 1080, small 780.
const widthCls =
	p.width === "small"
		? "max-w-[780px]"
		: p.width === "medium"
			? "max-w-[1080px]"
			: p.width === "large"
				? "max-w-[1320px]"
				: "max-w-[1920px]";

// Канон containerColorScheme (hidden): класс схемы на текст-половине.
const containerSchemeCls =
	typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";

// Кнопка: canon button {text, href|link}. С данными — CTA мерчанта (заданный
// пустой текст СКРЫВАЕТ кнопку). Пустое состояние (контракт «+ Кнопка»):
// нейтральный лейбл «Кнопка» → /catalog, БЕЗ мок-CTA «Перейти» →
// /catalog?collection=Мужское верстальщика.
const btnProvided = p.button !== undefined;
const btnTextProp =
	typeof p.button?.text === "string" && p.button.text.trim() ? p.button.text : undefined;
const btnDefaultText = isPlaceholder ? "Кнопка" : undefined;
const btnText = btnTextProp ?? (btnProvided ? undefined : btnDefaultText);
const btnHref =
	(typeof p.button?.href === "string" && p.button.href ? p.button.href : undefined) ??
	p.button?.link?.href ??
	(typeof p.button?.link === "string" && p.button.link ? p.button.link : undefined) ??
	"/catalog";
// Канон buttonStyle: solid/отсутствие (canon-default) = тёмная CTA литерала
// (метрики .satin-button-md + .satin-button-dark, g:106-126,155-159; цвета
// токенами); outlined = светлая контурная .satin-button-light (§3).
const btnBase =
	"inline-flex min-h-12 items-center justify-center rounded-[var(--radius-button,0px)] border border-solid px-6 text-[16px] font-normal uppercase leading-none transition-opacity duration-[180ms] hover:opacity-[0.78]";
const btnCls =
	p.buttonStyle === "outlined"
		? `${btnBase} border-[rgb(var(--color-button-2-text,0_0_0))] bg-transparent text-[rgb(var(--color-button-2-text,0_0_0))]`
		: `${btnBase} border-[rgb(var(--color-button-bg,0_0_0))] bg-[rgb(var(--color-button-bg,0_0_0))] text-[rgb(var(--color-button-text,255_255_255))]`;

// Канон ctaPosition: inline/отсутствие = литерал (кнопка в потоке под
// заголовком, gap-5); bottom-pinned — контент-блок растягивается, кнопка
// прижимается к нижней кромке (mt-auto).
const bottomPinned = p.ctaPosition === "bottom-pinned";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе
// (full-bleed литерал без вертикальных полей).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	class="relative w-full bg-[rgb(var(--color-bg,255_255_255))]"
	aria-label={text || undefined}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class={`mx-auto grid w-full ${widthCls} grid-cols-1 md:grid-cols-2`}>
		<div
			class:list={[
				"relative order-1 aspect-[375/362] overflow-hidden md:aspect-auto",
				/* Реальное фото ИЛИ дизайн-ассет пустого состояния (landscape-iwt.png) —
				   на тёмной подложке #111111 (cover). Контракт картиночных секций
				   (правило 2): картинка показывается ВСЕГДА, surface-rect не остаётся. */
				"bg-[#111111]",
				mdHeightCls,
				imgRight ? "md:order-2" : "md:order-1",
			]}
			aria-hidden={isPlaceholder ? "true" : undefined}
		>
			{
				imageUrl ? (
					isThemeAsset ? (
						<SatinPicture
							src={imageUrl}
							alt={imageAlt}
							loading="lazy"
							class="absolute inset-0 size-full object-cover object-center"
						/>
					) : (
						<img
							src={imageUrl}
							alt={imageAlt}
							loading="lazy"
							class="absolute inset-0 size-full object-cover object-center"
						/>
					)
				) : null
			}
		</div>
		<div
			class:list={[
				"flex items-center justify-center px-6 py-12 text-center md:py-0",
				mdHeightCls,
				imgRight ? "md:order-1" : "md:order-2",
				containerSchemeCls.trim(),
			]}
		>
			<div class={`flex max-w-[420px] flex-col items-center gap-5${bottomPinned ? " h-full" : ""}`}>
				{text && (
					<p
						class={textCls + italicCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="101"
						data-puck-subsection-field="text"
						set:html={text}
					/>
				)}
				<h2
					class={headingCls + headingAlignCls + italicCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
				{
					btnText && (
						<a
							href={btnHref}
							class={btnCls + (bottomPinned ? " mt-auto" : "")}
							data-puck-subsection-parent={id}
							data-puck-subsection-index="102"
							data-puck-subsection-field="button"
						>
							{btnText}
						</a>
					)
				}
			</div>
		</div>
	</div>
</section>
