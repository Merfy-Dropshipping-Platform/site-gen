{
  "$schema": "https://merfy.ru/schemas/theme-manifest.v2.json",
  "id": "satin",
  "name": "Satin",
  "version": "1.0.0",
  "extends": "@merfy/theme-base@workspace:*",
  "category": "fashion",
  "description": "Satin — elegant monochrome theme with Kelly Slab headings, Arsenal body, uppercase Manrope buttons, and flat (0px) radii for fashion and clothing stores.",
  "author": "Merfy",
  "tokens": "./tokens.json",
  "defaults": {
    "--font-heading": "'Kelly Slab', serif",
    "--font-body": "'Arsenal', sans-serif",
    "--weight-heading": "400",
    "--weight-body": "400",
    "--container-max-width": "1320px",
    "--radius-button": "0px",
    "--radius-input": "0px",
    "--radius-card": "0px",
    "--radius-media": "0px",
    "--radius-field": "0px",
    "--size-hero-heading": "72px",
    "--size-hero-button-h": "48px",
    "--size-nav-link": "16px",
    "--size-section-heading": "20px",
    "--size-newsletter-form-w": "480px",
    "--size-logo-width": "24px",
    "--size-card-border": "1px",
    "--spacing-section-y": "40px",
    "--spacing-grid-col-gap": "40px",
    "--spacing-grid-row-gap": "40px",
    "--button-style": "solid",
    "--footer-layout": "2-part",
    "--contact-form-layout": "wide",
    "--cart-type": "drawer",
    "--card-style": "standard",
    "--card-alignment": "left",
    "--color-error": "255 148 148"
  },
  "blockDefaults": {
    "Header": {
      "logoPosition": "center-absolute"
    },
    "Footer": {
      "variant": "2-part"
    },
    "Newsletter": {
      "formLayout": "inline-submit",
      "alignment": "left"
    },
    "Video": {
      "padded": true,
      "align": "container"
    },
    "PopularProducts": {
      "heading": {
        "text": "Коллекция товаров",
        "size": "medium",
        "alignment": "left"
      },
      "text": {
        "content": "",
        "size": "small"
      },
      "cards": 3,
      "columns": 3,
      "productCard": {
        "columns": 3,
        "buttonStyle": "primary",
        "cardStyle": "portrait",
        "nextPhoto": "false",
        "quickAdd": "true",
        "buttonText": "В корзину"
      },
      "padding": {
        "top": 80,
        "bottom": 80
      },
      "viewAll": {
        "show": true,
        "text": "Смотреть ещё",
        "href": "/catalog"
      }
    },
    "Hero": {
      "backgroundImages": {
        "url1": "https://minio.merfy.ru/product-images/d8d0bc51-183f-4509-b517-150066b71bad.png"
      }
    },
    "ImageWithText": {
      "image": {
        "url": "https://minio.merfy.ru/product-images/2bcd0822-b566-44b3-a973-024a544bd81b.png",
        "alt": ""
      }
    },
    "Gallery": {
      "items": [
        {
          "id": "item-1",
          "type": "image",
          "url": "https://minio.merfy.ru/product-images/42581ed8-e00c-44f7-9554-3b180e2dbbf4.png",
          "alt": "Изображение"
        },
        {
          "id": "item-2",
          "type": "image",
          "url": "https://minio.merfy.ru/product-images/ff8fdfad-e787-4884-91e4-68f2d9b24b68.png",
          "alt": "Изображение"
        },
        {
          "id": "item-3",
          "type": "image",
          "url": "https://minio.merfy.ru/product-images/c7d5a251-242a-4796-b27d-ce6378b2f50c.png",
          "alt": "Изображение"
        }
      ]
    },
    "Slideshow": {
      "slides": [
        {
          "id": "slide-1",
          "imageUrl": "https://minio.merfy.ru/product-images/d8d0bc51-183f-4509-b517-150066b71bad.png",
          "ctaUrl": "/catalog"
        },
        {
          "id": "slide-2",
          "imageUrl": "https://minio.merfy.ru/product-images/2bcd0822-b566-44b3-a973-024a544bd81b.png",
          "ctaUrl": "/catalog"
        },
        {
          "id": "slide-3",
          "imageUrl": "https://minio.merfy.ru/product-images/493706c0-98af-4425-ba6b-5e4f4c451690.png",
          "ctaUrl": "/catalog"
        }
      ]
    },
    "MultiRows": {
      "rows": [
        {
          "id": "row-1",
          "imageUrl": "https://minio.merfy.ru/product-images/ebd21164-eabe-4eaa-ab34-a87716858be7.png"
        },
        {
          "id": "row-2",
          "imageUrl": "https://minio.merfy.ru/product-images/80db2fe6-9f38-4d7f-9be8-7b7a7377f8e1.png"
        }
      ]
    },
    "MultiColumns": {
      "columns": [
        {
          "id": "col-1",
          "heading": "Колонка 1",
          "text": "",
          "imageUrl": "https://minio.merfy.ru/product-images/3d8e5b82-77b2-4a05-add9-d8b507b928de.png"
        },
        {
          "id": "col-2",
          "heading": "Колонка 2",
          "text": "",
          "imageUrl": "https://minio.merfy.ru/product-images/d237e918-2224-4823-a689-582ecda2e575.png"
        }
      ]
    }
  },
  "colorSchemes": [
    {
      "id": "scheme-1",
      "name": "1",
      "tokens": {
        "--color-bg": "8 2 0",
        "--color-surface": "8 2 0",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "200 200 200",
        "--color-primary": "255 255 255",
        "--color-accent": "68 68 68",
        "--color-button-bg": "255 255 255",
        "--color-button-text": "0 0 0",
        "--color-button-border": "255 255 255",
        "--color-button-2-bg": "0 0 0",
        "--color-button-2-text": "255 255 255",
        "--color-button-2-border": "68 68 68"
      }
    },
    {
      "id": "scheme-2",
      "name": "2",
      "tokens": {
        "--color-bg": "255 255 255",
        "--color-surface": "255 255 255",
        "--color-heading": "0 0 0",
        "--color-text": "0 0 0",
        "--color-muted": "153 153 153",
        "--color-primary": "0 0 0",
        "--color-accent": "0 0 0",
        "--color-button-bg": "0 0 0",
        "--color-button-text": "255 255 255",
        "--color-button-border": "0 0 0",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "238 238 238"
      }
    },
    {
      "id": "scheme-3",
      "name": "3",
      "tokens": {
        "--color-bg": "245 245 245",
        "--color-surface": "245 245 245",
        "--color-heading": "0 0 0",
        "--color-text": "0 0 0",
        "--color-muted": "153 153 153",
        "--color-primary": "0 0 0",
        "--color-accent": "0 0 0",
        "--color-button-bg": "0 0 0",
        "--color-button-text": "255 255 255",
        "--color-button-border": "0 0 0",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "238 238 238"
      }
    },
    {
      "id": "scheme-4",
      "name": "4",
      "tokens": {
        "--color-bg": "68 68 68",
        "--color-surface": "68 68 68",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "200 200 200",
        "--color-primary": "255 255 255",
        "--color-accent": "100 100 100",
        "--color-button-bg": "255 255 255",
        "--color-button-text": "68 68 68",
        "--color-button-border": "255 255 255",
        "--color-button-2-bg": "68 68 68",
        "--color-button-2-text": "255 255 255",
        "--color-button-2-border": "100 100 100"
      }
    }
  ],
  "blocks": {
    "Header": {
      "override": {
        "path": "./blocks/Header",
        "reason": "Satin uses 1320px container, Kelly Slab heading font, flat (0px) radii, Manrope uppercase cart badge font, and monochrome iconography."
      }
    },
    "Footer": {
      "override": {
        "path": "./blocks/Footer",
        "reason": "Satin uses 2-part grid (logo+nav LEFT, contact+social RIGHT), uppercase tracking-0.05em on newsletter heading + submit, and a powered-by black strip below copyright."
      }
    },
    "Hero": {
      "override": {
        "path": "./blocks/Hero",
        "reason": "Satin uses edge-to-edge split-fullbleed layout (50/50 text+image, 680px fixed height), Kelly Slab 32px uppercase title, grey #999 Arsenal kicker above title, 10% dark overlay on image, zero radii on solid-black CTA."
      }
    },
    "Collections": {
      "override": {
        "path": "./blocks/Collections",
        "reason": "Satin 3-col portrait grid (430x564 aspect), Arsenal 16px uppercase LEFT-aligned card label, 20px gap between image and label, zero radii, 1320px container with 40px side padding."
      }
    },
    "PopularProducts": {
      "override": {
        "path": "./blocks/PopularProducts",
        "reason": "Satin 3-col portrait grid (430x564 aspect), Arsenal 16px uppercase LEFT-aligned title, strikethrough grey old price, black 'Скидка' badge top-left, zero radii."
      }
    },
    "MultiRows": {
      "override": {
        "path": "./blocks/MultiRows",
        "reason": "Satin alternating 50/50 rows with 640x560 image aspect, Kelly Slab 32px uppercase row headings, Arsenal 16px body, black Manrope uppercase CTA, zero radii."
      }
    },
    "MainText": {
      "override": {
        "path": "./blocks/MainText",
        "reason": "Satin 40px Kelly Slab uppercase heading, Arsenal 16px body, 1320px container with 40px gutters, zero-radius CTA."
      }
    },
    "ImageWithText": {
      "override": {
        "path": "./blocks/ImageWithText",
        "reason": "Satin 50/50 split with 640x560 image, Kelly Slab 32px uppercase heading, Arsenal 16px body, zero-radius black CTA."
      }
    },
    "MultiColumns": {
      "override": {
        "path": "./blocks/MultiColumns",
        "reason": "Satin 3-col grid with 24px gap, Arsenal 16px uppercase left-aligned column titles, flat imagery with zero radii."
      }
    },
    "CollapsibleSection": {
      "override": {
        "path": "./blocks/CollapsibleSection",
        "reason": "Satin FAQ style — hairline dividers instead of rounded cards, Kelly Slab 32px uppercase section heading, Arsenal 16px uppercase summary rows, zero radii."
      }
    },
    "Product": {},
    "Newsletter": {},
    "ContactForm": {}
  },
  "features": {
    "newsletter": true,
    "cart-drawer": true,
    "otp-auth": true,
    "wishlist": false,
    "color-swatches": true,
    "filter-sidebar": true
  },
  "fonts": [
    {
      "family": "Kelly Slab",
      "weights": [
        400
      ],
      "source": "google"
    },
    {
      "family": "Arsenal",
      "weights": [
        400,
        700
      ],
      "source": "google"
    },
    {
      "family": "Manrope",
      "weights": [
        400,
        500
      ],
      "source": "google"
    },
    {
      "family": "Tinos",
      "weights": [
        400
      ],
      "italic": true,
      "source": "google"
    },
    {
      "family": "Roboto",
      "weights": [
        300,
        400
      ],
      "source": "google"
    },
    {
      "family": "Inter",
      "weights": [
        300,
        400
      ],
      "source": "google"
    }
  ],
  "manifestVersion": "2.0",
  "pages": [
    {
      "id": "home",
      "name": "Главная страница",
      "slug": "/",
      "role": "system",
      "contentFile": "pages/home.json",
      "isHome": true
    },
    {
      "id": "page-about",
      "name": "О нас",
      "slug": "/about",
      "role": "system",
      "contentFile": "pages/about.json"
    },
    {
      "id": "page-delivery",
      "name": "Доставка",
      "slug": "/delivery",
      "role": "system",
      "contentFile": "pages/delivery.json"
    },
    {
      "id": "page-contacts",
      "name": "Контакты",
      "slug": "/contacts",
      "role": "system",
      "contentFile": "pages/contacts.json"
    },
    {
      "id": "page-catalog",
      "name": "Коллекции",
      "slug": "/catalog",
      "role": "system",
      "contentFile": "pages/catalog.json"
    },
    {
      "id": "page-collection",
      "name": "Страница коллекции",
      "slug": "/collections/preview",
      "role": "system",
      "contentFile": "pages/collection.json"
    },
    {
      "id": "page-cart",
      "name": "Корзина",
      "slug": "/cart",
      "role": "system",
      "contentFile": "pages/cart.json"
    },
    {
      "id": "page-product",
      "name": "Товар",
      "slug": "/product",
      "role": "system",
      "contentFile": "pages/product.json"
    },
    {
      "id": "page-checkout",
      "name": "Оформление заказа",
      "slug": "/checkout",
      "role": "system",
      "contentFile": "pages/checkout.json"
    }
  ]
}