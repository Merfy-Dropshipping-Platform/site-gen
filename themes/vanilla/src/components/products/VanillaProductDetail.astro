---
/**
 * Разметка страницы товара (PDP) — общий компонент для demo-SSG `[id].astro`
 * и клиентски-гидрируемой `/product?id=` (Option B, спек 098). Единый источник
 * разметки → parity demo ↔ реальный товар (никаких дублей).
 *
 * `data-pdp-*` хуки — точки клиентского патча в `/product?id=` (имя, цена,
 * картинка, описание, варианты, атрибуты корзины). На demo-странице патча нет —
 * рендерится как было.
 *
 * Галерея инлайнится (а не через `ProductGallery.astro`), чтобы тот же компонент
 * работал и для skeleton на `/product?id=` (там нет статичного списка картинок).
 */
import VanillaPicture from "../img/VanillaPicture.astro";
import ShareIcon from "../../icons/ShareIcon.astro";
import { withBase } from "../../lib/with-base";

interface Props {
	product: {
		id?: string;
		name: string;
		price: string;
		oldPrice?: string;
		image: string;
		description?: string;
		brand?: string;
		collection?: string;
		colors?: string[];
		gallery?: string[];
	};
}

const { product } = Astro.props;

const galleryImages =
	product.gallery && product.gallery.length > 0 ? product.gallery : [product.image];
const [mainImage, ...thumbImages] = galleryImages;
const categoryLabel = product.collection ?? product.brand ?? "";
const cartVariantColor = product.colors?.[0] ?? "";
---

<section
	class="vanilla-pad w-full bg-[var(--vanilla-surface)] py-10 md:py-14 lg:min-h-[712px] lg:py-16"
	aria-labelledby="product-title"
	data-pdp-section
	data-cart-color={cartVariantColor}
>
	<div
		class="mx-auto flex w-full max-w-[1320px] flex-col gap-10 xl:flex-row xl:items-start xl:justify-between xl:gap-8 min-[1536px]:gap-16"
	>
		<div class="flex w-full flex-col gap-6 xl:min-w-0 xl:flex-1 xl:gap-8 min-[1536px]:max-w-[628px]">
			<div class="flex flex-col gap-2">
				<p
					class="font-vanilla-arsenal text-sm font-normal leading-none text-[#444444]"
					data-pdp-brand
					hidden={!categoryLabel}
				>
					{categoryLabel}
				</p>
				<h1
					id="product-title"
					class="font-vanilla-arsenal text-xl font-normal leading-none text-black"
					data-pdp-name
				>
					{product.name}
				</h1>
				<div class="flex flex-wrap items-baseline gap-3 pt-1">
					<span class="font-vanilla-arsenal text-base font-normal leading-none text-black" data-pdp-price>
						{product.price}
					</span>
					<span
						class="font-vanilla-arsenal text-sm font-normal leading-none text-[#444444] line-through"
						data-pdp-oldprice
						hidden={!product.oldPrice}
					>
						{product.oldPrice}
					</span>
				</div>
			</div>

			{/* Контейнер вариант-селектора. Demo: пусто (decorative варианты не нужны).
			    /product?id=: клиентский рендер реальных групп из variantCombinations. */}
			<div class="flex flex-col gap-4 empty:hidden" data-pdp-variants hidden></div>

			<div class="flex items-center gap-3" data-pdp-qty>
				<button
					type="button"
					class="flex size-6 items-center justify-center bg-[var(--vanilla-header-bg)] transition-opacity hover:opacity-80"
					aria-label="Уменьшить количество"
					data-action="qty-dec"
				>
					<img src={withBase("/icons/minus.svg")} alt="" width="12" height="12" class="size-3 brightness-0 invert" aria-hidden="true" />
				</button>
				<input
					type="number"
					min="1"
					value="1"
					class="h-6 w-10 bg-transparent text-center font-vanilla-arsenal text-base font-normal leading-none text-black outline-none [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
					aria-label="Количество"
					data-pdp-qty-value
				/>
				<button
					type="button"
					class="flex size-6 items-center justify-center bg-[var(--vanilla-header-bg)] transition-opacity hover:opacity-80"
					aria-label="Увеличить количество"
					data-action="qty-inc"
				>
					<img src={withBase("/icons/plus.svg")} alt="" width="12" height="12" class="size-3 brightness-0 invert" aria-hidden="true" />
				</button>
			</div>

			<div class="flex w-full max-w-[628px] flex-col gap-3">
				<button
					type="button"
					data-add-to-cart
					data-product-id={product.id}
					data-name={product.name}
					data-price={product.price}
					data-old-price={product.oldPrice ?? ""}
					data-image={mainImage}
					data-variant-color={cartVariantColor}
					data-quantity="1"
					class="flex h-14 w-full items-center justify-center border border-black bg-white px-2.5 font-vanilla-arsenal text-base font-normal leading-none text-black transition-opacity hover:opacity-80"
				>
					Добавить в корзину
				</button>
				<button
					type="button"
					data-action="buy-now"
					data-product-id={product.id}
					data-name={product.name}
					data-price={product.price}
					data-image={mainImage}
					class="flex h-14 w-full items-center justify-center bg-[var(--vanilla-header-bg)] px-2.5 font-vanilla-arsenal text-base font-normal leading-none text-white transition-opacity hover:opacity-80"
				>
					Купить сейчас
				</button>
			</div>

			<div class="flex max-w-[628px] flex-col gap-3">
				<h2 class="font-vanilla-arsenal text-base font-normal leading-none text-black">Описание</h2>
				<p class="font-vanilla-arsenal text-sm font-normal leading-[1.4] text-[#444444]" data-pdp-desc>{product.description}</p>
				<button
					type="button"
					data-action="share"
					class="inline-flex w-fit items-center gap-2 pt-1 font-vanilla-arsenal text-sm font-normal leading-none text-black transition-opacity hover:opacity-70"
					aria-label="Поделиться"
				>
					<ShareIcon class="size-4" />
					<span>Поделиться</span>
				</button>
			</div>
		</div>

		<div class="w-full xl:max-w-[660px] xl:shrink-0">
			<div class="flex w-full flex-col gap-4 lg:flex-row lg:items-start lg:gap-5">
				<div class="relative mx-auto aspect-square w-full max-w-[552px] shrink-0 overflow-hidden bg-[var(--vanilla-card)] lg:mx-0 lg:size-[552px]">
					<VanillaPicture
						src={mainImage}
						alt={product.name}
						width="552"
						height="552"
						loading="eager"
						fetchpriority="high"
						class="h-full w-full object-cover"
						data-pdp-main
					/>
				</div>

				{thumbImages.length > 0 && (
					<div
						class="mx-auto flex w-full max-w-[552px] flex-row items-center gap-3 lg:mx-0 lg:w-auto lg:flex-col lg:gap-2"
						data-pdp-thumbs-row
					>
						<div class="flex flex-1 gap-2 overflow-x-auto [scrollbar-width:none] lg:max-h-[280px] lg:w-[88px] lg:flex-col lg:overflow-x-hidden lg:overflow-y-auto [&::-webkit-scrollbar]:hidden">
							{thumbImages.map((img, index) => (
								<button
									type="button"
									class:list={[
										"aspect-square w-[72px] shrink-0 overflow-hidden bg-[var(--vanilla-card)] transition-[opacity,box-shadow] hover:opacity-80 lg:size-[88px]",
										index === 0 ? "opacity-100 ring-1 ring-black/30" : "opacity-50",
									]}
									data-pdp-thumb
									data-image={img}
									aria-label={`Показать изображение ${index + 1}`}
								>
									<VanillaPicture src={img} alt={product.name} width="88" height="88" loading="lazy" class="h-full w-full object-cover" />
								</button>
							))}
						</div>
					</div>
				)}
			</div>
		</div>
	</div>
</section>

<script>
	/**
	 * View Transitions подменяют <main> без полной перезагрузки — обработчики вешаем на astro:page-load
	 * и снимаем через AbortController при уходе со страницы товара.
	 */
	let pdpUiAbort: AbortController | null = null;

	const syncQtyToAddButton = (qty: number) => {
		document.querySelector<HTMLButtonElement>("[data-add-to-cart]")?.setAttribute("data-quantity", String(qty));
	};

	function initVanillaProductPage() {
		pdpUiAbort?.abort();
		pdpUiAbort = null;

		if (!document.querySelector("[data-pdp-section]")) return;

		pdpUiAbort = new AbortController();
		const { signal } = pdpUiAbort;

		// Миниатюры: клик меняет главную картинку + data-image кнопок корзины.
		document.querySelectorAll<HTMLButtonElement>("[data-pdp-thumb]").forEach((thumb) => {
			thumb.addEventListener(
				"click",
				() => {
					const src = thumb.dataset.image;
					const mainEl = document.querySelector<HTMLImageElement>("[data-pdp-main]");
					if (mainEl && src) {
						const webp = src.replace(/\.(png|jpe?g)$/i, ".webp");
						mainEl.src = webp;
						// <picture><source type="image/webp"> также нужно перенацелить,
						// иначе браузер продолжит отдавать webp от предыдущей картинки.
						const source = mainEl
							.closest("picture")
							?.querySelector<HTMLSourceElement>("source[type='image/webp']");
						if (source) source.srcset = webp;
					}
					document.querySelector<HTMLElement>("[data-add-to-cart]")?.setAttribute("data-image", src ?? "");
					document.querySelector<HTMLElement>("[data-action='buy-now']")?.setAttribute("data-image", src ?? "");
				},
				{ signal }
			);
		});

		const qtyInput = document.querySelector<HTMLInputElement>("[data-pdp-qty-value]");
		document.querySelector<HTMLButtonElement>("[data-action='qty-dec']")?.addEventListener(
			"click",
			() => {
				if (!qtyInput) return;
				const next = Math.max(1, Number(qtyInput.value || 1) - 1);
				qtyInput.value = String(next);
				syncQtyToAddButton(next);
			},
			{ signal }
		);
		document.querySelector<HTMLButtonElement>("[data-action='qty-inc']")?.addEventListener(
			"click",
			() => {
				if (!qtyInput) return;
				const next = Number(qtyInput.value || 1) + 1;
				qtyInput.value = String(next);
				syncQtyToAddButton(next);
			},
			{ signal }
		);
		qtyInput?.addEventListener(
			"input",
			() => {
				const value = Math.max(1, Number(qtyInput.value || 1));
				qtyInput.value = String(value);
				syncQtyToAddButton(value);
			},
			{ signal }
		);

		document.querySelector<HTMLButtonElement>("[data-action='share']")?.addEventListener(
			"click",
			async () => {
				try {
					if (navigator.share) {
						await navigator.share({ title: document.title, url: location.href });
					} else {
						await navigator.clipboard.writeText(location.href);
						alert("Ссылка скопирована");
					}
				} catch {
					/* пользователь отменил */
				}
			},
			{ signal }
		);

		document.querySelector<HTMLButtonElement>("[data-action='buy-now']")?.addEventListener(
			"click",
			() => {
				const add = document.querySelector<HTMLElement>("[data-add-to-cart]");
				add?.dispatchEvent(new MouseEvent("click", { bubbles: true }));
				window.location.href = "/cart";
			},
			{ signal }
		);
	}

	initVanillaProductPage();
	document.addEventListener("astro:page-load", initVanillaProductPage);
</script>
