---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import collectionsData from '../../data/collections.json';

// Component map — same set as catalog.astro for now
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Footer from '../../components/Footer.astro';
import Catalog from '../../components/Catalog.astro';
import PromoBanner from '../../components/PromoBanner.astro';
import Collections from '../../components/Collections.astro';
import PopularProducts from '../../components/PopularProducts.astro';
import Gallery from '../../components/Gallery.astro';
import Newsletter from '../../components/Newsletter.astro';

const componentMap: Record<string, any> = {
  Header, Hero, Footer, Catalog, PromoBanner, Collections, PopularProducts, Gallery, Newsletter,
};

export function getStaticPaths() {
  const cols: any[] = Array.isArray(collectionsData) ? (collectionsData as any) : [];
  if (cols.length === 0) {
    return [{ params: { slug: '_placeholder' }, props: { collection: null } }];
  }
  const paths: { params: { slug: string }; props: { collection: any } }[] = [];
  const seen = new Set<string>();
  for (const c of cols) {
    for (const slug of [c.id, c.slug, c.handle].filter(Boolean) as string[]) {
      if (seen.has(slug)) continue;
      seen.add(slug);
      paths.push({ params: { slug }, props: { collection: c } });
    }
  }
  return paths;
}

const { slug } = Astro.params;
const { collection } = Astro.props;

// Read pagesData['page-collection'] template, fallback to inline default if absent
const pagesData = (data as any)?.pagesData ?? {};
const collectionPage = pagesData['page-collection'];

const FALLBACK_DEFAULT = [
  { type: 'Header', props: { id: 'Header-fallback' } },
  {
    type: 'Hero',
    props: {
      id: 'Hero-fallback',
      variant: 'split',
      heading: { text: '{{COLLECTION_NAME}}', size: 'large' },
      subtitle: { content: '{{COLLECTION_DESCRIPTION}}', size: 'medium' },
      padding: { top: 80, bottom: 80 },
    },
  },
  {
    type: 'Catalog',
    props: {
      id: 'Catalog-fallback',
      cards: 24,
      columns: 3,
      showFilter: 'true',
      filterPosition: 'side',
      showSort: 'true',
      padding: { top: 40, bottom: 80 },
    },
  },
  { type: 'Footer', props: { id: 'Footer-fallback' } },
];

const blocks: any[] = collectionPage?.content && Array.isArray(collectionPage.content)
  ? collectionPage.content
  : FALLBACK_DEFAULT;

// Header/Footer fallbacks from siteConfig
const headerBlock = blocks.find((b: any) => b?.type === 'Header');
const footerBlock = blocks.find((b: any) => b?.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};

// Inline template var substitution (mirror of src/utils/template-vars.ts but
// inlined here because Astro pages can't import outside scaffold scope at build).
function renderProps(p: any, vars: Record<string, string>): any {
  if (p === null || p === undefined) return p;
  if (typeof p === 'string') {
    return p.replace(/\{\{(\w+)\}\}/g, (match, key) => vars[key] !== undefined ? String(vars[key]) : match);
  }
  if (Array.isArray(p)) return p.map((item) => renderProps(item, vars));
  if (typeof p === 'object') {
    const out: Record<string, any> = {};
    for (const [k, v] of Object.entries(p)) out[k] = renderProps(v, vars);
    return out;
  }
  return p;
}

const templateVars = {
  COLLECTION_NAME: collection?.title ?? collection?.name ?? slug ?? 'Коллекция',
  COLLECTION_DESCRIPTION: collection?.description ?? '',
  COLLECTION_IMAGE: collection?.image ?? '',
};

const meta = collectionPage?.root?.props?.meta ?? data?.meta ?? {};
const title = renderProps(meta?.title, templateVars) || `${templateVars.COLLECTION_NAME}`;
---
<BaseLayout title={title} description={collection?.description ?? meta?.description}>
  {blocks.map((block: any) => {
    if (!block || !block.type) return null;
    if (block.type === 'Header') {
      return <Header {...headerProps} />;
    }
    if (block.type === 'Footer') {
      return <Footer {...footerProps} />;
    }
    const Comp = componentMap[block.type];
    if (!Comp) return null;
    const resolvedProps = renderProps(block.props, templateVars);
    return <Comp {...resolvedProps} _astroSlug={slug} />;
  })}
</BaseLayout>
