---
import type { PromoBannerProps } from './PromoBanner.puckConfig';
import { PromoBannerClasses as C } from './PromoBanner.classes';

interface Props extends PromoBannerProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const { id, text, linkText, linkUrl, colorScheme, padding } = raw as Props;

// Pupa parity: link {text, href} object preferred over linkText/linkUrl, plus size.
const linkObj = raw.link as { text?: string; href?: string } | undefined;
const resolvedLinkText = linkObj?.text ?? linkText;
const resolvedLinkHref = linkObj?.href ?? linkUrl;
const size = typeof raw.size === 'string' ? raw.size : 'medium';
const sizeClass =
  size === 'large' ? 'text-base py-4' :
  size === 'medium' ? 'text-sm py-3' :
  size === 'small' ? 'text-xs py-2' : '';

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
const schemeClass = colorScheme ? `color-scheme-${String(colorScheme).replace('scheme-', '')}` : '';
---
<section
  class:list={[C.root, schemeClass, sizeClass]}
  data-puck-component-id={id}
  style={paddingStyle}
>
  <div class={C.container}>
    <span class={C.text}>{text}</span>
    {resolvedLinkText && (
      <>
        <span aria-hidden="true">.</span>
        <a href={resolvedLinkHref} class={C.link}>{resolvedLinkText}</a>
      </>
    )}
  </div>
</section>
