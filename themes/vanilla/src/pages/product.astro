---
/**
 * Универсальная страница товара `/product` (Option B, спек 098 + live-wiring).
 *
 * Реальные товары не имеют статических `/products/{id}` страниц (getStaticPaths
 * знает только demo bag-N на сборке сервиса). Эта одна страница рендерит
 * нейтральный skeleton; вся live-гидрация (определение товара по slug пути /
 * ?id= / __MERFY_DEFAULT_PRODUCT_ID__, заполнение data-pdp-* хуков, варианты,
 * корзина, галерея, «Товар не найден») выполняется единым `is:inline`-скриптом
 * ВНУТРИ `VanillaProductDetail`. Источник — ЖИВОЙ `/api/store/products` (как
 * каталог/Popular vanilla), с фолбэком на per-site `/data/products.json` (цены
 * копейки→рубли) и preview storefront-data. Разметка — общий
 * `VanillaProductDetail` (parity с demo `[id].astro`).
 */
import Layout from "../layouts/Layout.astro";
import VanillaProductDetail from "../components/products/VanillaProductDetail.astro";

// Нейтральный skeleton: рендерится до клиентской гидрации (и на demo-сборке без
// данных). placeholder-картинка, без галереи/бренда/старой цены.
const skeleton = {
	id: "",
	name: "Товар",
	price: "",
	image: "/images/placeholder.png",
};
---

<Layout title="Товар">
	{/* Вся live-гидрация PDP живёт ВНУТРИ VanillaProductDetail.astro единым
	    is:inline-скриптом — он работает на обоих маршрутах (`/product` и demo
	    `products/[id]`) и на live (pre-built theme dist), где module-<script>
	    страницы не компилится. Здесь — только скелетон; дублирующий хелпер-скрипт
	    + отдельный not-found убраны (иначе двойная конфликтующая гидрация). */}
	<VanillaProductDetail product={skeleton} />
</Layout>
