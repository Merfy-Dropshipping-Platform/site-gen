---
// Секция MultiColumns («Мультиколонны») в манере flux. Донора-секции у
// верстальщика flux НЕТ (секций всего 4, MANNER §10) — секция собрана в ЕДИНОМ
// flux-языке: ВСЯ секция = font-roboto-flex (заголовок секции / заголовок колонки /
// текст / ссылка / кнопка); прежний дрейф на comfortaa/manrope (наследие
// разошедшегося product-grid порта) УДАЛЁН. Заголовок секции — roboto-flex
// uppercase (как MainText/Popular/Collections); заголовок колонки — roboto-flex;
// текст колонки — roboto-flex 300 (font-light); ссылка — roboto-flex; чёрная CTA
// h-14 uppercase (эталон MainText/Hero, кнопка-2 схем flux). Скролл-анимаций НЕТ —
// манера flux статична (MANNER §6, БЕЗ data-animate), только hover-zoom медиа и
// hover-opacity ссылок/кнопки.
//
// НАСТРОЙКИ = паритет rose MultiColumns (themes/rose/.../MultiColumns.astro):
// читаются те же поля heading / headingSize / columns[] / imageAspectRatio /
// textPosition / containerEnabled / containerColorScheme / buttonText / padding /
// colorScheme + per-колоночные imageSize / headingSize / textSize. Ступени
// размеров — НА БАЗЕ flux (заголовок 19/23, колонка 16/18, текст 14/16), НЕ
// раздутые. colorScheme навешивается обёрткой composeV2Page; фон секции = bg-токен
// с белым фоллбеком (у flux нет цветных полотен, MANNER §7), surface-фоллбек 251 =
// scheme-1 flux.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Figma 1:19335 — пустое состояние секции «Мультиколонны». Признак пустоты: мерчант
// не задал ни одной колонки (p.columns пуст/нет). Тогда секция рендерит ДОСЛОВНЫЙ
// Figma-плейсхолдер (заголовок «Мультиколонны»; 3 пустые surface-колонки «Колонна» +
// хелпер-текст + «Кнопка»), а НЕ дефолт-контент верстальщика. MultiColumns —
// текстово-картинная секция (схема columns[]: heading/text/imageUrl/link, без
// collectionPicker/productPicker), поэтому SSR-фетч товаров/коллекций ей не нужен
// (в отличие от Popular/Collections).
const hasColumns = Array.isArray(p.columns) && p.columns.length > 0;

// Канон heading: string | { text, alignment, size }. С данными мерчанта — его
// заголовок (пусто → без шапки). В пустом состоянии — Figma-лейбл «Мультиколонны».
// Роль = заголовок секции flux: roboto-flex uppercase, токен color-heading.
// Лестница flux (паритет MainText, ступени rose small/medium/large): medium
// (canon-default) и отсутствие = 19/md:23 (база), small ступень ниже, large выше.
const headingRaw = typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "");
const heading = hasColumns ? headingRaw : (headingRaw || "Мультиколонны");
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[16px] md:text-[19px]"
		: headingSize === "large"
			? "text-[23px] md:text-[29px]"
			: "text-[19px] md:text-[23px]"; // medium (canon-default) + absent
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center" ? " text-center" : headingAlignment === "right" ? " text-right" : "";
const headingCls = `font-roboto-flex font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))] ${headingSizeCls}${headingAlignCls}`;

// Канон columns[] ≤10 (item: heading|title, text|description, imageUrl|image,
// imageSize, headingSize/textSize per-item, link {text,href} | flat linkText+link).
// Пустое состояние (мерчант не задал колонки) = ДОСЛОВНЫЙ Figma-плейсхолдер
// 1:19335: 3 ПУСТЫЕ surface-колонки «Колонна» + хелпер «Сочетай текст, чтобы
// подчеркнуть плюсы товара или коллекции.» + ссылка-плейсхолдер «Кнопка» (НЕ
// мок-картинки и НЕ готовые тексты верстальщика). Мерчант задал columns → рендерим ИХ.
const FIGMA_PLACEHOLDER_COLUMNS = [
	{
		id: "ph-1",
		heading: "Колонна",
		text: "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.",
		imageUrl: "",
		link: { text: "Кнопка", href: "/catalog" },
		isPlaceholder: true,
	},
	{
		id: "ph-2",
		heading: "Колонна",
		text: "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.",
		imageUrl: "",
		link: { text: "Кнопка", href: "/catalog" },
		isPlaceholder: true,
	},
	{
		id: "ph-3",
		heading: "Колонна",
		text: "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.",
		imageUrl: "",
		link: { text: "Кнопка", href: "/catalog" },
		isPlaceholder: true,
	},
];
const rawColumns = hasColumns ? p.columns : FIGMA_PLACEHOLDER_COLUMNS;
const columns = rawColumns.slice(0, 10).map((c: any) => {
	// Ссылка колонки: canon link {text,href} ИЛИ flat-пара linkText + link
	// (string из arrayFields конструктора). Рендер при непустом тексте.
	const linkText =
		(c.link && typeof c.link === "object" && typeof c.link.text === "string" && c.link.text.trim()
			? c.link.text
			: undefined) ?? (typeof c.linkText === "string" && c.linkText.trim() ? c.linkText : undefined);
	const linkHref =
		(c.link && typeof c.link === "object" && typeof c.link.href === "string" && c.link.href
			? c.link.href
			: undefined) ??
		(typeof c.link === "string" && c.link ? c.link : undefined) ??
		"/catalog";
	return {
		heading:
			(typeof c.heading === "string" && c.heading) || (typeof c.title === "string" && c.title) || "",
		text:
			(typeof c.text === "string" && c.text) ||
			(typeof c.description === "string" && c.description) ||
			"",
		image:
			(typeof c.imageUrl === "string" && c.imageUrl.trim()) ||
			(typeof c.image === "string" && c.image.trim()) ||
			"",
		imageSize: c.imageSize,
		headingSize: c.headingSize,
		textSize: c.textSize,
		link: linkText ? { text: linkText, href: linkHref } : undefined,
		// Пустое состояние Figma: рисуем пустой surface-rect вместо <img> даже без
		// картинки (в обычном режиме колонка без image вообще не показывает медиа-блок).
		isPlaceholder: c.isPlaceholder === true,
	};
});

// Канон imageAspectRatio (паритет rose): square (canon-default / отсутствие) | adapt
// (нативный) | portrait 430/500 | landscape 429/309 — литералы манеры карточек.
// Формат с лидирующим пробелом (rose): adapt → "".
const aspectCls =
	p.imageAspectRatio === "adapt"
		? ""
		: p.imageAspectRatio === "portrait"
			? " aspect-[430/500]"
			: p.imageAspectRatio === "landscape"
				? " aspect-[429/309]"
				: " aspect-square";

// Канон displayColumns 1-4 (паритет rose): видимые колонны с lg (canon-default 3);
// мобильная лестница 1 → md:2 фиксирована, lg — через CSS-var --cols.
const displayColumnsRaw = Number(p.displayColumns);
const displayColumns =
	Number.isFinite(displayColumnsRaw) && displayColumnsRaw >= 1 && displayColumnsRaw <= 4
		? Math.round(displayColumnsRaw)
		: 3;
const gridStyle = `--cols:${displayColumns}`;

// Канон width (s/m/l/full, паритет rose): small 780 | medium 1080 (canon-default /
// отсутствие) | large 1320 | full — без лимита. Контент-контейнер внутри
// flux-носителя max-w-[1920px].
const widthCls =
	p.width === "small"
		? "max-w-[780px]"
		: p.width === "large"
			? "max-w-[1320px]"
			: p.width === "full"
				? "max-w-none"
				: "max-w-[1080px]";

// Канон textPosition (паритет rose): left (canon-default) | center — выравнивание
// содержимого колонок.
const textAlignCls = p.textPosition === "center" ? "items-center text-center" : "items-start text-left";

// Канон containerEnabled (toggle; legacy background.enabled) — per-element:
// surface-плашка на КАЖДУЮ колонку (паритет rose/bloom cardSurfaceCls), НЕ один
// общий бокс вокруг грида. Дефолт ВЫКЛ: голые колонки. ВКЛ → flux-плашка
// rounded-12 / surface (фоллбек 251 = scheme-1 flux) / p-6 md:p-10.
const containerEnabled =
	String(p.containerEnabled ?? p.background?.enabled ?? "false") === "true";
const cardSurfaceCls = containerEnabled
	? " rounded-[12px] bg-[rgb(var(--color-surface,251_251_251))] p-6 md:p-10"
	: "";
// Класс схемы контейнера — на обёртке СПИСКА (<ul>), красит плашки колонок. ВКЛ
// только при включённом контейнере (при ВЫКЛ — основная секционная схема).
const containerSchemeCls =
	containerEnabled && typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";

// Канон buttonText/buttonLink (hidden) — общая чёрная CTA под гридом при непустом
// тексте.
const btnText = typeof p.buttonText === "string" && p.buttonText.trim() ? p.buttonText : undefined;
const btnHref =
	(typeof p.buttonLink === "string" && p.buttonLink ? p.buttonLink : undefined) ??
	(typeof p.link === "string" && p.link ? p.link : undefined) ??
	"/catalog";

// Шкалы per-item размеров на flux-базе (паритет rose small/medium/large).
// Заголовок колонки — roboto-flex (НЕ uppercase, паритет rose h3): medium /
// отсутствие = 16/md:18, small ниже, large выше. Текст колонки — roboto-flex 300:
// medium / отсутствие = 14/md:16, small ниже, large выше.
const itemHeadingCls = (s: string | undefined) =>
	s === "small"
		? "text-[14px] md:text-[16px]"
		: s === "large"
			? "text-[19px] md:text-[22px]"
			: "text-[16px] md:text-[18px]";
const itemTextCls = (s: string | undefined) =>
	s === "small"
		? "text-[12px] md:text-[13px]"
		: s === "large"
			? "text-[16px] md:text-[19px]"
			: "text-[14px] md:text-[16px]";

// Per-колоночный imageSize (паритет rose): small сужает медиа-плитку до w-1/2;
// medium/large/отсутствие = w-full. Аспект/радиус/фон не меняются.
const itemImageCls = (s: string | undefined) => (s === "small" ? "w-1/2" : "w-full");

// Канон padding {top,bottom} — inline-override вертикали ТОЛЬКО при заданном пропе
// (паттерн MainText/Popular): py-классы контейнера снимаются, чтобы не было двойного
// отступа.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

// Чёрная CTA манеры flux: h-14 rounded-6 px-6 roboto-flex 16 uppercase leading-none,
// hover:opacity-90 (эталон MainText/Hero; кнопка-2 = чёрная в схемах flux, MANNER §7).
// active:scale в манере flux НЕ используется (§3).
const btnCls =
	"inline-flex h-14 items-center justify-center rounded-[var(--radius-button,6px)] bg-[rgb(var(--color-button-2-bg,0_0_0))] px-6 font-roboto-flex text-[16px] font-normal uppercase leading-none text-[rgb(var(--color-button-2-text,255_255_255))] transition-opacity hover:opacity-90";

// Контейнер = flux-носитель темы (Header/Footer/Popular/MainText: mx-auto
// max-w-[1920px] px-4 md:px-20 2xl:px-80). Вертикаль py-10 md:py-16 (канон); при
// заданном padding (настройка) py-классы убираются — inline-стиль ставит
// padding-top/bottom.
const containerCls = paddingStyle
	? "mx-auto w-full max-w-[1920px] px-4 md:px-20 2xl:px-80"
	: "mx-auto w-full max-w-[1920px] px-4 py-10 md:px-20 md:py-16 2xl:px-80";

const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
>
	<div class={containerCls} style={paddingStyle}>
		<div class={`mx-auto flex w-full ${widthCls} flex-col gap-8 md:gap-12`}>
			{
				heading && (
					<h2
						id={titleId}
						class={headingCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="100"
						data-puck-subsection-field="heading"
					>
						{heading}
					</h2>
				)
			}
			<ul
				class={`grid w-full grid-cols-1 gap-6 md:grid-cols-2 md:gap-8 lg:grid-cols-[repeat(var(--cols),minmax(0,1fr))]${containerSchemeCls}`}
				role="list"
				style={gridStyle}
			>
				{
					columns.map((c, index) => (
						<li
							class={`group flex w-full flex-col gap-4 md:gap-5 ${textAlignCls}${cardSurfaceCls}`}
							data-puck-subsection-parent={id}
							data-puck-subsection-index={index}
							data-puck-subsection-field="columns"
						>
							{c.image ? (
								<div
									class={`${itemImageCls(c.imageSize)} overflow-hidden rounded-[12px] bg-[rgb(var(--color-surface,251_251_251))]${aspectCls}`}
								>
									<img
										src={c.image}
										alt={c.heading || "Колонна"}
										loading="lazy"
										decoding="async"
										class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
									/>
								</div>
							) : c.isPlaceholder ? (
								/* Пустое состояние Figma 1:19335: пустой surface-rect (без картинки). */
								<div
									class={`${itemImageCls(c.imageSize)} overflow-hidden rounded-[12px] bg-[rgb(var(--color-surface,251_251_251))]${aspectCls}`}
									aria-hidden="true"
								/>
							) : null}
							<div class="flex w-full flex-col gap-2 md:gap-3">
								{c.heading && (
									<h3
										class={`font-roboto-flex ${itemHeadingCls(c.headingSize)} font-normal leading-normal text-[rgb(var(--color-heading,0_0_0))]`}
									>
										{c.heading}
									</h3>
								)}
								{c.text && (
									<div
										class={`font-roboto-flex ${itemTextCls(c.textSize)} font-light leading-relaxed text-[rgb(var(--color-text,0_0_0))]`}
										set:html={c.text}
									/>
								)}
								{c.link && (
									<a
										href={c.link.href}
										class="font-roboto-flex text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] underline underline-offset-4 transition-opacity hover:opacity-70 md:text-[16px]"
									>
										{c.link.text}
									</a>
								)}
							</div>
						</li>
					))
				}
			</ul>
			{
				btnText && (
					<div class="flex justify-center">
						<a
							href={btnHref}
							class={btnCls}
							data-puck-subsection-parent={id}
							data-puck-subsection-index="102"
							data-puck-subsection-field="buttonText"
						>
							{btnText}
						</a>
					</div>
				)
			}
		</div>
	</div>
</section>
