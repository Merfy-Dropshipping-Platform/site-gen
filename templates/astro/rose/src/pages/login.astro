---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthShell from '../components/auth/AuthShell.astro';
import AuthInput from '../components/auth/AuthInput.astro';
import PasswordField from '../components/auth/PasswordField.astro';
import AuthButton from '../components/auth/AuthButton.astro';
import AuthSecondaryLink from '../components/auth/AuthSecondaryLink.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import data from '../data/data.json';
import siteConfig from '../data/site-config.json';

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};
---
<BaseLayout title={`Вход — ${meta?.title ?? 'Мой сайт'}`}>
  <Header {...headerProps} />
  <AuthShell
    title="Вход в аккаунт"
    description="Введите свои данные чтобы войти в аккаунт"
  >
    <form id="login-form" class="w-full flex flex-col gap-6" novalidate>
      <AuthInput
        label="E-mail"
        type="email"
        name="email"
        id="login-email"
        placeholder="example@merfy.ru"
        required
        autocomplete="email"
      />
      <PasswordField
        label="Пароль"
        name="password"
        id="login-password"
        placeholder="Введите пароль"
        required
      />
      <div class="auth-helper-error hidden text-center" id="login-error" role="alert"></div>
    </form>

    <div class="w-full flex flex-col items-center gap-10">
      <AuthButton id="btn-login" loadingLabel="Вход...">Войти</AuthButton>
      <div class="flex flex-col items-center gap-3">
        <AuthSecondaryLink href="/register" helper="Нет аккаунта?">Зарегистрироваться</AuthSecondaryLink>
        <AuthSecondaryLink href="/reset-password">Забыл пароль?</AuthSecondaryLink>
      </div>
    </div>
  </AuthShell>

  <Footer {...footerProps} />

  <script is:inline src="/scripts/customer-store.js"></script>
  <script is:inline src="/scripts/customer-auth.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      // If already logged in, redirect
      if (window.CustomerStore && window.CustomerStore.isLoggedIn()) {
        var params = new URLSearchParams(window.location.search);
        window.location.href = params.get('redirect') || '/account';
        return;
      }

      var form = document.getElementById('login-form');
      var errorEl = document.getElementById('login-error');
      var btn = document.getElementById('btn-login');
      var loadingEl = btn.querySelector('[data-loading]');
      var textEl = btn.querySelector('[data-button-text]');

      // Prefill email from ?email=... (e.g. after redirect from invite-register ALREADY_REGISTERED)
      var initialParams = new URLSearchParams(window.location.search);
      var prefillEmail = initialParams.get('email');
      if (prefillEmail) {
        var emailField = document.getElementById('login-email');
        if (emailField) emailField.value = prefillEmail;
      }

      function setFieldError(id, hasError) {
        var el = document.getElementById(id);
        if (el) el.setAttribute('data-error', hasError ? 'true' : 'false');
      }

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        errorEl.classList.add('hidden');
        errorEl.textContent = '';
        setFieldError('login-email', false);
        setFieldError('login-password', false);

        var email = document.getElementById('login-email').value.trim();
        var password = document.getElementById('login-password').value;

        // Client-side validation
        if (!email) {
          setFieldError('login-email', true);
          errorEl.textContent = 'Введите e-mail';
          errorEl.classList.remove('hidden');
          return;
        }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          setFieldError('login-email', true);
          errorEl.textContent = 'Введите корректный e-mail';
          errorEl.classList.remove('hidden');
          return;
        }
        if (!password) {
          setFieldError('login-password', true);
          errorEl.textContent = 'Введите пароль';
          errorEl.classList.remove('hidden');
          return;
        }

        loadingEl.classList.remove('hidden');
        textEl.classList.add('hidden');
        btn.disabled = true;

        try {
          var result = await window.CustomerAuth.login({ email: email, password: password });

          if (result.success) {
            var params = new URLSearchParams(window.location.search);
            window.location.href = params.get('redirect') || '/account';
          } else {
            throw result;
          }
        } catch (err) {
          var msg = 'Неверный email или пароль';
          if (err.error === 'ACCOUNT_LOCKED' || err.code === 'RATE_LIMIT_EXCEEDED') {
            msg = 'Слишком много попыток. Попробуйте через 30 минут';
          } else if (err.message) {
            msg = err.message;
          }
          errorEl.textContent = msg;
          errorEl.classList.remove('hidden');
        } finally {
          loadingEl.classList.add('hidden');
          textEl.classList.remove('hidden');
          btn.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>
