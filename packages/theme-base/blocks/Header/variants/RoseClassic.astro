              <path d="M11 17H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M11 23H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {/* Desktop nav (left) */}
          <div class:list={[C.navMenu, menuSchemeClass]}>
            {navigationLinks?.map((link) => (
