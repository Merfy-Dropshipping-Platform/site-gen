---
/**
 * Универсальная страница товара `/product` (Option B, спек 098 + live-wiring).
 *
 * Реальные товары не имеют статических `/products/{id}` страниц (getStaticPaths
 * знает только demo bag-N на сборке сервиса). Эта одна страница рендерит
 * нейтральный skeleton; вся live-гидрация (определение товара по slug пути /
 * ?id= / __MERFY_DEFAULT_PRODUCT_ID__, заполнение data-pdp-* хуков, варианты,
 * корзина, галерея, «Товар не найден») выполняется единым `is:inline`-скриптом
 * ВНУТРИ `BloomProductDetail`. Источник — ЖИВОЙ `/api/store/products` (как
 * каталог bloom), с фолбэком на per-site `/data/products.json` (копейки→цены
 * /100) и preview storefront-data. Разметка — общий `BloomProductDetail`
 * (parity с demo `[id].astro`).
 */
import Layout from "../layouts/Layout.astro";
import BloomProductDetail from "../components/products/BloomProductDetail.astro";
import type { CatalogProduct } from "../data/products";

// Нейтральный skeleton: рендерится до клиентской гидрации (и на demo-сборке без
// данных). placeholder-картинка, без галереи/бренда/старой цены/вариантов.
const skeleton = {
	id: "",
	name: "Товар",
	price: "",
	image: "/images/placeholder.png",
	gallery: ["/images/placeholder.png"],
	colors: [],
	category: "skin-care",
	inStock: true,
	description: "",
} as CatalogProduct;
---

<Layout title="Товар">
	{/* Вся live-гидрация PDP живёт ВНУТРИ BloomProductDetail.astro единым
	    is:inline-скриптом — он работает на обоих маршрутах (`/product` и demo
	    `products/[id]`) и на live (theme dist), где module-<script> страницы
	    надёжно не компилится по универсальному маршруту. Здесь — только скелетон;
	    дублирующий хелпер-скрипт (import storefront-hydrate) убран — иначе двойная
	    конфликтующая гидрация. Блок «Товар не найден» тоже переехал в компонент. */}
	<BloomProductDetail product={skeleton} />
</Layout>
