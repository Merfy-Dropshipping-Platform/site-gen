---
import Layout from "../../layouts/Layout.astro";
import NtAuthPanel from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtAuthPanel.astro";
import NtTextField from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtTextField.astro";
---

<Layout title="Восстановление пароля" description="Восстановление доступа к аккаунту Bloom">
	<section class="flex w-full flex-1 items-center justify-center bg-white px-4 py-16 md:py-24">
		<form class="w-full max-w-[430px]" data-auth-form>
			<NtAuthPanel title="Восстановление" subtitle="Введите e-mail, мы отправим инструкции">
				<div slot="fields" class="flex flex-col gap-4">
					<NtTextField label="E-mail" name="email" type="email" autocomplete="email" />
				</div>
				<button
					slot="primary"
					type="submit"
					class="flex h-12 w-full items-center justify-center rounded-[6px] bg-[#000000] px-6 font-manrope text-[16px] font-normal leading-normal text-white transition-opacity hover:opacity-95"
				>
					Отправить ссылку
				</button>
				<div slot="links" class="flex w-full flex-col items-center gap-3 text-center">
					<a href="/auth/sign-in" class="font-manrope text-[16px] font-normal text-[#000000] hover:opacity-80">
						Вернуться ко входу
					</a>
				</div>
			</NtAuthPanel>
		</form>
	</section>
</Layout>

<script>
	document.querySelector<HTMLFormElement>("[data-auth-form]")?.addEventListener("submit", (event) => {
		event.preventDefault();
		alert("Если такой e-mail есть в базе, мы отправили на него инструкции.");
	});
</script>
