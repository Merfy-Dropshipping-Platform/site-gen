---
/**
 * FluxProductCard (порт из themes/flux/src/components/products/FluxProductCard.astro).
 *
 * Тип Product заинлайнен (минимальный shape витрины) вместо импорта
 * ../../types/product — block-папка override-темы автономна (компилятор превью
 * не резолвит пути за пределы папки). FluxPicture — sibling (./).
 *
 * Добавлены props (cardAspectClass / showQuickAdd / quickAddText / btnStyle /
 * btnBg / btnFg / btnBorder) для parity с настройками карточки Catalog и
 * client-функцией renderCardHtml (SSG ≡ live). Меняется СИНХРОННО с renderCardHtml.
 */
import FluxPicture from "./FluxPicture.astro";

interface Product {
  name: string;
  price: string;
  oldPrice?: string;
  image: string;
  id?: string;
  discount?: boolean;
}

interface Props {
  product: Product;
  priority?: boolean;
  /** Вид изображения карточки (Tailwind aspect-класс). Дефолт flux — квадрат
      (theme.json blockDefaults.Catalog.productCard.cardStyle = 'square').
      Передаётся из Catalog.astro (настройка «Вид изображения»),
      зеркалит client renderCardHtml для parity. */
  cardAspectClass?: string;
  /** Быстрое действие: кнопка под карточкой (none → нет; иначе текст). */
  showQuickAdd?: boolean;
  quickAddText?: string;
  /** Inline-стили кнопки quickAdd по «Стилю кнопки» (primary/secondary/link). */
  btnStyle?: string;
  btnBg?: string;
  btnFg?: string;
  btnBorder?: string;
  /** «Контейнер» карточки (Figma productCard.cardBackground). true → контент с
      внутренним отступом 12px (фото/кнопка inset, surface-фон карточки);
      false (дефолт) → флеш к краям (фото full-bleed, кнопка full-width).
      Зеркалит client renderCardHtml для parity. */
  cardContainerOn?: boolean;
}

const {
  product,
  priority = false,
  cardAspectClass = "aspect-square",
  showQuickAdd = false,
  quickAddText = "В КОРЗИНУ",
  btnStyle = "primary",
  btnBg = "rgb(var(--color-button-bg,0 0 0))",
  btnFg = "rgb(var(--color-button-text,255 255 255))",
  btnBorder = "1px solid rgb(var(--color-button-bg,0 0 0))",
  cardContainerOn = false,
} = Astro.props as Props;
const href = `/products/${product.id}`;
const showSaleBadge = product.discount === true;
// «Контейнер» (cardBackground): true → внутренний отступ 12px со всех сторон +
//   surface-фон → фото/название/цена/кнопка inset (кнопка width:100% становится
//   cardW−24, НЕ во всю ширину). false (дефолт) → флеш к краям, фон не задаётся,
//   кнопка край-в-край. Бейдж «Скидка» остаётся ~8px от края (top-2/left-2 = 8px)
//   в обоих состояниях. inline-style зеркалит client renderCardHtml (parity).
const cardContainerStyle = cardContainerOn
  ? "padding:12px;background:rgb(var(--color-surface,245 245 245));border-radius:var(--radius-media,8px);"
  : "";
// Стиль кнопки quickAdd (зеркалит client renderCardHtml). link → текст-ссылка.
const quickBtnStyle =
  `width:100%;height:44px;padding:0 12px;border-radius:var(--radius-button,6px);` +
  `font-family:var(--font-body);font-size:14px;text-transform:uppercase;cursor:pointer;` +
  `display:flex;align-items:center;justify-content:center;` +
  `background:${btnBg};color:${btnFg};border:${btnBorder};` +
  (btnStyle === "link" ? "text-decoration:underline;background:transparent;" : "");

// Outline-сердце избранного (SSR-дефолт). Геометрия = public/icons/favourite.svg
// flux и зеркалит wishlist.ts heartSvg(false). Инлайн (НЕ <img> NtIcon) — чтобы
// глобальный делегат initWishlistUI мог переключать fill на filled (акцент flux).
// На SSG нет window → рисуем outline; делегат поставит filled на page-load если
// товар в избранном. SVG-строка автономна (block-папка override-темы не резолвит
// импорты наружу — путь дублируется здесь намеренно).
const defaultHeartSvg =
  '<svg viewBox="0 0 17.4 15.4" width="100%" height="100%" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="display:block">' +
  '<path d="M7.428 14.2615C5.172 12.5239 0.7 8.55212 0.7 4.97729C0.7 2.61547 2.384 0.7 4.7 0.7C5.9 0.7 7.1 1.11175 8.7 2.75876C10.3 1.11175 11.5 0.7 12.7 0.7C15.016 0.7 16.7 2.61547 16.7 4.97729C16.7 8.5513 12.228 12.5239 9.972 14.2615C9.212 14.8462 8.188 14.8462 7.428 14.2615Z" ' +
  'fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>' +
  "</svg>";
---

<article
  class="group flex w-full flex-col gap-3 md:gap-4"
  data-nt="flux-product-card"
  data-card-container={cardContainerOn ? "true" : "false"}
  style={cardContainerStyle}
  aria-label={product.name}
>
  {/* Обёртка медиа: relative-родитель для overlay-сердца избранного. Сердце —
      sibling <a> (НЕ внутри: button-in-anchor невалиден + клик по сердцу не должен
      открывать товар). aspect-класс несёт сам <a>; обёртка только позиционирует. */}
  <div class="relative w-full">
  <a
    href={href}
    class:list={[cardAspectClass, "relative block w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-[#F5F5F5]"]}
    aria-label={product.name}
  >
    {product.image ? (
      <FluxPicture
        src={product.image}
        alt={product.name}
        width="318"
        height="444"
        loading="eager"
        fetchpriority={priority ? "high" : undefined}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        data-img-primary={product.image}
      />
    ) : (
      /* Товар без фото: surface-плейсхолдер вместо <img> (битой иконки).
         Цвета только токенами; разметку зеркалит CARD_MEDIA_FALLBACK_HTML
         в client renderCardHtml — менять синхронно. */
      <div
        class="absolute inset-0 flex items-center justify-center"
        style="background:rgb(var(--color-surface,245 245 245))"
        aria-hidden="true"
      >
        <svg
          class="size-10"
          style="color:rgb(var(--color-muted,153 153 153))"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="3" width="18" height="18" rx="2"></rect>
          <circle cx="9" cy="9" r="2"></circle>
          <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
        </svg>
      </div>
    )}
    {showSaleBadge && (
      <span
        class="absolute left-2 top-2 z-10 inline-flex h-6 items-center rounded-[4px] bg-[rgb(var(--color-accent,250_81_9))] px-1.5 font-roboto-flex text-[11px] font-light leading-none !text-[#000000] md:text-[12px]"
      >
        Скидка
      </span>
    )}
  </a>
    {/* Сердце избранного (overlay top-right, зеркалит бейдж «Скидка» по позиции).
        data-product-id ловит глобальный делегат initWishlistUI: toggle + перерисовка
        состояния (filled-акцент/outline + aria-pressed). Начальное состояние ставит
        делегат на page-load (SSG рендер без window — рисуем outline-сердце). z-20
        поверх фото/бейджа. Зеркалит client renderCardHtml (parity SSG↔live). */}
    <button
      type="button"
      data-wishlist-toggle
      data-product-id={product.id}
      aria-pressed="false"
      aria-label="В избранное"
      class="absolute right-2 top-2 z-20 flex size-9 items-center justify-center rounded-full bg-white/90 text-[#000000] shadow-[0_2px_8px_rgba(0,0,0,0.10)] backdrop-blur-sm transition-opacity hover:opacity-80"
    >
      <span data-wishlist-icon class="block size-[18px]" set:html={defaultHeartSvg}></span>
    </button>
  </div>
  <div class="flex w-full flex-col gap-1 text-left">
    <a
      href={href}
      class="flux-product-name block w-full font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-80 md:text-[16px]"
    >
      {product.name}
    </a>
    <div class="flex w-full flex-wrap items-baseline gap-2">
      <span class="flux-product-price font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]">
        {product.price}
      </span>
      {product.oldPrice && (
        <span class="flux-product-oldprice font-manrope text-[12px] font-normal leading-[1.366] text-[rgb(var(--color-muted,153_153_153))] line-through md:text-[14px]">
          {product.oldPrice}
        </span>
      )}
    </div>
  </div>
  {/* Быстрое действие (настройка «Быстрое добавление»). Кнопка СНАРУЖИ <a>
      (button-in-anchor — невалидный HTML). Зеркалит client renderCardHtml. */}
  {showQuickAdd && (
    <button type="button" data-quick-add-id={product.id} style={quickBtnStyle}>
      {quickAddText}
    </button>
  )}
</article>
