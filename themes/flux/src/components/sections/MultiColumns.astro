---
// Фаза B (flux): новая канон-секция MultiColumns в манере flux (см.
// themes/flux/MANNER.md). Донора-карточек у верстальщика НЕТ (МАННЕРА §10) —
// секция с нуля: грид-паттерн Puk.astro:13 (grid-cols-1 gap-6 md:grid-cols-2
// md:gap-8 lg:grid-cols-3; сам Puk — тестовый мусор, в канон не входит, но
// паттерн грида валиден), колонки ГОЛЫЕ — без подложек и бордеров (карточная
// манера §4), медиа-плитка rounded-8 / surface #F5F5F5 (Puk.astro:16),
// подзаголовок колонки = роль заголовка рассылки (F:40), текст = Roboto Flex
// 300 muted (F:44), ссылка = текстовая Manrope с hover:opacity-70 (H:98).
// Анимаций скролла НЕТ (§6). Схема полей = packages/theme-base/blocks/
// MultiColumns/MultiColumns.puckConfig.ts; процесс-эталон — bloom MultiColumns.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Figma 1:19335 — пустое состояние секции «Мультиколонны». Признак пустоты: мерчант
// не задал ни одной колонки (p.columns пуст/нет). Тогда секция рендерит ДОСЛОВНЫЙ
// Figma-плейсхолдер (заголовок «Мультиколонны»; 3 пустые surface-колонки «Колонна» +
// хелпер-текст + «Кнопка»), а НЕ дефолт-контент верстальщика (CANON_COLUMNS).
// MultiColumns — текстово-картинная секция (схема columns[]: heading/text/imageUrl/
// link, без collectionPicker/productPicker), поэтому SSR-фетч товаров/коллекций ей
// не нужен (в отличие от Popular/Collections — эталон rose Popular.astro).
const hasColumns = Array.isArray(p.columns) && p.columns.length > 0;

// Канон heading: string | { text, alignment, size }. С данными мерчанта — его
// заголовок (пусто → без шапки). В пустом состоянии — Figma-лейбл «Мультиколонны».
// Роль = внутрисекционный h2 (Comfortaa uppercase leading-[1.115], МАННЕРА §1).
// Лестница §9 «Внутренний h2 24/28»: large/отсутствие = литерал 24/md:28,
// medium 20/24, small 17/20.
const headingRaw = typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "");
const heading = hasColumns ? headingRaw : (headingRaw || "Мультиколонны");
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[17px] md:text-[20px]"
		: headingSize === "medium"
			? "text-[20px] md:text-[24px]"
			: "text-[24px] md:text-[28px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center" ? " text-center" : headingAlignment === "right" ? " text-right" : "";
const headingCls = `font-comfortaa ${headingSizeCls} font-normal uppercase leading-[1.115] text-[rgb(var(--color-heading,0_0_0))]${headingAlignCls}`;

// Канон columns[] ≤10 (item: heading|title, text|description, imageUrl|image,
// headingSize/textSize per-item, link {text,href} | flat linkText+link). Пустое
// состояние (мерчант не задал колонки) = ДОСЛОВНЫЙ Figma-плейсхолдер 1:19335:
// 3 ПУСТЫЕ surface-колонки «Колонна» + хелпер «Сочетай текст, чтобы подчеркнуть
// плюсы товара или коллекции.» + ссылка-плейсхолдер «Кнопка» (НЕ мок-картинки и
// НЕ готовые тексты верстальщика). Мерчант задал columns → рендерим ИХ.
const FIGMA_PLACEHOLDER_COLUMNS = [
	{
		id: "ph-1",
		heading: "Колонна",
		text: "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.",
		imageUrl: "",
		link: { text: "Кнопка", href: "/catalog" },
		isPlaceholder: true,
	},
	{
		id: "ph-2",
		heading: "Колонна",
		text: "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.",
		imageUrl: "",
		link: { text: "Кнопка", href: "/catalog" },
		isPlaceholder: true,
	},
	{
		id: "ph-3",
		heading: "Колонна",
		text: "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.",
		imageUrl: "",
		link: { text: "Кнопка", href: "/catalog" },
		isPlaceholder: true,
	},
];
const rawColumns = hasColumns ? p.columns : FIGMA_PLACEHOLDER_COLUMNS;
const columns = rawColumns.slice(0, 10).map((c: any) => {
	// Ссылка колонки: canon link {text,href} ИЛИ flat-пара linkText + link
	// (string из arrayFields конструктора). Рендер при непустом тексте.
	const linkText =
		(c.link && typeof c.link === "object" && typeof c.link.text === "string" && c.link.text.trim()
			? c.link.text
			: undefined) ?? (typeof c.linkText === "string" && c.linkText.trim() ? c.linkText : undefined);
	const linkHref =
		(c.link && typeof c.link === "object" && typeof c.link.href === "string" && c.link.href
			? c.link.href
			: undefined) ??
		(typeof c.link === "string" && c.link ? c.link : undefined) ??
		"/catalog";
	return {
		heading:
			(typeof c.heading === "string" && c.heading) || (typeof c.title === "string" && c.title) || "",
		text:
			(typeof c.text === "string" && c.text) ||
			(typeof c.description === "string" && c.description) ||
			"",
		image:
			(typeof c.imageUrl === "string" && c.imageUrl.trim()) ||
			(typeof c.image === "string" && c.image.trim()) ||
			"",
		imageSize: c.imageSize,
		headingSize: c.headingSize,
		textSize: c.textSize,
		link: linkText ? { text: linkText, href: linkHref } : undefined,
		// Пустое состояние Figma: рисуем пустой surface-rect вместо <img> даже без
		// картинки (в обычном режиме колонка без image вообще не показывает медиа-блок).
		isPlaceholder: c.isPlaceholder === true,
	};
});

// Канон imageAspectRatio: отсутствие = вертикальная плитка 430/500 (литерал
// Puk.astro:16 ≡ карточка коллекции §4); square/portrait/landscape — лестница;
// adapt — натуральная высота картинки.
const tileAspectCls =
	p.imageAspectRatio === "square"
		? "aspect-square"
		: p.imageAspectRatio === "landscape"
			? "aspect-[16/9]"
			: p.imageAspectRatio === "adapt"
				? ""
				: "aspect-[430/500]";

// Канон displayColumns 1-4: canon-default 3 и отсутствие = грид-литерал Puk
// (grid-cols-1 gap-6 md:grid-cols-2 md:gap-8 lg:grid-cols-3 байт-в-байт);
// иное значение — мобильная лестница 1 → md:2 фиксирована, lg — через CSS-var.
const displayColumnsRaw = Number(p.displayColumns);
const displayColumns =
	Number.isFinite(displayColumnsRaw) && displayColumnsRaw >= 1 && displayColumnsRaw <= 4
		? Math.round(displayColumnsRaw)
		: 3;
const gridCls =
	displayColumns === 3
		? "grid w-full grid-cols-1 gap-6 md:grid-cols-2 md:gap-8 lg:grid-cols-3"
		: "grid w-full grid-cols-1 gap-6 md:grid-cols-2 md:gap-8 lg:grid-cols-[repeat(var(--cols),minmax(0,1fr))]";
const gridStyle = displayColumns === 3 ? undefined : `--cols:${displayColumns}`;

// Канон width (s/m/l/full): отсутствие/large = 1320 (контейнер манеры §2),
// medium 1080, small 780, full — без лимита.
const widthCls =
	p.width === "small"
		? "max-w-[780px]"
		: p.width === "medium"
			? "max-w-[1080px]"
			: p.width === "full"
				? "max-w-none"
				: "max-w-[1320px]";

// Канон textPosition ('left' canon-default): выравнивание содержимого колонок.
// Отсутствие/left = флаговая вёрстка (подписи карточек flux всегда left, §4);
// center — по центру.
const colAlignCls = p.textPosition === "center" ? " items-center text-center" : "";

// Канон containerEnabled — тоггл «Фон»/«Контейнер». ФЛИП дефолта на ВЫКЛ: раньше
// flux MultiColumns был «голым» (бокса не было вовсе), теперь по канону дефолт
// false = голые колонки, ВКЛ = подложка-бокс.
const containerEnabled =
	String(p.containerEnabled ?? p.background?.enabled ?? "false") === "true";
// Канон Nikita: тоггл «Фон»/«Контейнер» САМ показывает подложку-бокс (surface +
// радиус + паддинг, СОХРАНЁН flux-радиус 12px) — раньше бокс висел на наличии
// скрытой «Цв. схемы контейнера», поэтому тоггл был пустышкой. Цв. схема контейнера
// (если задана) — отдельный класс поверх, перекрашивает бокс. При ВЫКЛ — ни бокса,
// ни схемы (работает основная схема секции).
const containerSchemeCls = containerEnabled
	? ` rounded-[var(--radius-card,12px)] bg-[rgb(var(--color-surface,245_245_245))] p-6 md:p-10${
			typeof p.containerColorScheme === "string" && p.containerColorScheme
				? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
				: ""
		}`
	: "";

// Канон buttonText/buttonLink (hidden) — общая кнопка под гридом, чёрная CTA
// манеры §3 (contacts.astro:76; кнопка-2 в схемах flux, МАННЕРА §7), рендер
// при непустом тексте. active:scale не используется (§3).
const btnText = typeof p.buttonText === "string" && p.buttonText.trim() ? p.buttonText : undefined;
const btnHref =
	(typeof p.buttonLink === "string" && p.buttonLink ? p.buttonLink : undefined) ??
	(typeof p.link === "string" && p.link ? p.link : undefined) ??
	"/catalog";

// Шкалы per-item размеров. Подзаголовок колонки = роль заголовка рассылки
// (F:40, Comfortaa 16/18 uppercase): лестница §9 medium/отсутствие = литерал
// 16/18, small 11/13, large 19/22. Текст = роль текста рассылки (F:44, Roboto
// Flex 300 12/14 muted): medium/отсутствие = литерал 12/14, small 10/11,
// large 14/17.
const itemHeadingCls = (s: string | undefined) =>
	s === "small"
		? "text-[11px] md:text-[13px]"
		: s === "large"
			? "text-[19px] md:text-[22px]"
			: "text-[16px] md:text-[18px]";
const itemTextCls = (s: string | undefined) =>
	s === "small"
		? "text-[10px] md:text-[11px]"
		: s === "large"
			? "text-[14px] md:text-[17px]"
			: "text-[12px] md:text-[14px]";

// Per-колоночный imageSize (small/medium/large): ширина медиа-плитки внутри
// колонки (паритет rose). medium/large/отсутствие = манера (w-full, текущий вид
// байт-в-байт); small — сужение плитки до w-1/2, аспект/радиус/фон не меняются.
const itemImageCls = (s: string | undefined) =>
	s === "small" ? "w-1/2" : "w-full";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

// colorScheme навешивает обёрткой composeV2Page; фон секции — bg-токен с белым
// фоллбеком (у flux нет цветных полотен, МАННЕРА §7).
const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 py-16 md:px-20 md:py-24 2xl:px-80"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class={`mx-auto flex w-full ${widthCls} flex-col gap-8 md:gap-12${containerSchemeCls}`}>
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}
		<ul class={gridCls} role="list" style={gridStyle}>
			{
				columns.map((c, index) => (
					<li
						class={`group flex w-full flex-col gap-4 md:gap-5${colAlignCls}`}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={index}
						data-puck-subsection-field="columns"
					>
						{c.image ? (
							<div
								class={`${itemImageCls(c.imageSize)} overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))] ${tileAspectCls}`}
							>
								<img
									src={c.image}
									alt={c.heading || ""}
									loading="lazy"
									decoding="async"
									class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
								/>
							</div>
						) : c.isPlaceholder ? (
							/* Пустое состояние Figma 1:19335: пустой surface-rect (без картинки). */
							<div
								class={`${itemImageCls(c.imageSize)} overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))] ${tileAspectCls}`}
								aria-hidden="true"
							/>
						) : null}
						<div class="flex w-full flex-col gap-2">
							{c.heading && (
								<h3
									class={`font-comfortaa ${itemHeadingCls(c.headingSize)} font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))]`}
								>
									{c.heading}
								</h3>
							)}
							{c.text && (
								<p
									class={`font-roboto-flex ${itemTextCls(c.textSize)} font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]`}
									set:html={c.text}
								/>
							)}
							{c.link && (
								<a
									href={c.link.href}
									class="font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70 md:text-[16px]"
								>
									{c.link.text}
								</a>
							)}
						</div>
					</li>
				))
			}
		</ul>
		{
			btnText && (
				<div class="flex justify-center">
					<a
						href={btnHref}
						class="inline-flex h-12 items-center justify-center rounded-[var(--radius-button,6px)] bg-[rgb(var(--color-button-2-bg,0_0_0))] px-6 font-manrope text-[16px] font-normal leading-normal text-[rgb(var(--color-button-2-text,255_255_255))] transition-opacity hover:opacity-95"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="102"
						data-puck-subsection-field="buttonText"
					>
						{btnText}
					</a>
				</div>
			)
		}
	</div>
</section>
