---
import Layout from "../layouts/Layout.astro";
import NtTextField from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtTextField.astro";
---

<Layout title="Контакты" description="Свяжитесь с Flux — контакты магазина и форма обратной связи">
	<section
		class="w-full bg-white px-4 pb-[60px] pt-12 md:px-20 md:pb-[80px] md:pt-20 2xl:px-[300px]"
		aria-labelledby="contacts-title"
	>
		<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-16 md:gap-20">
			<div class="flex flex-col gap-6">
				<h1
					id="contacts-title"
					class="font-comfortaa text-[28px] font-normal uppercase leading-[1.115] text-[#000000] md:text-[32px] lg:text-[36px]"
				>
					Контакты
				</h1>
				<dl class="flex flex-col gap-3 font-manrope text-[14px] font-normal leading-normal md:text-[16px]">
					<div class="flex flex-col gap-1 md:flex-row md:gap-16">
						<dt class="text-[#999999] md:w-[200px]">Номер телефона</dt>
						<dd class="text-[#000000]">
							<a href="tel:+70000000000" class="hover:opacity-80 transition-opacity">
								+7 (000) 000-00-00
							</a>
						</dd>
					</div>
					<div class="flex flex-col gap-1 md:flex-row md:gap-16">
						<dt class="text-[#999999] md:w-[200px]">E-mail</dt>
						<dd class="text-[#000000]">
							<a href="mailto:flux@example.ru" class="hover:opacity-80 transition-opacity">
								flux@example.ru
							</a>
						</dd>
					</div>
				</dl>
			</div>

			<div class="flex flex-col gap-8">
				<h2 class="font-comfortaa text-[24px] font-normal uppercase leading-[1.115] text-[#000000] md:text-[28px]">
					Остались вопросы?
				</h2>

				<form
					class="grid grid-cols-1 gap-6 lg:grid-cols-[430px_1fr] lg:items-start lg:gap-10"
					data-contacts-form
					novalidate
				>
					<div class="flex flex-col gap-4">
						<NtTextField label="Имя" name="name" autocomplete="name" />
						<NtTextField label="E-mail" name="email" type="email" autocomplete="email" />
						<NtTextField
							label="Номер телефона"
							name="phone"
							type="tel"
							autocomplete="tel"
							border="error"
						/>
					</div>

					<div class="flex flex-col gap-2">
						<label for="contacts-question" class="font-manrope text-[16px] font-normal leading-normal text-[#000000]">
							Ваш вопрос
						</label>
						<textarea
							id="contacts-question"
							name="question"
							rows={8}
							class="min-h-[232px] w-full rounded-[4px] border border-[#000000] bg-white p-4 font-manrope text-[16px] font-normal leading-normal text-[#000000] outline-none placeholder:text-[#999999] focus-visible:border-[#000000]"
						></textarea>
					</div>

					<div class="lg:col-start-2 lg:flex lg:justify-end">
						<button
							type="submit"
							class="inline-flex h-12 items-center justify-center rounded-[6px] bg-[#000000] px-6 font-manrope text-[16px] font-normal leading-normal text-white transition-opacity hover:opacity-95"
						>
							Отправить
						</button>
					</div>

					<p
						data-contacts-status
						role="status"
						class="hidden lg:col-span-2 font-manrope text-[16px] font-normal leading-normal text-[#4AD300]"
					></p>
				</form>
			</div>
		</div>
	</section>
</Layout>

<script>
	document.querySelector<HTMLFormElement>("[data-contacts-form]")?.addEventListener("submit", (event) => {
		event.preventDefault();
		const form = event.currentTarget as HTMLFormElement;
		const status = document.querySelector<HTMLElement>("[data-contacts-status]");
		if (status) {
			status.textContent = "Спасибо! Мы свяжемся с вами в ближайшее время.";
			status.classList.remove("hidden");
		}
		form.reset();
	});
</script>
