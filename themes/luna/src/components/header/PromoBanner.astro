---
interface Props {
	text: string;
	link: string;
	linkText?: string;
}

const { text, link, linkText = "Перейти" } = Astro.props;
---

<div class="bg-black text-white w-full py-2 sm:py-2.5 md:py-3 lg:py-3.5 xl:py-4">
	<div class="w-full max-w-[1920px] mx-auto px-3 sm:px-4 md:px-6 lg:px-8 xl:px-12 2xl:px-16">
		<a
			href={link}
			class="block text-center hover:opacity-80 transition-opacity text-xs sm:text-sm md:text-base lg:text-lg xl:text-xl font-normal leading-tight font-manrope"
		>
			<span class="inline-block">{text}</span>
			<span class="inline-block ml-1 sm:ml-2 md:ml-3 lg:ml-4 underline decoration-1 underline-offset-2">
				{linkText}
			</span>
		</a>
	</div>
</div>
