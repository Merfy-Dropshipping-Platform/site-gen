---
// Секция «Корзина» (V2-порт flux). Вынесена из themes/flux/src/pages/cart.astro
// БЕЗ изменения логики — та же ванильная корзина (getCart/render + мост checkout +
// cart-store.js/cart-api.js). Теперь это Puck-секция: page-cart редактируема как
// главная, корзину можно двигать/настраивать, добавлять другие секции вокруг.
// Корзина одна на странице (maxInstances:1) → document.querySelector безопасен
// (first-match не ловит дубль). Резолвится раньше theme-base скаффолда (resolveV2Section).
// Вёрстка приведена к канону верстальщиков (flux-theme/src/pages/cart.astro, Figma
// 905-18809): roboto-flex, flux-container, контент слева (max-w-[343px]), оранж-кнопка
// оформления, богатая товарная строка (207px превью + чёрный счётчик + Цвет/Размер).

interface Props {
	id?: string;
	padding?: { top: number; bottom: number };
	colorScheme?: number | string;
}
const { id, padding, colorScheme } = Astro.props as Props;

// Мост корзины → checkout: build.service.ts патчит `const shopId = ""` → siteId на деплое.
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";
// Проп «Отступы» из конструктора (px). Если не задан — дефолтные адаптивные классы.
const padStyle = padding
	? `padding-top:${Math.min(Number(padding.top) || 0, 160)}px;padding-bottom:${Math.min(Number(padding.bottom) || 0, 160)}px;`
	: undefined;
// Цветовая схема секции: пусто → наследует :root сайта.
const schemeClass = `color-scheme-${String(colorScheme ?? 2).replace("scheme-", "")}`;
---

<section
	data-puck-component-id={id}
	data-block="cart-section"
	class:list={[
		"w-full bg-white",
		schemeClass,
		padStyle ? "" : "pb-[80px] pt-[40px] md:pb-[120px] md:pt-[60px]",
	]}
	style={padStyle}
	aria-labelledby="cart-title"
>
	<div class="mx-auto w-full max-w-[1920px] px-4 md:px-20 2xl:px-80">
		<!-- Пустое состояние -->
		<div
			data-cart-page-empty
			class="flex w-full max-w-[343px] flex-col items-start gap-6"
		>
			<div class="flex w-full flex-col items-start gap-2">
				<h1
					id="cart-title"
					class="font-roboto-flex text-[20px] font-normal uppercase leading-normal text-black"
				>
					Корзина
				</h1>
				<p class="font-roboto-flex text-[16px] font-light leading-normal text-[#cccccc]">
					Вы пока не добавили товар в корзину
				</p>
			</div>
			<a
				href="/catalog"
				class="inline-flex h-[56px] items-center justify-center rounded-[6px] bg-black px-4 font-roboto-flex text-[16px] font-normal uppercase leading-normal text-white transition-opacity hover:opacity-90"
			>
				Продолжить покупки
			</a>
			<p class="font-roboto-flex text-[14px] font-light leading-normal text-[#999999]">
				Есть аккаунт?
				<a href="/login" class="text-black hover:opacity-80">Войти</a>
			</p>
		</div>

		<!-- Наполненная корзина -->
		<div
			data-cart-page-filled
			class="hidden w-full flex-col gap-6"
		>
			<div class="flex flex-col gap-6">
				<h1 class="font-roboto-flex text-[20px] font-normal uppercase leading-normal text-black">
					Корзина
				</h1>
				<ul
					data-cart-page-items
					role="list"
					class="flex flex-col gap-6"
				></ul>
			</div>

			<!-- Сводка заказа -->
			<div class="flex w-full max-w-[343px] flex-col gap-6 pt-1">
				<div class="flex flex-col gap-4">
					<p class="max-w-[269px] font-roboto-flex text-[14px] font-light leading-normal text-[#cccccc]">
						Налоги, скидки и стоимость доставки рассчитываются при оформлении заказа
					</p>
					<div class="flex items-center gap-3">
						<span class="font-roboto-flex text-[20px] font-light leading-normal text-black">Итого</span>
						<span data-cart-page-total class="font-roboto-flex text-[20px] font-light leading-normal text-black">0 ₽</span>
					</div>
				</div>
				<button
					type="button"
					data-action="checkout"
					class="inline-flex h-[56px] w-full items-center justify-center rounded-[6px] bg-[#FA5109] px-4 font-roboto-flex text-[16px] font-normal uppercase leading-normal text-white transition-opacity hover:opacity-90"
				>
					Оформить заказ
				</button>
			</div>
		</div>
	</div>
</section>

<script>
	import { getCart, getCartTotal, formatCartPrice } from "../../lib/cart";
	import { cartLineThumbPictureHtml } from "../../lib/cart-thumb-html";
	import { withBase } from "../../lib/with-base";

	const emptyBlock = document.querySelector<HTMLElement>("[data-cart-page-empty]");
	const filledBlock = document.querySelector<HTMLElement>("[data-cart-page-filled]");
	const itemsEl = document.querySelector<HTMLElement>("[data-cart-page-items]");
	const totalEl = document.querySelector<HTMLElement>("[data-cart-page-total]");

	const render = () => {
		const lines = getCart();
		if (!emptyBlock || !filledBlock || !itemsEl || !totalEl) return;
		if (lines.length === 0) {
			emptyBlock.classList.remove("hidden");
			emptyBlock.classList.add("flex");
			filledBlock.classList.add("hidden");
			filledBlock.classList.remove("flex");
			return;
		}
		emptyBlock.classList.add("hidden");
		emptyBlock.classList.remove("flex");
		filledBlock.classList.remove("hidden");
		filledBlock.classList.add("flex");

		itemsEl.innerHTML = lines
			.map((line) => {
				// Богатая товарная строка — канон верстальщиков (207px превью + бейдж
				// скидки + Цвет/Размер + чёрный счётчик с иконками). Данные счётчика/
				// удаления (data-cart-inc/dec/remove + data-id) НЕ трогаем: их слушает
				// общий делегат initCartUI (nt-cart-flux.ts). «Новинка»-бейдж опущен —
				// NtCartLine его не несёт; бейдж скидки берётся из реального oldPrice.
				const color = line.variant?.color ?? "";
				const size = line.variant?.size ?? "";
				const hasSale = typeof line.oldPrice === "number" && line.oldPrice > line.price;
				const oldPrice = hasSale ? formatCartPrice(line.oldPrice as number) : "";
				const discountPercent = hasSale
					? `-${Math.round((1 - line.price / (line.oldPrice as number)) * 100)}%`
					: "";
				const badges = discountPercent
					? `<div class="absolute left-1 top-1 flex flex-col items-start gap-1"><span class="flex items-center justify-center rounded-[2px] bg-[#FA5109] px-1.5 py-1 font-roboto-flex text-[12px] font-light leading-normal text-white">${discountPercent}</span></div>`
					: "";
				const varInfo =
					color || size
						? `<div class="flex items-center gap-1 font-roboto-flex text-[16px] font-light leading-normal text-black">${color ? `<span>Цвет:</span><span>${color}</span>` : ""}${size ? `<span class="ml-1">Размер:</span><span>${size}</span>` : ""}</div>`
						: "";
				return `
					<li class="flex flex-col gap-4 sm:flex-row sm:items-start sm:gap-4" data-line-id="${line.id}">
						<a href="/products/${line.productId}" class="relative block size-[207px] shrink-0 overflow-hidden rounded-[8px] bg-[#F5F5F5] max-sm:size-[140px]">
							${cartLineThumbPictureHtml(line.image, line.name)}
							${badges}
						</a>
						<div class="flex min-w-0 flex-1 items-start gap-4 self-stretch">
							<div class="flex min-w-0 flex-1 flex-col gap-4">
								<div class="flex flex-col gap-1">
									<a href="/products/${line.productId}" class="font-roboto-flex text-[20px] font-light leading-normal text-black transition-opacity hover:opacity-70">${line.name}</a>
									<div class="flex items-center gap-2 uppercase">
										<span class="font-roboto-flex text-[20px] font-light leading-normal text-black">${formatCartPrice(line.price)}</span>
										${oldPrice ? `<span class="font-roboto-flex text-[16px] font-normal leading-normal text-[#cccccc] line-through">${oldPrice}</span>` : ""}
									</div>
								</div>
								${varInfo}
							</div>
							<div class="flex h-full w-auto shrink-0 flex-col items-end justify-between gap-4 sm:w-[111px]">
								<button type="button" data-cart-remove data-id="${line.id}" class="flex size-6 items-center justify-center transition-opacity hover:opacity-70" aria-label="Удалить товар">
									<img src="${withBase("/icons/menu-close.svg")}" alt="" aria-hidden="true" width="12" height="12" class="size-3" />
								</button>
								<div class="inline-flex items-center justify-center gap-2 rounded-[4px] bg-black p-2">
									<button type="button" data-cart-dec data-id="${line.id}" class="flex size-8 items-center justify-center rounded-[4px] transition-opacity hover:opacity-70" aria-label="Уменьшить количество">
										<img src="${withBase("/icons/minus.svg")}" alt="" aria-hidden="true" width="16" height="16" class="size-4 brightness-0 invert" />
									</button>
									<span class="min-w-[16px] text-center font-roboto-flex text-[20px] font-light leading-normal text-white">${line.quantity}</span>
									<button type="button" data-cart-inc data-id="${line.id}" class="flex size-8 items-center justify-center rounded-[4px] transition-opacity hover:opacity-70" aria-label="Увеличить количество">
										<img src="${withBase("/icons/plus.svg")}" alt="" aria-hidden="true" width="16" height="16" class="size-4 brightness-0 invert" />
									</button>
								</div>
							</div>
						</div>
					</li>
				`;
			})
			.join("");

		totalEl.textContent = formatCartPrice(getCartTotal(lines));
	};

	render();
	window.addEventListener("flux:cart:updated", render);

	// Кол-во (+/−) и «Удалить» обрабатывает ОДИН общий делегат initCartUI
	// (nt-cart-flux.ts, document-level). Свои обработчики здесь УДАЛЕНЫ: иначе
	// клик ловился ДВАЖДЫ (страница + делегат) → «+»/«−» меняли количество на 2,
	// «Удалить» дёргался дважды.
	document.addEventListener("click", (event) => {
		const target = event.target as HTMLElement;
		const checkout = target.closest<HTMLButtonElement>("[data-action='checkout']");
		if (checkout) {
			// Мост NtCart → backend cart: строим серверную корзину из локальных линий,
			// чтобы checkout (cartStore) показал товары и submit/оплата работали.
			void (async () => {
				const cs = (window as any).cartStore;
				const lines = getCart();
				if (!cs) {
					window.alert("Корзина ещё загружается. Обновите страницу и попробуйте снова.");
					return;
				}
				if (lines.length) {
					let ok = true;
					try {
						cs.clear();
						for (const l of lines) {
							if ((await cs.addItem(l.productId, l.variant?.variantCombinationId ?? null, l.quantity)) === false) ok = false;
						}
					} catch (e) {
						ok = false;
					}
					// Не уходить в пустой /checkout: cs.clear() уже очистил серверную корзину,
					// при сбое addItem остаёмся на /cart с сообщением (иначе чекаут пуст).
					if (!ok) {
						window.alert("Не удалось перенести товары в оформление. Обновите страницу и попробуйте снова.");
						return;
					}
				}
				window.location.href = "/checkout"; // full load = VT-safe (checkout-скрипты стартуют свежими)
			})();
		}
	});
</script>

{/* Мост корзины → backend cart: грузим cartStore + конфиг, чтобы «Оформить заказ»
    создал серверную корзину из локальных NtCart-линий (shopId патчится на деплое). */}
<script is:inline define:vars={{ shopId, apiUrl }}>
	window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
		shopId: shopId || "",
		apiUrl: apiUrl || "https://gateway.merfy.ru/api",
	};
</script>
<script is:inline type="module" src="/scripts/cart-api.js"></script>
<script is:inline type="module" src="/scripts/cart-store.js"></script>
