---
import NavLink from './header/NavLink.astro';
import siteConfig from '../data/site-config.json';

interface Props {
  siteTitle?: string;
  logo?: string;
  logoPosition?: "top-left" | "top-center" | "top-right" | "center-left";
  stickiness?: "scroll-up" | "always" | "none";
  colorScheme?: string;
  padding?: { top: number; bottom: number };
  navigationLinks?: Array<{ label: string; href: string; submenu?: Array<{ label: string; href: string }> }>;
  menuColorScheme?: string;
  menuType?: "dropdown" | "mega-menu" | "sidebar";
  actionButtons?: { showSearch?: string; showCart?: string; showProfile?: string };
}

const {
  siteTitle = 'Мой магазин',
  logo = '/logo.svg',
  logoPosition = 'top-left',
  stickiness = 'scroll-up',
  colorScheme,
  padding,
  navigationLinks = [
    { label: 'Главная', href: '/' },
    { label: 'Каталог', href: '/catalog' },
    { label: 'О нас', href: '/about' },
    { label: 'Контакты', href: '/contacts' },
  ],
  menuColorScheme,
  actionButtons = { showSearch: 'true', showCart: 'true', showProfile: 'true' },
} = Astro.props;

const showSearch = actionButtons?.showSearch === 'true';
const showCart = actionButtons?.showCart === 'true';
const showProfile = actionButtons?.showProfile === 'true';

// Resolve color schemes from site-config.json
const colorSchemes = (siteConfig as any)?.colorSchemes ?? [];
const scheme = colorScheme
  ? colorSchemes.find((s: any) => s.id === colorScheme) || colorSchemes[0]
  : colorSchemes[0] || null;
const menuScheme = menuColorScheme
  ? colorSchemes.find((s: any) => s.id === menuColorScheme) || scheme
  : scheme;

const bgColor = scheme?.background ?? null;
const textColor = scheme?.text ?? null;
const menuBg = menuScheme?.background ?? bgColor;
const menuText = menuScheme?.text ?? textColor;

// Stickiness
const stickyClass = stickiness === "always"
  ? "sticky top-0 z-50"
  : stickiness === "scroll-up"
    ? "sticky top-0 z-50 transition-transform duration-300"
    : "relative z-50";

// Padding
const paddingTop = padding?.top ?? 0;
const paddingBottom = padding?.bottom ?? 0;
const useCustomPadding = paddingTop > 0 || paddingBottom > 0;

// Style objects
const headerStyle = [
  bgColor ? `background-color: ${bgColor};` : '',
  textColor ? `color: ${textColor};` : '',
  textColor ? `border-color: ${textColor}15;` : '',
  useCustomPadding ? `padding-top: ${paddingTop}px; padding-bottom: ${paddingBottom}px;` : '',
].filter(Boolean).join(' ');

const wrapperStyle = bgColor ? `background-color: ${bgColor};` : '';

const menuStyle = [
  menuBg ? `background-color: ${menuBg};` : '',
  textColor ? `border-color: ${textColor}15;` : '',
].filter(Boolean).join(' ');

const navLinkStyle = menuText ? `color: ${menuText};` : '';
const textStyle = textColor ? `color: ${textColor};` : '';

// Logo filter: if textColor is light (on dark bg), invert the logo SVG via CSS filter
// Parse hex color to determine if it's light
function isLightColor(hex: string | null): boolean {
  if (!hex) return false;
  const clean = hex.replace('#', '');
  if (clean.length < 6) return false;
  const r = parseInt(clean.slice(0, 2), 16);
  const g = parseInt(clean.slice(2, 4), 16);
  const b = parseInt(clean.slice(4, 6), 16);
  const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
  return luminance > 0.5;
}

const logoNeedsInvert = isLightColor(textColor);
const logoStyle = logoNeedsInvert ? 'filter: brightness(0) invert(1);' : '';

const isCenterLeft = logoPosition === 'center-left';
---

<div class={`w-full shadow-sm ${stickyClass}`} style={wrapperStyle} data-header-wrapper>
  <header
    class:list={[
      'w-full flex items-center border-b',
      !bgColor && 'bg-theme-background border-theme',
      !useCustomPadding && !isCenterLeft && 'h-16 md:h-[80px]',
    ]}
    style={headerStyle}
  >
    <nav
      class:list={[
        'w-full max-w-[1320px] mx-auto px-4 md:px-6 flex items-center relative',
        !isCenterLeft && 'justify-between',
      ]}
    >
      {/* ============ LAYOUT: top-left (default) ============ */}
      {logoPosition === 'top-left' && (
        <>
          {/* Mobile hamburger */}
          <button
            id="mobile-menu-button"
            aria-label="Меню"
            aria-expanded="false"
            class:list={['md:hidden w-10 h-10 flex items-center justify-center hover:opacity-70 transition-opacity', !textColor && 'text-theme-foreground']}
            style={textStyle}
          >
            <svg id="menu-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M11 17H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M11 23H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {/* Logo */}
          <div class="absolute left-1/2 -translate-x-1/2 md:relative md:left-auto md:transform-none">
            <a href="/" class="flex items-center hover:opacity-80 transition-opacity">
              {logo ? (
                <img src={logo} alt={siteTitle} class="h-5 sm:h-6 md:h-[26px] w-auto" style={logoStyle || undefined} />
              ) : (
                <span class:list={['text-base sm:text-lg md:text-[26px] font-semibold tracking-[0.2em] uppercase leading-none font-body', !textColor && 'text-theme-foreground']} style={textStyle}>{siteTitle}</span>
              )}
            </a>
          </div>

          {/* Desktop nav */}
          <div class="hidden md:flex items-center gap-[40px]">
            {navigationLinks?.map((link) => (
              <a
                href={link.href}
                class:list={['text-[16px] font-normal hover:opacity-70 transition-opacity leading-[1.4] font-body', !menuText && 'text-theme-foreground']}
                style={navLinkStyle}
              >
                {link.label}
              </a>
            ))}
          </div>

          {/* Actions */}
          <div class="flex items-center gap-[24px]">
            {showSearch && (
              <button
                aria-label="Поиск"
                class:list={['hidden md:flex w-8 h-8 items-center justify-center hover:opacity-70 transition-opacity', !textColor && 'text-theme-foreground']}
