---
// Секция «Puk» — НЕ каноническая секция конструктора (не регистрируется в
// puckConfig). Тематическая доп-секция → ближайший тип контракта Figma 1:19335 =
// PopularProducts «Коллекция товаров» (эталон flux Popular.astro / rose
// Popular.astro). Пустое состояние = ДОСЛОВНЫЙ Figma-плейсхолдер, НЕ мок-демо
// верстальщика «АКЦИЯ ПУКНИ» с pukItems.
//
// Гейт как у PopularProducts: коллекция ВЫБРАНА → реальные товары через SSR-фетч
// storefront-data (как эталон); выбора НЕТ → дефолт-заголовок «Коллекция
// товаров» + N карточек-плейсхолдеров с цветной курткой циклом
// blue→yellow→red→green, подпись «Товар», цена «2 500 ₽».
import FluxPicture from "../img/FluxPicture.astro";

const p = Astro.props as Record<string, any>;
const id = p.id;

// Figma 1:19335 — ДОСЛОВНЫЙ плейсхолдер пустого состояния PopularProducts:
// заголовок «Коллекция товаров», без хелпер-подзаголовка (только заголовок +
// карточки-куртки). Дефолт-текст верстальщика заменён на Figma-текст. Когда
// мерчант задал свой heading/text/subtitle — рендерим ЕГО (?? fallback
// срабатывает только при пустых данных).
const heading =
  (typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title ?? "Коллекция товаров";
const subtitle =
  (typeof p.text === "string" ? p.text : p.text?.content) ??
  (typeof p.subtitle === "string" ? p.subtitle : p.subtitle?.content) ??
  undefined;

// Количество карточек-плейсхолдеров (дефолт 4 — паритет PopularProducts).
const cardsN =
  typeof p.cards === "number" && p.cards > 0
    ? Math.max(1, Math.min(24, Math.round(p.cards)))
    : 4;

// Ассеты курток-плейсхолдеров: лежат в packages/theme-base/public/placeholders/
// и копируются в корень сайта (доступны как /placeholders/sweater-<color>.png).
// Паритет с FluxProductDetail.astro / storefront-hydrate.ts (root-relative URL).
const SWEATERS = [
  "/placeholders/sweater-blue.svg",
  "/placeholders/sweater-yellow.svg",
  "/placeholders/sweater-red.svg",
  "/placeholders/sweater-green.svg",
];

// Канон collection (collectionPicker, id или slug): носитель для SSR-фетча.
const collectionRef =
  typeof p.collection === "string" && p.collection.trim() ? p.collection.trim() : undefined;

// SSR-фетч реальных товаров выбранной коллекции (Figma-цель, эталон flux/rose
// Popular.astro): коллекция ВЫБРАНА → реальные товары ПРЯМО в статике, чтобы их
// видело и ПРЕВЬЮ конструктора (Astro Container не исполняет клиентскую
// гидрацию). siteId инжектит рендер-пайплайн (preview.service / build). Нет
// коллекции / siteId / ошибка → realItems пуст → секция рендерит
// плейсхолдер-куртки Figma.
const siteId = typeof p.siteId === "string" ? p.siteId : "";
const fmtPrice = (v: unknown): string => {
  const n = typeof v === "number" ? v : parseFloat(String(v ?? ""));
  return Number.isFinite(n) ? `${Math.round(n).toLocaleString("ru-RU")} ₽` : "";
};
type RealItem = { id: string; title: string; image: string; price: string };
let realItems: RealItem[] = [];
if (collectionRef && siteId) {
  try {
    const base = (import.meta as any).env?.SITES_INTERNAL_BASE ?? "http://localhost:3114";
    const res = await fetch(`${base}/api/sites/${siteId}/storefront-data`).catch(() => null);
    if (res && res.ok) {
      const data: any = await res.json();
      const all: any[] = Array.isArray(data?.products) ? data.products : [];
      const cols: any[] = Array.isArray(data?.collections) ? data.collections : [];
      const matched = cols.find(
        (c) =>
          c &&
          (c.id === collectionRef ||
            c.slug === collectionRef ||
            c.name === collectionRef ||
            c.handle === collectionRef),
      );
      const ids =
        matched && Array.isArray(matched.productIds) && matched.productIds.length
          ? new Set(matched.productIds)
          : null;
      const picked = (ids ? all.filter((pr) => pr?.id && ids.has(pr.id)) : all).slice(0, cardsN);
      realItems = picked.map((pr) => {
        const img =
          Array.isArray(pr?.images) && pr.images[0]
            ? typeof pr.images[0] === "string"
              ? pr.images[0]
              : pr.images[0]?.url ?? ""
            : pr?.image ?? "";
        return {
          id: String(pr?.id ?? ""),
          title: String(pr?.name ?? pr?.title ?? "Товар"),
          image: String(img ?? ""),
          price: fmtPrice(pr?.basePrice ?? pr?.price),
        };
      });
    }
  } catch {
    realItems = [];
  }
}

// Гейт по реальным данным: коллекция выбрана И есть реальные товары → рендер
// реальных карточек. Иначе — плейсхолдер-куртки циклом по цветам (НЕ мок-товары
// верстальщика).
const hasRealData = realItems.length > 0;

const cards = hasRealData
  ? realItems.map((it) => ({
      title: it.title || "Товар",
      price: it.price || "",
      image: it.image || SWEATERS[0],
      isPlaceholder: false,
    }))
  : Array.from({ length: cardsN }, (_, i) => ({
      title: "Товар",
      price: "2 500 ₽",
      image: SWEATERS[i % SWEATERS.length],
      isPlaceholder: true,
    }));
---

<section
  class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-16 pt-16 md:px-20 md:pb-24 md:pt-24 2xl:px-80"
  data-puck-component-id={id}
>
  <div class="mx-auto w-full max-w-[1320px]">
    {/* Figma 1:19335: заголовок «Коллекция товаров» рендерится ВСЕГДА (дефолт в
        frontmatter), подзаголовок — только если задан мерчантом. */}
    <div class="mb-12 flex flex-col items-center gap-1 text-center md:mb-16">
      <h2 class="font-comfortaa text-[24px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))] md:text-[28px]">
        {heading}
      </h2>
      {subtitle && (
        <p class="font-roboto-flex text-[18px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] md:text-[20px]">
          {subtitle}
        </p>
      )}
    </div>

    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:gap-6 lg:grid-cols-4">
      {cards.map((card) => (
        <div class="flex flex-col gap-4 md:gap-5">
          <div class="aspect-[318/444] w-full overflow-hidden rounded-[8px] bg-[rgb(var(--color-surface,251_251_251))]">
            {card.isPlaceholder ? (
              // Плейсхолдер-куртка: сырой <img>, НЕ FluxPicture — у ассетов
              // /placeholders/sweater-*.png НЕТ соимённого .webp, а <picture>
              // не откатывается на <img> при 404 webp-source (баг корзины).
              <img
                src={card.image}
                alt={card.title}
                class="h-full w-full object-contain p-[15%]"
                loading="lazy"
              />
            ) : (
              <FluxPicture
                src={card.image}
                alt={card.title}
                class="h-full w-full object-cover transition-transform duration-300 hover:scale-105"
                loading="lazy"
              />
            )}
          </div>
          <div class="flex flex-col items-start gap-1">
            <p class="font-manrope text-[18px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[20px]">
              {card.title}
            </p>
            {card.price && (
              <p class="font-manrope text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] md:text-[18px]">
                {card.price}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
