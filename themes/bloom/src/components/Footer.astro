---
import SocialIcon from "./footer/SocialIcon.astro";
import { SITE_TITLE } from "../consts";
import { categoryPages } from "../data/categories";

const today = new Date();

const navColumnDefault = [
	...categoryPages,
	{ label: "О нас", href: "/about" },
];

// ОЖИВЛЕНИЕ (Фаза B, объём rose Footer): канон-схема theme-base Footer.puckConfig —
// siteTitle, phone, email/socialColumn.email, newsletter.enabled, navigationColumn,
// informationColumn, socialColumn.socialLinks, copyright, bottomStrip, padding.
// Тело ниже — verbatim верстальщика; дефолтные ветки = прежним строкам байт-в-байт
// (цвета → токены с пиксель-фоллбеком §7); новые элементы (заголовки колонок) не
// рендерятся без пропсов.
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустая строка (canon default Puck / коэрсер) не должна ронять «Bloom».
const siteTitle = typeof p.siteTitle === "string" && p.siteTitle.trim() ? p.siteTitle : SITE_TITLE;
const phone = typeof p.phone === "string" && p.phone.trim() ? p.phone.trim() : "";
const rawEmail = p.socialColumn?.email ?? p.email ?? "";
const email = typeof rawEmail === "string" ? rawEmail.trim() : "";
const contactFields: Array<{ label: string; value: string }> = Array.isArray(p.socialColumn?.contactFields)
	? p.socialColumn.contactFields.filter((f: any) => f && typeof f.value === "string" && f.value.trim())
	: [];
const emailPlaceholder = `example@${siteTitle.toLowerCase()}.merfy`;

// Канон newsletter.enabled — скрыть блок подписки ТОЛЬКО при явном false/'false'
// (булево может прийти строкой). Отсутствие пропа → блок показан = пиксель.
const newsletterEnabled = !(
	p.newsletter &&
	(p.newsletter.enabled === false || p.newsletter.enabled === "false")
);

// Канон-колонки {title, links:[{label,href}]}: ссылки из пропсов с fallback на
// литералы верстальщика (навигация = категории + О нас; информация = правовые
// ссылки /legal/*); заголовок колонки — НОВЫЙ элемент, рендерится только при
// непустом title (в вёрстке верстальщика заголовков колонок нет).
const coerceColumnLinks = (
	col: any,
	fallback: Array<{ label: string; href: string }>,
): Array<{ label: string; href: string }> =>
	Array.isArray(col?.links) && col.links.length > 0
		? col.links.map((l: any) => ({ label: String(l?.label ?? ""), href: String(l?.href ?? "/") }))
		: fallback;
const navLinks = coerceColumnLinks(p.navigationColumn, navColumnDefault);
const infoLinks = coerceColumnLinks(p.informationColumn, []);
const columnTitle = (col: any): string | undefined =>
	typeof col?.title === "string" && col.title.trim() ? col.title : undefined;
const navColTitle = columnTitle(p.navigationColumn);
const infoColTitle = columnTitle(p.informationColumn);
const columnTitleCls =
	"font-urbanist text-[16px] font-light uppercase leading-normal text-[rgb(var(--color-text,0_0_0))]";

// Канон socialColumn.socialLinks (enum платформ) → подписи верстальщика для
// SocialIcon (DS-карта иконок); fallback = литеральный набор верстальщика дословно.
const SOCIAL_PLATFORMS: Record<string, string> = {
	vk: "VK",
	youtube: "YouTube",
	dzen: "Яндекс Дзен",
	tiktok: "TikTok",
	telegram: "Telegram",
};
const socials = Array.isArray(p.socialColumn?.socialLinks)
	? p.socialColumn.socialLinks
			.map((s: any) => {
				const label = SOCIAL_PLATFORMS[String(s?.platform ?? "")];
				const href = String(s?.href ?? "").trim();
				return label && href && href !== "#" ? { platform: label, href } : null;
			})
			.filter((s: any) => s !== null)
	: [];

// Канон copyright {companyName, poweredBy, showYear} (+ legacy-строка целиком).
// Дефолтная сборка = литерал блока 3 верстальщика байт-в-байт:
// «© {год} {siteTitle} Theme Все права защищены.» — БЕЗ хвоста Powered by
// (он живёт в розовой полосе блока 4). canon-default poweredBy 'Powered by Merfy'
// из puckConfig трактуется как «не задан» → литерал (правило canon-default → пиксель).
const copyrightProp = p.copyright;
const copyrightOverride =
	typeof copyrightProp === "string" && copyrightProp.trim() ? copyrightProp : undefined;
const copyrightObj = copyrightProp && typeof copyrightProp === "object" ? copyrightProp : {};
const showYear = !(copyrightObj.showYear === false || copyrightObj.showYear === "false");
const companyPart =
	typeof copyrightObj.companyName === "string" && copyrightObj.companyName.trim()
		? copyrightObj.companyName
		: `${siteTitle} Theme`;
const poweredByTail =
	typeof copyrightObj.poweredBy === "string" &&
	copyrightObj.poweredBy.trim() &&
	copyrightObj.poweredBy !== "Powered by Merfy"
		? copyrightObj.poweredBy
		: "";
const copyrightText =
	copyrightOverride ??
	`© ${showYear ? `${today.getFullYear()} ` : ""}${companyPart} Все права защищены.${poweredByTail ? ` ${poweredByTail}` : ""}`;

// Канон bottomStrip {enabled, text} — розовая полоса блока 4 верстальщика.
// enabled false/'false' → полоса скрыта; непустой text перебивает литеральную
// сборку. НЮАНС: blockDefaults bloom пишут text «© 2026 Bloom Theme. Powered by
// Merfy» (короче литерала) — трактуем как canon-default → литерал.
const CANON_STRIP_TEXT = "© 2026 Bloom Theme. Powered by Merfy";
const strip = p.bottomStrip && typeof p.bottomStrip === "object" ? p.bottomStrip : undefined;
const bottomStripVisible = !(strip && (strip.enabled === false || strip.enabled === "false"));
const stripText =
	typeof strip?.text === "string" && strip.text.trim() && strip.text !== CANON_STRIP_TEXT
		? strip.text
		: `© ${today.getFullYear()} ${siteTitle} Theme Все права защищены. Powered by Merfy`;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при пропе, на носителе отступов
// верстальщика (контейнер pt-16 pb-24 md:pb-28). {80,80} = canon-default puckConfig
// (его впрыскивает коэрсер) → литерал (правило canon-default → пиксель).
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const isCanonPad = pad && Number(pad.top) === 80 && Number(pad.bottom) === 80;
const footerPadStyle =
	pad && !isCanonPad
		? `padding-top:${Number(pad.top) || 0}px;padding-bottom:${Number(pad.bottom) || 0}px;`
		: undefined;
const footerContainerCls = footerPadStyle
	? "mx-auto w-full max-w-[1920px] px-4 md:px-20 2xl:px-[300px]"
	: "mx-auto w-full max-w-[1920px] px-4 pt-16 pb-24 md:px-20 md:pb-28 2xl:px-[300px]";
---

<footer class="w-full bg-[rgb(var(--color-bg,255_255_255))]" data-puck-component-id={id}>
	<div class={footerContainerCls} style={footerPadStyle} data-animate>
		<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-12">
			<!-- Block 1: Newsletter -->
			{newsletterEnabled && (
			<section
				class="flex w-full flex-col gap-6 lg:flex-row lg:items-start lg:justify-between"
				aria-labelledby="newsletter-heading"
			>
				<div class="flex flex-col gap-2">
					<h2
						id="newsletter-heading"
						class="font-urbanist text-[20px] font-light uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))]"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="100"
						data-puck-subsection-field="newsletter"
					>
						ПОДПИШИТЕСЬ НА РАССЫЛКУ
					</h2>
					<p class="font-inter text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]">
						Подпишитесь на наши акции и новости
					</p>
				</div>

				<div class="flex w-full max-w-[318px] flex-col gap-2 lg:shrink-0">
					<form
						class="flex h-10 w-full items-center gap-2 rounded-full border border-[rgb(var(--color-input-border,255_212_229))] bg-white pl-4 pr-1 transition-colors focus-within:border-[#E38E9F]"
						data-newsletter-form
						data-puck-subsection-parent={id}
						data-puck-subsection-index="997"
						data-puck-subsection-field="newsletter"
					>
						<input
							type="email"
							name="email"
							required
							placeholder={emailPlaceholder}
							aria-label="Email"
							class="min-w-0 flex-1 bg-transparent font-inter text-[14px] font-light leading-normal text-black outline-none placeholder:text-[#FFD4E5]"
						/>
						<button
							type="submit"
							class="inline-flex h-8 shrink-0 items-center justify-center rounded-full bg-[rgb(var(--color-surface,253_244_246))] px-4 font-inter text-[12px] font-light leading-normal text-[rgb(var(--color-accent,227_142_159))] transition-opacity hover:opacity-80 active:scale-95"
						>
							Отправить
						</button>
					</form>
					<p
						data-newsletter-status
						role="status"
						class="hidden font-inter text-[14px] font-light leading-normal text-[rgb(var(--color-accent,227_142_159))]"
					></p>
				</div>
			</section>
			)}

			<!-- Block 2: Main footer -->
			<section
				class="flex w-full flex-col gap-10 lg:flex-row lg:items-start lg:justify-between lg:gap-16"
				aria-label="Навигация по сайту"
			>
				<div class="flex flex-col items-start">
					<a href="/" class="inline-flex transition-opacity hover:opacity-80" aria-label={siteTitle}>
						<img
							src="/icons/Bloom.svg"
							alt={siteTitle}
							width="65"
							height="19"
							class="h-[19px] w-[65px]"
							decoding="async"
						/>
					</a>

					<address class="mt-8 flex flex-col gap-[3px] not-italic">
						<span class="font-inter text-[14px] font-light leading-[18px] text-[rgb(var(--color-muted,153_153_153))]">
							Адрес:
						</span>
						<span class="font-inter text-[14px] font-light leading-[18px] text-[rgb(var(--color-muted,153_153_153))]">
							г. Москва,
						</span>
						<span class="font-inter text-[14px] font-light leading-[18px] text-[rgb(var(--color-muted,153_153_153))]">
							ул. Пушкина,
						</span>
						<span class="font-inter text-[14px] font-light leading-[18px] text-[rgb(var(--color-muted,153_153_153))]">
							д. 0
						</span>
					</address>

					<div
						class="mt-5 flex flex-col gap-[3px]"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="994"
						data-puck-subsection-field="socialColumn"
					>
						<span class="font-inter text-[14px] font-light leading-[18px] text-[rgb(var(--color-muted,153_153_153))]">
							Контакты:
						</span>
						{phone && (
							<a
								href={`tel:${phone.replace(/[^+\d]/g, "")}`}
								class="font-inter text-[14px] font-light leading-[18px] text-[rgb(var(--color-muted,153_153_153))] transition-opacity hover:opacity-70"
							>
								{phone}
							</a>
						)}
						{email && (
							<a
								href={`mailto:${email}`}
								class="font-inter text-[14px] font-light leading-[18px] text-[rgb(var(--color-muted,153_153_153))] transition-opacity hover:opacity-70"
							>
								{email}
							</a>
						)}
						{contactFields.map((f) => (
							<div class="font-inter text-[14px] font-light leading-[18px] text-[rgb(var(--color-muted,153_153_153))]">
								<span class="text-[rgb(var(--color-text,0_0_0))]">{f.label}:</span> {f.value}
							</div>
						))}
					</div>

					{socials.length > 0 && (
						<div class="mt-6 flex flex-wrap items-center gap-2">
							{socials.map((s) => (
								<SocialIcon
									href={s.href}
									ariaLabel={s.platform}
									platform={s.platform}
								/>
							))}
						</div>
					)}
				</div>

				<ul
					class="flex flex-col gap-3 lg:ml-auto lg:pt-0"
					role="list"
					data-puck-subsection-parent={id}
					data-puck-subsection-index="996"
					data-puck-subsection-field="navigationColumn"
				>
					{navColTitle && (
						<li>
							<h3 class={columnTitleCls}>{navColTitle}</h3>
						</li>
					)}
					{navLinks.map((link) => (
						<li>
							<a
								href={link.href}
								class="font-inter text-[14px] font-light leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70"
							>
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</section>

			<!-- Block 3: Legal row -->
			<section class="flex w-full flex-col gap-4 pt-2" aria-label="Правовая информация">
				<div class="h-px w-full bg-[rgb(var(--color-accent,227_142_159)/0.5)]" aria-hidden="true"></div>

				<div class="flex w-full flex-col gap-3 md:flex-row md:items-center md:justify-between">
					<p
						class="font-inter text-[14px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="993"
						data-puck-subsection-field="copyright"
					>
						{copyrightText}
					</p>

					{(infoColTitle || infoLinks.length > 0) && (
						<div
							class="flex flex-wrap items-center gap-x-4 gap-y-2"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="995"
							data-puck-subsection-field="informationColumn"
						>
							{infoColTitle && <span class={columnTitleCls}>{infoColTitle}</span>}
							{infoLinks.map((link) => (
								<a
									href={link.href}
									class="font-inter text-[14px] font-light leading-normal text-[rgb(var(--color-text,0_0_0))] underline underline-offset-2 transition-opacity hover:opacity-70"
								>
									{link.label}
								</a>
							))}
						</div>
					)}
				</div>
			</section>
		</div>
	</div>

	<!-- Block 4: Bottom pink bar -->
	{bottomStripVisible && (
		<div
			class="w-full bg-[rgb(var(--color-bg,227_142_159))] py-5"
			data-puck-subsection-parent={id}
			data-puck-subsection-index="992"
			data-puck-subsection-field="bottomStrip"
		>
			<p class="text-center font-inter text-[14px] font-light leading-normal text-[rgb(var(--color-text,255_255_255))]">
				{stripText}
			</p>
		</div>
	)}
</footer>

<script>
	document.querySelector<HTMLFormElement>("[data-newsletter-form]")?.addEventListener("submit", (event) => {
		event.preventDefault();
		const form = event.currentTarget as HTMLFormElement;
		const status = document.querySelector<HTMLElement>("[data-newsletter-status]");
		if (status) {
			status.textContent = "Спасибо! Мы отправим вам приветственное письмо.";
			status.classList.remove("hidden");
		}
		form.reset();
	});
</script>
