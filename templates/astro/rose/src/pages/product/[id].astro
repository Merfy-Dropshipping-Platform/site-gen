---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import products from '../../data/products.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  const productList = products || [];
  return productList.map((product: any) => ({
    params: { id: product.slug ?? product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};

// Images: support both formats
const productImages: string[] = Array.isArray(product?.images)
  ? product.images.filter(Boolean)
  : product?.image
    ? [product.image]
    : [];
const mainImage = productImages[0] || null;
const hasMultipleImages = productImages.length > 1;

// Variants from products.json (added by build pipeline)
const productVariants: Array<{ id: string; title: string; price: string; available: boolean }> =
  Array.isArray(product?.variants) ? product.variants : [];
const hasVariants = product?.hasVariants === true && productVariants.length > 0;

// JSON for JS interactivity
const imagesJson = JSON.stringify(productImages);
---
<BaseLayout title={`${product?.name ?? 'Товар'} — ${meta?.title ?? 'Мой магазин'}`} description={product?.description}>
  <Header {...headerProps} />

  <main class="flex-1 w-full" style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));">
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-0 py-10">
      <!-- Breadcrumbs -->
      <nav class="mb-8 font-body" style="color: rgb(var(--color-muted));">
        <a href="/" class="hover:opacity-80 transition-opacity" style="color: rgb(var(--color-muted));">Главная</a>
        <span class="mx-1">/</span>
        <a href="/catalog" class="hover:opacity-80 transition-opacity" style="color: rgb(var(--color-muted));">Каталог</a>
        <span class="mx-1">/</span>
        <span style="color: rgb(var(--color-foreground));">{product?.name}</span>
      </nav>

      <div class="flex flex-col lg:flex-row lg:justify-center gap-10">
        <!-- Image block -->
        <div class="w-full lg:w-[480px] lg:shrink-0">
          <!-- Main image (stacked layout) -->
          <div
            class="overflow-hidden w-full aspect-square flex items-center justify-center cursor-pointer"
            style="background: #FBFBFB; border-radius: var(--radius-card, 12px);"
            id="main-image-container"
            data-images={imagesJson}
          >
            {mainImage ? (
              <img
                id="main-product-image"
                src={mainImage}
                alt={product?.name ?? 'Товар'}
                class="w-full h-full object-cover"
                loading="eager"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-gray-300">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21,15 16,10 5,21"/>
                </svg>
              </div>
            )}
          </div>

          <!-- Thumbnails grid (stacked: 2 columns for remaining images) -->
          {hasMultipleImages && (
            <div class="grid grid-cols-2 gap-3 mt-3" id="thumbnail-strip">
              {productImages.slice(1).map((img: string, i: number) => (
                <button
                  type="button"
                  class="thumb-btn overflow-hidden aspect-square flex items-center justify-center cursor-pointer border-2 border-transparent transition-colors"
                  style="background: #FBFBFB; border-radius: var(--radius-card, 12px);"
                  data-index={i + 1}
                  data-src={img}
                >
                  <img src={img} alt={`${product?.name} — фото ${i + 2}`} class="w-full h-full object-cover" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Product info -->
        <div class="flex flex-col lg:w-[352px]">
          <!-- Badge -->
          {product?.quantity != null && product.quantity <= 5 && product.quantity > 0 && (
            <span class="font-body" style="color: rgb(var(--color-foreground)); font-size: 14px;">
              Осталось мало
            </span>
          )}

          <!-- Title -->
          <h1 class="font-heading" style="color: rgb(var(--color-foreground)); font-size: 28px; line-height: 33px;">
            {product?.name}
          </h1>

          <!-- Price -->
          <div class="flex items-baseline gap-3 mt-2">
            <span class="text-xl leading-[23px] font-body" id="price-display" style="color: rgb(var(--color-foreground));">
              {product?.price ?? '0 ₽'}
            </span>
            {(product?.oldPrice) && (
              <span class="text-base leading-[19px] line-through opacity-50 font-body" style="color: rgb(var(--color-foreground));">
                {product.oldPrice}
              </span>
            )}
          </div>

          <!-- Variants -->
          {hasVariants && (
            <div class="flex flex-wrap gap-2 mt-6" id="variants-container">
              {productVariants.map((v, i) => (
                <button
                  type="button"
                  class="variant-btn h-10 px-5 text-base leading-[19px] inline-flex items-center font-body cursor-pointer transition-colors border-0"
                  style={`border-radius: var(--radius-button, 8px); background: ${i === 0 ? 'rgb(var(--color-primary))' : 'rgb(var(--color-secondary))'}; color: ${i === 0 ? 'rgb(var(--color-button-text))' : 'rgb(var(--color-foreground))'};`}
                  data-variant-id={v.id}
                  data-price={v.price}
                  data-available={String(v.available)}
                  disabled={!v.available}
                >
                  {v.title}
                </button>
              ))}
            </div>
          )}

          <!-- Quantity -->
          <div class="flex items-center mt-6">
            <button type="button" id="qty-minus" class="w-10 h-10 flex items-center justify-center cursor-pointer border-0" style="border-radius: var(--radius-button, 8px); background: #FBFBFB; color: rgb(var(--color-foreground));">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M6 12H18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            </button>
            <span id="qty-display" class="w-10 h-10 flex items-center justify-center mx-[5px] text-base font-body" style="border-radius: 10px; background: rgb(var(--color-background)); color: rgb(var(--color-foreground));">
              1
            </span>
            <button type="button" id="qty-plus" class="w-10 h-10 flex items-center justify-center cursor-pointer border-0" style="border-radius: var(--radius-button, 8px); background: #FBFBFB; color: rgb(var(--color-foreground));">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 6V18M6 12H18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            </button>
          </div>

          <!-- Buttons -->
          <div class="flex flex-col mt-6">
            <button
              type="button"
              id="add-to-cart-btn"
              class="w-full h-14 flex items-center justify-center text-base font-body transition-colors cursor-pointer border-0"
              style="border-radius: var(--radius-button, 8px); background: rgb(var(--color-secondary)); color: rgb(var(--color-foreground));"
              data-product-id={product?.id}
              data-product-slug={product?.slug ?? product?.id}
            >
              Добавить в корзину
            </button>
            <button
              type="button"
              id="buy-now-btn"
              class="w-full h-14 flex items-center justify-center text-base font-body transition-colors cursor-pointer border-0 mt-3"
              style="border-radius: var(--radius-button, 8px); background: rgb(var(--color-primary)); color: rgb(var(--color-button-text));"
              data-product-id={product?.id}
              data-product-slug={product?.slug ?? product?.id}
            >
              Купить сейчас
            </button>
          </div>

          <!-- Description -->
          {product?.description && (
            <p class="text-base leading-6 mt-6 opacity-70 whitespace-pre-line font-body" style="color: rgb(var(--color-foreground));">
              {product.description}
            </p>
          )}

          <!-- Share -->
          <button type="button" id="share-btn" class="flex items-center gap-3 mt-8 opacity-80 hover:opacity-100 transition-opacity font-body cursor-pointer border-0 bg-transparent p-0" style="color: rgb(var(--color-foreground)); font-size: 16px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 6L12 3M12 3L15 6M12 3V13M7.00023 10C6.06835 10 5.60241 10 5.23486 10.1522C4.74481 10.3552 4.35523 10.7448 4.15224 11.2349C4 11.6024 4 12.0681 4 13V17.8C4 18.9201 4 19.4798 4.21799 19.9076C4.40973 20.2839 4.71547 20.5905 5.0918 20.7822C5.5192 21 6.07899 21 7.19691 21H16.8036C17.9215 21 18.4805 21 18.9079 20.7822C19.2842 20.5905 19.5905 20.2839 19.7822 19.9076C20 19.4802 20 18.921 20 17.8031V13C20 12.0681 19.9999 11.6024 19.8477 11.2349C19.6447 10.7448 19.2554 10.3552 18.7654 10.1522C18.3978 10 17.9319 10 17 10" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Поделиться</span>
          </button>
        </div>
      </div>
    </div>
  </main>

  <Footer {...footerProps} />
</BaseLayout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/css/glightbox.min.css" />
<script src="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/js/glightbox.min.js" defer></script>
<script src="/scripts/product-detail.js" defer></script>
