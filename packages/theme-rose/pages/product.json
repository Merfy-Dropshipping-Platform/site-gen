{
  "content": [
    {
      "type": "Header",
      "props": {
        "id": "Header-product",
        "siteTitle": "Мой магазин",
        "logo": "/logo.svg",
        "logoPosition": "top-left",
        "navigationLinks": [
          { "label": "Главная", "href": "/" },
          { "label": "Каталог", "href": "/catalog" },
          { "label": "О нас", "href": "/about" },
          { "label": "Контакты", "href": "/contacts" }
        ],
        "actionButtons": { "showSearch": "true", "showCart": "true", "showProfile": "true" }
      }
    },
    {
      "type": "Product",
      "props": {
        "id": "Product-1",
        "colorScheme": "scheme-2",
        "visualConfig": {
          "gallery": { "variant": "wrap-large", "showDiscountBadge": true },
          "variantsType": "chips",
          "counter": { "variant": "inline" },
          "showDescription": true
        },
        "padding": { "top": 40, "bottom": 80 }
      }
    },
    {
      "type": "PopularProducts",
      "props": {
        "id": "PopularProducts-product",
        "dataSource": "auto",
        "cards": 4,
        "heading": { "text": "Вам также может понравиться", "size": "small" },
        "colorScheme": "scheme-2",
        "productCard": { "buttonStyle": "primary", "cardStyle": "portrait", "columns": 4 },
        "padding": { "top": 80, "bottom": 80 }
      }
    },
    {
      "type": "Footer",
      "props": { "id": "Footer-product", "colorScheme": "scheme-2", "padding": { "top": 80, "bottom": 80 } }
    }
  ],
  "root": { "props": { "title": "Товар" } },
  "zones": {}
}
