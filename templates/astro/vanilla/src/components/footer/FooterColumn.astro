---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<div class="flex flex-col gap-[24px]">
	<h3 class="text-[20px] font-normal uppercase leading-[1.2] font-heading" style="color: rgb(var(--color-foreground));">
		{title}
	</h3>
	<div class="flex flex-col gap-[8px]">
		<slot />
	</div>
</div>
