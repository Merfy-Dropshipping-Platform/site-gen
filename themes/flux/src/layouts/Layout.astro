---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import CheckoutHeader from "../../../../packages/theme-base/blocks/CheckoutHeader/CheckoutHeader.astro";
import Footer from "../components/Footer.astro";
import NtCartDrawer from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtCartDrawer.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

interface Props {
	title?: string;
	description?: string;
	// "checkout" → минимальная шапка оформления (CheckoutHeader, Figma 1:13563);
	// build.service патчит бренд CheckoutHeader под мерчанта на сборке сайта.
	header?: "default" | "checkout";
	// promo=false → скрыть хардкод промо-полосу в Header (системные/account страницы,
	// паритет rose 577648f7/eb8c8bd3). Дефолт true — обычные страницы показывают промо.
	promo?: boolean;
}

const { title, description = SITE_DESCRIPTION, header = "default", promo = true } = Astro.props;
const pageTitle = title ? `${title} — ${SITE_TITLE}` : SITE_TITLE;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={pageTitle} description={description} />
	</head>
	<body class="antialiased bg-white">
		{header === "checkout" ? (
			<div class="color-scheme-2" style="--size-checkout-brand:24px;--size-checkout-brand-image:32px;">
				<CheckoutHeader siteTitle={SITE_TITLE} logoMode="text" logoImage={null} rightIcon="cart" accountLink="/account" backLink="/cart" cartLink="/cart" padding={{ top: 24, bottom: 24 }} />
			</div>
		) : (
			<Header promo={promo} />
		)}
		<main>
			<slot />
		</main>
		{/* Чекаут — без футера (header="checkout"), паритет с rose. */}
		{header !== "checkout" && <Footer />}
		<NtCartDrawer rootId="flux-cart-drawer-root" eventPrefix="flux:cart" />
		{/* Стор корзины (window.cartStore) — общий бэкенд-стор витрины (как rose
		    BaseLayout): quick-add в каталоге/Popular вызывает window.cartStore.addItem.
		    Без него /catalog не грузил cart-store.js → window.cartStore undefined →
		    «В корзину» не работало. Подключаем глобально на ВСЕХ страницах. */}
		<script is:inline type="module" src="/scripts/cart-store.js"></script>
		<script>
			import { initCartUI } from "../lib/cart";
			import { initAnimations } from "../lib/animations";
			import { initWishlistUI } from "../lib/wishlist";
			import { initAuthUI } from "../lib/auth";
			initCartUI();
			initAnimations();
			// Избранное (wishlist) — глобальный делегат сердец/бейджей, зеркало корзины.
			initWishlistUI();
			initAuthUI();

			// Регулярное оформление («Оформить» корзины/drawer, data-action=checkout)
			// сбрасывает express «Купить сейчас» (sessionStorage flux:buynow) — чтобы
			// чекаут показал корзину покупателя, а не залипший buy-now товар.
			document.addEventListener(
				"click",
				(e) => {
					const el = e.target as Element | null;
					if (el && el.closest("[data-action='checkout']")) {
						try { sessionStorage.removeItem("flux:buynow"); } catch (err) {}
					}
				},
				true,
			);

				// Корзина «Сайдбар»/«Страница» (--cart-type): перехват клика по иконке
				// (<button data-cart-open>) в capture-фазе, опережая bubble-обработчик
				// панели (DS NtCartDrawer). page → /cart (live: переход; превью: <a> →
				// nav-агент → postMessage navigate). drawer (дефолт) → панель открывается сама.
				document.addEventListener(
					"click",
					(e) => {
						const el = e.target as Element | null;
						if (!el || !el.closest("[data-cart-open]")) return;
						const cartType = getComputedStyle(document.documentElement)
							.getPropertyValue("--cart-type")
							.trim()
							.replace(/['"]/g, "");
						if (cartType !== "page") return;
						e.preventDefault();
						e.stopImmediatePropagation();
						if (window.self === window.top) {
							window.location.assign("/cart");
						} else {
							const a = document.createElement("a");
							a.href = "/cart";
							document.body.appendChild(a);
							a.click();
							a.remove();
						}
					},
					true,
				);
		</script>
	</body>
</html>
