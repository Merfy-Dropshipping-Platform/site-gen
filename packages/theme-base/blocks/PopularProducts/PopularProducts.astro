---
import type { PopularProductsProps } from './PopularProducts.puckConfig';
import { PopularProductsClasses as C } from './PopularProducts.classes';

interface Props extends PopularProductsProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  heading: headingProp,
  subtitle: subtitleProp,
  cards = 4,
  columns = 4,
  padding,
} = Astro.props as Props & { subtitle?: string };

// Constructor legacy schema writes heading as { text } and subtitle as
// { content }; accept both shapes so nothing renders as [object Object].
const heading = (() => {
  if (typeof headingProp === 'string') return headingProp || undefined;
  if (headingProp && typeof headingProp === 'object') {
    const h = headingProp as { text?: string };
    return h.text || undefined;
  }
  return undefined;
})();
const subtitle =
  (typeof subtitleProp === 'string' && subtitleProp) ||
  (() => {
    const t = raw.text;
    if (typeof t === 'string') return t;
    if (t && typeof t === 'object' && typeof (t as { content?: unknown }).content === 'string') {
      return (t as { content: string }).content;
    }
    return undefined;
  })();

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
const gridTemplateCols = `grid-template-columns: repeat(${columns}, minmax(0, 1fr));`;
// Demo product cards render for seed sites that don't yet have real products
// wired in. Live storefronts show 4 real cards — we emulate with demo
// content so preview visually matches Figma. When a site gets real products
// (dataSource: 'auto' resolved), the block should be replaced by a real
// product loader upstream; for now this is visual-parity scaffolding.
const DEMO_PRODUCTS = [
  { title: 'Сумка', price: '5 990 ₽', oldPrice: '' },
  { title: 'Сумка', price: '5 990 ₽', oldPrice: '' },
  { title: 'Сумка', price: '5 990 ₽', oldPrice: '' },
  { title: 'Сумка', price: '5 990 ₽', oldPrice: '7 990 ₽' },
];
const demo = DEMO_PRODUCTS.slice(0, Math.min(cards, DEMO_PRODUCTS.length));
---
<section
  class={C.root}
  data-puck-component-id={id}
  data-block="popular-products"
  style={paddingStyle}
>
  <div class={C.container}>
    {heading && <h2 class={C.heading}>{heading}</h2>}
    {subtitle && <p class={C.subtitle}>{subtitle}</p>}
    <div class={C.grid} style={gridTemplateCols}>
      {demo.map((p, i) => (
        <div
          class={C.card}
          aria-label="Товар"
          data-product-index={i}
        >
          <div class={C.cardMedia} aria-hidden="true">
            {p.oldPrice && <span class={C.cardBadge}>Скидка</span>}
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <polyline points="21,15 16,10 5,21" />
            </svg>
          </div>
          <div class="flex flex-col gap-1 items-start w-full">
            <div class={C.cardTitle}>{p.title}</div>
            <div class={C.cardPriceRow}>
              <div class={C.cardPrice}>{p.price}</div>
              {p.oldPrice && <div class={C.cardOldPrice}>{p.oldPrice}</div>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
