---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CatalogIsland from '../../components/react/CatalogIsland';

let collectionsData: any[] = [];
try {
  const mod = await import('../../data/collections.json');
  collectionsData = mod.default ?? [];
} catch {
  collectionsData = [];
}

export function getStaticPaths() {
  let cols: any[] = [];
  try {
    // Dynamic import not available in getStaticPaths, use fs
    cols = collectionsData;
  } catch {
    cols = [];
  }

  // Always generate at least a fallback path
  if (cols.length === 0) {
    return [{ params: { slug: '_placeholder' }, props: { collection: null } }];
  }

  return cols.map((c: any) => ({
    params: { slug: c.handle || c.id },
    props: { collection: c },
  }));
}

const { slug } = Astro.params;
const { collection } = Astro.props;

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};

const title = collection?.title ?? slug ?? 'Коллекция';
---
<BaseLayout title={`${title} — ${meta?.title ?? 'Мой сайт'}`} description={collection?.description ?? meta?.description}>
  <Header {...headerProps} />

  <main class="flex-1 w-full" style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));">
    <div class="max-w-[1320px] mx-auto px-4 sm:px-6 py-[75px]">
      <div class="text-center mb-10">
        <p class="mb-4 text-sm font-body" style="color: rgb(var(--color-muted));">
          <a href="/" class="hover:underline" style="color: rgb(var(--color-muted));">Главная</a>
          <span class="mx-1">/</span>
          <a href="/catalog" class="hover:underline" style="color: rgb(var(--color-muted));">Каталог</a>
          <span class="mx-1">/</span>
          {title}
        </p>
        <h1 class="text-4xl font-heading" style="color: rgb(var(--color-foreground));">{title}</h1>
        {collection?.description && (
          <p class="mt-3 font-body max-w-2xl mx-auto" style="color: rgb(var(--color-muted));">{collection.description}</p>
        )}
      </div>

    <CatalogIsland client:load collectionSlug={slug} showCollectionFilter={false} />
  </main>

  <Footer {...footerProps} />
</BaseLayout>
