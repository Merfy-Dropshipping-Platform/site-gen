---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import VanilaLogo from "../icons/VanilaLogo.astro";
import { SITE_TITLE } from "../consts";
import { getProductById } from "../data/products";

interface NavLink {
	label: string;
	href: string;
	match?: (url: URL) => boolean;
}

function pathnameBase(url: URL): string {
	const p = url.pathname.replace(/\/+$/, "");
	return p === "" ? "/" : p;
}

/** Активный раздел каталога на карточке товара */
function catalogNavFromProduct(url: URL): "textile" | "decor" | null {
	const p = pathnameBase(url);
	const m = p.match(/^\/products\/([^/]+)$/);
	if (!m?.[1]) return null;
	const product = getProductById(m[1]);
	return product?.collection === "Декор" ? "decor" : "textile";
}

const defaultNav: NavLink[] = [
	{
		label: "Текстиль",
		href: "/catalog/textile",
		match: (url) =>
			catalogNavFromProduct(url) === "textile" ||
			pathnameBase(url) === "/catalog" ||
			pathnameBase(url) === "/catalog/textile",
	},
	{
		label: "Декор",
		href: "/catalog/decor",
		match: (url) => catalogNavFromProduct(url) === "decor" || pathnameBase(url) === "/catalog/decor",
	},
	{ label: "История", href: "/about", match: (url) => pathnameBase(url).startsWith("/about") },
];

// ОЖИВЛЕНИЕ (Фаза B, объём bloom Header): канон-схема theme-base Header.puckConfig —
// siteTitle, navigationLinks, logo, logoPosition, activeLinkIndicator, stickiness,
// padding. Тело ниже — verbatim верстальщика; дефолтные ветки тернарников = прежним
// строкам байт-в-байт (цвета шапки → токены с пиксель-фоллбеком родных, MANNER §7).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустая строка (впрыск коэрсера live-пути) не должна гасить название магазина.
const siteTitle = typeof p.siteTitle === "string" && p.siteTitle.trim() ? p.siteTitle : SITE_TITLE;
const nav: NavLink[] =
	Array.isArray(p.navigationLinks) && p.navigationLinks.length > 0
		? p.navigationLinks.map((l: any) => ({ label: l.label ?? l.text ?? "", href: l.href ?? l.link ?? "/" }))
		: defaultNav;

// Канон logo (URL картинки; панель «Логотип» пишет в props.logo): непустая строка →
// <img> высотой var(--size-logo-width) (слайдер «Размер» канона задаёт высоту лого)
// в mobile И desktop. Дефолт = SVG-вордмарк VanilaLogo верстальщика (white-вариант):
// mobile h-6 (24px), desktop h-7 (28px) — фоллбеки токена = родные высоты.
const logo = typeof p.logo === "string" && p.logo.trim() ? p.logo : undefined;
const logoImgMobileCls = "h-[var(--size-logo-width,24px)] w-auto max-w-[76px] object-contain";
const logoImgDesktopCls = "h-[var(--size-logo-width,28px)] w-auto max-w-[160px] object-contain";

// Канон logoPosition: 'center-absolute' (canon-default из blockDefaults vanilla) И
// отсутствие / неизвестное значение → ЛИТЕРАЛ верстальщика (лого центр абсолютом,
// нав слева, иконки справа gap-5). Явный 'center-left' («Слева») → лого в поток в
// начало строки (justify-between раздаёт: лого слева, нав в центре, иконки справа).
// 'top-left' / 'top-center' → TWO-ROW layouts (NEW).
const logoPosition = typeof p.logoPosition === "string" ? p.logoPosition : "";
const logoLeft = logoPosition === "center-left";
const isTwoRow = logoPosition === "top-left" || logoPosition === "top-center";
const desktopLogoCls = logoLeft
	? "flex shrink-0 items-center text-white"
	: "absolute left-1/2 top-1/2 flex -translate-x-1/2 -translate-y-1/2 items-center text-white";

// Канон activeLinkIndicator: 'underline' (canon-default из blockDefaults vanilla) И
// отсутствие = литерал верстальщика (after:h-px белая полоска под активной ссылкой);
// явный 'none' снимает индикатор (desktop-полоску и полоску бургера).
const activeUnderline = p.activeLinkIndicator !== "none";

// Канон stickiness: шапка верстальщика НЕ sticky — 'none' / отсутствие = литерал.
// 'always' / 'scroll-up' → position:sticky inline-стилем (глобальный
// [data-vanilla-header]{position:relative} перебивается только inline);
// 'scroll-up' дополнительно прячет шапку при скролле вниз (паттерн rose/bloom):
// is:inline скрипт через data-атрибут, идемпотентность — data-hydrated.
const stickiness = typeof p.stickiness === "string" ? p.stickiness : "";
const isSticky = stickiness === "always" || stickiness === "scroll-up";
const rootCls =
	stickiness === "scroll-up"
		? "flex w-full flex-col transition-transform duration-300"
		: "flex w-full flex-col";
const stickyStyle = isSticky ? "position:sticky;top:0;z-index:50;" : undefined;
const SCROLL_UP_JS = [
	"(function(){",
	"var root=document.querySelector('[data-vanilla-sticky=\"scroll-up\"]');",
	"if(!root||root.getAttribute('data-hydrated')==='true')return;",
	"root.setAttribute('data-hydrated','true');",
	"var last=window.scrollY;",
	"window.addEventListener('scroll',function(){",
	"var y=window.scrollY;",
	"if(y>last&&y>root.offsetHeight){root.style.transform='translateY(-100%)';}else{root.style.transform='';}",
	"last=y;",
	"},{passive:true});",
	"})();",
].join("");

// Канон padding {top,bottom} — clamp ≤64 на носителе высоты верстальщика
// (desktop-ряд h-20; мобильная строка h-14 фиксированная). {32,32} = canon-default
// blockDefaults vanilla (его же пишет seed) → ЛИТЕРАЛ h-20 (32+28 ≈ те же 80px);
// иное значение снимает h-20 и ведёт высоту inline-отступами.
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const isCanonPad = pad && Number(pad.top) === 32 && Number(pad.bottom) === 32;
const headerPad =
	pad && !isCanonPad
		? { top: Math.min(Number(pad.top) || 0, 64), bottom: Math.min(Number(pad.bottom) || 0, 64) }
		: undefined;
const headerPadStyle = headerPad
	? `padding-top:${headerPad.top}px;padding-bottom:${headerPad.bottom}px;`
	: undefined;
const desktopWrapCls = isTwoRow
	? (headerPad
		? "vanilla-pad relative mx-auto hidden w-full max-w-[1560px] flex-col md:flex min-[1920px]:max-w-[1920px] min-[1920px]:px-[300px]"
		: "vanilla-pad relative mx-auto hidden w-full max-w-[1560px] flex-col py-5 md:flex min-[1920px]:max-w-[1920px] min-[1920px]:px-[300px]")
	: (headerPad
		? "vanilla-pad relative mx-auto hidden w-full max-w-[1560px] items-center justify-between md:flex min-[1920px]:max-w-[1920px] min-[1920px]:px-[300px]"
		: "vanilla-pad relative mx-auto hidden h-20 w-full max-w-[1560px] items-center justify-between md:flex min-[1920px]:max-w-[1920px] min-[1920px]:px-[300px]");

// Канон menuType: 'dropdown' (по умолчанию) / 'mega-menu' (Расширенное) / 'sidebar' (Боковое).
// Для mega-menu добавляем uppercase + tracking к десктопным ссылкам нав-меню.
// Для sidebar — десктопный inline-nav скрыт, показывается hamburger → правая шторка.
const menuType = typeof p.menuType === "string" ? p.menuType : "dropdown";
const isMegaMenu = menuType === "mega-menu";
const isSidebar = menuType === "sidebar";
const megaLinkCls = isMegaMenu ? "uppercase tracking-[0.06em] font-medium" : "";

// Канон menuColorScheme: опциональная отдельная цветовая схема для десктопного <nav>.
// При задании — добавляем класс color-scheme-<X> к обёртке <nav>.
const menuColorScheme = typeof p.menuColorScheme === "string" ? p.menuColorScheme : "";
const menuSchemeClass = menuColorScheme ? `color-scheme-${menuColorScheme.replace("scheme-", "")}` : "";

const catalogSearchAction = pathnameBase(Astro.url) === "/catalog/decor" ? "/catalog/decor" : "/catalog/textile";

const isActive = (link: NavLink) => (link.match ? link.match(Astro.url) : Astro.url.pathname === link.href);
---

<div
	class={rootCls}
	data-vanilla-header
	data-puck-component-id={id}
	data-vanilla-sticky={stickiness === "scroll-up" ? "scroll-up" : undefined}
	style={stickyStyle}
>
	{
		/* Встроенная полоса объявления — ТОЛЬКО статик-режим (без props.id):
		   в канон-композиции полоса = отдельная секция PromoBanner, иначе дубль. */
		!id && (
			<a
				href="/catalog/textile"
				data-vanilla-announcement
				class="m-0 flex h-11 w-full shrink-0 items-center justify-center border-0 bg-[var(--vanilla-announcement-bg)] px-4 text-center font-vanilla-arsenal text-[14px] font-normal uppercase leading-none tracking-normal text-white md:h-12 md:text-base"
			>
				<span class="min-w-0 shrink">Бесплатная доставка на весь ассортимент</span>
			</a>
		)
	}

	<header class="relative m-0 shrink-0 border-0 w-full overflow-visible bg-[rgb(var(--color-bg,58_69_48))] pb-[3px] -mb-[3px] text-[rgb(var(--color-text,255_255_255))]" data-nt="vanilla-header">
		<div class="relative z-[60] flex h-14 items-center justify-between px-4 md:hidden">
			<button
				type="button"
				id="vanilla-burger-btn"
				data-burger-toggle
				class="flex size-9 items-center justify-center transition-opacity hover:opacity-70"
				aria-label="Меню"
				aria-expanded="false"
				aria-controls="vanilla-burger"
			>
				<span class="burger-icon" data-icon="open">
					<NtIcon name="menu-burger" sizeClass="size-6" class="brightness-0 invert" />
				</span>
				<span class="burger-icon hidden" data-icon="close">
					<NtIcon name="menu-close" sizeClass="size-6" class="brightness-0 invert" />
				</span>
			</button>
			<a href="/" class="flex shrink-0 items-center text-white" aria-label={siteTitle}>
				{logo ? <img src={logo} alt={siteTitle} class={logoImgMobileCls} /> : <VanilaLogo class="h-6 w-auto max-w-[76px]" />}
			</a>
			<div class="flex items-center gap-3">
				<button
					type="button"
					data-action="toggle-search"
					class="flex size-6 items-center justify-center"
					aria-label="Поиск"
					aria-expanded="false"
					aria-controls="vanilla-search-panel"
				>
					<NtIcon name="search-sm" sizeClass="size-6" class="brightness-0 invert" />
				</button>
				<a
					href="/wishlist"
					class="relative flex size-6 items-center justify-center transition-opacity hover:opacity-80"
					aria-label="Избранное"
				>
					<NtIcon name="favourite" sizeClass="size-4" class="brightness-0 invert" />
					<span
						data-wishlist-count
						data-empty="true"
						class="absolute -right-2 -top-2 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-white px-1 font-manrope text-[10px] font-normal leading-none text-[var(--vanilla-dark)] data-[empty=true]:hidden"
					>0</span>
				</a>
				<a
					href="/cart"
					class="relative flex size-6 items-center justify-center"
					aria-label="Корзина"
				>
					<NtIcon name="cart-sm" sizeClass="size-4" class="brightness-0 invert" />
					<span
						data-cart-count
						data-empty="true"
						class="absolute -right-2 -top-2 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-white px-1 font-manrope text-[10px] font-normal leading-none text-[var(--vanilla-dark)] data-[empty=true]:hidden"
					>0</span>
				</a>
				<button
					type="button"
					data-login-open
					class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
					aria-label="Аккаунт"
					aria-haspopup="dialog"
				>
					<NtIcon name="user-sm" sizeClass="size-4" class="brightness-0 invert" />
				</button>
			</div>
		</div>

		<div class={desktopWrapCls} style={headerPadStyle}>
			{isTwoRow ? (
				/* ── TWO-ROW LAYOUTS: top-left / top-center ── */
				logoPosition === "top-left" ? (
					/* top-left: Row1=[logo LEFT + actions RIGHT], Row2=[nav LEFT] */
					<>
						<div class="flex w-full items-center justify-between">
							<a href="/" class="flex shrink-0 items-center text-white" aria-label={siteTitle}>
								{logo ? <img src={logo} alt={siteTitle} class={logoImgDesktopCls} /> : <VanilaLogo class="h-7 w-[89px]" />}
							</a>
							<div class="flex items-center gap-5">
								<button
									type="button"
									data-action="toggle-search"
									class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Поиск"
									aria-expanded="false"
									aria-controls="vanilla-search-panel"
								>
									<NtIcon name="search-lg" sizeClass="size-5" class="brightness-0 invert" />
								</button>
								<a
									href="/wishlist"
									class="relative flex size-6 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Избранное"
								>
									<NtIcon name="favourite" sizeClass="size-5" class="brightness-0 invert" />
									<span
										data-wishlist-count
										data-empty="true"
										class="absolute -right-1 -top-1 inline-flex h-5 min-w-[20px] items-center justify-center rounded-full bg-white px-1.5 font-manrope text-[10px] font-bold leading-none text-[var(--vanilla-dark)] data-[empty=true]:hidden"
									>0</span>
								</a>
								<a
									href="/cart"
									class="relative flex size-6 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Корзина"
								>
									<NtIcon name="cart" sizeClass="size-5" class="brightness-0 invert" />
									<span
										data-cart-count
										data-empty="true"
										class="absolute -right-1 -top-1 inline-flex h-5 min-w-[20px] items-center justify-center rounded-full bg-white px-1.5 font-manrope text-[10px] font-bold leading-none text-[var(--vanilla-dark)] data-[empty=true]:hidden"
									>0</span>
								</a>
								<button
									type="button"
									data-login-open
									class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Аккаунт"
									aria-haspopup="dialog"
								>
									<NtIcon name="user" sizeClass="size-5" class="brightness-0 invert" />
								</button>
								{isSidebar && (
									<button
										type="button"
										data-burger-toggle
										class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
										aria-label="Меню"
										aria-expanded="false"
										aria-controls="vanilla-burger"
									>
										<span class="burger-icon" data-icon="open">
											<NtIcon name="menu-burger" sizeClass="size-5" class="brightness-0 invert" />
										</span>
										<span class="burger-icon hidden" data-icon="close">
											<NtIcon name="menu-close" sizeClass="size-5" class="brightness-0 invert" />
										</span>
									</button>
								)}
							</div>
						</div>
						<nav
							class:list={["mt-3 flex w-full items-center justify-start gap-[40px]", menuSchemeClass, isSidebar && "md:!hidden"]}
							aria-label="Основная навигация"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="997"
							data-puck-subsection-field="navigationLinks"
						>
							{nav.map((link) => {
								const active = isActive(link);
								return (
									<a
										href={link.href}
										aria-current={active ? "page" : undefined}
										class:list={[
											"relative pb-1 font-vanilla-arsenal text-base font-normal leading-none tracking-normal text-[rgb(var(--color-text,255_255_255))] transition-all duration-200 hover:opacity-70",
											active &&
												activeUnderline &&
												"after:pointer-events-none after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-[rgb(var(--color-text,255_255_255))] after:content-['']",
											megaLinkCls,
										]}
									>
										{link.label}
									</a>
								);
							})}
						</nav>
					</>
				) : (
					/* top-center: Row1=[search LEFT | logo CENTER | cart+user RIGHT], Row2=[nav CENTER] */
					<>
						<div class="grid w-full grid-cols-[1fr_auto_1fr] items-center">
							<div class="flex items-center">
								<button
									type="button"
									data-action="toggle-search"
									class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Поиск"
									aria-expanded="false"
									aria-controls="vanilla-search-panel"
								>
									<NtIcon name="search-lg" sizeClass="size-5" class="brightness-0 invert" />
								</button>
							</div>
							<div class="flex items-center justify-center">
								<a href="/" class="flex items-center text-white" aria-label={siteTitle}>
									{logo ? <img src={logo} alt={siteTitle} class={logoImgDesktopCls} /> : <VanilaLogo class="h-7 w-[89px]" />}
								</a>
							</div>
							<div class="flex items-center justify-end gap-5">
								<a
									href="/wishlist"
									class="relative flex size-6 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Избранное"
								>
									<NtIcon name="favourite" sizeClass="size-5" class="brightness-0 invert" />
									<span
										data-wishlist-count
										data-empty="true"
										class="absolute -right-1 -top-1 inline-flex h-5 min-w-[20px] items-center justify-center rounded-full bg-white px-1.5 font-manrope text-[10px] font-bold leading-none text-[var(--vanilla-dark)] data-[empty=true]:hidden"
									>0</span>
								</a>
								<a
									href="/cart"
									class="relative flex size-6 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Корзина"
								>
									<NtIcon name="cart" sizeClass="size-5" class="brightness-0 invert" />
									<span
										data-cart-count
										data-empty="true"
										class="absolute -right-1 -top-1 inline-flex h-5 min-w-[20px] items-center justify-center rounded-full bg-white px-1.5 font-manrope text-[10px] font-bold leading-none text-[var(--vanilla-dark)] data-[empty=true]:hidden"
									>0</span>
								</a>
								<button
									type="button"
									data-login-open
									class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Аккаунт"
									aria-haspopup="dialog"
								>
									<NtIcon name="user" sizeClass="size-5" class="brightness-0 invert" />
								</button>
								{isSidebar && (
									<button
										type="button"
										data-burger-toggle
										class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
										aria-label="Меню"
										aria-expanded="false"
										aria-controls="vanilla-burger"
									>
										<span class="burger-icon" data-icon="open">
											<NtIcon name="menu-burger" sizeClass="size-5" class="brightness-0 invert" />
										</span>
										<span class="burger-icon hidden" data-icon="close">
											<NtIcon name="menu-close" sizeClass="size-5" class="brightness-0 invert" />
										</span>
									</button>
								)}
							</div>
						</div>
						<nav
							class:list={["mt-3 flex w-full items-center justify-center gap-[40px]", menuSchemeClass, isSidebar && "md:!hidden"]}
							aria-label="Основная навигация"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="997"
							data-puck-subsection-field="navigationLinks"
						>
							{nav.map((link) => {
								const active = isActive(link);
								return (
									<a
										href={link.href}
										aria-current={active ? "page" : undefined}
										class:list={[
											"relative pb-1 font-vanilla-arsenal text-base font-normal leading-none tracking-normal text-[rgb(var(--color-text,255_255_255))] transition-all duration-200 hover:opacity-70",
											active &&
												activeUnderline &&
												"after:pointer-events-none after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-[rgb(var(--color-text,255_255_255))] after:content-['']",
											megaLinkCls,
										]}
									>
										{link.label}
									</a>
								);
							})}
						</nav>
					</>
				)
			) : (
				/* ── SINGLE-ROW LAYOUTS: center-left / center-absolute ── */
				<>
					<a
						href="/"
						class={desktopLogoCls}
						aria-label={siteTitle}
					>
						{logo ? <img src={logo} alt={siteTitle} class={logoImgDesktopCls} /> : <VanilaLogo class="h-7 w-[89px]" />}
					</a>

					<nav
						class:list={["flex items-center gap-[40px]", menuSchemeClass, isSidebar && "md:!hidden"]}
						aria-label="Основная навигация"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="997"
						data-puck-subsection-field="navigationLinks"
					>
						{nav.map((link) => {
							const active = isActive(link);
							return (
								<a
									href={link.href}
									aria-current={active ? "page" : undefined}
									class:list={[
										"relative pb-1 font-vanilla-arsenal text-base font-normal leading-none tracking-normal text-[rgb(var(--color-text,255_255_255))] transition-all duration-200 hover:opacity-70",
										active &&
											activeUnderline &&
											"after:pointer-events-none after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-[rgb(var(--color-text,255_255_255))] after:content-['']",
										megaLinkCls,
									]}
								>
									{link.label}
								</a>
							);
						})}
					</nav>

					<div class="flex items-center gap-5">
						<button
							type="button"
							data-action="toggle-search"
							class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
							aria-label="Поиск"
							aria-expanded="false"
							aria-controls="vanilla-search-panel"
						>
							<NtIcon name="search-lg" sizeClass="size-5" class="brightness-0 invert" />
						</button>
						<a
							href="/wishlist"
							class="relative flex size-6 items-center justify-center transition-opacity hover:opacity-80"
							aria-label="Избранное"
						>
							<NtIcon name="favourite" sizeClass="size-5" class="brightness-0 invert" />
							<span
								data-wishlist-count
								data-empty="true"
								class="absolute -right-1 -top-1 inline-flex h-5 min-w-[20px] items-center justify-center rounded-full bg-white px-1.5 font-manrope text-[10px] font-bold leading-none text-[var(--vanilla-dark)] data-[empty=true]:hidden"
							>0</span>
						</a>
						<a
							href="/cart"
							class="relative flex size-6 items-center justify-center transition-opacity hover:opacity-80"
							aria-label="Корзина"
						>
							<NtIcon name="cart" sizeClass="size-5" class="brightness-0 invert" />
							<span
								data-cart-count
								data-empty="true"
								class="absolute -right-1 -top-1 inline-flex h-5 min-w-[20px] items-center justify-center rounded-full bg-white px-1.5 font-manrope text-[10px] font-bold leading-none text-[var(--vanilla-dark)] data-[empty=true]:hidden"
							>0</span>
						</a>
						<button
							type="button"
							data-login-open
							class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
							aria-label="Аккаунт"
							aria-haspopup="dialog"
						>
							<NtIcon name="user" sizeClass="size-5" class="brightness-0 invert" />
						</button>
						{isSidebar && (
							<button
								type="button"
								data-burger-toggle
								class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
								aria-label="Меню"
								aria-expanded="false"
								aria-controls="vanilla-burger"
							>
								<span class="burger-icon" data-icon="open">
									<NtIcon name="menu-burger" sizeClass="size-5" class="brightness-0 invert" />
								</span>
								<span class="burger-icon hidden" data-icon="close">
									<NtIcon name="menu-close" sizeClass="size-5" class="brightness-0 invert" />
								</span>
							</button>
						)}
					</div>
				</>
			)}
		</div>

		<!-- Поиск: как в rose-theme — выезжает вниз по клику (1320×48), кнопка в цвете Vanilla -->
			<div
			id="vanilla-search-panel"
			data-search-panel
			class="pointer-events-none absolute left-0 right-0 top-full z-40 w-full overflow-hidden bg-transparent transition-[max-height] duration-300 ease-in-out"
			style="max-height: 0;"
			aria-hidden="true"
		>
			<div class="vanilla-pad py-2 lg:py-2">
				<form
					role="search"
					action={catalogSearchAction}
					method="get"
					class="pointer-events-auto mx-auto flex h-12 w-full max-w-[1320px] items-center gap-2 rounded-[4px] border border-[#E5E5E5] bg-white pl-3 pr-1 shadow-[0_8px_24px_rgba(0,0,0,0.08)]"
				>
					<input
						id="vanilla-site-search-input"
						type="search"
						name="q"
						placeholder="Поиск..."
						aria-label="Поиск"
						class="min-h-0 min-w-0 flex-1 bg-transparent py-1 font-manrope text-[16px] font-light leading-normal text-[#000000] placeholder:text-[#999999] outline-none"
					/>
					<button
						type="submit"
						class="flex h-10 shrink-0 items-center justify-center rounded-[4px] border-0 bg-[var(--vanilla-header-bg)] px-3 py-2.5 font-manrope text-[14px] font-normal leading-none text-white transition-opacity hover:opacity-90"
					>
						Найти
					</button>
				</form>
			</div>
		</div>
	</header>

	<!-- Мобильный бургер / Desktop sidebar drawer -->
	<div
		id="vanilla-burger"
		class:list={[
			"fixed z-[55] hidden overflow-y-auto bg-[var(--vanilla-surface)]",
			isSidebar
				? "inset-y-0 right-0 bottom-0 w-[360px] max-w-[90vw] px-6 pt-6 pb-8"
				: "inset-x-0 bottom-0 w-full px-4 pb-8 pt-4 md:hidden",
		]}
		role="dialog"
		aria-modal="true"
		aria-label="Меню"
	>
		{isSidebar ? (
			/* Sidebar drawer: logo + cart at top */
			<div class="flex items-center justify-between">
				<a href="/" class="flex shrink-0 items-center text-white" aria-label={siteTitle}>
					{logo ? <img src={logo} alt={siteTitle} class={logoImgMobileCls} /> : <VanilaLogo class="h-6 w-auto max-w-[76px]" />}
				</a>
				<a
					href="/wishlist"
					class="relative mr-3 flex size-6 shrink-0 items-center justify-center transition-opacity hover:opacity-80"
					aria-label="Избранное"
				>
					<NtIcon name="favourite" sizeClass="size-4" class="brightness-0" />
					<span
						data-wishlist-count
						data-empty="true"
						class="absolute -right-2 -top-2 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[var(--vanilla-header-bg)] px-1 font-manrope text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
					>0</span>
				</a>
				<a
					href="/cart"
					class="relative flex size-6 shrink-0 items-center justify-center transition-opacity hover:opacity-80"
					aria-label="Корзина"
				>
					<NtIcon name="cart-sm" sizeClass="size-4" class="brightness-0" />
					<span
						data-cart-count
						data-empty="true"
						class="absolute -right-2 -top-2 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-white px-1 font-manrope text-[10px] font-normal leading-none text-[var(--vanilla-dark)] data-[empty=true]:hidden"
					>0</span>
				</a>
			</div>
		) : (
			/* Mobile drawer: search + profile */
			<div class="flex items-center gap-2">
				<form
					class="flex h-10 min-h-10 flex-1 items-center justify-between rounded-[4px] border border-[var(--vanilla-line)] bg-white pl-3 pr-2"
					role="search"
					action={catalogSearchAction}
					method="get"
				>
					<input
						type="search"
						name="q"
						placeholder="Поиск"
						class="min-w-0 flex-1 bg-transparent font-manrope text-[12px] font-normal leading-normal text-[var(--vanilla-dark)] placeholder:text-[var(--vanilla-muted)] outline-none"
					/>
					<button type="submit" class="flex size-10 shrink-0 items-center justify-center" aria-label="Найти">
						<NtIcon name="search-sm" sizeClass="size-6" />
					</button>
				</form>
				<button
					type="button"
					data-login-open
					class="flex size-10 shrink-0 items-center justify-center bg-[var(--vanilla-green)] transition-opacity hover:opacity-90"
					aria-label="Профиль"
					aria-haspopup="dialog"
				>
					<NtIcon name="user" sizeClass="size-6" class="brightness-0 invert" />
				</button>
			</div>
		)}

		<nav class="mt-10 flex flex-col gap-5" aria-label="Основное меню">
			{nav.map((link) => {
				const active = isActive(link);
				return (
					<div class="flex flex-col gap-1">
						<a
							href={link.href}
							class:list={[
								"text-[14px] font-normal leading-normal transition-colors",
								active ? "text-[var(--vanilla-green)]" : "text-[var(--vanilla-muted)] hover:text-[var(--vanilla-green)]",
							]}
						>
							{link.label}
						</a>
						{active && activeUnderline && <div class="h-px w-[54px] bg-[var(--vanilla-header-bg)]" aria-hidden="true"></div>}
					</div>
				);
			})}
			<a href="/cart" class="text-[14px] font-normal leading-normal text-[var(--vanilla-muted)]">Корзина</a>
			<a href="/register" class="text-[14px] font-normal leading-normal text-[var(--vanilla-muted)]">Регистрация</a>
		</nav>
	</div>

	{stickiness === "scroll-up" && <script is:inline set:html={SCROLL_UP_JS} />}
</div>

<script>
	const headerOffsetBelowPromo = () => {
		const promo = document.querySelector<HTMLElement>("[data-vanilla-announcement]");
		const headerEl = document.querySelector<HTMLElement>('[data-nt="vanilla-header"]');
		const p = promo?.offsetHeight ?? 48;
		const h = headerEl?.offsetHeight ?? 80;
		return p + h;
	};

	const positionBurger = () => {
		const burger = document.getElementById("vanilla-burger");
		if (!burger) return;
		burger.style.top = `${headerOffsetBelowPromo()}px`;
	};

	const setSearchOpen = (open: boolean) => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel) return;
		panel.setAttribute("aria-hidden", String(!open));
		if (open) {
			panel.style.maxHeight = `${panel.scrollHeight}px`;
			queueMicrotask(() => {
				panel.querySelector<HTMLInputElement>("input[type='search']")?.focus();
			});
		} else {
			panel.style.maxHeight = "0px";
		}
		document.querySelectorAll<HTMLElement>("[data-action='toggle-search']").forEach((btn) => {
			btn.setAttribute("aria-expanded", String(open));
		});
	};

	const isSearchPanelOpen = () => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel) return false;
		const h = panel.style.maxHeight;
		return Boolean(h && h !== "0px" && h !== "0");
	};

	const syncSearchPanelHeight = () => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel || !isSearchPanelOpen()) return;
		panel.style.maxHeight = `${panel.scrollHeight}px`;
	};

	const isSidebarDrawer = () => {
		const burger = document.getElementById("vanilla-burger");
		// Sidebar right-panel has inset-y-0 — detect via right-side positioning
		return burger ? burger.classList.contains("inset-y-0") : false;
	};

	const syncBurgerButtonIcons = (open: boolean) => {
		// Update ALL burger toggle buttons (mobile #vanilla-burger-btn + desktop [data-burger-toggle])
		document.querySelectorAll<HTMLElement>("[data-burger-toggle]").forEach((burgerBtn) => {
			burgerBtn.setAttribute("aria-expanded", String(open));
			burgerBtn.querySelectorAll<HTMLElement>(".burger-icon").forEach((el) => {
				const key = el.dataset.icon;
				if (key === "open") el.classList.toggle("hidden", open);
				else el.classList.toggle("hidden", !open);
			});
		});
	};

	const setBurger = (open: boolean) => {
		const burger = document.getElementById("vanilla-burger");
		if (!burger) return;
		if (open) setSearchOpen(false);
		burger.classList.toggle("hidden", !open);
		syncBurgerButtonIcons(open);
		document.body.style.overflow = open ? "hidden" : "";
		// positionBurger only for mobile bottom-sheet (not right-side panel)
		if (open && !isSidebarDrawer()) positionBurger();
	};

	const syncHeaderChromeAfterNavigation = () => {
		document.body.style.overflow = "";
		window.dispatchEvent(new CustomEvent("vanilla:login:close"));
		setSearchOpen(false);
		const burgerEl = document.getElementById("vanilla-burger");
		if (burgerEl) burgerEl.classList.add("hidden");
		syncBurgerButtonIcons(false);
		if (!isSidebarDrawer()) positionBurger();
	};

	let headerDelegatesBound = false;
	const bindHeaderDelegatedClicks = () => {
		if (headerDelegatesBound) return;
		headerDelegatesBound = true;

		document.addEventListener(
			"click",
			(event: MouseEvent) => {
				const raw = event.target;
				const el = raw instanceof Element ? raw : null;
				if (!el?.closest("[data-login-open]")) return;
				setSearchOpen(false);
				setBurger(false);
			},
			true
		);

		document.addEventListener("click", (event: MouseEvent) => {
			const raw = event.target;
			const el = raw instanceof Element ? raw : null;
			if (!el) return;

			if (el.closest("[data-burger-toggle]")) {
				const b = document.getElementById("vanilla-burger");
				if (!b) return;
				event.preventDefault();
				setBurger(b.classList.contains("hidden"));
				return;
			}

			if (el.closest("[data-action='toggle-search']")) {
				event.preventDefault();
				event.stopPropagation();
				const willOpen = !isSearchPanelOpen();
				const burger = document.getElementById("vanilla-burger");
				if (willOpen && burger && !burger.classList.contains("hidden")) {
					setBurger(false);
				}
				setSearchOpen(willOpen);
				return;
			}

			if (el.closest("#vanilla-burger a[href]")) {
				setBurger(false);
			}
		});

		document.addEventListener("click", (event: MouseEvent) => {
			if (!isSearchPanelOpen()) return;
			const target = event.target;
			if (!(target instanceof Node)) return;
			const panel = document.querySelector<HTMLElement>("[data-search-panel]");
			if (panel?.contains(target)) return;
			const tEl = target instanceof Element ? target : null;
			if (tEl?.closest?.("[data-action='toggle-search']")) return;
			setSearchOpen(false);
		});

		window.addEventListener("resize", () => {
			syncSearchPanelHeight();
			positionBurger();
		});
	};

	bindHeaderDelegatedClicks();
	document.addEventListener("astro:page-load", syncHeaderChromeAfterNavigation);
	syncHeaderChromeAfterNavigation();
</script>
