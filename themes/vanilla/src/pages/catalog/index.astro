---
import Layout from "../../layouts/Layout.astro";
import VanillaCatalogSection from "../../components/catalog/VanillaCatalogSection.astro";

// Реальная страница /catalog (раньше был JS-редирект на /catalog/textile).
// Нужна как настоящий шелл (Layout → Header+Footer → есть </footer>), чтобы
// конструктор нарезал её на выделяемые Puck-секции, а live-сборка пересаживала
// сюда блоки ревизии (catalog out of V2_COMPLEX_ROUTE_PREFIXES, page-catalog в
// CONTENT_PAGES). Category-подстраницы /catalog/textile и /catalog/decor остаются.
// Без section VanillaCatalogSection показывает весь демо-каталог; на live сетку
// перерисовывает гидрация реальных товаров.
---

<Layout title="Каталог" description="Каталог Vanilla — все товары магазина">
	<VanillaCatalogSection categoryTitle="Каталог" />
</Layout>
