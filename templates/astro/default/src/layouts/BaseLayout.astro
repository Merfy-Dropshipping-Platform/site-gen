---
import data from '../data/data.json';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Мой магазин', description } = Astro.props;
const meta = data?.meta ?? {};
const shopId = (meta as any)?.shopId || '';
const apiUrl = (meta as any)?.apiUrl || 'https://gateway.merfy.ru/api';
---
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <style>
      :root { font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; color: #0f172a; background: #f8fafc; }
      body { margin: 0; padding: 0; }
      main { max-width: 960px; margin: 0 auto; padding: 32px 16px 64px; }
    </style>
  </head>
  <body>
    <slot />
    <script is:inline define:vars={{ shopId, apiUrl }}>
      window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
        shopId: shopId || '',
        apiUrl: apiUrl || 'https://gateway.merfy.ru/api',
      };
    </script>
  </body>
</html>
