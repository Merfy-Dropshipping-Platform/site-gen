---
import {
	normalizeRoseSlidePosition,
	roseSlideshowHeightClass,
} from "../../lib/section-settings";
import { inlineFormat } from "../../lib/rich-text";

// Фаза 3 (T17): новая канон-секция Slideshow в манере rose (см. themes/rose/MANNER.md).
// Схема полей = packages/theme-base/blocks/Slideshow/Slideshow.puckConfig.ts.
// Композиция = hero-полотно манеры: фон-фото, белый текст лестницей героя §1,
// белая CTA героя §3, плавный fade (манера hero-animate). Параметры скрипту —
// ТОЛЬКО data-атрибуты (define:vars компилятором секций не поддерживается);
// идемпотентность — data-slideshow-hydrated (паттерн плана Фазы 3 Task 17).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон slides[] 1-5 (item: imageUrl|image, heading(string|{text,size}), subtitle,
// text{content,size}, ctaText/ctaUrl | button{text,link}, container, position,
// alignment, colorScheme).
//
// Figma 1:19335 — ПУСТОЕ состояние секции «Слайд-шоу». Пока мерчант НЕ добавил
// слайды (slides пуст), секция показывает ДОСЛОВНЫЙ Figma-плейсхолдер: один слайд
// с дизайн-ассетом /placeholders/landscape-slideshow.png + заголовок «Слайд-шоу» +
// хелпер «Добавь несколько изображений с информацией о своём бренде» + кнопка
// «Кнопка» + точки навигации. Ассет раздаётся на каждой теме из
// packages/theme-base/public/placeholders (copyPublic) — НЕ пустая surface и НЕ
// мок-контент верстальщика (прежние 3 слайда-болванки «Первый/Второй/Третий слайд»
// с кнопками «Подробнее/Смотреть/Купить») — он удалён. Когда слайды ЗАДАНЫ —
// рендерим их (поведение ниже не меняется).
const PLACEHOLDER_SLIDE_IMAGE = "/placeholders/landscape-slideshow.png";
const PLACEHOLDER_SLIDES = [
	{
		id: "slide-placeholder",
		// Figma 1236-42150: imageUrl пуст → маппинг ниже пометит слайд как isPromptCard,
		// сам подставит PLACEHOLDER_SLIDE_IMAGE фоном и включит белую карточку (boxed).
		imageUrl: "",
		heading: "Слайд-шоу",
		subtitle: "Добавь несколько изображений с информацией о своём бренде",
		ctaText: "Кнопка",
		ctaUrl: "/catalog",
	},
];
const hasSlides = Array.isArray(p.slides) && p.slides.length > 0;
const rawSlides = hasSlides ? p.slides : PLACEHOLDER_SLIDES;
const hasOwn = (value: unknown, key: string) =>
	!!value && typeof value === "object" && Object.prototype.hasOwnProperty.call(value, key);
const resolveSlideLink = (value: unknown) => {
	if (typeof value === "string") return value;
	if (value && typeof value === "object" && typeof (value as { href?: unknown }).href === "string") {
		return (value as { href: string }).href;
	}
	return undefined;
};

// Заголовок слайда — лестница героя (20→28→36→40); size small ≈0.85, large ≈1.2.
const slideHeadingCls = (s: string | undefined) =>
	s === "small"
		? "text-[17px] sm:text-[24px] md:text-[31px] lg:text-[34px]"
		: s === "large"
			? "text-[24px] sm:text-[34px] md:text-[43px] lg:text-[48px]"
			: "text-[20px] sm:text-[28px] md:text-[36px] lg:text-[40px]";

// Текст слайда — параллельная лестница; small ≈0.85, large ≈1.2 (раньше per-slide
// «Текст→Размер» рендером ИГНОРИРОВАЛСЯ — размер подзаголовка был захардкожен).
const slideTextCls = (s: string | undefined) =>
	s === "small"
		? "text-[12px] sm:text-[14px] md:text-[16px] lg:text-[17px]"
		: s === "large"
			? "text-[16px] sm:text-[19px] md:text-[22px] lg:text-[24px]"
			: "text-[14px] sm:text-[16px] md:text-[18px] lg:text-[20px]";

// Figma 1:19335: слайд пустого состояния несёт дизайн-ассет landscape-slideshow.png
// (PLACEHOLDER_SLIDES выше). Реальный слайд мерчанта без фото = ПУСТАЯ surface-карточка
// (рендер ниже: `s.image ? <img> : <div bg-surface>`), а НЕ мок-ассет верстальщика
// (/images/*.webp). Прежний массив SLIDE_FALLBACKS (мок-картинки по позиции) удалён.

// Per-slide раскладка = мини-Hero (паттерн Hero.astro). Каждый слайд несёт
// position (РАЗМЕЩЕНИЕ блока по сетке 3×3) + alignment (выравнивание КОНТЕНТА
// внутри блока, независимо) + container (плашка-подложка boxed).
//   Позиция: вертикаль top / center(=середина) / bottom; горизонталь left/center/
//   right. Пустой/невалидный проп = безопасный legacy fallback center.
//   defaultItemProps пишет position:'center' → дефолтный слайд = середина-центр.
//   Legacy left/right (3-опционная схема) → center-left/center-right.
const slideLayoutCls = (s: any) => {
	const norm = normalizeRoseSlidePosition(s.position);
	const vPos = norm.startsWith("top")
		? "top"
		: norm.startsWith("bottom")
			? "bottom"
			: norm === "center" || norm.startsWith("center")
				? "middle"
				: "middle";
	const hPos = norm.endsWith("left") ? "left" : norm.endsWith("right") ? "right" : "center";
	// Внешний контейнер слайда: vJustify = вертикаль (justify-* при flex-col),
	// hItems = горизонталь (items-*).
	const vJustifyCls = vPos === "top" ? "justify-start" : vPos === "middle" ? "justify-center" : "justify-end";
	const hItemsCls =
		hPos === "left"
			? "items-start"
			: hPos === "right"
				? "items-end"
				: "items-center";
	// alignment — НЕЗАВИСИМОЕ выравнивание контента внутри блока (items + text-align).
	const alignItemsCls =
		s.alignment === "left" ? "items-start" : s.alignment === "right" ? "items-end" : "items-center";
	const textAlignCls =
		s.alignment === "left" ? "text-left" : s.alignment === "right" ? "text-right" : "text-center";
	return { vJustifyCls, hItemsCls, alignItemsCls, textAlignCls };
};
// Figma node 1:33170: «Затемнение» — PER-SLIDE. Читаем s.overlay с fallback на
// section-level p.overlay (backward-compat со старыми данными где overlay был в секции).
const slideOverlayN = (s: any) => Math.max(0, Math.min(100, Number(s.overlay ?? p.overlay) || 0));
const slides = rawSlides.slice(0, 5).map((s: any, i: number) => {
	const ctaText =
		hasOwn(s.button, "text") && typeof s.button.text === "string"
			? s.button.text
			: typeof s.ctaText === "string"
				? s.ctaText
				: undefined;
	// Figma node 1236-42150 (пустое/дефолтное состояние секции): слайд БЕЗ картинки
	// мерчанта = дизайн-подсказка — фото-плейсхолдер landscape-slideshow.png ФОНОМ +
	// белая карточка (boxed) по ЦЕНТРУ полотна (заголовок/подзаголовок/кнопка). Слайд
	// С фото мерчанта — full-bleed как раньше (boxed управляется флагом «Контейнер»).
	const merchantImage =
		hasOwn(s, "image") && typeof s.image === "string"
			? s.image.trim()
			: typeof s.imageUrl === "string"
				? s.imageUrl.trim()
				: "";
	const isPromptCard = !merchantImage;
	// Карточка-подсказка включена по умолчанию (Figma), но тумблер «Контейнер: Скрыть»
	// (container==='false') её выключает — тогда слайд без фото = пустая surface-карточка
	// (прежнее поведение). undefined/'true' → карточка.
	const promptBoxed = isPromptCard && String(s.container) !== "false";
	const layout = slideLayoutCls(s);
	return {
		// Figma: карточка-подсказка сидит на фото-плейсхолдере. Выключенная подсказка и
		// реальный слайд без фото → пустая surface (bg-surface, рендер ниже).
		image: merchantImage || (promptBoxed ? PLACEHOLDER_SLIDE_IMAGE : ""),
		heading: typeof s.heading === "string" ? s.heading : (s.heading?.text ?? ""),
		headingCls: slideHeadingCls(typeof s.heading === "object" ? s.heading?.size : undefined),
		textCls: slideTextCls(typeof s.text === "object" ? s.text?.size : undefined),
		subtitle:
			hasOwn(s.text, "content") && typeof s.text.content === "string"
				? s.text.content
				: typeof s.subtitle === "string"
					? s.subtitle
					: undefined,
		ctaText,
		ctaHref: (hasOwn(s.button, "link") || hasOwn(s.button, "href")
			? resolveSlideLink(hasOwn(s.button, "link") ? s.button.link : s.button.href)
			: resolveSlideLink(s.ctaUrl)) ?? "/catalog",
		// Подсказка → карточка (если не выключена тумблером). Реальный слайд с фото → по «Контейнеру».
		boxed: isPromptCard ? promptBoxed : String(s.container ?? "false") === "true",
		schemeCls:
			typeof s.colorScheme === "string" && s.colorScheme
				? ` color-scheme-${String(s.colorScheme).replace("scheme-", "")}`
				: "",
		// Карточка-подсказка центрируется по полотну (Figma: карточка в середине), реальный
		// слайд размещается по своей position (сетка 3×3).
		...(promptBoxed
			? { ...layout, vJustifyCls: "justify-center", hItemsCls: "items-center" }
			: layout),
		overlayN: slideOverlayN(s),
		active: i === 0,
	};
});

// Канон interval (slider 1-20 c, схема до 60) / autoplay: canon-defaults 5 / true.
const intervalMs = String(
	(typeof p.interval === "number" && p.interval >= 1 && p.interval <= 60 ? p.interval : 5) * 1000,
);
const autoplay = p.autoplay === false || p.autoplay === "false" ? "false" : "true";

// Канон size (s/m/l) — высота полотна. МОБИЛА = СТЕК (паритет Hero): min-h ТОЛЬКО
// на md+ (на мобиле высота полотна = активный слайд: медиа aspect-[4/3] + карточка
// снизу, в потоке). Раньше min-h держался и на мобиле (min(40svh,320px)) → полотно
// было выше стек-контента → карточка «съезжала» вниз с пустотой сверху. Десктоп-
// оверлей: min-h держит высоту фона (все слайды absolute), кап min(svh,px).
const heightCls = roseSlideshowHeightClass(p.size);

// Канон imagePosition («Положение изображения»): fullscreen (canon-default;
// полотно во всю ширину секции, как hero — без боковых полей и радиуса) |
// contained «в окне» (+legacy left/right) — внутри контейнера манеры с полями
// секции, max-width и радиусом медиа. Управляет обёрткой полотна (см. wrapperCls/
// frameCls) — у contained появляется max-w + rounded, у fullscreen их нет.
const contained = p.imagePosition === "contained" || p.imagePosition === "left" || p.imagePosition === "right";
// Мобила = full-bleed стек (медиа во всю ширину + карточка снизу, паритет Hero):
// боковые поля/радиус «в окне» — ТОЛЬКО с md+ (иначе на мобиле рамка + внутренняя
// карточка = «контейнер в контейнере» + двойные боковые отступы). Десктоп-окно цело.
const wrapperCls = contained
	? "w-full md:px-10 lg:px-16 xl:px-20 2xl:px-[280px]"
	: "w-full";
const frameCls = contained ? " max-w-[1320px] md:rounded-[var(--radius-media,8px)]" : "";

// Канон overlay 0-100 — «Затемнение» PER-SLIDE (Figma node 1:33170). Хелпер
// slideOverlayN объявлен ВЫШЕ (перед маппингом slides), т.к. используется в нём.

// Канон pagination: numbers (отсутствие = numbers, как панель/vanilla/bloom) | dots | counter | lines | none.
const pagination =
	p.pagination === "numbers" ||
	p.pagination === "counter" ||
	p.pagination === "lines" ||
	p.pagination === "none" ||
	p.pagination === "dots"
		? p.pagination
		: "numbers";

// Канон buttonStyle: solid (canon-default) = белая CTA героя §3; outlined =
// прозрачная с белым бордером (ветка outlined героя T11).
const ctaCls =
	p.buttonStyle === "outlined"
		? "inline-flex h-10 min-h-10 w-auto min-w-[120px] items-center justify-center rounded border border-solid border-[rgb(var(--color-button-bg,255_255_255))] !bg-transparent px-3 py-2.5 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-button-bg,255_255_255))] transition-opacity hover:opacity-90 sm:h-[52px] sm:min-h-[52px] sm:min-w-[160px] sm:rounded-[var(--radius-button,6px)] sm:px-6 sm:py-[10px] sm:text-[15px] md:text-[16px]"
		: "inline-flex h-10 min-h-10 w-auto min-w-[120px] items-center justify-center rounded !border-0 !bg-[rgb(var(--color-button-bg,255_255_255))] px-3 py-2.5 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-button-text,0_0_0))] transition-opacity hover:opacity-90 sm:h-[52px] sm:min-h-[52px] sm:min-w-[160px] sm:rounded-[var(--radius-button,6px)] sm:px-6 sm:py-[10px] sm:text-[15px] md:text-[16px]";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн T11).
// Стек-секция (мобила): верхний «Отступ» применяется ТОЛЬКО на десктопе (md:pt), на
// мобиле pt=0 — медиа встык под предыдущей секцией (убрать промежуток над медиа,
// паритет Hero). Нижний паддинг (pb) — на всех ширинах.
const paddingVars = p.padding
	? `--ss-pt:${p.padding.top}px;--ss-pb:${p.padding.bottom}px;`
	: undefined;
---

<section
	class="relative w-full overflow-hidden bg-[rgb(var(--color-bg,255_255_255))] pb-[var(--ss-pb,0px)] md:pt-[var(--ss-pt,0px)]"
	data-puck-component-id={id}
	data-interval={intervalMs}
	data-autoplay={autoplay}
	style={paddingVars}
>
	<div class={wrapperCls}>
		<div
			class={`relative mx-auto w-full overflow-hidden ${heightCls}${frameCls}`}
		>
			{
				slides.map((s, i) => (
					<div
						data-slide
						class={`transition-opacity duration-700 ease-out relative md:!absolute md:inset-0 md:!block ${s.active ? "opacity-100" : "hidden pointer-events-none opacity-0"}${s.schemeCls}`}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="slides"
					>
						{/* МЕДИА — мобила: блок 4/3 сверху (стек как Hero «Изображение»);
						    десктоп: absolute на весь слайд (оверлей под текстом). Затемнение
						    и градиент — ВНУТРИ медиа-обёртки (скоуп на фото, не на карточку
						    снизу, иначе на мобиле затемняли бы и текстовый блок). */}
						<div class="relative z-0 aspect-[4/3] w-full md:absolute md:inset-0 md:aspect-auto">
							{s.image ? (
								<img src={s.image} alt={s.heading || "Слайд"} loading={i === 0 ? "eager" : "lazy"} class="!absolute inset-0 !h-full !w-full object-cover" />
							) : (
								<div class="absolute inset-0 bg-[rgb(var(--color-surface,245_245_245))]" aria-hidden="true" />
							)}
							{s.overlayN > 0 && s.image && (
								<div class="pointer-events-none absolute inset-0 bg-black" style={`opacity:${s.overlayN / 100}`} aria-hidden="true" />
							)}
							{s.image && !s.boxed && (
								<div
									class="pointer-events-none absolute inset-x-0 bottom-0 hidden h-1/2 bg-linear-to-t from-black/35 to-transparent md:block"
									aria-hidden="true"
								/>
							)}
						</div>
						{/* КОНТЕНТ — мобила: блок ПОД медиа (стек); десктоп: absolute-оверлей
						    поверх фото (сетка 3×3 через vJustify/hItems). «Контейнер» ON →
						    карточка (boxed ниже) = единственный контейнер, обёртка прозрачная
						    (гаттер+зазор), иначе «контейнер внутри контейнера». «Контейнер» OFF
						    → обёртка = подложка (фон схемы) под медиа. Текст на мобиле всегда
						    тёмный (на подложке снизу), белый — только десктоп-оверлей поверх фото. */}
						<div class={`relative z-10 flex w-full flex-col ${s.hItemsCls} ${s.vJustifyCls} ${s.boxed ? "px-4 pt-4 pb-8 sm:px-5" : "bg-[rgb(var(--color-bg,255_255_255))] px-4 py-10 sm:px-5 sm:py-12"} md:absolute md:inset-0 md:bg-transparent md:px-12 md:pb-16 md:pt-0`}>
							<div
								class={`flex w-full flex-col gap-4 md:max-w-[640px] ${s.alignItemsCls} ${s.textAlignCls}${s.boxed ? " rounded-[var(--radius-card,8px)] bg-[rgb(var(--color-bg,255_255_255))]/95 p-6 shadow-sm md:p-10 [&_h2]:!text-[rgb(var(--color-heading,0_0_0))] [&_p]:!text-[rgb(var(--color-text,0_0_0))]" : ""}`}
							>
								{s.heading && (
									<h2
										class={`font-comfortaa !font-normal uppercase !leading-none ${s.headingCls} text-[rgb(var(--color-heading,0_0_0))]${s.image && !s.boxed ? " md:text-white" : ""}`}
									>
										<Fragment set:html={inlineFormat(s.heading)} />
									</h2>
								)}
								{s.subtitle && (
									<p
										class={`font-manrope ${s.textCls} font-normal leading-none text-[rgb(var(--color-text,0_0_0))]${s.image && !s.boxed ? " md:text-white" : ""}`}
									>
										<Fragment set:html={inlineFormat(s.subtitle)} />
									</p>
								)}
								{s.ctaText && (
									<div class="mt-2">
										<a href={s.ctaHref} class={ctaCls}>
											{s.ctaText}
										</a>
									</div>
								)}
							</div>
						</div>
					</div>
				))
			}

			{
				slides.length > 1 && (
					<>
						{/* Боковые круглые стрелки — только для точек/линий/счётчика. Для «Числа»
						    (canon-default, Figma node 1236-42150) навигация инлайн внутри пагинации:
						    ← 1 2 3 → (стрелки-шевроны вокруг чисел по центру снизу). */}
						{pagination !== "numbers" && (
							<>
								<button
									type="button"
									data-slide-prev
									aria-label="Предыдущий слайд"
									class="absolute left-4 top-1/2 z-20 flex size-10 -translate-y-1/2 items-center justify-center !rounded-full !bg-black/30 !text-white transition-opacity hover:opacity-80"
								>
									<svg class="size-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
										<path d="M12.5 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
									</svg>
								</button>
								<button
									type="button"
									data-slide-next
									aria-label="Следующий слайд"
									class="absolute right-4 top-1/2 z-20 flex size-10 -translate-y-1/2 items-center justify-center !rounded-full !bg-black/30 !text-white transition-opacity hover:opacity-80"
								>
									<svg class="size-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
										<path d="M7.5 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
									</svg>
								</button>
							</>
						)}
						{pagination !== "none" && (
							<div
								class={`relative z-20 mx-auto mt-5 flex w-fit items-center rounded-full bg-black/35 px-4 py-2 md:absolute md:bottom-5 md:left-1/2 md:mx-0 md:mt-0 md:w-auto md:-translate-x-1/2 md:rounded-none md:bg-transparent md:px-0 md:py-0 ${pagination === "numbers" ? "gap-4" : "gap-2"}`}
							>
								{pagination === "dots" &&
									slides.map((_, i) => (
										<button
											type="button"
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											aria-label={`Слайд ${i + 1}`}
											class="size-2 !rounded-full !bg-white/50 transition-colors data-[active=true]:!bg-white"
										/>
									))}
								{pagination === "lines" &&
									slides.map((_, i) => (
										<button
											type="button"
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											aria-label={`Слайд ${i + 1}`}
											class="h-0.5 w-6 !bg-white/50 transition-colors data-[active=true]:!bg-white"
										/>
									))}
								{/* Figma node 1236-42150: ← 1 2 3 → — стрелки-шевроны по краям +
								    числа (активное белое, неактивные white/50) по центру снизу. */}
								{pagination === "numbers" && (
									<>
										<button
											type="button"
											data-slide-prev
											aria-label="Предыдущий слайд"
											class="flex size-6 items-center justify-center !text-white/70 transition-opacity hover:opacity-100"
										>
											<svg class="size-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
												<path d="M12.5 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
											</svg>
										</button>
										{slides.map((_, i) => (
											<button
												type="button"
												data-slide-dot
												data-active={i === 0 ? "true" : "false"}
												class="font-manrope text-[16px] font-normal leading-none !text-white/50 transition-colors data-[active=true]:!text-white"
											>
												{i + 1}
											</button>
										))}
										<button
											type="button"
											data-slide-next
											aria-label="Следующий слайд"
											class="flex size-6 items-center justify-center !text-white/70 transition-opacity hover:opacity-100"
										>
											<svg class="size-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
												<path d="M7.5 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
											</svg>
										</button>
									</>
								)}
								{pagination === "counter" && (
									<span
										data-slide-counter
										data-total={slides.length}
										class="font-manrope text-[14px] font-normal leading-none text-white"
									>
										<span data-slide-counter-current>1</span><span class="mx-1" aria-hidden="true">/</span>{slides.length}
									</span>
								)}
							</div>
						)}
					</>
				)
			}

			{/* Figma node 1236-42150 — пустое состояние: декоративная пагинация ← 1 2 3 →
			    поверх слайда-плейсхолдера (реальных слайдов для пролистывания нет, поэтому
			    статичная, без data-slide-*). Активное «1» белое, «2 3» — white/50; стрелки-
			    шевроны white/70. Зеркалит рабочую numbers-пагинацию выше. */}
			{
				!hasSlides && (
					<div class="relative z-20 mx-auto mt-5 flex w-fit items-center gap-4 rounded-full bg-black/35 px-4 py-2 md:absolute md:bottom-5 md:left-1/2 md:mx-0 md:mt-0 md:w-auto md:-translate-x-1/2 md:rounded-none md:bg-transparent md:px-0 md:py-0" aria-hidden="true">
						<span class="flex size-6 items-center justify-center text-white/70">
							<svg class="size-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
								<path d="M12.5 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</span>
						<span class="font-manrope text-[16px] font-normal leading-none text-white">1</span>
						<span class="font-manrope text-[16px] font-normal leading-none text-white/50">2</span>
						<span class="font-manrope text-[16px] font-normal leading-none text-white/50">3</span>
						<span class="flex size-6 items-center justify-center text-white/70">
							<svg class="size-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
								<path d="M7.5 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</span>
					</div>
				)
			}
		</div>
	</div>
</section>

<script is:inline>
	(function () {
		var scripts = document.querySelectorAll("script");
		var me = scripts[scripts.length - 1];
		var root = me && me.previousElementSibling;
		// hot-replace вставляет скрипт заново — ищем ближайший необработанный слайдер
		if (!root || !root.hasAttribute("data-interval")) {
			var all = document.querySelectorAll("[data-interval][data-puck-component-id]");
			for (var k = 0; k < all.length; k++)
				if (all[k].dataset.slideshowHydrated !== "true") {
					root = all[k];
					break;
				}
		}
		if (!root || root.dataset.slideshowHydrated === "true") return;
		root.dataset.slideshowHydrated = "true";
		var interval = parseInt(root.dataset.interval || "5000", 10);
		var autoplay = root.dataset.autoplay !== "false";
		var slides = root.querySelectorAll("[data-slide]");
		var dots = root.querySelectorAll("[data-slide-dot]");
		// Счётчик «текущий/всего» (pagination='counter'): JS обновляет текущий номер.
		var counterCurrent = root.querySelector("[data-slide-counter-current]");
		if (slides.length < 2) return;
		var idx = 0,
			timer = null;
		function show(n) {
			idx = (n + slides.length) % slides.length;
			slides.forEach(function (s, i) {
				s.style.opacity = i === idx ? "1" : "0";
				s.style.pointerEvents = i === idx ? "auto" : "none";
					if (i === idx) s.classList.remove("hidden");
					else s.classList.add("hidden"); // мобила-стек: неактивный слайд вне потока (десктоп держит md:!block)
			});
			dots.forEach(function (d, i) {
				d.setAttribute("data-active", i === idx ? "true" : "false");
			});
			if (counterCurrent) counterCurrent.textContent = String(idx + 1);
		}
		function restart() {
			if (timer) clearInterval(timer);
			if (autoplay)
				timer = setInterval(function () {
					show(idx + 1);
				}, interval);
		}
		root.querySelectorAll("[data-slide-prev]").forEach(function (b) {
			b.addEventListener("click", function () {
				show(idx - 1);
				restart();
			});
		});
		root.querySelectorAll("[data-slide-next]").forEach(function (b) {
			b.addEventListener("click", function () {
				show(idx + 1);
				restart();
			});
		});
		dots.forEach(function (d, i) {
			d.addEventListener("click", function () {
				show(i);
				restart();
			});
		});
		show(0);
		restart();
	})();
</script>
