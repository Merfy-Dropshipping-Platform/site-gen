---
import Layout from "../layouts/Layout.astro";

// Мост корзины → checkout: build.service.ts патчит `const shopId = ""` → siteId на деплое.
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";
---

<Layout title="Корзина" description="Ваша корзина — Vanilla" showNewsletter={false}>
	<section class="vanilla-pad w-full bg-white py-12 md:py-16 lg:py-20" aria-labelledby="cart-title">
		<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-10 md:gap-12">
			<div
				data-cart-page-empty
				class="flex flex-col items-start gap-6 py-8"
			>
				<h1
					id="cart-title"
					class="font-vanilla-bitter text-[20px] font-normal italic leading-none tracking-normal text-[var(--vanilla-dark)] md:text-[24px]"
				>
					Корзина
				</h1>
				<p class="font-manrope text-[14px] font-normal leading-normal text-[var(--vanilla-muted)]">
					Вы пока не добавили товар в корзину.
				</p>
				<a href="/catalog/textile" class="vanilla-button vanilla-button-cart">
					Продолжить покупки
				</a>
				<p class="font-manrope text-[12px] font-normal leading-normal text-[var(--vanilla-muted)]">
					Есть аккаунт?
					<a href="/auth/sign-in" class="text-[var(--vanilla-header-bg)] hover:opacity-80">Войти</a>
				</p>
			</div>

			<div data-cart-page-filled class="hidden flex-col gap-10 md:gap-12">
				<h1 class="font-vanilla-bitter text-[20px] font-normal italic leading-none tracking-normal text-[var(--vanilla-dark)] md:text-[24px]">
					Корзина
				</h1>

				<ul data-cart-page-items role="list" class="flex flex-col"></ul>

				<div class="flex flex-col items-stretch gap-4 border-t border-[var(--vanilla-line)] pt-8 md:items-end md:gap-5 md:pt-10">
					<p class="max-w-[420px] text-right font-manrope text-[12px] font-normal leading-normal text-[#444444]">
						Налоги, скидки и стоимость доставки
						<br />
						рассчитываются при оформлении заказа
					</p>
					<div class="flex items-baseline justify-between gap-3 md:justify-start">
						<span class="font-manrope text-[16px] font-normal leading-normal text-[var(--vanilla-dark)] md:text-[18px]">
							Итого
						</span>
						<span
							data-cart-page-total
							class="font-manrope text-[18px] font-normal leading-normal text-[var(--vanilla-dark)] md:text-[20px]"
						>
							0 ₽
						</span>
					</div>
					<button type="button" data-action="checkout" class="vanilla-button vanilla-button-cart">
						Оформить заказ
					</button>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	import { getCart, getCartTotal, formatCartPrice } from "../lib/cart";
	import { cartLineThumbPictureHtml } from "../lib/cart-thumb-html";
	import { withBase } from "../lib/with-base";

	const emptyBlock = document.querySelector<HTMLElement>("[data-cart-page-empty]");
	const filledBlock = document.querySelector<HTMLElement>("[data-cart-page-filled]");
	const itemsEl = document.querySelector<HTMLElement>("[data-cart-page-items]");
	const totalEl = document.querySelector<HTMLElement>("[data-cart-page-total]");

	const trashIconHtml = `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="size-6 opacity-60 transition-opacity group-hover:opacity-100" aria-hidden="true"><path d="M4 7h16M10 7V5a1 1 0 011-1h2a1 1 0 011 1v2M6 7l1 14a1 1 0 001 1h8a1 1 0 001-1l1-14M10 11v6M14 11v6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

	const render = () => {
		const lines = getCart();
		if (!emptyBlock || !filledBlock || !itemsEl || !totalEl) return;

		if (lines.length === 0) {
			emptyBlock.classList.remove("hidden");
			emptyBlock.classList.add("flex");
			filledBlock.classList.add("hidden");
			filledBlock.classList.remove("flex");
			return;
		}

		emptyBlock.classList.add("hidden");
		emptyBlock.classList.remove("flex");
		filledBlock.classList.remove("hidden");
		filledBlock.classList.add("flex");

		itemsEl.innerHTML = lines
			.map((line) => {
				const oldPriceHtml =
					line.oldPrice && line.oldPrice > line.price
						? `<span class="font-manrope text-[14px] font-normal leading-normal text-[var(--vanilla-muted)] line-through md:text-[16px]">${formatCartPrice(line.oldPrice * line.quantity)}</span>`
						: "";

				return `
					<li class="flex flex-col gap-4 border-b border-[var(--vanilla-line)] py-6 first:pt-0 last:border-b-0 md:flex-row md:items-center md:justify-between md:gap-8" data-line-id="${line.id}">
						<div class="flex min-w-0 flex-1 items-center gap-4 md:gap-6">
							<a href="/products/${line.productId}" class="block size-20 shrink-0 overflow-hidden bg-[var(--vanilla-card)] md:size-24">
								${cartLineThumbPictureHtml(line.image, line.name)}
							</a>
							<div class="flex min-w-0 flex-col gap-2">
								<a href="/products/${line.productId}" class="break-words font-manrope text-[14px] font-normal uppercase leading-normal text-[var(--vanilla-dark)] hover:opacity-80 md:text-[16px]">${line.name}</a>
								<div class="flex flex-wrap items-center gap-2">
									<span class="font-manrope text-[14px] font-normal leading-normal text-[var(--vanilla-dark)] md:text-[16px]">${formatCartPrice(line.price * line.quantity)}</span>
									${oldPriceHtml}
								</div>
							</div>
						</div>
						<div class="flex w-full items-center justify-between gap-4 md:w-auto md:justify-end md:gap-6">
							<button type="button" data-cart-remove data-id="${line.id}" class="group flex size-10 items-center justify-center transition-opacity hover:opacity-80" aria-label="Удалить">
								${trashIconHtml}
							</button>
							<div class="inline-flex h-10 items-center border border-[var(--vanilla-line)]">
								<button type="button" data-cart-dec data-id="${line.id}" class="flex h-10 w-10 items-center justify-center font-manrope text-[16px] leading-none text-[var(--vanilla-dark)] transition-opacity hover:opacity-70" aria-label="Уменьшить">−</button>
								<span class="min-w-[28px] text-center font-manrope text-[14px] font-normal leading-none text-[var(--vanilla-dark)]">${line.quantity}</span>
								<button type="button" data-cart-inc data-id="${line.id}" class="flex h-10 w-10 items-center justify-center font-manrope text-[16px] leading-none text-[var(--vanilla-dark)] transition-opacity hover:opacity-70" aria-label="Увеличить">+</button>
							</div>
						</div>
					</li>
				`;
			})
			.join("");

		totalEl.textContent = formatCartPrice(getCartTotal(lines));
	};

	render();
	window.addEventListener("vanilla:cart:updated", render);

	document.addEventListener("click", (event) => {
		const checkout = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-action='checkout']");
		if (checkout) {
			// Мост NtCart → backend cart: строим серверную корзину из локальных линий,
			// чтобы checkout (cartStore) показал товары и submit/оплата работали.
			void (async () => {
				const cs = (window as any).cartStore;
				const lines = getCart();
				if (cs && lines.length) {
					try {
						cs.clear();
						for (const l of lines) await cs.addItem(l.productId, l.variant?.variantCombinationId ?? null, l.quantity);
					} catch (e) {}
				}
				window.location.href = "/checkout"; // full load = VT-safe (checkout-скрипты стартуют свежими)
			})();
		}
	});
</script>

{/* Мост корзины → backend cart: грузим cartStore + конфиг, чтобы «Оформить заказ»
    создал серверную корзину из локальных NtCart-линий (shopId патчится на деплое). */}
<script is:inline define:vars={{ shopId, apiUrl }}>
	window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
		shopId: shopId || "",
		apiUrl: apiUrl || "https://gateway.merfy.ru/api",
	};
</script>
<script is:inline type="module" src="/scripts/cart-api.js"></script>
<script is:inline type="module" src="/scripts/cart-store.js"></script>

<style>
	.vanilla-button-cart {
		color: #ffffff;
		background: var(--vanilla-header-bg);
		border-color: var(--vanilla-header-bg);
		min-height: 48px;
		padding-inline: 24px;
		font-size: 12px;
	}

	@media (max-width: 639px) {
		.vanilla-button-cart {
			width: 100%;
		}
	}
</style>
