---
import type { ContactFormProps } from './ContactForm.puckConfig';
import { ContactFormClasses as C } from './ContactForm.classes';

interface Props extends ContactFormProps {
  id?: string;
}

const {
  id,
  heading,
  description,
  fields,
  buttonText,
  padding,
} = Astro.props as Props;

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';

// Constructor passes enabled/required as "true"/"false" strings.
// Normalize to booleans at render time so conditional blocks work correctly.
const toBool = (v: unknown): boolean => (typeof v === 'boolean' ? v : v === 'true');
const norm = {
  name: {
    enabled: toBool(fields?.name?.enabled),
    required: toBool(fields?.name?.required),
    label: fields?.name?.label ?? 'Имя',
  },
  email: {
    enabled: toBool(fields?.email?.enabled),
    required: toBool(fields?.email?.required),
    label: fields?.email?.label ?? 'Email',
  },
  phone: {
    enabled: toBool(fields?.phone?.enabled),
    required: toBool(fields?.phone?.required),
    label: fields?.phone?.label ?? 'Телефон',
  },
  message: {
    enabled: toBool(fields?.message?.enabled),
    required: toBool(fields?.message?.required),
    label: fields?.message?.label ?? 'Сообщение',
  },
};
---
<section
  class={C.root}
  data-puck-component-id={id}
  style={paddingStyle}
>
  <div class={C.container}>
    <div class={C.inner}>
      {heading && <h2 class={C.heading}>{heading}</h2>}
      {description && <p class={C.description}>{description}</p>}
      <form class={C.form} method="POST" action="/api/contact/submit">
        {norm.name.enabled && (
          <div class={C.field}>
            <label class={C.label} for="contact-name">
              {norm.name.label}
              {norm.name.required && <span class={C.required}>*</span>}
            </label>
            <input
              id="contact-name"
              type="text"
              name="name"
              class={C.input}
              required={norm.name.required}
            />
          </div>
        )}
        {norm.email.enabled && (
          <div class={C.field}>
            <label class={C.label} for="contact-email">
              {norm.email.label}
              {norm.email.required && <span class={C.required}>*</span>}
            </label>
            <input
              id="contact-email"
              type="email"
              name="email"
              class={C.input}
              required={norm.email.required}
            />
          </div>
        )}
        {norm.phone.enabled && (
          <div class={C.field}>
            <label class={C.label} for="contact-phone">
              {norm.phone.label}
              {norm.phone.required && <span class={C.required}>*</span>}
            </label>
            <input
              id="contact-phone"
              type="tel"
              name="phone"
              class={C.input}
              required={norm.phone.required}
            />
          </div>
        )}
        {norm.message.enabled && (
          <div class={C.field}>
            <label class={C.label} for="contact-message">
              {norm.message.label}
              {norm.message.required && <span class={C.required}>*</span>}
            </label>
            <textarea
              id="contact-message"
              name="message"
              class={C.textarea}
              required={norm.message.required}
            ></textarea>
          </div>
        )}
        <button type="submit" class={C.button}>{buttonText}</button>
      </form>
    </div>
  </div>
</section>
