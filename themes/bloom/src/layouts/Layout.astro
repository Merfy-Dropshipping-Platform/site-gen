---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import CheckoutHeader from "../../../../packages/theme-base/blocks/CheckoutHeader/CheckoutHeader.astro";
import Footer from "../components/Footer.astro";
import BloomCartAddedModal from "../components/cart/BloomCartAddedModal.astro";
import NtCartDrawer from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtCartDrawer.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { ViewTransitions } from "astro:transitions";

interface Props {
	title?: string;
	description?: string;
	// "checkout" → минимальная шапка оформления (CheckoutHeader, Figma 1:13563);
	// build.service патчит бренд CheckoutHeader под мерчанта на сборке сайта.
	header?: "default" | "checkout";
}

const { title, description = SITE_DESCRIPTION, header = "default" } = Astro.props;
const pageTitle = title ? `${title} — ${SITE_TITLE}` : SITE_TITLE;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={pageTitle} description={description} />
		<ViewTransitions />
	</head>
	<body class="antialiased bg-white">
		{header === "checkout" ? (
			<div class="color-scheme-2" style="--size-checkout-brand:24px;--size-checkout-brand-image:32px;">
				<CheckoutHeader siteTitle={SITE_TITLE} logoMode="text" logoImage={null} rightIcon="cart" accountLink="/account" backLink="/cart" cartLink="/cart" padding={{ top: 24, bottom: 24 }} />
			</div>
		) : (
			<Header />
		)}
		<main>
			<slot />
		</main>
		<Footer />
		<NtCartDrawer rootId="bloom-cart-drawer-root" eventPrefix="bloom:cart" />
		<BloomCartAddedModal />
		<script>
			import { initCartUI } from "../lib/cart";
			import { initWishlistUI } from "../lib/wishlist";
			initCartUI();
			// Избранное (wishlist) — глобальный делегат сердец/бейджей, зеркало корзины.
			initWishlistUI();

				// Корзина «Сайдбар»/«Страница» (--cart-type): перехват клика по иконке
				// (<button data-cart-open>) в capture-фазе, опережая bubble-обработчик
				// панели (DS NtCartDrawer). page → /cart (live: переход; превью: <a> →
				// nav-агент → postMessage navigate). drawer (дефолт) → панель открывается сама.
				document.addEventListener(
					"click",
					(e) => {
						const el = e.target as Element | null;
						if (!el || !el.closest("[data-cart-open]")) return;
						const cartType = getComputedStyle(document.documentElement)
							.getPropertyValue("--cart-type")
							.trim()
							.replace(/['"]/g, "");
						if (cartType !== "page") return;
						e.preventDefault();
						e.stopImmediatePropagation();
						if (window.self === window.top) {
							window.location.assign("/cart");
						} else {
							const a = document.createElement("a");
							a.href = "/cart";
							document.body.appendChild(a);
							a.click();
							a.remove();
						}
					},
					true,
				);
		</script>
		<script>
			const initScrollAnimations = () => {
				const targets = document.querySelectorAll<HTMLElement>("[data-animate]");
				if (!targets.length) return;

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								observer.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.08, rootMargin: "0px 0px -36px 0px" },
				);

				targets.forEach((el) => {
					el.classList.remove("is-visible");
					const delay = el.dataset.animateDelay;
					if (delay) el.style.animationDelay = delay;
					observer.observe(el);
				});
			};

			initScrollAnimations();
			document.addEventListener("astro:after-swap", initScrollAnimations);
		</script>
	</body>
</html>
