---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Корзина" description="Ваша корзина — Luna">
	<section
		class="w-full bg-white px-4 pb-[60px] pt-16 md:px-20 md:pb-[80px] md:pt-20 2xl:px-[300px]"
		aria-labelledby="cart-title"
	>
		<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-16">
			<!-- Пустое состояние -->
			<div
				data-cart-page-empty
				class="flex flex-col items-center gap-4 py-10"
			>
				<h1
					id="cart-title"
					class="font-comfortaa text-[28px] font-normal uppercase leading-[1.115] text-[#000000] md:text-[32px]"
				>
					Корзина
				</h1>
				<p class="font-manrope text-[14px] font-light leading-normal text-[#999999] md:text-[16px]">
					Вы пока не добавили товар в корзину.
				</p>
				<a
					href="/catalog"
					class="inline-flex h-12 items-center justify-center rounded-[6px] bg-[#71C0FF] px-6 font-manrope text-[16px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-95"
				>
					Продолжить покупки
				</a>
				<p class="font-manrope text-[14px] font-normal leading-normal text-[#999999] md:text-[16px]">
					Есть аккаунт?
					<a href="/auth/sign-in" class="text-[#000000] hover:opacity-80">Войти</a>
				</p>
			</div>

			<!-- Наполненная корзина -->
			<div
				data-cart-page-filled
				class="hidden flex-col gap-10"
			>
				<h1 class="font-comfortaa text-[28px] font-normal uppercase leading-[1.115] text-[#000000] md:text-[32px]">
					Корзина
				</h1>
				<ul
					data-cart-page-items
					role="list"
					class="flex flex-col gap-6"
				></ul>
				<div class="flex items-center justify-end gap-6 border-t border-[#F5F5F5] pt-6">
					<span class="font-manrope text-[16px] font-normal leading-normal text-[#000000]">Итого</span>
					<span data-cart-page-total class="font-manrope text-[20px] font-normal leading-normal text-[#000000]">0 ₽</span>
				</div>
				<div class="flex justify-end">
					<button
						type="button"
						data-action="checkout"
						class="inline-flex h-12 items-center justify-center rounded-[6px] bg-[#71C0FF] px-6 font-manrope text-[16px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-95"
					>
						Оформить заказ
					</button>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	import { getCart, getCartTotal, formatCartPrice, updateQuantity, removeFromCart } from "../lib/cart";
	import { cartLineThumbPictureHtml } from "../lib/cart-thumb-html";

	const emptyBlock = document.querySelector<HTMLElement>("[data-cart-page-empty]");
	const filledBlock = document.querySelector<HTMLElement>("[data-cart-page-filled]");
	const itemsEl = document.querySelector<HTMLElement>("[data-cart-page-items]");
	const totalEl = document.querySelector<HTMLElement>("[data-cart-page-total]");

	const render = () => {
		const lines = getCart();
		if (!emptyBlock || !filledBlock || !itemsEl || !totalEl) return;
		if (lines.length === 0) {
			emptyBlock.classList.remove("hidden");
			emptyBlock.classList.add("flex");
			filledBlock.classList.add("hidden");
			filledBlock.classList.remove("flex");
			return;
		}
		emptyBlock.classList.add("hidden");
		emptyBlock.classList.remove("flex");
		filledBlock.classList.remove("hidden");
		filledBlock.classList.add("flex");

		itemsEl.innerHTML = lines
			.map((line) => {
				const variant = [line.variant?.color, line.variant?.size].filter(Boolean).join(", ");
				return `
					<li class="flex flex-col gap-4 border-b border-[#F5F5F5] pb-6 md:flex-row md:items-start md:justify-between" data-line-id="${line.id}">
						<div class="flex gap-4">
							<a href="/products/${line.productId}" class="block size-24 shrink-0 overflow-hidden bg-[#F5F5F5]">
								${cartLineThumbPictureHtml(line.image, line.name)}
							</a>
							<div class="flex flex-col gap-2">
								<a href="/products/${line.productId}" class="font-manrope text-[16px] font-normal text-[#000000] hover:opacity-80 md:text-[20px]">${line.name}</a>
								${variant ? `<span class="font-manrope text-[14px] font-light text-[#999999]">${variant}</span>` : ""}
								<button type="button" data-cart-remove data-id="${line.id}" class="w-fit font-manrope text-[14px] font-normal text-[#999999] transition-opacity hover:text-[#000000]">Удалить</button>
							</div>
						</div>
						<div class="flex items-center justify-between gap-6 md:flex-col md:items-end md:justify-start md:gap-3">
							<div class="inline-flex h-10 items-center rounded-[4px] border border-[#F5F5F5]">
								<button type="button" data-cart-dec data-id="${line.id}" class="flex h-10 w-10 items-center justify-center" aria-label="Уменьшить">−</button>
								<span class="min-w-[28px] text-center font-manrope text-[14px]">${line.quantity}</span>
								<button type="button" data-cart-inc data-id="${line.id}" class="flex h-10 w-10 items-center justify-center" aria-label="Увеличить">+</button>
							</div>
							<span class="font-manrope text-[16px] font-normal text-[#000000] md:text-[20px]">${formatCartPrice(line.price * line.quantity)}</span>
						</div>
					</li>
				`;
			})
			.join("");

		totalEl.textContent = formatCartPrice(getCartTotal(lines));
	};

	render();
	window.addEventListener("luna:cart:updated", render);

	document.addEventListener("click", (event) => {
		const target = event.target as HTMLElement;
		const inc = target.closest<HTMLButtonElement>("[data-cart-inc]");
		if (inc) {
			const id = inc.dataset.id ?? "";
			const line = getCart().find((l) => l.id === id);
			if (line) updateQuantity(id, line.quantity + 1);
			return;
		}
		const dec = target.closest<HTMLButtonElement>("[data-cart-dec]");
		if (dec) {
			const id = dec.dataset.id ?? "";
			const line = getCart().find((l) => l.id === id);
			if (line) updateQuantity(id, line.quantity - 1);
			return;
		}
		const remove = target.closest<HTMLButtonElement>("[data-cart-remove]");
		if (remove) removeFromCart(remove.dataset.id ?? "");
		const checkout = target.closest<HTMLButtonElement>("[data-action='checkout']");
		if (checkout) {
			alert("Спасибо за заказ! Мы свяжемся с вами для подтверждения.");
		}
	});
</script>
