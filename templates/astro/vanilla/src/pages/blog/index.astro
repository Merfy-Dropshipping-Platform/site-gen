---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import publications from '../../data/publications.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};

const posts = (publications || [])
  .filter((p: any) => p.status === 'published')
  .sort((a: any, b: any) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());
---
<BaseLayout title={`Блог — ${meta?.title ?? 'Мой магазин'}`} description="Блог магазина">
  <Header {...headerProps} />

  <main class="flex-1 w-full" style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 py-10">
      <nav class="mb-8 font-body text-sm" style="color: rgb(var(--color-muted));">
        <a href="/" class="hover:opacity-80 transition-opacity" style="color: rgb(var(--color-muted));">Главная</a>
        <span class="mx-1">/</span>
        <span style="color: rgb(var(--color-foreground));">Блог</span>
      </nav>

      <h1 class="font-heading text-3xl sm:text-4xl font-medium mb-10" style="color: rgb(var(--color-foreground));">
        Блог
      </h1>

      {posts.length === 0 ? (
        <p class="font-body text-lg" style="color: rgb(var(--color-muted));">
          Пока нет публикаций.
        </p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
          {posts.map((post: any) => (
            <a
              href={`/blog/${post.slug}`}
              class="group block overflow-hidden transition-transform hover:-translate-y-1"
              style={`border-radius: var(--radius-card, 0px); border: 1px solid rgb(var(--color-border));`}
            >
              {post.coverImageUrl && post.coverImageUrl !== '/images/placeholder.png' && (
                <div class="aspect-[16/10] overflow-hidden">
                  <img
                    src={post.coverImageUrl}
                    alt={post.title}
                    class="w-full h-full object-cover transition-transform group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-5">
                {post.category && (
                  <span class="text-xs font-body uppercase tracking-wider mb-2 block" style="color: rgb(var(--color-muted));">
                    {post.category}
                  </span>
                )}
                <h2 class="font-heading text-lg sm:text-xl font-medium mb-2 line-clamp-2" style="color: rgb(var(--color-foreground));">
                  {post.title}
                </h2>
                {post.excerpt && (
                  <p class="font-body text-sm line-clamp-3 mb-3" style="color: rgb(var(--color-muted));">
                    {post.excerpt}
                  </p>
                )}
                {post.dateFormatted && (
                  <time class="text-xs font-body" style="color: rgb(var(--color-muted));">
                    {post.dateFormatted}
                  </time>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer {...footerProps} />
</BaseLayout>
