---
interface Props {
	id?: string;
	name: string;
	price: string;
	oldPrice?: string;
	image: string;
	href?: string;
	quantity?: number;
	quickAdd?: boolean;
	discountPercent?: number;
	colorOptions?: Array<{ color: string; label?: string }>;
}

const { id, name, price, oldPrice, image, href = '#', quantity, quickAdd = false, discountPercent, colorOptions } = Astro.props;
const hasImage = image && !image.includes('placeholder');
const hasDiscount = discountPercent && discountPercent > 0;
const hasColors = colorOptions && colorOptions.length > 0;
---

<article class="product-card flex flex-col gap-[20px] group cursor-pointer">
	<a href={href} class="cursor-pointer">
		<div class="product-card-image-wrap relative overflow-hidden w-full" style="aspect-ratio: 1 / 1; background: rgb(var(--color-foreground) / 0.05);">
			{hasImage ? (
				<img
					src={image}
					alt={name}
					loading="lazy"
					class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
				/>
			) : (
				<div class="w-full h-full flex items-center justify-center" style="background: rgb(var(--color-foreground) / 0.05);">
					<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-theme-muted">
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
						<circle cx="8.5" cy="8.5" r="1.5" />
						<polyline points="21 15 16 10 5 21" />
					</svg>
				</div>
			)}

			{/* Discount badge — top-left */}
			{hasDiscount && (
				<span class="product-card-badge">
					-{discountPercent}%
				</span>
			)}

			{/* Color dots — bottom-right */}
			{hasColors && (
				<div class="product-card-colors">
					{colorOptions.map((opt) => (
						<span
							class="product-card-color-dot"
							style={`background: ${opt.color};`}
							title={opt.label || opt.color}
						/>
					))}
				</div>
			)}
		</div>
	</a>
	<div class="flex flex-col gap-[4px]">
		<a href={href} class="no-underline text-inherit">
			<h3 class="text-[16px] font-normal uppercase leading-[1.25] font-body line-clamp-2" style="color: #000;">
				{name}
			</h3>
		</a>
		<div class="flex items-center gap-[8px] flex-wrap">
			<span class="text-[16px] font-normal leading-[1.25] font-body" style="color: #000;">
				{price}
			</span>
			{oldPrice && (
				<span class="text-[14px] font-normal line-through leading-[1.25] font-body" style="color: #444;">
					{oldPrice}
				</span>
			)}
		</div>
		{quickAdd && id && (
			<button
				type="button"
				class="add-to-cart-btn mt-2 w-full py-2 px-4 text-sm font-normal hover:opacity-90 transition-colors font-body"
				style="background: rgb(var(--color-button)); color: rgb(var(--color-button-text));"
				data-product-id={id}
				data-stock={quantity != null ? quantity : undefined}
			>
				В корзину
			</button>
		)}
	</div>
</article>

<style>
	/* Discount badge */
	.product-card-badge {
		position: absolute;
		top: 8px;
		left: 8px;
		background: #26311C;
		color: #fff;
		font-family: var(--font-body, 'Arsenal', sans-serif);
		font-size: 12px;
		line-height: 24px;
		height: 24px;
		padding: 0 6px;
		text-align: center;
		white-space: nowrap;
		border-radius: 0;
		z-index: 1;
	}

	/* Color dots container */
	.product-card-colors {
		position: absolute;
		bottom: 8px;
		right: 8px;
		display: flex;
		align-items: center;
		gap: 2px;
		background: #fff;
		padding: 2px;
		z-index: 1;
	}

	/* Individual color dot — square, not circle */
	.product-card-color-dot {
		display: block;
		width: 8px;
		height: 8px;
		border-radius: 0;
		flex-shrink: 0;
	}
</style>
