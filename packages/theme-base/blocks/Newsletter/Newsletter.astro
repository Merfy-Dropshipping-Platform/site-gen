---
import type { NewsletterProps } from './Newsletter.puckConfig';
import { NewsletterClasses as C } from './Newsletter.classes';

interface Props extends NewsletterProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  heading: headingProp,
  description: descriptionProp,
  placeholder: placeholderProp,
  buttonText: buttonTextProp,
  padding,
} = Astro.props as Props;

// Constructor legacy schema writes heading as { text }, description as text.content,
// placeholder/buttonText inside form.*. Accept both shapes.
const h = headingProp ?? (raw.heading as { text?: string } | string | undefined);
const heading =
  typeof h === 'string' ? h : (h?.text ?? undefined);
const t = raw.text as { content?: string } | string | undefined;
const description =
  descriptionProp ?? (typeof t === 'string' ? t : t?.content) ?? '';
const form = raw.form as { placeholder?: string; buttonText?: string } | undefined;
const placeholder = placeholderProp ?? form?.placeholder ?? 'email@example.com';
const buttonText = buttonTextProp ?? form?.buttonText ?? 'Подписаться';

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
---
<section
  class={C.root}
  data-puck-component-id={id}
  style={paddingStyle}
>
  <div class={C.container}>
    <div class={C.inner}>
      {heading && <h2 class={C.heading}>{heading}</h2>}
      {description && <p class={C.description}>{description}</p>}
      <form class={C.form} method="POST" action="/api/newsletter/subscribe">
        <input type="email" name="email" placeholder={placeholder} required class={C.input} />
        <button type="submit" class={C.button} aria-label={buttonText}>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10h12m0 0l-5-5m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>
