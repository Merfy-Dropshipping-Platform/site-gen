---
import VanillaProductCard from "../products/VanillaProductCard.astro";
import VanillaCatalogFilterSidebar from "./VanillaCatalogFilterSidebar.astro";
import {
	CATALOG_PRICE_ROW,
	CATALOG_PRICE_VALUE,
	CATALOG_PRICE_WRAP,
	CATALOG_RADIO_CIRCLE,
	CATALOG_RADIO_TEXT,
} from "./filter-classes";
import { catalogProducts } from "../../data/products";

interface Props {
	section?: "textile" | "decor";
	categoryTitle: string;
}

const { section, categoryTitle } = Astro.props;

const isTextile = section === "textile";

const textileFeaturedIds = ["bag-3", "bag-4", "bag-5", "bag-1"] as const;
const decorFeaturedIds = ["bag-2", "bag-6"] as const;

const featuredIds = isTextile ? textileFeaturedIds : decorFeaturedIds;

// section задан → демо-подборка категории (textile/decor). Без section — это
// страница /catalog: показываем весь демо-каталог. На live сетку всё равно
// перерисовывает гидрация реальных товаров (renderCatalog ниже).
const displayedProducts = section
	? featuredIds
			.map((id) => catalogProducts.find((product) => product.id === id))
			.filter((product): product is (typeof catalogProducts)[number] => Boolean(product))
	: catalogProducts;

const totalCount = displayedProducts.length;
const showLoadMore = section ? isTextile : totalCount > 4;

function pluralizeProducts(count: number): string {
	const mod10 = count % 10;
	const mod100 = count % 100;
	if (mod100 >= 11 && mod100 <= 14) return `${count} товаров`;
	if (mod10 === 1) return `${count} товар`;
	if (mod10 >= 2 && mod10 <= 4) return `${count} товара`;
	return `${count} товаров`;
}

const productCountLabel = pluralizeProducts(totalCount);

/* ── Раскладка «top» (настройка конструктора): ряд фильтров строкой над гридом.
   UI-only списки повторяют секции VanillaCatalogFilterSidebar; манера vanilla:
   font-vanilla-arsenal, плоские панели без скруглений, radio с кастомным кружком
   (общие классы — filter-classes.ts). Цвета зоны фильтров — токены схем
   конструктора rgb(var(--color-*)) с фолбэками на родную палитру vanilla. ── */

interface RadioOption {
	value: string;
	label: string;
	checked?: boolean;
}

const rowSortOptions: RadioOption[] = [
	{ value: "popularity", label: "По популярности", checked: true },
	{ value: "new", label: "По новизне" },
	{ value: "price-desc", label: "По убыванию цены" },
	{ value: "price-asc", label: "По возрастанию цены" },
];

const rowStockOptions: RadioOption[] = [
	{ value: "all", label: "Все", checked: true },
	{ value: "in", label: "В наличии" },
	{ value: "out", label: "Распродано" },
];

/* Summary — типографика заголовков секций сайдбара; открытая панель — плоская,
   border приглушённый (#999999), фон = фон страницы rgb(var(--color-bg)) —
   единообразно для всех дропдаунов ряда (Наличие/Стоимость/Коллекции/сортировка). */
const rowSummaryClass =
	"flex cursor-pointer list-none items-center gap-2 font-vanilla-arsenal text-base font-normal leading-none text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70 [&::-webkit-details-marker]:hidden";
const rowPanelClass =
	"absolute top-full z-30 mt-2 flex w-[240px] flex-col gap-3 border border-[rgb(var(--color-muted,153_153_153))] bg-[rgb(var(--color-bg,238_238_238))] p-4";
---

<section
	class="vanilla-pad w-full bg-[var(--vanilla-surface)] py-16 md:py-20"
	aria-labelledby="catalog-title"
	data-nt="vanilla-catalog-section"
	data-section={section ?? "all"}
	data-catalog-layout="side"
>
	{/* Переключение раскладки ДО рендера вариантов (без мигания): глобал инжектится
	    платформой (превью-контроллер и билд) из настройки конструктора; глобала
	    нет — остаётся родной side-вид vanilla. */}
	<script is:inline>
		var l = window.__MERFY_CATALOG_LAYOUT__;
		if (l === "top" || l === "side") {
			document.currentScript.parentElement.setAttribute("data-catalog-layout", l);
		}
	</script>
	<div class="vanilla-container flex flex-col gap-10">
		<header>
			<h1
				id="catalog-title"
				class="font-vanilla-bitter text-[20px] font-normal italic uppercase leading-none tracking-normal text-black"
			>
				{categoryTitle}
			</h1>
		</header>

		{/* ── Раскладка «top»: фильтры/сортировка строкой над гридом. Ритм отступов —
		    как на соседних страницах каталога: ряд отбит от заголовка контейнерным
		    gap-10 и тем же шагом от грида; грид→футер — gap-8, как в side-виде. ── */}
		<div class="flex flex-col gap-10" data-catalog-variant="top">
			<div
				class="relative z-30 flex flex-wrap items-center justify-between gap-x-6 gap-y-4"
				data-nt="catalog-filters"
			>
				<div class="flex flex-wrap items-center gap-x-6 gap-y-4">
					<details class="relative [&[open]]:z-30">
						<summary class={rowSummaryClass}>
							<span>Наличие</span>
							<svg aria-hidden="true" viewBox="0 0 10 6" fill="none" class="h-[6px] w-[10px]">
								<path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" />
							</svg>
						</summary>
						<div class={`${rowPanelClass} left-0`}>
							{
								rowStockOptions.map((option) => (
									<label class="group flex cursor-pointer items-center gap-2">
										<input
											type="radio"
											name="vanilla-top-stock"
											value={option.value}
											checked={option.checked}
											class="peer sr-only"
										/>
										<span aria-hidden="true" class={CATALOG_RADIO_CIRCLE} />
										<span class={CATALOG_RADIO_TEXT}>{option.label}</span>
									</label>
								))
							}
						</div>
					</details>

					<details class="relative [&[open]]:z-30">
						<summary class={rowSummaryClass}>
							<span>Стоимость</span>
							<svg aria-hidden="true" viewBox="0 0 10 6" fill="none" class="h-[6px] w-[10px]">
								<path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" />
							</svg>
						</summary>
						<div class={`${rowPanelClass} left-0`}>
							<div class={CATALOG_PRICE_WRAP}>
								<div class={CATALOG_PRICE_ROW}>
									<span>от</span>
									<div class={CATALOG_PRICE_VALUE}>
										<span>0</span>
										<span>₽</span>
									</div>
								</div>
								<div class={CATALOG_PRICE_ROW}>
									<span>до</span>
									<div class={CATALOG_PRICE_VALUE}>
										<span>5 990</span>
										<span>₽</span>
									</div>
								</div>
							</div>
						</div>
					</details>

					{/* Фильтр по коллекциям (row-ветка): дропдаун в манере vanilla. Скрыт на
					    demo-сборке, гидрация показывает его при наличии коллекций магазина и
					    уважает ?collection= из ссылок тайлов Collections/Gallery. */}
					<details
						class="relative [&[open]]:z-30"
						data-nt="catalog-collections-filter"
						data-collections-dropdown
						style="display:none;"
					>
						<summary class={rowSummaryClass}>
							<span data-collections-label>Коллекции</span>
							<svg aria-hidden="true" viewBox="0 0 10 6" fill="none" class="h-[6px] w-[10px]">
								<path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" />
							</svg>
						</summary>
						<div class={`${rowPanelClass} left-0`}>
							<div data-collections-options class="flex flex-col gap-3"></div>
						</div>
					</details>
				</div>

				<details class="relative [&[open]]:z-30">
					<summary class={rowSummaryClass}>
						<span>По популярности</span>
						<svg aria-hidden="true" viewBox="0 0 10 6" fill="none" class="h-[6px] w-[10px]">
							<path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" />
						</svg>
					</summary>
					<div class={`${rowPanelClass} right-0`}>
						{
							rowSortOptions.map((option) => (
								<label class="group flex cursor-pointer items-center gap-2">
									<input
										type="radio"
										name="vanilla-top-sort"
										value={option.value}
										checked={option.checked}
										class="peer sr-only"
									/>
									<span aria-hidden="true" class={CATALOG_RADIO_CIRCLE} />
									<span class={CATALOG_RADIO_TEXT}>{option.label}</span>
								</label>
							))
						}
					</div>
				</details>
			</div>

			<div class="flex flex-col gap-8">
				<ul
					class="grid grid-cols-1 gap-x-3 gap-y-9 sm:grid-cols-2 md:grid-cols-3 md:gap-x-4 md:gap-y-12"
					role="list"
					data-nt="catalog-grid"
				>
					{displayedProducts.map((product, index) => (
						<li data-product-id={product.id}>
							<VanillaProductCard product={product} priority={index < 2} />
						</li>
					))}
				</ul>

				<div
					class:list={[
						"flex flex-col items-stretch gap-4 sm:flex-row sm:items-center",
						showLoadMore ? "sm:justify-between" : "sm:justify-end",
					]}
				>
					{
						showLoadMore && (
							<button
								type="button"
								data-action="load-more"
								class="inline-flex h-12 min-h-12 w-full items-center justify-center bg-[var(--vanilla-header-bg)] px-6 font-vanilla-arsenal text-base font-normal uppercase leading-none text-white transition-opacity hover:opacity-90 sm:w-auto sm:px-16"
							>
								Смотреть ещё
							</button>
						)
					}
					<span class="font-vanilla-arsenal text-base font-normal leading-none text-black" data-nt="catalog-count">
						{productCountLabel}
					</span>
				</div>
			</div>
		</div>

		{/* ── Раскладка «side» (родная для vanilla): левый сайдбар фильтров ── */}
		<div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:gap-6" data-catalog-variant="side">
			<VanillaCatalogFilterSidebar class="w-full lg:shrink-0" />

			<div class="flex min-w-0 flex-1 flex-col gap-8">
				<ul class="grid grid-cols-1 gap-x-3 gap-y-9 sm:grid-cols-2 md:gap-x-4 md:gap-y-12" role="list" data-nt="catalog-grid">
					{displayedProducts.map((product, index) => (
						<li data-product-id={product.id}>
							<VanillaProductCard product={product} priority={index < 2} />
						</li>
					))}
				</ul>

				<div
					class:list={[
						"flex flex-col items-stretch gap-4 sm:flex-row sm:items-center",
						showLoadMore ? "sm:justify-between" : "sm:justify-end",
					]}
				>
					{
						showLoadMore && (
							<button
								type="button"
								data-action="load-more"
								class="inline-flex h-12 min-h-12 w-full items-center justify-center bg-[var(--vanilla-header-bg)] px-6 font-vanilla-arsenal text-base font-normal uppercase leading-none text-white transition-opacity hover:opacity-90 sm:w-auto sm:px-16"
							>
								Смотреть ещё
							</button>
						)
					}
					<span class="font-vanilla-arsenal text-base font-normal leading-none text-black" data-nt="catalog-count">
						{productCountLabel}
					</span>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	/* Переключение раскладок: глобал __MERFY_CATALOG_LAYOUT__ выставляет
	   data-catalog-layout на секции — противоположный вариант скрывается. */
	[data-catalog-layout="top"] [data-catalog-variant="side"] {
		display: none;
	}
	[data-catalog-layout="side"] [data-catalog-variant="top"] {
		display: none;
	}
</style>

<script>
	document.addEventListener("click", (event) => {
		const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-action='load-more']");
		if (!button) return;
		button.disabled = true;
		button.textContent = "Больше товаров нет";
		button.classList.add("opacity-60", "pointer-events-none");
	});
</script>

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		filterByCollection,
		findCollection,
		renderCardHtml,
		escapeHtml,
		updateCount,
		type RealCollection,
	} from "../../lib/storefront-hydrate";
	import {
		CATALOG_OPTION_ACTIVE,
		CATALOG_OPTION_IDLE,
		CATALOG_RADIO_CIRCLE,
		CATALOG_RADIO_TEXT,
	} from "./filter-classes";

	// Реальные товары (Option B): на published-сайте /data/products.json реальный →
	// перерисовываем demo-гриды ОБЕИХ раскладок (top/side) и счётчики. На demo-сборке
	// loadRealProducts() вернёт null → no-op.
	// Фильтр по коллекциям: ?collection= (slug/id из ссылок тайлов) + контейнеры
	// «Коллекции» обеих раскладок (radio в сайдбаре, дропдаун в row-ветке) —
	// заполняются из collections.json/storefront-data.
	let catalogCollections: RealCollection[] | null = null;

	function currentCollectionRef(): string | null {
		return new URLSearchParams(window.location.search).get("collection");
	}

	async function renderCatalog() {
		const products = await loadRealProducts();
		if (!products) return; // demo-сборка
		const ref = currentCollectionRef();
		const items = ref ? filterByCollection(products, catalogCollections, ref) : products;
		const html = items
			.map((p) => `<li data-product-id="${escapeHtml(p.id)}">${renderCardHtml(p)}</li>`)
			.join("");
		for (const grid of Array.from(document.querySelectorAll('[data-nt="catalog-grid"]'))) {
			grid.innerHTML = html;
		}
		updateCount('[data-nt="catalog-count"]', items.length);
	}

	let radioNameSeq = 0; // своя radio-группа на контейнер — иначе checked конфликтует между раскладками

	/** Опция фильтра «Коллекции» с гарантированно непустыми значением и лейблом. */
	interface CollectionOption {
		id: string;
		value: string;
		label: string;
	}

	/** Готовит пункты списков «Коллекции»: коллекции с пустым именем давали пустые
	 *  строки между пунктами дропдауна top-вида (`?? "Коллекция"` пропускает "") —
	 *  такие, как и без slug/id, отфильтровываются в обеих раскладках. */
	function collectionOptions(): CollectionOption[] {
		return (catalogCollections ?? [])
			.map((c) => {
				const slug = typeof c?.slug === "string" ? c.slug.trim() : "";
				const id = typeof c?.id === "string" ? c.id.trim() : "";
				const label = typeof c?.name === "string" ? c.name.trim() : "";
				return { id, value: slug || id, label };
			})
			.filter((option) => option.value !== "" && option.label !== "");
	}

	/** Перерисовывает опции одного контейнера «Коллекции» из текущего ?collection=. */
	function renderCollectionsBox(box: HTMLElement): void {
		const list = box.querySelector<HTMLElement>("[data-collections-options]");
		if (!list) return;
		const options = collectionOptions();
		if (options.length === 0) return;
		const current = findCollection(catalogCollections, currentCollectionRef());
		if (box.hasAttribute("data-collections-dropdown")) {
			// Row-ветка: список-кнопки в дропдауне, манера vanilla (приглушённый → текст).
			const label = box.querySelector<HTMLElement>("[data-collections-label]");
			const currentLabel = typeof current?.name === "string" ? current.name.trim() : "";
			if (label) label.textContent = currentLabel || "Коллекции";
			const optionHtml = (value: string, name: string, active: boolean) =>
				`<button type="button" data-collection-option="${escapeHtml(value)}" class="cursor-pointer text-left font-vanilla-arsenal text-base font-normal leading-none transition-colors ${active ? CATALOG_OPTION_ACTIVE : CATALOG_OPTION_IDLE}">${escapeHtml(name)}</button>`;
			list.innerHTML =
				optionHtml("", "Все", !current) +
				options
					.map((option) => optionHtml(option.value, option.label, !!current && current.id === option.id))
					.join("");
		} else {
			// Sidebar-ветка: radio в манере секций сайдбара.
			let radioName = box.getAttribute("data-cf-radio-name");
			if (!radioName) {
				radioName = `vanilla-collection-${++radioNameSeq}`;
				box.setAttribute("data-cf-radio-name", radioName);
			}
			const optionHtml = (value: string, name: string, active: boolean) =>
				`<label class="group flex cursor-pointer items-center gap-2">
	<input type="radio" name="${escapeHtml(radioName)}" value="${escapeHtml(value)}" data-collection-option="${escapeHtml(value)}"${active ? " checked" : ""} class="peer sr-only" />
	<span aria-hidden="true" class="${CATALOG_RADIO_CIRCLE}"></span>
	<span class="${CATALOG_RADIO_TEXT}">${escapeHtml(name)}</span>
</label>`;
			list.innerHTML =
				optionHtml("", "Все", !current) +
				options
					.map((option) => optionHtml(option.value, option.label, !!current && current.id === option.id))
					.join("");
		}
	}

	/** Выбор коллекции в любом контейнере: URL → синк активного состояния в обоих
	 *  контейнерах → перерисовка гридов обеих раскладок. */
	function applyCollectionSelection(value: string): void {
		const params = new URLSearchParams(window.location.search);
		if (value) params.set("collection", value);
		else params.delete("collection");
		const qs = params.toString();
		window.history.replaceState({}, "", window.location.pathname + (qs ? `?${qs}` : ""));
		for (const box of Array.from(
			document.querySelectorAll<HTMLElement>('[data-nt="catalog-collections-filter"][data-cf-hydrated="true"]'),
		)) {
			renderCollectionsBox(box);
			box.removeAttribute("open"); // закрыть details-дропдаун row-ветки
		}
		renderCatalog();
	}

	async function initCollectionsFilter() {
		const boxes = Array.from(
			document.querySelectorAll<HTMLElement>('[data-nt="catalog-collections-filter"]'),
		);
		if (boxes.length === 0) return;
		catalogCollections = await loadRealCollections();
		// Нет ни одного пригодного пункта (см. collectionOptions) — секции «Коллекции»
		// остаются скрытыми, а не дропдаун из одного «Все».
		if (collectionOptions().length === 0) return;
		for (const box of boxes) {
			if (box.getAttribute("data-cf-hydrated") === "true") continue; // идемпотентность astro:page-load
			const list = box.querySelector<HTMLElement>("[data-collections-options]");
			if (!list) continue;
			box.setAttribute("data-cf-hydrated", "true");
			box.style.display = "";
			renderCollectionsBox(box);
			// Radio сайдбара отдаёт change, кнопки дропдауна — click; делегируем на список.
			list.addEventListener("change", (ev) => {
				const input = (ev.target as HTMLElement).closest<HTMLInputElement>("input[data-collection-option]");
				if (input) applyCollectionSelection(input.value);
			});
			list.addEventListener("click", (ev) => {
				const btn = (ev.target as HTMLElement).closest<HTMLElement>("button[data-collection-option]");
				if (btn) applyCollectionSelection(btn.getAttribute("data-collection-option") ?? "");
			});
		}
	}

	async function hydrateCatalog() {
		await initCollectionsFilter();
		await renderCatalog();
	}

	hydrateCatalog();
	document.addEventListener("astro:page-load", hydrateCatalog);
</script>
