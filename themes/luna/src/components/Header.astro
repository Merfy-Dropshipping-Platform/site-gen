---
import NtPromoBanner from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtPromoBanner.astro";
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { SITE_TITLE } from "../consts";

interface NavLink {
	label: string;
	href: string;
	match?: (pathname: string) => boolean;
}

const nav: NavLink[] = [
	{ label: "Коллекции", href: "/catalog", match: (p) => p === "/" || p.startsWith("/catalog") || p.startsWith("/products") },
	{ label: "История", href: "/contacts" },
	{ label: "Контакты", href: "/contacts" },
];

const pathname = Astro.url.pathname;
const isActive = (link: NavLink) => (link.match ? link.match(pathname) : pathname === link.href);
---

<div class="sticky top-0 z-50 w-full">
	<NtPromoBanner
		text="Скидка 10% на общую сумму заказа от 9 000 ₽."
		link="/catalog"
		linkText="Перейти"
	/>

	<header class="w-full border-b border-[#F5F5F5] bg-white" data-nt="luna-header">
		<div class="relative z-[60] flex h-16 items-center justify-between bg-white px-4 md:hidden">
			<button
				type="button"
				id="luna-burger-btn"
				class="flex size-10 items-center justify-center transition-opacity hover:opacity-70"
				aria-label="Меню"
				aria-expanded="false"
				aria-controls="luna-burger"
			>
				<span class="burger-icon" data-icon="open">
					<NtIcon name="menu-burger" sizeClass="size-6" />
				</span>
				<span class="burger-icon hidden" data-icon="close">
					<NtIcon name="menu-close" sizeClass="size-6" />
				</span>
			</button>
			<a href="/" class="font-comfortaa text-[20px] font-normal uppercase text-[#000000] hover:opacity-80">{SITE_TITLE}</a>
			<div class="flex items-center gap-4">
				<a href="#" data-action="toggle-search" class="flex size-6 items-center justify-center" aria-label="Поиск">
					<NtIcon name="search-sm" sizeClass="size-6" />
				</a>
				<button type="button" data-cart-open class="relative flex size-6 items-center justify-center" aria-label="Корзина">
					<NtIcon name="cart-sm" sizeClass="size-4" />
					<span data-cart-count data-empty="true" class="absolute -right-2 -top-2 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#71C0FF] px-1 font-manrope text-[10px] font-normal leading-none text-[#000000] data-[empty=true]:hidden">0</span>
				</button>
				<a href="/auth/sign-in" class="flex size-6 items-center justify-center" aria-label="Аккаунт">
					<NtIcon name="user-sm" sizeClass="size-4" />
				</a>
			</div>
		</div>

		<div class="hidden w-full max-w-[1920px] mx-auto px-4 md:flex md:items-center md:justify-between md:py-5 md:px-20 2xl:px-[300px]">
			<nav class="flex items-center gap-8" aria-label="Основная навигация">
				{nav.map((link) => {
					const active = isActive(link);
					return (
						<a
							href={link.href}
							aria-current={active ? "page" : undefined}
							class:list={[
								"relative pb-1 font-manrope text-[16px] font-normal uppercase leading-normal text-[#000000] transition-opacity hover:opacity-70",
								active && "after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-[#71C0FF] after:content-['']",
							]}
						>
							{link.label}
						</a>
					);
				})}
			</nav>

			<a href="/" class="shrink-0 font-comfortaa text-[24px] font-normal uppercase leading-none text-[#000000] hover:opacity-90 lg:text-[32px]">{SITE_TITLE}</a>

			<div class="flex items-center gap-5">
				<button type="button" data-action="toggle-search" class="flex size-10 items-center justify-center transition-opacity hover:opacity-80" aria-label="Поиск">
					<NtIcon name="search-lg" sizeClass="size-8" />
				</button>
				<button type="button" data-cart-open class="relative flex size-10 items-center justify-center transition-opacity hover:opacity-80" aria-label="Корзина">
					<NtIcon name="cart" sizeClass="size-8" />
					<span data-cart-count data-empty="true" class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#71C0FF] px-1 font-manrope text-[10px] font-normal leading-none text-[#000000] data-[empty=true]:hidden">0</span>
				</button>
				<a href="/auth/sign-in" class="flex size-10 items-center justify-center transition-opacity hover:opacity-80" aria-label="Аккаунт">
					<NtIcon name="user" sizeClass="size-8" />
				</a>
			</div>
		</div>

		<div data-search-panel class="hidden w-full border-t border-[#F5F5F5] bg-white px-4 py-5 md:px-20 2xl:px-[300px]" hidden>
			<form role="search" action="/catalog" method="get" class="mx-auto flex h-12 w-full max-w-[1320px] items-center justify-between gap-2 border border-[#000000] bg-white pl-3 pr-1">
				<input type="search" name="q" placeholder="Поиск..." aria-label="Поиск" class="min-w-0 flex-1 bg-transparent font-manrope text-[16px] font-light leading-normal text-[#000000] placeholder:text-[#999999] outline-none" />
				<button type="submit" class="flex h-10 shrink-0 items-center justify-center bg-[#71C0FF] px-3 py-2.5 font-manrope text-[14px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-95">Найти</button>
			</form>
		</div>
	</header>

	<div id="luna-burger" class="fixed inset-x-0 top-[96px] bottom-0 z-[55] hidden w-full overflow-y-auto bg-white px-4 pt-4 pb-8 md:hidden" role="dialog" aria-modal="true" aria-label="Меню">
		<div class="flex items-center gap-2">
			<form class="flex h-10 min-h-10 flex-1 items-center justify-between border border-[#999999] bg-white pl-3 pr-2" role="search" action="/catalog" method="get">
				<input type="search" name="q" placeholder="Поиск" class="min-w-0 flex-1 bg-transparent font-manrope text-[12px] font-normal leading-normal text-[#000000] placeholder:text-[#999999] outline-none" />
				<button type="submit" class="flex h-6 w-6 shrink-0 items-center justify-center" aria-label="Найти">
					<NtIcon name="search-sm" sizeClass="size-6" />
				</button>
			</form>
			<a href="/auth/sign-in" class="flex size-10 shrink-0 items-center justify-center bg-[#71C0FF]" aria-label="Профиль">
				<NtIcon name="user" sizeClass="size-6" />
			</a>
		</div>

		<nav class="mt-10 flex flex-col gap-5" aria-label="Основное меню">
			{nav.map((link) => {
				const active = isActive(link);
				return (
					<div class="flex flex-col gap-1">
						<a href={link.href} class:list={["text-[14px] font-normal uppercase leading-normal", active ? "text-[#000000]" : "text-[#999999]"]}>{link.label}</a>
						{active && <div class="h-px w-[54px] bg-[#71C0FF]" aria-hidden="true"></div>}
					</div>
				);
			})}
			<a href="/cart" class="text-[14px] font-normal uppercase leading-normal text-[#999999]">Корзина</a>
			<a href="/auth/sign-up" class="text-[14px] font-normal uppercase leading-normal text-[#999999]">Регистрация</a>
		</nav>
	</div>
</div>

<script>
	const burgerBtn = document.getElementById("luna-burger-btn");
	const burger = document.getElementById("luna-burger");

	const setBurger = (open: boolean) => {
		if (!burger || !burgerBtn) return;
		burger.classList.toggle("hidden", !open);
		burgerBtn.setAttribute("aria-expanded", String(open));
		burgerBtn.querySelectorAll<HTMLElement>(".burger-icon").forEach((el) => {
			const key = el.dataset.icon;
			if (key === "open") el.classList.toggle("hidden", open);
			else el.classList.toggle("hidden", !open);
		});
		document.body.style.overflow = open ? "hidden" : "";
	};

	burgerBtn?.addEventListener("click", () => {
		const isHidden = burger?.classList.contains("hidden");
		setBurger(Boolean(isHidden));
	});

	burger?.querySelectorAll("a").forEach((a) => {
		a.addEventListener("click", () => setBurger(false));
	});

	document.querySelectorAll<HTMLElement>("[data-action='toggle-search']").forEach((el) => {
		el.addEventListener("click", (event) => {
			event.preventDefault();
			const panel = document.querySelector<HTMLElement>("[data-search-panel]");
			if (!panel) return;
			const hidden = panel.hasAttribute("hidden");
			if (hidden) {
				panel.removeAttribute("hidden");
				panel.classList.remove("hidden");
				panel.classList.add("block");
				panel.querySelector<HTMLInputElement>("input[type='search']")?.focus();
			} else {
				panel.setAttribute("hidden", "");
				panel.classList.add("hidden");
				panel.classList.remove("block");
			}
		});
	});
</script>
