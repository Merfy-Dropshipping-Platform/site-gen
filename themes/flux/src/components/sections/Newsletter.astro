---
// Канон-секция Newsletter в манере flux. Схема полей = packages/theme-base/blocks/
// Newsletter/Newsletter.puckConfig.ts; настройки применяются КАК rose T17
// (heading/headingSize · text/textSize · position-«Выравнивание» · formLayout ·
// padding · colorScheme), но визуал — чистый flux.
//
// Стиль (строго flux): font-roboto-flex ВЕЗДЕ (роль заголовка/описания/формы
// подписки — см. обновлённый Footer.astro и панель поиска Header.astro:451-461).
// Email-форма = живой канон панели поиска flux: h-14/16 rounded-[8px]
// border-[#FA5109] bg-white, input roboto-flex 16 light, кнопка bg-[#FA5109]
// text-white roboto-flex uppercase (акцент #FA5109 — фирменный flux). Секционные
// цвета — токены (на scheme-1 секция ТЁМНАЯ: bg #000 / heading #fff / muted #ccc),
// форма всегда белая коробка с оранжевым акцентом. Манера статична — скролл-
// анимаций нет (MANNER §6). Радиус формы — литерал 8px (канон панели поиска
// Header:451), НЕ var(--radius-field) (4px).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Live-конфиг подписки: shopId патчит build.service (patchShopIdInDist) → siteId
// на деплое (заменяет `const shopId = ""` в HTML); apiUrl — публичный gateway.
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";

// Канон heading: string | { text, alignment, size }; canon-default = «Подпишитесь
// на нашу рассылку» (Figma 1:19335 / Footer flux). Роль flux рассылки — roboto-flex
// uppercase, цвет — токен heading (на scheme-1 = белый). Заданный мерчантом
// heading рендерим (?? срабатывает лишь при пустых данных).
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Подпишитесь на нашу рассылку");
// Лестница headingSize (дефолт роли — medium = текст секции рассылки flux
// 19/md:23): отсутствие пропа и medium = 19/23; small 15/18, large 24/30.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[15px] md:text-[18px]"
		: headingSize === "large"
			? "text-[24px] md:text-[30px]"
			: "text-[19px] md:text-[23px]";
const headingCls = `font-roboto-flex ${headingSizeCls} font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))]`;

// Канон «Выравнивание» = ЕДИНЫЙ контрол (конструктор пишет position): рулит И
// позицией блока в контейнере (posCls), И выключкой содержимого внутри
// (alignCls: заголовок/текст/форма), И выравниванием stacked-кнопки (selfCls).
// «слева-слева», «центр-по центру», «право-право». Зеркало rose T17.
const position = p.position === "center" || p.position === "right" ? p.position : "left";
const posCls = position === "center" ? "mx-auto" : position === "right" ? "ml-auto" : "mr-auto";
const alignCls =
	position === "center"
		? "items-center text-center"
		: position === "right"
			? "items-end text-right"
			: "items-start text-left";
const selfCls = position === "center" ? "self-center" : position === "right" ? "self-end" : "self-start";

// Канон description (string) + text {content, size} (pupa-дубль). ПУСТОЕ состояние:
// дословный Figma-плейсхолдер 1:19335 «Узнавайте первыми о новых коллекциях и
// эксклюзивных предложениях.». Когда мерчант задал description/text.content —
// рендерим ЕГО (?? fallback срабатывает только при пустых данных). Роль flux —
// roboto-flex font-light, цвет токен muted (на scheme-1 = #ccc). Лестница textSize:
// small 14, medium/отсутствие = 16, large 18/20.
const description =
	(typeof p.description === "string" && p.description.trim() ? p.description : undefined) ??
	(typeof p.text?.content === "string" && p.text.content.trim() ? p.text.content : undefined) ??
	"Узнавайте первыми о новых коллекциях и эксклюзивных предложениях.";
const descSize = p.text?.size;
const descSizeCls =
	descSize === "small"
		? "text-[14px]"
		: descSize === "large"
			? "text-[18px] md:text-[20px]"
			: "text-[16px]";

// Канон placeholder. ПУСТОЕ состояние: дословный Figma-плейсхолдер 1:19335
// «email@example.com». Заданный мерчантом placeholder — рендерим его.
const placeholder =
	typeof p.placeholder === "string" && p.placeholder.trim() ? p.placeholder : "email@example.com";

// Канон buttonText. ПУСТОЕ состояние: дословный Figma-плейсхолдер 1:19335 —
// текстовая кнопка «Кнопка». Заданный мерчантом buttonText — рендерим его.
const buttonText = typeof p.buttonText === "string" && p.buttonText.trim() ? p.buttonText : "Кнопка";

// Канон formLayout: stacked (canon-default rose/puckConfig) — поле + оранжевая
// CTA под ним; inline-submit — форма-панель flux дословно (input + кнопка в
// одной оранжевой рамке, как панель поиска Header:451).
const inlineSubmit = p.formLayout === "inline-submit";

// Канон agreement (toggle 'true'/'false', default 'false'): при 'true' — чекбокс
// согласия под формой (манера flux: roboto-flex мелкий muted, акцент #FA5109);
// иначе ничего.
const showAgreement = p.agreement === "true";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 py-10 md:px-20 md:py-16 2xl:px-80"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto w-full max-w-[1920px]">
		<div class={`flex w-full max-w-[652px] flex-col gap-6 ${posCls} ${alignCls}`}>
			<div class="flex w-full flex-col gap-2">
				<h2
					id={titleId}
					class={headingCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
				<p
					class={`font-roboto-flex ${descSizeCls} font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]`}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="101"
					data-puck-subsection-field="text"
				>
					{description}
				</p>
			</div>

			{
				inlineSubmit ? (
					<form
						class="flex h-14 w-full items-center justify-between gap-2 rounded-[8px] border border-[#FA5109] bg-white pl-4 pr-2 md:h-16"
						data-newsletter-form
						data-puck-subsection-parent={id}
						data-puck-subsection-index="997"
						data-puck-subsection-field="placeholder"
					>
						<input
							type="email"
							name="email"
							required
							placeholder={placeholder}
							aria-label="Email"
							class="min-w-0 flex-1 bg-transparent font-roboto-flex text-[16px] font-light leading-normal text-[#000000] placeholder:text-[#cccccc] outline-none"
						/>
						<button
							type="submit"
							class="flex h-10 shrink-0 items-center justify-center rounded-[8px] bg-[#FA5109] px-4 py-2 font-roboto-flex text-[14px] font-normal uppercase leading-normal text-white transition-opacity hover:opacity-95 md:h-12 md:px-5 md:text-[16px]"
						>
							{buttonText}
						</button>
					</form>
				) : (
					<form
						class="flex w-full flex-col gap-4"
						data-newsletter-form
						data-puck-subsection-parent={id}
						data-puck-subsection-index="997"
						data-puck-subsection-field="placeholder"
					>
						<input
							type="email"
							name="email"
							required
							placeholder={placeholder}
							aria-label="Email"
							class="h-14 w-full rounded-[8px] border border-[#FA5109] bg-white px-4 font-roboto-flex text-[16px] font-light leading-normal text-[#000000] placeholder:text-[#cccccc] outline-none md:h-16"
						/>
						<button
							type="submit"
							class={`inline-flex h-12 w-auto min-w-[200px] items-center justify-center ${selfCls} rounded-[8px] bg-[#FA5109] px-8 font-roboto-flex text-[14px] font-normal uppercase leading-normal text-white transition-opacity hover:opacity-95 md:text-[16px]`}
						>
							{buttonText}
						</button>
					</form>
				)
			}
			{
				showAgreement && (
					<label class="flex w-full cursor-pointer items-start gap-2 font-roboto-flex text-[13px] font-light leading-snug text-[rgb(var(--color-muted,153_153_153))]">
						<input
							type="checkbox"
							required
							class="mt-0.5 size-4 shrink-0 accent-[#FA5109]"
						/>
						<span>Согласен на обработку персональных данных</span>
					</label>
				)
			}
			<p
				data-newsletter-status
				role="status"
				class="hidden w-full font-roboto-flex text-[12px] font-light text-[#4AD300] md:text-[14px]"
			></p>
		</div>
	</div>
</section>

<script is:inline define:vars={{ shopId, apiUrl }}>
	// Реальная отправка подписки на gateway. Самодостаточно (не зависит от
	// скрипта футера): гард __merfyNewsletterWired исключает двойную привязку,
	// если на странице есть и футер, и эта секция. store_id — из пропатченного
	// shopId (деплой) либо window.__MERFY_SITE_ID__ (превью конструктора).
	(function () {
		window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
			shopId: shopId || "",
			apiUrl: apiUrl || "https://gateway.merfy.ru/api",
		};
		var cfg = window.__MERFY_CONFIG__;
		var base = String(cfg.apiUrl || "https://gateway.merfy.ru/api").replace(/\/+$/, "");
		var storeId = cfg.shopId || window.__MERFY_SITE_ID__ || "";

		function wire(form) {
			if (!form || form.__merfyNewsletterWired) return;
			form.__merfyNewsletterWired = true;
			var section = form.closest("section") || document;
			var status = section.querySelector("[data-newsletter-status]");
			var btn = form.querySelector('button[type="submit"]');

			function show(msg, isError) {
				if (!status) return;
				status.textContent = msg;
				status.style.color = isError ? "#E11D48" : "";
				status.classList.remove("hidden");
			}

			form.addEventListener("submit", function (event) {
				event.preventDefault();
				var input = form.querySelector('input[type="email"]');
				var email = input ? String(input.value || "").trim() : "";
				if (!email) return;
				if (btn) btn.disabled = true;
				show("Отправляем…", false);

				fetch(base + "/storefront/newsletter/subscribe", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ store_id: storeId, email: email }),
				})
					.then(function (res) {
						return res
							.json()
							.catch(function () { return {}; })
							.then(function (data) { return { ok: res.ok, code: res.status, data: data }; });
					})
					.then(function (r) {
						if (r.ok) {
							show(
								r.data && r.data.alreadySubscribed
									? "Вы уже подписаны на рассылку."
									: "Спасибо! Мы отправим вам приветственное письмо.",
								false,
							);
							form.reset();
						} else if (r.code === 429) {
							show("Слишком много попыток. Попробуйте позже.", true);
						} else {
							show("Не удалось подписаться. Попробуйте позже.", true);
						}
					})
					.catch(function () {
						show("Не удалось подписаться. Проверьте соединение.", true);
					})
					.finally(function () {
						if (btn) btn.disabled = false;
					});
			});
		}

		function init() {
			var forms = document.querySelectorAll("[data-newsletter-form]");
			for (var i = 0; i < forms.length; i++) wire(forms[i]);
		}
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", init);
		} else {
			init();
		}
	})();
</script>
