---
// Фаза B (bloom): канон-секция MultiColumns — адаптация Benefits.astro (см.
// themes/bloom/MANNER.md §10: Benefits = 3 белые карточки-фичи на розовом =
// основа MultiColumns). Тело верстальщика перенесено КОПИЕЙ — Benefits.astro
// не тронут (его используют страницы). Схема полей = packages/theme-base/
// blocks/MultiColumns/MultiColumns.puckConfig.ts.
// ПУСТОЕ СОСТОЯНИЕ (без columns[]) = ДОСЛОВНЫЙ ПЛЕЙСХОЛДЕР по контракту
// Figma 1:19335: заголовок «Мультиколонны» + 3 колонки (пустой surface-rect +
// «Колонна» + «Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.» +
// «Кнопка»), НЕ мок-демо верстальщика. Когда мерчант добавил columns[] — рендер
// реальных данных без изменений (Shopify-модель, как theme-base PopularProducts/
// Collections).
const p = Astro.props as Record<string, any>;
const id = p.id;

// hasManualColumns: мерчант явно добавил хотя бы одну колонку (Shopify-модель).
// Объявлено выше блока heading — fallback заголовка ниже зависит от него.
const hasManualColumns = Array.isArray(p.columns) && p.columns.length > 0;

// Канон heading: string | { text, alignment, size }; у верстальщика шапки НЕТ
// → при заданных колонках рендер ТОЛЬКО при непустом (как у верстальщика).
// Figma 1:19335 — ПУСТОЕ состояние секции имеет ДОСЛОВНЫЙ заголовок
// «Мультиколонны»: когда мерчант НЕ добавил колонки (плейсхолдер), показываем
// его (как rose Collections/Popular показывают дефолт-заголовок). Мерчант задал
// свой heading → его и рендерим. Роль = заголовок секции (МАННЕРА §1), на
// розовом полотне — белый. Лестница §9: medium/отсутствие = 18/md:20,
// small 15/17, large 22/24.
const headingRaw = typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "");
const heading = headingRaw || (!hasManualColumns ? "Мультиколонны" : "");
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[15px] md:text-[17px]"
		: headingSize === "large"
			? "text-[22px] md:text-[24px]"
			: "text-[18px] md:text-[20px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center" ? " text-center" : headingAlignment === "right" ? " text-right" : "";
const headingCls = `font-urbanist ${headingSizeCls} font-normal uppercase leading-none text-[rgb(var(--color-heading,255_255_255))]${headingAlignCls}`;

// Канон columns[] ≤10 (item: heading|title, text|description, imageUrl|image —
// иконка 44×44, headingSize/textSize, link {text,href} | flat linkText+link).
// Гейт пустого состояния: НЕТ ручных колонок → ПЛЕЙСХОЛДЕР по контракту
// (Figma 1:19335), НЕ мок-демо верстальщика. Когда мерчант добавил колонки —
// рендерим реальные без изменений (так же, как theme-base PopularProducts/
// Collections: пустой выбор = заглушка, выбранное = данные).
// Контракт Мультиколонн: 3 колонки = пустой rect + «Колонна» +
// «Сочетай текст…» + Кнопка.
const PLACEHOLDER_TEXT = "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.";
const PLACEHOLDER_COLUMNS = [
	{ heading: "Колонна", text: PLACEHOLDER_TEXT, imageUrl: "", link: { text: "Кнопка", href: "/catalog" } },
	{ heading: "Колонна", text: PLACEHOLDER_TEXT, imageUrl: "", link: { text: "Кнопка", href: "/catalog" } },
	{ heading: "Колонна", text: PLACEHOLDER_TEXT, imageUrl: "", link: { text: "Кнопка", href: "/catalog" } },
];
const rawColumns = hasManualColumns ? p.columns : PLACEHOLDER_COLUMNS;
const columns = rawColumns.slice(0, 10).map((c: any) => {
	// Ссылка карточки: canon link {text,href} ИЛИ flat-пара linkText + link
	// (string из arrayFields конструктора). Рендер при непустом тексте.
	const linkText =
		(c.link && typeof c.link === "object" && typeof c.link.text === "string" && c.link.text.trim()
			? c.link.text
			: undefined) ?? (typeof c.linkText === "string" && c.linkText.trim() ? c.linkText : undefined);
	const linkHref =
		(c.link && typeof c.link === "object" && typeof c.link.href === "string" && c.link.href
			? c.link.href
			: undefined) ??
		(typeof c.link === "string" && c.link ? c.link : undefined) ??
		"/catalog";
	return {
		heading:
			(typeof c.heading === "string" && c.heading) || (typeof c.title === "string" && c.title) || "",
		text:
			(typeof c.text === "string" && c.text) ||
			(typeof c.description === "string" && c.description) ||
			"",
		image:
			(typeof c.imageUrl === "string" && c.imageUrl.trim()) ||
			(typeof c.image === "string" && c.image.trim()) ||
			"",
		imageSize: c.imageSize,
		headingSize: c.headingSize,
		textSize: c.textSize,
		link: linkText ? { text: linkText, href: linkHref } : undefined,
		// Пустое состояние: рисуем нейтральный rect-плейсхолдер вместо иконки.
		isPlaceholder: !hasManualColumns,
	};
});

// Канон displayColumns 1-4: canon-default 3 и отсутствие = литерал верстальщика
// (md:grid-cols-2 xl:grid-cols-3 байт-в-байт); иное значение — мобильная
// лестница 1 → md:2 фиксирована, xl — через CSS-var.
const displayColumnsRaw = Number(p.displayColumns);
const displayColumns =
	Number.isFinite(displayColumnsRaw) && displayColumnsRaw >= 1 && displayColumnsRaw <= 4
		? Math.round(displayColumnsRaw)
		: 3;
const gridCls =
	displayColumns === 3
		? "grid w-full grid-cols-1 justify-items-center gap-10 md:grid-cols-2 xl:grid-cols-3"
		: "grid w-full grid-cols-1 justify-items-center gap-10 md:grid-cols-2 xl:grid-cols-[repeat(var(--cols),minmax(0,1fr))]";
const gridStyle = displayColumns === 3 ? undefined : `--cols:${displayColumns}`;

// Канон width (s/m/l/full): отсутствие/large = 1320 (литерал верстальщика),
// medium 1080, small 780, full — без лимита.
const widthCls =
	p.width === "small"
		? "max-w-[780px]"
		: p.width === "medium"
			? "max-w-[1080px]"
			: p.width === "full"
				? "max-w-none"
				: "max-w-[1320px]";

// Канон containerEnabled (canon-default ВЫКЛ — контракт дизайнера/паритет rose;
// legacy background.enabled). «Контейнер» в манере bloom = белая подложка карточки
// на цветном полотне (МАННЕРА §4): ВКЛ → карточки Benefits с подложкой; ВЫКЛ
// (дефолт) → содержимое без подложки прямо на полотне.
const containerEnabled = String(p.containerEnabled ?? p.background?.enabled ?? "false") === "true";
const cardSurfaceCls = containerEnabled
	? " rounded-[var(--radius-card,12px)] bg-[rgb(var(--color-surface,255_255_255))] px-6 py-8"
	: "";
// Канон containerColorScheme (hidden) — класс схемы на контейнере карточек.
// Канон Nikita: класс схемы вешаем ТОЛЬКО при включённом контейнере (при ВЫКЛ
// боксов-карточек нет → работает основная секционная схема).
const containerSchemeCls =
	containerEnabled && typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";

// Канон buttonText/buttonLink (hidden) — общая кнопка под гридом, белый pill
// манеры §3 (CTA на розовом полотне), рендер при непустом тексте.
const btnText = typeof p.buttonText === "string" && p.buttonText.trim() ? p.buttonText : undefined;
const btnHref =
	(typeof p.buttonLink === "string" && p.buttonLink ? p.buttonLink : undefined) ??
	(typeof p.link === "string" && p.link ? p.link : undefined) ??
	"/catalog";

// Шкалы per-item размеров (≈0.85/1.2 от литералов карточки §4):
// заголовок карточки 20 → small 17 / large 24; текст 16 → small 14 / large 19.
const itemHeadingCls = (s: string | undefined) =>
	s === "small" ? "text-[17px]" : s === "large" ? "text-[24px]" : "text-[20px]";
const itemTextCls = (s: string | undefined) =>
	s === "small" ? "text-[14px]" : s === "large" ? "text-[19px]" : "text-[16px]";

// Канон imageAspectRatio (adapt/square/portrait/landscape) — аспект медиа-обёртки
// колонки (порт rose MultiColumns:126-133): square (canon-default/отсутствие) |
// adapt (нативный) | portrait 430/500 | landscape 429/309. Раньше рендером
// ИГНОРИРОВАЛСЯ (изображение было захардкожено иконкой 44×44).
const aspectCls =
	p.imageAspectRatio === "adapt"
		? ""
		: p.imageAspectRatio === "portrait"
			? " aspect-[430/500]"
			: p.imageAspectRatio === "landscape"
				? " aspect-[429/309]"
				: " aspect-square";

// Per-колоночный imageSize (small/medium/large) — ширина медиа-обёртки внутри
// колонки (порт rose MultiColumns:174): medium/отсутствие = w-full, small = w-1/2.
// Раньше c.imageSize рендером ИГНОРИРОВАЛСЯ.
const itemImageCls = (s: string | undefined) =>
	s === "small" ? "w-1/2" : s === "large" ? "w-full" : "w-full";

// Канон textPosition (radio «Положение текста»): center → контент по центру,
// left/отсутствие → влево (порт rose MultiColumns:136). Раньше рендером
// ИГНОРИРОВАЛСЯ — карточка была захардкожена по центру (items-center text-center).
const textAlignCls = p.textPosition === "center" ? "items-center text-center" : "items-start text-left";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

// colorScheme навешивает обёрткой composeV2Page; фон секции — токен с РОЗОВЫМ
// литерал-фоллбеком верстальщика (#E38E9F = 227 142 159, МАННЕРА §7).
const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	id={id ? undefined : "benefits"}
	class="w-full bg-[rgb(var(--color-bg,227_142_159))] px-4 py-20 md:px-20 md:py-[120px] 2xl:px-[300px]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class={`mx-auto flex w-full ${widthCls} flex-col gap-10`}>
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-animate
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}
		<ul class={`${gridCls}${containerSchemeCls}`} role="list" style={gridStyle}>
			{
				columns.map((c, index) => (
					<li
						class={`group flex min-h-[252px] w-full max-w-[429px] flex-col ${textAlignCls} gap-6${cardSurfaceCls} transition-transform duration-300 ease-out hover:-translate-y-1`}
						data-animate
						data-animate-delay={`${index * 0.08}s`}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={index}
						data-puck-subsection-field="columns"
					>
						{c.image ? (
							<div
								class={`${itemImageCls(c.imageSize)} overflow-hidden rounded-[var(--radius-media,12px)] bg-[rgb(var(--color-surface,255_255_255))]${aspectCls}`}
							>
								<img
									src={c.image}
									alt=""
									loading="lazy"
									decoding="async"
									class="!h-full !w-full object-cover transition-transform duration-300 ease-out group-hover:scale-105"
								/>
							</div>
						) : (
							c.isPlaceholder && (
								<div
									class={`${itemImageCls(c.imageSize)} overflow-hidden rounded-[var(--radius-media,12px)] bg-[rgb(var(--color-surface,255_255_255))]${aspectCls}`}
									aria-hidden="true"
								/>
							)
						)}
						{c.heading && (
							<h3
								class={`font-urbanist ${itemHeadingCls(c.headingSize)} font-light uppercase leading-none text-[rgb(var(--color-heading,0_0_0))]`}
							>
								{c.heading}
							</h3>
						)}
						{c.text && (
							<p
								class={`font-inter ${itemTextCls(c.textSize)} font-light leading-none text-[rgb(var(--color-muted,153_153_153))]`}
								set:html={c.text}
							/>
						)}
						{c.link && (
							<a
								href={c.link.href}
								class="font-inter text-[16px] font-light leading-none text-[rgb(var(--color-text,0_0_0))] underline underline-offset-4 transition-opacity hover:opacity-70"
							>
								{c.link.text}
							</a>
						)}
					</li>
				))
			}
		</ul>
		{
			btnText && (
				<div class="flex justify-center" data-animate>
					<a
						href={btnHref}
						class="inline-flex h-12 items-center justify-center rounded-[var(--radius-button,100px)] bg-[rgb(var(--color-button-2-bg,255_255_255))] px-6 font-inter text-[16px] font-light leading-none text-[rgb(var(--color-button-2-text,0_0_0))] transition-opacity hover:opacity-90 active:scale-95"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="102"
						data-puck-subsection-field="buttonText"
					>
						{btnText}
					</a>
				</div>
			)
		}
	</div>
</section>
