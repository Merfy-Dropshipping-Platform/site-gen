---
// ОЖИВЛЕНИЕ (Фаза B, рецепт bloom Collections): конструкторная схема theme-base
// Collections.puckConfig поверх разметки верстальщика. Тело + demo-данные
// verbatim: страницы темы зовут <Collections items={...}/> и id="collections-2"
// с legacy-пропсами (index.astro:24,29) — их рендер не меняется (дефолт-ветки
// тернарников = прежние строки классов байт-в-байт; цвета → токены с
// пиксель-фоллбеком родных литералов, MANNER.md §7).
const p = Astro.props as Record<string, any>;
// id двойного назначения: legacy DOM-id верстальщика (index передаёт
// "collections-2", якорь Hero — "#collections") и Puck component id конструктора.
const id = p.id;
const domId = typeof p.id === "string" && p.id ? p.id : "collections";

// Legacy p.items[] верстальщика (страницы темы передают свои наборы плиток)
// БОЛЬШЕ НЕ рендерятся как demo — пустое состояние = плейсхолдер (см. ниже).

// Шапки у верстальщика НЕТ — заголовок/текст рендерятся ТОЛЬКО при непустом
// пропе (роль «заголовок секции» font-logo 20 / body 16 light muted, §1).
const rawTitle = (typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title;
const sectionTitle = typeof rawTitle === "string" && rawTitle.trim() ? rawTitle : undefined;
const sectionSubtitle =
	typeof p.subtitle === "string" && p.subtitle.trim() ? p.subtitle : undefined;

// Канон headingSize: 'medium' (canon-default) и отсутствие = роль «заголовок
// секции» дословно (20px, TextBlock.astro:15). Лестница §9: small 17, large 24.
// Приоритет top-level headingSize (live-селект «Размер заголовка»); nested
// heading.size — только legacy-фолбэк (сиды/миграции). Раньше nested читался
// ПЕРВЫМ и глушил живой селект (паритет rose Collections: top-level первым).
const headingSize = p.headingSize ?? p.heading?.size;
const headingCls =
	headingSize === "small"
		? "font-logo text-[17px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]"
		: headingSize === "large"
			? "font-logo text-[24px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]"
			: "font-logo text-[20px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]";
// Канон subtitleSize: 'small' (canon-default puckConfig) и отсутствие = body-роль
// манеры (Arsenal 16 light muted, catalog.astro:41); medium ≈1.2× (19),
// large ≈1.44× (23) — ряд bloom Collections от роли 16.
const subtitleCls =
	p.subtitleSize === "medium"
		? "font-manrope text-[19px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
		: p.subtitleSize === "large"
			? "font-manrope text-[23px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
			: "font-manrope text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]";
// Канон titleAlignment: отсутствие = заголовок слева (литерал манеры, без
// класса). Двигают только center/right. Зазор «шапка → грид» = mb-8 (манера §2).
const titleAlignCls =
	p.titleAlignment === "center" ? " text-center" : p.titleAlignment === "right" ? " text-right" : "";
const headWrapCls = `satin-container mb-8 flex flex-col gap-2${titleAlignCls}`;

// Канон columns 1-6: 3 (canon-default = sm:grid-cols-3 верстальщика) и
// отсутствие → дефолт-ветка; иное → inline-var на гриде с sm (mobile-лестница
// верстальщика grid-cols-2 сохраняется).
const colsRaw =
	typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : undefined;
const cols = colsRaw && colsRaw !== 3 ? colsRaw : undefined;
const gridBase = "satin-container grid grid-cols-2 gap-4 sm:grid-cols-3";
const gridCls = cols
	? "satin-container grid grid-cols-2 gap-4 sm:grid-cols-[repeat(var(--cols),minmax(0,1fr))]"
	: gridBase;
const gridStyle = cols ? `--cols:${cols}` : undefined;

// Канон imageView square/portrait/wide (+legacy alias gridAspect '1:1'→square):
// 'square' → квадрат 1:1 (Figma-паритет rose Collections), 'wide' → 16/9,
// 'portrait'/отсутствие/canon-default = плитка верстальщика 430/564 дословно
// (SatinCollectionCard — портретная манера satin). Раньше ветка 'square'
// отсутствовала и проваливалась в дефолт 430/564 → «Вид изображения: Квадрат»
// не применялся (только 'wide' работал). Класс кладётся напрямую на медиа-див
// плитки (манера satin), паритет rose (там — override-селектор на гриде).
const tileAspect =
	p.imageView === "square" || p.gridAspect === "1:1"
		? "aspect-square"
		: p.imageView === "wide"
			? "aspect-[16/9]"
			: "aspect-[430/564]";
// Канон cardCaptionStyle: 'uppercase' (canon-default) и отсутствие = родной
// капс подписи (CC:31-35); 'default' снимает капс.
const captionCase = p.cardCaptionStyle === "default" ? "" : " uppercase";

// Канон collections[] (≤10): плитки коллекций из пропса при непустом массиве.
// Имя/обложку выбранной коллекции резолвим SSR-фетчем storefront-data (см. ниже,
// паритет rose Popular.astro) → реальные данные видит и ПРЕВЬЮ конструктора;
// гидрация ниже (data-collection-ref) ещё раз освежает на live (collections.json).
// Паритет theme-base: имя коллекции перебивает ручной heading, обложка — только
// при пустой своей. Картинки нет → пустая surface-плитка (НЕ мок верстальщика).
//
// КОНТРАКТ ПЛЕЙСХОЛДЕРОВ (Figma 1:19335 — пустое состояние секции, ЗАМЕНЯЕТ
// мок-демо верстальщика). Эталон: rose Collections DEMO_COLLECTIONS — без
// ручного выбора рисуем N ПУСТЫХ карточек (rounded-rect surface-подложка, БЕЗ
// картинки) с подписью «Коллекция», НЕ плитки верстальщика (defaultCollections /
// legacy p.items: «Верхняя одежда» c /images/4x/Коллекция_N.png). Гейт = наличие
// ручного выбора коллекций в пикере (usePropCollections). Грид сохраняет
// data-collections-autofill → на live автоподстановка реальными коллекциями
// магазина (collections.json) перерисует его; demo-сборка без данных остаётся
// плейсхолдером. Дефолт — 3 карточки (canon-default columns 3), но уважаем
// выбранное число колонок (cols).
const PLACEHOLDER_COLLECTION_COUNT = cols ?? 3;
const placeholderCollections = Array.from({ length: PLACEHOLDER_COLLECTION_COUNT }, () => ({
	name: "Коллекция",
}));
const cardLinkBase =
	typeof p.cardLinkBase === "string" && p.cardLinkBase.trim() ? p.cardLinkBase : "/catalog?collection=";

// SSR-фетч реальных коллекций магазина (имя/обложка) для picker-выбранных плиток
// — паритет rose Popular.astro (Figma-цель: коллекция ВЫБРАНА → реальные данные
// ПРЯМО в статике, чтобы их видело и ПРЕВЬЮ конструктора; Astro Container не
// исполняет клиентскую module-гидрацию ниже). siteId инжектит рендер-пайплайн
// (preview.service / build). Нет siteId / ошибка / коллекция без обложки →
// image остаётся "" → пустая surface-плитка (НЕ мок /images/4x/Коллекция_N.png).
const siteId = typeof p.siteId === "string" ? p.siteId : "";
type RawCollection = { id?: string; name?: string; slug?: string; image?: string | null; images?: string[] };
let ssrCollections: RawCollection[] = [];
if (siteId && Array.isArray(p.collections) && p.collections.length) {
	try {
		const base = (import.meta as any).env?.SITES_INTERNAL_BASE ?? "http://localhost:3114";
		const res = await fetch(`${base}/api/sites/${siteId}/storefront-data`).catch(() => null);
		if (res && res.ok) {
			const data: any = await res.json();
			ssrCollections = Array.isArray(data?.collections) ? data.collections : [];
		}
	} catch {
		ssrCollections = [];
	}
}
const findSsrCollection = (ref: string | null): RawCollection | null => {
	if (!ref) return null;
	return (
		ssrCollections.find((c) => c && (c.id === ref || c.slug === ref || c.name === ref)) ?? null
	);
};
const ssrCover = (c: RawCollection | null): string =>
	(c && (c.image || (Array.isArray(c.images) ? c.images[0] : ""))) || "";

const propCollections = (Array.isArray(p.collections) ? p.collections : [])
	.filter((c: any) => c && typeof c === "object")
	.slice(0, 10)
	.map((c: any) => {
		const collectionId =
			typeof c.collectionId === "string" && c.collectionId.trim() ? c.collectionId.trim() : null;
		const ownImage = typeof c.image === "string" && c.image ? c.image : "";
		const real = findSsrCollection(collectionId);
		return {
			collectionId,
			name:
				(typeof c.heading === "string" && c.heading) ||
				(typeof c.name === "string" && c.name) ||
				(real?.name && String(real.name)) ||
				"Коллекция",
			// Картинка карточки: своя выбранная мерчантом → реальная обложка коллекции
			// из storefront-data (SSR) → "" (пустая surface-плитка, Figma 1:19335).
			// БЕЗ мок-фото верстальщика. На live гидрация (data-collection-ref) ещё
			// раз освежит из collections.json.
			image: ownImage || ssrCover(real),
			hasOwnImage: !!ownImage,
			href: collectionId ? `${cardLinkBase}${collectionId}` : "#",
		};
	});
const usePropCollections = propCollections.length > 0;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id={domId}
	class="satin-pad w-full bg-[rgb(var(--color-bg,255_255_255))] py-8 md:py-12"
	aria-label="Коллекции Satin"
	data-puck-component-id={id}
	style={paddingStyle}
>
	{(sectionTitle || sectionSubtitle) && (
		<div
			class={headWrapCls}
			data-puck-subsection-parent={id}
			data-puck-subsection-index="100"
			data-puck-subsection-field="heading"
		>
			{sectionTitle && <h2 class={headingCls}>{sectionTitle}</h2>}
			{sectionSubtitle && <p class={subtitleCls}>{sectionSubtitle}</p>}
		</div>
	)}
	<ul class={gridCls} role="list" style={gridStyle} data-collections-autofill={!usePropCollections ? "" : undefined}>
		{usePropCollections ? propCollections.map((c, i) => (
			<li class:list={[i === 0 && "col-span-2 sm:col-span-1"]}>
				<a
					href={c.href}
					class="group flex cursor-pointer flex-col gap-3"
					aria-label={c.name}
					data-nt="satin-collection-card"
					data-collection-ref={c.collectionId ?? undefined}
					data-own-image={c.hasOwnImage ? "true" : undefined}
					data-puck-subsection-parent={id}
					data-puck-subsection-index={i}
					data-puck-subsection-field="collections"
				>
					<div
						class={`${tileAspect} w-full overflow-hidden rounded-[var(--radius-media,0px)] bg-[rgb(var(--color-surface,245_245_245))]`}
						aria-hidden={c.image ? undefined : "true"}
					>
						{c.image && (
							<img
								src={c.image}
								alt={c.name}
								loading="lazy"
								class="!h-full !w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
							/>
						)}
					</div>
					<h3
						class={`satin-collection-name font-manrope text-[16px] font-normal leading-tight text-[rgb(var(--color-text,0_0_0))]${captionCase}`}
					>
						{c.name}
					</h3>
				</a>
			</li>
		)) : placeholderCollections.map((c, index) => (
			<li class:list={[index === 0 && "col-span-2 sm:col-span-1"]}>
				<div class="group flex flex-col gap-3" data-nt="satin-collection-card">
					<div
						class={`${tileAspect} w-full overflow-hidden rounded-[var(--radius-media,0px)] bg-[rgb(var(--color-surface,251_251_251))]`}
						aria-hidden="true"
					></div>
					<h3
						class={`satin-collection-name font-manrope text-[16px] font-normal leading-tight text-[rgb(var(--color-text,0_0_0))]${captionCase}`}
					>
						{c.name}
					</h3>
				</div>
			</li>
		))}
	</ul>
</section>

<script>
	import { loadRealCollections, findCollection, escapeHtml } from "../../lib/storefront-hydrate";

	// Резолв collectionId→имя/обложка на плитках (data-collection-ref).
	// Паритет theme-base resolveManual: имя коллекции перебивает ручной heading;
	// обложка коллекции подставляется, только если мерчант не загрузил свою
	// (data-own-image). Без данных (demo-сборка) — no-op, SSG остаётся.
	const hydrateCollectionTiles = async () => {
		const tiles = Array.from(
			document.querySelectorAll<HTMLElement>('[data-nt="satin-collection-card"][data-collection-ref]'),
		);
		if (tiles.length === 0) return;
		const collections = await loadRealCollections();
		if (!collections) return;
		for (const tile of tiles) {
			const col = findCollection(collections, tile.getAttribute("data-collection-ref"));
			if (!col) continue;
			if (col.name) {
				const h3 = tile.querySelector(".satin-collection-name");
				if (h3 && h3.textContent !== col.name) h3.textContent = col.name;
				tile.setAttribute("aria-label", col.name);
			}
			const cover = col.image || (Array.isArray(col.images) ? col.images[0] : "");
			if (cover && tile.getAttribute("data-own-image") !== "true") {
				const img = tile.querySelector("img");
				if (img && img.getAttribute("src") !== cover) {
					img.setAttribute("src", cover);
					if (col.name) img.setAttribute("alt", col.name);
				}
			}
		}
	};

	// АВТОПОДСТАНОВКА: пустой пикер (SSR = demo-плитки верстальщика) → реальные
	// коллекции магазина из /data/collections.json (live) / storefront-data (превью).
	// Прежде показывались фейк-демо, что вводило в заблуждение. Явный выбор в пикере
	// имеет приоритет (грид не помечен data-collections-autofill). Реальных нет
	// (demo-сборка без collections.json) → no-op, демо остаётся. Разметка плитки =
	// propCollections-ветка satin (canon-default при пустом пикере: imageView
	// 'square' → aspect-[430/564], cardCaptionStyle 'uppercase'; первая плитка =
	// col-span-2 sm:col-span-1, как в demo/prop-ветке). Обложка: реальная картинка
	// коллекции; нет своей — ПУСТАЯ surface-плитка (Figma 1:19335), БЕЗ мок-фото
	// верстальщика (/images/4x/Коллекция_N.png).
	const autofillCollections = async () => {
		const grids = Array.from(document.querySelectorAll<HTMLElement>("ul[data-collections-autofill]"));
		if (grids.length === 0) return;
		const collections = await loadRealCollections();
		if (!collections || collections.length === 0) return;
		const visible = collections.filter((c) => c && c.slug !== "general").slice(0, 6);
		if (visible.length === 0) return;
		const html = visible
			.map((c, i) => {
				const name = escapeHtml(c.name || "Коллекция");
				const ref = c.slug || c.id || "";
				const href = "/catalog?collection=" + encodeURIComponent(ref);
				const cover = c.image || (Array.isArray(c.images) ? c.images[0] : "") || "";
				const liCls = i === 0 ? " class=\"col-span-2 sm:col-span-1\"" : "";
				const media = cover
					? `<img src="${escapeHtml(cover)}" alt="${name}" loading="lazy" class="!h-full !w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]" />`
					: "";
				return `<li${liCls}><a href="${href}" class="group flex cursor-pointer flex-col gap-3" aria-label="${name}" data-nt="satin-collection-card">
			<div class="aspect-[430/564] w-full overflow-hidden rounded-[var(--radius-media,0px)] bg-[rgb(var(--color-surface,245_245_245))]"${cover ? "" : ' aria-hidden="true"'}>${media}</div>
			<h3 class="satin-collection-name font-manrope text-[16px] font-normal leading-tight text-[rgb(var(--color-text,0_0_0))] uppercase">${name}</h3>
		</a></li>`;
			})
			.join("");
		for (const grid of grids) grid.innerHTML = html;
	};

	hydrateCollectionTiles();
	autofillCollections();
	document.addEventListener("astro:page-load", () => {
		hydrateCollectionTiles();
		autofillCollections();
	});
</script>
