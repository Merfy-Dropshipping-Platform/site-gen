---
// Фаза B (vanilla, группа misc): канон-секция Publications в манере vanilla
// (см. themes/vanilla/MANNER.md §2/§4/§9/§11; эталон — themes/bloom Publications,
// rose-эталона нет). Схема полей = packages/theme-base/blocks/Publications/
// Publications.puckConfig.ts.
// ПУСТОЕ СОСТОЯНИЕ (нет реальных публикаций) = ПЛЕЙСХОЛДЕР по контракту Figma
// 1:19335 (колонки: пустой image-rect surface + «Колонна» + нейтральный текст),
// а НЕ мок-демо верстальщика (статьи про уют/плед + /images/vanilla-product-N.webp).
// Когда у магазина есть реальные публикации (SSR fetch /api/sites/<id>/publications
// → fallback publications.json) — рендерим их без изменений (Shopify-модель, как
// theme-base PopularProducts/Collections/MultiColumns: пустое = заглушка, данные =
// реальный контент). Платформенный резолв по publicationType остаётся
// data-атрибутом на гриде. Обложки реальных публикаций — прямой <img> (пути
// работают и в превью Container API).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading (string | { text, alignment, size }); canon-default «Публикации».
// Роль = заголовок секции §1 (Col:20, Bitter italic 20), токен heading 38_49_28.
const heading = typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Публикации");
// Лестница §9 (база-литерал 20 = canon-default medium): small 17, large 24.
const headingSize = p.headingSize ?? p.heading?.size;
const headingSizeCls =
	headingSize === "small" ? "text-[17px]" : headingSize === "large" ? "text-[24px]" : "text-[20px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-vanilla-bitter ${headingSizeCls} font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]${headingAlignCls}`;

// Канон columnsCount (slider 1-6) приоритетнее hidden columns (1-4); дефолт 3 =
// лестница товарного грида верстальщика (Pop:30, 1 → sm:2 → md:3); иное
// значение — CSS-var на md-брейкпоинте.
const columnsRaw =
	typeof p.columnsCount === "number" ? p.columnsCount : typeof p.columns === "number" ? p.columns : 3;
const columns = Math.max(1, Math.min(6, Math.round(columnsRaw) || 3));
const gridCls =
	columns === 3
		? "grid w-full grid-cols-1 gap-x-3 gap-y-9 sm:grid-cols-2 md:grid-cols-3 md:gap-x-4 md:gap-y-12"
		: "grid w-full grid-cols-1 gap-x-3 gap-y-9 sm:grid-cols-2 md:grid-cols-[repeat(var(--pub-cols),minmax(0,1fr))] md:gap-x-4 md:gap-y-12";
const gridStyle = columns === 3 ? undefined : `--pub-cols:${columns};`;

// Канон cardsCount (slider 1-12) приоритетнее hidden cards (1-4); дефолт 3 карточки.
const cardsRaw =
	typeof p.cardsCount === "number" ? p.cardsCount : typeof p.cards === "number" ? p.cards : 3;
const cards = Math.max(1, Math.min(12, Math.round(cardsRaw) || 3));

// Канон showDateTime (toggle) / legacy dateTime.enabled (hidden) — дата
// рендерится только при true/'true'.
const showDate = String(p.showDateTime ?? p.dateTime?.enabled ?? "false") === "true";

// Канон publicationType (pagePicker) — носитель data-атрибут на гриде для
// платформенного резолва публикаций.
const publicationType =
	typeof p.publicationType === "string" && p.publicationType ? p.publicationType : undefined;

// Реальные публикации: SSR fetch storefront-data (gateway → sites-service) с
// fallback на build-time publications.json (паттерн canonical theme-base
// Publications.astro + порт bloom). siteId инжектит build pipeline / preview
// controller. publications.json в теме vanilla может отсутствовать — import
// в try/catch (тогда realPublications остаётся пустым → плейсхолдер).
type RawPublication = {
	id: string;
	title?: string;
	slug?: string;
	excerpt?: string;
	coverImageUrl?: string | null;
	publishedAt?: string | null;
};
const siteIdFromRoot = typeof p.siteId === "string" ? p.siteId : "";
let realPublications: RawPublication[] = [];
if (siteIdFromRoot) {
	try {
		const internalBase =
			(import.meta as unknown as { env?: { SITES_INTERNAL_BASE?: string } }).env?.SITES_INTERNAL_BASE ??
			"http://localhost:3114";
		const res = await fetch(`${internalBase}/api/sites/${siteIdFromRoot}/publications`).catch(() => null);
		if (res && res.ok) {
			const data = (await res.json()) as { publications?: RawPublication[] };
			realPublications = data.publications ?? [];
		}
	} catch {
		/* swallow */
	}
}
try {
	if (realPublications.length === 0) {
		const pubData = await import("../data/publications.json");
		realPublications = ((pubData as { default?: RawPublication[] }).default ??
			(pubData as unknown as RawPublication[])) as RawPublication[];
	}
} catch {
	/* swallow — publications.json отсутствует */
}

function formatPubDate(iso: string | null | undefined): string {
	if (!iso) return "";
	try {
		return new Intl.DateTimeFormat("ru-RU", { day: "numeric", month: "long", year: "numeric" }).format(
			new Date(iso),
		);
	} catch {
		return "";
	}
}

// Гейт пустого состояния (Shopify-модель, паритет theme-base/blocks/Publications
// + порт bloom): есть реальные публикации → рендерим их без изменений; нет —
// ПЛЕЙСХОЛДЕР по контракту Figma 1:19335 (колонки: пустой image-rect surface +
// «Колонна» + нейтральный текст), а НЕ мок-демо верстальщика (статьи про уют/
// плед + /images/vanilla-product-N.webp). Текст-болванка в нейтральном тоне
// публикаций (как theme-base MultiColumns), не привязан к товарам/уходу.
const hasRealPublications = realPublications.length > 0;
const PLACEHOLDER_TEXT = "Поделись новостями бренда, гайдами и историями в этом блоке.";
type PubItem = { title: string; date: string; excerpt: string; image: string; slug?: string; isPlaceholder: boolean };
const items: PubItem[] = hasRealPublications
	? realPublications.slice(0, cards).map((pub) => ({
			title: pub.title ?? "",
			date: formatPubDate(pub.publishedAt),
			excerpt: pub.excerpt ?? "",
			image: pub.coverImageUrl ?? "",
			slug: pub.slug,
			isPlaceholder: false,
		}))
	: Array.from({ length: cards }, () => ({
			title: "Колонна",
			date: "",
			excerpt: PLACEHOLDER_TEXT,
			image: "",
			isPlaceholder: true,
		}));

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="vanilla-pad w-full bg-[rgb(var(--color-bg,238_238_238))] py-20 md:py-28"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="vanilla-container flex max-w-[1180px] flex-col gap-8">
		{
			heading && (
				<div class="flex max-w-[760px] flex-col gap-2" data-animate>
					<h2
						id={titleId}
						class={headingCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="100"
						data-puck-subsection-field="heading"
					>
						{heading}
					</h2>
				</div>
			)
		}

		<div
			class={gridCls}
			style={gridStyle}
			data-publication-type={publicationType}
			data-animate
			data-animate-delay="0.1s"
		>
			{
				items.map((item, i) => {
					const href = item.slug ? `/publication/${item.slug}` : undefined;
					const Wrapper = href ? "a" : "article";
					return (
						<Wrapper class="group flex flex-col gap-3" href={href} data-publication-index={i}>
							{/* Медиа: реальная обложка → <img>; пустое состояние (плейсхолдер
							   или публикация без обложки) → пустой image-rect surface
							   (контракт Figma 1:19335). */}
							<div class="relative aspect-square w-full overflow-hidden bg-[rgb(var(--color-surface,236_235_231))]">
								{item.image && (
									<img
										src={item.image}
										alt={item.title}
										loading="lazy"
										class="absolute inset-0 size-full object-cover transition-transform duration-300 group-hover:scale-105"
									/>
								)}
							</div>
							<div class="flex flex-col gap-1">
								{showDate && !item.isPlaceholder && item.date && (
									<span class="font-vanilla-arsenal text-[14px] font-normal leading-[1.45] text-[rgb(var(--color-muted,68_68_68))]">
										{item.date}
									</span>
								)}
								<span class="font-vanilla-arsenal text-base font-normal uppercase leading-none text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70">
									{item.title}
								</span>
								{item.excerpt && (
									<span class="font-vanilla-arsenal text-[14px] font-normal leading-[1.45] text-[rgb(var(--color-muted,68_68_68))]">
										{item.excerpt}
									</span>
								)}
							</div>
						</Wrapper>
					);
				})
			}
		</div>
	</div>
</section>
