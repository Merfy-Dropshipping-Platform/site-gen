                <span>{link.label}</span>
                <svg class="w-4 h-4 transition-transform submenu-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
              <div class={C.mobileMenu.submenuWrap} data-id={`submenu-${link.label}`}>
                {link.submenu?.map((sub) => (
                  <a href={sub.href} class={C.mobileMenu.submenuLink}>{sub.label}</a>
                ))}
              </div>
            </div>
          ) : (
            <a href={link.href} class={C.mobileMenu.link}>{link.label}</a>
          );
        })}
      </div>
      {showProfile && (
        <a href="/login" class:list={[C.mobileMenu.link, 'auth-nav-btn flex items-center gap-2']}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <span class="auth-nav-label">Войти</span>
        </a>
      )}
    </nav>
  </div>
</div>

<script is:inline>
  // Vanilla JS only. NB: do NOT add `<style>` block to this .astro file —
  // Astro compiler bakes a virtual `?astro&type=style` import into the
  // .mjs which then ENOENT-fails at runtime in Docker preview iframe.
  // Use inline-style/class toggles instead.
  (function () {
    // Mobile menu toggle.
    var mobileMenuButton = document.getElementById('mobile-menu-button');
    var mobileMenu = document.getElementById('mobile-menu');
    if (mobileMenuButton && mobileMenu) {
      var menuIcon = document.getElementById('menu-icon');
      mobileMenuButton.addEventListener('click', function () {
        mobileMenu.classList.toggle('hidden');
        var isOpen = !mobileMenu.classList.contains('hidden');
        mobileMenuButton.setAttribute('aria-expanded', String(isOpen));
        if (menuIcon) menuIcon.classList.toggle('menu-open', isOpen);
      });
    }

    // Submenu toggles in mobile drawer.
    document.querySelectorAll('.mobile-submenu-toggle').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var targetId = btn.getAttribute('data-target');
        var submenu = document.querySelector('.mobile-submenu[data-id="' + targetId + '"]');
        var arrow = btn.querySelector('.submenu-arrow');
        if (submenu) submenu.classList.toggle('hidden');
        if (arrow) arrow.classList.toggle('rotate-180');
      });
    });

    // Close mobile menu on link click inside drawer.
    var menuLinks = mobileMenu ? mobileMenu.querySelectorAll('a') : [];
    menuLinks.forEach(function (link) {
      link.addEventListener('click', function () {
        if (mobileMenu) mobileMenu.classList.add('hidden');
        if (mobileMenuButton) mobileMenuButton.setAttribute('aria-expanded', 'false');
        var icon = document.getElementById('menu-icon');
        if (icon) icon.classList.remove('menu-open');
      });
    });

    // Scroll-up stickiness — hide header on scroll-down, show on scroll-up.
    // Только если у wrapper применён `transition-transform` (sticky=scroll-up).
    (function () {
      var wrapper = document.querySelector('[data-header-wrapper][data-header-variant="rose-classic"]');
      if (!wrapper || !wrapper.classList.contains('transition-transform')) return;
      var lastScrollY = 0;
      window.addEventListener('scroll', function () {
        var currentScrollY = window.scrollY;
        if (currentScrollY < lastScrollY || currentScrollY < 10) {
          wrapper.style.transform = 'translateY(0)';
        } else {
          wrapper.style.transform = 'translateY(-100%)';
        }
        lastScrollY = currentScrollY;
      }, { passive: true });
    })();

    // Cart badge update (читает window.cartStore — глобал из storefront runtime).
    function updateCartBadge() {
      var badge = document.getElementById('cart-badge');
      if (!badge) return;
      var count = window.cartStore ? window.cartStore.getCount() : 0;
      if (count > 0) {
        badge.textContent = String(count > 99 ? '99+' : count);
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    }
    document.addEventListener('cart:updated', updateCartBadge);
    document.addEventListener('DOMContentLoaded', function () {
      setTimeout(updateCartBadge, 100);
    });

    // Mark add-to-cart buttons for products already in cart.
    function syncCartButtons() {
      if (!window.cartStore) return;
      var items = window.cartStore.getItems();
      var inCartIds = new Set(items.map(function (i) { return i.productId; }));
      document.querySelectorAll('.add-to-cart-btn').forEach(function (btn) {
        if (!(btn instanceof HTMLButtonElement)) return;
        var pid = btn.dataset.productId;
        if (pid && inCartIds.has(pid)) {
          btn.textContent = 'В корзине ✓';
          btn.classList.add('in-cart');
          btn.disabled = false;
        } else if (pid) {
          btn.textContent = 'В корзину';
          btn.classList.remove('in-cart');
          btn.disabled = false;
        }
      });
    }
    document.addEventListener('cart:updated', syncCartButtons);
    document.addEventListener('DOMContentLoaded', function () {
      setTimeout(syncCartButtons, 200);
    });

    // Delegated add-to-cart click handler.
    document.addEventListener('click', async function (e) {
      var target = e.target;
      if (!(target instanceof Element)) return;
      var btn = target.closest('.add-to-cart-btn');
      if (!btn || !(btn instanceof HTMLButtonElement)) return;
      var productId = btn.dataset.productId;
      if (!productId || !window.cartStore) return;

      var items = window.cartStore.getItems();
      var existingItem = items.find(function (i) { return i.productId === productId; });
      var maxStock = btn.dataset.stock ? parseInt(btn.dataset.stock, 10) : null;

      if (existingItem) {
        if (maxStock !== null && existingItem.quantity >= maxStock) {
          btn.textContent = 'Макс. ' + maxStock + ' шт.';
          setTimeout(function () { btn.textContent = 'В корзине ✓'; }, 1500);
          return;
        }
        if (window.cartDrawer) window.cartDrawer.open();
        return;
      }

      if (maxStock !== null && maxStock <= 0) {
        btn.textContent = 'Нет в наличии';
        btn.disabled = true;
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Добавляем...';
      var ok = await window.cartStore.addItem(productId, null, 1);
      if (ok) {
        btn.textContent = 'В корзине ✓';
        btn.classList.add('in-cart');
        btn.disabled = false;
      } else {
        btn.textContent = 'Ошибка';
        setTimeout(function () {
          btn.textContent = 'В корзину';
          btn.disabled = false;
        }, 1500);
      }
    });

    // Auth-aware nav button: rewrites href + label если пользователь залогинен.
    document.querySelectorAll('.auth-nav-btn').forEach(function (link) {
      if (window.CustomerStore && window.CustomerStore.isLoggedIn && window.CustomerStore.isLoggedIn()) {
        link.setAttribute('href', '/account');
        link.setAttribute('aria-label', 'Личный кабинет');
        var label = link.querySelector('.auth-nav-label');
        if (label) label.textContent = 'Личный кабинет';
      }
    });

    // Cart action — читает --cart-type CSS var:
    //   'drawer' → preventDefault + window.cartDrawer.open()
    //   default → нативная навигация на /cart
    // Меняется через Theme Settings → Корзина (Сайдбар/Страница).
    document.querySelectorAll('a[data-action="cart"]').forEach(function (cartLink) {
      cartLink.addEventListener('click', function (e) {
        var cartType = getComputedStyle(document.documentElement)
          .getPropertyValue('--cart-type')
          .trim()
          .replace(/['"]/g, '');
        if (cartType !== 'drawer') return;
        if (!window.cartDrawer || typeof window.cartDrawer.open !== 'function') return;
        e.preventDefault();
        window.cartDrawer.open();
      });
    });
  })();
</script>
