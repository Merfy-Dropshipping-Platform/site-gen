---
import type { PageProps } from './Page.puckConfig';
import { PageClasses as C } from './Page.classes';
import { PLACEHOLDER_DOC } from '../../runtime/placeholders';

interface Props extends PageProps {
  id?: string;
}

const { id, pageId, colorScheme, padding } = Astro.props as Props;
const raw = Astro.props as Record<string, unknown>;

const schemeClass = typeof colorScheme === 'string' && colorScheme
  ? `color-scheme-${colorScheme.replace('scheme-', '')}`
  : '';
const paddingStyle = padding
  ? `padding-top:${padding.top}px;padding-bottom:${padding.bottom}px;`
  : '';

// SSR resolve page meta (title + path) для embed-карточки.
const siteIdFromRoot = typeof raw.siteId === 'string' ? raw.siteId : '';
type PageMeta = { id: string; title: string; slug: string; path: string; url?: string };
let pageMeta: PageMeta | null = null;

if (pageId && siteIdFromRoot) {
  try {
    const internalBase = (import.meta as unknown as { env?: { SITES_INTERNAL_BASE?: string } }).env?.SITES_INTERNAL_BASE
      ?? 'http://localhost:3114';
    const res = await fetch(`${internalBase}/api/sites/${siteIdFromRoot}/page-meta?pageId=${encodeURIComponent(pageId)}`).catch(() => null);
    if (res && res.ok) {
      const data = (await res.json()) as { page?: PageMeta };
      pageMeta = data.page ?? null;
    }
  } catch {/* swallow */}
}
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-page-embed
  data-page-id={pageId || ''}
  style={paddingStyle}
>
  <div class={C.container}>
    {pageMeta ? (
      <a href={pageMeta.path} class={`${C.placeholder} hover:bg-[rgb(var(--color-surface))]/80 transition-colors no-underline flex-col gap-3`}>
        <div class="w-12 h-12 text-[rgb(var(--color-text))]"><Fragment set:html={PLACEHOLDER_DOC} /></div>
        <p class={C.text}>{pageMeta.title}</p>
        <p class="text-xs [font-family:var(--font-body)] text-[rgb(var(--color-muted))]/70">{pageMeta.path}</p>
      </a>
    ) : pageId ? (
      <div class={`${C.placeholder} flex-col gap-3`}>
        <div class="w-12 h-12 text-[rgb(var(--color-text))]"><Fragment set:html={PLACEHOLDER_DOC} /></div>
        <p class={C.text}>Страница «{pageId}» не найдена</p>
      </div>
    ) : (
      <div class={`${C.placeholder} flex-col gap-3`}>
        <div class="w-12 h-12 text-[rgb(var(--color-text))]"><Fragment set:html={PLACEHOLDER_DOC} /></div>
        <p class={C.text}>Выберите страницу в правом меню</p>
      </div>
    )}
  </div>
</section>
