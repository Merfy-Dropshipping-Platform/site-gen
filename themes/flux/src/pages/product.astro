---
/**
 * Универсальная страница товара `/product` (Option B, спек 098 + live-wiring).
 *
 * Реальные товары не имеют статических `/products/{id}` страниц (getStaticPaths
 * знает только demo на сборке сервиса). Эта одна страница рендерит нейтральный
 * skeleton; вся live-гидрация (определение товара по slug пути / ?id= /
 * __MERFY_DEFAULT_PRODUCT_ID__, заполнение data-pdp-* хуков, варианты, корзина,
 * галерея, «Товар не найден») выполняется единым `is:inline`-скриптом ВНУТРИ
 * `FluxProductDetail`. Источник — ЖИВОЙ `/api/store/products` (как каталог flux),
 * с фолбэком на per-site `/data/products.json` и preview storefront-data.
 * Разметка — общий `FluxProductDetail` (parity с demo `[id].astro`).
 */
import Layout from "../layouts/Layout.astro";
import FluxProductDetail from "../components/products/FluxProductDetail.astro";
import type { Product } from "../types/product";

// Нейтральный skeleton: рендерится до клиентской гидрации (и на demo-сборке без
// данных). placeholder-картинка, без галереи/бренда/старой цены.
const skeleton = {
	id: "",
	name: "Товар",
	price: "",
	image: "/images/placeholder.png",
} as Product;
---

<Layout title="Товар">
	{/* Вся live-гидрация PDP живёт ВНУТРИ FluxProductDetail.astro единым
	    is:inline-скриптом — он работает на обоих маршрутах (`/product` и demo
	    `products/[id]`) и на live (theme dist), где module-<script> страницы не
	    компилится. Здесь — только скелетон; прежний дублирующий хелпер-скрипт
	    (storefront-hydrate, читал только products.json) убран, чтобы не было
	    двойной конфликтующей гидрации. Блок «Товар не найден» переехал в компонент. */}
	<FluxProductDetail product={skeleton} />
</Layout>
