---
import Layout from "../../layouts/Layout.astro";
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import NtVariantTextRow from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtVariantTextRow.astro";
import BloomPicture from "../../components/img/BloomPicture.astro";
import { catalogProducts } from "../../data/products";

export const getStaticPaths = () =>
	catalogProducts.map((product) => ({
		params: { id: product.id },
		props: { product },
	}));

const { product } = Astro.props;

const colorLabels: Record<string, string> = {
	brown: "Коричневый",
	black: "Чёрный",
	white: "Белый",
	olive: "Оливковый",
	gray: "Серый",
};

const colors = product.colors.map((color, index) => ({
	id: color,
	label: colorLabels[color] ?? color,
	unavailable: index === product.colors.length - 1 && product.colors.length > 1,
}));

const galleryImages = product.gallery && product.gallery.length > 0 ? product.gallery : [product.image];
const [mainImage, ...thumbs] = galleryImages;
---

<Layout title={product.name} description={product.description}>
	<section
		class="w-full bg-white px-4 pb-[80px] pt-10 md:px-20 md:pb-[120px] md:pt-16 2xl:px-[300px]"
		aria-labelledby="product-title"
	>
		<div class="mx-auto grid w-full max-w-[1320px] grid-cols-1 gap-8 lg:grid-cols-[600px_minmax(0,1fr)] lg:gap-10">
			<div class="flex flex-col gap-4">
				<div class="relative aspect-square w-full overflow-hidden bg-[#F5F5F5]">
					<BloomPicture
						src={mainImage}
						alt={product.name}
						loading="eager"
						fetchpriority="high"
						class="h-full w-full object-contain"
						data-pdp-main
					/>
					{product.discount && (
						<span class="absolute left-3 top-3 inline-flex h-6 items-center rounded-[4px] bg-[#000000] px-1.5 font-manrope text-[12px] font-normal leading-none text-white">
							Скидка
						</span>
					)}
				</div>
				{thumbs.length > 0 && (
					<div class="grid grid-cols-3 gap-4">
						{[mainImage, ...thumbs].slice(0, 6).map((img) => (
							<button
								type="button"
								class="aspect-square w-full overflow-hidden bg-[#F5F5F5] transition-opacity hover:opacity-90"
								data-pdp-thumb
								data-image={img}
								aria-label="Показать изображение"
							>
								<BloomPicture
									src={img}
									alt={product.name}
									loading="eager"
									class="h-full w-full object-contain"
								/>
							</button>
						))}
					</div>
				)}
			</div>

			<div class="flex flex-col gap-10">
				<div class="flex flex-col gap-2">
					{product.brand && (
						<p class="font-manrope text-[14px] font-light leading-normal text-[#999999]">
							{product.brand}
						</p>
					)}
					<h1
						id="product-title"
						class="font-comfortaa text-[28px] font-normal uppercase leading-[1.115] text-[#000000] md:text-[32px] lg:text-[36px]"
					>
						{product.name}
					</h1>
					<div class="flex flex-wrap items-baseline gap-2">
						<span class="font-manrope text-[20px] font-normal leading-normal text-[#000000] md:text-[24px]">
							{product.price}
						</span>
						{product.oldPrice && (
							<span class="font-manrope text-[16px] font-light leading-normal text-[#999999] line-through md:text-[18px]">
								{product.oldPrice}
							</span>
						)}
					</div>
				</div>

				<div class="flex flex-col gap-6">
					<NtVariantTextRow
						items={colors}
						selectedId={colors[0]?.id}
						groupLabel="Цвет"
						groupName="pdp-color"
					/>

					<div class="flex h-10 w-fit items-center rounded-[4px] border border-[#F5F5F5]" data-pdp-qty>
						<button
							type="button"
							class="flex size-10 items-center justify-center transition-opacity hover:opacity-80"
							aria-label="Уменьшить количество"
							data-action="qty-dec"
						>
							<NtIcon name="minus" sizeClass="size-4" />
						</button>
						<input
							type="number"
							min="1"
							value="1"
							class="h-10 w-12 bg-transparent text-center font-manrope text-[14px] font-normal leading-normal text-[#000000] outline-none"
							aria-label="Количество"
							data-pdp-qty-value
						/>
						<button
							type="button"
							class="flex size-10 items-center justify-center transition-opacity hover:opacity-80"
							aria-label="Увеличить количество"
							data-action="qty-inc"
						>
							<NtIcon name="plus" sizeClass="size-4" />
						</button>
					</div>
				</div>

				<div class="flex flex-col gap-3">
					<button
						type="button"
						data-add-to-cart
						data-product-id={product.id}
						data-name={product.name}
						data-price={product.price}
						data-old-price={product.oldPrice ?? ""}
						data-image={product.image}
						data-volume={product.volume ?? ""}
						data-variant-color={product.colors[0] ?? ""}
						data-quantity="1"
						class="inline-flex h-12 items-center justify-center rounded-[6px] border border-[#000000] bg-white px-4 font-manrope text-[16px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-90"
					>
						Добавить в корзину
					</button>
					<button
						type="button"
						data-action="buy-now"
						data-product-id={product.id}
						data-name={product.name}
						data-price={product.price}
						data-image={product.image}
						data-volume={product.volume ?? ""}
						class="inline-flex h-12 items-center justify-center rounded-[6px] bg-[#000000] px-4 font-manrope text-[16px] font-normal leading-normal text-white transition-opacity hover:opacity-95"
					>
						Купить сейчас
					</button>
				</div>

				<div class="flex flex-col gap-4">
					<h2 class="font-comfortaa text-[18px] font-normal uppercase leading-normal text-[#000000]">
						Описание
					</h2>
					<p class="font-manrope text-[14px] font-light leading-[1.5] text-[#999999] md:text-[15px]">
						{product.description}
					</p>
					<button
						type="button"
						data-action="share"
						class="inline-flex w-fit items-center gap-2 font-manrope text-[14px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-70"
						aria-label="Поделиться"
					>
						<NtIcon name="share" sizeClass="size-5" />
						<span>Поделиться</span>
					</button>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	const main = document.querySelector<HTMLImageElement>("[data-pdp-main]");
	document.querySelectorAll<HTMLButtonElement>("[data-pdp-thumb]").forEach((thumb) => {
		thumb.addEventListener("click", () => {
			const src = thumb.dataset.image;
			if (main && src) {
				main.src = src;
			}
			document.querySelector<HTMLElement>("[data-add-to-cart]")?.setAttribute("data-image", src ?? "");
			document.querySelector<HTMLElement>("[data-action='buy-now']")?.setAttribute("data-image", src ?? "");
		});
	});

	const qtyInput = document.querySelector<HTMLInputElement>("[data-pdp-qty-value]");
	document.querySelector<HTMLButtonElement>("[data-action='qty-dec']")?.addEventListener("click", () => {
		if (!qtyInput) return;
		const next = Math.max(1, Number(qtyInput.value || 1) - 1);
		qtyInput.value = String(next);
		syncQtyToAddButton(next);
	});
	document.querySelector<HTMLButtonElement>("[data-action='qty-inc']")?.addEventListener("click", () => {
		if (!qtyInput) return;
		const next = Number(qtyInput.value || 1) + 1;
		qtyInput.value = String(next);
		syncQtyToAddButton(next);
	});
	qtyInput?.addEventListener("input", () => {
		const value = Math.max(1, Number(qtyInput.value || 1));
		qtyInput.value = String(value);
		syncQtyToAddButton(value);
	});

	const syncQtyToAddButton = (qty: number) => {
		document.querySelector<HTMLButtonElement>("[data-add-to-cart]")?.setAttribute("data-quantity", String(qty));
	};

	document.querySelectorAll<HTMLElement>("[data-nt='variant-text-row'] button[role='radio']").forEach((btn) => {
		btn.addEventListener("click", () => {
			const group = btn.closest<HTMLElement>("[data-nt='variant-text-row']");
			group?.querySelectorAll("button[role='radio']").forEach((b) => {
				b.setAttribute("aria-checked", "false");
				b.classList.remove("bg-[#000000]", "text-[#FFFFFF]");
				b.classList.add("border", "border-[#000000]", "text-[#000000]");
			});
			btn.setAttribute("aria-checked", "true");
			btn.classList.add("bg-[#000000]", "text-[#FFFFFF]");
			btn.classList.remove("border", "border-[#000000]", "text-[#000000]");
			const addBtn = document.querySelector<HTMLElement>("[data-add-to-cart]");
			addBtn?.setAttribute("data-variant-color", btn.getAttribute("data-id") ?? "");
		});
	});

	document.querySelector<HTMLButtonElement>("[data-action='share']")?.addEventListener("click", async () => {
		try {
			if (navigator.share) {
				await navigator.share({ title: document.title, url: location.href });
			} else {
				await navigator.clipboard.writeText(location.href);
				alert("Ссылка скопирована");
			}
		} catch {
			/* пользователь отменил */
		}
	});

	document.querySelector<HTMLButtonElement>("[data-action='buy-now']")?.addEventListener("click", () => {
		const add = document.querySelector<HTMLElement>("[data-add-to-cart]");
		add?.dispatchEvent(new MouseEvent("click", { bubbles: true }));
		window.location.href = "/cart";
	});
</script>
