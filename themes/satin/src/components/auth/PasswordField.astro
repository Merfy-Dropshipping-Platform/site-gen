---
/**
 * PasswordField — поле пароля с eye-toggle (vanilla, БЕЗ React island).
 * Заменяет templates-версию на PasswordEyeToggle.tsx (client:load) — порт
 * сторфронта без React. Toggle через делегат по [data-password-toggle].
 */
interface Props {
  label: string;
  name: string;
  id?: string;
  placeholder?: string;
  required?: boolean;
  autocomplete?: string;
  minlength?: number;
  error?: string;
}
const {
  label,
  name,
  id = name,
  placeholder,
  required,
  autocomplete = 'current-password',
  minlength,
  error,
} = Astro.props;
---
<div class="flex flex-col items-start gap-2 w-full">
  <label for={id} class="auth-label">
    {label}{required && <span class="auth-required"> *</span>}
  </label>
  <div class="auth-password-wrapper">
    <input
      type="password"
      id={id}
      name={name}
      placeholder={placeholder}
      required={required}
      autocomplete={autocomplete}
      minlength={minlength}
      data-error={error ? 'true' : 'false'}
      class="auth-input"
    />
    <button
      type="button"
      class="auth-eye-toggle"
      data-password-toggle={id}
      aria-label="Показать пароль"
      data-testid={`password-eye-toggle-${id}`}
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M10 4.5C5 4.5 1.73 8.11 0.75 10c0.98 1.89 4.25 5.5 9.25 5.5s8.27-3.61 9.25-5.5C18.27 8.11 15 4.5 10 4.5zm0 9c-1.93 0-3.5-1.57-3.5-3.5S8.07 6.5 10 6.5s3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5zm0-5.5a2 2 0 1 0 0 4 2 2 0 0 0 0-4z" fill="currentColor"/>
      </svg>
    </button>
  </div>
  {error && <span class="auth-helper-error" data-error-for={id}>{error}</span>}
  {!error && <span class="auth-helper-error hidden" data-error-for={id}></span>}
</div>

<script is:inline>
  // Делегат eye-toggle (vanilla, идемпотентно по флагу).
  (function () {
    if (window.__rosePwToggleBound) return;
    window.__rosePwToggleBound = true;
    document.addEventListener('click', function (e) {
      var t = e.target;
      var btn = t && t.closest ? t.closest('[data-password-toggle]') : null;
      if (!btn) return;
      var input = document.getElementById(btn.getAttribute('data-password-toggle'));
      if (!input) return;
      var show = input.type === 'password';
      input.type = show ? 'text' : 'password';
      btn.setAttribute('aria-label', show ? 'Скрыть пароль' : 'Показать пароль');
    });
  })();
</script>
