{
  "$schema": "https://merfy.ru/schemas/theme-manifest.v2.json",
  "id": "flux",
  "name": "Flux",
  "version": "1.0.0",
  "extends": "@merfy/theme-base@workspace:*",
  "category": "electronics",
  "description": "Flux — modern dark theme with orange accent (#fa5109), Roboto Flex headings + body, medium (6px) button radii for tech and electronics stores.",
  "author": "Merfy",
  "tokens": "./tokens.json",
  "defaults": {
    "--font-heading": "'Roboto Flex', sans-serif",
    "--font-body": "'Roboto Flex', sans-serif",
    "--weight-heading": "600",
    "--weight-body": "400",
    "--container-max-width": "1320px",
    "--radius-button": "6px",
    "--radius-input": "8px",
    "--radius-card": "12px",
    "--radius-media": "8px",
    "--radius-field": "4px",
    "--size-hero-heading": "72px",
    "--size-hero-button-h": "48px",
    "--size-section-heading": "24px",
    "--size-nav-link": "16px",
    "--size-newsletter-form-w": "480px",
    "--size-logo-width": "24px",
    "--size-card-border": "1px",
    "--catalog-sidebar-w": "318px",
    "--size-catalog-title": "20px",
    "--size-catalog-subtitle": "16px",
    "--weight-catalog-title": "400",
    "--spacing-section-y": "64px",
    "--spacing-grid-col-gap": "40px",
    "--spacing-grid-row-gap": "40px",
    "--button-style": "solid",
    "--footer-layout": "2-part",
    "--contact-form-layout": "wide",
    "--cart-type": "drawer",
    "--card-style": "card",
    "--card-alignment": "left",
    "--color-error": "255 148 148"
  },
  "blockDefaults": {
    "Footer": {
      "variant": "3-col",
      "newsletter": {
        "enabled": true,
        "heading": "Подпишитесь на нашу рассылку",
        "description": "Введите электронную почту и получайте информацию нашего бренда",
        "placeholder": "flux@example.ru"
      },
      "navigationColumn": {
        "title": "Навигация",
        "links": [
          {
            "label": "Смартфоны",
            "href": "/catalog"
          },
          {
            "label": "Наушники",
            "href": "/catalog"
          },
          {
            "label": "Ноутбуки",
            "href": "/catalog"
          },
          {
            "label": "Аксессуары",
            "href": "/catalog"
          }
        ]
      },
      "informationColumn": {
        "title": "Информация",
        "links": [
          {
            "label": "Политика доставки",
            "href": "/legal/delivery"
          },
          {
            "label": "Политика возврата",
            "href": "/legal/returns"
          },
          {
            "label": "Условия обслуживания",
            "href": "/legal/terms"
          },
          {
            "label": "Политика конфиденциальности",
            "href": "/legal/privacy"
          }
        ]
      },
      "socialColumn": {
        "title": "Социальные сети",
        "email": "flux@example.ru",
        "socialLinks": [
          {
            "platform": "telegram",
            "href": "#"
          },
          {
            "platform": "vk",
            "href": "#"
          },
          {
            "platform": "youtube",
            "href": "#"
          },
          {
            "platform": "dzen",
            "href": "#"
          },
          {
            "platform": "tiktok",
            "href": "#"
          }
        ]
      },
      "copyright": {
        "poweredBy": "Powered by Merfy",
        "showYear": true
      },
      "padding": {
        "top": 64,
        "bottom": 64
      }
    },
    "Header": {
      "variant": "two-tier",
      "promoBar": {
        "enabled": true,
        "text": "Бесплатная доставка на весь ассортимент до 30.06.2026.",
        "linkText": "смотреть больше",
        "linkHref": "/promo"
      }
    },
    "Collections": {
      "variant": "tile"
    },
    "PopularProducts": {
      "cardVariant": "rich"
    },
    "Catalog": {
      "categoryTitle": "СМАРТФОНЫ",
      "categorySubtitle": "M Phone",
      "categorySubtitleColor": "accent",
      "productCard": {
        "buttonStyle": "primary",
        "cardBackground": "true",
        "cardStyle": "square",
        "quickAdd": "cart"
      },
      "filterPosition": "side",
      "showSort": "true",
      "showFilter": "true",
      "columns": 3,
      "padding": {
        "top": 80,
        "bottom": 80
      }
    },
    "Product": {
      "visualConfig": {
        "gallery": {
          "variant": "inline-small",
          "showDiscountBadge": false
        },
        "variantsType": "dropdown",
        "counter": {
          "variant": "pill"
        },
        "showDescription": false
      }
    },
    "Hero": {
      "backgroundImages": {
        "url1": "https://minio.merfy.ru/product-images/f92e309e-009c-4e15-85cc-87a59a439dea.png"
      }
    },
    "ImageWithText": {
      "image": {
        "url": "https://minio.merfy.ru/product-images/f76f3053-7cfa-4823-894a-ce30fee3f1e0.png",
        "alt": ""
      }
    },
    "Gallery": {
      "items": [
        {
          "id": "item-1",
          "type": "image",
          "url": "https://minio.merfy.ru/product-images/f76f3053-7cfa-4823-894a-ce30fee3f1e0.png",
          "alt": "Изображение"
        },
        {
          "id": "item-2",
          "type": "image",
          "url": "https://minio.merfy.ru/product-images/cdc1fcbd-6e1e-4ac6-b734-5978ce57e2f5.png",
          "alt": "Изображение"
        },
        {
          "id": "item-3",
          "type": "image",
          "url": "https://minio.merfy.ru/product-images/113f237c-bc9d-4026-940f-362c34d5edef.png",
          "alt": "Изображение"
        }
      ]
    },
    "Slideshow": {
      "slides": [
        {
          "id": "slide-1",
          "imageUrl": "https://minio.merfy.ru/product-images/f92e309e-009c-4e15-85cc-87a59a439dea.png",
          "ctaUrl": "/catalog"
        },
        {
          "id": "slide-2",
          "imageUrl": "https://minio.merfy.ru/product-images/e901c239-7331-4421-854c-5cdbfd2200a7.png",
          "ctaUrl": "/catalog"
        }
      ]
    },
    "MultiRows": {
      "rows": [
        {
          "id": "row-1",
          "imageUrl": "https://minio.merfy.ru/product-images/cdc1fcbd-6e1e-4ac6-b734-5978ce57e2f5.png"
        },
        {
          "id": "row-2",
          "imageUrl": "https://minio.merfy.ru/product-images/113f237c-bc9d-4026-940f-362c34d5edef.png"
        }
      ]
    },
    "MultiColumns": {
      "columns": [
        {
          "id": "col-1",
          "heading": "Колонка 1",
          "text": "",
          "imageUrl": "https://minio.merfy.ru/product-images/f92e309e-009c-4e15-85cc-87a59a439dea.png"
        },
        {
          "id": "col-2",
          "heading": "Колонка 2",
          "text": "",
          "imageUrl": "https://minio.merfy.ru/product-images/f76f3053-7cfa-4823-894a-ce30fee3f1e0.png"
        },
        {
          "id": "col-3",
          "heading": "Колонка 3",
          "text": "",
          "imageUrl": "https://minio.merfy.ru/product-images/cdc1fcbd-6e1e-4ac6-b734-5978ce57e2f5.png"
        }
      ]
    }
  },
  "colorSchemes": [
    {
      "id": "scheme-1",
      "name": "1",
      "tokens": {
        "--color-bg": "0 0 0",
        "--color-surface": "26 26 26",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "204 204 204",
        "--color-primary": "255 255 255",
        "--color-accent": "250 81 9",
        "--color-button-bg": "250 81 9",
        "--color-button-text": "255 255 255",
        "--color-button-border": "250 81 9",
        "--color-button-secondary-bg": "255 255 255",
        "--color-button-secondary-text": "0 0 0",
        "--color-button-secondary-border": "255 255 255",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "255 255 255"
      }
    },
    {
      "id": "scheme-2",
      "name": "2",
      "tokens": {
        "--color-bg": "255 255 255",
        "--color-surface": "251 251 251",
        "--color-heading": "0 0 0",
        "--color-text": "0 0 0",
        "--color-muted": "204 204 204",
        "--color-primary": "0 0 0",
        "--color-accent": "250 81 9",
        "--color-button-bg": "250 81 9",
        "--color-button-text": "255 255 255",
        "--color-button-border": "250 81 9",
        "--color-button-secondary-bg": "0 0 0",
        "--color-button-secondary-text": "255 255 255",
        "--color-button-secondary-border": "0 0 0",
        "--color-button-2-bg": "0 0 0",
        "--color-button-2-text": "255 255 255",
        "--color-button-2-border": "0 0 0"
      }
    },
    {
      "id": "scheme-3",
      "name": "3",
      "tokens": {
        "--color-bg": "250 250 250",
        "--color-surface": "245 245 245",
        "--color-heading": "0 0 0",
        "--color-text": "0 0 0",
        "--color-muted": "204 204 204",
        "--color-primary": "0 0 0",
        "--color-accent": "250 81 9",
        "--color-button-bg": "250 81 9",
        "--color-button-text": "255 255 255",
        "--color-button-border": "250 81 9",
        "--color-button-secondary-bg": "0 0 0",
        "--color-button-secondary-text": "255 255 255",
        "--color-button-secondary-border": "0 0 0",
        "--color-button-2-bg": "0 0 0",
        "--color-button-2-text": "255 255 255",
        "--color-button-2-border": "0 0 0"
      }
    },
    {
      "id": "scheme-4",
      "name": "4",
      "tokens": {
        "--color-bg": "11 11 11",
        "--color-surface": "26 26 26",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "204 204 204",
        "--color-primary": "255 255 255",
        "--color-accent": "250 81 9",
        "--color-button-bg": "250 81 9",
        "--color-button-text": "255 255 255",
        "--color-button-border": "250 81 9",
        "--color-button-secondary-bg": "255 255 255",
        "--color-button-secondary-text": "11 11 11",
        "--color-button-secondary-border": "255 255 255",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "11 11 11",
        "--color-button-2-border": "255 255 255"
      }
    }
  ],
  "blocks": {
    "Header": {
      "override": {
        "path": "./blocks/Header",
        "reason": "Flux uses 1320px container, Roboto Flex bold headings, orange-accent cart badge with 2px badge radius, and 6px button radius for tech/electronics aesthetic."
      }
    },
    "Hero": {
      "variant": "overlay"
    },
    "PopularProducts": {},
    "Collections": {},
    "Product": {},
    "Newsletter": {},
    "ContactForm": {}
  },
  "features": {
    "newsletter": true,
    "cart-drawer": true,
    "otp-auth": true,
    "wishlist": false,
    "color-swatches": true,
    "filter-sidebar": true,
    "puckDrivenPages": true
  },
  "fonts": [
    {
      "family": "Roboto Flex",
      "weights": [
        300,
        400,
        500,
        600,
        700
      ],
      "source": "google"
    },
    {
      "family": "Barlow",
      "weights": [
        400,
        500
      ],
      "source": "google"
    },
    {
      "family": "Inter",
      "weights": [
        300,
        400
      ],
      "source": "google"
    }
  ],
  "manifestVersion": "2.0",
  "pages": [
    {
      "id": "home",
      "name": "Главная страница",
      "slug": "/",
      "role": "system",
      "contentFile": "pages/home.json",
      "isHome": true
    },
    {
      "id": "page-about",
      "name": "О нас",
      "slug": "/about",
      "role": "system",
      "contentFile": "pages/about.json"
    },
    {
      "id": "page-delivery",
      "name": "Доставка",
      "slug": "/delivery",
      "role": "system",
      "contentFile": "pages/delivery.json"
    },
    {
      "id": "page-contacts",
      "name": "Контакты",
      "slug": "/contacts",
      "role": "system",
      "contentFile": "pages/contacts.json"
    },
    {
      "id": "page-catalog",
      "name": "Коллекции",
      "slug": "/catalog",
      "role": "system",
      "contentFile": "pages/catalog.json"
    },
    {
      "id": "page-collection",
      "name": "Страница коллекции",
      "slug": "/collections/preview",
      "role": "system",
      "contentFile": "pages/collection.json"
    },
    {
      "id": "page-cart",
      "name": "Корзина",
      "slug": "/cart",
      "role": "system",
      "contentFile": "pages/cart.json"
    },
    {
      "id": "page-product",
      "name": "Товар",
      "slug": "/product",
      "role": "system",
      "contentFile": "pages/product.json"
    },
    {
      "id": "page-checkout",
      "name": "Оформление заказа",
      "slug": "/checkout",
      "role": "system",
      "contentFile": "pages/checkout.json"
    }
  ]
}