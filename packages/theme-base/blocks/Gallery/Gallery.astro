---
import type { GalleryProps } from './Gallery.puckConfig';
import { GalleryClasses as C } from './Gallery.classes';
import { PLACEHOLDER_ASSETS } from '../../runtime/placeholders';

interface Props extends GalleryProps {
  id?: string;
  subheading?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  items = [],
  padding,
} = Astro.props as Props;

// Accept both flat heading + object envelope from legacy revisions.
const headingText = (() => {
  const h = raw.heading;
  if (typeof h === 'string') return h || undefined;
  if (h && typeof h === 'object') {
    const o = h as { text?: string };
    return o.text || undefined;
  }
  return undefined;
})();
const subheadingText = (() => {
  const s = raw.subheading ?? raw.text;
  if (typeof s === 'string') return s || undefined;
  if (s && typeof s === 'object') {
    const o = s as { content?: string; text?: string };
    return o.content || o.text || undefined;
  }
  return undefined;
})();

// Figma Rose default is "featured": big left + 2 small right (when there
// are at least 3 items). Fall back to "grid" when the merchant picked it
// explicitly or there are fewer than 3 items.
const requestedLayout = raw.layout as 'grid' | 'side-by-side' | 'featured' | undefined;
const layout: 'grid' | 'side-by-side' | 'featured' =
  requestedLayout ?? (items.length >= 3 ? 'featured' : 'grid');

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
const innerClass = C.inner[layout];
const colorSchemeRaw = typeof raw.colorScheme === 'string' ? raw.colorScheme : undefined;
const schemeClass = colorSchemeRaw ? `color-scheme-${colorSchemeRaw.replace('scheme-', '')}` : '';

// SSR resolve real product/collection data via storefront-data endpoint
// (same pattern as Hero.astro / Product.astro). Sites service serves under
// SITES_INTERNAL_BASE (localhost:3114 inside container), public proxy is
// gateway.merfy.ru.
type RawProduct = {
  id: string;
  slug?: string;
  handle?: string;
  name?: string;
  price?: number | string;
  images?: string[];
};
type RawCollection = {
  id: string;
  slug?: string;
  name?: string;
  imageUrl?: string;
  image?: string;
};

const siteIdFromRoot = typeof raw.siteId === 'string' ? raw.siteId : '';
let realProducts: RawProduct[] = [];
let realCollections: RawCollection[] = [];

// Pull live data at SSR. Try local sites service first (preview iframe),
// fall back to public gateway (live SSG).
async function fetchStorefrontData(siteId: string): Promise<{ products: RawProduct[]; collections: RawCollection[] }> {
  if (!siteId) return { products: [], collections: [] };
  const internalBase = (import.meta as unknown as { env?: { SITES_INTERNAL_BASE?: string } }).env?.SITES_INTERNAL_BASE
    ?? 'http://localhost:3114';
  try {
    const res = await fetch(`${internalBase}/api/sites/${siteId}/storefront-data`).catch(() => null);
    if (res && res.ok) {
      const data = (await res.json()) as { products?: RawProduct[]; collections?: RawCollection[] };
      return { products: data.products ?? [], collections: data.collections ?? [] };
    }
  } catch {/* swallow */}
  return { products: [], collections: [] };
}

if (siteIdFromRoot) {
  const data = await fetchStorefrontData(siteIdFromRoot);
  realProducts = data.products;
  realCollections = data.collections;
}

// Try to embed real data fallback through products.json (live SSG mode).
try {
  if (realProducts.length === 0) {
    const productsData = await import('../data/products.json');
    realProducts = ((productsData as { default?: RawProduct[] }).default ?? (productsData as unknown as RawProduct[])) as RawProduct[];
  }
} catch {/* swallow — products.json absent in dev */}

function resolveProduct(productId: string | null | undefined): RawProduct | null {
  if (!productId) return null;
  return realProducts.find((p) => p.id === productId || p.slug === productId || p.handle === productId) ?? null;
}

function resolveCollection(collectionId: string | null | undefined): RawCollection | null {
  if (!collectionId) return null;
  return realCollections.find((c) => c.id === collectionId || c.slug === collectionId) ?? null;
}

function formatPrice(value: number | string | undefined): string {
  if (value === undefined || value === null) return '';
  const num = typeof value === 'string' ? Number(value) : value;
  if (Number.isNaN(num)) return '';
  return new Intl.NumberFormat('ru-RU').format(num) + ' ₽';
}

type ItemDemo = {
  type: 'image' | 'product' | 'collection';
  url?: string;
  alt?: string;
  productId?: string | null;
  collectionId?: string | null;
};

// Figma 1:19439 — empty state shows 3 placeholder items: large image, product
// card («Товар» + price), collection card («Выбери коллекцию»).
const DEMO_ITEMS: ItemDemo[] = [
  { type: 'image', url: '', alt: '' },
  { type: 'product' },
  { type: 'collection' },
];

const hasRealItems = items.length > 0;
const effectiveItems = hasRealItems ? items : DEMO_ITEMS;

type ResolvedItem = {
  type: 'image' | 'product' | 'collection';
  url: string;
  alt: string;
  label: string;
  price: string;
  href: string;
  isPlaceholder: boolean;
};

function resolveItem(raw: ItemDemo): ResolvedItem {
  if (raw.type === 'product') {
    const product = resolveProduct(raw.productId);
    if (product) {
      return {
        type: 'product',
        url: product.images?.[0] ?? '',
        alt: product.name ?? '',
        label: product.name ?? '',
        price: formatPrice(product.price),
        href: product.slug ? `/product/${product.slug}` : '/catalog',
        isPlaceholder: false,
      };
    }
    return { type: 'product', url: '', alt: '', label: 'Товар', price: '2 500 ₽', href: '/catalog', isPlaceholder: true };
  }
  if (raw.type === 'collection') {
    const collection = resolveCollection(raw.collectionId);
    if (collection) {
      return {
        type: 'collection',
        url: collection.imageUrl ?? collection.image ?? '',
        alt: collection.name ?? '',
        label: collection.name ?? '',
        price: '',
        href: collection.slug ? `/catalog/${collection.slug}` : '/catalog',
        isPlaceholder: false,
      };
    }
    return { type: 'collection', url: '', alt: '', label: 'Выбери коллекцию', price: '', href: '/catalog', isPlaceholder: true };
  }
  return {
    type: 'image',
    url: raw.url ?? '',
    alt: raw.alt ?? '',
    label: '',
    price: '',
    href: '#',
    isPlaceholder: !raw.url,
  };
}

const resolvedItems: ResolvedItem[] = effectiveItems.map((item) => resolveItem(item as ItemDemo));
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-layout={layout}
  style={paddingStyle}
>
  <div class={C.container}>
    {headingText && (
      <h2 class={C.heading} data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">{headingText}</h2>
    )}
    {subheadingText && (
      <p class={C.subheading} data-puck-subsection-parent={id} data-puck-subsection-index="101" data-puck-subsection-field="text">{subheadingText}</p>
    )}
    <div class={innerClass}>
      {layout === 'featured'
        ? resolvedItems.map((item, idx) => {
            const isPrimary = idx === 0;
            if (isPrimary) {
              return (
                <div
                  class={C.itemPrimary}
                  data-puck-subsection-parent={hasRealItems ? id : undefined}
                  data-puck-subsection-index={hasRealItems ? idx : undefined}
                  data-puck-subsection-field={hasRealItems ? 'items' : undefined}
                >
                  {item.url ? (
                    <img src={item.url} alt={item.alt} class={C.image} />
                  ) : (
                    <div class="w-full aspect-[3/4] bg-[rgb(var(--color-surface,var(--color-text)/0.05))] overflow-hidden text-[rgb(var(--color-accent))]" aria-hidden="true">
                      <img src={PLACEHOLDER_ASSETS.landscape.gallery} alt="" class="w-full h-full object-cover" loading="lazy" />
                    </div>
                  )}
                </div>
              );
            }
            return (
              <a
                href={item.href}
                class={C.itemSmall}
                data-puck-subsection-parent={hasRealItems ? id : undefined}
                data-puck-subsection-index={hasRealItems ? idx : undefined}
                data-puck-subsection-field={hasRealItems ? 'items' : undefined}
              >
                {item.url ? (
                  <img src={item.url} alt={item.alt} class={C.imageSmall} />
                ) : (
                  <div class={`${C.cardMedia} flex items-center justify-center overflow-hidden text-[rgb(var(--color-accent))]`} aria-hidden="true">
                    {item.type === 'product' ? (
                      <img src={PLACEHOLDER_ASSETS.sweater.blue} alt="" class="w-[60%] aspect-square object-contain" loading="lazy" />
                    ) : item.type === 'collection' ? (
                      <img src={PLACEHOLDER_ASSETS.landscape.gallery} alt="" class="w-full h-full object-cover" loading="lazy" />
                    ) : (
                      <img src={PLACEHOLDER_ASSETS.landscape.gallery} alt="" class="w-full h-full object-cover" loading="lazy" />
                    )}
                  </div>
                )}
                {item.label && <div class={C.cardLabel}>{item.label}</div>}
                {item.price && <div class={C.cardPrice}>{item.price}</div>}
              </a>
            );
          })
        : resolvedItems.map((item, idx) => {
            if (item.type === 'image') {
              return (
                <div
                  class={C.item}
                  data-puck-subsection-parent={hasRealItems ? id : undefined}
                  data-puck-subsection-index={hasRealItems ? idx : undefined}
                  data-puck-subsection-field={hasRealItems ? 'items' : undefined}
                >
                  {item.url ? (
                    <img src={item.url} alt={item.alt} class={C.image} />
                  ) : (
                    <div class="w-full aspect-square bg-[rgb(var(--color-surface,var(--color-text)/0.05))] overflow-hidden text-[rgb(var(--color-accent))]" aria-hidden="true">
                      <img src={PLACEHOLDER_ASSETS.landscape.gallery} alt="" class="w-full h-full object-cover" loading="lazy" />
                    </div>
                  )}
                </div>
              );
            }
            return (
              <a
                href={item.href}
                class={C.card}
                data-puck-subsection-parent={hasRealItems ? id : undefined}
                data-puck-subsection-index={hasRealItems ? idx : undefined}
                data-puck-subsection-field={hasRealItems ? 'items' : undefined}
              >
                {item.url ? (
                  <img src={item.url} alt={item.alt} class={C.imageSmall} />
                ) : (
                  <div class={`${C.cardMedia} flex items-center justify-center overflow-hidden text-[rgb(var(--color-accent))]`} aria-hidden="true">
                    {item.type === 'product' ? (
                      <img src={PLACEHOLDER_ASSETS.sweater.blue} alt="" class="w-[60%] aspect-square object-contain" loading="lazy" />
                    ) : item.type === 'collection' ? (
                      <img src={PLACEHOLDER_ASSETS.landscape.gallery} alt="" class="w-full h-full object-cover" loading="lazy" />
                    ) : (
                      <img src={PLACEHOLDER_ASSETS.landscape.gallery} alt="" class="w-full h-full object-cover" loading="lazy" />
                    )}
                  </div>
                )}
                {item.label && <div class={C.cardLabel}>{item.label}</div>}
                {item.price && <div class={C.cardPrice}>{item.price}</div>}
              </a>
            );
          })}
    </div>
  </div>
</section>
