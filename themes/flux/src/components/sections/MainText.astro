---
// Фаза B (flux): новая канон-секция MainText в манере flux (см.
// themes/flux/MANNER.md). Донора-манифеста у верстальщика НЕТ (секций всего 4,
// MANNER §10) — секция написана с нуля: сетка главной §2 (px-4 md:px-20
// 2xl:px-80, вертикаль 64/96), текст-манифест = роль внутреннего h2
// (Comfortaa uppercase 24/md:28, contacts.astro:40; cart.astro:76), чёрная CTA
// §3 (contacts.astro:76). Скролл-анимаций НЕТ — манера flux статична (§6).
// Схема полей = packages/theme-base/blocks/MainText/MainText.puckConfig.ts;
// процесс-эталон — bloom MainText.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Figma 1:19335 — ПУСТОЕ состояние секции (тип "MainText"): дословный
// плейсхолдер (НЕ дефолт-контент верстальщика). MainText — чисто текстовая
// секция (нет товаров/коллекций для SSR-фетча, эталон rose MainText), потому
// пустое состояние = дефолтные значения полей: заголовок «Расскажи о своем
// бренде». Роль = внутрисекционный h2 (Comfortaa uppercase leading-[1.115],
// МАННЕРА §1). Лестница §9 «Внутренний h2 24/28»: large/отсутствие = литерал
// 24/md:28, medium 20/24, small 17/20. Когда мерчант задаёт heading —
// рендерится ЕГО значение (?? fallback только при пустых данных).
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Расскажи о своем бренде");
const headingSize = p.headingSize ?? p.heading?.size;
const headingCls =
	headingSize === "small"
		? "font-comfortaa text-[17px] font-normal uppercase leading-[1.115] text-[rgb(var(--color-heading,0_0_0))] md:text-[20px]"
		: headingSize === "medium"
			? "font-comfortaa text-[20px] font-normal uppercase leading-[1.115] text-[rgb(var(--color-heading,0_0_0))] md:text-[24px]"
			: "font-comfortaa text-[24px] font-normal uppercase leading-[1.115] text-[rgb(var(--color-heading,0_0_0))] md:text-[28px]";

// Канон text: string | { content, size }. Figma 1:19335 — пустое состояние:
// дословный хелпер-текст плейсхолдера «Расскажи подробнее о своем онлайн-
// магазине в этом блоке» (НЕ болванка-манифест верстальщика). Мерчант задал
// text — рендерим его.
const text =
	typeof p.text === "string"
		? p.text
		: (p.text?.content ?? "Расскажи подробнее о своем онлайн-магазине в этом блоке");

// Канон textSize (top-level hidden приоритетнее text.size сабпанели). Та же
// роль внутреннего h2: лестница §9 large/отсутствие = литерал 24/md:28,
// medium 20/24, small 17/20; цвет — text-токен с чёрным фоллбеком (§7).
const textSize = p.textSize ?? p.text?.size;
const textCls =
	textSize === "small"
		? "font-comfortaa text-[17px] font-normal uppercase leading-[1.115] text-[rgb(var(--color-text,0_0_0))] md:text-[20px]"
		: textSize === "medium"
			? "font-comfortaa text-[20px] font-normal uppercase leading-[1.115] text-[rgb(var(--color-text,0_0_0))] md:text-[24px]"
			: "font-comfortaa text-[24px] font-normal uppercase leading-[1.115] text-[rgb(var(--color-text,0_0_0))] md:text-[28px]";

// Канон position — позиция контент-колонки; alignment — выравнивание внутри.
// canon-default обоих = 'center'.
const position = p.position === "left" || p.position === "right" ? p.position : "center";
const alignment = p.alignment === "left" || p.alignment === "right" ? p.alignment : "center";
const posCls = position === "left" ? "mr-auto" : position === "right" ? "ml-auto" : "mx-auto";
const itemsCls =
	alignment === "left" ? "items-start" : alignment === "right" ? "items-end" : "items-center";
const textAlignCls =
	alignment === "left" ? "text-left" : alignment === "right" ? "text-right" : "text-center";

// Канон textStyle (hidden): italic → курсив заголовка и текста.
const italicCls = p.textStyle === "italic" ? " italic" : "";

// Кнопка: canon-сабпанель button {text, link} приоритетнее legacy hidden cta.
// Figma 1:19335 — пустое состояние: дословный плейсхолдер «Кнопка» (НЕ
// «Подробнее»). Мерчант задал текст пропа — рендерим его; пустой текст
// ЗАДАННОГО пропа СКРЫВАЕТ кнопку (canon-defaults кнопку не пишут → плейсхолдер).
const btnProvided = p.button !== undefined || p.cta !== undefined;
const btnTextProp =
	(typeof p.button?.text === "string" && p.button.text.trim() ? p.button.text : undefined) ??
	(typeof p.cta?.text === "string" && p.cta.text.trim() ? p.cta.text : undefined);
const btnText = btnTextProp ?? (btnProvided ? undefined : "Кнопка");
const btnHref =
	p.button?.link?.href ??
	(typeof p.button?.link === "string" && p.button.link ? p.button.link : undefined) ??
	(typeof p.cta?.href === "string" && p.cta.href ? p.cta.href : undefined) ??
	(typeof p.cta?.link === "string" && p.cta.link ? p.cta.link : undefined) ??
	"/catalog";

// Канон buttonStyle: 'solid'/отсутствие = чёрная CTA манеры §3 дословно
// (contacts.astro:76: h-12 rounded-6 px-6 Manrope 16, hover:opacity-95;
// в схемах flux чёрная кнопка = кнопка-2, МАННЕРА §7). outlined = бордер/текст
// цвета заливки на прозрачном (ховер 0.90 — паттерн PDP-кнопки с бордером,
// PDP:168). active:scale в манере flux НЕ используется (§3).
const btnCls =
	p.buttonStyle === "outlined"
		? "inline-flex h-12 items-center justify-center rounded-[var(--radius-button,6px)] border border-solid border-[rgb(var(--color-button-2-bg,0_0_0))] bg-transparent px-6 font-manrope text-[16px] font-normal leading-normal text-[rgb(var(--color-button-2-bg,0_0_0))] transition-opacity hover:opacity-90"
		: "inline-flex h-12 items-center justify-center rounded-[var(--radius-button,6px)] bg-[rgb(var(--color-button-2-bg,0_0_0))] px-6 font-manrope text-[16px] font-normal leading-normal text-[rgb(var(--color-button-2-text,255_255_255))] transition-opacity hover:opacity-95";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

// colorScheme навешивает обёрткой composeV2Page; фон секции — bg-токен с БЕЛЫМ
// фоллбеком (у flux нет цветных полотен — фон секций всегда белый, МАННЕРА §7).
const textId = id ? `${id}-text` : "main-text";
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 py-16 md:px-20 md:py-24 2xl:px-80"
	aria-labelledby={textId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class={`${posCls} flex w-full max-w-[1320px] flex-col ${itemsCls} gap-10 ${textAlignCls}`}>
		{
			heading && (
				<h2
					class={headingCls + italicCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}
		<p
			id={textId}
			class={textCls + italicCls}
			data-puck-subsection-parent={id}
			data-puck-subsection-index="101"
			data-puck-subsection-field="text"
			set:html={text}
		/>

		{
			btnText && (
				<a
					href={btnHref}
					class={btnCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="button"
				>
					{btnText}
				</a>
			)
		}
	</div>
</section>
