---
// ПЛЕЙСХОЛДЕР пустого состояния (контракт Figma 1:19335 / theme-base
// Collections 1:33070): когда у секции НЕТ ручного выбора коллекций —
// рендерим N пустых квадратных карточек (rounded-rect bg surface) с подписью
// «Коллекция», а НЕ мок-демо верстальщика (реальные имена + фото текстиль/
// декор). Это паритет theme-base DEMO_COLLECTIONS (curated-модель Shopify:
// пустой пикер = плейсхолдер, НЕ авто-подхват всего каталога).
//
// Когда коллекции ВЫБРАНЫ (usePropCollections=true) — рендер реальных
// SSR-данных + клиентская гидрация (data-collection-ref → имя/обложка
// магазина) остаются БЕЗ изменений.
//
// Канон-дефолты конструктора (headingSize medium / subtitleSize small /
// titleAlignment 'left', gridAspect '1:1', cardCaptionStyle 'uppercase' из
// blockDefaults vanilla) → пиксель верстальщика; дефолтная ветка каждого
// тернарника = прежняя строка классов (цвета → токены с пиксель-фоллбеком
// родных литералов, MANNER.md §7).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Figma 1:19335 — ДОСЛОВНЫЙ плейсхолдер ПУСТОГО состояния секции «Список
// коллекций» (тип Collections): заголовок «Список коллекций» БЕЗ подзаголовка,
// а НЕ дефолт-копирайт верстальщика («Коллекции, которые становятся любимыми» /
// «Вдохновение для каждого дня…»). Эталон — rose Collections.astro.
// Мерчант задал свой heading/subtitle → рендерим ЕГО (?? срабатывает только при
// пустых данных).
const sectionTitle =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ??
	p.title ??
	"Список коллекций";
const sectionSubtitle =
	typeof p.subtitle === "string" && p.subtitle.trim() ? p.subtitle : "";

// Канон headingSize (top-level приоритетнее legacy heading.size): 'medium'
// (canon-default, MANNER §9) и отсутствие = роль «заголовок секции»
// верстальщика дословно (Bitter italic 20). Лестница §9: small 17, large 24.
const headingSize = p.headingSize ?? p.heading?.size;
const headingCls =
	headingSize === "small"
		? "font-vanilla-bitter text-[17px] font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]"
		: headingSize === "large"
			? "font-vanilla-bitter text-[24px] font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]"
			: "font-vanilla-bitter text-[20px] font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]";
// Канон subtitleSize: 'small' (canon-default) и отсутствие = подзаголовок
// верстальщика дословно (Arsenal italic 16). Лестница §9: medium 19, large 23.
const subtitleCls =
	p.subtitleSize === "medium"
		? "font-vanilla-arsenal text-[19px] font-normal italic leading-none text-[rgb(var(--color-muted,68_68_68))]"
		: p.subtitleSize === "large"
			? "font-vanilla-arsenal text-[23px] font-normal italic leading-none text-[rgb(var(--color-muted,68_68_68))]"
			: "font-vanilla-arsenal text-base font-normal italic leading-none text-[rgb(var(--color-muted,68_68_68))]";
// Канон titleAlignment: 'left' (canon-default из blockDefaults vanilla) и
// отсутствие = литерал верстальщика (шапка слева, без класса).
const titleAlignCls =
	p.titleAlignment === "center" ? " text-center" : p.titleAlignment === "right" ? " text-right" : "";
const headWrapCls = `flex max-w-[760px] flex-col gap-2${titleAlignCls}`;

// Канон columns 1-6: 2 (срез верстальщика = canon-default, blockDefaults
// columns не задают) и отсутствие → дефолт-ветка (литерал md:grid-cols-2);
// иное → inline-var на гриде с md (мобильная колонка верстальщика остаётся).
const colsRaw =
	typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : undefined;
const cols = colsRaw && colsRaw !== 2 ? colsRaw : undefined;
const gridCls = cols
	? "grid grid-cols-1 gap-4 md:grid-cols-[repeat(var(--cols),minmax(0,1fr))]"
	: "grid grid-cols-1 gap-4 md:grid-cols-2";
const gridStyle = cols ? `--cols:${cols}` : undefined;

// Канон gridAspect '1:1' (canon-default из blockDefaults vanilla) и
// отсутствие = квадратные плитки верстальщика (aspect-[1/1], §4); без него
// вид ведёт imageView: portrait → 430/500, wide → 16/9.
const tileAspect =
	p.gridAspect === "1:1"
		? "aspect-[1/1]"
		: p.imageView === "portrait"
			? "aspect-[430/500]"
			: p.imageView === "wide"
				? "aspect-[16/9]"
				: "aspect-[1/1]";
// Канон cardCaptionStyle: 'uppercase' (canon-default из blockDefaults) и
// отсутствие = капс-подпись верстальщика; 'default' снимает капс.
const captionCase = p.cardCaptionStyle === "default" ? "" : " uppercase";

// Канон collections[] (≤10): плитки коллекций из пропса при непустом массиве.
// Иначе — плейсхолдер (DEMO_COLLECTIONS, ниже). SSR рендерит сохранённые поля
// item, резолв collectionId→имя/обложка делает гидрация ниже
// (data-collection-ref): live — /data/collections.json, превью —
// storefront-data; паритет theme-base (имя коллекции перебивает ручной
// heading, обложка — только при отсутствии своей, data-own-image).
const cardLinkBase =
	typeof p.cardLinkBase === "string" && p.cardLinkBase.trim()
		? p.cardLinkBase
		: "/catalog?collection=";
const propCollections = (Array.isArray(p.collections) ? p.collections : [])
	.filter((c: any) => c && typeof c === "object")
	.slice(0, 10)
	.map((c: any) => {
		const collectionId =
			typeof c.collectionId === "string" && c.collectionId.trim() ? c.collectionId.trim() : null;
		const hasOwnImage = !!(typeof c.image === "string" && c.image);
		return {
			collectionId,
			name:
				(typeof c.heading === "string" && c.heading) ||
				(typeof c.name === "string" && c.name) ||
				"Коллекция",
			// Своя картинка — её; иначе пусто (плитка-плейсхолдер: пустой rect).
			// Обложку выбранной коллекции магазина подставит гидрация по
			// collectionId. Мок-фото верстальщика здесь НЕ показываем.
			image: hasOwnImage ? c.image : null,
			hasOwnImage,
			href: collectionId ? `${cardLinkBase}${collectionId}` : "#",
		};
	});
const usePropCollections = propCollections.length > 0;

// SSR-резолв реальных коллекций по collectionId (Figma-цель: коллекция ВЫБРАНА →
// реальное имя/обложка ПРЯМО в статике, чтобы их видело и ПРЕВЬЮ конструктора —
// Astro Container не исполняет клиентскую module-гидрацию ниже). Эталон —
// rose Popular.astro / Collections.astro (siteId инжектит рендер-пайплайн
// preview.service / build). Нет siteId / выбранных collectionId / ошибка →
// resolved пуст → остаётся SSR из пропса (heading/обложка), а живая гидрация
// ниже освежит данные на live. Паритет theme-base resolveManual: имя коллекции
// перебивает ручной heading, обложка — только при пустой своей (hasOwnImage).
const siteId = typeof p.siteId === "string" ? p.siteId : "";
const wantResolve = usePropCollections && propCollections.some((c) => c.collectionId);
const resolvedCols = new Map<string, { name?: string; image?: string }>();
if (wantResolve && siteId) {
	try {
		const base = (import.meta as any).env?.SITES_INTERNAL_BASE ?? "http://localhost:3114";
		const res = await fetch(`${base}/api/sites/${siteId}/storefront-data`).catch(() => null);
		if (res && res.ok) {
			const data: any = await res.json();
			const cols: any[] = Array.isArray(data?.collections) ? data.collections : [];
			for (const c of propCollections) {
				if (!c.collectionId) continue;
				const m = cols.find(
					(x) =>
						x &&
						(x.id === c.collectionId ||
							x.slug === c.collectionId ||
							x.name === c.collectionId ||
							x.handle === c.collectionId),
				);
				if (!m) continue;
				const cover =
					(typeof m.image === "string" && m.image) ||
					(Array.isArray(m.images) && typeof m.images[0] === "string" ? m.images[0] : "");
				resolvedCols.set(c.collectionId, {
					name: typeof m.name === "string" ? m.name : undefined,
					image: cover || undefined,
				});
			}
		}
	} catch {
		/* нет данных — остаётся SSR из пропса, гидрация освежит на live */
	}
}
// Применяем резолв к карточкам пропса: реальное имя перебивает ручной heading,
// обложка — только если мерчант не загрузил свою (hasOwnImage).
const resolvedCollections = propCollections.map((c) => {
	const r = c.collectionId ? resolvedCols.get(c.collectionId) : undefined;
	if (!r) return c;
	return {
		...c,
		name: r.name || c.name,
		image: c.hasOwnImage ? c.image : r.image || c.image,
	};
});

// ПЛЕЙСХОЛДЕР пустого состояния (контракт Figma 1:19335, паритет theme-base
// DEMO_COLLECTIONS / rose Collections.astro): 3 пустые квадратные карточки
// (rounded-rect bg surface) с подписью «Коллекция». Без ручного выбора
// показываем ИХ, а не мок верстальщика и НЕ авто-подхват каталога
// (curated-модель Shopify). Количество — ровно 3 (контракт Figma: «3 карточки»).
const demoCollections = [{ name: "Коллекция" }, { name: "Коллекция" }, { name: "Коллекция" }];

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id="collections"
	class="vanilla-pad w-full bg-[rgb(var(--color-bg,238_238_238))] py-20 md:py-28"
	aria-labelledby="collections-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="vanilla-container flex max-w-[1180px] flex-col gap-8">
		<div
			class={headWrapCls}
			data-animate
			data-puck-subsection-parent={id}
			data-puck-subsection-index="100"
			data-puck-subsection-field="heading"
		>
			<h2 id="collections-title" class={headingCls}>
				{sectionTitle}
			</h2>
			{sectionSubtitle && <p class={subtitleCls}>{sectionSubtitle}</p>}
		</div>

		<ul class={gridCls} role="list" data-animate data-animate-delay="0.1s" style={gridStyle}>
			{usePropCollections ? resolvedCollections.map((c, i) => (
				<li>
					<a
						href={c.href}
						class="group flex w-full cursor-pointer flex-col gap-3"
						aria-label={c.name}
						data-nt="vanilla-collection-card"
						data-collection-ref={c.collectionId ?? undefined}
						data-own-image={c.hasOwnImage ? "true" : undefined}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="collections"
					>
						<div class={`${tileAspect} w-full overflow-hidden bg-[rgb(var(--color-surface,236_235_231))]`}>
							{c.image && (
								<img
									src={c.image}
									alt={c.name}
									loading="lazy"
									class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.08]"
								/>
							)}
						</div>
						<h3
							class={`vanilla-collection-name font-vanilla-arsenal text-base font-normal leading-none text-[rgb(var(--color-heading,38_49_28))] transition-opacity group-hover:opacity-70${captionCase}`}
						>
							{c.name}
						</h3>
					</a>
				</li>
			)) : demoCollections.map((c) => (
				<li>
					<div class="flex w-full flex-col gap-3" data-nt="vanilla-collection-card-placeholder">
						<div
							class={`${tileAspect} w-full overflow-hidden bg-[rgb(var(--color-surface,236_235_231))]`}
							aria-hidden="true"
						></div>
						<h3
							class={`font-vanilla-arsenal text-base font-normal leading-none text-[rgb(var(--color-heading,38_49_28))]${captionCase}`}
						>
							{c.name}
						</h3>
					</div>
				</li>
			))}
		</ul>
	</div>
</section>

<script>
	import { loadRealCollections, findCollection } from "../../lib/storefront-hydrate";

	// Резолв collectionId→имя/обложка на ВЫБРАННЫХ плитках (data-collection-ref).
	// Паритет theme-base resolveManual: имя коллекции перебивает ручной heading;
	// обложка коллекции подставляется, только если мерчант не загрузил свою
	// (data-own-image). Без данных (demo-сборка) — no-op, SSG остаётся.
	//
	// NB: автоподстановки каталога в пустой грид НЕТ (curated-модель Shopify):
	// пустой пикер = плейсхолдер (3 пустые карточки «Коллекция»), а не реальные
	// коллекции магазина. Паритет theme-base Collections (hasManualCollections).
	const hydrateCollectionTiles = async () => {
		const tiles = Array.from(
			document.querySelectorAll<HTMLElement>(
				'[data-nt="vanilla-collection-card"][data-collection-ref]',
			),
		);
		if (tiles.length === 0) return;
		const collections = await loadRealCollections();
		if (!collections) return;
		for (const tile of tiles) {
			const col = findCollection(collections, tile.getAttribute("data-collection-ref"));
			if (!col) continue;
			if (col.name) {
				const h3 = tile.querySelector(".vanilla-collection-name");
				if (h3 && h3.textContent !== col.name) h3.textContent = col.name;
				tile.setAttribute("aria-label", col.name);
			}
			const cover = col.image || (Array.isArray(col.images) ? col.images[0] : "");
			if (cover && tile.getAttribute("data-own-image") !== "true") {
				const img = tile.querySelector("img");
				if (img && img.getAttribute("src") !== cover) {
					img.setAttribute("src", cover);
					if (col.name) img.setAttribute("alt", col.name);
				}
			}
		}
	};

	hydrateCollectionTiles();
	document.addEventListener("astro:page-load", () => {
		hydrateCollectionTiles();
	});
</script>
