---
// Фаза B (satin, группа content): канон-секция MultiColumns — адаптация
// src/components/sections/Features.astro (тело КОПИЕЙ; оригинал не тронут —
// index.astro:31 его использует). Схема полей = packages/theme-base/blocks/
// MultiColumns/MultiColumns.puckConfig.ts; манера — themes/satin/MANNER.md
// (эталон процесса — bloom MultiColumns). Пустое состояние (без columns[]) =
// ДОСЛОВНЫЙ Figma-плейсхолдер 1:19335 (эталон rose MultiColumns.astro):
// заголовок «Мультиколонны» + 3 пустые surface-колонки «Колонна» + хелпер
// «Сочетай текст…» + per-column ссылка «Кнопка». НЕ мок верстальщика
// (материалы/доставка) и НЕ общая кнопка «Перейти».
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { withBase } from "../../lib/with-base";

const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон columns[] ≤10 (item: heading|title, text|description, imageUrl|image —
// ИКОНКА 56×56; headingSize/textSize per-item; link {text,href} | flat-пара
// linkText+link). Отсутствие массива → ПЛЕЙСХОЛДЕР пустого состояния (Figma
// 1:19335): НЕ мок-демо верстальщика (материалы/доставка), а 3 нейтральные
// колонки «Колонна». Гейт по наличию реальных данных нужен ещё для шапки
// (заголовок-плейсхолдер «Мультиколонны»), поэтому объявлен выше. legacy
// flat-проп items[] {title, body, icon} поддержан алиасами.
const hasManualColumns =
	(Array.isArray(p.columns) && p.columns.length > 0) ||
	(Array.isArray(p.items) && p.items.length > 0);

// Канон heading: string | { text, alignment, size } — у верстальщика шапки НЕТ
// → рендер ТОЛЬКО при непустом. Роль = заголовок секции §1 (font-logo 20
// uppercase leading-[1.15], токен heading). Лестница §9: medium/отсутствие =
// литерал 20, small 17, large 24. В ПУСТОМ состоянии — дословный Figma-лейбл
// «Мультиколонны» (контракт 1:19335, эталон rose MultiColumns.astro), а не
// отсутствие шапки. С данными мерчанта — его заголовок (пусто → без шапки).
const headingRaw = typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "");
const heading = hasManualColumns ? headingRaw : (headingRaw || "Мультиколонны");
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small" ? "text-[17px]" : headingSize === "large" ? "text-[24px]" : "text-[20px]";
const headingAlignment =
	p.headingAlignment ?? (typeof p.heading === "object" ? p.heading?.alignment : undefined);
const headingAlignCls =
	headingAlignment === "center" ? " text-center" : headingAlignment === "right" ? " text-right" : "";
const headingCls = `font-logo ${headingSizeCls} font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]${headingAlignCls}`;

// Плейсхолдер колонки (Figma 1:19335): пустой rect (без иконки-картинки) +
// «Колонна» + поясняющий текст + per-column ссылка-плейсхолдер «Кнопка»
// (дословно как rose MultiColumns.astro — кнопка В КАЖДОЙ колонке, не общая).
const PLACEHOLDER_COLUMN = {
	heading: "Колонна",
	text: "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.",
	imageUrl: "",
	link: { text: "Кнопка", href: "/catalog" },
};
const rawColumns = hasManualColumns
	? Array.isArray(p.columns) && p.columns.length
		? p.columns
		: p.items
	: [];
const columns = rawColumns.slice(0, 10).map((c: any) => {
	// Ссылка карточки: canon link {text,href} ИЛИ flat-пара linkText + link
	// (string из arrayFields конструктора) → текстовая ссылка-CTA манеры
	// «Перейти» + arrow-right size-5 (литерал Journal.astro:53-56). Рендер
	// ТОЛЬКО при непустом тексте.
	const linkText =
		(c.link && typeof c.link === "object" && typeof c.link.text === "string" && c.link.text.trim()
			? c.link.text
			: undefined) ?? (typeof c.linkText === "string" && c.linkText.trim() ? c.linkText : undefined);
	const linkHref =
		(c.link && typeof c.link === "object" && typeof c.link.href === "string" && c.link.href
			? c.link.href
			: undefined) ??
		(typeof c.link === "string" && c.link ? c.link : undefined) ??
		"/catalog";
	return {
		heading:
			(typeof c.heading === "string" && c.heading) || (typeof c.title === "string" && c.title) || "",
		text:
			(typeof c.text === "string" && c.text) ||
			(typeof c.description === "string" && c.description) ||
			(typeof c.body === "string" && c.body) ||
			"",
		image:
			(typeof c.imageUrl === "string" && c.imageUrl.trim()) ||
			(typeof c.image === "string" && c.image.trim()) ||
			(typeof c.icon === "string" && c.icon.trim()) ||
			"",
		headingSize: c.headingSize,
		textSize: c.textSize,
		link: linkText ? { text: linkText, href: linkHref } : undefined,
	};
});

// Пустое состояние (Figma 1:19335): 3 нейтральные колонки «Колонна» с
// поясняющим текстом — НЕ мок-демо верстальщика. Эталон theme-base: гейт по
// наличию реальных данных (collectionRef/hasManualCollections); тут — columns[]/items[].
const isPlaceholder = !hasManualColumns;
const effectiveColumns = isPlaceholder
	? Array.from({ length: 3 }, () => ({
			heading: PLACEHOLDER_COLUMN.heading,
			text: PLACEHOLDER_COLUMN.text,
			image: "",
			headingSize: undefined as string | undefined,
			textSize: undefined as string | undefined,
			// Per-column ссылка-плейсхолдер «Кнопка» (Figma 1:19335 — кнопка в
			// КАЖДОЙ колонке, дословно как rose MultiColumns.astro), не общая снизу.
			link: { ...PLACEHOLDER_COLUMN.link } as { text: string; href: string },
		}))
	: columns;

// Канон displayColumns 1-4: canon-default 3 (его пишет коэрсер) И отсутствие =
// ЛИТЕРАЛ md:grid-cols-2 (Features.astro:31 — у satin 2 колонки, не 3!);
// иное значение → CSS-var на md+ (mobile-лестница grid-cols-1 сохраняется).
// Пустое состояние форсирует РОВНО 3 видимые колонки (контракт Figma 1:19335 —
// «3 колонки»), поэтому минует литерал md:grid-cols-2.
const displayColumnsRaw = Number(p.displayColumns);
const displayColumns = isPlaceholder
	? 3
	: Number.isFinite(displayColumnsRaw) && displayColumnsRaw >= 1 && displayColumnsRaw <= 4
		? Math.round(displayColumnsRaw)
		: 3;
const gridCls =
	displayColumns === 3 && !isPlaceholder
		? "grid grid-cols-1 gap-4 md:grid-cols-2"
		: "grid grid-cols-1 gap-4 md:grid-cols-[repeat(var(--cols),minmax(0,1fr))]";
const gridStyle = displayColumns === 3 && !isPlaceholder ? undefined : `--cols:${displayColumns}`;

// Канон width (s/m/l/full): large/отсутствие = .satin-container 1320 (литерал
// Features.astro:31); medium 1080, small 780, full — на всю ширину (поля
// .satin-pad секции остаются).
const widthCls =
	p.width === "small"
		? "mx-auto w-full max-w-[780px]"
		: p.width === "medium"
			? "mx-auto w-full max-w-[1080px]"
			: p.width === "full"
				? "w-full"
				: "satin-container";

// Канон containerEnabled ('true' canon-default; legacy background.enabled):
// true/отсутствие = «подложечная» карточка §4 — СЕРАЯ подложка bg surface
// 245_245_245 + p-6 БЕЗ радиуса (литерал Features.astro:33); false — контент
// без подложек прямо на фоне секции.
const containerEnabled = String(p.containerEnabled ?? p.background?.enabled ?? "true") !== "false";
// В пустом состоянии серую «подложечную» карточку НЕ рисуем — плейсхолдер сам
// рендерит пустой rect (#FBFBFB), двойная подложка читалась бы как баг.
const cardSurfaceCls =
	containerEnabled && !isPlaceholder ? " bg-[rgb(var(--color-surface,245_245_245))] p-6" : "";

// Канон containerColorScheme (hidden) — класс схемы на гриде карточек.
const containerSchemeCls =
	typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";

// Канон textPosition (radio «Положение колонн»): манера satin — карточка-фича
// ВСЕГДА по центру (MANNER §4, Features.astro:33 items-center text-center), это
// и редакторский дефолт satin → отсутствие/center = центр; left — выключка влево.
const colAlignCls = p.textPosition === "left" ? "items-start text-left" : "items-center text-center";

// Канон buttonText/buttonLink (hidden) — общая кнопка под гридом: светлая
// контурная роль .satin-button-md LIGHT (родная роль satin §3), w-fit СЛЕВА
// (манера «Смотреть больше» Popular — НЕ по центру). Метрики .satin-button-md
// (g:106-126) + токены кнопки-2. Рендер ТОЛЬКО при непустом тексте. В пустом
// состоянии (плейсхолдер) общей кнопки НЕТ — кнопку «Кнопка» рисует КАЖДАЯ
// колонка (per-column link выше), дословно как rose MultiColumns.astro (Figma
// 1:19335). Двойная кнопка (per-column + общая) читалась бы как баг.
const btnText =
	isPlaceholder || !(typeof p.buttonText === "string" && p.buttonText.trim())
		? undefined
		: p.buttonText;
const btnHref =
	(typeof p.buttonLink === "string" && p.buttonLink ? p.buttonLink : undefined) ??
	(typeof p.link === "string" && p.link ? p.link : undefined) ??
	"/catalog";
const btnCls =
	"inline-flex min-h-12 w-fit items-center justify-center rounded-[var(--radius-button,0px)] border border-solid border-[rgb(var(--color-button-2-text,0_0_0))] bg-transparent px-6 text-[16px] font-normal uppercase leading-none text-[rgb(var(--color-button-2-text,0_0_0))] transition-opacity duration-[180ms] hover:opacity-[0.78]";

// Шкалы per-item (лестницы §9): заголовок карточки 18/md:20 — литерал
// Features.astro:43 (small 15/17, large 22/24 — ряд аккордеона); текст
// карточки = body .satin-copy 16 + max-w-[560px] — литерал Features.astro:44
// (small 14, large 19; классы расписаны явно ради лестницы и токена muted).
const itemHeadingCls = (s: string | undefined) =>
	s === "small"
		? "font-logo text-[15px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))] md:text-[17px]"
		: s === "large"
			? "font-logo text-[22px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))] md:text-[24px]"
			: "font-logo text-[18px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))] md:text-[20px]";
const itemTextCls = (s: string | undefined) =>
	s === "small"
		? "max-w-[560px] text-[14px] font-light leading-[1.5] text-[rgb(var(--color-muted,153_153_153))]"
		: s === "large"
			? "max-w-[560px] text-[19px] font-light leading-[1.5] text-[rgb(var(--color-muted,153_153_153))]"
			: "max-w-[560px] text-[16px] font-light leading-[1.5] text-[rgb(var(--color-muted,153_153_153))]";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

{/* Секция: вертикаль фич §2 (py-10 md:py-20 — литерал Features.astro:30), поля .satin-pad, грид gap-4. */}
<section
	class="satin-pad w-full bg-[rgb(var(--color-bg,255_255_255))] py-10 md:py-20"
	aria-labelledby={titleId}
	aria-label={heading ? undefined : "Преимущества"}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class={`${widthCls} flex flex-col gap-8`}>
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}
		<ul class={`${gridCls}${containerSchemeCls}`} role="list" style={gridStyle}>
			{
				effectiveColumns.map((c, index) => (
					<li
						class={`flex flex-col gap-6 ${colAlignCls}${cardSurfaceCls}`}
						data-puck-subsection-parent={isPlaceholder ? undefined : id}
						data-puck-subsection-index={isPlaceholder ? undefined : index}
						data-puck-subsection-field={isPlaceholder ? undefined : "columns"}
					>
						{isPlaceholder ? (
							/* Пустой rect-плейсхолдер (Figma 1:19335): подложка #FBFBFB /
							   rgb(var(--color-surface)) вместо иконки-картинки колонки. */
							<div
								class="aspect-[4/3] w-full bg-[rgb(var(--color-surface,251_251_251))]"
								aria-hidden="true"
							/>
						) : (
							c.image && (
								<img
									src={c.image.startsWith("/") ? withBase(c.image) : c.image}
									alt=""
									width="56"
									height="56"
									loading="lazy"
									class="h-14 w-14 shrink-0 object-contain"
									aria-hidden="true"
								/>
							)
						)}
						{c.heading && <h3 class={itemHeadingCls(c.headingSize)}>{c.heading}</h3>}
						{c.text && <p class={itemTextCls(c.textSize)} set:html={c.text} />}
						{c.link && (
							<a
								href={c.link.href}
								class="inline-flex items-center gap-2 font-manrope text-[14px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70"
							>
								<span>{c.link.text}</span>
								<NtIcon name="arrow-right" sizeClass="size-5" />
							</a>
						)}
					</li>
				))
			}
		</ul>
		{
			btnText && (
				<a
					href={btnHref}
					class={btnCls}
					data-puck-subsection-parent={isPlaceholder ? undefined : id}
					data-puck-subsection-index={isPlaceholder ? undefined : "102"}
					data-puck-subsection-field={isPlaceholder ? undefined : "buttonText"}
				>
					{btnText}
				</a>
			)
		}
	</div>
</section>
