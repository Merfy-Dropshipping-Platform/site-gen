---
// Checkout page (rose theme, Phase 1 pilot of Live Per-Theme Checkout).
//
// Composes the SHARED theme-base mega-blocks CheckoutForm + CheckoutSummary.
// Those blocks carry ALL live logic via inline scripts (DaData autocomplete in
// CheckoutDeliveryForm, СДЭК delivery in CheckoutDeliveryMethod, YooKassa in
// CheckoutPayment, submit-chain in CheckoutSubmit). They are token-driven, so
// they inherit rose's colors. NO checkout-JS is rewritten here.
//
// Import mechanism: DIRECT relative import from packages/theme-base/blocks/.
// The block tree is fully self-contained (only sibling .astro + .classes value
// imports + type-only .puckConfig imports), so a relative path resolves the
// whole tree. astro.config.mjs adds vite.server.fs.allow = [workspaceRoot] so
// Vite can read files outside the themes/rose project root.
//
// Plumbing: the block inline-scripts need window.cartStore + window.__MERFY_CONFIG__
// (+ optional window.__DADATA_TOKEN__). themes/rose's native NtCart system does
// NOT expose window.cartStore, so we load the templates' cart-api.js + cart-store.js
// (copied into public/scripts/) and inject config on this page only — keeping the
// rest of the rose theme on its native cart.
import Layout from "../layouts/Layout.astro";
import CheckoutForm from "../../../../packages/theme-base/blocks/CheckoutForm/CheckoutForm.astro";
import CheckoutSummary from "../../../../packages/theme-base/blocks/CheckoutSummary/CheckoutSummary.astro";

// Pilot defaults. In production build.service.ts string-patches shopId and
// injects DADATA_API_KEY; here we hardcode the apiUrl and leave shopId/dadataToken
// to be patched at build/deploy time (the injection script below reads them).
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";
const dadataToken = "";
---
<Layout title="Оформление заказа" description="Оформление заказа" header="checkout">
  {/* Figma 1:13398 — checkout по умолчанию светлая схема (color-scheme-2).
      Мерчантскую «Цветовую схему» КАЖДОЙ панели (форма/сводка) красит её ФОН:
      на live её патчит unifyChromeInDist (data-checkout-column → color-scheme-N),
      в превью — injectCheckoutBlockIds. */}
  <div class="color-scheme-2">
    {/* Figma 1:19998 split-checkout: левая половина (форма) и правая (сводка) —
        две панели 50/50 во всю ширину, каждая заливается ФОНОМ своей схемы, без
        прогалов; контент прижат к середине (форма справа, сводка слева). */}
    <main class="mfy-checkout-split" style="color: rgb(var(--color-text));">
      <div class="mfy-checkout-pane mfy-checkout-pane--form" data-checkout-column="form">
        <div class="mfy-checkout-pane__inner">
          <CheckoutForm />
        </div>
      </div>
      <div class="mfy-checkout-pane mfy-checkout-pane--summary" data-checkout-column="summary">
        <div class="mfy-checkout-pane__inner">
          <CheckoutSummary />
        </div>
      </div>
    </main>
  </div>

  {/* Split-checkout CSS. Панель заливает фон своей схемы (--color-bg) во всю
      ширину половины; align-items:stretch уравнивает высоты → короткая сводка
      тянется до низа формы (нет белого просвета). Контент панелей ограничен и
      прижат к центральному стыку — как в Figma 1:19998.
      Покраска (запрос мерчанта): «Фон → инпуты» — `--color-input-bg` следует за
      фоном схемы панели (checkout-scoped alias; иначе инпуты остаются дефолтным
      белым из theme.json и не перекрашиваются). Текст инпутов уже идёт через
      --color-text; кнопки — через --color-button-* (основная кнопка). */}
  <style is:global>
    .mfy-checkout-split { display: flex; flex-direction: column; width: 100%; align-items: stretch; }
    .mfy-checkout-pane { width: 100%; box-sizing: border-box; background: rgb(var(--color-bg)); color: rgb(var(--color-text)); --color-input-bg: var(--color-bg); }
    .mfy-checkout-pane__inner { width: 100%; max-width: 560px; margin: 0 auto; padding: 32px 16px; box-sizing: border-box; }
    @media (min-width: 1024px) {
      .mfy-checkout-split { flex-direction: row; }
      .mfy-checkout-pane { width: 50%; display: flex; }
      .mfy-checkout-pane--form { justify-content: flex-end; }
      .mfy-checkout-pane--summary { justify-content: flex-start; }
      .mfy-checkout-pane--form .mfy-checkout-pane__inner { margin: 0 0 0 auto; max-width: 480px; padding: 56px 32px 56px 24px; }
      .mfy-checkout-pane--summary .mfy-checkout-pane__inner { margin: 0 auto 0 0; max-width: 520px; padding: 56px 24px 56px 40px; }
    }
  </style>

  {/* --- Live checkout plumbing (checkout page only) --- */}
  {/* Config injection (templates pattern). build.service.ts patches shopId +
      DADATA_API_KEY at deploy; for the local pilot the script just has to exist. */}
  <script is:inline define:vars={{ shopId, apiUrl, dadataToken }}>
    window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
      shopId: shopId || "",
      apiUrl: apiUrl || "https://gateway.merfy.ru/api",
    };
    if (dadataToken) {
      window.__DADATA_TOKEN__ = dadataToken;
    }
  </script>
  {/* `is:inline` is REQUIRED — without it Astro bundles these through Vite, can't
      resolve `/scripts/...` (public dir) and SILENTLY drops the tag, leaving
      window.cartStore undefined → empty checkout. cart-store.js imports cart-api.js,
      so both are loaded as ES modules. */}
  <script is:inline type="module" src="/scripts/cart-api.js"></script>
  <script is:inline type="module" src="/scripts/cart-store.js"></script>
  <script is:inline>
    // Чекаут рендерит «Сводку заказа» МГНОВЕННО из nt-cart (rose:cart:v1) — без
    // серверных запросов на загрузке. Серверная корзина (cartStore) синкается
    // позже, при «Оформить» (CheckoutSubmit → cartStore.syncToServer). Так товары
    // появляются сразу с лоадером, а не по одному.
    document.addEventListener("DOMContentLoaded", function () {
      var cs = window.cartStore;
      if (!cs) return;
      // express-ключ больше не используется (buy-now = вся корзина) — чистим на всякий
      try { sessionStorage.removeItem("rose:buynow"); } catch (e) {}
      var lines = [];
      try { lines = JSON.parse(localStorage.getItem("rose:cart:v1") || "[]"); } catch (e) { lines = []; }
      if (!Array.isArray(lines)) lines = [];
      // nt-cart → серверная форма для дисплея (priceCents = рубли*100). Серверные
      // запросы НЕ делаем — синк уйдёт в «Оформить» (cartStore.syncToServer).
      var display = lines.map(function (l) {
        var v = l.variant || {};
        var opts = {};
        if (v.color) opts["Цвет"] = v.color;
        if (v.size) opts["Размер"] = v.size;
        return {
          id: l.id,
          productId: l.productId,
          name: l.name,
          priceCents: Math.round((parseFloat(l.price) || 0) * 100),
          compareAtPriceCents: l.oldPrice ? Math.round((parseFloat(l.oldPrice) || 0) * 100) : undefined,
          image: l.image,
          imageUrl: l.image,
          quantity: l.quantity || 1,
          options: opts,
          variantCombinationId: (v.variantCombinationId) || null,
        };
      });
      if (cs.setLocalItems) cs.setLocalItems(display);
      else if (cs.init) cs.init();

      // Фоновый синк серверной корзины ПОСЛЕ мгновенного локального first-paint.
      // Сервер при пересчёте сам добавляет авто-BOGO «Подарок» (0₽-позиция,
      // isBonus) — без синка он не виден до сабмита. syncToServer({notify:true})
      // создаёт серверную корзину из локальных items, кладёт серверные items
      // (с подарком) в state и шлёт cart:updated → сводка/итоги перерисуются.
      // Локальный рендер уже на экране — это второй проход, не теряем first-paint.
      // debounce: уступаем место мгновенному рендеру и не воюем с apply-промокода
      // (in-flight guard в syncToServer дедуплицирует параллельные синки).
      if (display.length && cs.syncToServer) {
        setTimeout(function () {
          try { cs.syncToServer({ notify: true }).catch(function () {}); }
          catch (e) { /* сеть/корзина недоступны — остаёмся на локальном рендере */ }
        }, 250);
      }
    });
  </script>
</Layout>
