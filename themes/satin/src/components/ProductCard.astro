---
import SatinPicture from "./img/SatinPicture.astro";

interface Props {
	name: string;
	price: string;
	oldPrice: string;
	image: string;
	alt?: string;
}

const { name, price, oldPrice, image, alt = name } = Astro.props;
---

<article class="flex flex-col gap-4 sm:gap-5 md:gap-6 group cursor-pointer">
	<div class="bg-white border border-[#DDDDDD] rounded overflow-hidden w-full aspect-[318/515]">
		<SatinPicture
			src={image}
			alt={alt}
			loading="lazy"
			class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
		/>
	</div>
	<div class="flex flex-col gap-2 sm:gap-2.5 md:gap-3 px-0">
		<h3 class="text-sm sm:text-base md:text-lg lg:text-lg font-normal text-black leading-tight font-manrope">
			{name}
		</h3>
		<div class="flex items-center gap-2 sm:gap-3 md:gap-4 flex-wrap">
			<span class="text-base sm:text-lg md:text-xl lg:text-lg font-normal text-black leading-tight font-manrope">
				{price}
			</span>
			<span class="text-xs sm:text-sm md:text-base lg:text-sm font-light text-[#999999] line-through leading-tight font-manrope">
				{oldPrice}
			</span>
		</div>
	</div>
</article>
