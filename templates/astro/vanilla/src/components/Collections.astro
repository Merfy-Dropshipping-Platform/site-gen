---
import SectionHeader from './shared/SectionHeader.astro';
import CollectionCardItem from './shared/CollectionCardItem.astro';

interface Props {
  title?: string;
  subtitle?: string;
  titleSize?: string;
  subtitleSize?: string;
  dataSource?: string;
  collections?: Array<{ name: string; image: string; slug?: string }>;
  columnsCount?: number;
  imageView?: string;
  colorScheme?: string;
  padding?: { top?: number; bottom?: number };
}

const {
  title = 'Снова в продаже',
  subtitle = 'Стиль для каждой ситуации - найдите свой в каталоге.',
  titleSize = 'small',
  subtitleSize = 'small',
  dataSource = 'auto',
  collections = [],
  columnsCount = 2,
  imageView = 'square',
  colorScheme,
  padding = { top: 120, bottom: 120 },
} = Astro.props;
const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';

let collectionsData = collections || [];

if (dataSource === 'auto' || collectionsData.length === 0) {
  try {
    const imported = await import('../data/collections.json');
    collectionsData = imported.default || [];
  } catch {
    collectionsData = [];
  }
}

const cols = columnsCount || 2;
const aspectMap: Record<string, string> = {
  portrait: '430/500',
  square: '1/1',
  wide: '16/9',
};
const aspect = aspectMap[imageView] || aspectMap.square;
const padTop = padding?.top ?? 120;
const padBottom = padding?.bottom ?? 120;
---

<section
  id="collections"
  class={`w-full scroll-mt-16 sm:scroll-mt-20 ${schemeClass}`}
  style={`padding-top: ${padTop}px; padding-bottom: ${padBottom}px; background: rgb(var(--color-background)); color: rgb(var(--color-foreground));`}
>
  <div class="max-w-[1320px] mx-auto px-5">
    <SectionHeader title={title} subtitle={subtitle} />

    {collectionsData.length > 0 && (
    <div class="collections-grid" role="list">
      {collectionsData.map((collection, index) => (
        <CollectionCardItem
          name={collection.name}
          image={collection.image}
          slug={collection.slug}
          aspect={aspect}
          eager={index < 2}
        />
      ))}
    </div>
    )}
  </div>
</section>

<style define:vars={{ cols }}>
  .collections-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 640px) {
    .collections-grid {
      grid-template-columns: repeat(var(--cols), 1fr);
      gap: 16px;
    }
  }
</style>
