---
// Секция «Корзина» (V2-порт rose). Вынесена из themes/rose/src/pages/cart.astro
// БЕЗ изменения логики — та же ванильная корзина (getCart/render + мост checkout +
// cart-store.js/cart-api.js). Теперь это Puck-секция: page-cart редактируема как
// главная, корзину можно двигать/настраивать, добавлять другие секции вокруг.
// Корзина одна на странице (maxInstances:1) → document.querySelector безопасен
// (first-match не ловит дубль). Резолвится раньше theme-base скаффолда (resolveV2Section).
import { withBase } from "../../lib/with-base";

interface Props {
	id?: string;
	padding?: { top: number; bottom: number };
}
const { id, padding } = Astro.props as Props;

const deleteIconSrc = withBase("/icons/delete.svg");
// Мост корзины → checkout: build.service.ts патчит `const shopId = ""` → siteId на деплое.
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";
// Проп «Отступы» из конструктора (px). Если не задан — дефолтные адаптивные классы.
const padStyle = padding
	? `padding-top:${Math.min(Number(padding.top) || 0, 160)}px;padding-bottom:${Math.min(Number(padding.bottom) || 0, 160)}px;`
	: undefined;
---

<section
	data-puck-component-id={id}
	data-block="cart-section"
	class:list={[
		"w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 sm:px-5 md:px-10 lg:px-16 xl:px-20 2xl:px-[280px]",
		padStyle ? "" : "pb-16 pt-12 sm:pb-20 sm:pt-16 md:pb-[120px] md:pt-20 lg:pb-[140px] lg:pt-24 xl:pb-[140px] xl:pt-28",
	]}
	style={padStyle}
	aria-labelledby="cart-title"
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-16 lg:gap-20">
		<!-- Пустое состояние -->
		<div
			data-cart-page-empty
			class="flex flex-col items-center gap-4 py-10 sm:gap-6 md:py-16"
		>
			<h1 id="cart-title" class="rose-title">
				Корзина
			</h1>
			<p class="rose-subtitle text-center max-w-md">
				Вы пока не добавили товар в корзину.
			</p>
			<a
				href="/catalog"
				class="inline-flex h-12 items-center justify-center rounded-[var(--radius-button,6px)] bg-[rgb(var(--color-button-bg,0_0_0))] px-6 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-95 sm:text-[16px]"
			>
				Продолжить покупки
			</a>
			<p class="font-manrope text-[12px] font-normal leading-[1.43] text-[rgb(var(--color-muted,153_153_153))] sm:text-[14px] md:text-[16px]">
				Есть аккаунт?
				<a href="/auth/sign-in" class="text-[rgb(var(--color-text,0_0_0))] hover:opacity-80">Войти</a>
			</p>
		</div>

		<!-- Наполненная корзина -->
		<div
			data-cart-page-filled
			class="hidden flex-col gap-10 lg:gap-12"
		>
			<h1 class="rose-title">
				Корзина
			</h1>
			<ul
				data-cart-page-items
				role="list"
				class="flex flex-col gap-4 sm:gap-6"
			></ul>
			<div class="flex flex-col items-end gap-4 pt-6 sm:gap-5 sm:pt-8">
				<p class="max-w-md text-right font-manrope text-[12px] font-light leading-[1.5] text-[rgb(var(--color-muted,153_153_153))] sm:text-[13px] md:text-[14px]">
					Налоги, скидки и стоимость доставки рассчитываются при оформлении заказа
				</p>
				<div class="flex w-full flex-wrap items-baseline justify-end gap-x-3 gap-y-1 sm:gap-x-4">
					<span class="font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] sm:text-[16px] md:text-[18px]">Итого</span>
					<span data-cart-page-total class="font-manrope text-[18px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] sm:text-[20px] md:text-[24px]">0 ₽</span>
				</div>
				<button
					type="button"
					data-action="checkout"
					class="inline-flex h-12 w-full max-w-[320px] items-center justify-center rounded-[var(--radius-button,6px)] !bg-[rgb(var(--color-button-bg,0_0_0))] px-6 font-manrope text-[14px] font-normal leading-normal !text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-95 sm:w-auto sm:min-w-[200px] sm:text-[16px]"
				>
					Оформить заказ
				</button>
			</div>
		</div>
	</div>
</section>

<script>
	import { getCart, getCartTotal, formatCartPrice } from "../../lib/cart";
	import { cartLineThumbPictureHtml } from "../../lib/cart-thumb-html";

	const deleteIconSrc =
		(window as unknown as { __ROSE_DELETE_ICON__?: string }).__ROSE_DELETE_ICON__ ?? "/icons/delete.svg";

	const VARIANT_COLOR_LABELS: Record<string, string> = {
		brown: "Коричневый",
		black: "Чёрный",
		white: "Белый",
		olive: "Оливковый",
		gray: "Серый",
	};

	const emptyBlock = document.querySelector<HTMLElement>("[data-cart-page-empty]");
	const filledBlock = document.querySelector<HTMLElement>("[data-cart-page-filled]");
	const itemsEl = document.querySelector<HTMLElement>("[data-cart-page-items]");
	const totalEl = document.querySelector<HTMLElement>("[data-cart-page-total]");

	const render = () => {
		const lines = getCart();
		if (!emptyBlock || !filledBlock || !itemsEl || !totalEl) return;
		if (lines.length === 0) {
			emptyBlock.classList.remove("hidden");
			emptyBlock.classList.add("flex");
			filledBlock.classList.add("hidden");
			filledBlock.classList.remove("flex");
			return;
		}
		emptyBlock.classList.add("hidden");
		emptyBlock.classList.remove("flex");
		filledBlock.classList.remove("hidden");
		filledBlock.classList.add("flex");

		itemsEl.innerHTML = lines
			.map((line) => {
				const slug = line.variant?.color ?? "";
				const colorLabel = slug ? (VARIANT_COLOR_LABELS[slug] ?? slug) : "";
				const sizePart = line.variant?.size ?? "";
				const variantUnderPrice = [colorLabel, sizePart].filter(Boolean).join(", ");
				const totalCurrent = formatCartPrice(line.price * line.quantity);
				const totalOld =
					typeof line.oldPrice === "number" && line.oldPrice > line.price
						? formatCartPrice(line.oldPrice * line.quantity)
						: "";

				return `
					<li class="flex gap-4 sm:gap-6 md:flex-row md:items-start md:justify-between" data-line-id="${line.id}">
						<div class="flex min-w-0 flex-1 gap-3 sm:gap-4">
							<a href="/products/${line.productId}" class="block size-20 shrink-0 overflow-hidden rounded-[8px] bg-[#F5F5F5] sm:size-24 md:size-[120px]">
								${cartLineThumbPictureHtml(line.image, line.name)}
							</a>
							<div class="flex min-w-0 flex-col gap-2">
								<a href="/products/${line.productId}" class="font-manrope text-[14px] font-normal leading-none tracking-normal text-[#000000] hover:opacity-80 sm:text-[15px] md:text-[18px]">${line.name}</a>
								<div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
									<span class="font-manrope text-[14px] font-normal leading-normal text-[#000000] sm:text-[16px] md:text-[18px]">${totalCurrent}</span>
									${
										totalOld
											? `<span class="font-manrope text-[13px] font-light leading-normal text-[#999999] line-through sm:text-[14px] md:text-[16px]">${totalOld}</span>`
											: ""
									}
								</div>
								${
									variantUnderPrice
										? `<p class="font-manrope text-[12px] font-light leading-normal text-[#999999] sm:text-[13px] md:text-[14px]">${variantUnderPrice}</p>`
										: ""
								}
							</div>
						</div>
						<div class="flex shrink-0 flex-col items-end gap-3 self-start md:gap-4">
							<button type="button" data-cart-remove data-id="${
								line.id
							}" class="flex size-9 items-center justify-center rounded-[4px] text-[#000000] transition-opacity hover:bg-[#F5F5F5] hover:opacity-80 md:size-10" aria-label="Удалить товар из корзины">
								<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="pointer-events-none size-[22px] md:size-6" aria-hidden="true"><path d="M4 7h16M10 7V5a1 1 0 011-1h2a1 1 0 011 1v2M6 7l1 14a1 1 0 001 1h8a1 1 0 001-1l1-14M10 11v6M14 11v6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
							</button>
							<div class="inline-flex h-10 items-center rounded-[4px] border border-solid border-[#E5E5E5]">
								<button type="button" data-cart-dec data-id="${line.id}" class="flex h-10 w-10 items-center justify-center font-manrope text-[16px] text-[#000000]" aria-label="Уменьшить">−</button>
								<span class="min-w-[28px] text-center font-manrope text-[12px] text-[#000000] sm:text-[14px]">${line.quantity}</span>
								<button type="button" data-cart-inc data-id="${line.id}" class="flex h-10 w-10 items-center justify-center font-manrope text-[16px] text-[#000000]" aria-label="Увеличить">+</button>
							</div>
						</div>
					</li>
				`;
			})
			.join("");

		totalEl.textContent = formatCartPrice(getCartTotal(lines));
	};

	render();
	document.addEventListener("astro:page-load", render);
	window.addEventListener("rose:cart:updated", render);

	document.addEventListener("click", (event) => {
		const target = event.target as HTMLElement;
		const checkout = target.closest<HTMLButtonElement>("[data-action='checkout']");
		if (checkout) {
			void (async () => {
				const cs = (window as any).cartStore;
				const lines = getCart();
				if (!cs) {
					window.alert("Корзина ещё загружается. Обновите страницу и попробуйте снова.");
					return;
				}
				if (lines.length) {
					let ok = true;
					try {
						cs.clear();
						for (const l of lines) {
							if ((await cs.addItem(l.productId, l.variant?.variantCombinationId ?? null, l.quantity)) === false) ok = false;
						}
					} catch (e) {
						ok = false;
					}
					if (!ok) {
						window.alert("Не удалось перенести товары в оформление. Обновите страницу и попробуйте снова.");
						return;
					}
				}
				window.location.href = "/checkout";
			})();
		}
	});
</script>

{/* Мост корзины → backend cart: грузим cartStore + конфиг (shopId патчится на деплое). */}
<script is:inline define:vars={{ shopId, apiUrl, deleteIconSrc }}>
	window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
		shopId: shopId || "",
		apiUrl: apiUrl || "https://gateway.merfy.ru/api",
	};
	window.__ROSE_DELETE_ICON__ = deleteIconSrc;
</script>
<script is:inline type="module" src="/scripts/cart-api.js"></script>
<script is:inline type="module" src="/scripts/cart-store.js"></script>
