---
import type { PublicationsProps } from './Publications.puckConfig';
import { PublicationsClasses as C } from './Publications.classes';
import { PLACEHOLDER_ASSETS } from '../../runtime/placeholders';

interface Props extends PublicationsProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  columns = 3,
  cards = 3,
  padding,
} = Astro.props as Props;

// Accept legacy {text,size} heading envelope.
const headingText = (() => {
  const h = raw.heading;
  if (typeof h === 'string') return h || undefined;
  if (h && typeof h === 'object') {
    const o = h as { text?: string };
    return o.text || undefined;
  }
  return undefined;
})();

// SSR fetch publications from storefront-data endpoint (gateway → sites-service).
type RawPublication = {
  id: string;
  title?: string;
  slug?: string;
  excerpt?: string;
  category?: string;
  coverImageUrl?: string | null;
  publishedAt?: string | null;
};
type Article = { id?: string; date: string; title: string; excerpt: string; image?: string; slug?: string };

function formatDate(iso: string | null | undefined): string {
  if (!iso) return '';
  try {
    return new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(iso));
  } catch {
    return '';
  }
}

const siteIdFromRoot = typeof raw.siteId === 'string' ? raw.siteId : '';
let realPublications: RawPublication[] = [];
if (siteIdFromRoot) {
  try {
    const internalBase = (import.meta as unknown as { env?: { SITES_INTERNAL_BASE?: string } }).env?.SITES_INTERNAL_BASE
      ?? 'http://localhost:3114';
    const res = await fetch(`${internalBase}/api/sites/${siteIdFromRoot}/publications`).catch(() => null);
    if (res && res.ok) {
      const data = (await res.json()) as { publications?: RawPublication[] };
      realPublications = data.publications ?? [];
    }
  } catch {/* swallow */}
}
try {
  if (realPublications.length === 0) {
    const pubData = await import('../data/publications.json');
    realPublications = ((pubData as { default?: RawPublication[] }).default ?? (pubData as unknown as RawPublication[])) as RawPublication[];
  }
} catch {/* swallow — publications.json absent */}

// Placeholder articles (Figma 1:19531 reference cards) when no real
// publications exist yet — keeps preview alive for seed sites.
const DEMO_ARTICLES: Article[] = [
  { date: '15 марта 2025', title: 'Новая коллекция весна 2025', excerpt: 'Рассказываем о вдохновении и ключевых силуэтах новой коллекции.' },
  { date: '28 февраля 2025', title: 'Как ухаживать за кожаными изделиями', excerpt: 'Простые правила, чтобы ваши вещи служили долгие годы.' },
  { date: '10 февраля 2025', title: 'История бренда: от идеи до магазина', excerpt: 'Путь от первой сумки, сшитой вручную, до собственной коллекции.' },
  { date: '25 января 2025', title: 'Тренды аксессуаров 2025', excerpt: 'Обзор ключевых трендов сезона — от цветов до фактур.' },
];

const hasRealPublications = realPublications.length > 0;
const items: Article[] = (hasRealPublications
  ? realPublications.map((p) => ({
      id: p.id,
      slug: p.slug,
      date: formatDate(p.publishedAt),
      title: p.title ?? '',
      excerpt: p.excerpt ?? '',
      image: p.coverImageUrl ?? undefined,
    }))
  : DEMO_ARTICLES
).slice(0, cards);

// Pupa parity: cardsCount, columnsCount, headingAlignment, headingSize, dateTime.enabled, colorScheme.
const cardsResolved = typeof raw.cardsCount === 'number' ? raw.cardsCount : cards;
const columnsResolved = typeof raw.columnsCount === 'number' ? raw.columnsCount : columns;
const headingObj = raw.heading;
const headingAlignment =
  (typeof headingObj === 'object' ? (headingObj as { alignment?: string })?.alignment : undefined) ??
  (typeof raw.headingAlignment === 'string' ? raw.headingAlignment : undefined);
const headingSize =
  (typeof headingObj === 'object' ? (headingObj as { size?: string })?.size : undefined) ??
  (typeof raw.headingSize === 'string' ? raw.headingSize : undefined);
const dateTimeEnabled = (raw.dateTime as { enabled?: string } | undefined)?.enabled !== 'false';
const colorScheme = raw.colorScheme as string | undefined;
const schemeClass = colorScheme ? `color-scheme-${String(colorScheme).replace('scheme-', '')}` : '';
const headingAlignClass =
  headingAlignment === 'left' ? 'text-left' :
  headingAlignment === 'right' ? 'text-right' :
  headingAlignment === 'center' ? 'text-center' : '';
const headingSizeClass =
  headingSize === 'large' ? 'text-3xl md:text-4xl' :
  headingSize === 'medium' ? 'text-2xl md:text-3xl' :
  headingSize === 'small' ? 'text-xl md:text-2xl' : '';

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
const gridTemplateCols = `grid-template-columns: repeat(${columnsResolved}, minmax(0, 1fr));`;
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-block="publications"
  style={paddingStyle}
>
  <div class={C.container}>
    {headingText && (
      <h2 class:list={[C.heading, headingAlignClass, headingSizeClass]} data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">{headingText}</h2>
    )}
    <div class={C.grid} style={gridTemplateCols}>
      {items.slice(0, cardsResolved).map((item, i) => {
        const href = item.slug ? `/publication/${item.slug}` : '#';
        const Wrapper = item.slug ? 'a' : 'article';
        return (
          <Wrapper class={C.card} href={item.slug ? href : undefined} data-article-index={i}>
            {item.image ? (
              <img src={item.image} alt={item.title} class={`${C.cardMedia} object-cover`} loading="lazy" />
            ) : (
              <img src={PLACEHOLDER_ASSETS.publicationCard} alt="" class={`${C.cardMedia} object-cover`} aria-hidden="true" loading="lazy" />
            )}
            <div class={C.cardBody}>
              {dateTimeEnabled && item.date && <div class={C.cardDate}>{item.date}</div>}
              <div class={C.cardTitle}>{item.title}</div>
              {item.excerpt && <div class={C.cardExcerpt}>{item.excerpt}</div>}
            </div>
          </Wrapper>
        );
      })}
    </div>
  </div>
</section>
