---
interface Props {
	id?: string;
	name: string;
	price: string;
	oldPrice?: string;
	image: string;
	href?: string;
	quantity?: number;
	quickAdd?: boolean;
}

const { id, name, price, oldPrice, image, href = '#', quantity, quickAdd = false } = Astro.props;
const hasImage = image && !image.includes('placeholder');
---

<article class="flex flex-col gap-4 sm:gap-5 md:gap-6 lg:gap-[25px] group cursor-pointer">
	<a href={href} class="cursor-pointer">
		<div class="bg-gray-100 rounded-lg sm:rounded-[8px] md:rounded-[10px] overflow-hidden w-full aspect-[318/515]">
			{hasImage ? (
				<img
					src={image}
					alt={name}
					loading="lazy"
					class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
				/>
			) : (
				<div class="w-full h-full flex items-center justify-center" style="background: rgb(var(--color-foreground) / 0.05);">
					<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-theme-muted">
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
						<circle cx="8.5" cy="8.5" r="1.5" />
						<polyline points="21 15 16 10 5 21" />
					</svg>
				</div>
			)}
		</div>
	</a>
	<div class="flex flex-col gap-2 sm:gap-2.5 md:gap-3 lg:gap-[10px] px-2 sm:px-3 md:px-4 lg:px-[15px]">
		<a href={href} class="no-underline text-inherit">
			<h3 class="text-base sm:text-lg md:text-xl lg:text-[24px] font-normal text-theme-foreground leading-[1.366] font-manrope line-clamp-2">
				{name}
			</h3>
		</a>
		<div class="flex items-center gap-2 sm:gap-3 md:gap-4 lg:gap-[15px] flex-wrap">
			<span class="text-lg sm:text-xl md:text-2xl lg:text-[32px] font-normal text-theme-foreground leading-[1.366] font-manrope">
				{price}
			</span>
			{oldPrice && (
				<span class="text-sm sm:text-base md:text-lg lg:text-[20px] font-medium text-[#999999] line-through leading-[1.366] font-manrope">
					{oldPrice}
				</span>
			)}
		</div>
		{quickAdd && id && (
			<button
				type="button"
				class="add-to-cart-btn mt-2 w-full py-2 px-4 text-sm font-normal rounded-[10px] hover:opacity-90 transition-colors font-manrope"
				style="background: rgb(var(--color-button)); color: rgb(var(--color-button-text));"
				data-product-id={id}
				data-stock={quantity != null ? quantity : undefined}
			>
				В корзину
			</button>
		)}
	</div>
</article>
