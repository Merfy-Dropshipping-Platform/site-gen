---
import VanillaProductCard from "../products/VanillaProductCard.astro";
import { catalogProducts } from "../../data/products";

// ОЖИВЛЕНИЕ (Фаза B, контракт bloom Popular T13): полная конструкторная схема
// theme-base PopularProducts.puckConfig поверх разметки верстальщика. Тело +
// demo-данные verbatim (страницы зовут <Popular /> без пропсов — дефолт-ветка
// даёт прежний рендер). Шапка — СВОЯ у vanilla (Bitter italic 20 + Arsenal
// italic 16), НЕ DS NtSectionHeading. Канон-дефолты конструктора (textSize
// small, imageView square, quickAddMode none, columns 3 из blockDefaults) →
// пиксель верстальщика; дефолтные ветки тернарников = прежние строки
// байт-в-байт (цвета → токены с пиксель-фоллбеком родных литералов, §7).
// ⚠️ canon-default puckConfig headingSize='small' при литерале верстальщика
// 20px = medium (MANNER §9: canon-default роли «заголовок секции» — medium);
// рекомендация следующей фазе — blockDefaults PopularProducts.headingSize=
// 'medium' в theme.json (как columns: 3 сейчас).
const p = Astro.props as Record<string, any>;
const id = p.id;
const sectionTitle =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title ?? "Популярные товары";
// Подзаголовок у верстальщика ЕСТЬ — дефолт-литерал рендерится и при пустом
// пропе (конструктор вставляет text: '' из canon-дефолтов).
const rawSubtitle =
	(typeof p.text === "string" ? p.text : p.text?.content) ??
	(typeof p.subtitle === "string" ? p.subtitle : p.subtitle?.content);
const sectionSubtitle =
	typeof rawSubtitle === "string" && rawSubtitle.trim()
		? rawSubtitle
		: "Вдохновение для каждого дня — актуальные коллекции текстиля и декора, созданные, чтобы радовать и удивлять.";

// Канон headingSize (top-level приоритетнее legacy heading.size): 'medium' и
// отсутствие = роль «заголовок секции» верстальщика дословно (Bitter italic
// 20). Лестница §9: small 17, large 24.
const headingSize = p.headingSize ?? p.heading?.size;
const headingCls =
	headingSize === "small"
		? "font-vanilla-bitter text-[17px] font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]"
		: headingSize === "large"
			? "font-vanilla-bitter text-[24px] font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]"
			: "font-vanilla-bitter text-[20px] font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]";
// Канон textSize: 'small' (canon-default) и отсутствие = подзаголовок
// верстальщика дословно (Arsenal italic 16). Лестница §9: medium 19, large 23.
const textSize = p.textSize ?? p.text?.size;
const subtitleCls =
	textSize === "medium"
		? "font-vanilla-arsenal text-[19px] font-normal italic leading-none text-[rgb(var(--color-muted,68_68_68))]"
		: textSize === "large"
			? "font-vanilla-arsenal text-[23px] font-normal italic leading-none text-[rgb(var(--color-muted,68_68_68))]"
			: "font-vanilla-arsenal text-base font-normal italic leading-none text-[rgb(var(--color-muted,68_68_68))]";

// Канон cards 2-24: лимит demo-среза и гидрации (data-cards на гриде).
// 6 = срез верстальщика (и отсутствие пропа) → дефолт-ветка.
const cardsN =
	typeof p.cards === "number" && p.cards > 0 ? Math.max(1, Math.min(24, Math.round(p.cards))) : 6;

// Под Container API (live/превью v2) cwd ≠ корень темы: fs-проверка
// VanillaPicture не находит public/ и .png остался бы в src (на диске темы
// только .webp → 404). Подменяем расширение заранее; на сборке темы вывод
// байт-в-байт тот же (VanillaPicture/assetUrl находят тот же .webp).
const toWebp = (src: string) => src.replace(/\.(png|jpe?g)$/i, ".webp");
const products = catalogProducts
	.slice(0, cardsN)
	.map((prod) => ({ ...prod, image: toWebp(prod.image) }));

// Канон columns 1-6: 3 (canon-default из blockDefaults vanilla = литерал
// md:grid-cols-3 верстальщика) и отсутствие → дефолт-ветка; иное →
// inline-var на гриде с md (мобильная лестница 1→sm:2 сохраняется).
const colsRaw =
	typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : undefined;
const cols = colsRaw && colsRaw !== 3 ? colsRaw : undefined;
// Канон imageView square/portrait/wide (+legacy alias adaptive→wide):
// 'square' (canon-default) и отсутствие = aspect-square карточки верстальщика;
// portrait → 430/500, wide → 16/9 (перекрытие медиа-ссылки карточки — и
// demo-SSR VanillaProductCard, и гидрированной renderCardHtml: обе article>a).
const tileAspectCls =
	p.imageView === "portrait"
		? " [&_li>article>a]:aspect-[430/500]"
		: p.imageView === "wide" || p.imageView === "adaptive"
			? " [&_li>article>a]:aspect-[16/9]"
			: "";
const gridCls =
	(cols
		? "grid grid-cols-1 gap-x-3 gap-y-9 sm:grid-cols-2 md:grid-cols-[repeat(var(--cols),minmax(0,1fr))] md:gap-x-4 md:gap-y-12"
		: "grid grid-cols-1 gap-x-3 gap-y-9 sm:grid-cols-2 md:grid-cols-3 md:gap-x-4 md:gap-y-12") +
	tileAspectCls;
const gridStyle = cols ? `--cols:${cols}` : undefined;

// Канон quickAddMode none/standard/cart (+legacy alias count→cart). НЮАНС
// vanilla: карточка верстальщика БЕЗ кнопки — 'none' (canon-default) и
// отсутствие = карточка verbatim; standard/cart ДОБАВЛЯЮТ кнопку «В корзину»
// в манере §3 (solid h-12 uppercase). Носители для гидрации — data-quick-add
// и data-qa-text/data-qa-cls на гриде; клики ловит делегат nt-cart-vanilla
// ([data-add-to-cart] + data-product-id/name/price/image, как PDP).
const qaModeRaw = p.quickAddMode === "count" ? "cart" : p.quickAddMode;
const quickAddMode = qaModeRaw === "standard" || qaModeRaw === "cart" ? qaModeRaw : undefined;
const quickAddText =
	(typeof p.quickAddText === "string" && p.quickAddText) ||
	(quickAddMode === "cart" ? "В КОРЗИНУ" : "В корзину");
const QA_BTN_CLS =
	"mt-3 inline-flex h-12 min-h-12 w-full items-center justify-center bg-[rgb(var(--color-button-bg,58_69_48))] px-4 font-vanilla-arsenal text-base font-normal uppercase leading-none tracking-normal text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-90";

// Канон buttonStyle link/primary/secondary — стиль добавленной кнопки.
// primary/отсутствие = solid-манера дословно; secondary = контур в тонах
// кнопки-1; link = текстовая ссылка. Носитель — data-btn-style на гриде +
// глобальный <style> ниже (работает и для SSR-demo, и для гидрации).
const btnStyle =
	p.buttonStyle === "secondary" || p.buttonStyle === "link" ? p.buttonStyle : undefined;

// Канон nextPhotoOnHover (toggle, true/'true'): смена фото на вторую картинку
// товара при наведении. Носитель данных: data-image-2 на <li> (demo —
// gallery[1] верстальщика, если есть; реальные товары — images[1], ставит
// гидрация ниже).
const nextPhoto = p.nextPhotoOnHover === true || p.nextPhotoOnHover === "true";
// is:inline + set:html (без define:vars — компилятор секций его не умеет);
// идемпотентность data-np-hydrated; без data-image-2 скрипт — no-op.
const NEXT_PHOTO_JS = [
	"(function(){",
	"var grids=document.querySelectorAll('[data-nt=\"popular-grid\"][data-next-photo]');",
	"for(var i=0;i<grids.length;i++){(function(g){",
	"if(g.getAttribute('data-np-hydrated')==='true')return;",
	"g.setAttribute('data-np-hydrated','true');",
	"function swap(li,on){",
	"var u=on?li.getAttribute('data-image-2'):null;",
	"var im=li.querySelectorAll('img');",
	"for(var j=0;j<im.length;j++){",
	"if(on){if(!im[j].getAttribute('data-image-1'))im[j].setAttribute('data-image-1',im[j].getAttribute('src')||'');im[j].setAttribute('src',u);}",
	"else{var s1=im[j].getAttribute('data-image-1');if(s1)im[j].setAttribute('src',s1);}",
	"}",
	"var so=li.querySelectorAll('source');",
	"for(var k=0;k<so.length;k++){",
	"if(on){if(!so[k].getAttribute('data-srcset-1'))so[k].setAttribute('data-srcset-1',so[k].getAttribute('srcset')||'');so[k].setAttribute('srcset',u);}",
	"else{var ss=so[k].getAttribute('data-srcset-1');if(ss)so[k].setAttribute('srcset',ss);}",
	"}",
	"}",
	"g.addEventListener('mouseover',function(e){",
	"var t=e.target;if(!t||!t.closest)return;",
	"var li=t.closest('li[data-image-2]');",
	"if(!li||!g.contains(li)||li.getAttribute('data-np-on')==='true')return;",
	"li.setAttribute('data-np-on','true');swap(li,true);",
	"});",
	"g.addEventListener('mouseout',function(e){",
	"var t=e.target;if(!t||!t.closest)return;",
	"var li=t.closest('li[data-image-2]');",
	"if(!li||li.getAttribute('data-np-on')!=='true')return;",
	"var to=e.relatedTarget;if(to&&li.contains(to))return;",
	"li.setAttribute('data-np-on','false');swap(li,false);",
	"});",
	"})(grids[i]);}",
	"})();",
].join("");

// Канон viewAll {show,text,href}: кнопка под гридом — «Смотреть все товары»
// коллекции (Figma 1-33175, контракт rose Popular). По умолчанию ПОКАЗАНА
// (часть дизайна секции), скрыть — viewAll.show === false. Текст по умолчанию
// «Смотреть все товары»; href ведёт на каталог выбранной коллекции
// (?collection=) либо в общий каталог.
const viewAllRaw = p.viewAll;
const viewAllShow = !(
	viewAllRaw &&
	typeof viewAllRaw === "object" &&
	(viewAllRaw.show === false || viewAllRaw.show === "false")
);
const viewAllText =
	(!!viewAllRaw &&
		typeof viewAllRaw === "object" &&
		typeof viewAllRaw.text === "string" &&
		viewAllRaw.text) ||
	"Смотреть все товары";
const viewAllCollection =
	typeof p.collection === "string" && p.collection.trim() ? p.collection.trim() : "";
const viewAllHref =
	(!!viewAllRaw &&
		typeof viewAllRaw === "object" &&
		typeof viewAllRaw.href === "string" &&
		viewAllRaw.href) ||
	(viewAllCollection ? `/catalog?collection=${encodeURIComponent(viewAllCollection)}` : "/catalog");
// Стиль кнопки «Смотреть все» = единый «Стиль кнопки» секции (buttonStyle, Figma
// 1195-42536): link = текстовая ссылка с подчёркиванием, secondary = контурная
// (бордер в тонах кнопки-1), primary/отсутствие = solid-манера (заливка
// кнопки-1). Манера vanilla: font-vanilla-arsenal uppercase, острые углы (без
// радиуса), токены кнопки-1.
const viewAllBase =
	"inline-flex h-12 min-h-12 items-center justify-center font-vanilla-arsenal text-base font-normal uppercase leading-none tracking-normal transition-opacity";
const viewAllCls =
	p.buttonStyle === "link"
		? `${viewAllBase} px-0 text-[rgb(var(--color-text,0_0_0))] underline underline-offset-4 hover:opacity-70`
		: p.buttonStyle === "secondary"
			? `${viewAllBase} border border-solid border-[rgb(var(--color-button-bg,58_69_48))] bg-transparent px-6 text-[rgb(var(--color-button-bg,58_69_48))] hover:opacity-90 sm:px-16`
			: `${viewAllBase} bg-[rgb(var(--color-button-bg,58_69_48))] px-6 text-[rgb(var(--color-button-text,255_255_255))] hover:opacity-90 sm:px-16`;

// Канон collection (collectionPicker, id или slug): носитель — data-collection
// на гриде; фильтрацию делает гидрация (filterByCollection: productIds
// коллекции → membership товара → все, паритет theme-base). Demo — no-op.
const collectionRef =
	typeof p.collection === "string" && p.collection.trim() ? p.collection.trim() : undefined;

// blockDefaults vanilla swatchOverlay/cardCaptionStyle/headingAlignment —
// демо-карточка верстальщика уже несёт свотчи и капс-подписи (VanillaProductCard
// и renderCardHtml), отдельный рендер-свитч не требуется.

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id="popular"
	class="vanilla-pad w-full bg-[rgb(var(--color-bg,238_238_238))] py-20 md:py-28"
	aria-labelledby="popular-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="vanilla-container flex max-w-[1180px] flex-col gap-8">
		<div
			class="flex max-w-[760px] flex-col gap-2"
			data-animate
			data-puck-subsection-parent={id}
			data-puck-subsection-index="100"
			data-puck-subsection-field="heading"
		>
			<h2 id="popular-title" class={headingCls}>
				{sectionTitle}
			</h2>
			<p class={subtitleCls}>{sectionSubtitle}</p>
		</div>

		<ul
			class={gridCls}
			role="list"
			data-animate
			data-animate-delay="0.1s"
			data-nt="popular-grid"
			style={gridStyle}
			data-cards={cardsN !== 6 ? String(cardsN) : undefined}
			data-collection={collectionRef}
			data-next-photo={nextPhoto ? "true" : undefined}
			data-quick-add={quickAddMode}
			data-qa-text={quickAddMode ? quickAddText : undefined}
			data-qa-cls={quickAddMode ? QA_BTN_CLS : undefined}
			data-btn-style={btnStyle}
		>
			{products.map((product) => (
				<li
					data-product-id={product.id}
					data-image-2={nextPhoto && product.gallery?.[1] ? toWebp(product.gallery[1]) : undefined}
				>
					<VanillaProductCard product={product} />
					{quickAddMode && (
						<button
							type="button"
							data-add-to-cart
							data-product-id={product.id}
							data-name={product.name}
							data-price={product.price}
							data-image={product.image}
							class={QA_BTN_CLS}
						>
							{quickAddText}
						</button>
					)}
				</li>
			))}
		</ul>{viewAllShow && (
			<div class="flex w-full justify-center">
				<a
					href={viewAllHref}
					class={viewAllCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="viewAll"
				>
					{viewAllText}
				</a>
			</div>
		)}
	</div>
</section>{nextPhoto && <script is:inline set:html={NEXT_PHOTO_JS} />}

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		resolveCollectionProducts,
		renderCardHtml,
		productImage,
		formatPrice,
		escapeHtml,
	} from "../../lib/storefront-hydrate";

	// Текст добавленной кнопки (quickAddText): применяется и к demo-SSR, и к
	// перерисованным гидрацией карточкам.
	const applyQaText = (grid: HTMLElement) => {
		const text = grid.getAttribute("data-qa-text");
		if (!text) return;
		for (const btn of Array.from(grid.querySelectorAll<HTMLElement>("[data-add-to-cart]"))) {
			if (btn.textContent !== text) btn.textContent = text;
		}
	};

	// Реальные товары (Option B, расширение прежнего hydrateGrid по bloom):
	// первые N из /data/products.json (N = data-cards, дефолт 6 — срез
	// верстальщика). Канон-поля T13 поверх: data-collection → фильтр по
	// коллекции, data-next-photo → data-image-2 (вторая картинка товара) для
	// hover-скрипта, data-quick-add → кнопка «В корзину» с атрибутами корзины
	// (класс из data-qa-cls — единый источник с SSR). Demo-сборка → no-op
	// (только переименование кнопки).
	const hydratePopular = async () => {
		const grids = Array.from(document.querySelectorAll<HTMLElement>('[data-nt="popular-grid"]'));
		if (grids.length === 0) return;
		const products = await loadRealProducts();
		if (!products) {
			for (const grid of grids) applyQaText(grid);
			return;
		}
		const needCollections = grids.some((g) => g.getAttribute("data-collection"));
		const collections = needCollections ? await loadRealCollections() : null;
		for (const grid of grids) {
			const limitRaw = Number(grid.getAttribute("data-cards"));
			const limit = Number.isFinite(limitRaw) && limitRaw > 0 ? limitRaw : 6;
			const wantNextPhoto = grid.hasAttribute("data-next-photo");
			const wantQuickAdd = grid.hasAttribute("data-quick-add");
			const qaCls = grid.getAttribute("data-qa-cls") || "";
			const collectionRef = grid.getAttribute("data-collection");
			// Shopify-модель: без выбранной коллекции / пустая коллекция → оставляем
			// SSR-моки (demo), не подтягиваем весь каталог магазина.
			if (!collectionRef) continue;
			const pool = resolveCollectionProducts(products, collections, collectionRef);
			if (pool.length === 0) continue;
			const items = pool.slice(0, limit);
			grid.innerHTML = items
				.map((prod) => {
					const img2 =
						wantNextPhoto && Array.isArray(prod.images) && prod.images[1]
							? ` data-image-2="${escapeHtml(prod.images[1])}"`
							: "";
					const qa = wantQuickAdd
						? `<button type="button" data-add-to-cart data-product-id="${escapeHtml(prod.id)}" data-name="${escapeHtml(prod.name)}" data-price="${escapeHtml(formatPrice(prod.price))}" data-image="${escapeHtml(productImage(prod))}" class="${qaCls}">В корзину</button>`
						: "";
					return `<li data-product-id="${escapeHtml(prod.id)}"${img2}>${renderCardHtml(prod)}${qa}</li>`;
				})
				.join("");
			applyQaText(grid);
		}
	};

	hydratePopular();
	document.addEventListener("astro:page-load", hydratePopular);
</script>

<style is:global>
	/* Канон buttonStyle: перекрытие добавленной кнопки «В корзину» (и demo-SSR,
	   и гидрированной разметки). Дефолт (без data-btn-style) — без правил,
	   solid-манера дословно. */
	[data-nt="popular-grid"][data-btn-style="secondary"] [data-add-to-cart] {
		background: transparent;
		border: 1px solid rgb(var(--color-button-bg, 58 69 48));
		color: rgb(var(--color-button-bg, 58 69 48));
	}

	[data-nt="popular-grid"][data-btn-style="link"] [data-add-to-cart] {
		background: transparent;
		color: rgb(var(--color-text, 0 0 0));
		text-decoration: underline;
		text-underline-offset: 4px;
	}
</style>
