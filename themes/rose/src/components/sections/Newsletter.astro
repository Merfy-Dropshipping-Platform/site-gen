---
// Фаза 3 (T17): новая канон-секция Newsletter в манере rose (см. themes/rose/MANNER.md).
// Схема полей = packages/theme-base/blocks/Newsletter/Newsletter.puckConfig.ts.
// Дизайн = блок подписки подвала верстальщика (Footer.astro:132-176, перенесён
// КОПИЕЙ — подвал не тронут): заголовок rose-title, подзаголовок Manrope muted,
// форма-рамка radius-input/border-input с инпутом; сетка секций §2.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Live-конфиг подписки: shopId патчит build.service (patchShopIdInDist) → siteId
// на деплое (заменяет `const shopId = ""` в HTML); apiUrl — публичный gateway.
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";

// Канон heading: string | { text, alignment, size }. Figma 1:19335 — ДОСЛОВНЫЙ
// плейсхолдер пустого состояния Newsletter: «Подпишитесь на нашу рассылку»
// (дефолт-текст верстальщика «Подпишись на новости» заменён на Figma-текст).
// Мерчант задал свой heading → рендерим ЕГО (?? срабатывает лишь при пустых данных).
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Подпишитесь на нашу рассылку");
// Заголовок — Figma 1236-42156: нейтральный грот (Manrope), sentence-case (НЕ
// uppercase rose-title), medium=24px чёрный. Размер: small 20 / medium 24 / large 28.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[17px] md:text-[20px]"
		: headingSize === "large"
			? "text-[24px] md:text-[28px]"
			: "text-[20px] md:text-[24px]";
const headingCls = `font-manrope ${headingSizeCls} font-light leading-[1.3] text-[rgb(var(--color-heading,17_17_17))]`;

// Канон description (string) + text {content,size} (pupa-дубль). Figma 1:19335 —
// ДОСЛОВНЫЙ плейсхолдер: «Узнавайте первыми о новых коллекциях и эксклюзивных
// предложениях.» (дефолт-текст верстальщика «Узнавай о новинках и акциях первым»
// заменён на Figma-текст). Манера = подзаголовок подписки подвала (Manrope 16 muted).
// Мерчант задал description/text → рендерим ЕГО (?? лишь при пустых данных).
const description =
	(typeof p.description === "string" && p.description.trim() ? p.description : undefined) ??
	(typeof p.text?.content === "string" && p.text.content.trim() ? p.text.content : undefined) ??
	"Узнавайте первыми о новых коллекциях и эксклюзивных предложениях.";
// Подзаголовок — Figma: Manrope, medium=20px, muted #999. small 16 / large 24.
const descSize = p.text?.size;
const descSizeCls =
	descSize === "small"
		? "text-[15px] md:text-[16px]"
		: descSize === "large"
			? "text-[20px] md:text-[24px]"
			: "text-[17px] md:text-[20px]";
const descCls = `font-manrope ${descSizeCls} font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]`;

// Канон placeholder/buttonText. Figma 1:19335 — ДОСЛОВНЫЙ плейсхолдер пустого
// состояния: input «email@example.com», кнопка «Кнопка» (дефолты верстальщика
// «Твой email» / «Подписаться» заменены на Figma-текст). Мерчант задал свои
// placeholder/buttonText → рендерим ИХ (fallback лишь при пустых данных).
const placeholder =
	typeof p.placeholder === "string" && p.placeholder.trim() ? p.placeholder : "email@example.com";
const buttonText =
	typeof p.buttonText === "string" && p.buttonText.trim() ? p.buttonText : "Кнопка";

// Канон formLayout: stacked (canon-default) — поле + чёрная CTA манеры §3 под ним;
// inline-submit — форма подвала верстальщика дословно (кнопка-стрелка в рамке).
const inlineSubmit = p.formLayout === "inline-submit";

// Канон agreement (toggle 'true'/'false', default 'false'): при 'true' — чекбокс
// согласия под формой (манера rose: Manrope мелкий muted); иначе ничего.
const showAgreement = p.agreement === "true";
// Текст согласия + опциональная ссылка (страница/URL, даже несуществующая).
const agreeText = typeof p.agreementText === "string" && p.agreementText.trim() ? p.agreementText : "Согласен на обработку персональных данных";
const agreeLink = typeof p.agreementLink === "string" ? p.agreementLink.trim() : "";

// Канон «Выравнивание» = ЕДИНЫЙ контрол (конструктор пишет position): рулит И
// позицией блока в контейнере (posCls), И выключкой содержимого внутри
// (alignCls: заголовок/текст/форма), И выравниванием stacked-кнопки (selfCls).
// «слева-слева», «центр-по центру», «право-право». Раньше alignCls читал
// отдельный heading.alignment (конструктор его не пишет) → блок двигался, а
// текст и кнопка застревали слева = «выравнивается только часть».
// Figma-эталон центрирован → center = дефолт (left/right — явный выбор мерчанта).
const position = p.position === "left" || p.position === "right" ? p.position : "center";
const posCls = position === "center" ? "mx-auto" : position === "right" ? "ml-auto" : "mr-auto";
const alignCls =
	position === "center"
		? "items-center text-center"
		: position === "right"
			? "items-end text-right"
			: "items-start text-left";
const selfCls = position === "center" ? "self-center" : position === "right" ? "self-end" : "self-start";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-14 pt-14 sm:px-5 sm:pb-16 sm:pt-16 md:px-10 md:pb-[100px] md:pt-[100px] lg:px-16 lg:pb-[120px] lg:pt-[120px] xl:px-20 xl:pb-[140px] xl:pt-[140px] 2xl:px-[280px]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto w-full max-w-[1320px]">
		<div class={`flex w-full flex-col gap-8 md:gap-10 ${alignCls}`} data-animate>
			<div class="flex w-full max-w-[768px] flex-col gap-3">
				<h2
					id={titleId}
					class={headingCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
				<p
					class={descCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="101"
					data-puck-subsection-field="text"
				>
					{description}
				</p>
			</div>

			{/* Форма — Figma 1236-42156: инлайн, 376px, h-48, рамка #f5f5f5 radius-input,
			    поле слева + светлая кнопка #fbfbfb h-36 справа в один ряд. Светлые серые
			    (рамка/кнопка/плейсхолдер) — design baseline минимал-эталона (см.
			    theme-pixel-tuning §5): намеренно НЕ токенизируются под scheme. */}
			<form
				class="flex h-12 w-full max-w-[376px] items-center justify-between gap-2 rounded-[var(--radius-input,4px)] border border-[#f5f5f5] bg-white py-2.5 pl-3 pr-1.5 transition-colors focus-within:border-[#dddddd]"
				data-newsletter-form
				data-puck-subsection-parent={id}
				data-puck-subsection-index="997"
				data-puck-subsection-field="placeholder"
			>
				<input
					type="email"
					name="email"
					required
					placeholder={placeholder}
					aria-label="Email"
					class="min-w-0 flex-1 bg-transparent font-manrope text-[16px] font-light leading-none text-[#000000] placeholder:text-[#dddddd] outline-none"
				/>
				<button
					type="submit"
					class="flex h-9 shrink-0 items-center justify-center rounded-[var(--radius-input,4px)] bg-[#fbfbfb] px-4 font-manrope text-[14px] font-light leading-none text-[#000000] transition-colors hover:bg-[#f2f2f2] active:scale-[0.98]"
				>
					{buttonText}
				</button>
			</form>
			{
				showAgreement && (
					<label class="flex w-full max-w-[376px] cursor-pointer items-center gap-2.5 font-manrope text-[14px] font-normal leading-snug text-[rgb(var(--color-muted,153_153_153))]">
						<span class="relative flex size-5 shrink-0">
							<input
								type="checkbox"
								required
								class="peer size-5 cursor-pointer appearance-none rounded-[var(--radius-input,4px)] border border-[rgb(var(--color-input-border,153_153_153))] bg-white transition-colors checked:border-[rgb(var(--color-button-bg,0_0_0))] checked:bg-[rgb(var(--color-button-bg,0_0_0))]"
							/>
							<svg
								class="pointer-events-none absolute inset-0 m-auto size-3 text-[rgb(var(--color-button-text,255_255_255))] opacity-0 transition-opacity peer-checked:opacity-100"
								viewBox="0 0 12 12"
								fill="none"
								aria-hidden="true"
							>
								<path d="M2.5 6.5 5 9l4.5-5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</span>
						{
						agreeLink ? (
							<a href={agreeLink} target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 transition-opacity hover:opacity-70">{agreeText}</a>
						) : (
							<span>{agreeText}</span>
						)
					}
					</label>
				)
			}
			<p
				data-newsletter-status
				role="status"
				class="hidden w-full font-manrope text-[14px] font-normal leading-none text-[#4AD300]"
			></p>
		</div>
	</div>
</section>

<script is:inline define:vars={{ shopId, apiUrl }}>
	// Реальная отправка подписки на gateway. Самодостаточно (не зависит от
	// скрипта футера): гард __merfyNewsletterWired исключает двойную привязку,
	// если на странице есть и футер, и эта секция. store_id — из пропатченного
	// shopId (деплой) либо window.__MERFY_SITE_ID__ (превью конструктора).
	(function () {
		window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
			shopId: shopId || "",
			apiUrl: apiUrl || "https://gateway.merfy.ru/api",
		};
		var cfg = window.__MERFY_CONFIG__;
		var base = String(cfg.apiUrl || "https://gateway.merfy.ru/api").replace(/\/+$/, "");
		var storeId = cfg.shopId || window.__MERFY_SITE_ID__ || "";

		function wire(form) {
			if (!form || form.__merfyNewsletterWired) return;
			form.__merfyNewsletterWired = true;
			var section = form.closest("section") || document;
			var status = section.querySelector("[data-newsletter-status]");
			var btn = form.querySelector('button[type="submit"]');

			function show(msg, isError) {
				if (!status) return;
				status.textContent = msg;
				status.style.color = isError ? "#E11D48" : "";
				status.classList.remove("hidden");
			}

			form.addEventListener("submit", function (event) {
				event.preventDefault();
				var input = form.querySelector('input[type="email"]');
				var email = input ? String(input.value || "").trim() : "";
				if (!email) return;
				if (btn) btn.disabled = true;
				show("Отправляем…", false);

				fetch(base + "/storefront/newsletter/subscribe", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ store_id: storeId, email: email }),
				})
					.then(function (res) {
						return res
							.json()
							.catch(function () { return {}; })
							.then(function (data) { return { ok: res.ok, code: res.status, data: data }; });
					})
					.then(function (r) {
						if (r.ok) {
							show(
								r.data && r.data.alreadySubscribed
									? "Вы уже подписаны на рассылку."
									: "Спасибо! Мы отправим вам приветственное письмо.",
								false,
							);
							form.reset();
						} else if (r.code === 429) {
							show("Слишком много попыток. Попробуйте позже.", true);
						} else {
							show("Не удалось подписаться. Попробуйте позже.", true);
						}
					})
					.catch(function () {
						show("Не удалось подписаться. Проверьте соединение.", true);
					})
					.finally(function () {
						if (btn) btn.disabled = false;
					});
			});
		}

		function init() {
			var forms = document.querySelectorAll("[data-newsletter-form]");
			for (var i = 0; i < forms.length; i++) wire(forms[i]);
		}
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", init);
		} else {
			init();
		}
	})();
</script>
