---
import NtSectionHeading from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtSectionHeading.astro";
import RosePicture from "../img/RosePicture.astro";

// ОЖИВЛЕНИЕ: конструкторная схема Gallery (heading/subtitle union). Тело + данные verbatim.
// T13: полная канон-схема (items[] ≤3, imagePosition, headingSize, textSize, padding).
// Дефолтные ветки тернарников = прежние строки байт-в-байт; канон-дефолты
// конструктора (medium/medium/left) → пиксель верстальщика (прецедент T11 'center').
const p = Astro.props as Record<string, any>;
const id = p.id;
const sectionTitle = p.heading?.text ?? p.heading ?? "Снова в наличии!";
const sectionSubtitle =
	p.text?.content ?? p.subtitle?.content ?? p.subtitle ?? "Сравнивайте, находите своё — от культовых моделей до свежих решений для особенных моментов";

// Канон headingSize (top-level приоритетнее legacy heading.size): 'medium'
// (canon-default) и отсутствие = clamp верстальщика (14px→20px) дословно;
// small/large масштабируют clamp в манере (≈0.85× / ≈1.2×).
const headingSize = p.headingSize ?? p.heading?.size;
const headingSizeCls =
	headingSize === "small"
		? " [&_h2]:!text-[length:clamp(12px,3.2vw,17px)]"
		: headingSize === "large"
			? " [&_h2]:!text-[length:clamp(17px,4.6vw,24px)]"
			: "";
// Канон textSize (top-level приоритетнее legacy text.size): 'medium' (canon-default)
// и отсутствие = 16px верстальщика; small → 14px, large → 19px.
const textSize = p.textSize ?? p.text?.size;
const textSizeCls =
	textSize === "small"
		? " [&_p]:!text-[14px]"
		: textSize === "large"
			? " [&_p]:!text-[19px]"
			: "";
const headWrapCls = `gallery-section-heading flex w-full min-w-0 justify-center${headingSizeCls}${textSizeCls}`;

// Канон imagePosition left/right: 'left' (canon-default) и отсутствие = большая
// плитка слева (пиксель верстальщика); 'right' → зеркало раскладки на lg
// (узкая колонка слева, большая плитка справа — через swap grid-template + order).
const mirror = p.imagePosition === "right";
const galleryGridCls = mirror
	? "grid min-h-0 min-w-0 grid-cols-1 gap-6 md:gap-8 lg:grid-cols-[minmax(280px,429px)_minmax(0,1fr)] lg:items-stretch lg:gap-6 xl:gap-8"
	: "grid min-h-0 min-w-0 grid-cols-1 gap-6 md:gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,429px)] lg:items-stretch lg:gap-6 xl:gap-8";
const heroTileOrderCls = mirror ? " lg:order-2" : "";
const sideColOrderCls = mirror ? " lg:order-1" : "";

// Канон items[] (≤3, типы image/product/collection): плитки из пропсов с fallback
// на три плитки верстальщика ДОСЛОВНО. SSR рендерит канон-плейсхолдеры
// («Товар» 2 500 ₽ / «Выбери коллекцию»); резолв productId/collectionId→имя/
// цена/картинка делает гидрация ниже (data-gallery-product/-collection):
// live — /data/{products,collections}.json, превью — storefront-data.
type GalleryTile = {
	kind: "image" | "product" | "collection";
	url: string;
	alt: string;
	label: string;
	price: string;
	href: string;
	ref: string | null;
};
const galleryTiles: GalleryTile[] = (Array.isArray(p.items) ? p.items : [])
	.filter((x: any) => x && typeof x === "object")
	.slice(0, 3)
	.map((it: any): GalleryTile => {
		if (it.type === "product") {
			const pid = typeof it.productId === "string" && it.productId ? it.productId : null;
			return {
				kind: "product",
				url: "",
				alt: "Товар",
				label: "Товар",
				price: "2 500 ₽",
				href: pid ? `/product?id=${encodeURIComponent(pid)}` : "/catalog",
				ref: pid,
			};
		}
		if (it.type === "collection") {
			const cid = typeof it.collectionId === "string" && it.collectionId ? it.collectionId : null;
			return {
				kind: "collection",
				url: "",
				alt: "Коллекция",
				label: "Выбери коллекцию",
				price: "",
				href: cid ? `/catalog?collection=${encodeURIComponent(cid)}` : "/catalog",
				ref: cid,
			};
		}
		return {
			kind: "image",
			url: typeof it.url === "string" ? it.url : "",
			alt: typeof it.alt === "string" ? it.alt : "",
			label: "",
			price: "",
			href: "/catalog",
			ref: null,
		};
	});
// Канон-плейсхолдер = реальный ассет темы (принцип T15 ImageWithText): плитка
// без url (image c пустым url, product/collection без выбранной сущности)
// получает фото верстальщика по позиции — «добавил секцию → сразу красиво»,
// подписи-плейсхолдеры (Товар/цена/Выбери коллекцию) остаются.
const TILE_FALLBACKS = [
	"/images/Изображение_Галерея.webp",
	"/images/Товар_1.webp",
	"/images/Коллекция_1.webp",
];
galleryTiles.forEach((t, i) => {
	if (!t.url) t.url = TILE_FALLBACKS[i % TILE_FALLBACKS.length];
});
const useItems = galleryTiles.length > 0;
const heroTile = useItems ? galleryTiles[0] : undefined;
const sideTiles = useItems ? galleryTiles.slice(1) : [];

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id="gallery"
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-14 pt-14 sm:px-5 sm:pb-16 sm:pt-16 md:px-10 md:pb-[100px] md:pt-[100px] lg:px-16 lg:pb-[120px] lg:pt-[120px] xl:px-20 xl:pb-[140px] xl:pt-[140px] 2xl:px-[280px]"
	aria-labelledby="gallery-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-8 md:gap-10">
		<div class={headWrapCls} data-animate data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">
			<NtSectionHeading variant="rose" titleId="gallery-title" title={sectionTitle} subtitle={sectionSubtitle} />
		</div>

		<div
			data-animate
			data-animate-delay="0.1s"
			class={galleryGridCls}
		>
			{heroTile ? (
				<a
					href={heroTile.href}
					class={`gallery-hero-tile group relative block min-h-[280px] w-full min-w-0 overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))] lg:min-h-0 lg:h-full${heroTileOrderCls}`}
					aria-label={heroTile.alt || heroTile.label || "Перейти в каталог"}
					data-gallery-product={heroTile.kind === "product" ? (heroTile.ref ?? undefined) : undefined}
					data-gallery-collection={heroTile.kind === "collection" ? (heroTile.ref ?? undefined) : undefined}
					data-puck-subsection-parent={id}
					data-puck-subsection-index={0}
					data-puck-subsection-field="items"
				>
					{heroTile.url && (
						<img
							src={heroTile.url}
							alt={heroTile.alt}
							loading="eager"
							class="absolute inset-0 !size-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.05]"
						/>
					)}
				</a>
			) : (
			<a
				href="/catalog"
				class={`gallery-hero-tile group relative block min-h-[280px] w-full min-w-0 overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))] lg:min-h-0 lg:h-full${heroTileOrderCls}`}
				aria-label="Перейти в каталог"
			>
				<RosePicture
					src="/images/Изображение_Галерея.png"
					alt="Галерея"
					loading="eager"
					class="absolute inset-0 !size-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.05]"
					width="875"
					height="875"
				/>
			</a>
			)}

			{useItems ? sideTiles.length > 0 && (
				<div class={`flex min-h-0 min-w-0 flex-col gap-6${sideColOrderCls}`}>
					{sideTiles.map((tile, i) =>
						tile.kind === "collection" ? (
							<a
								href={tile.href}
								class="group flex min-w-0 flex-col items-start gap-4 text-left md:gap-5"
								aria-label={tile.label || tile.alt}
								data-gallery-collection={tile.ref ?? undefined}
								data-puck-subsection-parent={id}
								data-puck-subsection-index={i + 1}
								data-puck-subsection-field="items"
							>
								<div class="aspect-[429/309] w-full min-h-0 overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))]" aria-hidden={tile.url ? undefined : "true"}>
									{tile.url && (
										<img
											src={tile.url}
											alt={tile.alt}
											loading="eager"
											class="block !size-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.05]"
										/>
									)}
								</div>
								{tile.label && (
									<h3 class="gallery-collection-title font-manrope bg-transparent text-[16px] font-normal leading-[100%] text-black">
										{tile.label}
									</h3>
								)}
							</a>
						) : (
							<a
								href={tile.href}
								class="group flex flex-col items-start gap-4 text-left md:gap-5"
								aria-label={tile.label || tile.alt || "Изображение"}
								data-gallery-product={tile.kind === "product" ? (tile.ref ?? undefined) : undefined}
								data-puck-subsection-parent={id}
								data-puck-subsection-index={i + 1}
								data-puck-subsection-field="items"
							>
								<div
									class="gallery-bag-media relative aspect-[429/444] w-full min-h-0 overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))] leading-none"
									aria-hidden={tile.url ? undefined : "true"}
								>
									{tile.url && (
										<img
											src={tile.url}
											alt={tile.alt}
											loading="eager"
											class="absolute inset-0 !size-full max-w-none object-cover object-center transition-transform duration-300 group-hover:scale-110"
										/>
									)}
								</div>
								{(tile.label || tile.price) && (
									<div class="flex flex-col gap-[4px] bg-transparent">
										{tile.label && (
											<h3 class="gallery-product-title font-manrope text-[16px] font-normal leading-none text-black md:text-[16px] lg:text-[16px] xl:text-[16px]">
												{tile.label}
											</h3>
										)}
										{tile.price && (
											<span class="gallery-product-price font-manrope text-[16px] font-normal leading-none text-black md:text-[16px] lg:text-[16px] xl:text-[16px]">
												{tile.price}
											</span>
										)}
									</div>
								)}
							</a>
						),
					)}
				</div>
			) : (
			<div class={`flex min-h-0 min-w-0 flex-col gap-6${sideColOrderCls}`}>
				<a
					href="/products/bag-1"
					class="group flex flex-col items-start gap-4 text-left md:gap-5"
					aria-label="Сумка"
				>
					<div
						class="gallery-bag-media relative aspect-[429/444] w-full min-h-0 overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))] leading-none"
					>
						<RosePicture
							src="/images/Товар_5__2_.png"
							alt="Сумка"
							width="429"
							height="444"
							loading="eager"
							class="absolute inset-0 !size-full max-w-none object-cover object-center transition-transform duration-300 group-hover:scale-110"
						/>
					</div>
					<div class="flex flex-col gap-[4px] bg-transparent">
						<h3
							class="gallery-product-title font-manrope text-[16px] font-normal leading-none text-black md:text-[16px] lg:text-[16px] xl:text-[16px]"
						>
							Сумка
						</h3>
						<span
							class="gallery-product-price font-manrope text-[16px] font-normal leading-none text-black md:text-[16px] lg:text-[16px] xl:text-[16px]"
						>
							5 990₽
						</span>
					</div>
				</a>

				<a
					href="/catalog?collection=FUTURISM"
					class="group flex min-w-0 flex-col items-start gap-4 text-left md:gap-5"
					aria-label="Коллекция FUTURISM"
				>
					<div class="aspect-[429/309] w-full min-h-0 overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))]">
						<RosePicture
							src="/images/Коллекция_3.png"
							alt="Коллекция FUTURISM"
							width="429"
							height="309"
							loading="eager"
							class="block !size-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.05]"
						/>
					</div>
					<h3 class="gallery-collection-title font-manrope bg-transparent text-[16px] font-normal leading-[100%] text-black">
						Коллекция FUTURISM
					</h3>
				</a>
			</div>
			)}
		</div>
	</div>
</section>

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		findCollection,
		formatPrice,
		productHref,
		productImage,
	} from "../../lib/storefront-hydrate";

	// Резолв выбранных в конструкторе товара/коллекции на плитках галереи
	// (data-gallery-product / data-gallery-collection). SSR несёт канон-плейсхолдеры;
	// здесь подставляем имя/цену/картинку/ссылку реальной сущности. Без данных
	// (demo-сборка) — no-op.
	const hydrateGalleryTiles = async () => {
		const prodTiles = Array.from(document.querySelectorAll<HTMLElement>("[data-gallery-product]"));
		const colTiles = Array.from(document.querySelectorAll<HTMLElement>("[data-gallery-collection]"));
		if (prodTiles.length === 0 && colTiles.length === 0) return;
		const [products, collections] = await Promise.all([
			prodTiles.length ? loadRealProducts() : Promise.resolve(null),
			colTiles.length ? loadRealCollections() : Promise.resolve(null),
		]);
		for (const tile of prodTiles) {
			const ref = tile.getAttribute("data-gallery-product");
			const product = products?.find((x) => x.id === ref || x.slug === ref) ?? null;
			if (!product) continue;
			const title = tile.querySelector(".gallery-product-title");
			if (title && product.name) title.textContent = product.name;
			const price = tile.querySelector(".gallery-product-price");
			if (price) price.textContent = formatPrice(product.price);
			const img = tile.querySelector("img");
			const cover = productImage(product);
			if (img && cover) {
				img.setAttribute("src", cover);
				if (product.name) img.setAttribute("alt", product.name);
			}
			tile.setAttribute("href", productHref(product));
			if (product.name) tile.setAttribute("aria-label", product.name);
		}
		for (const tile of colTiles) {
			const col = findCollection(collections, tile.getAttribute("data-gallery-collection"));
			if (!col) continue;
			const title = tile.querySelector(".gallery-collection-title");
			if (title && col.name) title.textContent = col.name;
			const cover = col.image || (Array.isArray(col.images) ? col.images[0] : "");
			const img = tile.querySelector("img");
			if (img && cover) {
				img.setAttribute("src", cover);
				if (col.name) img.setAttribute("alt", col.name);
			}
			if (col.name) tile.setAttribute("aria-label", col.name);
			if (col.slug) tile.setAttribute("href", `/catalog?collection=${encodeURIComponent(col.slug)}`);
		}
	};

	hydrateGalleryTiles();
	document.addEventListener("astro:page-load", hydrateGalleryTiles);
</script>

<style>
	/* NtSectionHeading из DS не пробрасывает class на h2 — на широких экранах одна строка с плавным уменьшением */
	:global(#gallery-title) {
		white-space: nowrap;
		font-size: clamp(14px, 3.8vw, 20px) !important;
	}

	/* Figma 375: разрешаем перенос для коротких заголовков (max-width ограничен в global.css) и
	   возвращаем подзаголовку Manrope 12 как у .rose-subtitle */
	@media (max-width: 639.98px) {
		:global(#gallery-title) {
			white-space: normal !important;
		}

		:global(#gallery-title ~ p) {
			font-size: 12px !important;
			line-height: 1.4 !important;
			max-width: 100% !important;
			width: 100% !important;
			padding-inline: 0 !important;
		}

		:global(.gallery-section-heading [data-nt="section-heading"]) {
			max-width: 100% !important;
			width: 100% !important;
		}
	}

	/* Левая плитка: нижний край картинки совпадает с низом ряда, без «пустого» поля под object-cover */
	.gallery-hero-tile img {
		height: 100%;
		min-height: 100%;
		width: 100%;
		max-width: none;
	}

	/* Верхняя плитка справа: absolute inset-0 — без щели у нижнего края (как у hero) */
	.gallery-bag-media img {
		height: 100%;
		width: 100%;
		max-width: none;
	}

	.gallery-collection-title {
		white-space: nowrap;
		font-size: clamp(12px, 2.6vw, 16px);
	}

	/*
	 * global.css задаёт неслоёные h3 { font-size: 1.953em } и Comfortaa для всех h1–h6 —
	 * они сильнее @layer utilities Tailwind, поэтому заголовок «Сумка» визуально крупнее цены.
	 */
	:global(#gallery) .gallery-product-title,
	:global(#gallery) .gallery-product-price {
		font-family: "Manrope", sans-serif;
		font-size: 16px;
		font-weight: 400;
		line-height: 1;
	}

	/* Figma 375: подписи карточки товара — Manrope 12 */
	@media (max-width: 639.98px) {
		:global(#gallery) .gallery-product-title,
		:global(#gallery) .gallery-product-price {
			font-size: 12px;
		}
	}
</style>
