---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/data.json';
import siteConfig from '../data/site-config.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};
---
<BaseLayout title={`Восстановление пароля — ${meta?.title ?? 'Мой сайт'}`}>
  <Header {...headerProps} />

  <!-- Full-screen popup overlay layout per Figma -->
  <div class="reset-overlay">
    <div class="reset-bg" style="background-image: url('/main-image.png');"></div>
    <div class="reset-dark-overlay"></div>

    <div class="reset-panel">
      <div class="reset-panel-inner">
        <!-- Mode 1: Request reset -->
        <div id="mode-request">
          <h1 class="font-heading" style="font-size: 20px; font-weight: 400; color: rgb(var(--color-foreground)); margin-bottom: 8px;">Восстановление пароля</h1>
          <p class="font-body" style="font-size: 14px; color: rgb(var(--color-muted)); margin-bottom: 32px;">Введите email, и мы отправим ссылку для сброса пароля</p>

          <form id="forgot-form" class="flex flex-col gap-[16px]">
            <div>
              <label for="forgot-email" class="block mb-2 font-body" style="font-size: 14px; color: rgb(var(--color-foreground));">Email <span class="text-required">*</span></label>
              <input type="email" id="forgot-email" name="email" required placeholder="your@email.com" autocomplete="email"
                class="w-full h-[48px] px-4 border font-body text-[14px] focus:outline-none auth-input-focus" style="border-color: rgb(var(--color-foreground) / 0.19); border-radius: var(--radius-input, var(--radius-button)); background: transparent; color: rgb(var(--color-foreground));">
            </div>

            <div class="text-red-600 text-sm text-center hidden" id="forgot-error"></div>

            <button type="submit" class="login-submit-btn w-full font-body font-normal transition-colors" id="btn-forgot">
              Отправить ссылку
            </button>
          </form>

          <div id="forgot-success" class="hidden text-center py-6">
            <div style="color: #16a34a;" class="font-medium mb-2">Письмо отправлено!</div>
            <p class="font-body" style="font-size: 14px; color: rgb(var(--color-muted));">Если аккаунт с таким email существует, вы получите ссылку для сброса пароля.</p>
          </div>

          <div class="text-center text-[14px] mt-6 font-body" style="color: rgb(var(--color-muted));">
            <p><a href="/login" class="auth-link">Вернуться ко входу</a></p>
          </div>
        </div>

        <!-- Mode 2: Set new password (when token in URL) -->
        <div id="mode-reset" class="hidden">
          <h1 class="font-heading" style="font-size: 20px; font-weight: 400; color: rgb(var(--color-foreground)); margin-bottom: 32px;">Новый пароль</h1>

          <form id="reset-form" class="flex flex-col gap-[16px]">
            <div>
              <label for="new-password" class="block mb-2 font-body" style="font-size: 14px; color: rgb(var(--color-foreground));">Новый пароль <span class="text-required">*</span></label>
              <input type="password" id="new-password" name="password" required minlength="8" placeholder="Минимум 8 символов" autocomplete="new-password"
                class="w-full h-[48px] px-4 border font-body text-[14px] focus:outline-none auth-input-focus" style="border-color: rgb(var(--color-foreground) / 0.19); border-radius: var(--radius-input, var(--radius-button)); background: transparent; color: rgb(var(--color-foreground));">
            </div>

            <div>
              <label for="new-confirm" class="block mb-2 font-body" style="font-size: 14px; color: rgb(var(--color-foreground));">Подтвердите пароль <span class="text-required">*</span></label>
              <input type="password" id="new-confirm" name="confirmPassword" required minlength="8" placeholder="Повторите пароль" autocomplete="new-password"
                class="w-full h-[48px] px-4 border font-body text-[14px] focus:outline-none auth-input-focus" style="border-color: rgb(var(--color-foreground) / 0.19); border-radius: var(--radius-input, var(--radius-button)); background: transparent; color: rgb(var(--color-foreground));">
            </div>

            <div class="text-red-600 text-sm text-center hidden" id="reset-error"></div>

            <button type="submit" class="login-submit-btn w-full font-body font-normal transition-colors" id="btn-reset">
              Сменить пароль
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <Footer {...footerProps} />

  <script is:inline src="/scripts/customer-store.js"></script>
  <script is:inline src="/scripts/customer-auth.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var params = new URLSearchParams(window.location.search);
      var token = params.get('token');

      if (token) {
        // Mode 2: Reset password with token
        document.getElementById('mode-request').classList.add('hidden');
        document.getElementById('mode-reset').classList.remove('hidden');

        var resetForm = document.getElementById('reset-form');
        var resetError = document.getElementById('reset-error');

        resetForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          resetError.classList.add('hidden');

          var password = document.getElementById('new-password').value;
          var confirm = document.getElementById('new-confirm').value;

          if (password !== confirm) {
            resetError.textContent = 'Пароли не совпадают';
            resetError.classList.remove('hidden');
            return;
          }

          if (password.length < 8) {
            resetError.textContent = 'Пароль должен быть не менее 8 символов';
            resetError.classList.remove('hidden');
            return;
          }

          try {
            var result = await window.CustomerAuth.resetPassword({ token: token, password: password });
            if (result.success) {
              window.location.href = '/account';
            } else {
              throw result;
            }
          } catch (err) {
            var msg = 'Не удалось сменить пароль';
            if (err.error === 'TOKEN_EXPIRED' || err.code === 'TOKEN_EXPIRED') {
              msg = 'Ссылка устарела. Запросите новую.';
            }
            resetError.textContent = msg;
            resetError.classList.remove('hidden');
          }
        });
      } else {
        // Mode 1: Request password reset
        var forgotForm = document.getElementById('forgot-form');
        var forgotError = document.getElementById('forgot-error');
        var forgotSuccess = document.getElementById('forgot-success');

        forgotForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          forgotError.classList.add('hidden');

          var email = document.getElementById('forgot-email').value.trim();

          try {
            await window.CustomerAuth.forgotPassword({ email: email });
            forgotForm.classList.add('hidden');
            forgotSuccess.classList.remove('hidden');
          } catch (err) {
            forgotError.textContent = 'Не удалось отправить письмо';
            forgotError.classList.remove('hidden');
          }
        });
      }
    });
  </script>
</BaseLayout>

<style>
  .reset-overlay {
    position: relative;
    min-height: 100vh;
    display: flex;
  }
  .reset-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .reset-dark-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1;
  }
  .reset-panel {
    position: relative;
    z-index: 2;
    margin-left: auto;
    width: 100%;
    max-width: 590px;
    background: rgb(var(--color-background));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
  }
  .reset-panel-inner {
    width: 100%;
    max-width: 430px;
  }
  .login-submit-btn {
    height: 56px;
    font-size: 16px;
    background: rgb(var(--color-foreground));
    color: #ffffff;
    border: none;
    border-radius: var(--radius-button);
    cursor: pointer;
  }
  .login-submit-btn:hover { filter: brightness(0.85); }
  .login-submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .text-required { color: rgb(var(--color-primary)); }
  .auth-link { color: rgb(var(--color-primary)); }
  .auth-link:hover { text-decoration: underline; }
  .auth-input-focus:focus { border-color: rgb(var(--color-foreground)); box-shadow: 0 0 0 2px rgba(41, 37, 36, 0.15); }

  @media (max-width: 768px) {
    .reset-panel {
      max-width: 100%;
    }
    .reset-bg, .reset-dark-overlay {
      display: none;
    }
  }
</style>
