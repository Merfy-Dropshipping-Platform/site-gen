---
import type { CollectionsProps } from './Collections.puckConfig';
import { CollectionsClasses as C } from './Collections.classes';
import { buildCollectionHref } from './card-href';
import { getPlaceholderSvg } from '../../runtime/placeholders';

interface Props extends CollectionsProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  heading: headingProp,
  subtitle: subtitleProp,
  collections = [],
  columns: columnsProp,
  colorScheme,
  padding,
} = Astro.props as Props & { subtitle?: string };

// Constructor legacy schema uses title/titleSize/subtitleSize/columnsCount/imageView.
// Normalise both shapes so sites edited via the constructor render correctly.
const heading =
  (typeof headingProp === 'string' && headingProp) ||
  (typeof raw.title === 'string' ? raw.title : undefined);

// Pupa parity: titleAlignment, titleSize, subtitleSize.
const titleAlignment = typeof raw.titleAlignment === 'string' ? raw.titleAlignment : 'center';
const titleSize = typeof raw.titleSize === 'string' ? raw.titleSize :
  (typeof raw.headingSize === 'string' ? raw.headingSize : 'medium');
const subtitleSize = typeof raw.subtitleSize === 'string' ? raw.subtitleSize : 'small';

// Default to `text-center` when prop is unset so pre-084 themes keep
// their centered headings. Vanilla overrides via blockDefaults.
const titleAlignClass =
  titleAlignment === 'left' ? 'text-left' :
  titleAlignment === 'right' ? 'text-right' :
  'text-center';
const titleSizeClass =
  titleSize === 'large' ? 'text-3xl md:text-4xl' :
  titleSize === 'medium' ? 'text-2xl md:text-3xl' :
  'text-xl md:text-2xl';
const subtitleSizeClass =
  subtitleSize === 'large' ? 'text-lg md:text-xl' :
  subtitleSize === 'medium' ? 'text-base md:text-lg' :
  'text-sm md:text-base';
const subtitle =
  (typeof subtitleProp === 'string' && subtitleProp) ||
  (typeof raw.subtitle === 'string' ? raw.subtitle : undefined);
const columns = typeof columnsProp === 'number'
  ? columnsProp
  : (typeof raw.columnsCount === 'number' ? raw.columnsCount : 3);

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
const gridTemplateCols = `grid-template-columns: repeat(${columns}, minmax(0, 1fr));`;
const schemeClass = colorScheme ? `color-scheme-${String(colorScheme).replace('scheme-', '')}` : '';

// Card link prefix: defaults to '/catalog?collection=' so cards filter the
// catalog page (rose reference behaviour). Merchant can switch to
// '/collections/' if they want dedicated collection pages.
const cardLinkBase = typeof raw.cardLinkBase === 'string' ? raw.cardLinkBase : undefined;

// imageView → aspect-ratio for tiles (falls back to portrait 430/500 for
// parity with legacy vanilla template).
const imageViewProp =
  typeof raw.imageView === 'string' &&
  ['square', 'portrait', 'wide'].includes(raw.imageView)
    ? (raw.imageView as 'square' | 'portrait' | 'wide')
    : 'portrait';
const aspectMap: Record<string, string> = {
  square: '1 / 1',
  portrait: '430 / 500',
  wide: '16 / 9',
};
const tileAspect = aspectMap[imageViewProp];
// 084 vanilla pilot: additive variants. Default behaviour preserved when
// these props are absent.
const cardCaptionStyleProp =
  raw.cardCaptionStyle === 'uppercase' || raw.cardCaptionStyle === 'default'
    ? (raw.cardCaptionStyle as 'uppercase' | 'default')
    : 'default';
const cardCaptionClass = C.cardCaption[cardCaptionStyleProp];
const gridAspectProp =
  raw.gridAspect === '1:1' || raw.gridAspect === 'auto'
    ? (raw.gridAspect as '1:1' | 'auto')
    : 'auto';
const gridAspectClass = C.gridAspect[gridAspectProp];
// When 1:1 forced, override the imageView-derived aspect for the wrapper.
const tileAspectStyle = gridAspectProp === '1:1' ? '1 / 1' : tileAspect;

// Additive layout variant (Figma flux 1:26298). `tile` — square rounded-12
// cards, left-aligned heading + caption, font-light, hover muted→text.
const variant = (raw.variant === 'tile' || raw.variant === 'standard')
  ? (raw.variant as 'tile' | 'standard') : 'standard';
const isTile = variant === 'tile';
// When the merchant hasn't wired real collections, show demo tiles so the
// preview matches Figma reference (3 collection cards). Real collections
// take precedence as soon as they exist.
const DEMO_COLLECTIONS = [
  { heading: 'Коллекция RIVIERA', image: '' },
  { heading: 'Коллекция URBAN', image: '' },
  { heading: 'Коллекция FUTURISM', image: '' },
];
const hasRealCollections = (collections ?? []).length > 0;
const effectiveCollections = hasRealCollections
  ? collections
  : DEMO_COLLECTIONS.slice(0, columns).map((c, i) => ({
      id: `demo-${i}`, heading: c.heading, image: c.image, collectionId: null,
    }));
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-collections-variant={variant}
  style={paddingStyle}
>
  <div class={C.container}>
    {heading && (
      <h2 class:list={[
        C.heading,
        isTile ? 'text-left mb-6 [font-family:var(--font-body)] !text-[20px] !leading-[24px] tracking-normal text-[rgb(var(--color-text))]' : `${titleAlignClass} ${titleSizeClass}`,
      ]} data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="title">{heading}</h2>
    )}
    {subtitle && (
      <p class:list={[C.subtitle, isTile ? 'text-left mb-10' : `${titleAlignClass} ${subtitleSizeClass}`]} data-puck-subsection-parent={id} data-puck-subsection-index="101" data-puck-subsection-field="subtitle">{subtitle}</p>
    )}
    <div class={C.grid} style={gridTemplateCols}>
      {effectiveCollections.map((item, i) => (
        <a
          href={buildCollectionHref(item.collectionId, cardLinkBase)}
          class:list={[C.card, isTile && 'group flex flex-col gap-4 items-start']}
          data-puck-subsection-parent={hasRealCollections ? id : undefined}
          data-puck-subsection-index={hasRealCollections ? i : undefined}
          data-puck-subsection-field={hasRealCollections ? 'collections' : undefined}
        >
          {item.image ? (
            <img src={item.image} alt={item.heading} class:list={[
              isTile ? 'w-full aspect-square object-cover rounded-[12px] bg-[rgb(var(--color-surface))] transition-transform duration-500 ease-out group-hover:scale-105' : `${C.image} ${gridAspectClass}`,
            ]} loading="lazy" style={isTile ? '' : `aspect-ratio: ${tileAspectStyle};`} />
          ) : (
            <div
              class:list={[
                'flex items-center justify-center overflow-hidden',
                isTile
                  ? 'w-full aspect-square rounded-[12px] bg-[rgb(var(--color-surface))] text-[rgb(var(--color-accent))]'
                  : `w-full rounded-[var(--radius-media)] bg-[rgb(var(--color-surface))] text-[rgb(var(--color-accent))] ${gridAspectClass}`,
              ]}
              style={isTile ? '' : `aspect-ratio: ${tileAspectStyle};`}
              aria-hidden="true"
            >
              <div class="w-[40%] aspect-square">
                <Fragment set:html={getPlaceholderSvg(i)} />
              </div>
            </div>
          )}
          <h3 class:list={[
            isTile ? '[font-family:var(--font-body)] font-light text-[length:var(--size-nav-link,16px)] leading-none text-[rgb(var(--color-muted))] group-hover:text-[rgb(var(--color-text))] transition-colors' : `${C.cardHeading} ${cardCaptionClass}`,
          ]}>{item.heading}</h3>
          {item.description && <p class:list={[C.cardDescription, cardCaptionClass, isTile && 'text-left']}>{item.description}</p>}
        </a>
      ))}
    </div>
  </div>
</section>
