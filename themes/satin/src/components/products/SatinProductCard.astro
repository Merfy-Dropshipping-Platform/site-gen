---
import type { Product } from "../../types/product";
import SatinPicture from "../img/SatinPicture.astro";
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";

interface Props {
	product: Product;
	priority?: boolean;
}

const { product, priority = false } = Astro.props;
const href = `/products/${product.id}`;
---

<article
	class="group flex flex-col gap-3"
	data-nt="satin-product-card"
	aria-label={product.name}
>
	<div class="relative aspect-[430/564] w-full overflow-hidden bg-[#F5F5F5]">
		<a href={href} class="block size-full" aria-label={product.name}>
			<SatinPicture
				src={product.image}
				alt={product.name}
				width="430"
				height="564"
				loading="eager"
				fetchpriority={priority ? "high" : undefined}
				class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
			/>
		</a>
		{product.discount && (
			<span class="pointer-events-none absolute left-0 top-0 inline-flex h-6 items-center bg-[#000000] px-2 font-manrope text-[12px] font-medium uppercase leading-none text-white">
				Скидка
			</span>
		)}
		<button
			type="button"
			data-fav-toggle
			data-product-id={product.id}
			aria-label="В избранное"
			aria-pressed="false"
			class="satin-fav absolute right-3 top-3 flex size-8 items-center justify-center opacity-70 transition hover:opacity-100"
		>
			<NtIcon name="favourite" sizeClass="size-6" class="transition-transform" />
		</button>
	</div>
	<div class="flex flex-col gap-1.5 md:gap-2">
		<a
			href={href}
			class="font-manrope text-[16px] font-normal uppercase leading-tight text-[#000000] hover:opacity-80"
		>
			{product.name}
		</a>
		<div class="flex flex-wrap items-baseline gap-1.5 md:gap-2">
			<span class="font-manrope text-[16px] font-normal leading-tight text-[#000000]">
				{product.price}
			</span>
			{product.oldPrice && (
				<span class="font-manrope text-[14px] font-light leading-tight text-[#999999] line-through">
					{product.oldPrice}
				</span>
			)}
		</div>
		<button
			type="button"
			data-add-to-cart
			data-product-id={product.id}
			data-name={product.name}
			data-price={product.price}
			data-old-price={product.oldPrice ?? ""}
			data-image={product.image}
			class="mt-2 flex h-11 w-full items-center justify-center bg-[#000000] px-3 font-manrope text-[14px] font-normal uppercase leading-none text-white transition-opacity hover:opacity-80"
		>
			В корзину
		</button>
	</div>
</article>

<script>
	const KEY = "satin-favourites";
	const load = (): Set<string> => {
		try {
			return new Set(JSON.parse(localStorage.getItem(KEY) || "[]"));
		} catch {
			return new Set<string>();
		}
	};
	const favs = load();
	const sync = () => {
		document.querySelectorAll<HTMLButtonElement>("[data-fav-toggle]").forEach((btn) => {
			btn.setAttribute("aria-pressed", String(favs.has(btn.dataset.productId ?? "")));
		});
	};
	sync();
	document.addEventListener("click", (event) => {
		const btn = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-fav-toggle]");
		if (!btn) return;
		event.preventDefault();
		const id = btn.dataset.productId ?? "";
		if (favs.has(id)) favs.delete(id);
		else favs.add(id);
		localStorage.setItem(KEY, JSON.stringify([...favs]));
		btn.setAttribute("aria-pressed", String(favs.has(id)));
	});
</script>
