---
import FluxPicture from "../img/FluxPicture.astro";
import { SITE_TITLE } from "../../consts";

// ОЖИВЛЕНИЕ (Фаза B, контракт bloom Hero): читаем канон-схему theme-base
// Hero.puckConfig и раскладываем по разметке верстальщика. Тело ниже — verbatim;
// значения flux = дефолты (index.astro зовёт <Hero title=... /> легаси-пропсами —
// они поддержаны наравне с nested). Полотно — ФИКС-высота h-[280px] sm:h-[360px]
// lg:h-[480px] (эталон Hero.astro:28). Поиск в Hero УБРАН (2026-06-15, баг тестера
// «два поиска на главной» — поиск только в Header, как rose). Анимаций нет (манера flux статична, §6).
const p = Astro.props as Record<string, any>;
const id = p.id;
const nonEmpty = (v: unknown): string | undefined =>
	typeof v === "string" && v.trim() ? v : undefined;
const title = p.heading?.text ?? p.title ?? SITE_TITLE;
const subtitle = p.text?.content ?? p.subtitle ?? "Там, где классика встречается с характером";
const ctaText = p.primaryButton?.text ?? p.cta?.text ?? p.ctaText ?? "В каталог";
const ctaLink =
	p.primaryButton?.link?.href ??
	(typeof p.primaryButton?.link === "string" ? p.primaryButton.link : undefined) ??
	p.cta?.href ??
	p.ctaLink ??
	"#collections";
// Канон backgroundImages (imagePair) / legacy backgroundImage / image.url. Картинка
// НЕ выбрана → "" (одиночная ветка рендера ниже не рисует фон); ПОЛНОСТЬЮ пустое
// состояние секции (isEmpty) рендерит отдельную ветку с дизайн-ассетом
// /placeholders/landscape-image.png (см. ниже), НЕ мок /images/4x/Главный_экран.png.
const backgroundImage =
	nonEmpty(p.backgroundImages?.url1) ??
	nonEmpty(p.backgroundImage) ??
	nonEmpty(p.image?.url) ??
	"";
// Сплит двух картинок 50/50 ТОЛЬКО когда второе фото задано; иначе одиночный рендер дословно.
const backgroundImage2 = nonEmpty(p.backgroundImages?.url2) ?? nonEmpty(p.backgroundImage2);

// Figma 1:19335 — ДОСЛОВНЫЙ плейсхолдер ПУСТОГО состояния секции «Изображение»
// (Hero/Image). «Пусто» = мерчант НЕ задал НИ фон-картинку, НИ заголовок, НИ текст,
// НИ кнопку (все значения берутся из flux-дефолтов: SITE_TITLE / «Там, где классика…»
// / «В каталог»). Тогда секция рендерит фон /placeholders/landscape-image.png +
// overlay-лейбл «Изображение» + хелпер «Покажи и расскажи о своем товаре в одном
// блоке» + кнопку «Кнопка» (ветка рендера ниже), а НЕ дефолт-контент верстальщика.
// Проверяем СЫРЫЕ пропсы (heading.text/title, text.content/subtitle, primaryButton.
// text/cta), а не resolved-значения с фолбэками — иначе пустое состояние не отличить
// от заданного. Hero/Image не имеет коллекционных данных → SSR-фетч сюда не относится
// (он для Popular/Collections/Gallery). Когда хоть что-то задано — рендер мерчанта
// дословно (нижняя ветка не трогается). Паттерн эталона rose Hero.astro.
const rawHeadingText =
	typeof p.heading?.text === "string"
		? p.heading.text
		: typeof p.title === "string"
			? p.title
			: "";
const rawSubtitleText =
	typeof p.text?.content === "string"
		? p.text.content
		: typeof p.subtitle === "string"
			? p.subtitle
			: "";
const rawPrimaryText =
	typeof p.primaryButton?.text === "string"
		? p.primaryButton.text
		: typeof p.cta?.text === "string"
			? p.cta.text
			: typeof p.ctaText === "string"
				? p.ctaText
				: "";
const isEmpty =
	!String(backgroundImage).trim() &&
	!String(backgroundImage2 ?? "").trim() &&
	!rawHeadingText.trim() &&
	!rawSubtitleText.trim() &&
	!rawPrimaryText.trim();
// Дословные тексты Figma-плейсхолдера (тип «Изображение»).
const PH_LABEL = "Изображение";
const PH_HELPER = "Покажи и расскажи о своем товаре в одном блоке";
const PH_BUTTON = "Кнопка";

// ДВА НЕЗАВИСИМЫХ размера у Hero:
//   • p.size — ВЫСОТА полотна (heroHeightCls ниже). НЕ шрифт.
//   • heading.size / text.size — размер ШРИФТА заголовка/текста (поля «Размер
//     заголовка»/«Размер текста»). font-size берётся ТОЛЬКО из heading.size/
//     text.size, БЕЗ фолбэка на p.size (иначе регулятор высоты снова менял бы
//     кегль). Отсутствие → дефолт-ветка large = ЭТАЛОН верстальщика (Hero.astro:43,47):
//     заголовок Roboto Flex uppercase 20/24; текст Roboto Flex 300 14/16; цвета →
//     токены §7 (белый фолбэк = эталонный text-white).
//   заголовок large 20/24 → medium 17/20 → small 14/17 (Roboto Flex uppercase)
//   текст     large 14/16 → medium 12/14 → small 11/12 (Roboto Flex 300)
const headingSize = p.heading?.size;
const headingCls =
	headingSize === "small"
		? "font-roboto-flex text-[14px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,255_255_255))] md:text-[17px]"
		: headingSize === "medium"
			? "font-roboto-flex text-[17px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,255_255_255))] md:text-[20px]"
			: "font-roboto-flex text-[20px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,255_255_255))] md:text-[24px]";
const textSize = p.text?.size;
const subtitleCls =
	textSize === "small"
		? "font-roboto-flex text-[11px] font-light leading-normal text-[rgb(var(--color-text,255_255_255))] md:text-[12px]"
		: textSize === "medium"
			? "font-roboto-flex text-[12px] font-light leading-normal text-[rgb(var(--color-text,255_255_255))] md:text-[14px]"
			: "font-roboto-flex text-[14px] font-light leading-normal text-[rgb(var(--color-text,255_255_255))] md:text-[16px]";
// «Размер» → ФИКСИРОВАННАЯ высота полотна (эталон верстальщика Hero.astro:28
// `h-[280px] sm:h-[360px] lg:h-[480px]`). large (дефолт flux) = эталон байт-в-байт;
// medium ≈0.82×, small ≈0.64× (каждый из трёх брейкпоинтов пропорционально ниже).
// Дефолт (p.size не задан) = large. Это Tailwind-КЛАССЫ высоты (адаптив sm/lg) —
// вешаются на div-полотно; <section> берёт высоту от потока полотна (+padding).
const heroSize = p.size === "small" ? "small" : p.size === "medium" ? "medium" : "large";
const heroHeightCls = {
	large: "h-[280px] sm:h-[360px] lg:h-[480px]",
	medium: "h-[230px] sm:h-[300px] lg:h-[400px]",
	small: "h-[180px] sm:h-[240px] lg:h-[320px]",
}[heroSize];
// Мобила = стек (медиа aspect-[4/3] сверху + карточка снизу, Shopify Image banner),
// десктоп = оверлей фикс-высоты (280/360/480). Поэтому min-h секции нужен ТОЛЬКО на
// md+ (на мобиле высота = медиа + карточка-подложка). md-only лестница высоты (без
// base/sm min-h), эталон верстальщика flux байт-в-байт. Паттерн rose heroHeightMdCls.
const heroHeightMdCls = {
	large: "md:h-[360px] lg:h-[480px]",
	medium: "md:h-[300px] lg:h-[400px]",
	small: "md:h-[240px] lg:h-[320px]",
}[heroSize];

// «Размер» (p.size) масштабирует не только высоту полотна, но и подложку-контейнер
// (max-w/gap/padding) + CTA-кнопку — симметрично (medium ≈0.82×, small ≈0.64×). Шрифты
// героя НЕ трогаем (у них свои поля heading.size/text.size). large = ТЕКУЩИЕ значения
// верстальщика flux байт-в-байт (max-w-[520px], gap-6 lg:gap-10, p-6 md:p-8, кнопка
// h-14 px-4 text-[16px]). Паттерн эталона rose Hero.astro.
// Мобила (стек): подложка-контейнер на всю ширину гаттера (без узкого max-w-кэпа —
// иначе small max-w-[380px] центрировался бы → пустые поля по бокам). Десктоп-оверлей
// (md+): max-w-кэп остаётся (карточка не во всю ширину поверх фото). Паттерн rose.
const panelMaxWCls = {
	large: "md:max-w-[520px]",
	medium: "md:max-w-[460px]",
	small: "md:max-w-[380px]",
}[heroSize];
const panelGapCls = {
	large: "gap-6 lg:gap-10",
	medium: "gap-5 lg:gap-8",
	small: "gap-4 lg:gap-6",
}[heroSize];
const panelPadCls = {
	large: "p-6 md:p-8",
	medium: "p-5 md:p-6",
	small: "p-4 md:p-5",
}[heroSize];
const ctaSizeCls = {
	large: "h-14 px-4 text-[16px]",
	medium: "h-[46px] px-[13px] text-[13px]",
	small: "h-9 px-2.5 text-[11px]",
}[heroSize];

// Вторая кнопка — ТОЛЬКО если мерчант задал (паритет с rose, FR-010): не
// подставляем дефолт «О нас», когда secondaryButton/aboutText не заданы.
// Пустой текст заданного пропа также скрывает. Legacy flat aboutText/aboutLink поддержаны.
const secondaryGiven = p.secondaryButton !== undefined && p.secondaryButton !== null;
const secondaryText = secondaryGiven
	? nonEmpty(p.secondaryButton?.text)
	: nonEmpty(p.aboutText);
const secondaryLink =
	p.secondaryButton?.link?.href ??
	(typeof p.secondaryButton?.link === "string" ? p.secondaryButton.link : undefined) ??
	nonEmpty(p.aboutLink) ??
	"#about";

// Канон overlay 0-100 (число или строка) → чёрный слой между фото (z-0) и контентом (z-10).
const overlayN = Math.max(0, Math.min(100, Number(p.overlay) || 0));

// Канон container (toggle «Контейнер» панели «Изображение») — подложка-плашка
// ТОЛЬКО под текстовым блоком, НЕ затемнение всего экрана (overlay отдельно).
// На светлой плашке белый текст flux не читается → переключаем на тёмный схемы.
const boxed = String(p.container ?? "false") === "true";
const boxedCls = boxed
	? ` rounded-[var(--radius-card,8px)] bg-[rgb(var(--color-bg,255_255_255))]/95 ${panelPadCls} shadow-sm [&_h1]:!text-[rgb(var(--color-heading,0_0_0))] [&_p]:!text-[rgb(var(--color-text,0_0_0))]`
	: "";
// Мобила-обёртка контента ПОД медиа (стек). «Контейнер» ON → карточка (boxedCls) сама
// = плашка-контейнер, поэтому обёртка ПРОЗРАЧНАЯ (только боковой гаттер + зазор от
// медиа) — иначе «контейнер внутри контейнера». «Контейнер» OFF → обёртка = сама
// подложка (фон схемы + вертик.паддинги). Десктоп (md+) — всегда absolute-оверлей,
// фон прозрачный (md:bg-transparent ниже). Паттерн rose wrapperMobileCls.
const wrapperMobileCls = boxed
	? "px-4 pt-4 pb-8 sm:px-5"
	: "bg-[rgb(var(--color-bg,255_255_255))] px-4 py-10 sm:px-5 sm:py-12";

// Канон position (видимое поле панели) / contentPosition (legacy, те же 9 значений).
// Позиция управляет РАЗМЕЩЕНИЕМ контент-блока по сетке 3×3 (как rose Hero):
//   вертикаль — top / center(=середина) / bottom; горизонталь — left / center / right.
// Выравнивание (alignment) теперь НЕЗАВИСИМО и отвечает только за выравнивание
// КОНТЕНТА внутри блока (заголовок/текст/кнопки), НЕ двигает сам блок.
// Раньше alignment (дефолт center) перебивал горизонталь позиции, а 'center'
// ошибочно не давал середину — это и был баг (см. rose Hero фикс).
//
// СОХРАНЕНИЕ ДЕФОЛТА ВЕРСТАЛЬЩИКА flux: дефолт = position:"left" (defaults/flux.json)
// и пустой проп (легаси-вызов index.astro <Hero title=.../>): оба = контент СЛЕВА
// ПО ЦЕНТРУ ВЕРТИКАЛИ (эталон Hero.astro:38 items-center). 'left' — горизонталь-
// только (нет верт-префикса) → hPos="left", vPos="". Пустой vPos у flux = ВЕРТ-ЦЕНТР
// (justify-center), как у верстальщика; пустой posRaw тоже трактуем как left-center
// (родная раскладка flux). Хром/поиск — в Header (манера flux сохраняется).
const posRaw =
	typeof p.position === "string" && p.position
		? p.position
		: typeof p.contentPosition === "string"
			? p.contentPosition
			: "";
const vPos = posRaw.startsWith("top")
	? "top"
	: posRaw.startsWith("bottom")
		? "bottom"
		: posRaw === "center" || posRaw.startsWith("center")
			? "middle"
			: ""; // пусто = верт-центр (эталон flux, см. vJustifyCls)
const hPos = posRaw.endsWith("left")
	? "left"
	: posRaw.endsWith("right")
		? "right"
		: posRaw === "" // пусто = left (родной дефолт flux, не center как у rose)
			? "left"
			: "center";
// flux ЭТАЛОН (Hero.astro:38 `flex h-full items-center`): дефолт = ВЕРТИКАЛЬНЫЙ
// ЦЕНТР. Пустой vPos (родная раскладка, position:"left") → justify-center, как у
// верстальщика. Явные top/middle/bottom продолжают работать (грид-варианты целы).
const vJustifyCls = vPos === "top" ? "justify-start" : vPos === "middle" ? "justify-center" : vPos === "bottom" ? "justify-end" : "justify-center";
// Вертикальный паддинг ДЕСКТОП-оверлея (md-only — на мобиле у карточки-обёртки свой
// py-10 через wrapperMobileCls). Позиция «центр»/дефолт-центр flux → СИММЕТРИЧНЫЙ
// (иначе перекошенный бокс уводит контент вниз = «ниже центра»); верх/низ — asymmetric
// (верх отодвигает от края, низ держит нижний отступ). Паттерн rose vPadMdCls.
const vPadMdCls =
	vPos === "top"
		? "md:pt-10 md:pb-10"
		: vPos === "bottom"
			? "md:pt-10 md:pb-10"
			: "md:py-10"; // middle + дефолт-центр flux = симметрично
const hItemsCls = hPos === "left" ? "items-start" : hPos === "right" ? "items-end" : "items-center"; // ПОЗИЦИЯ
// alignment — выравнивание КОНТЕНТА внутри блока (НЕ двигает сам блок — это делает
// Позиция через items на внешнем контейнере). items-* выравнивают заголовок/текст/
// кнопки друг относительно друга, text-align — многострочный текст.
// ВАЖНО flux: дефолт выравнивания (нет пропа alignment) = ВЛЕВО (родная раскладка
// верстальщика — контент у левого края блока), НЕ по центру как у rose. Явные
// alignment center/right двигают контент независимо от позиции.
const align = p.alignment === "center" || p.alignment === "right" ? p.alignment : "left";
const alignItemsCls = align === "right" ? "items-end" : align === "center" ? "items-center" : "items-start"; // ВЫРАВНИВАНИЕ
const textAlignCls = align === "right" ? "text-right" : align === "center" ? "text-center" : "text-left";
const buttonsJustifyCls = align === "right" ? "justify-end" : align === "center" ? "justify-center" : "justify-start";
// w-full — на мобиле блок контента заполняет обёртку-подложку (стек); на десктопе
// max-w-кэп (panelMaxWCls = md:max-w-*) ограничивает ширину карточки поверх фото.
const contentCls = `flex w-full ${panelMaxWCls} flex-col ${panelGapCls} ${alignItemsCls}${boxedCls}`;

// Канон buttonStyle solid|outlined для основной кнопки. ЭТАЛОН верстальщика
// (Hero.astro:59) = СПЛОШНАЯ ЧЁРНАЯ кнопка: h-14, bg-black, белый текст,
// font-roboto-flex, uppercase, px-4, text-[16px], leading-none, hover:opacity-90.
// solid/отсутствие = этот чёрный эталон (чёрная CTA — дизайн-интент верстальщика,
// поверх цветосхем); outlined = контур того же чёрного языка (бордер+текст black на
// прозрачном). Радиус остаётся токеном схемы (дефолт 6px = эталон).
// Ширина кнопок: при ВТОРОЙ кнопке — grid-колонки 1fr_1fr, кнопки тянутся в свою
// колонку (w-auto) → равная ширина «по большей» (rose 50d5b497). Одиночная —
// прежний w-fit (кнопка по контенту). НЕ использовать grid-cols-2 (=minmax(0,1fr) —
// сожмёт), только bare [grid-template-columns:1fr_1fr] (см. buttonsCls ниже).
const btnWidthCls = secondaryText ? "w-auto" : "w-fit";
const ctaBtnCls =
	p.buttonStyle === "outlined"
		? `inline-flex ${btnWidthCls} items-center justify-center rounded-[var(--radius-button,6px)] border border-black font-roboto-flex font-normal uppercase leading-none text-black transition-colors hover:bg-black/5 ${ctaSizeCls}`
		: `inline-flex ${btnWidthCls} items-center justify-center rounded-[var(--radius-button,6px)] bg-black font-roboto-flex font-normal uppercase leading-none text-white transition-opacity hover:opacity-90 ${ctaSizeCls}`;
// Вторая кнопка — outlined в том же чёрном языке эталона (h-14, font-roboto-flex,
// uppercase); рендерится ТОЛЬКО когда мерчант задал secondaryButton (условие ниже).
const secondaryBtnCls = `inline-flex ${btnWidthCls} items-center justify-center rounded-[var(--radius-button,6px)] border border-black font-roboto-flex font-normal uppercase leading-none text-black transition-colors hover:bg-black/5 ${ctaSizeCls}`;
// Кнопочный ряд: дефолт (нет второй кнопки) = прежняя строка (flex flex-wrap) с
// выравниванием от alignment; при secondaryButton — две кнопки РАВНОЙ ширины «по
// большей»: inline-grid из двух bare-1fr колонок (обе = ширине более широкой кнопки),
// кнопки-grid-items с w-auto заполняют свою колонку. Позиция ряда (left/center/right)
// задаётся alignment через buttonsJustifyCls (grid) / justify-контент (flex).
const buttonsCls = secondaryText
	? `inline-grid [grid-template-columns:1fr_1fr] items-stretch gap-3`
	: `flex flex-wrap gap-3 ${buttonsJustifyCls}`;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose
// T14 / bloom Hero). Для ПУСТОГО состояния (isEmpty-ветка) остаётся простой inline
// padding (фикс-высота полотна там прежняя).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
const rootStyle = paddingStyle;
// Стек-секция (мобила, основная ветка): «Отступы» как CSS-переменные → верхний
// паддинг применяется ТОЛЬКО на десктопе (md:pt через var), на мобиле pt=0 — медиа
// встык под шапкой (убрать «промежуток над медиа»). Нижний паддинг (pb) — на всех
// ширинах. Паттерн rose paddingVars (ac01a721).
const paddingVars = p.padding
	? `--hero-pt:${p.padding.top}px;--hero-pb:${p.padding.bottom}px;`
	: undefined;
---

{
	isEmpty ? (
		/* Пустое состояние (Figma 1:19335, тип «Изображение», контракт картиночных
		   секций): фон секции = дизайн-ассет /placeholders/landscape-image.png
		   (картинка показывается ВСЕГДА, НЕ пустой surface и НЕ мок верстальщика) +
		   лёгкий тёмный overlay для читаемости + overlay-лейбл «Изображение» +
		   хелпер-текст + кнопка «Кнопка». Без дефолт-контента верстальщика (SITE_TITLE
		   / «Там, где классика…» / «В каталог» / «О нас»). Манера flux: Roboto Flex
		   uppercase-заголовок и Roboto Flex-хелпер белым на фото (как обычный Hero на
		   картинке), высота полотна = heroHeightCls. Сырой <img> (нет .webp). */
		<section
			class="relative w-full overflow-hidden bg-[rgb(var(--color-surface,245_245_245))]"
			style={rootStyle}
			aria-labelledby="hero-title"
			data-puck-component-id={id}
		>
			<img
				src="/placeholders/landscape-image.png"
				alt=""
				aria-hidden="true"
				loading="eager"
				class="absolute inset-0 z-0 size-full object-cover object-center"
			/>
			<div class="pointer-events-none absolute inset-0 z-[1] bg-black/30" aria-hidden="true" />
			<div class={`relative w-full ${heroHeightCls}`}>
				<div class="absolute inset-0 z-10 flex w-full flex-col items-center justify-center gap-6 px-4 py-8 text-center md:gap-10 md:px-20 md:py-10 2xl:px-80">
					<div class="flex max-w-[432px] flex-col items-center gap-2 text-center">
						<h1
							id="hero-title"
							class="font-roboto-flex text-[20px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,255_255_255))] md:text-[24px]"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="100"
							data-puck-subsection-field="heading"
						>
							{PH_LABEL}
						</h1>
						<p
							class="font-roboto-flex text-[14px] font-light leading-normal text-[rgb(var(--color-text,255_255_255))] md:text-[16px]"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="101"
							data-puck-subsection-field="text"
						>
							{PH_HELPER}
						</p>
					</div>
					<div class="flex flex-wrap justify-center gap-3">
						<a
							href={ctaLink}
							class="inline-flex h-14 w-fit items-center justify-center rounded-[var(--radius-button,6px)] bg-black px-4 font-roboto-flex text-[16px] font-normal uppercase leading-none text-white transition-opacity hover:opacity-90"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="102"
							data-puck-subsection-field="primaryButton"
						>
							{PH_BUTTON}
						</a>
					</div>
				</div>
			</div>
		</section>
	) : (
<section
	class={`relative w-full overflow-hidden bg-[rgb(var(--color-bg,245_245_245))] pb-[var(--hero-pb,0px)] md:pt-[var(--hero-pt,0px)] ${heroHeightMdCls}`}
	style={paddingVars}
	aria-labelledby="hero-title"
	data-puck-component-id={id}
>
	{/* Баг M$rkul «чёрные полосы сверху/снизу»: фон-картинка кроет ВСЮ секцию
	    (absolute на уровне <section> на md+ → заполняет padding-box целиком, включая
	    зону «Отступы») → фон цветовой схемы больше не проступает полосами. «Отступы»
	    (padding на <section>) отодвигают КОНТЕНТ, а не создают полосы (rose Hero). */}
	{/* КАРТИНКА — мобила: блок-картинка сверху aspect-[4/3] (стек как Shopify Image
	    banner); десктоп: absolute на всю секцию (оверлей под текстом, aspect-auto). */}
	<div class="relative z-0 aspect-[4/3] w-full md:absolute md:inset-0 md:aspect-auto">
		{
			backgroundImage2 ? (
				<div class="absolute inset-0 grid grid-cols-2 overflow-hidden">
					<FluxPicture
						src={backgroundImage}
						alt={title}
						loading="eager"
						fetchpriority="high"
						class="size-full object-cover object-center"
					/>
					<FluxPicture
						src={backgroundImage2}
						alt=""
						loading="eager"
						fetchpriority="high"
						class="size-full object-cover object-center"
					/>
				</div>
			) : backgroundImage ? (
				<FluxPicture
					src={backgroundImage}
					alt={title}
					loading="eager"
					fetchpriority="high"
					class="absolute inset-0 size-full object-cover object-center"
				/>
			) : (
				<img
					src="/placeholders/landscape-image.png"
					alt=""
					aria-hidden="true"
					loading="eager"
					class="absolute inset-0 size-full object-cover object-center"
				/>
			)
		}
	</div>

	{/* Затемнение фото — только десктоп (на мобиле медиа в потоке, текст на подложке снизу). */}
	{
		overlayN > 0 && (
			<div
				class="pointer-events-none absolute inset-0 z-[1] hidden bg-black md:block"
				style={`opacity:${overlayN / 100}`}
			/>
		)
	}

	{/* КОНТЕНТ — мобила: блок-подложка (фон схемы) ПОД картинкой в потоке; десктоп:
	    absolute-оверлей поверх фото (md:bg-transparent). */}
	<div
		class={`relative z-10 flex w-full flex-col ${hItemsCls} ${vJustifyCls} ${wrapperMobileCls} md:absolute md:inset-0 md:bg-transparent md:px-20 2xl:px-80 ${vPadMdCls}`}
	>
		<div class={contentCls} data-reveal>
			<div class={`flex flex-col gap-2 ${alignItemsCls} ${textAlignCls}`}>
				<h1
					id="hero-title"
					class={headingCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{title}
				</h1>
				<p
					class={subtitleCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="101"
					data-puck-subsection-field="text"
				>
					{subtitle}
				</p>
			</div>

			<div class={buttonsCls}>
				<a
					href={ctaLink}
					class={ctaBtnCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="primaryButton"
				>
					{ctaText}
				</a>
				{
					secondaryText && (
						<a
							href={secondaryLink}
							class={secondaryBtnCls}
							data-puck-subsection-parent={id}
							data-puck-subsection-index="103"
							data-puck-subsection-field="secondaryButton"
						>
							{secondaryText}
						</a>
					)
				}
			</div>
		</div>
	</div>
</section>
	)
}
