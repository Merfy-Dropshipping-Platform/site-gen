---
interface Props {
  video?: { url?: string; coverImage?: string };
  position?: 'fullscreen' | 'window';
  content?: {
    size?: 'small' | 'medium' | 'large';
    heading?: { enabled?: string; text?: string; size?: string };
    subheading?: { enabled?: string; text?: string };
  };
  colorScheme?: string;
  padding?: { top?: number; bottom?: number };
}

const { video, position = 'window', content, colorScheme, padding } = Astro.props;
const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';
const videoUrl = video?.url ?? '';
const coverImage = video?.coverImage ?? '';
const showHeading = content?.heading?.enabled !== 'false' && content?.heading?.text;
const showSubheading = content?.subheading?.enabled !== 'false' && content?.subheading?.text;
const padTop = padding?.top ?? undefined;
const padBottom = padding?.bottom ?? undefined;

// Extract YouTube/Vimeo embed URL
function getEmbedUrl(url: string): string {
  if (!url) return '';
  const ytMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/);
  if (ytMatch) return `https://www.youtube.com/embed/${ytMatch[1]}`;
  const vimeoMatch = url.match(/vimeo\.com\/(\d+)/);
  if (vimeoMatch) return `https://player.vimeo.com/video/${vimeoMatch[1]}`;
  return url;
}

const embedUrl = getEmbedUrl(videoUrl);
const isFullscreen = position === 'fullscreen';
---

<section
  class={`video-section w-full ${schemeClass}`}
  style={`${padTop !== undefined ? `padding-top: ${padTop}px;` : ''} ${padBottom !== undefined ? `padding-bottom: ${padBottom}px;` : ''} background: rgb(var(--color-background)); color: rgb(var(--color-foreground));`}
>
  <div class={isFullscreen ? 'w-full' : 'video-container'}>
    {(showHeading || showSubheading) && (
      <div class="flex flex-col items-start gap-[8px] mb-[40px]">
        {showHeading && (
          <h2 class="text-[20px] font-normal leading-[1.2] font-heading" style="color: rgb(var(--color-foreground));">
            {content!.heading!.text}
          </h2>
        )}
        {showSubheading && (
          <p class="text-[16px] font-normal leading-[1.25] font-body" style="color: rgb(var(--color-muted));">
            {content!.subheading!.text}
          </p>
        )}
      </div>
    )}
    <div
      class={`video-player relative overflow-hidden ${isFullscreen ? 'rounded-none' : ''}`}
      style={isFullscreen ? '' : 'border-radius: var(--radius-card, 0px);'}
      data-video-url={embedUrl}
    >
      {embedUrl ? (
        <>
          {/* Cover image with overlay + play button (click to load iframe) */}
          {coverImage ? (
            <div class="video-cover absolute inset-0 z-10 cursor-pointer" data-embed-url={embedUrl}>
              <img src={coverImage} alt="Video cover" class="w-full h-full object-cover" loading="lazy" />
              <div class="absolute inset-0" style="background: rgba(0, 0, 0, 0.1);"></div>
              <button
                class="video-play-btn absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20 flex items-center justify-center"
                aria-label="Play video"
                type="button"
              >
                <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <polygon points="16,10 36,22 16,34" fill="white"/>
                </svg>
              </button>
            </div>
          ) : null}
          <iframe
            src={coverImage ? '' : embedUrl}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            class="w-full h-full absolute inset-0"
          ></iframe>
        </>
      ) : coverImage ? (
        <div class="relative w-full h-full">
          <img src={coverImage} alt="Video cover" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0" style="background: rgba(0, 0, 0, 0.1);"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex items-center justify-center">
            <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polygon points="16,10 36,22 16,34" fill="white"/>
            </svg>
          </div>
        </div>
      ) : (
        <div class="w-full h-full flex items-center justify-center" style="background: rgb(var(--color-foreground) / 0.05);">
          <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
            <polygon points="16,10 36,22 16,34" fill="rgb(var(--color-foreground))" opacity="0.3"/>
          </svg>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .video-section {
    padding-top: var(--spacing-section-mobile, 80px);
    padding-bottom: var(--spacing-section-mobile, 80px);
  }
  @media (min-width: 768px) {
    .video-section {
      padding-top: var(--spacing-section, 120px);
      padding-bottom: var(--spacing-section, 120px);
    }
  }

  .video-container {
    max-width: calc(100% - 40px);
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .video-container {
      max-width: none;
      margin: 0;
      padding-left: var(--content-padding, 300px);
      padding-right: var(--content-padding, 300px);
    }
  }

  .video-player {
    position: relative;
    width: 100%;
    aspect-ratio: 1319 / 742;
    background: rgb(var(--color-foreground));
  }
</style>

<script>
  document.querySelectorAll('.video-cover').forEach((cover) => {
    cover.addEventListener('click', () => {
      const embedUrl = cover.getAttribute('data-embed-url');
      if (!embedUrl) return;
      const player = cover.closest('.video-player');
      if (!player) return;
      const iframe = player.querySelector('iframe');
      if (iframe) {
        iframe.src = embedUrl + (embedUrl.includes('?') ? '&' : '?') + 'autoplay=1';
      }
      cover.remove();
    });
  });
</script>
