{
  "$schema": "https://merfy.ru/schemas/theme-manifest.v2.json",
  "id": "vanilla",
  "name": "Vanilla",
  "version": "1.0.0",
  "extends": "@merfy/theme-base@workspace:*",
  "category": "general",
  "description": "Vanilla flat theme — olive-green palette with square radii (Merfy universal storefront template).",
  "author": "Merfy",
  "tokens": "./tokens.json",

  "defaults": {
    "--font-heading": "'Bitter', serif",
    "--font-body": "'Arsenal', sans-serif",
    "--font-cart-counter": "'Exo 2', sans-serif",
    "--font-powered-by": "'Inter', sans-serif",
    "--weight-heading": "400",
    "--weight-body": "400",
    "--container-max-width": "1320px",
    "--radius-button": "0px",
    "--radius-input": "0px",
    "--radius-card": "0px",
    "--radius-media": "0px",
    "--radius-field": "0px",
    "--size-hero-heading": "24px",
    "--slide-min-height": "880px",
    "--size-hero-button-h": "48px",
    "--size-section-heading": "20px",
    "--size-nav-link": "16px",
    "--size-newsletter-form-w": "480px",
    "--size-logo-width": "120px",
    "--size-card-border": "1px",
    "--spacing-section-y": "80px",
    "--spacing-grid-col-gap": "40px",
    "--spacing-grid-row-gap": "40px",
    "--button-style": "solid",
    "--footer-layout": "2-part",
    "--contact-form-layout": "wide",
    "--cart-type": "drawer",
    "--card-style": "standard",
    "--card-alignment": "left",
    "--color-error": "255 148 148",
    "--color-bottom-strip-bg": "0 0 0",
    "--color-bottom-strip-text": "255 255 255",
    "--promo-banner-h-thin": "56px",
    "--color-header-bg": "58 69 48",
    "--size-header-h": "80px"
  },

  "blockDefaults": {
    "PromoBanner": {
      "size": "thin",
      "textTransform": "uppercase",
      "colorScheme": "scheme-1"
    },
    "Header": {
      "logoPosition": "center-absolute",
      "activeLinkIndicator": "underline",
      "padding": { "top": 32, "bottom": 32 }
    },
    "Hero": {
      "mode": "carousel",
      "imageFullBleed": true,
      "contentAlign": "left",
      "alignment": "left",
      "pagination": "numbers",
      "buttonStyle": "solid",
      "size": "large",
      "container": "false",
      "autoplay": true,
      "interval": 5
    },
    "Slideshow": {
      "alignment": "left",
      "pagination": "numbers",
      "contentAlign": "left",
      "imageFullBleed": true
    },
    "Collections": {
      "cardCaptionStyle": "uppercase",
      "gridAspect": "1:1",
      "titleAlignment": "left"
    },
    "MainText": {
      "buttonStyle": "outlined",
      "textStyle": "italic"
    },
    "Video": {
      "padded": true,
      "align": "container"
    },
    "ImageWithText": {
      "imagePosition": "right",
      "ctaPosition": "bottom-pinned"
    },
    "PopularProducts": {
      "swatchOverlay": true,
      "cardCaptionStyle": "uppercase",
      "headingAlignment": "left",
      "columns": 3
    },
    "Newsletter": {
      "formLayout": "inline-submit",
      "alignment": "left"
    },
    "Footer": {
      "variant": "2-part-asymmetric",
      "bottomStrip": {
        "enabled": true,
        "text": "© 2025 Vanilla Theme. Powered by Merfy"
      }
    }
  },

  "colorSchemes": [
    {
      "id": "scheme-1",
      "name": "1",
      "tokens": {
        "--color-bg": "38 49 28",
        "--color-surface": "38 49 28",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "200 200 200",
        "--color-primary": "255 255 255",
        "--color-accent": "58 69 48",
        "--color-button-bg": "58 69 48",
        "--color-button-text": "255 255 255",
        "--color-button-border": "58 69 48",
        "--color-button-2-bg": "238 238 238",
        "--color-button-2-text": "38 49 28",
        "--color-button-2-border": "200 200 200"
      }
    },
    {
      "id": "scheme-2",
      "name": "2",
      "tokens": {
        "--color-bg": "58 69 48",
        "--color-surface": "58 69 48",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "200 200 200",
        "--color-primary": "255 255 255",
        "--color-accent": "38 49 28",
        "--color-button-bg": "255 255 255",
        "--color-button-text": "58 69 48",
        "--color-button-border": "255 255 255",
        "--color-button-2-bg": "38 49 28",
        "--color-button-2-text": "255 255 255",
        "--color-button-2-border": "80 90 70"
      }
    },
    {
      "id": "scheme-3",
      "name": "3",
      "tokens": {
        "--color-bg": "238 238 238",
        "--color-surface": "238 238 238",
        "--color-heading": "38 49 28",
        "--color-text": "38 49 28",
        "--color-muted": "68 68 68",
        "--color-primary": "38 49 28",
        "--color-accent": "58 69 48",
        "--color-button-bg": "58 69 48",
        "--color-button-text": "255 255 255",
        "--color-button-border": "58 69 48",
        "--color-button-2-bg": "238 238 238",
        "--color-button-2-text": "38 49 28",
        "--color-button-2-border": "200 200 200"
      }
    },
    {
      "id": "scheme-4",
      "name": "4",
      "tokens": {
        "--color-bg": "255 255 255",
        "--color-surface": "255 255 255",
        "--color-heading": "38 49 28",
        "--color-text": "38 49 28",
        "--color-muted": "68 68 68",
        "--color-primary": "38 49 28",
        "--color-accent": "58 69 48",
        "--color-button-bg": "58 69 48",
        "--color-button-text": "255 255 255",
        "--color-button-border": "58 69 48",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "38 49 28",
        "--color-button-2-border": "200 200 200"
      }
    }
  ],

  "blocks": {
    "Hero": { "variant": "overlay" },
    "Header": {},
    "Footer": {},
    "PopularProducts": {},
    "Collections": {},
    "Product": {},
    "Newsletter": {},
    "ContactForm": {}
  },

  "features": {
    "newsletter": true,
    "cart-drawer": true,
    "otp-auth": true,
    "wishlist": false,
    "color-swatches": false,
    "filter-sidebar": true
  },

  "fonts": [
    { "family": "Bitter",  "weights": [400, 600, 700], "italic": true, "source": "google" },
    { "family": "Arsenal", "weights": [400, 700],                       "source": "google" },
    { "family": "Exo 2",   "weights": [400, 700],                       "source": "google" },
    { "family": "Inter",   "weights": [300, 400, 500],                  "source": "google" }
  ]
}
