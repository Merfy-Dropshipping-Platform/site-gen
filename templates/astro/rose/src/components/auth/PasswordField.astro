---
/**
 * PasswordField — поле пароля с eye-toggle иконкой справа.
 * Обёртка над AuthInput + PasswordEyeToggle island.
 */
import PasswordEyeToggle from './islands/PasswordEyeToggle.tsx';

interface Props {
  label: string;
  name: string;
  id?: string;
  placeholder?: string;
  required?: boolean;
  autocomplete?: string;
  minlength?: number;
  error?: string;
}
const {
  label,
  name,
  id = name,
  placeholder,
  required,
  autocomplete = 'current-password',
  minlength,
  error,
} = Astro.props;
---
<div class="flex flex-col items-start gap-2 w-full">
  <label for={id} class="auth-label">
    {label}{required && <span class="auth-required"> *</span>}
  </label>
  <div class="auth-password-wrapper">
    <input
      type="password"
      id={id}
      name={name}
      placeholder={placeholder}
      required={required}
      autocomplete={autocomplete}
      minlength={minlength}
      data-error={error ? 'true' : 'false'}
      class="auth-input"
    />
    <PasswordEyeToggle client:load targetId={id} />
  </div>
  {error && <span class="auth-helper-error" data-error-for={id}>{error}</span>}
  {!error && <span class="auth-helper-error hidden" data-error-for={id}></span>}
</div>
