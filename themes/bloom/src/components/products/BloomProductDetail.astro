---
/**
 * Разметка страницы товара (PDP) — общий компонент для demo-SSG `[id].astro`
 * и клиентски-гидрируемой `/product?id=` (Option B, спек 098). Единый источник
 * разметки → parity demo ↔ реальный товар (никаких дублей).
 *
 * `data-pdp-*` хуки — точки клиентского патча в `/product?id=` (имя, цена,
 * картинка, описание, атрибуты корзины). На demo-странице патча нет — рендерится
 * как было. Вариант-строка обёрнута в `data-pdp-variants` — на реальном товаре
 * её содержимое заменяется селектором из variantCombinations.
 */
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import NtVariantTextRow from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtVariantTextRow.astro";
import BloomPicture from "../img/BloomPicture.astro";
import type { CatalogProduct } from "../../data/products";

interface Props {
	product: CatalogProduct;
	/** Puck-id блока «Товар» (page-product). Задаётся ТОЛЬКО в preview-консьюмере
	 * (`/product`), куда build/preview инжектит реальный динамический Product-<ts>
	 * через window.__MERFY_PRODUCT_BLOCK_ID__. На demo `[id].astro` остаётся
	 * undefined → Astro опускает data-атрибуты (live визуально не меняется). */
	id?: string;
	/** Контекст магазина для ЖИВОЙ гидрации товара (`/api/store/products?store_id=`).
	 * Рендерится в `data-site-id` секции; live-inline-script читает его (или глобал
	 * превью `__MERFY_SITE_ID__`, или `data-site-id`) как store_id. На demo
	 * `[id].astro` не передаётся → Astro опускает атрибут → API-путь пропускается,
	 * остаётся demo-скелетон. */
	siteId?: string;
}

const { product, id, siteId } = Astro.props;

const colorLabels: Record<string, string> = {
	brown: "Коричневый",
	black: "Чёрный",
	white: "Белый",
	olive: "Оливковый",
	gray: "Серый",
	pink: "Розовый",
	"light-pink": "Светло-розовый",
};

const colors = (product.colors ?? []).map((color, index) => ({
	id: color,
	label: colorLabels[color] ?? color,
	unavailable: index === (product.colors?.length ?? 0) - 1 && (product.colors?.length ?? 0) > 1,
}));

const galleryImages =
	product.gallery && product.gallery.length > 0 ? product.gallery : [product.image];
const [mainImage, ...thumbs] = galleryImages;
const cartVariantColor = product.colors?.[0] ?? "";
---

<section
	class="w-full bg-white px-4 pb-[80px] pt-10 md:px-20 md:pb-[120px] md:pt-16 2xl:px-[300px]"
	aria-labelledby="product-title"
	data-pdp-section
	data-cart-color={cartVariantColor}
	data-site-id={siteId}
	data-puck-component-id={id}
>
	<div class="mx-auto grid w-full max-w-[1320px] grid-cols-1 gap-8 lg:grid-cols-[600px_minmax(0,1fr)] lg:gap-10" data-pdp-layout style="opacity:0;transition:opacity .15s ease">
		<div class="flex flex-col gap-4">
			<div class="relative aspect-square w-full overflow-hidden bg-[#F5F5F5]">
				<BloomPicture
					src={mainImage}
					alt={product.name}
					loading="eager"
					fetchpriority="high"
					class="h-full w-full object-contain"
					data-pdp-main
				/>
				{product.discount && (
					<span class="absolute left-3 top-3 inline-flex h-6 items-center rounded-[4px] bg-[#000000] px-1.5 font-manrope text-[12px] font-normal leading-none text-white" data-pdp-badge>
						Скидка
					</span>
				)}
			</div>
			{thumbs.length > 0 && (
				<div class="grid grid-cols-3 gap-4" data-pdp-thumbs-row>
					{[mainImage, ...thumbs].slice(0, 6).map((img) => (
						<button
							type="button"
							class="aspect-square w-full overflow-hidden bg-[#F5F5F5] transition-opacity hover:opacity-90"
							data-pdp-thumb
							data-image={img}
							aria-label="Показать изображение"
						>
							<BloomPicture
								src={img}
								alt={product.name}
								loading="eager"
								class="h-full w-full object-contain"
							/>
						</button>
					))}
				</div>
			)}
		</div>

		<div class="flex flex-col gap-10">
			<div class="flex flex-col gap-2">
				<p
					class="font-manrope text-[14px] font-light leading-normal text-[#999999]"
					data-pdp-brand
					hidden={!product.brand}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="text"
				>
					{product.brand}
				</p>
				<h1
					id="product-title"
					class="font-comfortaa text-[28px] font-normal uppercase leading-[1.115] text-[#000000] md:text-[32px] lg:text-[36px]"
					data-pdp-name
					data-puck-subsection-parent={id}
					data-puck-subsection-index="101"
					data-puck-subsection-field="title"
				>
					{product.name}
				</h1>
				<div
					class="flex flex-wrap items-baseline gap-2"
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="price"
				>
					<span class="font-manrope text-[20px] font-normal leading-normal text-[#000000] md:text-[24px]" data-pdp-price>
						{product.price}
					</span>
					<span
						class="font-manrope text-[16px] font-light leading-normal text-[#999999] line-through md:text-[18px]"
						data-pdp-oldprice
						hidden={!product.oldPrice}
					>
						{product.oldPrice}
					</span>
				</div>
			</div>

			<div class="flex flex-col gap-6">
				<div
					class="flex flex-col gap-4"
					data-pdp-variants
					data-puck-subsection-parent={id}
					data-puck-subsection-index="103"
					data-puck-subsection-field="variants"
				>
					<NtVariantTextRow
						items={colors}
						selectedId={colors[0]?.id}
						groupLabel="Цвет"
						groupName="pdp-color"
					/>
				</div>

				<div
					class="flex h-10 w-fit items-center rounded-[4px] border border-[#F5F5F5]"
					data-pdp-qty
					data-puck-subsection-parent={id}
					data-puck-subsection-index="104"
					data-puck-subsection-field="quantity"
				>
					<button
						type="button"
						class="flex size-10 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Уменьшить количество"
						data-action="qty-dec"
					>
						<NtIcon name="minus" sizeClass="size-4" />
					</button>
					<input
						type="number"
						min="1"
						value="1"
						class="h-10 w-12 bg-transparent text-center font-manrope text-[14px] font-normal leading-normal text-[#000000] outline-none"
						aria-label="Количество"
						data-pdp-qty-value
					/>
					<button
						type="button"
						class="flex size-10 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Увеличить количество"
						data-action="qty-inc"
					>
						<NtIcon name="plus" sizeClass="size-4" />
					</button>
				</div>
			</div>

			<div
				class="flex flex-col gap-3"
				data-puck-subsection-parent={id}
				data-puck-subsection-index="105"
				data-puck-subsection-field="buttons"
			>
				<button
					type="button"
					data-add-to-cart
					data-product-id={product.id}
					data-name={product.name}
					data-price={product.price}
					data-old-price={product.oldPrice ?? ""}
					data-image={mainImage}
					data-volume={product.volume ?? ""}
					data-variant-color={cartVariantColor}
					data-quantity="1"
					class="inline-flex h-12 items-center justify-center rounded-[6px] border border-[#000000] bg-white px-4 font-manrope text-[16px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-90"
				>
					Добавить в корзину
				</button>
				<button
					type="button"
					data-action="buy-now"
					data-product-id={product.id}
					data-name={product.name}
					data-price={product.price}
					data-image={mainImage}
					data-volume={product.volume ?? ""}
					class="inline-flex h-12 items-center justify-center rounded-[6px] bg-[#000000] px-4 font-manrope text-[16px] font-normal leading-normal text-white transition-opacity hover:opacity-95"
				>
					Купить сейчас
				</button>
			</div>

			<div class="flex flex-col gap-4">
				<div
					class="flex flex-col gap-4"
					data-puck-subsection-parent={id}
					data-puck-subsection-index="106"
					data-puck-subsection-field="description"
				>
					<h2 class="font-comfortaa text-[18px] font-normal uppercase leading-normal text-[#000000]">
						Описание
					</h2>
					<p class="font-manrope text-[14px] font-light leading-[1.5] text-[#999999] md:text-[15px]" data-pdp-desc>
						{product.description}
					</p>
				</div>
				<div
					data-puck-subsection-parent={id}
					data-puck-subsection-index="107"
					data-puck-subsection-field="share"
				>
					<button
						type="button"
						data-action="share"
						class="inline-flex w-fit items-center gap-2 font-manrope text-[14px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-70"
						aria-label="Поделиться"
					>
						<NtIcon name="share" sizeClass="size-5" />
						<span>Поделиться</span>
					</button>
				</div>
			</div>
		</div>
	</div>

	{/* «Товар не найден» — показывается live-гидрацией ТОЛЬКО когда товар не
	    резолвится (магазин пуст / неверный slug). Живёт в КОМПОНЕНТЕ, чтобы оба
	    маршрута (`/product` и demo `products/[id]`) получили его без дублей в
	    consumer-страницах. На demo-сборке без products.json гидрация — no-op
	    (остаётся demo-скелетон), блок остаётся скрытым. */}
	<div
		data-pdp-notfound
		hidden
		class="w-full bg-white py-24 text-center"
	>
		<p class="font-comfortaa text-[24px] uppercase text-[#000000]">Товар не найден</p>
		<a
			href="/catalog"
			class="mt-6 inline-flex h-12 items-center justify-center rounded-[6px] bg-[#000000] px-6 font-manrope text-[16px] text-white transition-opacity hover:opacity-90"
		>В каталог</a>
	</div>
</section>

<script is:inline>
	(function () {
		function stampProductBlockId() {
			var id = window.__MERFY_PRODUCT_BLOCK_ID__;
			if (!id) return;
			var section = document.querySelector("[data-pdp-section]");
			if (!section) return;
			if (!section.getAttribute("data-puck-component-id")) section.setAttribute("data-puck-component-id", id);
			section.querySelectorAll("[data-puck-subsection-index]").forEach(function (el) {
				if (!el.getAttribute("data-puck-subsection-parent")) el.setAttribute("data-puck-subsection-parent", id);
			});
		}
		stampProductBlockId();
		document.addEventListener("astro:page-load", stampProductBlockId);
	})();
</script>

<script is:inline define:vars={{ propSiteId: siteId }}>
	/**
	 * ЖИВАЯ ГИДРАЦИЯ PDP (bloom). Заменяет прежний demo-UI module-<script> +
	 * хелпер-импорт из product.astro: грузит РЕАЛЬНЫЙ товар из ЖИВОГО
	 * /api/store/products (как каталог bloom), заполняет существующие data-pdp-*
	 * хуки разметки и атрибуты корзины. Без живых данных (demo-сборка) — чистый
	 * no-op: остаётся SSR-скелетон, вёрстка/цвета/шрифты не трогаются.
	 *
	 * ТОЛЬКО is:inline (НЕ module-<script> с import): module client-script темы НЕ
	 * компилится в live theme dist по универсальному /product-маршруту надёжно →
	 * риск 404 / двойной гидрации. Логика инлайнится 1:1 из эталона
	 * RoseProductDetail, адаптируя селекторы/корзину под bloom.
	 *
	 * КОРЗИНА: НЕ зовём cart-API вручную. Тема bloom вешает ГЛОБАЛЬНЫЙ
	 * делегированный обработчик [data-add-to-cart] (cart.ts → initCartUI в
	 * Layout.astro), который читает data-product-id/-name/-price/-old-price/
	 * -image/-volume/-quantity/-variant-color/-variant-size/-variant-combination-id,
	 * кладёт линию в локальную корзину bloom и открывает «added»-модалку. Наша
	 * задача — заполнить эти атрибуты реальными значениями. «Купить сейчас» = тот
	 * же add + переход на /cart (там мост NtCart → серверный cartStore → /checkout).
	 */
	(function () {
		// ─── Источник данных: ЖИВОЙ storefront API (спек 098 — «не products.json»). ───
		// apiBase: на live (*.merfy.ru) cross-origin к gateway (CORS пропускает
		// *.merfy.ru); в превью iframe на gateway-origin → тот же URL same-origin.
		var apiBase =
			(typeof window !== "undefined" && window.__MERFY_API_BASE__) || "https://gateway.merfy.ru";
		// store_id (shopId) = siteId. На live build сам siteId инжектится консьюмером
		// (data-site-id) ИЛИ глобалом превью __MERFY_SITE_ID__.
		function resolveSiteId() {
			if (typeof window !== "undefined" && window.__MERFY_SITE_ID__) return window.__MERFY_SITE_ID__;
			var sec = document.querySelector("[data-pdp-section]");
			var fromAttr = sec && sec.getAttribute("data-site-id");
			if (fromAttr) return fromAttr;
			return propSiteId || undefined;
		}

		var PLACEHOLDER_IMAGE = "/placeholders/sweater-blue.png";
		var __cachedProducts; // undefined — не грузили; null — данных нет (demo).

		// Цена из API — в КОПЕЙКАХ (basePrice "79000.00" / variant.price 79000).
		function toCents(v) {
			var n = typeof v === "string" ? parseFloat(v) : v;
			return Number.isFinite(n) ? n : null;
		}
		function variantMinCents(p) {
			var vc = p.variantCombinations;
			if (Array.isArray(vc) && vc.length) {
				var ps = vc.map(function (v) { return toCents(v.price); }).filter(function (n) { return n !== null && n > 0; });
				if (ps.length) return Math.min.apply(null, ps);
			}
			return null;
		}
		// mapApiProduct: товар /api/store/products → форма клиента PDP. Цены
		// копейки→рубли; title→name; handle→slug; variantCombinations нормализуем в
		// рубли. Зеркало Catalog/RoseProductDetail.mapApiProduct.
		function mapApiProduct(p) {
			var cents =
				(p.hasVariants ? variantMinCents(p) : null) ??
				toCents(p.basePrice) ??
				variantMinCents(p) ??
				0;
			var oldCents = toCents(p.compareAtPrice);
			return {
				id: p.id,
				name: p.title || p.name || "",
				price: cents / 100,
				oldPrice: oldCents && oldCents > 0 ? oldCents / 100 : null,
				slug: p.handle || p.slug,
				description: p.description || p.metaDescription || "",
				images: Array.isArray(p.images) ? p.images : [],
				hasVariants: !!p.hasVariants,
				variantCombinations: Array.isArray(p.variantCombinations)
					? p.variantCombinations.map(function (vc) {
							var vcCents = toCents(vc.price);
							var vcOld = toCents(vc.compareAtPrice);
							return {
								id: vc.id,
								title: vc.title,
								price: vcCents !== null ? vcCents / 100 : 0,
								compareAtPrice: vcOld && vcOld > 0 ? vcOld / 100 : null,
								available: vc.available,
								quantity: vc.quantity,
								options: vc.options || {},
							};
						})
					: [],
			};
		}

		// loadRealProducts: 1) ЖИВОЙ /api/store/products (как каталог) →
		// 2) статический per-site /data/products.json (build.service инжектит на
		// live, богатый shape с variantCombinations; ⚠️ цены в КОПЕЙКАХ → /100) →
		// 3) preview storefront-data. Первый источник с ≥1 товаром выигрывает;
		// иначе null (demo — no-op).
		async function loadRealProducts() {
			if (__cachedProducts !== undefined) return __cachedProducts;
			var sid = resolveSiteId();

			// 1. ЖИВОЙ API (спек 098). Тянет первую страницу — PDP ищет один товар.
			if (sid) {
				try {
					var url =
						apiBase + "/api/store/products?store_id=" + encodeURIComponent(sid) + "&limit=100";
					var res = await fetch(url);
					if (res.ok) {
						var json = await res.json();
						var apiItems = Array.isArray(json.products) ? json.products.map(mapApiProduct) : [];
						if (apiItems.length > 0) {
							__cachedProducts = apiItems;
							return __cachedProducts;
						}
					}
				} catch (e) { /* API недоступен → фолбэк ниже */ }
			}

			// 2. Статический per-site файл — опубликованный сайт. ⚠️ Цены в
			// products.json — в КОПЕЙКАХ (как API basePrice: 269000 = 2690₽) → /100.
			try {
				var r2 = await fetch("/data/products.json");
				if (r2.ok) {
					var data = await r2.json();
					if (Array.isArray(data) && data.length > 0) {
						var k100 = function (v) { return typeof v === "number" ? v / 100 : v; };
						__cachedProducts = data.map(function (p) {
							return Object.assign({}, p, {
								price: k100(p.price),
								compareAtPrice: k100(p.compareAtPrice),
								oldPrice: k100(p.oldPrice),
								variantCombinations: Array.isArray(p.variantCombinations)
									? p.variantCombinations.map(function (vc) { return Object.assign({}, vc, { price: k100(vc.price) }); })
									: p.variantCombinations,
							});
						});
						return __cachedProducts;
					}
				}
			} catch (e) { /* файла нет — preview-фолбэк ниже */ }

			// 3. Preview-фолбэк: built-theme БЕЗ products.json → storefront-data.
			if (sid) {
				try {
					var r3 = await fetch("/api/sites/" + encodeURIComponent(sid) + "/storefront-data");
					if (r3.ok) {
						var payload = await r3.json();
						var products = payload && payload.products;
						if (Array.isArray(products) && products.length > 0) {
							__cachedProducts = products;
							return __cachedProducts;
						}
					}
				} catch (e) { /* preview-фолбэк не удался */ }
			}

			__cachedProducts = null;
			return __cachedProducts;
		}

		function formatPrice(value) {
			if (value === null || value === undefined || value === "") return "";
			if (typeof value === "string") return value; // demo строка "5 990 ₽"
			return value.toLocaleString("ru-RU") + " ₽";
		}
		function productImageRaw(p) {
			return (Array.isArray(p.images) && typeof p.images[0] === "string" && p.images[0]) || "";
		}
		function productImage(p) {
			return productImageRaw(p) || PLACEHOLDER_IMAGE;
		}
		function escapeHtml(value) {
			return String(value === null || value === undefined ? "" : value)
				.replace(/&/g, "&amp;")
				.replace(/</g, "&lt;")
				.replace(/>/g, "&gt;")
				.replace(/"/g, "&quot;")
				.replace(/'/g, "&#39;");
		}

		// Выводит группы вариантов из combos[].options (variantGroups часто null).
		function deriveVariantGroups(combos) {
			var order = [];
			var byGroup = {};
			for (var i = 0; i < combos.length; i++) {
				var opts = combos[i].options || {};
				for (var group in opts) {
					if (!Object.prototype.hasOwnProperty.call(opts, group)) continue;
					var value = opts[group];
					if (!byGroup[group]) { byGroup[group] = []; order.push(group); }
					if (byGroup[group].indexOf(value) === -1) byGroup[group].push(value);
				}
			}
			return order.map(function (name) { return { name: name, values: byGroup[name] }; });
		}
		// Находит комбинацию, у которой ВСЕ выбранные значения групп совпали.
		function findCombination(combos, selected) {
			for (var i = 0; i < combos.length; i++) {
				var c = combos[i];
				var ok = true;
				for (var group in selected) {
					if (!Object.prototype.hasOwnProperty.call(selected, group)) continue;
					if (!c.options || c.options[group] !== selected[group]) { ok = false; break; }
				}
				if (ok) return c;
			}
			return null;
		}

		// Классы вариант-кнопок 1:1 со стилем bloom NtVariantTextRow / storefront-hydrate
		// (выбран: чёрный фон/белый текст; невыбран: прозрачный фон/чёрный border;
		// rounded-[4px]). Core-utility, не arbitrary вне CSS превью.
		var VARIANT_BTN_BASE =
			"inline-flex h-10 shrink-0 items-center justify-center rounded-[4px] px-3 py-2.5 text-[14px] font-normal leading-normal outline-none transition-opacity";
		var VARIANT_BTN_SEL = "border-0 !bg-[#000000] !text-white hover:opacity-95";
		var VARIANT_BTN_UNSEL =
			"border border-solid border-[#000000] !bg-transparent !text-[#000000] hover:opacity-90";
		function renderVariantGroupsHtml(groups, selected) {
			return groups
				.map(function (g) {
					var buttons = g.values
						.map(function (v) {
							var isSel = selected[g.name] === v;
							var cls = VARIANT_BTN_BASE + " " + (isSel ? VARIANT_BTN_SEL : VARIANT_BTN_UNSEL);
							return (
								'<button type="button" class="' + cls + '" role="radio" aria-checked="' +
								isSel + '" data-variant-value="' + escapeHtml(v) + '">' + escapeHtml(v) + "</button>"
							);
						})
						.join("");
					return (
						'<div class="flex w-full flex-col gap-2 font-manrope" data-pdp-variant-group="' +
						escapeHtml(g.name) + '">' +
						'<span class="font-manrope text-[14px] font-normal leading-none text-[#000000]">' +
						escapeHtml(g.name) + "</span>" +
						'<div class="flex flex-wrap gap-2" role="radiogroup" aria-label="' +
						escapeHtml(g.name) + '">' + buttons + "</div></div>"
					);
				})
				.join("");
		}

		// ─── Определение товара: slug из пути → ?id= → __MERFY_DEFAULT_PRODUCT_ID__ → первый ───
		function lookupRefFromUrl() {
			var m = location.pathname.match(/\/product\/([^/]+)\/?$/);
			if (m) return decodeURIComponent(m[1]); // pretty /product/<slug>
			var q = new URLSearchParams(location.search).get("id");
			return q || null;
		}

		async function hydrateProductPage() {
			var section = document.querySelector("[data-pdp-section]");
			if (!section) return;
			var notFound = section.querySelector("[data-pdp-notfound]");

			var products = await loadRealProducts();
			if (!products) return; // demo-сборка без данных — оставляем SSR-скелетон

			// Приоритет: pretty-slug / ?id= → выбранный в конструкторе товар
			// (__MERFY_DEFAULT_PRODUCT_ID__) → первый.
			var urlRef = lookupRefFromUrl();
			var defaultId =
				(typeof window !== "undefined" && window.__MERFY_DEFAULT_PRODUCT_ID__) || null;
			var lookupRef = urlRef || defaultId;
			var explicit = !!urlRef;

			var p = null;
			if (lookupRef) {
				// Матч по id ИЛИ slug ИЛИ handle.
				for (var i = 0; i < products.length; i++) {
					var it = products[i];
					if (it.id === lookupRef || it.slug === lookupRef || it.handle === lookupRef) { p = it; break; }
				}
				if (!p && !explicit) p = products[0] || null; // дефолт/первый, но не при явном неверном slug
			} else {
				p = products[0] || null;
			}

			// not-found живёт ВНУТРИ секции → прячем не всю секцию, а внутренний грид.
			var layout = section.querySelector("[data-pdp-layout]");
			if (!p) {
				if (layout) layout.hidden = true;
				if (notFound) notFound.hidden = false;
				return;
			}
			if (layout) { layout.hidden = false; layout.style.opacity = "1"; }
			if (notFound) notFound.hidden = true;

			function setText(sel, t) {
				var el = section.querySelector(sel);
				if (el) el.textContent = t;
			}

			// ── Заголовок / бренд / описание / цена ──
			document.title = p.name || "Товар";
			setText("[data-pdp-name]", p.name || "Товар");
			setText("[data-pdp-price]", formatPrice(p.price));
			setText("[data-pdp-desc]", p.description || p.metaDescription || "");

			// Бренд: реальные товары обычно без бренда в API → прячем demo-остаток,
			// показываем только если поле реально пришло.
			var brandVal = p.brand || p.vendor || "";
			var brandEl = section.querySelector("[data-pdp-brand]");
			if (brandEl) {
				brandEl.textContent = brandVal;
				brandEl.hidden = !brandVal;
			}

			var oldRaw = formatPrice(p.oldPrice || p.compareAtPrice || null);
			var oldEl = section.querySelector("[data-pdp-oldprice]");
			if (oldEl) { oldEl.textContent = oldRaw; oldEl.hidden = !oldRaw; }

			// Бейдж «Скидка»: показываем при наличии старой цены.
			var badgeEl = section.querySelector("[data-pdp-badge]");
			if (badgeEl) badgeEl.hidden = !oldRaw;

			// ── Галерея: главное фото + миниатюры из p.images ──
			var src = productImage(p);
			var mainImg = section.querySelector("[data-pdp-main]");
			if (mainImg) {
				mainImg.src = src;
				mainImg.alt = p.name || "";
				// <picture><source webp> от skeleton/demo больше не валиден — снимаем.
				var picture = mainImg.closest("picture");
				var source = picture && picture.querySelector("source");
				if (source) source.removeAttribute("srcset");
			}
			var imgs = (Array.isArray(p.images) ? p.images : []).filter(function (s) {
				return typeof s === "string" && s;
			});
			var thumbsRow = section.querySelector("[data-pdp-thumbs-row]");
			if (thumbsRow) {
				// bloom-сетка миниатюр: grid-cols-3, квадрат, bg-[#F5F5F5] (как demo-разметка).
				var thumbUrls = imgs.slice(0, 6);
				if (thumbUrls.length > 1) {
					thumbsRow.innerHTML = thumbUrls
						.map(function (u) {
							return (
								'<button type="button" class="aspect-square w-full overflow-hidden bg-[#F5F5F5] transition-opacity hover:opacity-90" data-pdp-thumb data-image="' +
								escapeHtml(u) + '" aria-label="Показать изображение"><img src="' +
								escapeHtml(u) + '" alt="' + escapeHtml(p.name) +
								'" class="h-full w-full object-contain" loading="eager" /></button>'
							);
						})
						.join("");
					thumbsRow.hidden = false;
				} else {
					// Реальный товар с одним фото — прячем demo-миниатюры.
					thumbsRow.hidden = true;
					thumbsRow.innerHTML = "";
				}
			}

			// ── Атрибуты корзины: глобальный делегат [data-add-to-cart] (bloom
			//    cart.ts initCartUI) читает их при клике. Слаг кладём на секцию. ──
			section.setAttribute("data-product-id", p.id);
			section.setAttribute("data-product-slug", p.slug || p.id);
			var priceStr = formatPrice(p.price);
			var ctas = ["[data-add-to-cart]", "[data-action='buy-now']"];
			for (var k = 0; k < ctas.length; k++) {
				var btn = section.querySelector(ctas[k]);
				if (!btn) continue;
				btn.setAttribute("data-product-id", p.id);
				btn.setAttribute("data-name", p.name || "");
				btn.setAttribute("data-price", priceStr);
				btn.setAttribute("data-image", src);
				// volume — bloom-only поле «added»-модалки; у API-товара его нет → пусто.
				btn.setAttribute("data-volume", "");
			}
			var addBtn0 = section.querySelector("[data-add-to-cart]");
			if (addBtn0) {
				addBtn0.setAttribute("data-old-price", oldRaw);
				addBtn0.setAttribute("data-variant-color", "");
			}

			// ── Варианты УСЛОВНО: селектор только если есть variantCombinations ──
			var variantsEl = section.querySelector("[data-pdp-variants]");
			var combos = Array.isArray(p.variantCombinations) ? p.variantCombinations : [];
			var COLOR_KEYS = ["Цвет", "Color"];
			var SIZE_KEYS = ["Размер", "Size"];
			function pick(opts, keys) {
				for (var i = 0; i < keys.length; i++) {
					if (opts && opts[keys[i]] != null) return opts[keys[i]];
				}
				return "";
			}

			if (variantsEl && combos.length > 0) {
				var groups = deriveVariantGroups(combos);
				var firstAvailable = null;
				for (var fa = 0; fa < combos.length; fa++) {
					if (combos[fa].available !== false) { firstAvailable = combos[fa]; break; }
				}
				if (!firstAvailable) firstAvailable = combos[0];
				var selected = Object.assign({}, firstAvailable.options || {});

				function applyCombo() {
					var combo = findCombination(combos, selected);
					var priceVal = combo && combo.price ? combo.price : p.price;
					setText("[data-pdp-price]", formatPrice(priceVal));
					// Старая цена комбинации (если есть).
					var comboOld = formatPrice((combo && combo.compareAtPrice) || p.oldPrice || p.compareAtPrice || null);
					var oEl = section.querySelector("[data-pdp-oldprice]");
					if (oEl) { oEl.textContent = comboOld; oEl.hidden = !comboOld; }
					var available = combo
						? combo.available !== false && (combo.quantity == null || combo.quantity > 0)
						: false;
					for (var c = 0; c < ctas.length; c++) {
						var b = section.querySelector(ctas[c]);
						if (!b) continue;
						b.setAttribute("data-price", formatPrice(priceVal));
						b.setAttribute("data-old-price", comboOld);
						b.setAttribute("data-variant-combination-id", (combo && combo.id) || "");
						b.setAttribute("data-variant-color", pick(combo && combo.options, COLOR_KEYS));
						b.setAttribute("data-variant-size", pick(combo && combo.options, SIZE_KEYS));
					}
					var addEl = section.querySelector("[data-add-to-cart]");
					if (addEl) {
						addEl.disabled = !available;
						addEl.classList.toggle("opacity-50", !available);
						addEl.classList.toggle("pointer-events-none", !available);
						addEl.textContent = available ? "Добавить в корзину" : "Нет в наличии";
					}
				}

				variantsEl.hidden = false;
				variantsEl.innerHTML = renderVariantGroupsHtml(groups, selected);
				applyCombo();

				variantsEl.onclick = function (e) {
					var btn = e.target.closest("[data-variant-value]");
					if (!btn) return;
					var groupEl = btn.closest("[data-pdp-variant-group]");
					var group = groupEl && groupEl.getAttribute("data-pdp-variant-group");
					var value = btn.getAttribute("data-variant-value");
					if (!group || value == null) return;
					selected[group] = value;
					variantsEl.innerHTML = renderVariantGroupsHtml(groups, selected);
					applyCombo();
				};
			} else if (variantsEl) {
				// Невариативный реальный товар — demo color-row (NtVariantTextRow) убираем.
				variantsEl.hidden = true;
				variantsEl.innerHTML = "";
			}
		}

		// ─── UI: количество (±), миниатюры, поделиться, купить сейчас ───
		function syncQtyToCtas(qty) {
			var section = document.querySelector("[data-pdp-section]");
			if (!section) return;
			var ctas = section.querySelectorAll("[data-add-to-cart], [data-action='buy-now']");
			for (var i = 0; i < ctas.length; i++) ctas[i].setAttribute("data-quantity", String(qty));
		}

		function initBloomProductUi() {
			var section = document.querySelector("[data-pdp-section]");
			if (!section) return;
			// Идемпотентность при View Transitions (astro:page-load): не вешаем
			// обработчики повторно на ту же секцию.
			if (section.getAttribute("data-pdp-ui-bound") === "1") return;
			section.setAttribute("data-pdp-ui-bound", "1");

			// Количество (±). Counter статичен → прямые слушатели ок.
			var qtyInput = section.querySelector("[data-pdp-qty-value]");
			var dec = section.querySelector("[data-action='qty-dec']");
			var inc = section.querySelector("[data-action='qty-inc']");
			if (dec && qtyInput) {
				dec.addEventListener("click", function () {
					var next = Math.max(1, Number(qtyInput.value || 1) - 1);
					qtyInput.value = String(next);
					syncQtyToCtas(next);
				});
			}
			if (inc && qtyInput) {
				inc.addEventListener("click", function () {
					var next = Number(qtyInput.value || 1) + 1;
					qtyInput.value = String(next);
					syncQtyToCtas(next);
				});
			}
			if (qtyInput) {
				qtyInput.addEventListener("input", function () {
					var value = Math.max(1, Number(qtyInput.value || 1));
					qtyInput.value = String(value);
					syncQtyToCtas(value);
				});
			}

			// Миниатюры: делегат на секцию (innerHTML миниатюр перерисовывается
			// гидрацией) — свапаем главное фото + синкаем data-image на CTA.
			section.addEventListener("click", function (ev) {
				var thumb = ev.target.closest("[data-pdp-thumb]");
				if (!thumb || !section.contains(thumb)) return;
				var img = thumb.getAttribute("data-image");
				var mainEl = section.querySelector("[data-pdp-main]");
				if (mainEl && img) {
					mainEl.src = img;
					var pic = mainEl.closest("picture");
					var s = pic && pic.querySelector("source");
					if (s) s.removeAttribute("srcset");
				}
				var add = section.querySelector("[data-add-to-cart]");
				var buy = section.querySelector("[data-action='buy-now']");
				if (add) add.setAttribute("data-image", img || "");
				if (buy) buy.setAttribute("data-image", img || "");
			});

			// Поделиться.
			var shareBtn = section.querySelector("[data-action='share']");
			if (shareBtn) {
				shareBtn.addEventListener("click", async function () {
					try {
						if (navigator.share) {
							await navigator.share({ title: document.title, url: location.href });
						} else if (navigator.clipboard) {
							await navigator.clipboard.writeText(location.href);
							var span = shareBtn.querySelector("span");
							if (span) {
								var orig = span.textContent;
								span.textContent = "Ссылка скопирована!";
								setTimeout(function () { span.textContent = orig; }, 1500);
							}
						}
					} catch (e) { /* пользователь отменил */ }
				});
			}

			// «Купить сейчас»: переиспользуем ГЛОБАЛЬНЫЙ делегат корзины bloom —
			// диспатчим клик по [data-add-to-cart] (кладёт линию в локальную корзину
			// bloom), затем идём на /cart (мост NtCart → серверный cartStore →
			// /checkout). Не зовём cart-API напрямую (его на PDP нет).
			var buyBtn = section.querySelector("[data-action='buy-now']");
			if (buyBtn) {
				buyBtn.addEventListener("click", function () {
					if (buyBtn.disabled) return;
					var add = section.querySelector("[data-add-to-cart]");
					if (add && !add.disabled) {
						add.dispatchEvent(new MouseEvent("click", { bubbles: true }));
					}
					window.location.href = "/cart";
				});
			}
		}

		function bootProduct() {
			hydrateProductPage();
			initBloomProductUi();
		}

		bootProduct();
		document.addEventListener("astro:page-load", bootProduct);
	})();
</script>
