---
import type { CatalogProduct } from "../../data/products";
import BloomPicture from "../img/BloomPicture.astro";

interface Props {
	product: CatalogProduct;
	priority?: boolean;
	// aspect-ratio (W/H) карточного медиа — «Вид изображения» секции Popular
	// (square→1/1, portrait→430/500, wide→16/9). Дефолт 1/1 = прежний хардкод
	// aspect-square (каталог/категория/wishlist зовут без пропа → байт-в-байт).
	aspectRatio?: string;
}

const { product, priority = false, aspectRatio = "1/1" } = Astro.props;
const href = `/products/${product.id}`;

// Outline-сердце избранного — тот же heart-path, что wishlist.ts heartSvg()/
// wishlist.astro overlay. Outline по умолчанию; глобальный делегат initWishlistUI
// перекрашивает в filled на load (aria-pressed). set:html — статичная разметка.
const wishlistOutlineSvg =
	'<svg viewBox="0 0 17.4 15.4" width="100%" height="100%" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="display:block">' +
	'<path d="M7.428 14.2615C5.172 12.5239 0.7 8.55212 0.7 4.97729C0.7 2.61547 2.384 0.7 4.7 0.7C5.9 0.7 7.1 1.11175 8.7 2.75876C10.3 1.11175 11.5 0.7 12.7 0.7C15.016 0.7 16.7 2.61547 16.7 4.97729C16.7 8.5513 12.228 12.5239 9.972 14.2615C9.212 14.8462 8.188 14.8462 7.428 14.2615Z" ' +
	'fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>' +
	"</svg>";

// Соответствие имени цвета → русская метка и hex (верстальщик: src/data/colors.ts).
// Порт не несёт отдельного data/colors.ts, поэтому карта локальна. Используется
// интерактивным radiogroup свотчей (#16) и декоративным overlay-кластером.
const COLORS: Record<string, { label: string; hex: string }> = {
	pink: { label: "Розовый", hex: "#e38e9f" },
	"light-pink": { label: "Светло-розовый", hex: "#e8b1b7" },
	coral: { label: "Коралловый", hex: "#ea7c7f" },
	berry: { label: "Ягодный", hex: "#d76b69" },
	nude: { label: "Нюд", hex: "#e9c9b5" },
	beige: { label: "Бежевый", hex: "#ffddca" },
	ivory: { label: "Слоновая кость", hex: "#fff1de" },
	white: { label: "Белый", hex: "#ffffff" },
	black: { label: "Чёрный", hex: "#111111" },
	brown: { label: "Коричневый", hex: "#8b5e3c" },
	olive: { label: "Оливковый", hex: "#6b705c" },
	gray: { label: "Серый", hex: "#cccccc" },
};
const colorHex = (name: string): string => COLORS[name]?.hex ?? "#e38e9f";

// Верстальщик показывает ИНТЕРАКТИВНЫЙ radiogroup свотчей, когда у товара >1
// цвета (и нет размеров). Иначе — декоративный overlay-кластер (platform-доп).
const hasSizePills = Boolean(product.sizes && product.sizes.length > 1);
const hasColorSwatches = !hasSizePills && product.colors.length > 1;
const defaultColor = product.colors[0] ?? "";
---

<article
	class="group flex flex-col gap-4"
	data-nt="bloom-product-card"
	aria-label={product.name}
>
	<div class="relative w-full">
		<a
			href={href}
			class="relative block w-full overflow-hidden rounded-[12px] bg-[#F5F5F5]"
			style={`aspect-ratio:${aspectRatio}`}
			aria-label={product.name}
		>
			<BloomPicture
				src={product.image}
				alt={product.name}
				loading="eager"
				fetchpriority={priority ? "high" : undefined}
				class="h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-105"
			/>
			{product.discount && (
				<span
					class="absolute left-2 top-2 inline-flex h-6 items-center rounded-[16px] bg-[#e38e9f] px-1.5 font-inter text-[12px] font-normal leading-none text-white"
				>
					Скидка
				</span>
			)}
			{!hasColorSwatches && product.colors.length > 0 && (
				<div
					class="absolute bottom-2 right-2 inline-flex items-center gap-1 rounded-full bg-white/90 p-1"
					aria-hidden="true"
				>
					{product.colors.map((color) => (
						<span
							class="size-2 shrink-0 rounded-full border border-[#F5F5F5]"
							style={`background-color: ${colorHex(color)}`}
						/>
					))}
				</div>
			)}
		</a>
		<button
			type="button"
			data-wishlist-toggle
			data-product-id={product.id}
			aria-pressed="false"
			aria-label="В избранное"
			class="absolute right-2 top-2 z-20 flex size-9 items-center justify-center rounded-full bg-white/90 text-[#000000] shadow-[0_2px_8px_rgba(0,0,0,0.10)] backdrop-blur-sm transition-opacity hover:opacity-80"
		>
			<span data-wishlist-icon class="block size-[18px]" set:html={wishlistOutlineSvg} />
		</button>
	</div>
	<div class="flex flex-col gap-2">
		<a
			href={href}
			class="bloom-product-name font-inter text-[16px] font-light leading-none text-[#000000] transition-opacity hover:opacity-70"
		>
			{product.name}
		</a>
		<div class="flex flex-wrap items-baseline gap-2">
			<span class="bloom-product-price font-inter text-[16px] font-light leading-none text-[#000000]">
				{product.price}
			</span>
			{product.oldPrice && (
				<span class="bloom-product-oldprice font-inter text-[16px] font-light leading-none text-[#999999] line-through">
					{product.oldPrice}
				</span>
			)}
		</div>
		{hasSizePills && (
			<div class="flex flex-wrap items-center gap-[3px]" aria-hidden="true">
				{product.sizes!.map((size, index) => (
					<span
						class:list={[
							"flex h-6 items-center justify-center rounded-full px-1.5 font-inter text-[12px] font-light leading-normal",
							index === 0 ? "bg-[#e38e9f] text-white" : "border border-[#e38e9f] text-[#e38e9f]",
						]}
					>
						{size}
					</span>
				))}
			</div>
		)}
		{hasColorSwatches && (
			<div class="flex flex-wrap items-center gap-1" role="radiogroup" aria-label="Цвет">
				{product.colors.map((color, index) => (
					<button
						type="button"
						role="radio"
						aria-checked={index === 0 ? "true" : "false"}
						aria-label={COLORS[color]?.label ?? color}
						data-card-color={color}
						class="bloom-card-swatch"
					>
						<span
							class="bloom-card-swatch-dot"
							style={`background-color: ${colorHex(color)};${color === "white" ? "box-shadow:inset 0 0 0 1px #d9d9d9;" : ""}`}
						/>
					</button>
				))}
			</div>
		)}
		{product.inStock ? (
			<button
				type="button"
				data-add-to-cart
				data-cart-toggle
				data-in-cart="false"
				data-label-default="В корзину"
				data-label-in-cart="В корзине"
				aria-pressed="false"
				data-product-id={product.id}
				data-name={product.name}
				data-price={product.price}
				data-old-price={product.oldPrice ?? ""}
				data-image={product.image}
				data-volume={product.volume ?? ""}
				data-variant-color={defaultColor}
				data-variant-size={product.volume ?? ""}
				class="flex h-12 w-full items-center justify-center rounded-full bg-[#e38e9f] px-4 font-inter text-[16px] font-light leading-none text-white transition-opacity hover:opacity-90 active:scale-95"
			>
				В корзину
			</button>
		) : (
			<button
				type="button"
				disabled
				class="flex h-12 w-full cursor-not-allowed items-center justify-center rounded-full border border-[#e38e9f] bg-transparent px-4 font-inter text-[16px] font-light leading-none text-[#e38e9f]"
			>
				Нет в наличии
			</button>
		)}
	</div>
</article>

<style>
	@media (max-width: 639.98px) {
		.bloom-product-name,
		.bloom-product-price,
		.bloom-product-oldprice {
			font-size: 12px;
		}
	}

	/* Товар уже в корзине — «Inactive» из дизайн-системы кнопок (Figma 905:13034):
	   приглушённый фон/текст. Селектор с атрибутами перебивает Tailwind bg/text. */
	button[data-add-to-cart][data-in-cart="true"] {
		background-color: #fdf4f6;
		color: #ffd4e5;
	}

	/* Свотчи цвета: состояние управляется aria-checked (переключает lib/cart.ts).
	   Выбранный — кольцо #e38e9f с 16px точкой внутри, остальные — 20px круг. */
	.bloom-card-swatch {
		display: flex;
		width: 20px;
		height: 20px;
		align-items: center;
		justify-content: center;
		border-radius: 9999px;
		border: 1px solid transparent;
	}
	.bloom-card-swatch[aria-checked="true"] {
		border-color: #e38e9f;
	}
	.bloom-card-swatch-dot {
		width: 20px;
		height: 20px;
		flex-shrink: 0;
		border-radius: 9999px;
		transition:
			width 0.15s ease,
			height 0.15s ease;
	}
	.bloom-card-swatch[aria-checked="true"] .bloom-card-swatch-dot {
		width: 16px;
		height: 16px;
	}
</style>
