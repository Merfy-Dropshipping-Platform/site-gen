---
// Фаза B (flux): новая канон-секция MultiRows в манере flux (см.
// themes/flux/MANNER.md). Секции нет у верстальщика — ряды «картинка + текст»
// в чередующейся раскладке по паттерну ImageWithText: сетка секций §2
// (px-4 md:px-20 2xl:px-80, вертикаль 64/96, контейнер 1320), зазор грида
// галереи (Gallery.astro:20: gap-6 md:gap-8), медиа §4 (rounded-8 / surface
// #F5F5F5 / hover-zoom 1.03 duration-500 ease-out, Gallery.astro:67,74),
// типографика §1, чёрная CTA §3. Скролл-анимаций НЕТ — манера flux статична
// (§6; у bloom ряды с data-animate, у flux НЕ добавлять). Схема полей =
// packages/theme-base/blocks/MultiRows/MultiRows.puckConfig.ts;
// процесс-эталон — bloom MultiRows.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон top-heading: string | { text, alignment, size } (+ legacy _headingLegacy);
// отсутствие/пусто → шапки нет (canon-defaults heading не пишут). Роль =
// внутрисекционный h2 (Comfortaa uppercase leading-[1.115], МАННЕРА §1).
// Лестница §9 «Внутренний h2 24/28»: large/отсутствие = литерал 24/md:28,
// medium 20/24, small 17/20.
const heading =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p._headingLegacy ?? "";
const headingSize = p.headingSize ?? p.heading?.size;
const headingSizeCls =
	headingSize === "small"
		? "text-[17px] md:text-[20px]"
		: headingSize === "medium"
			? "text-[20px] md:text-[24px]"
			: "text-[24px] md:text-[28px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center" ? " text-center" : headingAlignment === "right" ? " text-right" : "";
const headingCls = `font-comfortaa ${headingSizeCls} font-normal uppercase leading-[1.115] text-[rgb(var(--color-heading,0_0_0))]${headingAlignCls}`;

// Канон rows[] 1-10 (item: heading|title, text|description, imageUrl|image,
// imagePosition, button {text, href|link}, size per-item, headingSize/textSize).
// Отсутствие массива = 2 ряда-болванки в тоне темы (МАННЕРА §11: технологично,
// без уменьшительности), чередование лево/право.
const CANON_ROWS = [
	{
		id: "row-1",
		heading: "Новое поколение звука",
		text: "Расскажите о флагмане: автономность, шумоподавление и звук без компромиссов.",
		imageUrl: "",
		imagePosition: "left",
		button: { text: "Подробнее", href: "/about" },
	},
	{
		id: "row-2",
		heading: "Мощность в каждом пикселе",
		text: "Опишите технологию: дисплей, камера и процессор, которые работают без паузы.",
		imageUrl: "",
		imagePosition: "right",
		button: { text: "Узнать больше", href: "/about" },
	},
];
const rawRows = Array.isArray(p.rows) && p.rows.length ? p.rows : CANON_ROWS;

// Канон rowsPosition: left | right — все картинки с одной стороны; alternate /
// отсутствие — per-item imagePosition, иначе чередование по индексу.
const rowsPosition =
	p.rowsPosition === "left" || p.rowsPosition === "right" ? p.rowsPosition : undefined;

// Канон size (s/m/l) — аспект медиа ряда (топ-уровень, per-item приоритетнее).
// Лестница манеры §4: medium/отсутствие = aspect-square (левая плитка галереи,
// Gallery.astro:23), small = широкое 16/9, large = карточная вертикаль 430/500
// (FluxCollectionCard.astro / Puk.astro:16).
const aspectFor = (s: string | undefined) =>
	s === "small" ? "aspect-[16/9]" : s === "large" ? "aspect-[430/500]" : "aspect-square";

// Канон-плейсхолдеры = реальные ассеты темы (принцип T15 rose; плитки галереи
// верстальщика, Gallery.astro:69,44) — «добавил секцию → сразу красиво».
// PLACEHOLDER_IMAGE гидрации (/placeholders/sweater-blue.png) в public НЕТ —
// берём родные /images/4x/* (МАННЕРА §10).
const ROW_FALLBACKS = ["/images/4x/Товар_5__2_.png", "/images/4x/Товар_5__3_.png"];

// Шкалы per-item размеров: заголовок ряда = роль внутреннего h2 (лестница §9,
// large/отсутствие = литерал 24/28); текст = body-роль Manrope light
// leading-[1.6] (legal/[slug].astro:25): medium/отсутствие = литерал 16,
// small 14, large 19.
const rowHeadingSizeCls = (s: string | undefined) =>
	s === "small"
		? "text-[17px] md:text-[20px]"
		: s === "medium"
			? "text-[20px] md:text-[24px]"
			: "text-[24px] md:text-[28px]";
const rowTextSizeCls = (s: string | undefined) =>
	s === "small" ? "text-[14px]" : s === "large" ? "text-[19px]" : "text-[16px]";

const rows = rawRows.slice(0, 10).map((r: any, i: number) => {
	const btnText =
		typeof r.button?.text === "string" && r.button.text.trim() ? r.button.text : undefined;
	return {
		heading:
			(typeof r.heading === "string" && r.heading) || (typeof r.title === "string" && r.title) || "",
		text:
			(typeof r.text === "string" && r.text) ||
			(typeof r.description === "string" && r.description) ||
			"",
		image:
			(typeof r.imageUrl === "string" && r.imageUrl.trim()) ||
			(typeof r.image === "string" && r.image.trim()) ||
			ROW_FALLBACKS[i % ROW_FALLBACKS.length],
		right:
			rowsPosition === "right" ||
			(rowsPosition !== "left" &&
				(r.imagePosition === "right" || (r.imagePosition !== "left" && i % 2 === 1))),
		aspectCls: aspectFor(r.size ?? p.size),
		headingCls: rowHeadingSizeCls(r.headingSize),
		textCls: rowTextSizeCls(r.textSize),
		btnText,
		btnHref:
			(typeof r.button?.href === "string" && r.button.href ? r.button.href : undefined) ??
			r.button?.link?.href ??
			(typeof r.button?.link === "string" && r.button.link ? r.button.link : undefined) ??
			"/catalog",
	};
});

// Канон width (s/m/l/full): large/отсутствие = 1320 (контейнер манеры §2),
// medium 1080, small 780, full — без лимита.
const widthCls =
	p.width === "small"
		? "max-w-[780px]"
		: p.width === "medium"
			? "max-w-[1080px]"
			: p.width === "full"
				? "max-w-none"
				: "max-w-[1320px]";

// Канон alignment — выравнивание текстовой колонки рядов (отсутствие = left,
// флаговая вёрстка flux).
const alignCls =
	p.alignment === "center"
		? "items-center text-center"
		: p.alignment === "right"
			? "items-end text-right"
			: "items-start text-left";

// Канон buttonStyle (primary/black/white): primary/black/отсутствие = чёрная
// CTA манеры §3 дословно (contacts.astro:76: h-12 rounded-6 px-6 Manrope 16,
// hover:opacity-95; кнопка-2 в схемах flux, МАННЕРА §7). 'white'-вариант bloom
// (белый pill на цветном полотне) flux не нужен — цветных полотен нет; «Белая»
// рендерится outlined: бордер/текст цвета заливки на прозрачном ≡ белая кнопка
// с чёрным бордером PDP:168 (ховер 0.90). active:scale не используется (§3).
const btnBase =
	"inline-flex h-12 items-center justify-center rounded-[var(--radius-button,6px)] px-6 font-manrope text-[16px] font-normal leading-normal transition-opacity";
const btnCls =
	p.buttonStyle === "white"
		? `${btnBase} border border-solid border-[rgb(var(--color-button-2-bg,0_0_0))] bg-transparent text-[rgb(var(--color-button-2-bg,0_0_0))] hover:opacity-90`
		: `${btnBase} bg-[rgb(var(--color-button-2-bg,0_0_0))] text-[rgb(var(--color-button-2-text,255_255_255))] hover:opacity-95`;

// Канон containerColorScheme (hidden) — класс схемы на контейнере рядов.
const containerSchemeCls =
	typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

// colorScheme навешивает обёрткой composeV2Page; фон секции — bg-токен с белым
// фоллбеком (у flux нет цветных полотен, МАННЕРА §7).
const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 py-16 md:px-20 md:py-24 2xl:px-80"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class={`mx-auto flex w-full ${widthCls} flex-col gap-8 md:gap-12${containerSchemeCls}`}>
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}
		<ul class="flex w-full flex-col gap-8 md:gap-12" role="list">
			{
				rows.map((r, i) => (
					<li
						class="grid w-full grid-cols-1 gap-6 md:gap-8 lg:grid-cols-2"
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="rows"
					>
						<div
							class={`group relative w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))] ${r.aspectCls}${r.right ? " lg:order-2" : ""}`}
							aria-hidden={r.image ? undefined : "true"}
						>
							{r.image && (
								<img
									src={r.image}
									alt={r.heading || "Ряд"}
									loading="lazy"
									class="absolute inset-0 size-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
								/>
							)}
						</div>
						<div class={`flex w-full flex-col gap-6 ${alignCls}${r.right ? " lg:order-1" : ""}`}>
							{r.heading && (
								<h3
									class={`font-comfortaa ${r.headingCls} font-normal uppercase leading-[1.115] text-[rgb(var(--color-heading,0_0_0))]`}
								>
									{r.heading}
								</h3>
							)}
							{r.text && (
								<div
									class={`font-manrope ${r.textCls} font-light leading-[1.6] text-[rgb(var(--color-text,0_0_0))]`}
									set:html={r.text}
								/>
							)}
							{r.btnText && (
								<div class="mt-2">
									<a href={r.btnHref} class={btnCls}>
										{r.btnText}
									</a>
								</div>
							)}
						</div>
					</li>
				))
			}
		</ul>
	</div>
</section>
