---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import VanilaLogo from "../icons/VanilaLogo.astro";
import { SITE_TITLE } from "../consts";
import { getProductById } from "../data/products";

interface NavLink {
	label: string;
	href: string;
	match?: (url: URL) => boolean;
}

function pathnameBase(url: URL): string {
	const p = url.pathname.replace(/\/+$/, "");
	return p === "" ? "/" : p;
}

/** Активный раздел каталога на карточке товара */
function catalogNavFromProduct(url: URL): "textile" | "decor" | null {
	const p = pathnameBase(url);
	const m = p.match(/^\/products\/([^/]+)$/);
	if (!m?.[1]) return null;
	const product = getProductById(m[1]);
	return product?.collection === "Декор" ? "decor" : "textile";
}

const nav: NavLink[] = [
	{
		label: "Текстиль",
		href: "/catalog/textile",
		match: (url) =>
			catalogNavFromProduct(url) === "textile" ||
			pathnameBase(url) === "/catalog" ||
			pathnameBase(url) === "/catalog/textile",
	},
	{
		label: "Декор",
		href: "/catalog/decor",
		match: (url) => catalogNavFromProduct(url) === "decor" || pathnameBase(url) === "/catalog/decor",
	},
	{ label: "История", href: "/about", match: (url) => pathnameBase(url).startsWith("/about") },
];

const catalogSearchAction = pathnameBase(Astro.url) === "/catalog/decor" ? "/catalog/decor" : "/catalog/textile";

const isActive = (link: NavLink) => (link.match ? link.match(Astro.url) : Astro.url.pathname === link.href);
---

<div class="flex w-full flex-col" data-vanilla-header>
	<a
		href="/catalog/textile"
		data-vanilla-announcement
		class="m-0 flex h-11 w-full shrink-0 items-center justify-center border-0 bg-[var(--vanilla-announcement-bg)] px-4 text-center font-vanilla-arsenal text-[14px] font-normal uppercase leading-none tracking-normal text-white md:h-12 md:text-base"
	>
		<span class="min-w-0 shrink">Бесплатная доставка на весь ассортимент</span>
	</a>

	<header class="relative m-0 shrink-0 border-0 w-full overflow-visible bg-[var(--vanilla-header-bg)] pb-[3px] -mb-[3px] text-white" data-nt="vanilla-header">
		<div class="relative z-[60] flex h-14 items-center justify-between px-4 md:hidden">
			<button
				type="button"
				id="vanilla-burger-btn"
				class="flex size-9 items-center justify-center transition-opacity hover:opacity-70"
				aria-label="Меню"
				aria-expanded="false"
				aria-controls="vanilla-burger"
			>
				<span class="burger-icon" data-icon="open">
					<NtIcon name="menu-burger" sizeClass="size-6" class="brightness-0 invert" />
				</span>
				<span class="burger-icon hidden" data-icon="close">
					<NtIcon name="menu-close" sizeClass="size-6" class="brightness-0 invert" />
				</span>
			</button>
			<a href="/" class="flex shrink-0 items-center text-white" aria-label={SITE_TITLE}>
				<VanilaLogo class="h-6 w-auto max-w-[76px]" />
			</a>
			<div class="flex items-center gap-3">
				<button
					type="button"
					data-action="toggle-search"
					class="flex size-6 items-center justify-center"
					aria-label="Поиск"
					aria-expanded="false"
					aria-controls="vanilla-search-panel"
				>
					<NtIcon name="search-sm" sizeClass="size-6" class="brightness-0 invert" />
				</button>
				<a
					href="/cart"
					class="relative flex size-6 items-center justify-center"
					aria-label="Корзина"
				>
					<NtIcon name="cart-sm" sizeClass="size-4" class="brightness-0 invert" />
					<span
						data-cart-count
						data-empty="true"
						class="absolute -right-2 -top-2 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-white px-1 font-manrope text-[10px] font-normal leading-none text-[var(--vanilla-dark)] data-[empty=true]:hidden"
					>0</span>
				</a>
				<button
					type="button"
					data-login-open
					class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
					aria-label="Аккаунт"
					aria-haspopup="dialog"
				>
					<NtIcon name="user-sm" sizeClass="size-4" class="brightness-0 invert" />
				</button>
			</div>
		</div>

		<div
			class="vanilla-pad relative mx-auto hidden h-20 w-full max-w-[1560px] items-center justify-between md:flex min-[1920px]:max-w-[1920px] min-[1920px]:px-[300px]"
		>
			<a
				href="/"
				class="absolute left-1/2 top-1/2 flex -translate-x-1/2 -translate-y-1/2 items-center text-white"
				aria-label={SITE_TITLE}
			>
				<VanilaLogo class="h-7 w-[89px]" />
			</a>

			<nav class="flex items-center gap-[40px]" aria-label="Основная навигация">
				{nav.map((link) => {
					const active = isActive(link);
					return (
						<a
							href={link.href}
							aria-current={active ? "page" : undefined}
							class:list={[
								"relative pb-1 font-vanilla-arsenal text-base font-normal leading-none tracking-normal text-white transition-all duration-200 hover:opacity-70",
								active &&
									"after:pointer-events-none after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-white after:content-['']",
							]}
						>
							{link.label}
						</a>
					);
				})}
			</nav>

			<div class="flex items-center gap-5">
				<button
					type="button"
					data-action="toggle-search"
					class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
					aria-label="Поиск"
					aria-expanded="false"
					aria-controls="vanilla-search-panel"
				>
					<NtIcon name="search-lg" sizeClass="size-5" class="brightness-0 invert" />
				</button>
				<a
					href="/cart"
					class="relative flex size-6 items-center justify-center transition-opacity hover:opacity-80"
					aria-label="Корзина"
				>
					<NtIcon name="cart" sizeClass="size-5" class="brightness-0 invert" />
					<span
						data-cart-count
						data-empty="true"
						class="absolute -right-1 -top-1 inline-flex h-5 min-w-[20px] items-center justify-center rounded-full bg-white px-1.5 font-manrope text-[10px] font-bold leading-none text-[var(--vanilla-dark)] data-[empty=true]:hidden"
					>0</span>
				</a>
				<button
					type="button"
					data-login-open
					class="flex size-6 items-center justify-center transition-opacity hover:opacity-80"
					aria-label="Аккаунт"
					aria-haspopup="dialog"
				>
					<NtIcon name="user" sizeClass="size-5" class="brightness-0 invert" />
				</button>
			</div>
		</div>

		<!-- Поиск: как в rose-theme — выезжает вниз по клику (1320×48), кнопка в цвете Vanilla -->
			<div
			id="vanilla-search-panel"
			data-search-panel
			class="pointer-events-none absolute left-0 right-0 top-full z-40 w-full overflow-hidden bg-transparent transition-[max-height] duration-300 ease-in-out"
			style="max-height: 0;"
			aria-hidden="true"
		>
			<div class="vanilla-pad py-2 lg:py-2">
				<form
					role="search"
					action={catalogSearchAction}
					method="get"
					class="pointer-events-auto mx-auto flex h-12 w-full max-w-[1320px] items-center gap-2 rounded-[4px] border border-[#E5E5E5] bg-white pl-3 pr-1 shadow-[0_8px_24px_rgba(0,0,0,0.08)]"
				>
					<input
						id="vanilla-site-search-input"
						type="search"
						name="q"
						placeholder="Поиск..."
						aria-label="Поиск"
						class="min-h-0 min-w-0 flex-1 bg-transparent py-1 font-manrope text-[16px] font-light leading-normal text-[#000000] placeholder:text-[#999999] outline-none"
					/>
					<button
						type="submit"
						class="flex h-10 shrink-0 items-center justify-center rounded-[4px] border-0 bg-[var(--vanilla-header-bg)] px-3 py-2.5 font-manrope text-[14px] font-normal leading-none text-white transition-opacity hover:opacity-90"
					>
						Найти
					</button>
				</form>
			</div>
		</div>
	</header>

	<!-- Мобильный бургер -->
	<div
		id="vanilla-burger"
		class="fixed inset-x-0 bottom-0 z-[55] hidden w-full overflow-y-auto bg-[var(--vanilla-surface)] px-4 pb-8 pt-4 md:hidden"
		role="dialog"
		aria-modal="true"
		aria-label="Меню"
	>
		<div class="flex items-center gap-2">
			<form
				class="flex h-10 min-h-10 flex-1 items-center justify-between rounded-[4px] border border-[var(--vanilla-line)] bg-white pl-3 pr-2"
				role="search"
				action={catalogSearchAction}
				method="get"
			>
				<input
					type="search"
					name="q"
					placeholder="Поиск"
					class="min-w-0 flex-1 bg-transparent font-manrope text-[12px] font-normal leading-normal text-[var(--vanilla-dark)] placeholder:text-[var(--vanilla-muted)] outline-none"
				/>
				<button type="submit" class="flex size-10 shrink-0 items-center justify-center" aria-label="Найти">
					<NtIcon name="search-sm" sizeClass="size-6" />
				</button>
			</form>
			<button
				type="button"
				data-login-open
				class="flex size-10 shrink-0 items-center justify-center bg-[var(--vanilla-green)] transition-opacity hover:opacity-90"
				aria-label="Профиль"
				aria-haspopup="dialog"
			>
				<NtIcon name="user" sizeClass="size-6" class="brightness-0 invert" />
			</button>
		</div>

		<nav class="mt-10 flex flex-col gap-5" aria-label="Основное меню">
			{nav.map((link) => {
				const active = isActive(link);
				return (
					<div class="flex flex-col gap-1">
						<a
							href={link.href}
							class:list={[
								"text-[14px] font-normal leading-normal transition-colors",
								active ? "text-[var(--vanilla-green)]" : "text-[var(--vanilla-muted)] hover:text-[var(--vanilla-green)]",
							]}
						>
							{link.label}
						</a>
						{active && <div class="h-px w-[54px] bg-[var(--vanilla-header-bg)]" aria-hidden="true"></div>}
					</div>
				);
			})}
			<a href="/cart" class="text-[14px] font-normal leading-normal text-[var(--vanilla-muted)]">Корзина</a>
			<a href="/auth/sign-up" class="text-[14px] font-normal leading-normal text-[var(--vanilla-muted)]">Регистрация</a>
		</nav>
	</div>
</div>

<script>
	const headerOffsetBelowPromo = () => {
		const promo = document.querySelector<HTMLElement>("[data-vanilla-announcement]");
		const headerEl = document.querySelector<HTMLElement>('[data-nt="vanilla-header"]');
		const p = promo?.offsetHeight ?? 48;
		const h = headerEl?.offsetHeight ?? 80;
		return p + h;
	};

	const positionBurger = () => {
		const burger = document.getElementById("vanilla-burger");
		if (!burger) return;
		burger.style.top = `${headerOffsetBelowPromo()}px`;
	};

	const setSearchOpen = (open: boolean) => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel) return;
		panel.setAttribute("aria-hidden", String(!open));
		if (open) {
			panel.style.maxHeight = `${panel.scrollHeight}px`;
			queueMicrotask(() => {
				panel.querySelector<HTMLInputElement>("input[type='search']")?.focus();
			});
		} else {
			panel.style.maxHeight = "0px";
		}
		document.querySelectorAll<HTMLElement>("[data-action='toggle-search']").forEach((btn) => {
			btn.setAttribute("aria-expanded", String(open));
		});
	};

	const isSearchPanelOpen = () => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel) return false;
		const h = panel.style.maxHeight;
		return Boolean(h && h !== "0px" && h !== "0");
	};

	const syncSearchPanelHeight = () => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel || !isSearchPanelOpen()) return;
		panel.style.maxHeight = `${panel.scrollHeight}px`;
	};

	const burgerBtn = document.getElementById("vanilla-burger-btn");
	const burger = document.getElementById("vanilla-burger");

	const syncBurgerButtonIcons = (open: boolean) => {
		if (!burgerBtn) return;
		burgerBtn.querySelectorAll<HTMLElement>(".burger-icon").forEach((el) => {
			const key = el.dataset.icon;
			if (key === "open") el.classList.toggle("hidden", open);
			else el.classList.toggle("hidden", !open);
		});
	};

	const setBurger = (open: boolean) => {
		if (!burger || !burgerBtn) return;
		if (open) setSearchOpen(false);
		burger.classList.toggle("hidden", !open);
		burgerBtn.setAttribute("aria-expanded", String(open));
		syncBurgerButtonIcons(open);
		document.body.style.overflow = open ? "hidden" : "";
		if (open) positionBurger();
	};

	const syncHeaderChromeAfterNavigation = () => {
		document.body.style.overflow = "";
		window.dispatchEvent(new CustomEvent("vanilla:login:close"));
		setSearchOpen(false);
		const burgerEl = document.getElementById("vanilla-burger");
		const btn = document.getElementById("vanilla-burger-btn");
		if (burgerEl) burgerEl.classList.add("hidden");
		if (btn) btn.setAttribute("aria-expanded", "false");
		syncBurgerButtonIcons(false);
		positionBurger();
	};

	let headerDelegatesBound = false;
	const bindHeaderDelegatedClicks = () => {
		if (headerDelegatesBound) return;
		headerDelegatesBound = true;

		document.addEventListener(
			"click",
			(event: MouseEvent) => {
				const raw = event.target;
				const el = raw instanceof Element ? raw : null;
				if (!el?.closest("[data-login-open]")) return;
				setSearchOpen(false);
				setBurger(false);
			},
			true
		);

		document.addEventListener("click", (event: MouseEvent) => {
			const raw = event.target;
			const el = raw instanceof Element ? raw : null;
			if (!el) return;

			if (el.closest("#vanilla-burger-btn")) {
				const b = document.getElementById("vanilla-burger");
				if (!b) return;
				event.preventDefault();
				setBurger(b.classList.contains("hidden"));
				return;
			}

			if (el.closest("[data-action='toggle-search']")) {
				event.preventDefault();
				event.stopPropagation();
				const willOpen = !isSearchPanelOpen();
				if (willOpen && burger && !burger.classList.contains("hidden")) {
					setBurger(false);
				}
				setSearchOpen(willOpen);
				return;
			}

			if (el.closest("#vanilla-burger a[href]")) {
				setBurger(false);
			}
		});

		document.addEventListener("click", (event: MouseEvent) => {
			if (!isSearchPanelOpen()) return;
			const target = event.target;
			if (!(target instanceof Node)) return;
			const panel = document.querySelector<HTMLElement>("[data-search-panel]");
			if (panel?.contains(target)) return;
			const tEl = target instanceof Element ? target : null;
			if (tEl?.closest?.("[data-action='toggle-search']")) return;
			setSearchOpen(false);
		});

		window.addEventListener("resize", () => {
			syncSearchPanelHeight();
			positionBurger();
		});
	};

	bindHeaderDelegatedClicks();
	document.addEventListener("astro:page-load", syncHeaderChromeAfterNavigation);
	syncHeaderChromeAfterNavigation();
</script>
