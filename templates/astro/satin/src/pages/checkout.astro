---
// Puck-managed checkout page (Figma 1:19998 — 2 mega sections).
//
// pagesData.checkout содержит [CheckoutHeader, CheckoutForm, CheckoutSummary,
// Footer]. CheckoutForm и CheckoutSummary — мега-блоки которые internally
// импортируют все необходимые inner Astro sections с data-checkout-slot.
// React Island (CheckoutFlow.tsx) находит slots через querySelectorAll и
// Portals interactive content без изменений.

import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/data.json';
import siteConfig from '../data/site-config.json';
import Footer from '../components/Footer.astro';
import CheckoutHeader from '../components/CheckoutHeader.astro';
import CheckoutForm from '../components/CheckoutForm.astro';
import CheckoutSummary from '../components/CheckoutSummary.astro';

const meta = (data as any)?.meta ?? {};
const checkoutPage = (data as any)?.pagesData?.checkout ?? { content: [] };

type Block = { type: string; props: Record<string, any> };
const blocks: Block[] = Array.isArray(checkoutPage.content) ? checkoutPage.content : [];

const headerBlock = blocks.find((b) => b.type === 'CheckoutHeader');
const formBlock = blocks.find((b) => b.type === 'CheckoutForm');
const summaryBlock = blocks.find((b) => b.type === 'CheckoutSummary');
const footerBlock = blocks.find((b) => b.type === 'Footer');
const homeFooter = ((data as any)?.content ?? []).find((b: any) => b.type === 'Footer');
const footerProps = footerBlock?.props ?? homeFooter?.props ?? (siteConfig as any)?.footer ?? {};
---
<BaseLayout title={`Оформление заказа — ${meta?.title ?? 'Мой сайт'}`}>
  {/* Figma 1:13398 — checkout always light scheme regardless of theme default. */}
  <div class="color-scheme-2">
    {headerBlock && <CheckoutHeader {...headerBlock.props} />}

    <main class="flex-1 w-full" style="background: rgb(var(--color-bg)); color: rgb(var(--color-text));">
      {/* Figma 1:19998 — form col 434px, summary col 589px, gap ~56px, x-offset 200px.
          Total content = 1280px. Mobile: stacked. */}
      <div class="mx-auto max-w-[1280px] px-4 xl:px-0 xl:pl-[200px] py-12 grid grid-cols-1 xl:grid-cols-[434px_589px] gap-x-[56px] gap-y-8">
        <div data-checkout-column="form" class="min-w-0">
          {formBlock && <CheckoutForm {...formBlock.props} />}
        </div>
        <div data-checkout-column="summary" class="min-w-0">
          {summaryBlock && <CheckoutSummary {...summaryBlock.props} />}
        </div>
      </div>
    </main>

    {footerBlock ? <Footer {...footerProps} /> : null}
  </div>

  <div id="checkout-island" style="display:contents"></div>

  <script is:inline define:vars={{ shopId: meta?.shopId, apiUrl: meta?.apiUrl, dadataToken: (meta as any)?.dadataToken || '' }}>
    window.__MERFY_CONFIG__ = {
      shopId: shopId || '',
      apiUrl: apiUrl || 'https://gateway.merfy.ru/api',
    };
    if (dadataToken) {
      window.__DADATA_TOKEN__ = dadataToken;
    }
  </script>
  <script>
    import { mountCheckoutFlow } from '../lib/storefront/checkout';

    const config = (window as any).__MERFY_CONFIG__ ?? {};
    const target = document.getElementById('checkout-island');
    if (target) {
      const cartId = (typeof localStorage !== 'undefined' && localStorage.getItem('merfy:cartId')) || null;
      mountCheckoutFlow(target as HTMLElement, {
        apiBase: config.apiUrl ?? 'https://gateway.merfy.ru/api',
        shopId: config.shopId ?? '',
        preview: Boolean((window as any).__MERFY_PREVIEW__),
        initialCartId: cartId,
      });
    }
  </script>
</BaseLayout>
