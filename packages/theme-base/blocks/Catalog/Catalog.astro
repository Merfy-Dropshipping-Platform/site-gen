---
// Catalog — pupa-style SSG render with optional client hydration.
//
// Renders the same visual structure as the live CatalogIsland (sort pills,
// filter sidebar, product grid) so the constructor preview mirrors the live
// storefront. When `siteId` is injected by the preview pipeline, an inline
// client script fetches real products from the storefront API and replaces
// placeholder cards.
//
// On live SSG bundles the theme catalog.astro intercepts Catalog blocks
// before they reach this file and renders the interactive React island
// directly, so this file is only used in preview.
import type { CatalogProps } from './Catalog.puckConfig';

interface Props extends CatalogProps {
  id?: string;
  siteId?: string;
}

const {
  id,
  padding,
  subtitle,
  cards = 8,
  columns = 4,
  productCard,
  showFilter,
  filterPosition,
  showSort,
  colorScheme,
  collectionSlug,
  // Legacy aliases (revisions saved before Figma redesign).
  showCollectionFilter,
  showSidebar,
  siteId,
} = Astro.props as Props;

const paddingStyle = padding
  ? `padding-top:${padding.top ?? 120}px; padding-bottom:${padding.bottom ?? 120}px;`
  : 'padding-top:120px; padding-bottom:120px;';

const subtitleVisible = subtitle !== 'false' && subtitle !== false;
// Priority new field showFilter; fallback to legacy showSidebar only when
// showFilter is not set (otherwise toggling filters off keeps showing them
// because legacy default 'true' wins).
const filterVisible =
  showFilter !== undefined
    ? showFilter !== 'false' && showFilter !== false
    : showSidebar !== undefined
      ? showSidebar !== 'false' && showSidebar !== false
      : true;
const filterSide = (filterPosition ?? 'side') === 'side';
const sortVisible = showSort !== 'false' && showSort !== false;
const collFilterLegacy =
  showCollectionFilter !== 'false' && showCollectionFilter !== false;

const cardCount = Math.max(2, Math.min(24, Number(cards) || 8));
const colCount = Math.max(1, Math.min(6, Number(columns) || 4));
const placeholderCards = Array.from({ length: cardCount });

const cardAspect =
  productCard?.cardStyle === 'square' ? '1 / 1'
  : productCard?.cardStyle === 'wide' ? '4 / 3'
  : '3 / 4';

// Card chrome — toggle background/border based on cardBackground.
const cardBgOn =
  productCard?.cardBackground === 'true' || productCard?.cardBackground === true;
// Quick-add button (none / standard / cart).
const quickAddMode = productCard?.quickAdd ?? 'none';
const showQuickAdd = quickAddMode === 'standard' || quickAddMode === 'cart';
const quickAddText = quickAddMode === 'cart' ? 'В КОРЗИНУ' : 'БЫСТРЫЙ ПРОСМОТР';
// Button style affects pill colors.
const btnStyle = productCard?.buttonStyle ?? 'primary';
const btnBg = btnStyle === 'primary' ? '#000000' : btnStyle === 'secondary' ? '#ffffff' : 'transparent';
const btnFg = btnStyle === 'primary' ? '#ffffff' : '#000000';
const btnBorder = btnStyle === 'link' ? 'none' : btnStyle === 'secondary' ? '1px solid #000000' : '1px solid #000000';
// Color scheme — apply CSS class so theme tokens swap.
const schemeClass =
  typeof colorScheme === 'string' && colorScheme
    ? `color-scheme-${colorScheme.replace('scheme-', '')}`
    : '';

const apiBase = 'https://gateway.merfy.ru/api';
---
<section
  class:list={[schemeClass]}
  data-puck-component-id={id}
  data-block="catalog"
  data-site-id={siteId}
  data-api-base={apiBase}
  data-collection-slug={collectionSlug}
  data-card-bg={cardBgOn ? 'true' : 'false'}
  data-quick-add={quickAddMode}
  data-next-photo={(productCard?.nextPhoto === 'true' || productCard?.nextPhoto === true) ? 'true' : 'false'}
  style={`background:rgb(var(--color-bg, 255 255 255));color:rgb(var(--color-text, 0 0 0));${paddingStyle}`}
>
  <div style="max-width: 1320px; margin: 0 auto; padding-left: 24px; padding-right: 24px;">
    <div style="margin-bottom: 24px;">
      <h1
        style="font-size: clamp(20px, 3vw, 36px); font-weight: 400; text-transform: uppercase; line-height: 1.1; color: rgb(var(--color-heading, 0 0 0)); margin: 0; font-family: var(--font-heading);"
      >КАТАЛОГ</h1>
      {subtitleVisible && (
        <p
          style="font-size: clamp(14px, 1.5vw, 20px); font-weight: 400; line-height: 1.4; color: rgb(var(--color-muted, 153 153 153)); margin-top: 6px; font-family: var(--font-body);"
        >Здесь начинается персональный стиль</p>
      )}
    </div>

    <div data-catalog-count style="margin-bottom: 16px; color: #000000; font-size: 14px;">{cardCount} товаров</div>

    {sortVisible && (
      <div
        data-catalog-sort
        style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px;"
      >
        <button type="button" data-sort="popularity" style="padding: 8px 18px; border: 1px solid #ff5a1f; background: #ffffff; color: #000000; border-radius: 999px; font-size: 14px;">По популярности</button>
        <button type="button" data-sort="newest" data-active="true" style="padding: 8px 18px; border: 1px solid #000000; background: #000000; color: #ffffff; border-radius: 999px; font-size: 14px;">По новизне</button>
        <button type="button" data-sort="price-asc" style="padding: 8px 18px; border: 1px solid #ff5a1f; background: #ffffff; color: #000000; border-radius: 999px; font-size: 14px;">По возрастанию цены</button>
        <button type="button" data-sort="price-desc" style="padding: 8px 18px; border: 1px solid #ff5a1f; background: #ffffff; color: #000000; border-radius: 999px; font-size: 14px;">По убыванию цены</button>
      </div>
    )}

    {filterVisible && !filterSide && (
      <div
        data-catalog-filters-top
        style="display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid rgba(0,0,0,0.1);"
      >
        <div style="font-weight: 500; color: #000;">Фильтры:</div>
        <button type="button" data-filter-toggle="stock" style="background: transparent; border: 0; color: #000; cursor: pointer;">Наличие ▾</button>
        <button type="button" data-filter-toggle="price" style="background: transparent; border: 0; color: #000; cursor: pointer;">Стоимость ▾</button>
        <button type="button" data-filter-toggle="color" style="background: transparent; border: 0; color: #000; cursor: pointer;">Цвет ▾</button>
      </div>
    )}

    <div style={`display: grid; grid-template-columns: ${filterVisible && filterSide ? '220px 1fr' : '1fr'}; gap: 32px; align-items: start;`}>
      {filterVisible && filterSide && (
        <aside
          style="display: flex; flex-direction: column; gap: 24px; font-size: 14px; color: #000000;"
        >
          <div style="font-weight: 500; opacity: 0.7;">Фильтры:</div>

          {collFilterLegacy && (
            <div data-catalog-collections>
              <div style="font-weight: 500; margin-bottom: 8px;">Коллекции</div>
              <label style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
                <input type="radio" name="cat-coll" checked />
                <span>Все</span>
              </label>
            </div>
          )}

          <div>
            <div style="font-weight: 500; margin-bottom: 8px;">Наличие</div>
            <label style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
              <input type="radio" name="cat-stock" checked />
              <span>Все</span>
            </label>
            <label style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
              <input type="radio" name="cat-stock" />
              <span>В наличии</span>
            </label>
            <label style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
              <input type="radio" name="cat-stock" />
              <span>Распродано</span>
            </label>
          </div>

          <div>
            <div style="font-weight: 500; margin-bottom: 8px;">Стоимость</div>
            <input type="text" placeholder="от" style="width: 100%; padding: 6px 8px; border: 1px solid rgba(0,0,0,0.15); margin-bottom: 6px; background: #ffffff; color: #000000;" />
            <input type="text" placeholder="до" style="width: 100%; padding: 6px 8px; border: 1px solid rgba(0,0,0,0.15); background: #ffffff; color: #000000;" />
          </div>
        </aside>
      )}

      <div
        data-catalog-grid
        style={`display: grid; grid-template-columns: repeat(${colCount}, 1fr); gap: 16px;`}
      >
        {placeholderCards.map(() => (
          <article style={`display: flex; flex-direction: column; gap: 12px; ${cardBgOn ? 'background:#fbfbfb;border:1px solid #f5f5f5;border-radius:8px;padding:8px;' : ''}`}>
            <div style={`aspect-ratio: ${cardAspect}; background: #f5f5f5; border-radius: 4px; display: flex; align-items: center; justify-content: center;`}>
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#cccccc" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            </div>
            <div style="display: flex; flex-direction: column; gap: 4px;">
              <div style="font-size: 14px; color: #000;">Товар</div>
              <div style="font-size: 14px; color: #000;">2 500 ₽</div>
            </div>
            {showQuickAdd && (
              <button
                type="button"
                style={`margin-top:4px;padding:8px 12px;border-radius:4px;font-size:12px;cursor:pointer;background:${btnBg};color:${btnFg};border:${btnBorder};${btnStyle === 'link' ? 'text-decoration:underline;background:transparent;' : ''}`}
              >
                {quickAddText}
              </button>
            )}
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ siteId, apiBase, cardCount, cardBgOn, btnBg, btnFg, btnBorder, btnStyle, showQuickAdd, quickAddText, collectionSlug }}>
  // Mirror live storefront in constructor preview: fetch real products and
  // replace placeholder grid with actual cards. Honor productCard.* settings
  // so user changes (cardBackground, buttonStyle, quickAdd, etc) reflect.
  (function () {
    if (!siteId) return;
    const root = document.querySelector('section[data-block="catalog"]');
    if (!root) return;
    const grid = root.querySelector('[data-catalog-grid]');
    const count = root.querySelector('[data-catalog-count]');
    const collsEl = root.querySelector('[data-catalog-collections]');
    if (!grid) return;

    function fmtPrice(p) {
      const num = typeof p === 'number' ? p : parseFloat(p);
      if (!Number.isFinite(num)) return '';
      const rubles = num > 1000000 ? Math.round(num / 100) : Math.round(num);
      return rubles.toLocaleString('ru-RU') + ' ₽';
    }

    const cardChrome = cardBgOn
      ? 'background:#fbfbfb;border:1px solid #f5f5f5;border-radius:8px;padding:8px;'
      : '';
    const buttonStyle = (
      'margin-top:4px;padding:8px 12px;border-radius:4px;font-size:12px;cursor:pointer;' +
      'background:' + btnBg + ';color:' + btnFg + ';border:' + btnBorder + ';' +
      (btnStyle === 'link' ? 'text-decoration:underline;background:transparent;' : '')
    );

    function escAttr(s) {
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function cardHtml(p) {
      const img = (Array.isArray(p.images) && p.images[0])
        ? (typeof p.images[0] === 'string' ? p.images[0] : p.images[0].url)
        : '';
      const title = p.title || p.name || '';
      const price = fmtPrice(p.basePrice ?? p.price);
      const compare = p.compareAtPrice ? fmtPrice(p.compareAtPrice) : '';
      const handle = p.handle || p.slug || p.id;
      const imgBlock = img
        ? '<div style="aspect-ratio:3/4;overflow:hidden;border-radius:4px;background:rgba(0,0,0,0.05);">' +
          '<img src="' + escAttr(img) + '" alt="' + escAttr(title) + '" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />' +
          '</div>'
        : '<div style="aspect-ratio:3/4;background:rgba(0,0,0,0.05);border-radius:4px;"></div>';
      return (
        '<article data-product-id="' + escAttr(p.id) + '" data-product-handle="' + escAttr(handle) + '" style="display:flex;flex-direction:column;gap:8px;cursor:pointer;' + cardChrome + '">' +
          imgBlock +
          '<div style="font-size:14px;color:#000;">' + escAttr(title) + '</div>' +
          '<div style="font-size:14px;color:#000;display:flex;gap:8px;align-items:baseline;">' +
            '<span>' + price + '</span>' +
            (compare ? '<span style="text-decoration:line-through;color:#999;">' + compare + '</span>' : '') +
          '</div>' +
          (showQuickAdd ? '<button type="button" data-quick-add-id="' + escAttr(p.id) + '" style="' + buttonStyle + '">' + escAttr(quickAddText) + '</button>' : '') +
        '</article>'
      );
    }

    // Local state for client-side filter/sort (preview parity with live).
    const state = {
      allProducts: [],
      sort: 'newest',
      stock: 'all',          // 'all' | 'in' | 'out'
      priceMin: null,
      priceMax: null,
      collection: collectionSlug || null,
    };

    function applyFilters(list) {
      let result = list.slice();
      // Collection filter
      if (state.collection) {
        result = result.filter(function (p) {
          if (!Array.isArray(p.collections)) return false;
          return p.collections.some(function (c) {
            return c && (c.id === state.collection || c.slug === state.collection || c.handle === state.collection);
          });
        });
      }
      // Stock
      if (state.stock === 'in') {
        result = result.filter(function (p) {
          const q = typeof p.quantity === 'number' ? p.quantity : 1;
          return q > 0;
        });
      } else if (state.stock === 'out') {
        result = result.filter(function (p) {
          const q = typeof p.quantity === 'number' ? p.quantity : 1;
          return q <= 0;
        });
      }
      // Price range
      if (state.priceMin != null) {
        result = result.filter(function (p) {
          return Number(p.basePrice ?? p.price ?? 0) >= state.priceMin;
        });
      }
      if (state.priceMax != null) {
        result = result.filter(function (p) {
          return Number(p.basePrice ?? p.price ?? 0) <= state.priceMax;
        });
      }
      // Sort
      const priceOf = (p) => Number(p.basePrice ?? p.price ?? 0);
      if (state.sort === 'price-asc') result.sort((a, b) => priceOf(a) - priceOf(b));
      else if (state.sort === 'price-desc') result.sort((a, b) => priceOf(b) - priceOf(a));
      else if (state.sort === 'newest') result.sort((a, b) => String(b.createdAt || '').localeCompare(String(a.createdAt || '')));
      else if (state.sort === 'popularity') result.sort((a, b) => (b.quantity || 0) - (a.quantity || 0));
      return result.slice(0, cardCount);
    }

    function rerender() {
      const filtered = applyFilters(state.allProducts);
      if (count) count.textContent = filtered.length + ' товаров';
      grid.innerHTML = filtered.length
        ? filtered.map(cardHtml).join('')
        : '<div style="grid-column:1/-1;padding:40px;text-align:center;color:#999;">Товары не найдены</div>';
    }

    // Sort pills click handler
    const sortBar = root.querySelector('[data-catalog-sort]');
    if (sortBar) {
      sortBar.addEventListener('click', function (ev) {
        const btn = ev.target.closest('[data-sort]');
        if (!btn) return;
        state.sort = btn.getAttribute('data-sort');
        // Update visual selection
        sortBar.querySelectorAll('[data-sort]').forEach(function (b) {
          if (b === btn) {
            b.style.background = '#000000';
            b.style.color = '#ffffff';
            b.style.border = '1px solid #000000';
            b.setAttribute('data-active', 'true');
          } else {
            b.style.background = '#ffffff';
            b.style.color = '#000000';
            b.style.border = '1px solid #ff5a1f';
            b.removeAttribute('data-active');
          }
        });
        rerender();
      });
    }

    // Side-bar filters (stock radios + price inputs)
    function attachSideFilters() {
      // Stock radios in aside
      root.querySelectorAll('input[name="cat-stock"]').forEach(function (input, idx) {
        input.addEventListener('change', function () {
          state.stock = idx === 0 ? 'all' : idx === 1 ? 'in' : 'out';
          rerender();
        });
      });
      // Price inputs (от / до)
      const priceInputs = root.querySelectorAll('aside input[type="text"]');
      if (priceInputs[0]) {
        priceInputs[0].addEventListener('input', function () {
          const v = parseFloat(this.value);
          state.priceMin = Number.isFinite(v) ? v : null;
          rerender();
        });
      }
      if (priceInputs[1]) {
        priceInputs[1].addEventListener('input', function () {
          const v = parseFloat(this.value);
          state.priceMax = Number.isFinite(v) ? v : null;
          rerender();
        });
      }
    }

    // Top-bar filter dropdown buttons (visual feedback only — actual control is in side panel)
    root.querySelectorAll('[data-filter-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const orig = btn.textContent;
        btn.textContent = orig.replace('▾', '▴');
        setTimeout(function () { btn.textContent = orig; }, 800);
      });
    });

    // Product card click → navigate to product page
    grid.addEventListener('click', function (ev) {
      const article = ev.target.closest('article[data-product-id]');
      if (!article) return;
      const button = ev.target.closest('button');
      if (button) return; // let button handlers fire instead
      const handle = article.getAttribute('data-product-handle') || article.getAttribute('data-product-id');
      if (handle) window.location.href = '/product/' + encodeURIComponent(handle);
    });

    // Quick-add button click
    grid.addEventListener('click', function (ev) {
      const btn = ev.target.closest('button[data-quick-add-id]');
      if (!btn) return;
      ev.preventDefault();
      ev.stopPropagation();
      const productId = btn.getAttribute('data-quick-add-id');
      if (window.cartStore && typeof window.cartStore.addItem === 'function') {
        window.cartStore.addItem(productId, null, 1);
      }
      const orig = btn.textContent;
      btn.textContent = '✓ Добавлено';
      setTimeout(function () { btn.textContent = orig; }, 1500);
    });

    fetch(apiBase + '/sites/' + siteId + '/storefront-data', { credentials: 'omit' })
      .catch(() => null)
      .then((r) => r && r.ok ? r.json() : null)
      .then((data) => {
        if (!data) return;
        const products = data.products || data.data?.products || [];
        const colls = data.collections || data.data?.collections || [];
        // Hydrate collection filter (legacy productIds → state)
        if (state.collection && Array.isArray(colls)) {
          const matchingColl = colls.find(function (c) {
            return c.id === state.collection || c.handle === state.collection || c.slug === state.collection;
          });
          if (matchingColl && Array.isArray(matchingColl.productIds) && matchingColl.productIds.length) {
            const allowed = new Set(matchingColl.productIds);
            products.forEach(function (p) {
              if (allowed.has(p.id) && !Array.isArray(p.collections)) {
                p.collections = [{ id: matchingColl.id, slug: matchingColl.handle }];
              }
            });
          }
        }
        state.allProducts = products;
        if (collsEl && Array.isArray(colls) && colls.length) {
          const items = colls.map(function (c) {
            const checked = c.id === state.collection || c.handle === state.collection ? 'checked' : '';
            return '<label data-coll-id="' + escAttr(c.id) + '" style="display:flex;align-items:center;gap:8px;padding:4px 0;cursor:pointer;"><input type="radio" name="cat-coll" ' + checked + ' /><span>' + escAttr(c.title || c.name || c.handle || c.id) + '</span></label>';
          }).join('');
          collsEl.innerHTML =
            '<div style="font-weight:500;margin-bottom:8px;">Коллекции</div>' +
            '<label data-coll-id="" style="display:flex;align-items:center;gap:8px;padding:4px 0;cursor:pointer;"><input type="radio" name="cat-coll" ' + (state.collection ? '' : 'checked') + ' /><span>Все</span></label>' +
            items;
          collsEl.addEventListener('click', function (ev) {
            const lbl = ev.target.closest('label[data-coll-id]');
            if (!lbl) return;
            state.collection = lbl.getAttribute('data-coll-id') || null;
            rerender();
          });
        }
        attachSideFilters();
        rerender();
      })
      .catch(() => {});
  })();
</script>
