{
  "$schema": "https://merfy.ru/schemas/theme-manifest.v2.json",
  "id": "flux",
  "name": "Flux",
  "version": "1.0.0",
  "extends": "@merfy/theme-base@workspace:*",
  "category": "electronics",
  "description": "Flux — modern dark theme with orange accent (#fa5109), Roboto Flex headings + body, medium (6px) button radii for tech and electronics stores.",
  "author": "Merfy",
  "tokens": "./tokens.json",

  "defaults": {
    "--font-heading": "'Roboto Flex', sans-serif",
    "--font-body": "'Roboto Flex', sans-serif",
    "--weight-heading": "600",
    "--weight-body": "400",
    "--container-max-width": "1320px",
    "--radius-button": "6px",
    "--radius-input": "8px",
    "--radius-card": "12px",
    "--radius-media": "8px",
    "--radius-field": "4px",
    "--size-hero-heading": "72px",
    "--size-hero-button-h": "48px",
    "--size-section-heading": "24px",
    "--size-nav-link": "16px",
    "--size-newsletter-form-w": "480px",
    "--size-logo-width": "120px",
    "--size-card-border": "1px",
    "--spacing-section-y": "64px",
    "--spacing-grid-col-gap": "40px",
    "--spacing-grid-row-gap": "40px",
    "--button-style": "solid",
    "--footer-layout": "2-part",
    "--contact-form-layout": "wide",
    "--cart-type": "drawer",
    "--card-style": "card",
    "--card-alignment": "left",
    "--color-error": "255 148 148"
  },

  "blockDefaults": {
    "Footer": {
      "variant": "2-part"
    }
  },

  "colorSchemes": [
    {
      "id": "scheme-1",
      "name": "1",
      "tokens": {
        "--color-bg": "0 0 0",
        "--color-surface": "0 0 0",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "153 153 153",
        "--color-primary": "255 255 255",
        "--color-accent": "250 81 9",
        "--color-button-bg": "250 81 9",
        "--color-button-text": "255 255 255",
        "--color-button-border": "250 81 9",
        "--color-button-2-bg": "51 51 51",
        "--color-button-2-text": "255 255 255",
        "--color-button-2-border": "51 51 51"
      }
    },
    {
      "id": "scheme-2",
      "name": "2",
      "tokens": {
        "--color-bg": "255 255 255",
        "--color-surface": "255 255 255",
        "--color-heading": "0 0 0",
        "--color-text": "0 0 0",
        "--color-muted": "204 204 204",
        "--color-primary": "0 0 0",
        "--color-accent": "250 81 9",
        "--color-button-bg": "250 81 9",
        "--color-button-text": "255 255 255",
        "--color-button-border": "250 81 9",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "245 245 245"
      }
    },
    {
      "id": "scheme-3",
      "name": "3",
      "tokens": {
        "--color-bg": "250 250 250",
        "--color-surface": "250 250 250",
        "--color-heading": "0 0 0",
        "--color-text": "0 0 0",
        "--color-muted": "204 204 204",
        "--color-primary": "0 0 0",
        "--color-accent": "250 81 9",
        "--color-button-bg": "250 81 9",
        "--color-button-text": "255 255 255",
        "--color-button-border": "250 81 9",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "245 245 245"
      }
    },
    {
      "id": "scheme-4",
      "name": "4",
      "tokens": {
        "--color-bg": "11 11 11",
        "--color-surface": "11 11 11",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "153 153 153",
        "--color-primary": "255 255 255",
        "--color-accent": "250 81 9",
        "--color-button-bg": "250 81 9",
        "--color-button-text": "255 255 255",
        "--color-button-border": "250 81 9",
        "--color-button-2-bg": "51 51 51",
        "--color-button-2-text": "255 255 255",
        "--color-button-2-border": "51 51 51"
      }
    }
  ],

  "blocks": {
    "Header": {
      "override": {
        "path": "./blocks/Header",
        "reason": "Flux uses 1320px container, Roboto Flex bold headings, orange-accent cart badge with 2px badge radius, and 6px button radius for tech/electronics aesthetic."
      }
    },
    "Footer": {
      "override": {
        "path": "./blocks/Footer",
        "reason": "Flux uses 2-part grid (logo+nav LEFT, contact+social RIGHT), orange accent submit button with 6px radius, and a powered-by black strip below copyright."
      }
    },
    "Hero": {
      "variant": "overlay"
    }
  },

  "features": {
    "newsletter": true,
    "cart-drawer": true,
    "otp-auth": true,
    "wishlist": false,
    "color-swatches": true,
    "filter-sidebar": true
  },

  "fonts": [
    { "family": "Roboto Flex", "weights": [300, 400, 500, 600, 700], "source": "google" },
    { "family": "Barlow",      "weights": [400, 500],                 "source": "google" },
    { "family": "Inter",       "weights": [300, 400],                 "source": "google" }
  ]
}
