---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};
---
<BaseLayout title={`Основные данные — ${meta?.title ?? 'Мой сайт'}`}>
  <Header {...headerProps} />

  <main class="account-page-container">
    <a href="/account" class="account-back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Вернуться назад
    </a>

    <div class="account-title">
      <h1>Основные данные</h1>
      <span class="account-subtitle" id="profile-email-display"></span>
    </div>

    <div id="profile-loading" style="color: #444444; font-family: var(--font-body);">Загрузка...</div>

    <form id="profile-form" class="account-form hidden">
      <div class="account-field">
        <label for="profile-email">E-mail</label>
        <input type="email" id="profile-email" class="auth-input" disabled>
      </div>

      <div class="account-field">
        <label for="profile-phone">Телефон</label>
        <input type="tel" id="profile-phone" class="auth-input" placeholder="+7 (000) 000-00-00" autocomplete="tel">
      </div>

      <div class="account-field">
        <label>Пароль</label>
        <div class="auth-input" style="display: flex; align-items: center; justify-content: space-between; cursor: default;">
          <span style="display: flex; gap: 0.25rem; align-items: center;">
            <span style="display: flex; gap: 0.25rem;" aria-hidden="true">
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
            </span>
            <span style="display: flex; gap: 0.25rem;" aria-hidden="true">
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
            </span>
            <span style="display: flex; gap: 0.25rem;" aria-hidden="true">
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #444444;"></span>
            </span>
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#444444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
        </div>
        <a href="/reset-password" class="account-text-link" style="font-size: 0.875rem;">Изменить</a>
      </div>
    </form>

    <div id="profile-status" class="hidden" style="font-family: var(--font-body); font-size: 0.875rem;"></div>

    <div class="account-actions" id="profile-actions" style="display: none;">
      <button type="submit" form="profile-form" class="account-button" id="btn-save">
        <span class="save-text">Сохранить</span>
        <span class="save-loading hidden">Сохранение...</span>
      </button>
      <button type="button" class="account-text-link" id="btn-delete">Удалить аккаунт</button>
    </div>
  </main>

  <Footer {...footerProps} />

  <script is:inline src="/scripts/customer-store.js"></script>
  <script is:inline src="/scripts/customer-auth.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', async function() {
      if (!window.CustomerStore || !window.CustomerStore.isLoggedIn()) {
        window.location.href = '/login?redirect=/account/profile';
        return;
      }

      var loadingEl = document.getElementById('profile-loading');
      var formEl = document.getElementById('profile-form');
      var actionsEl = document.getElementById('profile-actions');
      var statusEl = document.getElementById('profile-status');
      var emailDisplay = document.getElementById('profile-email-display');
      var btn = document.getElementById('btn-save');
      var deleteBtn = document.getElementById('btn-delete');

      try {
        var result = await window.CustomerAuth.me();
        if (!result.success) throw new Error('Failed');

        var c = result.data.customer || result.data;
        loadingEl.classList.add('hidden');
        formEl.classList.remove('hidden');
        actionsEl.style.display = '';

        emailDisplay.textContent = c.email || '';
        document.getElementById('profile-email').value = c.email || '';
        document.getElementById('profile-phone').value = c.phone || '';
      } catch (err) {
        window.CustomerStore.clearToken();
        window.location.href = '/login';
        return;
      }

      formEl.addEventListener('submit', async function(e) {
        e.preventDefault();
        statusEl.classList.add('hidden');
        btn.querySelector('.save-text').classList.add('hidden');
        btn.querySelector('.save-loading').classList.remove('hidden');
        btn.disabled = true;

        try {
          var payload = {
            phone: document.getElementById('profile-phone').value.trim(),
          };
          var result = await window.CustomerAuth.updateProfile(payload);
          if (result.success) {
            statusEl.textContent = 'Сохранено!';
            statusEl.style.color = 'green';
            statusEl.classList.remove('hidden');
            setTimeout(function() { statusEl.classList.add('hidden'); }, 3000);
          } else {
            throw result;
          }
        } catch (err) {
          statusEl.textContent = err.message || 'Не удалось сохранить';
          statusEl.style.color = 'rgb(var(--color-error))';
          statusEl.classList.remove('hidden');
        } finally {
          btn.querySelector('.save-text').classList.remove('hidden');
          btn.querySelector('.save-loading').classList.add('hidden');
          btn.disabled = false;
        }
      });

      if (deleteBtn) {
        deleteBtn.addEventListener('click', function() {
          alert('Для удаления аккаунта обратитесь в поддержку магазина.');
        });
      }
    });
  </script>
</BaseLayout>
