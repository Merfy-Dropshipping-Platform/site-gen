---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import SatinPicture from "../img/SatinPicture.astro";

// Фаза B (satin, группа misc): канон-секция Publications — адаптация
// src/components/sections/Journal.astro (тело КОПИЕЙ; оригинал не тронут —
// index.astro:32 его использует). Схема полей = packages/theme-base/blocks/
// Publications/Publications.puckConfig.ts; манера — themes/satin/MANNER.md
// (эталон процесса — bloom Publications).
// ПУСТОЕ СОСТОЯНИЕ (нет реальных публикаций) = ПЛЕЙСХОЛДЕР по контракту Figma
// 1:19335 (3 колонки: пустой image-rect + «Колонна» + нейтральный текст), НЕ
// мок-демо верстальщика (Journal-болванки про коллекции + /images/4x/journal-*.png).
// Когда у магазина есть реальные публикации (SSR fetch /api/sites/<id>/publications
// → fallback publications.json, либо legacy flat-проп p.posts) — рендерим их без
// изменений (Shopify-модель, как theme-base PopularProducts/Collections: пустое =
// заглушка, данные = реальный контент). Платформенный резолв по publicationType
// остаётся data-атрибутом на гриде.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading (string | { text, alignment, size }); canon-default
// «Публикации» — у верстальщика шапки НЕТ → рендер при непустом. Роль =
// заголовок секции §1 (font-logo 20 uppercase leading-[1.15]), токен heading.
const heading = typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Публикации");
// Лестница §9 «Заголовок секции» (база-литерал 20 = medium): small 17, large 24.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small" ? "text-[17px]" : headingSize === "large" ? "text-[24px]" : "text-[20px]";
const headingAlignment =
	p.headingAlignment ?? (typeof p.heading === "object" ? p.heading?.alignment : undefined);
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-logo ${headingSizeCls} font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]${headingAlignCls}`;

// Лестница §9 «Заголовок карточки журнала» (база-литерал 16 = medium,
// Journal.astro:50): small 14, large 19. Управляется тем же headingSize.
const cardTitleSizeCls =
	headingSize === "small" ? "text-[14px]" : headingSize === "large" ? "text-[19px]" : "text-[16px]";
const cardTitleCls = `font-logo ${cardTitleSizeCls} font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]`;

// Канон columnsCount (slider 1-6) приоритетнее hidden columns (1-4); дефолт 3 =
// sm:grid-cols-3 ЛИТЕРАЛ (Journal.astro:42); иное значение → CSS-var на sm.
const columnsRaw =
	typeof p.columnsCount === "number" ? p.columnsCount : typeof p.columns === "number" ? p.columns : 3;
const columns = Math.max(1, Math.min(6, Math.round(columnsRaw) || 3));
const gridCls =
	columns === 3
		? "grid grid-cols-1 gap-4 sm:grid-cols-3"
		: "grid grid-cols-1 gap-4 sm:grid-cols-[repeat(var(--pub-cols),minmax(0,1fr))]";
const gridStyle = columns === 3 ? undefined : `--pub-cols:${columns};`;

// Канон cardsCount (slider 1-12) приоритетнее hidden cards (1-4); дефолт 3 =
// литерал defaultPosts.
const cardsRaw =
	typeof p.cardsCount === "number" ? p.cardsCount : typeof p.cards === "number" ? p.cards : 3;
const cards = Math.max(1, Math.min(12, Math.round(cardsRaw) || 3));

// Канон showDateTime (toggle; legacy dateTime.enabled) — дефолт true =
// дата-строка «01.05, 12:41» (Arsenal 14 light uppercase tracking-[0.04em]
// muted — литерал Journal.astro:49); false скрывает.
const showDate = String(p.showDateTime ?? p.dateTime?.enabled ?? "true") === "true";

// Канон publicationType (pagePicker) — носитель платформенного резолва
// публикаций: data-атрибут на гриде (паттерн bloom).
const publicationType =
	typeof p.publicationType === "string" && p.publicationType ? p.publicationType : undefined;

// Реальные публикации: SSR fetch storefront publications (gateway → sites-
// service) c fallback на build-time publications.json (паттерн canonical
// theme-base / bloom Publications). siteId инжектит build pipeline / preview
// controller. Legacy flat-проп Journal posts[] {title,image,date,excerpt,href}
// — высший приоритет (back-compat для ревизий, где данные пришли так).
type RawPublication = {
	id: string;
	title?: string;
	slug?: string;
	excerpt?: string;
	coverImageUrl?: string | null;
	publishedAt?: string | null;
};
const legacyPosts = Array.isArray(p.posts) && p.posts.length ? p.posts : undefined;
const siteIdFromRoot = typeof p.siteId === "string" ? p.siteId : "";
let realPublications: RawPublication[] = [];
if (!legacyPosts && siteIdFromRoot) {
	try {
		const internalBase =
			(import.meta as unknown as { env?: { SITES_INTERNAL_BASE?: string } }).env?.SITES_INTERNAL_BASE ??
			"http://localhost:3114";
		const res = await fetch(`${internalBase}/api/sites/${siteIdFromRoot}/publications`).catch(() => null);
		if (res && res.ok) {
			const data = (await res.json()) as { publications?: RawPublication[] };
			realPublications = data.publications ?? [];
		}
	} catch {
		/* swallow */
	}
}
try {
	if (!legacyPosts && realPublications.length === 0) {
		const pubData = await import("../data/publications.json");
		realPublications = ((pubData as { default?: RawPublication[] }).default ??
			(pubData as unknown as RawPublication[])) as RawPublication[];
	}
} catch {
	/* swallow — publications.json отсутствует */
}

function formatPubDate(iso: string | null | undefined): string {
	if (!iso) return "";
	try {
		return new Intl.DateTimeFormat("ru-RU", { day: "numeric", month: "long", year: "numeric" }).format(
			new Date(iso),
		);
	} catch {
		return "";
	}
}

// Гейт пустого состояния (Shopify-модель): есть реальные публикации (legacy
// posts[] / SSR fetch / publications.json) → рендерим их; нет — ДОСЛОВНЫЙ
// ПЛЕЙСХОЛДЕР по контракту Figma 1:19335 для типа «Публикации»: 3 колонки =
// пустой image-rect (surface) + «Колонна» + «Сочетай текст, чтобы подчеркнуть
// плюсы товара или коллекции.» + стрелка-кнопка «Кнопка». НЕ мок-демо
// верстальщика. Текст/лейблы — дословно как rose/satin MultiColumns.astro
// (контракт Publications требует стрелки/кнопки в колоннах, как MultiColumns).
const PLACEHOLDER_TEXT = "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.";
// Контракт картиночных секций (правило 2): фолбэк-картинка колонки пустого
// состояния = дизайн-ассет publication-card.png (/placeholders/publication-card.png,
// раздаётся на каждой теме) — картинка показывается ВСЕГДА, НЕ пустой surface-rect.
// Эталон theme-base Publications.astro (PLACEHOLDER_ASSETS.publicationCard).
const PLACEHOLDER_IMAGE = "/placeholders/publication-card.png";
// Per-column ссылка-плейсхолдер «Кнопка» (Figma 1:19335 — стрелка/кнопка в
// КАЖДОЙ колонке, дословно как satin MultiColumns.astro PLACEHOLDER_COLUMN);
// рендер ниже тем же CTA «Перейти»-механизмом колонки (arrow-right size-5).
const PLACEHOLDER_LINK = { text: "Кнопка", href: "/catalog" };
type PubItem = {
	title: string;
	date: string;
	excerpt: string;
	image: string;
	href?: string;
	linkText?: string;
	isPlaceholder: boolean;
};
const items: PubItem[] = legacyPosts
	? legacyPosts.map((post: any) => ({
			title: post.title ?? "",
			date: post.date ?? "",
			excerpt: post.excerpt ?? "",
			image: post.image ?? "",
			href: post.href,
			isPlaceholder: false,
		}))
	: realPublications.length > 0
		? realPublications.slice(0, cards).map((pub) => ({
				title: pub.title ?? "",
				date: formatPubDate(pub.publishedAt),
				excerpt: pub.excerpt ?? "",
				image: pub.coverImageUrl ?? "",
				href: pub.slug ? `/publication/${pub.slug}` : undefined,
				isPlaceholder: false,
			}))
		: Array.from({ length: cards }, () => ({
				title: "Колонна",
				date: "",
				excerpt: PLACEHOLDER_TEXT,
				image: PLACEHOLDER_IMAGE,
				href: PLACEHOLDER_LINK.href,
				linkText: PLACEHOLDER_LINK.text,
				isPlaceholder: true,
			}));

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

{/* Секция: вертикаль-стандарт §2 (py-10 md:py-14 — литерал Journal.astro:41), поля .satin-pad. */}
<section
	class="satin-pad w-full bg-[rgb(var(--color-bg,255_255_255))] py-10 md:py-14"
	aria-labelledby={titleId}
	aria-label={heading ? undefined : "Журнал"}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="satin-container flex flex-col gap-8">
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}
		<ul
			class={gridCls}
			style={gridStyle}
			role="list"
			data-publication-type={publicationType}
		>
			{
				items.map((post, i) => (
					<li
						class="flex flex-col gap-6 bg-[rgb(var(--color-surface,245_245_245))] p-4"
						data-publication-index={i}
						data-puck-subsection-parent={post.isPlaceholder ? undefined : id}
						data-puck-subsection-index={post.isPlaceholder ? undefined : i}
						data-puck-subsection-field={post.isPlaceholder ? undefined : "cardsCount"}
					>
						{/* Медиа: реальная обложка → <img>; пустое состояние (плейсхолдер
						   Figma 1:19335 или публикация без обложки) → пустой image-rect
						   surface bg-[rgb(var(--color-surface))] (контракт — пустые
						   surface-карточки, токен темы вместо литерала). */}
						<div class="relative aspect-square w-full overflow-hidden bg-[rgb(var(--color-surface,245_245_245))]">
							{post.image &&
								(post.image.startsWith("/placeholders/") ? (
									/* Плоский <img> для placeholder-PNG: соимённого .webp нет, а
									   SatinPicture безусловно эмитит <source srcset=*.webp> → 404 +
									   <picture> не откатывается (баг project_cart_thumb_image_bug). */
									<img
										src={post.image}
										alt=""
										loading="lazy"
										class="absolute inset-0 size-full object-cover"
										aria-hidden="true"
									/>
								) : (
									<SatinPicture
										src={post.image}
										alt={post.title}
										loading="lazy"
										class="absolute inset-0 size-full object-cover"
									/>
								))}
						</div>
						<div class="flex flex-col gap-2">
							{showDate && !post.isPlaceholder && post.date && (
								<p class="font-manrope text-[14px] font-light uppercase tracking-[0.04em] text-[rgb(var(--color-muted,153_153_153))]">
									{post.date}
								</p>
							)}
							<h3 class={cardTitleCls}>{post.title}</h3>
							{post.excerpt && (
								<p class="font-manrope text-[14px] font-light leading-[1.5] text-[rgb(var(--color-muted,153_153_153))]">
									{post.excerpt}
								</p>
							)}
						</div>
						{/* CTA-стрелка «Перейти» для реальной публикации; для плейсхолдера
						   (Figma 1:19335 требует стрелку/кнопку в КАЖДОЙ колонне) —
						   дословный лейбл «Кнопка» тем же arrow-right механизмом колонки. */}
						{post.href && (post.isPlaceholder ? post.linkText : true) && (
							<a
								href={post.href}
								class="inline-flex items-center gap-2 font-manrope text-[14px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70"
							>
								<span>{post.isPlaceholder ? post.linkText : "Перейти"}</span>
								<NtIcon name="arrow-right" sizeClass="size-5" />
							</a>
						)}
					</li>
				))
			}
		</ul>
	</div>
</section>
