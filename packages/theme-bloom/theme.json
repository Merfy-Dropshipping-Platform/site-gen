{
  "$schema": "https://merfy.ru/schemas/theme-manifest.v2.json",
  "id": "bloom",
  "name": "Bloom",
  "version": "1.0.0",
  "extends": "@merfy/theme-base@workspace:*",
  "category": "beauty",
  "description": "Bloom — soft feminine theme with pink pastel accents (#CF7A8B / #E38E9F), Urbanist headings, pill-shaped buttons for beauty and cosmetics stores.",
  "author": "Merfy",
  "tokens": "./tokens.json",
  "defaults": {
    "--font-heading": "'Urbanist', sans-serif",
    "--font-body": "'Inter', sans-serif",
    "--weight-heading": "400",
    "--weight-body": "400",
    "--container-max-width": "1320px",
    "--radius-button": "100px",
    "--radius-input": "4px",
    "--radius-card": "12px",
    "--radius-media": "12px",
    "--radius-field": "4px",
    "--size-hero-heading": "72px",
    "--size-hero-button-h": "48px",
    "--size-section-heading": "24px",
    "--size-nav-link": "16px",
    "--size-newsletter-form-w": "480px",
    "--size-logo-width": "120px",
    "--size-card-border": "1px",
    "--spacing-section-y": "120px",
    "--spacing-grid-col-gap": "40px",
    "--spacing-grid-row-gap": "40px",
    "--button-style": "solid",
    "--footer-layout": "2-part",
    "--contact-form-layout": "wide",
    "--cart-type": "drawer",
    "--card-style": "standard",
    "--card-alignment": "left",
    "--color-error": "255 148 148"
  },
  "blockDefaults": {
    "PromoBanner": {
      "size": "thin",
      "textTransform": "uppercase",
      "colorScheme": "scheme-1"
    },
    "Header": {
      "logoPosition": "top-left",
      "padding": {
        "top": 16,
        "bottom": 16
      }
    },
    "Hero": {
      "variant": "split-bloom",
      "alignment": "left",
      "size": "large"
    },
    "Slideshow": {
      "alignment": "left",
      "pagination": "numbers",
      "contentAlign": "left"
    },
    "Collections": {
      "cardCaptionStyle": "uppercase",
      "gridAspect": "1:1",
      "titleAlignment": "left"
    },
    "MainText": {
      "buttonStyle": "solid",
      "textStyle": "regular"
    },
    "Video": {
      "padded": true,
      "align": "container"
    },
    "ImageWithText": {
      "imagePosition": "right",
      "ctaPosition": "bottom-pinned"
    },
    "PopularProducts": {
      "cardCaptionStyle": "uppercase",
      "headingAlignment": "left",
      "columns": 3
    },
    "Newsletter": {
      "formLayout": "inline-submit",
      "alignment": "left"
    },
    "Catalog": {
      "filterPosition": "side",
      "showFilter": "false",
      "showSort": "true",
      "columns": 3,
      "cards": 12,
      "gridAspect": "1:1",
      "cardCaptionStyle": "uppercase",
      "padding": {
        "top": 80,
        "bottom": 80
      },
      "productCard": {
        "cardStyle": "auto",
        "quickAdd": "none"
      }
    },
    "Footer": {
      "variant": "2-part",
      "bottomStrip": {
        "enabled": true,
        "text": "© 2026 Bloom Theme. Powered by Merfy"
      }
    }
  },
  "colorSchemes": [
    {
      "id": "scheme-1",
      "name": "1",
      "tokens": {
        "--color-bg": "207 122 139",
        "--color-surface": "207 122 139",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "245 245 245",
        "--color-primary": "255 255 255",
        "--color-accent": "227 142 159",
        "--color-button-bg": "255 255 255",
        "--color-button-text": "207 122 139",
        "--color-button-border": "227 142 159",
        "--color-button-2-bg": "207 122 139",
        "--color-button-2-text": "255 255 255",
        "--color-button-2-border": "247 162 179"
      }
    },
    {
      "id": "scheme-2",
      "name": "2",
      "tokens": {
        "--color-bg": "227 142 159",
        "--color-surface": "227 142 159",
        "--color-heading": "255 255 255",
        "--color-text": "255 255 255",
        "--color-muted": "245 245 245",
        "--color-primary": "255 255 255",
        "--color-accent": "247 162 179",
        "--color-button-bg": "255 255 255",
        "--color-button-text": "227 142 159",
        "--color-button-border": "247 162 179",
        "--color-button-2-bg": "227 142 159",
        "--color-button-2-text": "255 255 255",
        "--color-button-2-border": "255 181 175"
      }
    },
    {
      "id": "scheme-3",
      "name": "3",
      "tokens": {
        "--color-bg": "255 255 255",
        "--color-surface": "255 255 255",
        "--color-heading": "0 0 0",
        "--color-text": "0 0 0",
        "--color-muted": "153 153 153",
        "--color-primary": "0 0 0",
        "--color-accent": "207 122 139",
        "--color-button-bg": "207 122 139",
        "--color-button-text": "255 255 255",
        "--color-button-border": "207 122 139",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "217 217 217"
      }
    },
    {
      "id": "scheme-4",
      "name": "4",
      "tokens": {
        "--color-bg": "247 247 249",
        "--color-surface": "247 247 249",
        "--color-heading": "0 0 0",
        "--color-text": "0 0 0",
        "--color-muted": "153 153 153",
        "--color-primary": "0 0 0",
        "--color-accent": "207 122 139",
        "--color-button-bg": "207 122 139",
        "--color-button-text": "255 255 255",
        "--color-button-border": "207 122 139",
        "--color-button-2-bg": "255 255 255",
        "--color-button-2-text": "0 0 0",
        "--color-button-2-border": "217 217 217"
      }
    }
  ],
  "blocks": {
    "Hero": {
      "variant": "split-bloom"
    },
    "Header": {},
    "Footer": {},
    "PopularProducts": {},
    "Collections": {},
    "Product": {},
    "Newsletter": {},
    "ContactForm": {},
    "Catalog": {}
  },
  "features": {
    "newsletter": true,
    "cart-drawer": true,
    "otp-auth": true,
    "wishlist": false,
    "color-swatches": true,
    "filter-sidebar": true,
    "puckDrivenPages": true
  },
  "fonts": [
    {
      "family": "Urbanist",
      "weights": [
        400,
        500,
        600,
        700
      ],
      "source": "google"
    },
    {
      "family": "Inter",
      "weights": [
        300,
        400,
        500,
        600
      ],
      "source": "google"
    },
    {
      "family": "Roboto",
      "weights": [
        400,
        500
      ],
      "source": "google"
    },
    {
      "family": "Manrope",
      "weights": [
        400,
        500
      ],
      "source": "google"
    }
  ]
}
