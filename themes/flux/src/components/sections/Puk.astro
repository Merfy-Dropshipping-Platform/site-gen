---
import FluxPicture from "../img/FluxPicture.astro";
import { pukItems } from '../../data/pukItems';
---

<section class="w-full bg-white px-4 pb-16 pt-16 md:px-20 md:pb-24 md:pt-24 2xl:px-80">
  <div class="mx-auto w-full max-w-[1320px]">
    <div class="flex flex-col items-center gap-1 mb-12 text-center md:mb-16">
      <h2 class="font-comfortaa text-[24px] font-normal uppercase leading-normal text-[#000000] md:text-[28px]">АКЦИЯ ПУКНИ 3 раза</h2>
      <p class="font-roboto-flex text-[18px] font-light leading-normal text-[#999999] md:text-[20px]">ПУК ПУК ПУК</p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8 lg:grid-cols-3">
      {pukItems.map((item) => (
        <div class="flex flex-col gap-4 md:gap-5">
          <div class="w-full aspect-[430/500] overflow-hidden bg-[#F5F5F5] rounded-[8px]">
            <FluxPicture 
              src={item.image} 
              alt={item.title}
              class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
              loading="lazy"
            />
          </div>
          <p class="font-manrope text-[18px] font-normal leading-[1.366] text-[#000000] md:text-[20px]">{item.title}</p>
        </div>
      ))}
    </div>
  </div>
</section>



