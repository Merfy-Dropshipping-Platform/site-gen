---
// Satin Catalog — Puck shell. The actual filter sidebar + product grid +
// pagination is mounted inline by the live `catalog.astro` page (which
// imports CatalogIsland directly and inlines it for blocks of type
// "Catalog"), NOT by this file.
//
// This component intentionally does NOT import CatalogIsland.tsx because
// the constructor's preview pipeline renders block .astro files through
// Astro's Container API, which has no client-side runtime and cannot
// resolve `client:only="react"` directives. Importing the React island here
// breaks constructor preview ("No valid renderer was found for ./react/
// CatalogIsland"). Live builds work because catalog.astro inlines the
// island itself.
//
// In the constructor preview this renders as a labelled placeholder so the
// merchant sees where the catalog body will appear and can click into the
// block to edit its props (collectionSlug, sidebar visibility, padding,
// scheme).
import { CatalogClasses as C } from './Catalog.classes';
import type { CatalogProps } from './Catalog.puckConfig';

interface Props extends CatalogProps {
  id?: string;
}

const { id, padding, colorScheme } = Astro.props as Props;

const paddingStyle = padding
  ? `padding-top:${padding.top ?? 40}px; padding-bottom:${padding.bottom ?? 80}px;`
  : 'padding-top:40px; padding-bottom:80px;';
const schemeRaw = typeof colorScheme === 'string' ? colorScheme : undefined;
const schemeClass = schemeRaw ? `color-scheme-${schemeRaw.replace('scheme-', '')}` : '';
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-block="catalog"
  style={paddingStyle}
>
  <div class={C.container}>
    <div class="flex gap-[24px]">
      <aside class="hidden lg:block w-[280px] shrink-0">
        <div class="space-y-[24px]">
          <p class="[font-family:var(--font-body)] text-[18px] uppercase tracking-[0.05em] text-[rgb(var(--color-muted))]">
            Фильтры
          </p>
          <div class="space-y-[12px] [font-family:var(--font-body)] text-[14px] uppercase text-[rgb(var(--color-text))]">
            <div>Наличие</div>
            <div>Стоимость</div>
            <div>Цвет</div>
          </div>
        </div>
      </aside>
      <div class="flex-1 grid grid-cols-2 gap-[16px]">
        {Array.from({ length: 4 }).map(() => (
          <div class="aspect-[1/1] bg-[rgb(var(--color-surface))] opacity-50"></div>
        ))}
      </div>
    </div>
  </div>
</section>
