---
interface Props {
  heading?: { text?: string; size?: 'small' | 'medium' | 'large' };
  text?: { content?: string; size?: 'small' | 'medium' | 'large' };
  form?: { placeholder?: string; buttonText?: string };
  colorScheme?: string;
  padding?: { top?: number; bottom?: number };
}

const { heading, text, form, colorScheme, padding } = Astro.props;
const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';
const headingText = heading?.text ?? 'Подпишитесь на нашу рассылку';
const textContent = text?.content ?? '';
const placeholder = form?.placeholder ?? 'E-mail';
const buttonText = form?.buttonText ?? 'Отправить';
const padTop = padding?.top ?? 120;
const padBottom = padding?.bottom ?? 120;
---

<section
  class={`w-full ${schemeClass}`}
  style={`padding-top: ${padTop}px; padding-bottom: ${padBottom}px; background: rgb(var(--color-background)); color: rgb(var(--color-foreground));`}
>
  <div class="max-w-[1320px] mx-auto px-5 flex flex-col md:flex-row md:items-center gap-[40px]">
    <div class="flex-1 flex flex-col gap-[8px]">
      <h2 class="font-heading font-normal text-[20px] leading-[1.2]" style="color: rgb(var(--color-foreground));">
        {headingText}
      </h2>
      {textContent && (
        <p class="text-[16px] font-body leading-[1.25]" style="color: rgb(var(--color-foreground) / 0.9);">
          {textContent}
        </p>
      )}
    </div>
    <form
      class="w-full md:w-auto md:min-w-[652px] h-[56px] flex items-center shrink-0"
      action="https://gateway.merfy.ru/api/storefront/newsletter/subscribe"
      method="POST"
      data-newsletter-form
      style="border: 1px solid rgb(var(--color-foreground)); border-radius: var(--radius-input, var(--radius-button));"
    >
      <input type="hidden" name="store_id" value="" data-newsletter-store-id />
      <input
        type="email"
        name="email"
        placeholder={placeholder}
        required
        class="flex-1 h-full px-4 text-[16px] bg-transparent font-body focus:outline-none"
        style="color: rgb(var(--color-foreground) / 0.9); border: none;"
      />
      <button
        type="submit"
        class="h-[32px] px-2 mx-3 text-[12px] font-normal uppercase cursor-pointer transition-opacity hover:opacity-80 font-body whitespace-nowrap"
        style="background: rgb(var(--color-foreground)); color: rgb(var(--color-background)); border: none; border-radius: var(--radius-button);"
      >
        {buttonText}
      </button>
    </form>
  </div>
</section>
<script is:inline>
  // Wire newsletter form to the storefront gateway endpoint.
  // - store_id comes from window.__MERFY_CONFIG__.shopId (set by BaseLayout).
  // - When __MERFY_CONFIG__.apiUrl differs from prod (preview / staging),
  //   we rebuild the action URL on the form so this block doesn't have to
  //   bake a host at build time.
  // This script keeps the form as a NATIVE POST submit — no fetch, no
  // success/error UI. {alreadySubscribed} / 429 handling lives in a future
  // JS-handler iteration; for MVP the browser shows the JSON response.
  (function () {
    function wire(form) {
      if (!form || form.__merfyNewsletterWired) return;
      form.__merfyNewsletterWired = true;
      var cfg = (typeof window !== 'undefined' && window.__MERFY_CONFIG__) || {};
      var hidden = form.querySelector('[data-newsletter-store-id]');
      if (hidden && cfg.shopId) {
        hidden.value = String(cfg.shopId);
      }
      if (cfg.apiUrl) {
        // Strip trailing slash, append the storefront path.
        var base = String(cfg.apiUrl).replace(/\/+$/, '');
        form.setAttribute('action', base + '/storefront/newsletter/subscribe');
      }
    }
    function init() {
      var forms = document.querySelectorAll('form[data-newsletter-form]');
      for (var i = 0; i < forms.length; i++) wire(forms[i]);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
