---
import {
  resolveMultiRowsButtonStyle,
  resolveMultiRowsImagePosition,
  resolveMultiRowsItemSize,
  resolveMultiRowsWidth,
  getVisibleMultiRowEntries,
  resolveMultiRowsButton,
  type MultiRowsProps,
} from './MultiRows.puckConfig';
import { MultiRowsClasses as C } from './MultiRows.classes';
import { PLACEHOLDER_ASSETS } from '../../runtime/placeholders';
import { sanitizeInline } from '../../runtime/rich-text';

interface Props extends MultiRowsProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  rows = [],
  padding,
} = raw as Props;

const colorScheme = raw.colorScheme as string | undefined;
const schemeClass = colorScheme ? `color-scheme-${String(colorScheme).replace('scheme-', '')}` : '';

// containerColorScheme — отдельная видимая схема контейнера рядов по Figma
// (мирроль rose-порта + паттерн CollapsibleSection / Catalog). Когда не задана —
// контейнер наследует схему секции (визуально не отличается).
const containerColorScheme = raw.containerColorScheme as string | undefined;
const containerSchemeClass = containerColorScheme
  ? `color-scheme-${String(containerColorScheme).replace('scheme-', '')}`
  : '';

// Section Height is the authored control and wins when present. Old revisions
// without it can still use their per-row size as a compatibility fallback.
const aspectKey = (s: unknown, fallback: 'small' | 'medium' | 'large') =>
  s === 'small' || s === 'medium' || s === 'large' ? s : fallback;

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';

// Pupa parity: nested heading object.
const headingObj = raw.heading as { text?: string; alignment?: string; size?: string } | string | undefined;
const headingText = typeof headingObj === 'string' ? headingObj : headingObj?.text;
const headingAlignment = (typeof headingObj === 'object' ? headingObj?.alignment : undefined) ?? raw.headingAlignment;
const headingSize = (typeof headingObj === 'object' ? headingObj?.size : undefined) ?? raw.headingSize;
const headingAlignClass =
  headingAlignment === 'left' ? 'text-left' :
  headingAlignment === 'right' ? 'text-right' :
  headingAlignment === 'center' ? 'text-center' : 'text-center';
const headingSizeClass =
  headingSize === 'large' ? 'text-4xl md:text-5xl' :
  headingSize === 'medium' ? 'text-3xl md:text-4xl' :
  headingSize === 'small' ? 'text-2xl md:text-3xl' : 'text-3xl md:text-4xl';

// Pupa: rowsPosition (alternate, left, right).
const rowsPosition = typeof raw.rowsPosition === 'string' ? raw.rowsPosition : '';
const alignment = raw.alignment === 'center' || raw.alignment === 'right' ? raw.alignment : 'left';
const textAlignmentClass = C.textAlignment[alignment];
const buttonStyle = resolveMultiRowsButtonStyle(raw.buttonStyle);
const buttonClass = buttonStyle === 'secondary' ? C.buttonSecondary : C.button;
const widthClass = C.width[resolveMultiRowsWidth(raw.width)];
const visibleRowEntries = getVisibleMultiRowEntries(rows);
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  style={paddingStyle}
>
  <div class:list={[C.container, widthClass, containerSchemeClass]}>
    {headingText && (
      <h2 class:list={['[font-family:var(--font-heading)] text-[rgb(var(--color-heading))]', headingAlignClass, headingSizeClass, 'mb-8 font-medium']} data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading"><Fragment set:html={sanitizeInline(headingText)} /></h2>
    )}
    <div class={C.stack}>
      {visibleRowEntries.map(({ item: row, originalIndex }, i: number) => {
        // Pupa: rowsPosition alternate → odd rows mirror.
        const imagePos = resolveMultiRowsImagePosition(rowsPosition, i, row.imagePosition);
        const variantKey = imagePos === 'right' ? 'imageRight' : 'imageLeft';
        const rowImage = row.image || row.imageUrl;
        const rowTitle = row.title ?? row.heading;
        const rowDescription = row.description ?? row.text;
        // Top-level Height wins; legacy per-row size is only a fallback.
        const rowAspectClass = C.imageAspect[resolveMultiRowsItemSize(raw.size, row.size)];
        const rowHeadingSizeClass = C.rowHeadingSize[aspectKey(row.headingSize, 'medium')];
        const rowTextSizeClass = C.rowTextSize[aspectKey(row.textSize, 'medium')];
        const button = resolveMultiRowsButton(row.button);
        return (
          <div
            class={C.row[variantKey]}
            data-row-id={row.id}
            data-image-position={imagePos}
            data-puck-subsection-parent={id}
            data-puck-subsection-index={originalIndex}
            data-puck-subsection-field="rows"
          >
            <div class={C.imageCol[variantKey]}>
              {rowImage ? (
                <img src={rowImage} alt={rowTitle ?? ''} class:list={[C.image, rowAspectClass]} loading="lazy" />
              ) : (
                <img src={PLACEHOLDER_ASSETS.landscape.multirows} alt="" class:list={[C.image, rowAspectClass]} aria-hidden="true" loading="lazy" />
              )}
            </div>
            <div class:list={[C.textCol[variantKey], C.textColBase, textAlignmentClass]}>
              {rowTitle && <h3 class:list={[C.rowHeading, rowHeadingSizeClass]}><Fragment set:html={sanitizeInline(rowTitle)} /></h3>}
              {rowDescription && <p class:list={[C.rowText, rowTextSizeClass]}>{rowDescription}</p>}
              {button && (
                <a href={button.href} class={buttonClass}>{button.text}</a>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
