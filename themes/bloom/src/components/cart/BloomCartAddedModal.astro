---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { DEFAULT_CATEGORY_HREF } from "../../data/categories";
---

<div
	data-cart-added-modal
	class="fixed inset-0 z-[120] hidden items-center justify-center px-4 py-8"
	aria-hidden="true"
>
	<button
		type="button"
		data-cart-modal-overlay
		class="absolute inset-0 bg-black/30 backdrop-blur-[2px]"
		aria-label="Закрыть окно"
	></button>

	<section
		role="dialog"
		aria-modal="true"
		aria-labelledby="cart-added-title"
		class="relative z-10 flex w-full max-w-[430px] translate-y-3 flex-col gap-6 rounded-[24px] border border-[#FFD4E5] bg-white p-5 opacity-0 shadow-[0_24px_80px_rgba(227,142,159,0.24)] transition-[opacity,transform] duration-300 ease-out md:max-w-[520px] md:p-6"
		data-cart-modal-card
	>
		<div class="flex items-start justify-between gap-4">
			<div class="flex flex-col gap-1">
				<p class="font-inter text-[12px] font-light uppercase leading-none tracking-[0.08em] text-[#E38E9F]">
					Bloom
				</p>
				<h2
					id="cart-added-title"
					class="font-urbanist text-[20px] font-normal uppercase leading-none text-[#000000] md:text-[24px]"
				>
					Товар добавлен в корзину
				</h2>
			</div>
			<button
				type="button"
				data-cart-modal-close
				class="flex size-9 shrink-0 items-center justify-center rounded-full bg-[#FDF4F6] text-[#E38E9F] transition-opacity hover:opacity-80"
				aria-label="Закрыть"
			>
				<NtIcon name="menu-close" sizeClass="size-5" />
			</button>
		</div>

		<div class="flex gap-4 rounded-[18px] border border-[#F5F5F5] bg-[#FFF9FB] p-3">
			<a
				href="#"
				data-cart-modal-product-link
				class="group block size-[96px] shrink-0 overflow-hidden rounded-[14px] bg-white md:size-[112px]"
			>
				<img
					src=""
					alt=""
					data-cart-modal-image
					width="112"
					height="112"
					decoding="async"
					class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
				/>
			</a>
			<div class="flex min-w-0 flex-1 flex-col justify-center gap-2">
				<a
					href="#"
					data-cart-modal-name
					class="font-inter text-[16px] font-light leading-[1.2] text-[#000000] transition-opacity hover:opacity-70 md:text-[18px]"
				></a>
				<p
					data-cart-modal-volume
					class="font-inter text-[14px] font-light leading-normal text-[#999999]"
				></p>
				<p
					data-cart-modal-price
					class="font-inter text-[16px] font-light leading-none text-[#000000]"
				></p>
			</div>
		</div>

		<div class="grid gap-3">
			<a
				href="/cart"
				data-cart-modal-cart-link
				class="inline-flex h-12 items-center justify-center rounded-full bg-[#E38E9F] px-5 font-inter text-[16px] font-light leading-none text-white transition-opacity hover:opacity-90 active:scale-95"
			>
				В корзину
			</a>
			<a
				href="/cart"
				data-cart-modal-buy-now
				class="inline-flex h-12 items-center justify-center rounded-full border border-[#E38E9F] bg-white px-5 font-inter text-[16px] font-light leading-none text-[#E38E9F] transition-colors hover:bg-[#FDF4F6] active:scale-95"
			>
				Купить сейчас
			</a>
			<button
				type="button"
				data-cart-modal-continue
				data-continue-href={DEFAULT_CATEGORY_HREF}
				class="inline-flex h-12 items-center justify-center rounded-full bg-[#FDF4F6] px-5 font-inter text-[16px] font-light leading-none text-[#E38E9F] transition-opacity hover:opacity-80 active:scale-95"
			>
				Продолжить покупки
			</button>
		</div>
	</section>
</div>
