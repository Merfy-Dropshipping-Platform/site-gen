---
import NtPromoBanner from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtPromoBanner.astro";
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { SITE_TITLE } from "../consts";

interface NavLink {
	label: string;
	href: string;
	match?: (pathname: string) => boolean;
}

const defaultNav: NavLink[] = [
	{ label: "Главная", href: "/", match: (path) => path === "/" },
	{ label: "Смартфоны", href: "/catalog?collection=%D0%A1%D0%BC%D0%B0%D1%80%D1%82%D1%84%D0%BE%D0%BD%D1%8B", match: (path) => path.startsWith("/catalog") || path.startsWith("/products") },
	{ label: "Наушники", href: "/catalog?collection=%D0%9D%D0%B0%D1%83%D1%88%D0%BD%D0%B8%D0%BA%D0%B8" },
	{ label: "Ноутбуки", href: "/catalog?collection=%D0%9D%D0%BE%D1%83%D1%82%D0%B1%D1%83%D0%BA%D0%B8" },
	{ label: "Аксессуары", href: "/catalog?collection=%D0%90%D0%BA%D1%81%D0%B5%D1%81%D1%81%D1%83%D0%B0%D1%80%D1%8B" },
];

// ОЖИВЛЕНИЕ натянуто на ВЁРСТКУ ВЕРСТАЛЬЩИКОВ (эталон /tmp/flux-header-ref.astro):
// дефолтный Header (мерчант ничего не настроил) = two-tier верстальщика 1:1
// (Roboto Flex, py-6/gap-5/gap-8, size-8 desktop иконки, bg-white без border-b,
// промо-бар сверху); каждая настройка конструктора (logoPosition×4, menuType×3,
// stickiness, padding, nav, logo, colorScheme, wishlist) работает поверх этой
// вёрстки. Канон-схема theme-base Header.puckConfig — siteTitle, navigationLinks,
// logo, logoPosition, stickiness, padding, menuType, menuColorScheme.
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустая строка (впрыск коэрсера live-пути) не должна гасить название магазина.
const siteTitle = typeof p.siteTitle === "string" && p.siteTitle.trim() ? p.siteTitle : SITE_TITLE;
const nav: NavLink[] =
	Array.isArray(p.navigationLinks) && p.navigationLinks.length > 0
		? p.navigationLinks.map((l: any) => ({ label: l.label ?? l.text ?? "", href: l.href ?? l.link ?? "/" }))
		: defaultNav;

// Канон logo (URL картинки; панель «Логотип» пишет в props.logo): непустая строка →
// <img src={logo}> высотой var(--size-logo-width) в mobile И desktop. Дефолт flux
// (мерчант НЕ задал logo) = барчарт-SVG `/icons/logo-flux.svg` (эталон верстальщиков,
// 81×24, рендер h-6/24px). Текст-лого {siteTitle} остаётся ТОЛЬКО крайним фоллбэком —
// через alt дефолтного img (ассет не загрузился → браузер покажет alt = название).
const logo = typeof p.logo === "string" && p.logo.trim() ? p.logo : undefined;
const logoImgCls = "h-[var(--size-logo-width,24px)] w-auto max-w-[160px] object-contain";

// Канон actionButtons {showCart, showSearch, showProfile} (строки "true"/"false";
// панель «Кнопки действий»): show/hide трёх иконок шапки. Отсутствие/иное → показаны
// (дефолт = эталон верстальщиков: поиск + корзина + профиль).
const showSearch = String(p.actionButtons?.showSearch ?? "true") !== "false";
const showCart = String(p.actionButtons?.showCart ?? "true") !== "false";
const showProfile = String(p.actionButtons?.showProfile ?? "true") !== "false";

// Канон logoPosition: 'top-left' (canon-default = two-tier эталона) / 'top-center' /
// 'center-left' / 'center-absolute' (+ 'top-right' из enum → single-row). Отсутствие /
// неизвестное → 'top-left'. isTwoRow: два ряда (top-left, top-center); single-row:
// center-left / center-absolute / top-right.
const logoPosition = typeof p.logoPosition === "string" ? p.logoPosition : "";
const isTwoRow = logoPosition === "top-left" || logoPosition === "top-center";
// center-absolute: лого absolute по центру single-row
const isAbsoluteCenter = logoPosition === "center-absolute";
// center-left («Слева»): лого в потоке слева, nav центрируется ПО СТРАНИЦЕ через
// равные flex-1 фланги (лого + блок иконок), nav (auto) садится по центру.
const logoLeft = logoPosition === "center-left";

// Канон stickiness: дефолт puckConfig = 'scroll-up'. 'none' / 'always' / отсутствие →
// обычный sticky (= эталон верстальщика `sticky top-0 z-50`). 'scroll-up' → прячем при
// скролле вниз, показываем при скролле вверх: is:inline скрипт через data-атрибут
// (компилятор секций не умеет define:vars), идемпотентность через data-hydrated.
const stickiness = typeof p.stickiness === "string" ? p.stickiness : "";
const rootCls =
	stickiness === "scroll-up"
		? "sticky top-0 z-50 w-full transition-transform duration-300"
		: "sticky top-0 z-50 w-full";
const SCROLL_UP_JS = [
	"(function(){",
	"var root=document.querySelector('[data-flux-sticky=\"scroll-up\"]');",
	"if(!root||root.getAttribute('data-hydrated')==='true')return;",
	"root.setAttribute('data-hydrated','true');",
	"var last=window.scrollY;",
	"window.addEventListener('scroll',function(){",
	"var y=window.scrollY;",
	"if(y>last&&y>root.offsetHeight){root.style.transform='translateY(-100%)';}else{root.style.transform='';}",
	"last=y;",
	"},{passive:true});",
	"})();",
].join("");

// Канон padding {top,bottom} — носитель отступов десктопного ряда. Дефолт puckConfig =
// {12,12} → рендерим ЛИТЕРАЛ верстальщика py-6 (как и отсутствие padding); inline-стиль
// только при ином значении (clamp ≤64). Мобильная строка фиксирована h-20.
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const isCanonPad = pad && Number(pad.top) === 12 && Number(pad.bottom) === 12;
const headerPad =
	pad && !isCanonPad
		? { top: Math.min(Number(pad.top) || 0, 64), bottom: Math.min(Number(pad.bottom) || 0, 64) }
		: undefined;
const headerPadStyle = headerPad
	? `padding-top:${headerPad.top}px;padding-bottom:${headerPad.bottom}px;`
	: undefined;

// Канон menuType: 'dropdown' (по умолчанию) / 'mega-menu' (Расширенное) / 'sidebar'
// (Боковое). mega-menu → uppercase tracking к десктопным ссылкам. sidebar → десктопный
// inline-nav скрыт, hamburger открывает правую шторку.
const menuType = typeof p.menuType === "string" ? p.menuType : "dropdown";
const isMegaMenu = menuType === "mega-menu";
const isSidebar = menuType === "sidebar";
const megaLinkCls = isMegaMenu ? "tracking-[0.06em] font-medium" : "";

// Канон menuColorScheme: опциональная отдельная цветовая схема десктопного <nav>.
const menuColorScheme = typeof p.menuColorScheme === "string" ? p.menuColorScheme : "";
const menuSchemeClass = menuColorScheme ? `color-scheme-${menuColorScheme.replace("scheme-", "")}` : "";

const pathname = Astro.url.pathname;
const isActive = (link: NavLink) => (link.match ? link.match(pathname) : pathname === link.href);

// Бейдж счётчика (корзина) — эталон верстальщика: -right-1 -top-1,
// h-[18px] min-w-[18px], bg-[#FA5109], Roboto Flex 11px белый.
const badgeCls =
	"absolute -right-1 -top-1 inline-flex h-[18px] min-w-[18px] items-center justify-center rounded-full bg-[#FA5109] px-1 font-roboto-flex text-[11px] font-normal leading-none text-white data-[empty=true]:hidden";

// Лого всегда рендерится как <img> (мерчантский logo ИЛИ дефолтный барчарт-SVG) →
// якорь = img-ветка эталона h-6 (24px). isAbsoluteCenter центрирует лого в single-row.
const desktopLogoCls = `flex h-6 shrink-0 items-center hover:opacity-90${isAbsoluteCenter ? " md:absolute md:left-1/2 md:-translate-x-1/2" : ""}`;
const mobileLogoCls = "flex items-center hover:opacity-80";

// Десктопный flux-container эталона → носитель темы (как Footer/секции flux): 1920 + px-20/px-80.
const deskContainerBase = "mx-auto w-full max-w-[1920px] px-4 md:px-20 2xl:px-80";
// py-6 = вертикальный отступ верстальщика (дефолт); inline-стиль перебивает при настройке padding.
const deskPadCls = headerPad ? "" : "py-6";
const twoRowContainerCls = [deskContainerBase, "hidden flex-col gap-5 md:flex", deskPadCls].filter(Boolean).join(" ");
const singleRowContainerCls = [deskContainerBase, "hidden items-center justify-between md:flex", deskPadCls, isAbsoluteCenter ? "relative" : ""].filter(Boolean).join(" ");

// Пункт nav эталона: Roboto Flex 16px light; active чёрный, inactive #cccccc → hover чёрный.
// active/hover токенизированы (дефолт чёрный = эталон) → menuColorScheme их перекрашивает.
const navLinkBase = "font-roboto-flex text-[16px] font-light leading-normal transition-colors";
const navActiveCls = "text-[rgb(var(--color-text,0_0_0))]";
const navIdleCls = "text-[#cccccc] hover:text-[rgb(var(--color-text,0_0_0))]";
---

<div
	class={rootCls}
	data-flux-header
	data-puck-component-id={id}
	data-flux-sticky={stickiness === "scroll-up" ? "scroll-up" : undefined}
>
	{
		/* Встроенная полоса объявления — ТОЛЬКО статик-режим (без props.id):
		   в канон-композиции полоса = отдельная секция PromoBanner, иначе дубль. */
		!id && (
			<NtPromoBanner
				text="Бесплатная доставка на весь ассортимент до 30.06.2026."
				link="/catalog"
				linkText="Смотреть больше"
			/>
		)
	}

	<header
		class="w-full bg-[rgb(var(--color-bg,255_255_255))]"
		data-nt="flux-header"
	>
	<!-- Mobile (h-20): бургер слева | лого по центру (absolute) | wishlist+корзина справа -->
	<div class="relative z-[60] flex h-20 items-center justify-between bg-[rgb(var(--color-bg,255_255_255))] px-4 md:hidden">
		<button
			type="button"
			id="flux-burger-btn"
			data-burger-toggle
			class="flex size-8 items-center justify-center transition-opacity hover:opacity-70"
			aria-label="Меню"
			aria-expanded="false"
			aria-controls="flux-burger"
		>
			<span class="burger-icon" data-icon="open">
				<NtIcon name="menu-burger" sizeClass="size-6" />
			</span>
			<span class="burger-icon hidden" data-icon="close">
				<NtIcon name="menu-close" sizeClass="size-6" />
			</span>
		</button>
		<a href="/" class:list={["absolute left-1/2 -translate-x-1/2", mobileLogoCls]} aria-label={siteTitle}>
			{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : <img src="/icons/logo-flux.svg" alt={siteTitle} width="81" height="24" class="h-6 w-auto" />}
		</a>
		<div class="flex items-center gap-3">
			{showCart && (
				<button
					type="button"
					data-cart-open
					class="relative flex size-8 items-center justify-center"
					aria-label="Корзина"
				>
					<NtIcon name="cart" sizeClass="size-6" />
					<span data-cart-count data-empty="true" class={badgeCls}>0</span>
				</button>
			)}
		</div>
	</div>

	<!-- Desktop -->
	{isTwoRow ? (
		<div class={twoRowContainerCls} style={headerPadStyle}>
			{logoPosition === "top-center" ? (
				/* top-center: Row1=[search LEFT | logo CENTER | actions RIGHT], Row2=[nav CENTER] */
				<>
					<div class="grid w-full grid-cols-[1fr_auto_1fr] items-center">
						<div class="flex items-center">
							{showSearch && (
								<button
									type="button"
									data-action="toggle-search"
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Поиск"
								>
									<NtIcon name="search-lg" sizeClass="size-8" />
								</button>
							)}
						</div>
						<div class="flex items-center justify-center">
							<a href="/" class={desktopLogoCls} aria-label={siteTitle}>
								{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : <img src="/icons/logo-flux.svg" alt={siteTitle} width="81" height="24" class="h-6 w-auto" />}
							</a>
						</div>
						<div class="flex items-center justify-end gap-4">
							{showCart && (
								<button
									type="button"
									data-cart-open
									class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Корзина"
								>
									<NtIcon name="cart" sizeClass="size-8" />
									<span data-cart-count data-empty="true" class={badgeCls}>0</span>
								</button>
							)}
							{showProfile && (
								<a
									href="/login" data-auth-link
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Аккаунт"
								>
									<NtIcon name="user" sizeClass="size-8" />
								</a>
							)}
							{isSidebar && (
								<button
									type="button"
									data-burger-toggle
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Меню"
									aria-expanded="false"
									aria-controls="flux-burger"
								>
									<span class="burger-icon" data-icon="open">
										<NtIcon name="menu-burger" sizeClass="size-6" />
									</span>
									<span class="burger-icon hidden" data-icon="close">
										<NtIcon name="menu-close" sizeClass="size-6" />
									</span>
								</button>
							)}
						</div>
					</div>
					<nav
						class:list={["flex h-6 w-full items-center justify-center gap-8", menuSchemeClass, isSidebar && "md:!hidden"]}
						aria-label="Основная навигация" data-nav-inline
						data-puck-subsection-parent={id}
						data-puck-subsection-index="997"
						data-puck-subsection-field="navigationLinks"
					>
						{nav.map((link) => {
							const active = isActive(link);
							return (
								<a
									href={link.href}
									aria-current={active ? "page" : undefined}
									class:list={[navLinkBase, active ? navActiveCls : navIdleCls, megaLinkCls]}
								>
									{link.label}
								</a>
							);
						})}
					</nav>
				</>
			) : (
				/* top-left (designer default = two-tier эталона): Row1=[logo LEFT + actions RIGHT], Row2=[nav LEFT] */
				<>
					<div class="flex w-full items-center justify-between">
						<a href="/" class={desktopLogoCls} aria-label={siteTitle}>
							{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : <img src="/icons/logo-flux.svg" alt={siteTitle} width="81" height="24" class="h-6 w-auto" />}
						</a>
						<div class="flex items-center gap-4">
							{showSearch && (
								<button
									type="button"
									data-action="toggle-search"
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Поиск"
								>
									<NtIcon name="search-lg" sizeClass="size-8" />
								</button>
							)}
							{showCart && (
								<button
									type="button"
									data-cart-open
									class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Корзина"
								>
									<NtIcon name="cart" sizeClass="size-8" />
									<span data-cart-count data-empty="true" class={badgeCls}>0</span>
								</button>
							)}
							{showProfile && (
								<a
									href="/login" data-auth-link
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Аккаунт"
								>
									<NtIcon name="user" sizeClass="size-8" />
								</a>
							)}
							{isSidebar && (
								<button
									type="button"
									data-burger-toggle
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
									aria-label="Меню"
									aria-expanded="false"
									aria-controls="flux-burger"
								>
									<span class="burger-icon" data-icon="open">
										<NtIcon name="menu-burger" sizeClass="size-6" />
									</span>
									<span class="burger-icon hidden" data-icon="close">
										<NtIcon name="menu-close" sizeClass="size-6" />
									</span>
								</button>
							)}
						</div>
					</div>
					<nav
						class:list={["flex h-6 w-full items-center justify-start gap-8", menuSchemeClass, isSidebar && "md:!hidden"]}
						aria-label="Основная навигация" data-nav-inline
						data-puck-subsection-parent={id}
						data-puck-subsection-index="997"
						data-puck-subsection-field="navigationLinks"
					>
						{nav.map((link) => {
							const active = isActive(link);
							return (
								<a
									href={link.href}
									aria-current={active ? "page" : undefined}
									class:list={[navLinkBase, active ? navActiveCls : navIdleCls, megaLinkCls]}
								>
									{link.label}
								</a>
							);
						})}
					</nav>
				</>
			)}
		</div>
	) : (
		/* ── SINGLE-ROW LAYOUTS: center-left / center-absolute / top-right ── */
		<div class={singleRowContainerCls} style={headerPadStyle}>
			<a href="/" class:list={[desktopLogoCls, logoLeft && "flex-1"]} aria-label={siteTitle}>
				{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : <img src="/icons/logo-flux.svg" alt={siteTitle} width="81" height="24" class="h-6 w-auto" />}
			</a>

			<nav
				class:list={["flex items-center gap-8", menuSchemeClass, isSidebar && "md:!hidden"]}
				aria-label="Основная навигация" data-nav-inline
				data-puck-subsection-parent={id}
				data-puck-subsection-index="997"
				data-puck-subsection-field="navigationLinks"
			>
				{nav.map((link) => {
					const active = isActive(link);
					return (
						<a
							href={link.href}
							aria-current={active ? "page" : undefined}
							class:list={[navLinkBase, active ? navActiveCls : navIdleCls, megaLinkCls]}
						>
							{link.label}
						</a>
					);
				})}
			</nav>

			<div class:list={["flex items-center gap-4", logoLeft && "flex-1 justify-end"]}>
				{showSearch && (
					<button
						type="button"
						data-action="toggle-search"
						class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Поиск"
					>
						<NtIcon name="search-lg" sizeClass="size-8" />
					</button>
				)}
				{showCart && (
					<button
						type="button"
						data-cart-open
						class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Корзина"
					>
						<NtIcon name="cart" sizeClass="size-8" />
						<span data-cart-count data-empty="true" class={badgeCls}>0</span>
					</button>
				)}
				{showProfile && (
					<a
						href="/login" data-auth-link
						class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Аккаунт"
					>
						<NtIcon name="user" sizeClass="size-8" />
					</a>
				)}
				{isSidebar && (
					<button
						type="button"
						data-burger-toggle
						class="flex size-8 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Меню"
						aria-expanded="false"
						aria-controls="flux-burger"
					>
						<span class="burger-icon" data-icon="open">
							<NtIcon name="menu-burger" sizeClass="size-6" />
						</span>
						<span class="burger-icon hidden" data-icon="close">
							<NtIcon name="menu-close" sizeClass="size-6" />
						</span>
					</button>
				)}
			</div>
		</div>
	)}

	<!-- Desktop Search Panel (expandable) — эталон: border-t #F5F5F5, форма h-16 rounded-8 border #FA5109 -->
	<div
		data-search-panel
		class="hidden w-full border-t border-[#F5F5F5] bg-[rgb(var(--color-bg,255_255_255))] py-4"
		hidden
	>
		<div class={deskContainerBase}>
			<form role="search" action="/catalog" method="get" class="flex h-16 w-full items-center justify-between gap-2 rounded-[8px] border border-[#FA5109] bg-white pl-4 pr-2">
				<input
					type="search"
					name="q"
					placeholder="Поиск..."
					aria-label="Поиск"
					class="min-w-0 flex-1 bg-transparent font-roboto-flex text-[16px] font-light leading-normal text-[#000000] placeholder:text-[#cccccc] outline-none"
				/>
				<button
					type="submit"
					class="flex h-12 shrink-0 items-center justify-center rounded-[8px] bg-[#FA5109] px-4 py-2 font-roboto-flex text-[14px] font-normal leading-normal text-white transition-opacity hover:opacity-95"
				>
					Найти
				</button>
			</form>
		</div>
	</div>
	</header>

	<!-- Мобильный бургер / Desktop sidebar drawer -->
	<div
		id="flux-burger"
		class:list={[
			"fixed z-[55] hidden overflow-y-auto bg-white",
			isSidebar
				? "inset-y-0 right-0 bottom-0 w-[360px] max-w-[90vw] px-6 pt-6 pb-8"
				: "inset-x-0 top-[80px] bottom-0 w-full px-4 pt-4 pb-8 md:hidden",
		]}
		role="dialog"
		aria-modal="true"
		aria-label="Меню"
	>
		{isSidebar ? (
			/* Sidebar drawer: logo + cart at top */
			<div class="flex items-center justify-between">
				<a href="/" class={mobileLogoCls} aria-label={siteTitle}>
					{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : <img src="/icons/logo-flux.svg" alt={siteTitle} width="81" height="24" class="h-6 w-auto" />}
				</a>
				<div class="flex items-center gap-3">
					{showCart && (
						<button
							type="button"
							data-cart-open
							class="relative flex size-10 shrink-0 items-center justify-center transition-opacity hover:opacity-80"
							aria-label="Корзина"
						>
							<NtIcon name="cart" sizeClass="size-6" />
							<span data-cart-count data-empty="true" class={badgeCls}>0</span>
						</button>
					)}
				</div>
			</div>
		) : (
			/* Mobile drawer (эталон): поиск + профиль сверху */
			<div class="flex items-center gap-2">
				{showSearch && (
					<form class="flex h-11 min-h-11 flex-1 items-center justify-between rounded-[4px] border border-[#F5F5F5] bg-white pl-3 pr-2" role="search" action="/catalog" method="get">
						<input
							type="search"
							name="q"
							placeholder="Поиск"
							class="min-w-0 flex-1 bg-transparent font-roboto-flex text-[16px] font-light leading-normal text-[#000000] placeholder:text-[#cccccc] outline-none"
						/>
						<button type="submit" class="flex h-6 w-6 shrink-0 items-center justify-center" aria-label="Найти">
							<NtIcon name="search-sm" sizeClass="size-6" />
						</button>
					</form>
				)}
				{showProfile && (
					<a
						href="/login" data-auth-link
						class="flex size-11 shrink-0 items-center justify-center rounded-[4px] bg-black"
						aria-label="Профиль"
					>
						<NtIcon name="user" sizeClass="size-8" class="invert" />
					</a>
				)}
			</div>
		)}

		<nav class:list={["flex flex-col gap-3", isSidebar ? "mt-6" : "mt-[52px]"]} aria-label="Основное меню" data-nav-drawer>
			{nav.filter((l) => l.href !== "/").map((link) => {
				const active = isActive(link);
				return (
					<a
						href={link.href}
						class:list={[
							"flex h-11 items-center justify-between rounded-[4px] px-3 pr-[10px] font-roboto-flex text-[16px] leading-normal",
							active ? "bg-black font-normal text-white" : "font-light text-black",
						]}
					>
						<span>{link.label}</span>
						<NtIcon name="arrow-slide-right" sizeClass="size-6" class={active ? "invert" : ""} />
					</a>
				);
			})}
		</nav>
	</div>

	{stickiness === "scroll-up" && <script is:inline set:html={SCROLL_UP_JS} />}
</div>

<script>
	const syncBurgerButtonIcons = (open: boolean) => {
		// Update ALL burger toggle buttons (mobile #flux-burger-btn + desktop [data-burger-toggle])
		document.querySelectorAll<HTMLElement>("[data-burger-toggle]").forEach((btn) => {
			btn.setAttribute("aria-expanded", String(open));
			btn.querySelectorAll<HTMLElement>(".burger-icon").forEach((el) => {
				const key = el.dataset.icon;
				if (key === "open") el.classList.toggle("hidden", open);
				else el.classList.toggle("hidden", !open);
			});
		});
	};

	const setBurger = (open: boolean) => {
		const burger = document.getElementById("flux-burger");
		if (!burger) return;
		burger.classList.toggle("hidden", !open);
		syncBurgerButtonIcons(open);
		document.body.style.overflow = open ? "hidden" : "";
	};

	const syncFluxAfterNavigation = () => {
		document.body.style.overflow = "";
		const burger = document.getElementById("flux-burger");
		if (burger) burger.classList.add("hidden");
		syncBurgerButtonIcons(false);
	};

	let fluxDelegatesBound = false;
	const bindFluxDelegatedClicks = () => {
		if (fluxDelegatesBound) return;
		fluxDelegatesBound = true;

		document.addEventListener("click", (event: MouseEvent) => {
			const raw = event.target;
			const el = raw instanceof Element ? raw : null;
			if (!el) return;

			if (el.closest("[data-burger-toggle]")) {
				const burger = document.getElementById("flux-burger");
				if (!burger) return;
				event.preventDefault();
				setBurger(burger.classList.contains("hidden"));
				return;
			}

			if (el.closest("[data-action='toggle-search']")) {
				event.preventDefault();
				const panel = document.querySelector<HTMLElement>("[data-search-panel]");
				if (!panel) return;
				const hidden = panel.hasAttribute("hidden");
				if (hidden) {
					panel.removeAttribute("hidden");
					panel.classList.remove("hidden");
					panel.classList.add("block");
					panel.querySelector<HTMLInputElement>("input[type='search']")?.focus();
				} else {
					panel.setAttribute("hidden", "");
					panel.classList.add("hidden");
					panel.classList.remove("block");
				}
				return;
			}

			if (el.closest("#flux-burger a[href]")) {
				setBurger(false);
			}
		});
	};

	bindFluxDelegatedClicks();
	document.addEventListener("astro:page-load", syncFluxAfterNavigation);
	syncFluxAfterNavigation();
</script>
