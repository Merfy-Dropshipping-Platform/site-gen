---
// Секция «Корзина» (rose-порт, Spec 110) — список товаров + пустое состояние.
// Разбита из монолита CartSection.astro: товары здесь, сводка («Итого» + «Оформить»)
// — в соседнем блоке CartSummary. Логика корзины не изменена (та же ванильная
// getCart/render + cart-store.js/cart-api.js). Рантайм rose (getCart / rose:cart:updated)
// несовместим с nt-cart theme-base → свой порт. maxInstances:1 → document.querySelector
// безопасен (нет дубля). Этот блок грузит рантайм корзины ОДИН раз на странице
// (он неудаляем и всегда присутствует), CartSummary только читает getCart().
import { withBase } from "../../lib/with-base";

interface Props {
	id?: string;
	padding?: { top: number; bottom: number };
	colorScheme?: number | string;
}
const { id, padding, colorScheme } = Astro.props as Props;

const deleteIconSrc = withBase("/icons/delete.svg");
// Мост корзины → checkout: build.service.ts патчит `const shopId = ""` → siteId на деплое.
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";
// Отступы из конструктора (px, 0..160). Дефолт «Корзина»: сверху 80, снизу 40.
const pad = padding ?? { top: 80, bottom: 40 };
const padStyle = `padding-top:${Math.min(Number(pad.top) || 0, 160)}px;padding-bottom:${Math.min(Number(pad.bottom) || 0, 160)}px;`;
// Цветовая схема секции (как Newsletter/монолит): пусто → scheme-2 (белая в pupa).
const schemeClass = `color-scheme-${String(colorScheme ?? 2).replace("scheme-", "")}`;
---

<section
	data-puck-component-id={id}
	data-block="cart-body"
	class:list={[
		"w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 sm:px-5 md:px-10 lg:px-16 xl:px-20 2xl:px-[280px]",
		schemeClass,
	]}
	style={padStyle}
	aria-labelledby="cart-title"
>
	<!-- data-rc-preserve: контент рендерится на клиенте (getCart) и его нет в SSR.
	     При reconcile-морфе превью обёртка секции обновляется (отступы/схема), а этот
	     контейнер пропускается → товары/пустое состояние не сбрасываются и не мигают. -->
	<div id="rc-cart-body-content" data-rc-preserve class="mx-auto flex w-full max-w-[1320px] flex-col">
		<!-- Пустое состояние -->
		<div
			data-cart-page-empty
			class="flex flex-col items-center gap-4 py-10 sm:gap-6 md:py-16"
		>
			<h1 id="cart-title" class="rose-title">
				Корзина
			</h1>
			<p class="rose-subtitle text-center max-w-md">
				Вы пока не добавили товар в корзину.
			</p>
			<a
				href="/catalog"
				class="inline-flex h-12 items-center justify-center rounded-[var(--radius-button,6px)] bg-[rgb(var(--color-button-bg,0_0_0))] px-6 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-95 sm:text-[16px]"
			>
				Продолжить покупки
			</a>
			<p class="font-manrope text-[12px] font-normal leading-[1.43] text-[rgb(var(--color-muted,153_153_153))] sm:text-[14px] md:text-[16px]">
				Есть аккаунт?
				<a href="/auth/sign-in" class="text-[rgb(var(--color-text,0_0_0))] hover:opacity-80">Войти</a>
			</p>
		</div>

		<!-- Наполненная корзина: товары -->
		<div
			data-cart-page-filled
			class="hidden flex-col gap-10 lg:gap-12"
		>
			<h1 class="rose-title">
				Корзина
			</h1>
			<ul
				data-cart-page-items
				role="list"
				class="flex flex-col gap-4 sm:gap-6"
			></ul>
		</div>
	</div>
</section>

<script>
	import { getCart, formatCartPrice } from "../../lib/cart";
	import { cartLineThumbPictureHtml } from "../../lib/cart-thumb-html";

	const VARIANT_COLOR_LABELS: Record<string, string> = {
		brown: "Коричневый",
		black: "Чёрный",
		white: "Белый",
		olive: "Оливковый",
		gray: "Серый",
	};

	const render = () => {
		const lines = getCart();
		// Перезапрашиваем узлы каждый раз: после reconcile-морфа превью (смена
		// настроек) idiomorph мог пересоздать DOM секции — захваченные один раз
		// ссылки стали бы «битыми», и тоггл пусто/товары не применился бы.
		const emptyBlock = document.querySelector<HTMLElement>("[data-cart-page-empty]");
		const filledBlock = document.querySelector<HTMLElement>("[data-cart-page-filled]");
		const itemsEl = document.querySelector<HTMLElement>("[data-cart-page-items]");
		if (!emptyBlock || !filledBlock || !itemsEl) return;
		if (lines.length === 0) {
			emptyBlock.classList.remove("hidden");
			emptyBlock.classList.add("flex");
			filledBlock.classList.add("hidden");
			filledBlock.classList.remove("flex");
			return;
		}
		emptyBlock.classList.add("hidden");
		emptyBlock.classList.remove("flex");
		filledBlock.classList.remove("hidden");
		filledBlock.classList.add("flex");

		itemsEl.innerHTML = lines
			.map((line) => {
				const slug = line.variant?.color ?? "";
				const colorLabel = slug ? (VARIANT_COLOR_LABELS[slug] ?? slug) : "";
				const sizePart = line.variant?.size ?? "";
				const variantUnderPrice = [colorLabel, sizePart].filter(Boolean).join(", ");
				const totalCurrent = formatCartPrice(line.price * line.quantity);
				const totalOld =
					typeof line.oldPrice === "number" && line.oldPrice > line.price
						? formatCartPrice(line.oldPrice * line.quantity)
						: "";

				return `
					<li class="flex gap-4 sm:gap-6 md:flex-row md:items-start md:justify-between" data-line-id="${line.id}">
						<div class="flex min-w-0 flex-1 gap-3 sm:gap-4">
							<a href="/products/${line.productId}" class="block size-20 shrink-0 overflow-hidden rounded-[var(--radius-media,8px)] bg-[#F5F5F5] sm:size-24 md:size-[120px]">
								${cartLineThumbPictureHtml(line.image, line.name)}
							</a>
							<div class="flex min-w-0 flex-col gap-2">
								<a href="/products/${line.productId}" class="font-manrope text-[14px] font-normal leading-none tracking-normal text-[rgb(var(--color-text,0_0_0))] hover:opacity-80 sm:text-[15px] md:text-[18px]">${line.name}</a>
								<div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
									<span class="font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] sm:text-[16px] md:text-[18px]">${totalCurrent}</span>
									${
										totalOld
											? `<span class="font-manrope text-[13px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] line-through sm:text-[14px] md:text-[16px]">${totalOld}</span>`
											: ""
									}
								</div>
								${
									variantUnderPrice
										? `<p class="font-manrope text-[12px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] sm:text-[13px] md:text-[14px]">${variantUnderPrice}</p>`
										: ""
								}
							</div>
						</div>
						<div class="flex shrink-0 flex-col items-end gap-3 self-start md:gap-4">
							<button type="button" data-cart-remove data-id="${
								line.id
							}" class="flex size-9 items-center justify-center rounded-[var(--radius-button,8px)] text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:bg-[#F5F5F5] hover:opacity-80 md:size-10" aria-label="Удалить товар из корзины">
								<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="pointer-events-none size-[22px] md:size-6" aria-hidden="true"><path d="M4 7h16M10 7V5a1 1 0 011-1h2a1 1 0 011 1v2M6 7l1 14a1 1 0 001 1h8a1 1 0 001-1l1-14M10 11v6M14 11v6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
							</button>
							<div class="inline-flex h-10 items-center rounded-[var(--radius-input,8px)] border border-solid border-[#E5E5E5]">
								<button type="button" data-cart-dec data-id="${line.id}" class="flex h-10 w-10 items-center justify-center font-manrope text-[16px] text-[rgb(var(--color-text,0_0_0))]" aria-label="Уменьшить">−</button>
								<span class="min-w-[28px] text-center font-manrope text-[12px] text-[rgb(var(--color-text,0_0_0))] sm:text-[14px]">${line.quantity}</span>
								<button type="button" data-cart-inc data-id="${line.id}" class="flex h-10 w-10 items-center justify-center font-manrope text-[16px] text-[rgb(var(--color-text,0_0_0))]" aria-label="Увеличить">+</button>
							</div>
						</div>
					</li>
				`;
			})
			.join("");
	};

	render();
	document.addEventListener("astro:page-load", render);
	window.addEventListener("rose:cart:updated", render);
</script>

{/* Мост корзины → backend cart: грузим cartStore + конфиг (shopId патчится на деплое). */}
<script is:inline define:vars={{ shopId, apiUrl, deleteIconSrc }}>
	window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
		shopId: shopId || "",
		apiUrl: apiUrl || "https://gateway.merfy.ru/api",
	};
	window.__ROSE_DELETE_ICON__ = deleteIconSrc;
</script>
<script is:inline type="module" src="/scripts/cart-api.js"></script>
<script is:inline type="module" src="/scripts/cart-store.js"></script>
