---
import type { PopularProductsProps } from './PopularProducts.puckConfig';
import { PopularProductsClasses as C } from './PopularProducts.classes';

interface Props extends PopularProductsProps {
  id?: string;
}

const {
  id,
  heading,
  subtitle,
  cards = 4,
  columns = 4,
  colorScheme = 1,
  padding,
} = Astro.props as Props & { subtitle?: string };

const scheme = `color-scheme-${colorScheme}`;
const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
const gridTemplateCols = `grid-template-columns: repeat(${columns}, minmax(0, 1fr));`;
// Placeholders only render when the site explicitly asks for them via
// `dataSource: 'placeholder'`. Live storefronts omit them and just show
// the heading + CTA (matches seeds where `dataSource: 'auto'` resolves to
// real product cards, else empty grid). Without this gate preview pads
// the page with 6 grey boxes that don't exist on the live site.
const showPlaceholders = (Astro.props as { dataSource?: string }).dataSource === 'placeholder';
const placeholders = showPlaceholders ? Array.from({ length: cards }, (_, i) => i) : [];
---
<section
  class:list={[C.root, scheme]}
  data-puck-component-id={id}
  data-block="popular-products"
  style={paddingStyle}
>
  <div class={C.container}>
    {heading && <h2 class={C.heading}>{heading}</h2>}
    {subtitle && <p class={C.subtitle}>{subtitle}</p>}
    <div class={C.grid} style={gridTemplateCols}>
      {placeholders.map((i) => (
        <div
          class={C.placeholderCard}
          aria-label="Product placeholder"
          data-product-index={i}
        >
          <div class={C.placeholderMedia}></div>
          <div class={C.placeholderBody}>
            <div class={C.placeholderTitle}></div>
            <div class={C.placeholderPrice}></div>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-8">
      <a
        href="#popular"
        class="inline-block px-6 py-2.5 text-[16px] font-normal [font-family:var(--font-body)] bg-[rgb(var(--color-button-bg))] text-[rgb(var(--color-button-text))] rounded-[var(--radius-button)] hover:opacity-90 transition-colors no-underline"
      >
        Смотреть все
      </a>
    </div>
  </div>
</section>
