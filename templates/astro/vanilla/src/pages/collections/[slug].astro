---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CatalogIsland from '../../components/react/CatalogIsland';
import collectionsData from '../../data/collections.json';
import productsData from '../../data/products.json';

export function getStaticPaths() {
  const cols: any[] = Array.isArray(collectionsData) ? collectionsData : [];

  // Always generate at least a fallback path
  if (cols.length === 0) {
    return [{ params: { slug: '_placeholder' }, props: { collection: null } }];
  }

  // Generate a path for every reachable identifier (id, slug, handle)
  // so that links from blocks/admin still resolve regardless of which one
  // they used.
  const paths: { params: { slug: string }; props: { collection: any } }[] = [];
  const seen = new Set<string>();
  for (const c of cols) {
    for (const slug of [c.id, c.slug, c.handle].filter(Boolean) as string[]) {
      if (seen.has(slug)) continue;
      seen.add(slug);
      paths.push({ params: { slug }, props: { collection: c } });
    }
  }
  return paths;
}

const { slug } = Astro.params;
const { collection } = Astro.props;

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};

const title = collection?.title ?? collection?.name ?? slug ?? 'Коллекция';

const apiUrl = ((meta as any)?.apiUrl as string) ?? 'https://gateway.merfy.ru/api';
const shopId = ((meta as any)?.shopId as string) ?? '';
const toKopecks = (v: unknown): number => {
  const n = typeof v === 'string' ? parseFloat(v) : typeof v === 'number' ? v : 0;
  return Number.isFinite(n) ? Math.round(n * 100) : 0;
};
const collectionId: string | undefined = (collection as any)?.id;
const collectionProductIds: Set<string> = new Set(
  (collection as any)?.productIds && Array.isArray((collection as any).productIds)
    ? ((collection as any).productIds as string[])
    : [],
);
const filteredProducts = (productsData as any[]).filter((p: any) => {
  if (collectionProductIds.size > 0) return collectionProductIds.has(p.id);
  return true;
});
const initialProducts = filteredProducts.slice(0, 8).map((p: any) => ({
  id: p.id,
  handle: p.handle ?? p.slug ?? p.id,
  title: p.title ?? p.name,
  description: p.description,
  price: p.basePrice != null ? toKopecks(p.basePrice) : toKopecks(p.price),
  compareAtPrice: p.compareAtPrice ? toKopecks(p.compareAtPrice) : undefined,
  images: ((p.images ?? []) as any[]).map((img) =>
    typeof img === 'string' ? { url: img } : img,
  ),
  variants: p.variants ?? p.variantCombinations ?? [],
}));
const initialCollections = (collectionsData as any[]).map((c: any) => ({
  id: c.id,
  handle: c.handle ?? c.slug ?? c.id,
  title: c.title ?? c.name,
  description: c.description,
  image: c.image ? (typeof c.image === 'string' ? { url: c.image } : c.image) : undefined,
}));
const initialTotal = filteredProducts.length;
---
<BaseLayout title={`${title} — ${meta?.title ?? 'Мой сайт'}`} description={collection?.description ?? meta?.description}>
  <Header {...headerProps} />

  <main class="flex-1 w-full" style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));">
    <div class="max-w-[1320px] mx-auto px-4 sm:px-6 py-[75px]">
      <div class="text-center mb-10">
        <p class="mb-4 text-sm font-body" style="color: rgb(var(--color-muted));">
          <a href="/" class="hover:underline" style="color: rgb(var(--color-muted));">Главная</a>
          <span class="mx-1">/</span>
          <a href="/catalog" class="hover:underline" style="color: rgb(var(--color-muted));">Каталог</a>
          <span class="mx-1">/</span>
          {title}
        </p>
        <h1 class="text-4xl font-heading" style="color: rgb(var(--color-foreground));">{title}</h1>
        {collection?.description && (
          <p class="mt-3 font-body max-w-2xl mx-auto" style="color: rgb(var(--color-muted));">{collection.description}</p>
        )}
      </div>

    <CatalogIsland
      client:load
      collectionSlug={slug}
      showCollectionFilter={false}
      shopId={shopId}
      apiBase={apiUrl}
      initialProducts={initialProducts}
      initialTotal={initialTotal}
      initialCollections={initialCollections}
      initialCollectionId={collectionId}
    />
  </main>

  <Footer {...footerProps} />
</BaseLayout>
