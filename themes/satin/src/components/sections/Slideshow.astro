---
// НОВАЯ канон-секция Slideshow (Фаза B, рецепт bloom Slideshow): полотно слайда =
// about-герой верстальщика (about.astro:37-57) — фото full-bleed на подложке
// #111111 + штатный градиент bg-gradient-to-b from-black/30 to-black/45 +
// центрированный белый контент (кикер → заголовок Kelly Slab → белый контур-CTA).
// Схема полей — packages/theme-base/blocks/Slideshow/Slideshow.puckConfig.ts.
// Параметры скрипту — ТОЛЬКО data-атрибуты (define:vars компилятор секций не
// умеет); идемпотентность — data-slideshow-hydrated; реинициализация —
// astro:page-load (его шлёт превью-агент после hot-replace).
const p = Astro.props as Record<string, any>;
const id = p.id;

// КОНТРАКТ ПЛЕЙСХОЛДЕРОВ (Figma 1:19335 — пустое состояние секции, ЗАМЕНЯЕТ
// мок-демо верстальщика). Эталон: theme-base Slideshow.astro + satin
// ImageWithText.astro / Gallery.astro (пустой image-rect surface + заголовок
// секции + поясняющий текст + Кнопка + точки-навигация). Гейт = наличие
// реальных слайдов у мерчанта (p.slides[] непустой). Нет ни одного слайда →
// пустое состояние = ПЛЕЙСХОЛДЕР (НЕ 3 мок-слайда «Там, где классика…» с фото-
// кампаниями верстальщика /images/4x/*.png).
const hasSlides = Array.isArray(p.slides) && p.slides.length > 0;

// Лейблы пустого состояния (контракт Figma 1:19335 «Слайд-шоу»: заголовок секции
// + поясняющий текст + Кнопка). Один слайд-болванка. Контракт картиночных секций
// (правило 2): фолбэк-картинка слайда = дизайн-ассет landscape-slideshow.png
// (/placeholders/landscape-slideshow.png, раздаётся на каждой теме) — картинка
// показывается ВСЕГДА, НЕ пустой image-rect и НЕ фото-кампания верстальщика.
// Эталон theme-base Slideshow.astro (PLACEHOLDER_ASSETS.landscape.slideshow).
const PLACEHOLDER_HEADING = "Слайд-шоу";
const PLACEHOLDER_TEXT = "Добавь несколько изображений с информацией о своём бренде";
const PLACEHOLDER_IMAGE = "/placeholders/landscape-slideshow.png";
const PLACEHOLDER_SLIDE = {
	id: "placeholder",
	imageUrl: PLACEHOLDER_IMAGE,
	heading: PLACEHOLDER_HEADING,
	subtitle: PLACEHOLDER_TEXT,
	ctaText: "Кнопка",
	ctaUrl: "/catalog",
};
const rawSlides = hasSlides ? p.slides : [PLACEHOLDER_SLIDE];

// Заголовок слайда — роль заголовка баннера (about.astro:51, Kelly Slab uppercase
// БЕЛЫЙ на фото): лестница §9 small 18/22 → medium 22/27 → large 26/32 = литерал
// (canon-носитель large, отсутствие = литерал).
const slideHeadingCls = (s: string | undefined) =>
	s === "small"
		? "font-logo text-[18px] font-normal uppercase leading-[1.1] text-white md:text-[22px]"
		: s === "medium"
			? "font-logo text-[22px] font-normal uppercase leading-[1.1] text-white md:text-[27px]"
			: "font-logo text-[26px] font-normal uppercase leading-[1.1] text-white md:text-[32px]";
// Кикер слайда — литерал about.astro:50 (Arsenal 16 400 uppercase tracking-[0.04em]
// #999999 → токен muted): лестница §9 small 11 → medium 14 → large 16 = литерал.
const slideTextCls = (s: string | undefined) =>
	s === "small"
		? "font-manrope text-[11px] font-normal uppercase tracking-[0.04em] text-[rgb(var(--color-muted,153_153_153))]"
		: s === "medium"
			? "font-manrope text-[14px] font-normal uppercase tracking-[0.04em] text-[rgb(var(--color-muted,153_153_153))]"
			: "font-manrope text-[16px] font-normal uppercase tracking-[0.04em] text-[rgb(var(--color-muted,153_153_153))]";

// Пустое состояние = ПЛЕЙСХОЛДЕР по контракту: слайд без своего фото рендерит
// пустой image-rect surface (НЕ кампанию верстальщика /images/4x/*.png). Реальный
// слайд мерчанта со своим imageUrl/image рендерится без изменений (см. JSX).
// Канон overlay 0-100 — «Затемнение» PER-SLIDE (паритет rose): дополнительный
// чёрный слой ПОВЕРХ штатного градиента about-полотна. Читаем s.overlay с fallback
// на section-level p.overlay (backward-compat). Хелпер ВЫШЕ маппинга slides.
const slideOverlayN = (s: any) => Math.max(0, Math.min(100, Number(s.overlay ?? p.overlay) || 0));
const slides = rawSlides.slice(0, 5).map((s: any, i: number) => {
	const ctaText =
		(typeof s.ctaText === "string" && s.ctaText.trim() ? s.ctaText : undefined) ??
		(typeof s.button?.text === "string" && s.button.text.trim() ? s.button.text : undefined);
	return {
		image:
			(typeof s.imageUrl === "string" && s.imageUrl.trim()) ||
			(typeof s.image === "string" && s.image.trim()) ||
			"",
		heading: typeof s.heading === "string" ? s.heading : (s.heading?.text ?? ""),
		headingCls: slideHeadingCls(typeof s.heading === "object" ? s.heading?.size : undefined),
		subtitle:
			(typeof s.subtitle === "string" && s.subtitle.trim() ? s.subtitle : undefined) ??
			(typeof s.text?.content === "string" && s.text.content.trim() ? s.text.content : undefined),
		textCls: slideTextCls(s.text?.size),
		ctaText,
		ctaHref:
			(typeof s.ctaUrl === "string" && s.ctaUrl ? s.ctaUrl : undefined) ??
			s.button?.link?.href ??
			(typeof s.button?.link === "string" && s.button.link ? s.button.link : undefined) ??
			"/catalog",
		boxed: String(s.container ?? "false") === "true",
		schemeCls:
			typeof s.colorScheme === "string" && s.colorScheme
				? ` color-scheme-${String(s.colorScheme).replace("scheme-", "")}`
				: "",
		// position per-slide (приоритет) | top-level contentAlign: 'center'
		// (canon-default puckConfig) И отсутствие = центр about-полотна (литерал
		// `justify-center px-4`, about.astro:47); left/right — в полях satin-pad.
		posCls:
			s.position === "left" || (!s.position && p.contentAlign === "left")
				? "satin-pad justify-start"
				: s.position === "right"
					? "satin-pad justify-end"
					: "justify-center px-4",
		// alignment per-slide: 'center' (canon-default) И отсутствие =
		// items-center text-center литерала about.astro:48-49.
		alignCls:
			s.alignment === "left"
				? "items-start text-left"
				: s.alignment === "right"
					? "items-end text-right"
					: "items-center text-center",
		overlayN: slideOverlayN(s),
		active: i === 0,
	};
});

// Канон interval (slider 1-20 c, схема до 60) / autoplay: canon-defaults 5 / true.
const intervalMs = String(
	(typeof p.interval === "number" && p.interval >= 1 && p.interval <= 60 ? p.interval : 5) * 1000,
);
const autoplay = p.autoplay === false || p.autoplay === "false" ? "false" : "true";

// Канон size: medium/отсутствие = 680px-полотно full-bleed манеры §2 (mobile
// aspect-[375/362], как Hero/ImageBanner); small 560, large 760.
const heightCls =
	p.size === "small" ? "md:h-[560px]" : p.size === "large" ? "md:h-[760px]" : "md:h-[680px]";

// Канон imagePosition: fullscreen (canon-default) и отсутствие = full-bleed
// литерал (обёртка 1920 манеры §2); contained (+legacy left/right) — контейнер
// 1320 в полях satin-pad с радиус-токеном медиа. imageFullBleed=true возвращает
// full-bleed.
const contained =
	(p.imagePosition === "contained" || p.imagePosition === "left" || p.imagePosition === "right") &&
	p.imageFullBleed !== true &&
	p.imageFullBleed !== "true";
// Пустое состояние (нет слайдов мерчанта) = ПЛЕЙСХОЛДЕР: слайд-болванка несёт
// дизайн-ассет landscape-slideshow.png (контракт картиночных секций, правило 2),
// поэтому полотно — тёмное about-полотно #111111 (как и с реальными данными),
// а НЕ светлая surface-подложка. isPlaceholder оставлен только для декоративных
// точек-навигации (1 слайд — листать нечего).
const isPlaceholder = !hasSlides;
const canvasBg = "bg-[#111111]";
const canvasCls = contained
	? `satin-container relative w-full overflow-hidden rounded-[var(--radius-media,0px)] ${canvasBg} aspect-[375/362] md:aspect-auto ${heightCls}`
	: `relative mx-auto w-full max-w-[1920px] overflow-hidden ${canvasBg} aspect-[375/362] md:aspect-auto ${heightCls}`;

// Канон overlay 0-100 — «Затемнение» PER-SLIDE: дополнительный чёрный слой ПОВЕРХ
// штатного градиента about-полотна (у верстальщика 0 — слоя нет). Хелпер
// slideOverlayN объявлен ВЫШЕ (перед маппингом slides); overlayN теперь поле слайда.

// Канон pagination: 'dots' (canon-default blockDefaults satin) и отсутствие =
// КВАДРАТЫ size-2 манеры нулевых радиусов (активная белая, неактивная white/50);
// numbers — Arsenal 14 белые; lines/counter/none — канон.
const pagination =
	p.pagination === "numbers" ||
	p.pagination === "lines" ||
	p.pagination === "counter" ||
	p.pagination === "none" ||
	p.pagination === "dots"
		? p.pagination
		: "numbers";

// Канон buttonStyle: outlined (canon-default blockDefaults satin) И отсутствие =
// ЛИТЕРАЛ верстальщика — белый контур на фото `satin-button satin-button-md
// text-white` (about.astro:55; бордер базы = currentColor → белый); solid =
// белая заливка в токенах кнопки-2 (255_255_255 / 0_0_0), реплика
// .satin-button-md утилитами (паттерн Hero §3).
const ctaCls =
	p.buttonStyle === "solid"
		? "inline-flex min-h-12 w-fit items-center justify-center rounded-[var(--radius-button,0px)] border border-solid border-[rgb(var(--color-button-2-bg,255_255_255))] bg-[rgb(var(--color-button-2-bg,255_255_255))] px-6 font-manrope text-[16px] font-normal uppercase leading-none text-[rgb(var(--color-button-2-text,0_0_0))] transition-opacity duration-[180ms] hover:opacity-[0.78]"
		: "satin-button satin-button-md text-white";
// (Пустое состояние теперь несёт дизайн-ассет landscape-slideshow.png → рендерится
// как обычный фото-слайд: белый текст/контурная белая CTA = ctaCls. Отдельные
// placeholder-классы для светлого rect больше не нужны — правило 2.)

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	class="relative w-full bg-[rgb(var(--color-bg,255_255_255))]"
	aria-label="Слайд-шоу"
	data-puck-component-id={id}
	data-satin-slideshow
	data-interval={intervalMs}
	data-autoplay={autoplay}
	style={paddingStyle}
>
	<div class={contained ? "satin-pad w-full" : "w-full"}>
		<div class={canvasCls}>
			{
				slides.map((s, i) => (
					<div
						data-slide
						class={`!absolute inset-0 transition-opacity duration-700 ease-out ${s.active ? "opacity-100" : "pointer-events-none opacity-0"}${s.schemeCls}`}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="slides"
					>
						{/* С данными — фото мерчанта + штатный градиент about-полотна
						    (литерал about.astro:46). Пустое состояние — дизайн-ассет
						    landscape-slideshow.png (контракт картиночных секций,
						    правило 2: картинка показывается ВСЕГДА) + тот же градиент. */}
						{s.image && (
							<>
								<img
									src={s.image}
									alt={s.heading || "Слайд"}
									loading={i === 0 ? "eager" : "lazy"}
									class="absolute inset-0 !h-full !w-full object-cover object-center"
								/>
								<div class="absolute inset-0 bg-gradient-to-b from-black/30 to-black/45" aria-hidden="true" />
							</>
						)}
						{s.overlayN > 0 && (
							<div
								class="pointer-events-none absolute inset-0 bg-black"
								style={`opacity:${s.overlayN / 100}`}
								aria-hidden="true"
							/>
						)}
						{/* Контент about-полотна: вертикальный центр, кикер → заголовок → CTA
						    (gap-8 / gap-2.5 — литерал about.astro:48-49). */}
						<div class={`absolute inset-0 z-10 flex items-center ${s.posCls}`}>
							<div class={`flex w-full max-w-[540px] flex-col gap-8 text-white ${s.alignCls}${s.boxed ? " rounded-[var(--radius-card,0px)] bg-black/45 p-6" : ""}`}>
								<div class={`flex flex-col gap-2.5 ${s.alignCls}`}>
									{s.subtitle && (
										<p
											class={s.textCls}
											data-puck-subsection-parent={id}
											data-puck-subsection-index="101"
											data-puck-subsection-field="text"
										>
											{s.subtitle}
										</p>
									)}
									{s.heading && (
										<h2
											class={s.headingCls}
											data-puck-subsection-parent={id}
											data-puck-subsection-index="100"
											data-puck-subsection-field="heading"
										>
											{s.heading}
										</h2>
									)}
								</div>
								{s.ctaText && (
									<a
										href={s.ctaHref}
										class={ctaCls}
										data-puck-subsection-parent={id}
										data-puck-subsection-index="102"
										data-puck-subsection-field="button"
									>
										{s.ctaText}
									</a>
								)}
							</div>
						</div>
					</div>
				))
			}

			{
				slides.length > 1 && (
					<>
						{/* Стрелки — квадраты манеры нулевых радиусов (§4). */}
						<button
							type="button"
							data-slide-prev
							aria-label="Предыдущий слайд"
							class="absolute left-4 top-1/2 z-20 flex size-10 -translate-y-1/2 items-center justify-center !bg-white/80 !text-black transition-opacity hover:opacity-80"
						>
							<svg class="size-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
								<path d="M12.5 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</button>
						<button
							type="button"
							data-slide-next
							aria-label="Следующий слайд"
							class="absolute right-4 top-1/2 z-20 flex size-10 -translate-y-1/2 items-center justify-center !bg-white/80 !text-black transition-opacity hover:opacity-80"
						>
							<svg class="size-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
								<path d="M7.5 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</button>
						{pagination !== "none" && (
							<div class="absolute bottom-5 left-1/2 z-20 flex -translate-x-1/2 items-center gap-2">
								{pagination === "dots" &&
									slides.map((_, i) => (
										<button
											type="button"
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											aria-label={`Слайд ${i + 1}`}
											class="size-2 !bg-white/50 transition-colors data-[active=true]:!bg-white"
										/>
									))}
								{pagination === "numbers" &&
									slides.map((_, i) => (
										<button
											type="button"
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											aria-label={`Слайд ${i + 1}`}
											class="font-manrope text-[14px] font-normal leading-none !text-white/50 transition-colors data-[active=true]:!text-white"
										>
											{i + 1}
										</button>
									))}
								{pagination === "lines" &&
									slides.map((_, i) => (
										<button
											type="button"
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											aria-label={`Слайд ${i + 1}`}
											class="h-0.5 w-6 !bg-white/50 transition-colors data-[active=true]:!bg-white"
										/>
									))}
								{pagination === "counter" &&
									slides.map((_, i) => (
										<span
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											class="font-manrope text-[14px] font-normal leading-none text-white data-[active=false]:hidden"
										>
											{/* Разделитель «/» — в ОТДЕЛЬНОМ <span>: голый « / » текст-нода манглится
											    preview-URL-rewriter'ом в «/__theme/satin/» (обёртка защищает — паритет
											    rose data-slide-counter). */}
											{i + 1}<span class="mx-1" aria-hidden="true">/</span>{slides.length}
										</span>
									))}
							</div>
						)}
					</>
				)
			}

			{/* Пустое состояние: декоративные точки-навигация по контракту
			    «Слайд-шоу» (1 слайд — листать нечего; точки БЕЛЫЕ на фото-полотне
			    landscape-slideshow.png, без data-slide-dot чтобы скрипт их не трогал). */}
			{
				isPlaceholder && pagination !== "none" && (
					<div class="absolute bottom-5 left-1/2 z-20 flex -translate-x-1/2 items-center gap-2">
						{[0, 1, 2].map((i) => (
							<span
								aria-hidden="true"
								class={`size-2 ${i === 0 ? "bg-white" : "bg-white/50"}`}
							/>
						))}
					</div>
				)
			}
		</div>
	</div>
</section>

<script is:inline>
	(function () {
		function initOne(root) {
			if (root.dataset.slideshowHydrated === "true") return;
			root.dataset.slideshowHydrated = "true";
			var interval = parseInt(root.dataset.interval || "5000", 10);
			var autoplay = root.dataset.autoplay !== "false";
			var slides = root.querySelectorAll("[data-slide]");
			var dots = root.querySelectorAll("[data-slide-dot]");
			if (slides.length < 2) return;
			var idx = 0,
				timer = null;
			function show(n) {
				idx = (n + slides.length) % slides.length;
				for (var j = 0; j < slides.length; j++) {
					slides[j].style.opacity = j === idx ? "1" : "0";
					slides[j].style.pointerEvents = j === idx ? "auto" : "none";
				}
				for (var k = 0; k < dots.length; k++) {
					dots[k].setAttribute("data-active", k === idx ? "true" : "false");
				}
			}
			function restart() {
				if (timer) clearInterval(timer);
				if (autoplay)
					timer = setInterval(function () {
						show(idx + 1);
					}, interval);
			}
			root.querySelectorAll("[data-slide-prev]").forEach(function (b) {
				b.addEventListener("click", function () {
					show(idx - 1);
					restart();
				});
			});
			root.querySelectorAll("[data-slide-next]").forEach(function (b) {
				b.addEventListener("click", function () {
					show(idx + 1);
					restart();
				});
			});
			dots.forEach(function (d, i) {
				d.addEventListener("click", function () {
					show(i);
					restart();
				});
			});
			show(0);
			restart();
		}
		function initAll() {
			var roots = document.querySelectorAll("[data-satin-slideshow]");
			for (var k = 0; k < roots.length; k++) initOne(roots[k]);
		}
		initAll();
		// Hot-replace превью вставляет секцию заново (новый узел без флага) и шлёт
		// astro:page-load — реинициализация подхватит свежий слайдер.
		document.addEventListener("astro:page-load", initAll);
	})();
</script>
