---
// Bloom Catalog — Puck shell. The real toolbar+grid+show-more is mounted by
// `templates/astro/bloom/src/pages/catalog.astro` which imports CatalogIsland
// directly and inlines it for blocks of type "Catalog".
//
// This component intentionally does NOT import CatalogIsland.tsx because the
// constructor preview pipeline renders block .astro files through Astro's
// Container API, which has no client-side runtime and cannot resolve
// `client:only="react"`. Importing the React island here would break
// constructor preview ("No valid renderer was found for ./react/CatalogIsland").
//
// In the constructor preview this renders a labelled placeholder so the
// merchant sees where the catalog body will appear and can click into the
// block to edit its props.
import { CatalogClasses as C } from './Catalog.classes';
import type { CatalogProps } from './Catalog.puckConfig';

interface Props extends CatalogProps {
  id?: string;
}

const { id, padding, colorScheme } = Astro.props as Props;

const paddingStyle = padding
  ? `padding-top:${padding.top ?? 40}px; padding-bottom:${padding.bottom ?? 80}px;`
  : 'padding-top:40px; padding-bottom:80px;';
const schemeRaw = typeof colorScheme === 'string' ? colorScheme : undefined;
const schemeClass = schemeRaw ? `color-scheme-${schemeRaw.replace('scheme-', '')}` : '';
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-block="catalog"
  style={paddingStyle}
>
  <div class={C.container}>
    {/* Constructor-preview placeholder — pixel-rough mirror of the live UI. */}
    <div class="mb-[40px]">
      <h1 class="[font-family:var(--font-heading)] text-[32px] leading-[1.1] uppercase mb-1 text-[rgb(var(--color-heading))]">КАТАЛОГ</h1>
      <p class="[font-family:var(--font-body)] text-[16px] text-[rgb(var(--color-muted))]">Здесь начинается персональный стиль</p>
    </div>
    <div class="flex items-end justify-between mb-[24px]">
      <div class="flex gap-[12px] [font-family:var(--font-body)] text-[16px] uppercase text-[rgb(var(--color-text))]">
        <span class="inline-flex items-center gap-1">Наличие <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></span>
        <span class="inline-flex items-center gap-1">Стоимость <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></span>
      </div>
      <span class="[font-family:var(--font-body)] text-[16px] uppercase text-[rgb(var(--color-text))] inline-flex items-center gap-1">По новизне <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-[16px] gap-y-[40px]">
      {Array.from({ length: 6 }).map(() => (
        <div class="flex flex-col gap-5">
          <div class="aspect-[429/564] bg-[rgb(var(--color-foreground)/0.05)]"></div>
          <div class="h-5 w-3/4 bg-[rgb(var(--color-foreground)/0.06)]"></div>
          <div class="h-6 w-1/3 bg-[rgb(var(--color-foreground)/0.06)]"></div>
          <div class="h-12 w-full bg-[rgb(var(--color-foreground)/0.08)]"></div>
        </div>
      ))}
    </div>
  </div>
</section>
