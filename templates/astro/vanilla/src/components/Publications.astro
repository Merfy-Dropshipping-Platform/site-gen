---
import publicationsData from '../data/publications.json';

interface Post {
  image?: string;
  title?: string;
  description?: string;
  link?: { enabled?: string; text?: string; href?: string };
  hidden?: boolean;
}

interface Props {
  heading?: { enabled?: string; text?: string; size?: 'small' | 'medium' | 'large' };
  posts?: Post[];
  columnsCount?: number;
  dateTime?: { enabled?: string };
  colorScheme?: string;
  padding?: { top?: number; bottom?: number };
  cardsCount?: number;
  categoryFilter?: string;
}

const { heading, posts = [], columnsCount = 3, colorScheme, padding, cardsCount, categoryFilter } = Astro.props;
const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';
const showHeading = heading?.enabled !== 'false' && heading?.text;
const padTop = padding?.top ?? 80;
const padBottom = padding?.bottom ?? 80;
const showDate = Astro.props.dateTime?.enabled !== 'false';

// Merge: prefer real data from publications.json, fallback to Puck props
let mergedPosts: Post[];
if (publicationsData && publicationsData.length > 0) {
  let filtered = publicationsData as any[];
  if (categoryFilter && categoryFilter !== 'all') {
    filtered = filtered.filter((p: any) => p.category === categoryFilter);
  }
  const limit = cardsCount ?? 6;
  mergedPosts = filtered.slice(0, limit).map((p: any) => ({
    image: p.coverImageUrl,
    title: p.title,
    description: p.excerpt,
    date: p.dateFormatted,
    link: { enabled: 'true', text: 'Читать далее', href: p.href },
  }));
} else {
  mergedPosts = posts;
}

const visiblePosts = mergedPosts.filter((p: any) => !p.hidden);

const cols = columnsCount;
---

<section class={`publications-section max-w-[1320px] mx-auto px-5 ${schemeClass}`} style={`--pad-top: ${padTop}px; --pad-bottom: ${padBottom}px; background: rgb(var(--color-background)); color: rgb(var(--color-foreground));`}>
  <div>
    {showHeading && (
      <h2 class="font-heading italic font-normal text-center mb-12 text-[20px] leading-[1.2]" style="color: rgb(var(--color-foreground));">
        {heading!.text}
      </h2>
    )}

    {visiblePosts.length === 0 ? (
      <p class="text-center font-body text-[16px] py-10" style="color: rgb(var(--color-foreground) / 0.7);">Публикации скоро появятся</p>
    ) : (
      <div class="grid publications-grid gap-8 max-md:!grid-cols-2 max-md:gap-6 max-[480px]:!grid-cols-1">
        {visiblePosts.map((post: any) => (
          <article class="overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_16px_32px_rgba(0,0,0,0.08)] group" style="background: rgb(var(--color-background)); border-radius: var(--radius-card, 0px);">
            {post.image && (
              <div class="aspect-video overflow-hidden" style="background: rgb(var(--color-foreground) / 0.03);">
                <img
                  src={post.image}
                  alt={post.title ?? ''}
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-400 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-5">
              {showDate && post.date && (
                <time class="text-[12px] font-body mb-1 block" style="color: rgb(var(--color-foreground) / 0.7);">{post.date}</time>
              )}
              {post.title && (
                <h3 class="font-heading italic text-[16px] font-normal mb-2 leading-[1.3]" style="color: rgb(var(--color-foreground));">{post.title}</h3>
              )}
              {post.description && (
                <p class="text-[14px] font-body leading-relaxed mb-3" style="color: rgb(var(--color-foreground) / 0.7);">{post.description}</p>
              )}
              {post.link?.enabled !== 'false' && post.link?.href && (
                <a href={post.link.href} class="text-[14px] font-normal font-body no-underline transition-opacity duration-200 hover:opacity-80" style="color: rgb(var(--color-foreground));">
                  {post.link.text ?? 'Читать далее'}
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<style define:vars={{ cols }}>
  .publications-grid {
    grid-template-columns: repeat(var(--cols), 1fr);
  }
  .publications-section {
    padding-top: var(--spacing-section-mobile, 80px);
    padding-bottom: var(--spacing-section-mobile, 80px);
  }
  @media (min-width: 768px) {
    .publications-section {
      padding-top: var(--spacing-section, 120px);
      padding-bottom: var(--spacing-section, 120px);
    }
  }
</style>
