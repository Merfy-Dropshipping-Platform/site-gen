---
import SatinProductCard from "../products/SatinProductCard.astro";
import { catalogProducts } from "../../data/products";
import type { CatalogProduct } from "../../data/products";

// ОЖИВЛЕНИЕ (Фаза B, рецепт bloom Popular T13): полная конструкторная схема
// theme-base PopularProducts.puckConfig поверх разметки верстальщика. Тело
// verbatim: страницы зовут <Popular products={...}/> с legacy-пропсами
// (index.astro:25,30) — их рендер не меняется (дефолт-ветки тернарников =
// прежние строки байт-в-байт; цвета → токены с пиксель-фоллбеком родных
// литералов, MANNER.md §7).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Legacy products/moreLabel/moreHref верстальщика.
const legacyProducts: CatalogProduct[] | undefined = Array.isArray(p.products)
	? p.products
	: undefined;
const moreLabel = typeof p.moreLabel === "string" ? p.moreLabel : "Смотреть больше";
const moreHref = typeof p.moreHref === "string" ? p.moreHref : "/catalog";

// Шапки у верстальщика НЕТ — заголовок/текст рендерятся ТОЛЬКО при непустом
// пропе (роль «заголовок секции» font-logo 20 / body 16 light muted, §1).
const rawTitle = (typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title;
const sectionTitle = typeof rawTitle === "string" && rawTitle.trim() ? rawTitle : undefined;
const rawText =
	(typeof p.text === "string" ? p.text : p.text?.content) ??
	(typeof p.subtitle === "string" ? p.subtitle : p.subtitle?.content);
const sectionText = typeof rawText === "string" && rawText.trim() ? rawText : undefined;

// Канон headingSize (top-level приоритетнее legacy heading.size): 'medium'
// (canon-default blockDefaults satin) и отсутствие = роль «заголовок секции»
// (20px). Лестница §9: small 17, large 24.
const headingSize = p.headingSize ?? p.heading?.size;
const headingCls =
	headingSize === "small"
		? "font-logo text-[17px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]"
		: headingSize === "large"
			? "font-logo text-[24px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]"
			: "font-logo text-[20px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]";
// Канон textSize: 'small' (canon-default blockDefaults satin) и отсутствие =
// body-роль манеры (Arsenal 16 light muted); medium ≈1.2× (19), large ≈1.44×
// (23) — ряд bloom от роли 16.
const textSize = p.textSize ?? p.text?.size;
const textCls =
	textSize === "medium"
		? "font-manrope text-[19px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
		: textSize === "large"
			? "font-manrope text-[23px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
			: "font-manrope text-[16px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]";

// Канон cards 1-24. НЮАНС верстальщика: SSG-литерал demo = slice(0,3)
// (Popular.astro:13), а его гидрация рисовала 4 (hydrateGrid(...,4),
// Popular.astro:37) — обе ветки сохранены: без пропа demo 3 / live 4;
// явный cards перекрывает обе (носитель — data-cards на гриде).
const cardsRaw =
	typeof p.cards === "number" && p.cards > 0 ? Math.max(1, Math.min(24, Math.round(p.cards))) : undefined;
const products: CatalogProduct[] = legacyProducts ?? catalogProducts.slice(0, cardsRaw ?? 3);

// Канон columns 1-6: 3 (canon-default blockDefaults satin = sm:grid-cols-3
// верстальщика) и отсутствие → дефолт-ветка; иное → inline-var на гриде с sm
// (mobile-лестница grid-cols-1 сохраняется).
const colsRaw =
	typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : undefined;
const cols = colsRaw && colsRaw !== 3 ? colsRaw : undefined;
// Канон imageView square/portrait/wide (+legacy alias adaptive→wide):
// canon-default ('square' puckConfig) и отсутствие = медиа карточки
// верстальщика 430/564 дословно; portrait → 430/500, wide → 16/9
// (перекрытие медиа-дива карточки — и SSR, и гидрированной renderCardHtml).
const tileAspectCls =
	p.imageView === "portrait"
		? " [&_li>article>div:first-child]:aspect-[430/500]"
		: p.imageView === "wide" || p.imageView === "adaptive"
			? " [&_li>article>div:first-child]:aspect-[16/9]"
			: "";
const gridBase = "grid grid-cols-1 gap-4 sm:grid-cols-3";
const gridCls =
	(cols
		? "grid grid-cols-1 gap-4 sm:grid-cols-[repeat(var(--cols),minmax(0,1fr))]"
		: gridBase) + tileAspectCls;
const gridStyle = cols ? `--cols:${cols}` : undefined;

// Канон quickAddMode none/standard/cart (+legacy alias count→cart). НЮАНС
// satin: карточка верстальщика УЖЕ несёт чёрную CTA «В корзину»
// (data-add-to-cart, h-11 w-full uppercase 14) — дефолт 'none' (canon-default)
// = карточка verbatim со своей кнопкой; standard/cart сохраняют кнопку и
// переименовывают её в quickAddText (носители — data-quick-add и data-qa-text
// на гриде, текст ставит скрипт ниже и на demo-SSR, и после гидрации).
const qaModeRaw = p.quickAddMode === "count" ? "cart" : p.quickAddMode;
const quickAddMode = qaModeRaw === "standard" || qaModeRaw === "cart" ? qaModeRaw : undefined;
const quickAddText =
	(typeof p.quickAddText === "string" && p.quickAddText) ||
	(quickAddMode === "cart" ? "В КОРЗИНУ" : "В корзину");

// Канон buttonStyle link/primary/secondary — стиль встроенной кнопки карточки.
// primary/отсутствие = чёрная заливка верстальщика дословно; secondary =
// контурная (прозрачный фон, бордер/текст токена кнопки — родная роль
// satin-button-light); link = текстовая ссылка. Носитель — data-btn-style на
// гриде + глобальный <style> ниже (работает и для SSR-demo, и для гидрации).
const btnStyle =
	p.buttonStyle === "secondary" || p.buttonStyle === "link" ? p.buttonStyle : undefined;

// Канон nextPhotoOnHover (toggle, true/'true'): смена фото на вторую картинку
// товара при наведении. Носитель данных: data-image-2 на <li> (demo —
// gallery[1] верстальщика; реальные товары — images[1], ставит гидрация).
const nextPhoto = p.nextPhotoOnHover === true || p.nextPhotoOnHover === "true";
// is:inline + set:html (без define:vars — компилятор секций его не умеет);
// идемпотентность data-np-hydrated; без data-image-2 скрипт — no-op без ошибок.
const NEXT_PHOTO_JS = [
	"(function(){",
	"var grids=document.querySelectorAll('[data-nt=\"popular-grid\"][data-next-photo]');",
	"for(var i=0;i<grids.length;i++){(function(g){",
	"if(g.getAttribute('data-np-hydrated')==='true')return;",
	"g.setAttribute('data-np-hydrated','true');",
	"function swap(li,on){",
	"var u=on?li.getAttribute('data-image-2'):null;",
	"var im=li.querySelectorAll('img');",
	"for(var j=0;j<im.length;j++){",
	"if(on){if(!im[j].getAttribute('data-image-1'))im[j].setAttribute('data-image-1',im[j].getAttribute('src')||'');im[j].setAttribute('src',u);}",
	"else{var s1=im[j].getAttribute('data-image-1');if(s1)im[j].setAttribute('src',s1);}",
	"}",
	"var so=li.querySelectorAll('source');",
	"for(var k=0;k<so.length;k++){",
	"if(on){if(!so[k].getAttribute('data-srcset-1'))so[k].setAttribute('data-srcset-1',so[k].getAttribute('srcset')||'');so[k].setAttribute('srcset',u);}",
	"else{var ss=so[k].getAttribute('data-srcset-1');if(ss)so[k].setAttribute('srcset',ss);}",
	"}",
	"}",
	"g.addEventListener('mouseover',function(e){",
	"var t=e.target;if(!t||!t.closest)return;",
	"var li=t.closest('li[data-image-2]');",
	"if(!li||!g.contains(li)||li.getAttribute('data-np-on')==='true')return;",
	"li.setAttribute('data-np-on','true');swap(li,true);",
	"});",
	"g.addEventListener('mouseout',function(e){",
	"var t=e.target;if(!t||!t.closest)return;",
	"var li=t.closest('li[data-image-2]');",
	"if(!li||li.getAttribute('data-np-on')!=='true')return;",
	"var to=e.relatedTarget;if(to&&li.contains(to))return;",
	"li.setAttribute('data-np-on','false');swap(li,false);",
	"});",
	"})(grids[i]);}",
	"})();",
].join("");

// Канон viewAll {show,text,href}: у верстальщика кнопка ЕСТЬ всегда
// (satin-button-light w-fit СЛЕВА, Popular.astro:26 — НЕ по центру!) — дефолт
// = показана; прячет только явный show:false. Дефолты текста/ссылки = legacy
// moreLabel/moreHref ('Смотреть больше' / '/catalog').
const viewAllRaw = p.viewAll;
const viewAllShow = !(
	viewAllRaw === false ||
	viewAllRaw === "false" ||
	(!!viewAllRaw &&
		typeof viewAllRaw === "object" &&
		(viewAllRaw.show === false || viewAllRaw.show === "false"))
);
const viewAllText =
	(!!viewAllRaw &&
	typeof viewAllRaw === "object" &&
	typeof viewAllRaw.text === "string" &&
	viewAllRaw.text.trim()
		? viewAllRaw.text
		: undefined) ?? moreLabel;
const viewAllHref =
	(!!viewAllRaw &&
	typeof viewAllRaw === "object" &&
	typeof viewAllRaw.href === "string" &&
	viewAllRaw.href.trim()
		? viewAllRaw.href
		: undefined) ?? moreHref;

// Канон collection (collectionPicker, id или slug): носитель — data-collection
// на гриде; фильтрацию делает гидрация (filterByCollection: productIds коллекции
// → membership товара → все, паритет theme-base). Demo-сборка без данных — no-op.
const collectionRef =
	typeof p.collection === "string" && p.collection.trim() ? p.collection.trim() : undefined;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	class="satin-pad w-full bg-[rgb(var(--color-bg,255_255_255))] py-10 md:py-14"
	aria-label="Товары Satin"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="satin-container flex flex-col gap-8">
		{(sectionTitle || sectionText) && (
			<div
				class="flex flex-col gap-2"
				data-puck-subsection-parent={id}
				data-puck-subsection-index="100"
				data-puck-subsection-field="heading"
			>
				{sectionTitle && <h2 class={headingCls}>{sectionTitle}</h2>}
				{sectionText && <p class={textCls}>{sectionText}</p>}
			</div>
		)}
		<ul
			class={gridCls}
			role="list"
			data-nt="popular-grid"
			style={gridStyle}
			data-cards={cardsRaw ? String(cardsRaw) : undefined}
			data-collection={collectionRef}
			data-next-photo={nextPhoto ? "true" : undefined}
			data-quick-add={quickAddMode}
			data-qa-text={quickAddMode ? quickAddText : undefined}
			data-btn-style={btnStyle}
		>
			{products.map((product) => (
				<li data-product-id={product.id} data-image-2={nextPhoto ? product.gallery?.[1] : undefined}><SatinProductCard product={product} /></li>
			))}
		</ul>
		{viewAllShow && (
			<a
				href={viewAllHref}
				class="satin-button satin-button-md satin-button-light w-fit"
				data-puck-subsection-parent={id}
				data-puck-subsection-index="102"
				data-puck-subsection-field="viewAll"
			>
				{viewAllText}
			</a>
		)}
	</div>
</section>{nextPhoto && <script is:inline set:html={NEXT_PHOTO_JS} />}

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		filterByCollection,
		renderCardHtml,
		escapeHtml,
	} from "../../lib/storefront-hydrate";

	// Текст встроенной кнопки карточки (quickAddText): применяется и к demo-SSR,
	// и к перерисованным гидрацией карточкам (renderCardHtml несёт «В корзину»).
	const applyQaText = (grid: HTMLElement) => {
		const text = grid.getAttribute("data-qa-text");
		if (!text) return;
		for (const btn of Array.from(grid.querySelectorAll<HTMLElement>("[data-add-to-cart]"))) {
			if (btn.textContent !== text) btn.textContent = text;
		}
	};

	// Реальные товары (Option B, паритет bloom Popular): первые N из
	// /data/products.json (N = data-cards грида; дефолт 4 — прежнее поведение
	// hydrateGrid верстальщика). Канон-поля T13 поверх: data-collection →
	// фильтр по выбранной коллекции, data-next-photo → data-image-2 (вторая
	// картинка товара) для hover-скрипта, data-qa-text → текст кнопки карточки.
	// Demo-сборка → no-op (только переименование кнопки).
	const hydratePopular = async () => {
		const grids = Array.from(document.querySelectorAll<HTMLElement>('[data-nt="popular-grid"]'));
		if (grids.length === 0) return;
		const products = await loadRealProducts();
		if (!products) {
			for (const grid of grids) applyQaText(grid);
			return;
		}
		const needCollections = grids.some((g) => g.getAttribute("data-collection"));
		const collections = needCollections ? await loadRealCollections() : null;
		for (const grid of grids) {
			const limitRaw = Number(grid.getAttribute("data-cards"));
			const limit = Number.isFinite(limitRaw) && limitRaw > 0 ? limitRaw : 4;
			const wantNextPhoto = grid.hasAttribute("data-next-photo");
			const collectionRef = grid.getAttribute("data-collection");
			const pool = collectionRef ? filterByCollection(products, collections, collectionRef) : products;
			const items = pool.slice(0, limit);
			grid.innerHTML = items
				.map((p) => {
					const img2 =
						wantNextPhoto && Array.isArray(p.images) && p.images[1]
							? ` data-image-2="${escapeHtml(p.images[1])}"`
							: "";
					return `<li data-product-id="${escapeHtml(p.id)}"${img2}>${renderCardHtml(p)}</li>`;
				})
				.join("");
			applyQaText(grid);
		}
	};

	hydratePopular();
	document.addEventListener("astro:page-load", hydratePopular);
</script>

<style is:global>
	/* Канон buttonStyle: перекрытие встроенной кнопки карточки верстальщика
	   (и demo-SSR, и гидрированной разметки renderCardHtml). Дефолт (без
	   data-btn-style) — без правил, карточка байт-в-байт. secondary = контурная
	   роль satin-button-light в токенах кнопки. */
	[data-nt="popular-grid"][data-btn-style="secondary"] [data-add-to-cart] {
		background: transparent;
		border: 1px solid rgb(var(--color-button-bg, 0 0 0));
		color: rgb(var(--color-button-bg, 0 0 0));
	}

	[data-nt="popular-grid"][data-btn-style="link"] [data-add-to-cart] {
		background: transparent;
		color: rgb(var(--color-text, 0 0 0));
		text-decoration: underline;
		text-underline-offset: 4px;
	}
</style>
