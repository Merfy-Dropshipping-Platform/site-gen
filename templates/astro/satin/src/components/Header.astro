                <a href="/cart" id="header-cart-link" class:list={['relative w-8 h-8 flex items-center justify-center hover:opacity-70 transition-opacity', !textColor && 'text-theme-foreground']} style={textStyle} aria-label="Корзина">
                  <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M18.0295 11.6923C16.8004 11.6923 15.6678 12.3587 15.0708 13.4332C13.8175 15.6892 15.4488 18.4615 18.0295 18.4615H21.9704C24.5511 18.4615 26.1824 15.6892 24.9291 13.4332C24.3321 12.3587 23.1996 11.6923 21.9704 11.6923H18.0295ZM16.6847 14.3298C16.956 13.8414 17.4708 13.5385 18.0295 13.5385H21.9704C22.5291 13.5385 23.0439 13.8414 23.3152 14.3298C23.8849 15.3552 23.1434 16.6154 21.9704 16.6154H18.0295C16.8565 16.6154 16.115 15.3552 16.6847 14.3298Z" fill="currentColor"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M17.2489 8C15.1954 8 13.2924 9.07744 12.2359 10.8383L8.83312 16.5096C8.28797 17.4182 8 18.4579 8 19.5175V26.1538C8 29.3826 10.6174 32 13.8462 32H26.1538C29.3826 32 32 29.3826 32 26.1538V19.5175C32 18.4579 31.712 17.4182 31.1669 16.5096L27.7641 10.8383C26.7076 9.07744 24.8046 8 22.7511 8H17.2489ZM13.819 11.7882C14.5419 10.5833 15.8439 9.84615 17.2489 9.84615H22.7511C24.1561 9.84615 25.4581 10.5833 26.181 11.7882L29.5838 17.4595C29.9568 18.0811 30.1538 18.7925 30.1538 19.5175V26.1538C30.1538 28.363 28.363 30.1538 26.1538 30.1538H13.8462C11.637 30.1538 9.84615 28.363 9.84615 26.1538V19.5175C9.84615 18.7925 10.0432 18.0811 10.4162 17.4595L13.819 11.7882Z" fill="currentColor"/>
                  </svg>
                  <span id="cart-badge" class="hidden absolute -top-1 -right-1 text-white text-[10px] font-medium rounded-full min-w-[16px] h-[16px] flex items-center justify-center leading-none px-0.5" style="background-color: rgb(var(--color-accent)); font-family: var(--font-body, 'Exo 2', sans-serif);">0</span>
                </a>
              )}
              {showProfile && (
                <a href="/login" aria-label="Аккаунт" class:list={['auth-nav-btn w-8 h-8 flex items-center justify-center hover:opacity-70 transition-opacity', !textColor && 'text-theme-foreground']} style={textStyle}>
                  <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </a>
              )}
            </div>
          </div>

          {/* Desktop nav (centered, second row) */}
          <div class="hidden md:flex items-center justify-center gap-4 lg:gap-8 xl:gap-12 2xl:gap-[80px] mt-2">
            {navigationLinks?.map((link) => (
              <a
                href={link.href}
                class:list={['text-[16px] font-normal hover:opacity-70 transition-opacity leading-[1.4] font-body', !menuText && 'text-theme-foreground']}
                style={navLinkStyle}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      )}
    </nav>
  </header>

  {/* ============ Mobile Navigation Menu ============ */}
  <div
    id="mobile-menu"
    class="hidden md:hidden absolute top-full left-0 right-0 border-b shadow-lg z-50"
    style={menuStyle || undefined}
  >
    <nav class:list={['flex flex-col', !menuBg && 'bg-theme-background']} aria-label="Мобильная навигация">
      {showSearch && (
        <div class="px-4 pt-6 pb-4">
          <div class="relative">
            <input
              type="search"
              placeholder="Поиск..."
              class:list={['block w-full h-12 pl-5 pr-12 border rounded-none text-sm font-normal outline-none font-body', !menuBg && 'bg-theme-background border-theme text-theme-foreground placeholder:text-theme-muted']}
              style={menuBg ? `background-color: ${menuBg}; color: ${menuText}; border-color: ${menuText}30;` : undefined}
            />
            <button class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5">
              <svg class:list={['w-5 h-5', !menuText && 'text-theme-muted']} fill="none" stroke={menuText || 'currentColor'} viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </button>
          </div>
        </div>
      )}
      <div class="flex flex-col">
        {navigationLinks?.map((link) => {
          const hasSubmenu = link.submenu && link.submenu.length > 0;
          return hasSubmenu ? (
            <div class="border-t" style={menuText ? `border-color: ${menuText}15;` : undefined}>
              <button
                class:list={['mobile-submenu-toggle w-full px-4 py-4 text-base font-normal hover:opacity-80 transition-colors flex items-center justify-between font-body', !menuText && 'text-theme-foreground border-theme']}
                style={menuText ? `color: ${menuText};` : undefined}
                data-target={`submenu-${link.label}`}
              >
                <span>{link.label}</span>
                <svg class="w-4 h-4 transition-transform submenu-arrow" fill="none" stroke={menuText || 'currentColor'} viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
              <div class="hidden mobile-submenu" style={menuText ? `background-color: ${menuText}08;` : undefined} data-id={`submenu-${link.label}`}>
                {link.submenu?.map((sub) => (
                  <a
                    href={sub.href}
                    class:list={['block px-8 py-3 text-sm font-normal hover:opacity-70 transition-colors font-body border-t', !menuText && 'text-theme-muted hover:text-theme-foreground border-theme']}
                    style={menuText ? `color: ${menuText}99; border-color: ${menuText}15;` : undefined}
                  >
                    {sub.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={['px-4 py-4 text-base font-normal hover:opacity-80 transition-colors border-t font-body', !menuText && 'text-theme-foreground border-theme']}
              style={menuText ? `color: ${menuText}; border-color: ${menuText}15;` : undefined}
            >
              {link.label}
            </a>
          );
        })}
      </div>
      {showProfile && (
        <div class="border-t" style={menuText ? `border-color: ${menuText}15;` : undefined}>
          <a
            href="/login"
            class:list={['auth-nav-btn px-4 py-4 text-base font-normal hover:opacity-80 transition-colors flex items-center gap-2 font-body', !menuText && 'text-theme-foreground']}
            style={menuText ? `color: ${menuText};` : undefined}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span class="auth-nav-label">Войти</span>
          </a>
        </div>
      )}
    </nav>
  </div>
</div>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuButton && mobileMenu) {
    const menuIcon = document.getElementById('menu-icon');
    mobileMenuButton.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenuButton.setAttribute('aria-expanded', String(isOpen));
      if (menuIcon) {
        menuIcon.classList.toggle('menu-open', isOpen);
      }
    });
  }

  // Submenu toggles
  document.querySelectorAll('.mobile-submenu-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const submenu = document.querySelector(`.mobile-submenu[data-id="${targetId}"]`);
      const arrow = btn.querySelector('.submenu-arrow');
      if (submenu) submenu.classList.toggle('hidden');
      if (arrow) arrow.classList.toggle('rotate-180');
    });
  });

  // Close mobile menu on link click
  const menuLinks = mobileMenu?.querySelectorAll('a');
  menuLinks?.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
      document.getElementById('menu-icon')?.classList.remove('menu-open');
    });
  });

  // Scroll-up stickiness logic
  (function() {
    const wrapper = document.querySelector('[data-header-wrapper]') as HTMLElement;
    if (!wrapper || !wrapper.classList.contains('transition-transform')) return;

    let lastScrollY = 0;
    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;
      if (currentScrollY < lastScrollY || currentScrollY < 10) {
        wrapper.style.transform = 'translateY(0)';
      } else {
        wrapper.style.transform = 'translateY(-100%)';
      }
      lastScrollY = currentScrollY;
    }, { passive: true });
  })();

  // Cart badge update
  function updateCartBadge() {
    const badge = document.getElementById('cart-badge');
    if (!badge) return;
    const count = (window as any).cartStore ? (window as any).cartStore.getCount() : 0;
    if (count > 0) {
      badge.textContent = String(count > 99 ? '99+' : count);
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }
  }

  document.addEventListener('cart:updated', updateCartBadge);
  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(updateCartBadge, 100);
  });

  // Mark buttons for products already in cart
  function syncCartButtons() {
    if (!(window as any).cartStore) return;
    const items = (window as any).cartStore.getItems();
    const inCartIds = new Set(items.map((i: any) => i.productId));
    document.querySelectorAll('.add-to-cart-btn').forEach((btn) => {
      if (!(btn instanceof HTMLButtonElement)) return;
      const pid = btn.dataset.productId;
      if (pid && inCartIds.has(pid)) {
        btn.textContent = 'В корзине ✓';
        btn.classList.add('in-cart');
        btn.disabled = false;
      } else if (pid) {
        btn.textContent = 'В корзину';
        btn.classList.remove('in-cart');
        btn.disabled = false;
      }
    });
  }

  document.addEventListener('cart:updated', syncCartButtons);
  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(syncCartButtons, 200);
  });

  // Add-to-cart button handler (delegated)
  document.addEventListener('click', async (e) => {
    const btn = (e.target as Element).closest('.add-to-cart-btn');
    if (!btn || !(btn instanceof HTMLButtonElement)) return;

    const productId = btn.dataset.productId;
    if (!productId || !(window as any).cartStore) return;

    const items = (window as any).cartStore.getItems();
    const existingItem = items.find((i: any) => i.productId === productId);

    // Stock limit check
    const maxStock = btn.dataset.stock ? parseInt(btn.dataset.stock, 10) : null;
    if (existingItem) {
      if (maxStock !== null && existingItem.quantity >= maxStock) {
        btn.textContent = `Макс. ${maxStock} шт.`;
        setTimeout(() => {
          btn.textContent = 'В корзине ✓';
        }, 1500);
        return;
      }
      if ((window as any).cartDrawer) (window as any).cartDrawer.open();
      return;
    }

    if (maxStock !== null && maxStock <= 0) {
      btn.textContent = 'Нет в наличии';
      btn.disabled = true;
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Добавляем...';

    const ok = await (window as any).cartStore.addItem(productId, null, 1);

    if (ok) {
      btn.textContent = 'В корзине ✓';
      btn.classList.add('in-cart');
      btn.disabled = false;
    } else {
      btn.textContent = 'Ошибка';
      setTimeout(() => {
        btn.textContent = 'В корзину';
        btn.disabled = false;
      }, 1500);
    }
  });

  // Update auth nav links based on login state
  document.querySelectorAll('.auth-nav-btn').forEach(link => {
    if ((window as any).CustomerStore?.isLoggedIn()) {
      link.setAttribute('href', '/account');
      link.setAttribute('aria-label', 'Личный кабинет');
      const label = link.querySelector('.auth-nav-label');
      if (label) label.textContent = 'Личный кабинет';
    }
  });
</script>
