---
/**
 * Разметка страницы товара (PDP) — общий компонент для demo-SSG `[id].astro`
 * и клиентски-гидрируемой `/product?id=` (Option B, спек 098). Единый источник
 * разметки → parity demo ↔ реальный товар (никаких дублей).
 *
 * `data-pdp-*` хуки — точки клиентского патча в `/product?id=` (имя, цена,
 * картинка, описание, атрибуты корзины). На demo-странице патча нет — рендерится
 * как было.
 */
import RoseNtIcon from "../icons/RoseNtIcon.astro";
import RosePdpColorVariantRow from "./RosePdpColorVariantRow.astro";
import RosePicture from "../img/RosePicture.astro";
import type { Product } from "../../types/product";

interface Props {
	product: Product;
	/** Puck-id блока «Товар» (page-product). Задаётся ТОЛЬКО в preview-консьюмере
	 * (`/product`), куда build/preview инжектит реальный динамический Product-<ts>
	 * через window.__MERFY_PRODUCT_BLOCK_ID__. На demo `[id].astro` остаётся
	 * undefined → Astro опускает data-атрибуты (live визуально не меняется). */
	id?: string;
	/** Контекст магазина для ЖИВОЙ гидрации товара (`/api/store/products?store_id=`).
	 * Рендерится в `data-site-id` секции; live-inline-script читает его (или
	 * глобал превью `__MERFY_SITE_ID__`, или `data-site-id`) как store_id. На demo
	 * `[id].astro` не передаётся → Astro опускает атрибут → API-путь пропускается,
	 * остаётся demo-скелетон. */
	siteId?: string;
}

const { product, id, siteId } = Astro.props;

/** Demo-строка вариантов цвета (Figma Rose layout). Рендерится только как
 * SSR-скелетон до клиентской гидрации И на demo `[id].astro`. На опубликованном
 * сайте live-гидрация (inline-script ниже) ЗАМЕНЯЕТ её реальным селектором из
 * `variantCombinations`, либо СКРЫВАЕТ контейнер `[data-pdp-variants]`, если у
 * товара вариантов нет (basePrice). */
const pdpColorVariants = [
	{ id: "brown-selected", label: "Коричневый" },
	{ id: "brown-outline", label: "Коричневый" },
	{ id: "white-unavailable", label: "Белый", unavailable: true as const },
];

const galleryImages =
	product.gallery && product.gallery.length > 0
		? product.gallery
		: product.images && product.images.length > 0
			? product.images
			: [product.image];
const [mainImage, ...thumbImages] = galleryImages;
const cartVariantColor = product.colors?.[0] ?? "";

// Outline-сердце избранного (SSR-дефолт PDP). Геометрия = public/icons/favourite.svg,
// зеркалит wishlist.ts heartSvg(false) + RoseProductCard defaultHeartSvg (parity).
// Инлайн-SVG (НЕ <img>) — делегат initWishlistUI переключает fill на filled.
const pdpHeartSvg =
	'<svg viewBox="0 0 17.4 15.4" width="100%" height="100%" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="display:block">' +
	'<path d="M7.428 14.2615C5.172 12.5239 0.7 8.55212 0.7 4.97729C0.7 2.61547 2.384 0.7 4.7 0.7C5.9 0.7 7.1 1.11175 8.7 2.75876C10.3 1.11175 11.5 0.7 12.7 0.7C15.016 0.7 16.7 2.61547 16.7 4.97729C16.7 8.5513 12.228 12.5239 9.972 14.2615C9.212 14.8462 8.188 14.8462 7.428 14.2615Z" ' +
	'fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>' +
	"</svg>";
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-16 pt-10 sm:px-5 sm:pb-20 sm:pt-12 md:px-10 md:pb-[120px] md:pt-16 lg:px-16 lg:pb-[140px] lg:pt-20 xl:px-20 xl:pb-[140px] xl:pt-24 2xl:px-[280px]"
	aria-labelledby="product-title"
	data-pdp-section
	data-cart-color={cartVariantColor}
	data-site-id={siteId}
	data-puck-component-id={id}
>
	{/*
	  Скелетон-лоадер PDP (rose) — зеркалит раскладку реального `data-pdp-layout`
	  ниже (та же грид-сетка/gap/aspect/радиусы темы), чтобы при подмене на живой
	  товар не было сдвига. Виден по умолчанию; live-inline-script прячет его
	  (skel.hidden=true) и в success (рядом с layout.style.opacity="1"), и в ветке
	  not-found. Дизайн-токены темы: surface-плейсхолдеры
	  `bg-[rgb(var(--color-surface,245_245_245))]`, скруглённые радиусы rose
	  (--radius-media / 6px чипы-миниатюры / --radius-button), пульс `animate-pulse`
	  в манере скелетона каталога (data-nt=catalog-skeleton). aria-hidden — чисто
	  декоративная заглушка для скринридеров.
	*/}
	<div
		data-pdp-skeleton
		aria-hidden="true"
		class="mx-auto grid w-full max-w-[1320px] grid-cols-1 gap-6 sm:gap-8 lg:grid-cols-[1fr_1fr] lg:gap-10 xl:grid-cols-[600px_minmax(0,1fr)]"
	>
		{/* ── Колонка галереи: главное фото + ряд миниатюр (как реальный layout) ── */}
		<div class="flex flex-col gap-3 sm:gap-4">
			<div class="aspect-square w-full animate-pulse rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))]"></div>
			<div class="grid grid-cols-2 gap-2 sm:gap-3 md:gap-4">
				<div class="aspect-square w-full animate-pulse rounded-[6px] bg-[rgb(var(--color-surface,245_245_245))]"></div>
				<div class="aspect-square w-full animate-pulse rounded-[6px] bg-[rgb(var(--color-surface,245_245_245))]"></div>
			</div>
		</div>

		{/* ── Инфо-колонка: бренд/заголовок/цена · варианты+кол-во · кнопки · описание ── */}
		<div class="flex flex-col gap-8 lg:gap-10">
			<div class="flex flex-col gap-2 sm:gap-3">
				<div class="h-3 w-24 animate-pulse rounded bg-[rgb(var(--color-surface,245_245_245))]"></div>
				<div class="h-8 w-3/4 animate-pulse rounded bg-[rgb(var(--color-surface,245_245_245))] sm:h-9"></div>
				<div class="mt-1 h-6 w-28 animate-pulse rounded bg-[rgb(var(--color-surface,245_245_245))]"></div>
			</div>

			<div class="flex flex-col gap-5 sm:gap-6">
				<div class="flex flex-col gap-2">
					<div class="h-4 w-16 animate-pulse rounded bg-[rgb(var(--color-surface,245_245_245))]"></div>
					<div class="flex flex-wrap gap-2">
						<div class="h-10 w-24 animate-pulse rounded-[6px] bg-[rgb(var(--color-surface,245_245_245))]"></div>
						<div class="h-10 w-24 animate-pulse rounded-[6px] bg-[rgb(var(--color-surface,245_245_245))]"></div>
						<div class="h-10 w-20 animate-pulse rounded-[6px] bg-[rgb(var(--color-surface,245_245_245))]"></div>
					</div>
				</div>
				<div class="h-10 w-32 animate-pulse rounded-[var(--radius-input,4px)] bg-[rgb(var(--color-surface,245_245_245))]"></div>
			</div>

			<div class="flex flex-col gap-3 sm:gap-4">
				<div class="h-12 w-full animate-pulse rounded-[var(--radius-button,6px)] bg-[rgb(var(--color-surface,245_245_245))]"></div>
				<div class="h-12 w-full animate-pulse rounded-[var(--radius-button,6px)] bg-[rgb(var(--color-surface,245_245_245))]"></div>
			</div>

			<div class="flex flex-col gap-3 sm:gap-4">
				<div class="h-6 w-32 animate-pulse rounded bg-[rgb(var(--color-surface,245_245_245))]"></div>
				<div class="flex flex-col gap-2">
					<div class="h-3.5 w-full animate-pulse rounded bg-[rgb(var(--color-surface,245_245_245))]"></div>
					<div class="h-3.5 w-full animate-pulse rounded bg-[rgb(var(--color-surface,245_245_245))]"></div>
					<div class="h-3.5 w-5/6 animate-pulse rounded bg-[rgb(var(--color-surface,245_245_245))]"></div>
					<div class="h-3.5 w-2/3 animate-pulse rounded bg-[rgb(var(--color-surface,245_245_245))]"></div>
				</div>
			</div>
		</div>
	</div>

	<div class="mx-auto grid w-full max-w-[1320px] grid-cols-1 gap-6 sm:gap-8 lg:grid-cols-[1fr_1fr] lg:gap-10 xl:grid-cols-[600px_minmax(0,1fr)]" data-pdp-layout hidden style="opacity:0;transition:opacity .15s ease">
		<div class="flex flex-col gap-3 sm:gap-4">
			<div class="relative aspect-square w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-[rgb(var(--color-surface,245_245_245))]">
				<RosePicture
					src={mainImage}
					alt={product.name}
					loading="eager"
					fetchpriority="high"
					class="h-full w-full object-contain"
					data-pdp-main
				/>
				{product.discount === true && (
					<span class="absolute left-3 top-3 inline-flex h-6 min-w-12 items-center justify-center rounded-[4px] bg-[rgb(var(--color-accent,0_0_0))] px-2 font-manrope text-[12px] font-normal leading-none text-white" data-pdp-badge>
						Скидка
					</span>
				)}
			</div>
			{thumbImages.length > 0 && (
				<div class="grid grid-cols-2 gap-2 sm:gap-3 md:gap-4" data-pdp-thumbs-row>
					{thumbImages.map((img) => (
						<button
							type="button"
							class="aspect-square w-full overflow-hidden rounded-[6px] bg-[rgb(var(--color-surface,245_245_245))] transition-opacity hover:opacity-90"
							data-pdp-thumb
							data-image={img}
							aria-label="Показать изображение"
						>
							<RosePicture src={img} alt={product.name} loading="eager" class="h-full w-full object-contain" />
						</button>
					))}
				</div>
			)}
		</div>

		<div class="flex flex-col gap-8 lg:gap-10">
			<div class="flex flex-col gap-2 sm:gap-3">
				<p
					class="font-manrope text-[12px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] sm:text-[13px] md:text-[14px]"
					data-pdp-brand
					hidden={!product.brand}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="text"
				>
					{product.brand}
				</p>
				{/* Заголовок + сердце избранного в одной строке. data-product-id
				    проставляет live-гидрация (рядом где заполняет data-add-to-cart);
				    глобальный делегат initWishlistUI ловит клик и красит filled/outline. */}
				<div class="flex items-start justify-between gap-3">
					<h1
						id="product-title"
						class="font-comfortaa text-[28px] font-normal leading-none tracking-normal text-[rgb(var(--color-heading,0_0_0))] sm:text-[32px] md:text-[36px]"
						data-pdp-name
						data-puck-subsection-parent={id}
						data-puck-subsection-index="101"
						data-puck-subsection-field="title"
					>
						{product.name}
					</h1>
					<button
						type="button"
						data-wishlist-toggle
						data-product-id={product.id}
						aria-pressed="false"
						aria-label="В избранное"
						class="mt-1 flex size-10 shrink-0 items-center justify-center rounded-full border border-solid border-[#E5E5E5] text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-80"
					>
						<span data-wishlist-icon class="block size-5" set:html={pdpHeartSvg}></span>
					</button>
				</div>
				<div
					class="flex flex-wrap items-baseline gap-2"
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="price"
				>
					<span class="font-manrope text-[18px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] sm:text-[20px] md:text-[24px]" data-pdp-price>
						{product.price}
					</span>
					<span
						class="font-manrope text-[14px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] line-through sm:text-[16px] md:text-[18px]"
						data-pdp-oldprice
						hidden={!product.oldPrice}
					>
						{product.oldPrice}
					</span>
				</div>
			</div>

			<div class="flex flex-col gap-5 sm:gap-6">
				<div
					class="flex flex-col gap-4"
					data-pdp-variants
					data-puck-subsection-parent={id}
					data-puck-subsection-index="103"
					data-puck-subsection-field="variants"
				>
					<RosePdpColorVariantRow
						items={pdpColorVariants}
						selectedId="brown-selected"
						groupLabel="Цвет"
						groupName="pdp-color"
						class="max-w-none"
					/>
				</div>

				<div
					class="flex h-10 w-fit items-center rounded-[var(--radius-input,4px)] border border-solid border-[#E5E5E5]"
					data-pdp-qty
					data-puck-subsection-parent={id}
					data-puck-subsection-index="104"
					data-puck-subsection-field="quantity"
				>
					<button
						type="button"
						class="flex size-10 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Уменьшить количество"
						data-action="qty-dec"
					>
						<RoseNtIcon name="minus" sizeClass="size-4" />
					</button>
					<input
						type="number"
						min="1"
						value="1"
						class="h-10 w-12 bg-transparent text-center font-manrope text-[12px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] outline-none sm:text-[14px]"
						aria-label="Количество"
						data-pdp-qty-value
					/>
					<button
						type="button"
						class="flex size-10 items-center justify-center transition-opacity hover:opacity-80"
						aria-label="Увеличить количество"
						data-action="qty-inc"
					>
						<RoseNtIcon name="plus" sizeClass="size-4" />
					</button>
				</div>
			</div>

			<div
				class="flex flex-col gap-3 sm:gap-4"
				data-puck-subsection-parent={id}
				data-puck-subsection-index="105"
				data-puck-subsection-field="buttons"
			>
				<button
					type="button"
					data-add-to-cart
					data-product-id={product.id}
					data-name={product.name}
					data-price={product.price}
					data-old-price={product.oldPrice ?? ""}
					data-image={mainImage}
					data-variant-color={cartVariantColor}
					data-quantity="1"
					class="inline-flex h-12 w-full max-w-none items-center justify-center rounded-[var(--radius-button,6px)] border border-solid border-[rgb(var(--color-button-2-border,0_0_0))] !bg-[rgb(var(--color-button-2-bg,255_255_255))] px-4 font-manrope text-[14px] font-normal leading-normal !text-[rgb(var(--color-button-2-text,0_0_0))] transition-opacity hover:opacity-90 sm:text-[16px]"
				>
					Добавить в корзину
				</button>
				<button
					type="button"
					data-action="buy-now"
					data-product-id={product.id}
					data-name={product.name}
					data-price={product.price}
					data-image={mainImage}
					class="inline-flex h-12 w-full items-center justify-center rounded-[var(--radius-button,6px)] !bg-[rgb(var(--color-button-bg,0_0_0))] px-4 font-manrope text-[14px] font-normal leading-normal !text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-95 sm:text-[16px]"
				>
					Купить сейчас
				</button>
			</div>

			<div class="flex flex-col gap-3 sm:gap-4">
				<div
					class="flex flex-col gap-3 sm:gap-4"
					data-puck-subsection-parent={id}
					data-puck-subsection-index="106"
					data-puck-subsection-field="description"
				>
					<h2 class="rose-title">
						Описание
					</h2>
					<p class="font-manrope text-[13px] font-light leading-[1.54] text-[rgb(var(--color-muted,153_153_153))] sm:text-[14px] md:text-[15px]" data-pdp-desc>
						{product.description}
					</p>
				</div>
				<div
					data-puck-subsection-parent={id}
					data-puck-subsection-index="107"
					data-puck-subsection-field="share"
				>
					<button
						type="button"
						data-action="share"
						class="inline-flex w-fit items-center gap-2 font-manrope text-[13px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70 sm:text-[14px] md:text-[16px]"
						aria-label="Поделиться"
					>
						<RoseNtIcon name="share" sizeClass="size-5" />
						<span>Поделиться</span>
					</button>
				</div>
			</div>
		</div>
	</div>

	{/* «Товар не найден» — показывается live-гидрацией ТОЛЬКО когда товар не
	    резолвится (магазин пуст / неверный slug). Живёт в КОМПОНЕНТЕ, чтобы оба
	    маршрута (`/product` и demo `products/[id]`) получили его без дублей в
	    consumer-страницах. На demo-сборке без products.json гидрация — no-op
	    (остаётся demo-скелетон), блок остаётся скрытым. */}
	<div
		data-pdp-notfound
		hidden
		class="w-full bg-[rgb(var(--color-bg,255_255_255))] py-24 text-center"
	>
		<p class="font-comfortaa text-[24px] text-[rgb(var(--color-heading,0_0_0))]">Товар не найден</p>
		<a
			href="/catalog"
			class="mt-6 inline-flex h-12 items-center justify-center rounded-[var(--radius-button,6px)] bg-[rgb(var(--color-button-bg,0_0_0))] px-6 font-manrope text-[16px] text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-90"
		>В каталог</a>
	</div>
</section>

{/*
  Селектируемость блока «Товар» в конструкторе (T1/T2 спека 098). preview.controller /
  build.service инжектят реальный динамический id блока (`Product-<ts>` из ревизии
  page-product) в window.__MERFY_PRODUCT_BLOCK_ID__. Штампуем его на
  data-puck-component-id секции и data-puck-subsection-parent каждой подсекции —
  MutationObserver конструктора (useSubsectionClickHandler) регистрирует overlay-portals.
  Скрипт в КОМПОНЕНТЕ (не в consumer-странице): превью товара отдаёт билд
  `products/[id].astro` (firstBuiltProductRoute), а не `/product`. Без глобала
  (live / demo) — no-op, разметка инертна.
*/}
<script is:inline>
	(function () {
		function stampProductBlockId() {
			var id = window.__MERFY_PRODUCT_BLOCK_ID__;
			if (!id) return;
			var section = document.querySelector("[data-pdp-section]");
			if (!section) return;
			if (!section.getAttribute("data-puck-component-id")) {
				section.setAttribute("data-puck-component-id", id);
			}
			section.querySelectorAll("[data-puck-subsection-index]").forEach(function (el) {
				if (!el.getAttribute("data-puck-subsection-parent")) {
					el.setAttribute("data-puck-subsection-parent", id);
				}
			});
		}
		stampProductBlockId();
		document.addEventListener("astro:page-load", stampProductBlockId);
	})();
</script>

<script is:inline define:vars={{ propSiteId: siteId }}>
	/**
	 * ЖИВАЯ ГИДРАЦИЯ PDP (rose). Заменяет прежний demo-UI-скрипт: грузит РЕАЛЬНЫЙ
	 * товар из ЖИВОГО /api/store/products (как каталог rose) и заполняет
	 * существующие data-pdp-* хуки разметки. Без живых данных (demo-сборка) —
	 * чистый no-op: остаётся SSR-скелетон, разметка/вёрстка не трогается.
	 *
	 * ТОЛЬКО is:inline (НЕ module-<script> с import): module client-script темы НЕ
	 * компилится в live theme build → 404 на проде → вся логика мертва. Поэтому
	 * тела хелперов гидрации (loadProduct/deriveVariantGroups/findCombination/
	 * applyCombo/cart) инлайнены 1:1 из пилота packages/theme-rose/blocks/Product.
	 *
	 * КОРЗИНА: НЕ зовём cart-API вручную. Тема rose уже вешает ГЛОБАЛЬНЫЙ
	 * делегированный обработчик [data-add-to-cart] (nt-cart-rose.ts → initCartUI в
	 * Layout), который читает data-product-id/-name/-price/-image/-quantity/
	 * -variant-color/-variant-size/-variant-combination-id и кладёт линию в
	 * локальную корзину rose + открывает drawer. Наша задача — заполнить эти
	 * атрибуты реальными значениями. «Купить сейчас» = тот же add + переход на
	 * /cart (там живёт мост NtCart → серверный cartStore → /checkout).
	 */
	(function () {
		// ─── Источник данных: ЖИВОЙ storefront API (спек 098 — «не products.json»). ───
		// apiBase: на live (*.merfy.ru) cross-origin к gateway (CORS пропускает
		// *.merfy.ru); в превью iframe на gateway-origin → тот же URL same-origin.
		var apiBase =
			(typeof window !== "undefined" && window.__MERFY_API_BASE__) || "https://gateway.merfy.ru";
		// store_id (shopId) = siteId. На live build сам siteId инжектится на секцию
		// (data-site-id) консьюмером ИЛИ глобалом превью __MERFY_SITE_ID__.
		function resolveSiteId() {
			if (typeof window !== "undefined" && window.__MERFY_SITE_ID__) return window.__MERFY_SITE_ID__;
			var sec = document.querySelector("[data-pdp-section]");
			var fromAttr = sec && sec.getAttribute("data-site-id");
			if (fromAttr) return fromAttr;
			return propSiteId || undefined;
		}

		var PLACEHOLDER_IMAGE = "/placeholders/sweater-blue.png";
		var __cachedProducts; // undefined — не грузили; null — данных нет (demo).

		// Цена из API — в РУБЛЯХ (basePrice/variant.price = значение, которое ввёл
		// мерчант, как в admin «Товары»). Показываем БЕЗ мутации (не делим на 100).
		function toNum(v) {
			var n = typeof v === "string" ? parseFloat(v) : v;
			return Number.isFinite(n) ? n : null;
		}
		function variantMinCents(p) {
			var vc = p.variantCombinations;
			if (Array.isArray(vc) && vc.length) {
				var ps = vc.map(function (v) { return toNum(v.price); }).filter(function (n) { return n !== null && n > 0; });
				if (ps.length) return Math.min.apply(null, ps);
			}
			return null;
		}
		// mapApiProduct: товар /api/store/products → форма клиента PDP. Цены
		// копейки→рубли; title→name; handle→slug; variantCombinations as-is (для
		// селектора вариантов). Зеркало Catalog.mapApiProduct.
		function mapApiProduct(p) {
			var cents =
				(p.hasVariants ? variantMinCents(p) : null) ??
				toNum(p.basePrice) ??
				variantMinCents(p) ??
				0;
			var oldCents = toNum(p.compareAtPrice);
			return {
				id: p.id,
				name: p.title || p.name || "",
				price: cents,
				oldPrice: oldCents && oldCents > 0 ? oldCents : null,
				slug: p.handle || p.slug,
				description: p.description || p.metaDescription || "",
				images: Array.isArray(p.images) ? p.images : [],
				hasVariants: !!p.hasVariants,
				// variantCombinations: нормализуем price копейки→рубли, чтобы
				// applyCombo/корзина работали в рублях (как basePrice выше).
				variantCombinations: Array.isArray(p.variantCombinations)
					? p.variantCombinations.map(function (vc) {
							var vcCents = toNum(vc.price);
							var vcOld = toNum(vc.compareAtPrice);
							return {
								id: vc.id,
								title: vc.title,
								price: vcCents !== null ? vcCents : 0,
								compareAtPrice: vcOld && vcOld > 0 ? vcOld : null,
								available: vc.available,
								quantity: vc.quantity,
								options: vc.options || {},
