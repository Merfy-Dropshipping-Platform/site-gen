---
/**
 * ProductGallery — image gallery primitive.
 *
 * 4 макета (Figma 648:55733):
 *  - `split`        — thumbs column сбоку + main image. Thumbs выровнены по краю
 *                     (`photoPosition='right'` → thumbs справа, main слева).
 *  - `carousel`     — main image + ряд thumbs снизу (горизонтальный скролл).
 *  - `two-columns`  — все фото в grid 2×N одинакового размера.
 *  - `stacked`      — главное фото на всю ширину + thumbs в grid 2×N снизу.
 *
 * Размеры читаются из CSS-vars на root <section> Product.astro:
 *   --product-main-image-size  (440/552/640)
 *   --product-thumb-size       (72/88/96)
 *
 * Theme variants (`wrap-large` / `inline-small`) → радиус и discount-badge стиль.
 */
import type { GalleryView } from '../Product.types';
import { PLACEHOLDER_ASSETS } from '../../runtime/placeholders';

interface Props {
  gallery: GalleryView;
  variant?: 'wrap-large' | 'inline-small';
  layout?: 'split' | 'carousel' | 'two-columns' | 'stacked' | 'thumbnail';
  photoPosition?: 'left' | 'right';
  showDiscountBadge?: boolean;
  hasDiscount?: boolean;
  badgeText?: string;
}

const {
  gallery,
  variant = 'wrap-large',
  layout = 'two-columns',
  photoPosition = 'left',
  showDiscountBadge = false,
  hasDiscount = false,
  badgeText = 'Скидка',
} = Astro.props as Props;

const isInlineSmall = variant === 'inline-small';
const heroRadius = isInlineSmall ? 'rounded-[12px]' : 'rounded-[8px]';
const thumbRadius = 'rounded-[8px]';
const photoOnRight = photoPosition === 'right';

// Все thumbs включая hero (в two-columns/stacked-grid hero — первый item).
const allImages = gallery.hero
  ? [{ src: gallery.hero.src, alt: gallery.hero.alt }, ...gallery.thumbs]
  : gallery.thumbs;
---
<div class="w-full" data-product-gallery data-gallery-variant={variant} data-gallery-layout={layout}>
  {layout === 'split' && (
    <div class:list={[
      'flex flex-col lg:flex-row items-stretch gap-3 w-full',
      photoOnRight ? 'lg:flex-row-reverse' : '',
    ]}>
      {/* Main image — на mobile сверху full-width, на lg сбоку фиксированной ширины. */}
      <div class:list={['relative overflow-hidden bg-[rgb(var(--color-surface,var(--color-text)/0.05))] shrink-0 order-1 lg:order-2 w-full lg:w-[var(--product-main-image-size,552px)]', heroRadius]}
           style="aspect-ratio:1/1;" data-product-hero>
        {gallery.hero ? (
          <img src={gallery.hero.src} alt={gallery.hero.alt} loading="eager" class="absolute inset-0 w-full h-full object-cover block" data-product-hero-image/>
        ) : (
          <div class="absolute inset-0 flex items-center justify-center text-[rgb(var(--color-accent))]">
            <img src={PLACEHOLDER_ASSETS.sweater.blueLarge} alt="" class="w-[40%] aspect-square object-contain" loading="lazy" />
          </div>
        )}
        {showDiscountBadge && hasDiscount && gallery.hero && (
          <div class="absolute top-3 left-3 inline-flex items-center justify-center h-6 px-1.5 rounded-[4px] text-xs [font-family:var(--font-body)]"
               style="background:rgb(var(--color-text)); color:rgb(var(--color-bg));">{badgeText}</div>
        )}
      </div>
      {/* Thumbs — на mobile горизонтальная лента под main, на lg вертикальная сбоку. */}
      {gallery.thumbs.length > 0 && (
        <div class="flex flex-row lg:flex-col items-center gap-2 shrink-0 order-2 lg:order-1 w-full lg:w-auto"
             data-product-thumbs data-thumbs-axis="responsive">
          <button type="button" aria-label="Назад" class="shrink-0 h-6 w-6 flex items-center justify-center text-[rgb(var(--color-text))]" data-thumbs-prev>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lg:block hidden"><polyline points="18 15 12 9 6 15"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lg:hidden block"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div class="flex flex-row lg:flex-col gap-2 overflow-x-auto lg:overflow-y-auto flex-1 lg:flex-none lg:max-h-[var(--product-main-image-size,552px)]">
            {gallery.thumbs.map((thumb, idx) => (
              <button type="button" data-product-thumb data-thumb-idx={idx + 1} aria-label={`Изображение ${idx + 2}`}
                class:list={['relative overflow-hidden p-0 border-0 bg-transparent cursor-pointer shrink-0', thumbRadius,
                  'w-[var(--product-thumb-size,88px)] h-[var(--product-thumb-size,88px)]']}>
                <img src={thumb.src} alt={thumb.alt} loading="lazy" class="w-full h-full object-cover block"/>
              </button>
            ))}
          </div>
          <button type="button" aria-label="Вперёд" class="shrink-0 h-6 w-6 flex items-center justify-center text-[rgb(var(--color-text))]" data-thumbs-next>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lg:block hidden"><polyline points="6 9 12 15 18 9"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lg:hidden block"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      )}
    </div>
  )}

  {layout === 'carousel' && (
    <div class="flex flex-col gap-3 w-full">
      {/* Main image (full width of gallery col) */}
      <div class:list={['relative w-full overflow-hidden bg-[rgb(var(--color-surface,var(--color-text)/0.05))]', heroRadius]}
           style="aspect-ratio:1/1;" data-product-hero>
        {gallery.hero ? (
          <img src={gallery.hero.src} alt={gallery.hero.alt} loading="eager" class="absolute inset-0 w-full h-full object-cover block" data-product-hero-image/>
        ) : (
          <div class="absolute inset-0 flex items-center justify-center text-[rgb(var(--color-accent))]">
            <img src={PLACEHOLDER_ASSETS.sweater.blueLarge} alt="" class="w-[40%] aspect-square object-contain" loading="lazy" />
          </div>
        )}
        {showDiscountBadge && hasDiscount && gallery.hero && (
          <div class="absolute top-3 left-3 inline-flex items-center justify-center h-6 px-1.5 rounded-[4px] text-xs [font-family:var(--font-body)]"
               style="background:rgb(var(--color-text)); color:rgb(var(--color-bg));">{badgeText}</div>
        )}
      </div>
      {/* Thumbs row (horizontal) с chevron-left/right */}
      {gallery.thumbs.length > 0 && (
        <div class="flex items-center gap-2 w-full">
          <button type="button" aria-label="Назад" class="shrink-0 h-6 w-6 flex items-center justify-center text-[rgb(var(--color-text))]" data-thumbs-prev>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div class="flex gap-2 overflow-x-auto flex-1" data-product-thumbs data-thumbs-axis="horizontal">
            {gallery.thumbs.map((thumb, idx) => (
              <button type="button" data-product-thumb data-thumb-idx={idx + 1} aria-label={`Изображение ${idx + 2}`}
                class:list={['relative overflow-hidden p-0 border-0 bg-transparent cursor-pointer shrink-0', thumbRadius]}
                style="width:calc(var(--product-thumb-size,88px) * 1.55); aspect-ratio:1/1;">
                <img src={thumb.src} alt={thumb.alt} loading="lazy" class="w-full h-full object-cover block"/>
              </button>
            ))}
          </div>
          <button type="button" aria-label="Вперёд" class="shrink-0 h-6 w-6 flex items-center justify-center text-[rgb(var(--color-text))]" data-thumbs-next>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      )}
    </div>
  )}

  {layout === 'two-columns' && allImages.length === 0 && (
    <div class:list={['relative w-full overflow-hidden bg-[rgb(var(--color-surface,var(--color-text)/0.05))] flex items-center justify-center text-[rgb(var(--color-accent))]', heroRadius]}
         style="aspect-ratio:1/1;" data-product-hero>
      <img src={PLACEHOLDER_ASSETS.sweater.blueLarge} alt="" class="w-[40%] aspect-square object-contain" loading="lazy" />
    </div>
  )}
  {layout === 'two-columns' && allImages.length > 0 && (
    <div class="grid grid-cols-2 gap-3 w-full" data-product-thumbs data-thumbs-axis="grid">
      {allImages.map((img, idx) => (
        <div class:list={['relative overflow-hidden bg-[rgb(var(--color-surface,var(--color-text)/0.05))]', heroRadius]}
             style="aspect-ratio:1/1;"
             data-product-thumb={idx === 0 ? undefined : ''}
             data-thumb-idx={idx === 0 ? undefined : idx}>
          {idx === 0 ? (
            <>
              <img src={img.src} alt={img.alt} loading="eager" class="absolute inset-0 w-full h-full object-cover block" data-product-hero-image/>
              {showDiscountBadge && hasDiscount && (
                <div class="absolute top-3 left-3 inline-flex items-center justify-center h-6 px-1.5 rounded-[4px] text-xs [font-family:var(--font-body)]"
                     style="background:rgb(var(--color-text)); color:rgb(var(--color-bg));">{badgeText}</div>
              )}
            </>
          ) : (
            <img src={img.src} alt={img.alt} loading="lazy" class="absolute inset-0 w-full h-full object-cover block"/>
          )}
        </div>
      ))}
    </div>
  )}

  {layout === 'stacked' && (
    <div class="flex flex-col gap-3 w-full">
      {/* Main image — full width gallery col. */}
      <div class:list={['relative w-full overflow-hidden bg-[rgb(var(--color-surface,var(--color-text)/0.05))]', heroRadius]}
           style="aspect-ratio:1/1;" data-product-hero>
        {gallery.hero ? (
          <img src={gallery.hero.src} alt={gallery.hero.alt} loading="eager" class="absolute inset-0 w-full h-full object-cover block" data-product-hero-image/>
        ) : (
          <div class="absolute inset-0 flex items-center justify-center text-[rgb(var(--color-accent))]">
            <img src={PLACEHOLDER_ASSETS.sweater.blueLarge} alt="" class="w-[40%] aspect-square object-contain" loading="lazy" />
          </div>
        )}
        {showDiscountBadge && hasDiscount && gallery.hero && (
          <div class="absolute top-3 left-3 inline-flex items-center justify-center h-6 px-1.5 rounded-[4px] text-xs [font-family:var(--font-body)]"
               style="background:rgb(var(--color-text)); color:rgb(var(--color-bg));">{badgeText}</div>
        )}
      </div>
      {/* Thumbs grid 2 cols below */}
      {gallery.thumbs.length > 0 && (
        <div class="grid grid-cols-2 gap-3 w-full" data-product-thumbs data-thumbs-axis="grid">
          {gallery.thumbs.map((thumb, idx) => (
            <button type="button" data-product-thumb data-thumb-idx={idx + 1} aria-label={`Изображение ${idx + 2}`}
              class:list={['relative overflow-hidden p-0 border-0 bg-transparent cursor-pointer', thumbRadius]}
              style="aspect-ratio:1/1;">
              <img src={thumb.src} alt={thumb.alt} loading="lazy" class="absolute inset-0 w-full h-full object-cover block"/>
            </button>
          ))}
        </div>
      )}
    </div>
  )}
</div>
