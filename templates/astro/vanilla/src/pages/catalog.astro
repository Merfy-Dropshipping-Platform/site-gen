---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/data.json';
import siteConfig from '../data/site-config.json';
import products from '../data/products.json';
import collections from '../data/collections.json';

// Puck block components — render content from pagesData['page-catalog'].content[]
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import PopularProducts from '../components/PopularProducts.astro';
import Gallery from '../components/Gallery.astro';
import TextBlock from '../components/TextBlock.astro';
import MultiColumns from '../components/MultiColumns.astro';
import MultiRows from '../components/MultiRows.astro';
import Slideshow from '../components/Slideshow.astro';
import Video from '../components/Video.astro';
import ImageWithText from '../components/ImageWithText.astro';
import ContactForm from '../components/ContactForm.astro';
import PromoBanner from '../components/PromoBanner.astro';
import Publications from '../components/Publications.astro';
import CollapsibleSection from '../components/CollapsibleSection.astro';
import Collections from '../components/Collections.astro';
import Newsletter from '../components/Newsletter.astro';
import Product from '../components/Product.astro';
import CatalogIsland from '../components/react/CatalogIsland';

// Resolve catalog page blocks from multipage revision shape
const allPagesData = (data as any)?.pagesData ?? {};
const catalogPage =
  allPagesData['page-catalog'] ??
  ((data as any)?.currentPageId === 'page-catalog' ? data : null);

const catalogBlocks: any[] = catalogPage?.content
  ? (Array.isArray(catalogPage.content) ? catalogPage.content : [])
  : Array.isArray((data as any)?.content) && (data as any)?.currentPageId === 'page-catalog'
    ? (data as any).content
    : [];

const meta = data?.meta ?? {};

// Header/Footer fallbacks from siteConfig (or home page)
const homePage = allPagesData['home'];
const homeBlocks: any[] = (homePage?.content && Array.isArray(homePage.content)) ? homePage.content : [];
const headerBlock =
  catalogBlocks.find((b: any) => b?.type === 'Header') ??
  homeBlocks.find((b: any) => b?.type === 'Header');
const footerBlock =
  catalogBlocks.find((b: any) => b?.type === 'Footer') ??
  homeBlocks.find((b: any) => b?.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};

// Content blocks — exclude Header/Footer (rendered as chrome)
const contentBlocks = catalogBlocks.filter(
  (b: any) => b?.type && b.type !== 'Header' && b.type !== 'Footer',
);

const componentMap: Record<string, any> = {
  Hero,
  PopularProducts,
  Gallery,
  TextBlock,
  MainText: TextBlock,
  MultiColumns,
  MultiRows,
  Slideshow,
  Video,
  ImageWithText,
  ContactForm,
  PromoBanner,
  Publications,
  CollapsibleSection,
  Collections,
  Newsletter,
  Product,
};

// Build-time data → initialProducts/initialCollections so the CatalogIsland
// can render real product cards on first paint instead of a full-page
// skeleton while React Query is fetching.
const apiUrl = ((meta as any)?.apiUrl as string) ?? 'https://gateway.merfy.ru/api';
const shopId = ((meta as any)?.shopId as string) ?? '';
const toKopecks = (v: unknown): number => {
  const n = typeof v === 'string' ? parseFloat(v) : typeof v === 'number' ? v : 0;
  return Number.isFinite(n) ? Math.round(n * 100) : 0;
};
const initialProducts = (products as any[])
  .slice(0, 8)
  .map((p: any) => ({
    id: p.id,
    handle: p.handle ?? p.slug ?? p.id,
    title: p.title ?? p.name,
    description: p.description,
    price: p.basePrice != null ? toKopecks(p.basePrice) : toKopecks(p.price),
    compareAtPrice: p.compareAtPrice ? toKopecks(p.compareAtPrice) : undefined,
    images: ((p.images ?? []) as any[]).map((img) =>
      typeof img === 'string' ? { url: img } : img,
    ),
    variants: p.variants ?? p.variantCombinations ?? [],
  }));
const initialCollections = (collections as any[]).map((c: any) => ({
  id: c.id,
  handle: c.handle ?? c.slug ?? c.id,
  title: c.title ?? c.name,
  description: c.description,
  image: c.image ? (typeof c.image === 'string' ? { url: c.image } : c.image) : undefined,
}));
const initialTotal = (products as any[]).length;

const hasCatalogBlock = contentBlocks.some((b: any) => b.type === 'Catalog');
const pageTitle = (meta?.title && `Каталог — ${meta.title}`) || 'Каталог';
---
<BaseLayout title={pageTitle} description={meta?.description}>
  <div class="catalog-page flex flex-col flex-1" style="background: #EEEEEE; color: rgb(var(--color-foreground));">
    <Header {...headerProps} />

    <main class="catalog-main flex-1 w-full max-w-[1320px] mx-auto">
      {contentBlocks.map((block: any) => {
        if (block.type === 'Catalog') {
          const props = block.props ?? {};
          const padding = props.padding ?? { top: 40, bottom: 80 };
          const showColl = props.showCollectionFilter !== 'false' && props.showCollectionFilter !== false;
          return (
            <section
              data-puck-component-id={props.id}
              data-block="catalog"
              style={`padding-top:${padding.top ?? 40}px; padding-bottom:${padding.bottom ?? 80}px;`}
            >
              <div style="margin-bottom: 40px;">
                <h1
                  class="font-heading italic"
                  style="font-size: 20px; font-weight: 400; text-transform: uppercase; line-height: 1.2; color: rgb(var(--color-foreground)); margin: 0;"
                >КАТАЛОГ</h1>
              </div>
              <CatalogIsland
                client:only="react"
                shopId={shopId}
                apiBase={apiUrl}
                initialProducts={initialProducts}
                initialTotal={initialTotal}
                initialCollections={initialCollections}
                collectionSlug={props.collectionSlug}
                showCollectionFilter={showColl}
                cardStyle={props.productCard?.cardStyle}
              />
            </section>
          );
        }
        const Component = componentMap[block.type];
        if (!Component) return null;
        return <Component {...(block.props ?? {})} />;
      })}

      {/* Fallback: revisions без Catalog блока — рендерим default vanilla layout */}
      {!hasCatalogBlock && (
        <>
          <div style="margin-bottom: 40px;">
            <h1
              class="font-heading italic"
              style="font-size: 20px; font-weight: 400; text-transform: uppercase; line-height: 1.2; color: rgb(var(--color-foreground)); margin: 0;"
            >КАТАЛОГ</h1>
          </div>
          <CatalogIsland
            client:only="react"
            shopId={shopId}
            apiBase={apiUrl}
            initialProducts={initialProducts}
            initialTotal={initialTotal}
            initialCollections={initialCollections}
          />
          <noscript>
            <PopularProducts products={products} />
          </noscript>
        </>
      )}
    </main>

    <Footer {...footerProps} />
  </div>
</BaseLayout>

<style>
  .catalog-main {
    padding-left: 16px;
    padding-right: 16px;
    padding-top: 40px;
    padding-bottom: 40px;
  }
  @media (min-width: 640px) {
    .catalog-main {
      padding-left: 24px;
      padding-right: 24px;
      padding-top: 60px;
      padding-bottom: 60px;
    }
  }
  @media (min-width: 768px) {
    .catalog-main {
      padding-left: 32px;
      padding-right: 32px;
      padding-top: 80px;
      padding-bottom: 80px;
    }
  }
  @media (min-width: 1024px) {
    .catalog-main {
      padding-left: 64px;
      padding-right: 64px;
      padding-top: 100px;
      padding-bottom: 100px;
    }
  }
  @media (min-width: 1280px) {
    .catalog-main {
      padding-left: 96px;
      padding-right: 96px;
      padding-top: 120px;
      padding-bottom: 120px;
    }
  }
  @media (min-width: 1536px) {
    .catalog-main {
      padding-left: 300px;
      padding-right: 300px;
      padding-top: 120px;
      padding-bottom: 120px;
    }
  }
</style>
