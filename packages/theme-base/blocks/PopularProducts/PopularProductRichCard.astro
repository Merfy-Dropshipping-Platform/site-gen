---
/**
 * PopularProductRichCard — flux variant card per Figma 1:26389.
 *
 * Visual-only primitive consumed by PopularProducts.astro when
 * `cardVariant === 'rich'`. Rose / vanilla / bloom stay on the existing
 * minimal card branch so this file is purely additive.
 *
 * Layout (per Figma):
 *   ┌──────────────┐
 *   │ [badges]      │  badges absolute top-left, stacked vertical
 *   │   IMAGE       │  square aspect, rounded-12
 *   ├──────────────┤
 *   │ ▢ ▢ ▢         │  color swatches row (size-20 squares)
 *   │ Title         │
 *   │ Price  Old    │
 *   │ [128 256 512] │  memory chips row (small, last greyed if disabled)
 *   │ [В корзину]   │  black filled button h-44
 *   └──────────────┘
 *   surrounding card has bg-surface, p-12, rounded-12
 *
 * Colours flow from active scheme tokens (--color-text/--color-bg,
 * --color-surface, --color-button-bg/text, --color-muted, --color-accent for badges).
 */
interface Color {
  color?: string | null;
  available?: boolean;
}
interface MemoryChip {
  value: string;
  available?: boolean;
}
interface Badge {
  label: string;
  /** 'accent' (orange/scheme accent) — Figma default. */
  variant?: 'accent';
}

// Placeholder SVG (свитер из Figma 1:19342) — inline в блоке.
const PLACEHOLDER_SWEATER = '<svg preserveAspectRatio="xMidYMid meet" width="100%" height="100%" viewBox="0 0 80 80" fill="currentColor" xmlns="http://www.w3.org/2000/svg" style="display:block" aria-hidden="true"><g><path d="M4.57 68.57C4.11 66.29 4 61.71 4 61.71H14.29V70.86H6.86C6.86 70.86 5.03 70.86 4.57 68.57Z" fill-opacity="0.55"/><path d="M10.29 5.71C12 2.29 24 0 24 0H35.43V77.71C35.43 80 33.14 80 33.14 80H16C16 80 14.29 80 14.29 77.71L14.29 61.71H4C4 61.71 0 40 0 34.86C0 29.71 8.57 9.14 10.29 5.71Z" fill-opacity="0.85"/><path d="M69.71 5.71C68 2.29 56 0 56 0H44.57V77.71C44.57 80 46.86 80 46.86 80H64C64 80 65.71 80 65.71 77.71V61.71H76C76 61.71 80 40 80 34.86C80 29.71 71.43 9.14 69.71 5.71Z" fill-opacity="0.85"/><path d="M40 75.43V0L24 0C24 0 24.03 1.71 24.57 8C25.12 14.29 35.43 18.29 35.43 18.29V75.43H40Z" fill-opacity="0.55"/><path d="M40 75.43V0H56C56 0 55.97 1.71 55.43 8C54.88 14.29 44.57 18.29 44.57 18.29V75.43H40Z" fill-opacity="1"/><path d="M14.29 68.8V70.86L14.29 74.86L25.14 63.43L27.16 61.16C28.15 60.04 27.36 58.29 25.87 58.29C25.41 58.29 24.96 58.47 24.63 58.81L21.14 62.4L14.86 68.8H14.29Z" fill-opacity="0.55"/><path d="M65.71 68.8V70.86V74.86L54.86 63.43L52.84 61.16C51.85 60.04 52.64 58.29 54.13 58.29C54.59 58.29 55.04 58.47 55.37 58.81L58.86 62.4L65.14 68.8H65.71Z" fill-opacity="1"/><path d="M75.43 68.57C75.43 66.29 76 61.71 76 61.71H65.71V70.86H73.71C73.71 70.86 75.43 70.86 75.43 68.57Z" fill-opacity="1"/></g></svg>';

interface Props {
  href?: string;
  image?: string;
  title: string;
  price: string;
  oldPrice?: string;
  colors?: Color[];
  memoryChips?: MemoryChip[];
  badges?: Badge[];
  ctaLabel?: string;
  /** index в массиве карточек — для будущей вариативности placeholder'ов. */
  cardIndex?: number;
}

const {
  href = '/catalog',
  image,
  title,
  price,
  oldPrice,
  colors = [],
  memoryChips = [],
  badges = [],
  ctaLabel = 'В корзину',
  cardIndex = 0,
} = Astro.props as Props;

const showOld = !!(oldPrice && oldPrice.trim());
---
<div
  class="relative flex flex-col gap-4 p-3 rounded-[12px] w-full bg-[rgb(var(--color-surface))]"
  data-popular-card-rich
>
  <a href={href} class="block aspect-square rounded-[12px] overflow-hidden bg-[rgb(var(--color-text)/0.04)]">
    {image ? (
      <img src={image} alt={title} loading="lazy" class="w-full h-full object-cover block" />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-[rgb(var(--color-accent))]">
        <div class="w-[40%] aspect-square">
          <Fragment set:html={PLACEHOLDER_SWEATER} />
        </div>
      </div>
    )}
  </a>

  {badges.length > 0 && (
    <div class="absolute top-2 left-2 z-10 flex flex-col gap-1 items-start" data-popular-badges>
      {badges.map((b) => (
        <span
          class="inline-flex items-center justify-center px-1.5 py-1 rounded-[4px] [font-family:var(--font-body)] text-[16px] leading-none"
          style="background:#fa5109; color:#ffffff;"
        >{b.label}</span>
      ))}
    </div>
  )}

  <div class="flex flex-col gap-4 w-full">
    {colors.length > 0 && (
      <div class="flex items-center gap-1" data-popular-colors>
        {colors.map((c) => (
          <span
            class:list={[
              'inline-block w-5 h-5 rounded-[2px] relative overflow-hidden',
              c.available === false ? 'border border-[rgb(var(--color-text)/0.15)]' : '',
            ]}
            style={c.color ? `background:${c.color};` : 'background:rgb(var(--color-text)/0.05);'}
            aria-label={c.available === false ? 'недоступен' : undefined}
          >
            {c.available === false && (
              <svg viewBox="0 0 20 20" class="absolute inset-0 w-full h-full text-[rgb(var(--color-text)/0.4)]" stroke="currentColor" stroke-width="1" aria-hidden="true" preserveAspectRatio="none">
                <line x1="0" y1="20" x2="20" y2="0" />
              </svg>
            )}
          </span>
        ))}
      </div>
    )}

    <div class="flex flex-col gap-1 w-full">
      <a href={href} class="block [font-family:var(--font-body)] text-[16px] text-[rgb(var(--color-text))] truncate hover:opacity-80">{title}</a>
      <div class="flex items-center gap-2">
        <span class="[font-family:var(--font-body)] text-[16px] text-[rgb(var(--color-text))]">{price}</span>
        {showOld && (
          <span class="[font-family:var(--font-body)] text-[14px] text-[rgb(var(--color-muted))] line-through">{oldPrice}</span>
        )}
      </div>
    </div>

    {memoryChips.length > 0 && (
      <div class="flex items-start gap-1 flex-wrap" data-popular-memory>
        {memoryChips.map((m) => (
          <span
            class:list={[
              'inline-flex items-center px-1 py-1 rounded-[2px] [font-family:var(--font-body)] text-[12px] leading-none border border-solid',
              m.available === false
                ? 'text-[rgb(var(--color-muted))]'
                : 'text-[rgb(var(--color-text))]',
            ]}
            style={m.available === false
              ? 'background:rgb(var(--color-text)/0.05); border-color:rgb(var(--color-text)/0.05);'
              : 'background:transparent; border-color:rgb(var(--color-text)/0.05);'}
          >{m.value}</span>
        ))}
      </div>
    )}

    <button
      type="button"
      data-popular-cta
      class="w-full inline-flex items-center justify-center h-11 px-3 rounded-[4px] [font-family:var(--font-body)] font-normal text-[14px] uppercase tracking-[0.02em] cursor-pointer transition-opacity hover:opacity-85"
      style="background:#000000; color:#ffffff; font-weight:400;"
    >{ctaLabel}</button>
  </div>
</div>
