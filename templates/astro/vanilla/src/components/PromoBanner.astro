---
interface Props {
  text?: string;
  link?: any;
  linkText?: string;
  size?: string;
  colorScheme?: string;
}

const { text = 'Скидка 10% на общую сумму заказа от 9 000₽', link, linkText = 'Перейти', size = 'small', colorScheme } = Astro.props;

const href = typeof link === 'object' ? link?.href : (link || '#');
const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';

const sizeClasses: Record<string, string> = {
  small: 'py-2 sm:py-2.5 md:py-3 lg:py-3.5 xl:py-4 text-xs sm:text-sm md:text-base lg:text-lg xl:text-xl',
  medium: 'py-3 sm:py-3.5 md:py-4 lg:py-4.5 xl:py-5 text-sm sm:text-base md:text-lg lg:text-xl xl:text-2xl',
  large: 'py-4 sm:py-4.5 md:py-5 lg:py-5.5 xl:py-6 text-base sm:text-lg md:text-xl lg:text-2xl xl:text-3xl',
};
const sizeClass = sizeClasses[size] || sizeClasses.small;
---

<div class={`w-full ${sizeClass} ${schemeClass}`} style={schemeClass ? `background: rgb(var(--color-background)); color: rgb(var(--color-foreground));` : `background: rgb(var(--color-foreground)); color: rgb(var(--color-background));`}>
  <div class="w-full max-w-[1320px] mx-auto px-4 md:px-6">
    <a
      href={href}
      class="block text-center hover:opacity-80 transition-opacity font-normal leading-tight font-body"
    >
      <span class="inline-block">{text}</span>
      {linkText && (
        <span class="inline-block ml-1 sm:ml-2 md:ml-3 lg:ml-4 underline decoration-1 underline-offset-2">
          {linkText}
        </span>
      )}
    </a>
  </div>
</div>
