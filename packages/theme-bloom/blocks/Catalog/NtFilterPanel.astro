---
/**
 * NtFilterPanel (порт из design-systems-theme/components/ui/NtFilterPanel.astro).
 * Карточка фильтра 180px — «Фильтры 1920» (493:5444–5447) / «Фильтры 1280» (493:5439–5442).
 * Импорт NtFilterPriceRows — sibling в этой же block-папке (./).
 */
import NtFilterPriceRows from "./NtFilterPriceRows.astro";

type NtFilterPanelKind = "stock" | "price" | "color" | "sort";

interface Props {
  panel: NtFilterPanelKind;
  /** 1280: текст списков 12px (493:5442); 1920: 14px */
  density?: "1920" | "1280";
  class?: string;
}

const { panel, density = "1920", class: className = "" } = Astro.props;
const listSize = density === "1280" ? "text-[12px]" : "text-[14px]";
---

<div
  class:list={[
    "bg-[#FFFFFF] flex w-[180px] flex-col gap-2 rounded-[6px] border border-[#F5F5F5] p-3 font-manrope font-normal leading-[100%] min-h-[97px] justify-center",
    listSize,
    className,
  ]}
  data-nt="filter-panel"
  data-nt-panel={panel}
  data-nt-density={density}
>
  {
    panel === "stock" && (
      <>
        <p class="text-[#000000]">Все</p>
        <p class="text-[#999999]">В наличии</p>
        <p class="text-[#999999]">Распродано</p>
      </>
    )
  }
  {
    panel === "sort" && (
      <>
        <p class="text-[#000000]">Сначала дешевые</p>
        <p class="text-[#999999]">Сначала дорогие</p>
      </>
    )
  }
  {
    panel === "color" && (
      <>
        <p class="text-[#000000]">Белый</p>
        <p class="text-[#999999]">Чёрный</p>
        <p class="text-[#999999]">Серый</p>
      </>
    )
  }
  {panel === "price" && <NtFilterPriceRows variant="panel" />}
</div>
