---
import Layout from '../layouts/Layout.astro';
import AuthShell from '../components/auth/AuthShell.astro';
import AuthInput from '../components/auth/AuthInput.astro';
import AuthButton from '../components/auth/AuthButton.astro';
import AuthSecondaryLink from '../components/auth/AuthSecondaryLink.astro';

// Конфиг auth-стора: shopId патчит build.service (patchShopIdInDist) → siteId на деплое.
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";
---
<Layout title="Регистрация" promo={false}>
  <script is:inline define:vars={{ shopId, apiUrl }}>
    window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
      shopId: shopId || "",
      apiUrl: apiUrl || "https://gateway.merfy.ru/api",
    };
  </script>

  <AuthShell title="Создать аккаунт" description="Введите e-mail — пришлём ссылку для входа. Пароль не нужен.">
    <form id="magic-form" class="w-full flex flex-col gap-6" novalidate>
      <AuthInput
        label="E-mail"
        type="email"
        name="email"
        id="reg-email"
        placeholder="example@merfy.ru"
        required
        autocomplete="email"
      />
      <div class="auth-helper-error hidden text-center" id="reg-error" role="alert"></div>
    </form>

    <div class="w-full flex flex-col items-center gap-10">
      <AuthButton id="btn-magic" form="magic-form" loadingLabel="Отправляем...">Зарегистрироваться</AuthButton>
      <AuthSecondaryLink href="/login" helper="Уже есть аккаунт?">Войти</AuthSecondaryLink>
    </div>
  </AuthShell>

  <script>
    import { navTo, requestMagicLink, getToken } from '../lib/auth';

    // Санитайзер redirect-параметра: только same-origin относительный путь
    // ('/…', но не '//host'). Иначе — /account. Зеркалит login.astro.
    const safeRedirect = (r: string | null): string =>
      r && /^\/(?![\/\\])[^\u0000-\u001f\u007f]*$/.test(r) ? r : '/account';

    function initRegisterPage() {
      const form = document.getElementById('magic-form') as HTMLFormElement | null;
      if (!form || form.dataset.bound === 'true') return;
      form.dataset.bound = 'true';

      // Уже вошёл → редирект (чтим ?redirect, паритет с login).
      if (getToken()) {
        navTo(safeRedirect(new URLSearchParams(window.location.search).get('redirect')));
        return;
      }

      const errorEl = document.getElementById('reg-error')!;
      const emailField = document.getElementById('reg-email') as HTMLInputElement;
      const btn = document.getElementById('btn-magic') as HTMLButtonElement;

      // Префилл email (в т.ч. из invite-ссылки /register?invite=...&email=...).
      // Invite-токен игнорируем: magic-вход создаёт аккаунт и мигрирует гостевые
      // заказы через событие customer.registered (тот же эффект, без пароля).
      const prefill = new URLSearchParams(window.location.search).get('email');
      if (prefill) emailField.value = prefill;

      const validEmail = (e: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e);
      const showError = (msg: string) => { errorEl.textContent = msg; errorEl.classList.remove('hidden'); };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorEl.classList.add('hidden');
        const email = emailField.value.trim();
        if (!email || !validEmail(email)) {
          emailField.setAttribute('data-error', 'true');
          showError('Введите корректный e-mail');
          return;
        }
        const l = btn.querySelector('[data-loading]');
        const t = btn.querySelector('[data-button-text]');
        l?.classList.remove('hidden'); t?.classList.add('hidden'); btn.disabled = true;
        try {
          const result = await requestMagicLink({ email });
          if (result.success) {
            sessionStorage.setItem('magicEmail', email);
            // Паритет с login: проводим ?redirect сквозь /register → /verify
            // (sessionStorage, same-tab). verify.astro прочитает на успехе.
            const rd = safeRedirect(new URLSearchParams(window.location.search).get('redirect'));
            if (rd !== '/account') sessionStorage.setItem('authRedirect', rd);
            navTo('/verify');
          } else { throw result; }
        } catch (err: any) {
          let msg = err?.error || err?.message || 'Не удалось отправить ссылку';
          if (err?.code === 'RATE_LIMIT_EXCEEDED') msg = 'Письмо уже отправлено. Проверьте почту.';
          showError(msg);
        } finally {
          l?.classList.add('hidden'); t?.classList.remove('hidden'); btn.disabled = false;
        }
      });
    }

    initRegisterPage();
    document.addEventListener('astro:page-load', initRegisterPage);
  </script>
</Layout>
