---
import NtTextField from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtTextField.astro";

// ОЖИВЛЕНИЕ: канон-схема ContactForm. Тело верстальщика дословно.
// heading — поле канон-схемы (union string | { text }). phone/email — flat-пропсы
// оживления с фоллбеком на побайтовое значение верстальщика (схема описывает
// поля ФОРМЫ, контактные данные магазина приходят отдельными пропсами).
const p = Astro.props as Record<string, any>;
const id = p.id;
const heading = p.heading?.text ?? p.heading ?? "Контакты";
const phone = p.phone ?? "+7 (000) 000-00-00";
const email = p.email ?? "rose@example.ru";
const phoneHref = `tel:${phone.replace(/[^+\d]/g, "")}`;
const emailHref = `mailto:${email}`;
---

<section
	class="w-full bg-white px-4 pb-[60px] pt-12 sm:px-5 md:px-10 md:pb-[80px] md:pt-20 lg:px-16 xl:px-20 2xl:px-[280px]"
	aria-labelledby="contacts-title"
	data-puck-component-id={id}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-16 md:gap-20">
		<div class="flex flex-col gap-6">
			<h1
				id="contacts-title"
				class="rose-title"
				data-puck-subsection-parent={id}
				data-puck-subsection-index="100"
				data-puck-subsection-field="heading"
			>
				{heading}
			</h1>
			<dl class="flex flex-col gap-3 font-manrope text-[14px] font-normal leading-normal md:text-[16px]">
				<div class="flex flex-col gap-1 md:flex-row md:gap-16">
					<dt class="text-[#999999] md:w-[200px]">Номер телефона</dt>
					<dd class="text-[#000000]">
						<a href={phoneHref} class="hover:opacity-80 transition-opacity">
							{phone}
						</a>
					</dd>
				</div>
				<div class="flex flex-col gap-1 md:flex-row md:gap-16">
					<dt class="text-[#999999] md:w-[200px]">E-mail</dt>
					<dd class="text-[#000000]">
						<a href={emailHref} class="hover:opacity-80 transition-opacity">
							{email}
						</a>
					</dd>
				</div>
			</dl>
		</div>

		<div class="flex flex-col gap-8">
			<h2 class="rose-title">
				Остались вопросы?
			</h2>

			<form
				class="grid grid-cols-1 gap-6 lg:grid-cols-[430px_1fr] lg:items-start lg:gap-10"
				data-contacts-form
				novalidate
			>
				<div class="flex flex-col gap-4">
					<NtTextField label="Имя" name="name" autocomplete="name" />
					<NtTextField label="E-mail" name="email" type="email" autocomplete="email" />
					<NtTextField label="Номер телефона" name="phone" type="tel" autocomplete="tel" />
				</div>

				<div class="flex flex-col gap-2">
					<label for="contacts-question" class="font-manrope text-[16px] font-normal leading-normal text-[#000000]">
						Ваш вопрос
					</label>
					<textarea
						id="contacts-question"
						name="question"
						rows={8}
						class="min-h-[232px] w-full rounded-[4px] border border-[#000000] bg-white p-4 font-manrope text-[16px] font-normal leading-normal text-[#000000] outline-none placeholder:text-[#999999] focus-visible:border-[#000000]"
					></textarea>
				</div>

				<div class="lg:col-start-2 lg:flex lg:justify-end">
					<button
						type="submit"
						class="rose-btn-primary inline-flex h-12 min-w-[200px] items-center justify-center rounded-[6px] px-8 font-manrope text-[16px] font-normal leading-normal"
					>
						Отправить
					</button>
				</div>

				<p
					data-contacts-status
					role="status"
					class="hidden lg:col-span-2 font-manrope text-[16px] font-normal leading-normal text-[#4AD300]"
				></p>
			</form>
		</div>
	</div>
</section>
