---
/**
 * ProductCounter — quantity selector.
 *
 * Variants (LAYOUT only):
 *  - `inline` (rose) — minus/value/plus, no fill, icons size-6, gap-3
 *  - `pill` (flux) — same controls inside a filled rounded-4 pill, gap-2 p-2
 *
 * Pill colour is mono (--color-text on --color-bg) — matches the page text
 * colour, not the primary button colour. Counter is a utility control,
 * not a CTA, so it stays neutral regardless of merchant accent choice.
 */
interface Props {
  variant?: 'inline' | 'pill';
  initialValue?: number;
}

const { variant = 'inline', initialValue = 1 } = Astro.props as Props;
const isPill = variant === 'pill';
---
<div
  class:list={[
    'inline-flex items-center [font-family:var(--font-body)]',
    isPill ? 'gap-2 p-2 rounded-[4px]' : 'text-[rgb(var(--color-text))] gap-3',
  ]}
  style={isPill
    ? 'background:rgb(var(--color-text)); color:rgb(var(--color-bg));'
    : ''}
  data-product-counter
  data-counter-variant={variant}
>
  <button
    type="button"
    data-counter-action="decrement"
    aria-label="Уменьшить количество"
    class:list={[
      'inline-flex items-center justify-center cursor-pointer transition-opacity hover:opacity-70 bg-transparent border-0 text-current',
      isPill ? 'w-8 h-8 rounded-[4px]' : 'w-6 h-6',
    ]}
  >
    <svg width={isPill ? '16' : '24'} height={isPill ? '16' : '24'} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <line x1="5" y1="12" x2="19" y2="12" />
    </svg>
  </button>
  <span
    class:list={[
      'min-w-6 text-center select-none',
      isPill ? 'text-[20px]' : 'text-[16px]',
    ]}
    data-counter-value
  >{initialValue}</span>
  <button
    type="button"
    data-counter-action="increment"
    aria-label="Увеличить количество"
    class:list={[
      'inline-flex items-center justify-center cursor-pointer transition-opacity hover:opacity-70 bg-transparent border-0 text-current',
      isPill ? 'w-8 h-8 rounded-[4px]' : 'w-6 h-6',
    ]}
  >
    <svg width={isPill ? '16' : '24'} height={isPill ? '16' : '24'} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <line x1="12" y1="5" x2="12" y2="19" />
      <line x1="5" y1="12" x2="19" y2="12" />
    </svg>
  </button>
</div>
