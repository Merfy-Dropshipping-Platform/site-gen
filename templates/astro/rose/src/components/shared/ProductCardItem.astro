---
interface Props {
	id?: string;
	name: string;
	price: string;
	oldPrice?: string;
	image: string;
	href?: string;
	quantity?: number;
	quickAdd?: boolean;
}

const { id, name, price, oldPrice, image, href = '#', quantity, quickAdd = false } = Astro.props;
const hasImage = image && !image.includes('placeholder');
---

<div class="flex flex-col h-full overflow-hidden group">
	<a href={href} class="cursor-pointer">
		<div class="relative overflow-hidden w-full aspect-[3/4]" style="background: rgb(var(--color-foreground) / 0.05); border-radius: var(--card-radius, 10px);">
			{hasImage ? (
				<img
					src={image}
					alt={name}
					loading="lazy"
					class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
				/>
			) : (
				<div class="w-full h-full flex items-center justify-center" style="background: rgb(var(--color-foreground) / 0.05);">
					<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-theme-muted">
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
						<circle cx="8.5" cy="8.5" r="1.5" />
						<polyline points="21 15 16 10 5 21" />
					</svg>
				</div>
			)}
		</div>
	</a>
	<div class="pb-4 pt-3 flex flex-col gap-1 flex-1">
		<a href={href} class="no-underline text-inherit">
			<span class="text-base font-light text-theme-foreground font-body line-clamp-2">
				{name}
			</span>
		</a>
		<span class="text-base font-light text-theme-foreground font-body">
			{price}
		</span>
		{oldPrice && (
			<span class="text-sm font-light text-theme-muted line-through font-body">
				{oldPrice}
			</span>
		)}
		<a href={href} class="text-sm font-light underline mt-1 cursor-pointer text-theme-foreground font-body no-underline-offset">
			Подробнее
		</a>
		{quickAdd && id && (
			<button
				type="button"
				class="add-to-cart-btn mt-auto w-full py-2 px-4 bg-theme-primary text-theme-button-text text-sm font-light rounded-lg hover:opacity-90 transition-colors"
				data-product-id={id}
				data-stock={quantity != null ? quantity : undefined}
			>
				В корзину
			</button>
		)}
	</div>
</div>
