---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AccountNav from '../../components/AccountNav.astro';

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};
---
<BaseLayout title={`Мои заказы — ${meta?.title ?? 'Мой сайт'}`}>
  <Header {...headerProps} />

  <main class="flex-1 w-full font-body" style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));">
    <div class="max-w-[960px] mx-auto px-5 py-10 w-full">
      <h1 class="text-3xl font-heading mb-8" style="color: rgb(var(--color-foreground));">Мои заказы</h1>

      <div class="md:flex md:gap-10">
        <AccountNav active="orders" />

        <div class="flex-1">
          <div id="orders-loading" class="text-center py-10" style="color: rgb(var(--color-muted));">Загрузка...</div>
          <div id="orders-empty" class="hidden text-center py-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-4" style="color: rgb(var(--color-muted) / 0.4);"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="8" x2="16" y1="10" y2="10"/><line x1="8" x2="12" y1="14" y2="14"/></svg>
            <p class="text-lg mb-4" style="color: rgb(var(--color-muted));">У вас пока нет заказов</p>
            <a href="/catalog" class="inline-block py-3 px-6 font-medium transition-colors btn-primary" style="border-radius: 0;">Перейти в каталог</a>
          </div>
          <div id="orders-error" class="hidden text-center py-10">
            <p class="text-red-400 text-lg mb-4">Не удалось загрузить заказы</p>
            <button onclick="window.location.reload()" class="inline-block py-2.5 px-5 text-sm font-medium border transition-colors" style="border-radius: 0; border-color: rgb(var(--color-foreground) / 0.19); color: rgb(var(--color-foreground));">Попробовать снова</button>
          </div>
          <div id="orders-list" class="hidden space-y-4"></div>
        </div>
      </div>
    </div>
  </main>

  <Footer {...footerProps} />

  <script is:inline src="/scripts/customer-store.js"></script>
  <script is:inline src="/scripts/customer-auth.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', async function() {
      if (!window.CustomerStore || !window.CustomerStore.isLoggedIn()) {
        window.location.href = '/login?redirect=/account/orders';
        return;
      }

      var loadingEl = document.getElementById('orders-loading');
      var emptyEl = document.getElementById('orders-empty');
      var errorEl = document.getElementById('orders-error');
      var listEl = document.getElementById('orders-list');
      var logoutBtn = document.getElementById('btn-logout');

      // Logout handler
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async function() {
          await window.CustomerAuth.logout();
          window.location.href = '/login';
        });
      }

      var statusLabels = {
        cart: '\u041a\u043e\u0440\u0437\u0438\u043d\u0430',
        pending: '\u041e\u0436\u0438\u0434\u0430\u0435\u0442 \u043e\u043f\u043b\u0430\u0442\u044b',
        paid: '\u041e\u043f\u043b\u0430\u0447\u0435\u043d',
        processing: '\u0412 \u0441\u0431\u043e\u0440\u043a\u0435',
        sent: '\u041e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d',
        delivered: '\u0414\u043e\u0441\u0442\u0430\u0432\u043b\u0435\u043d',
        cancelled: '\u041e\u0442\u043c\u0435\u043d\u0451\u043d',
        refunded: '\u0412\u043e\u0437\u0432\u0440\u0430\u0442',
      };

      var statusColors = {
        cart: 'bg-gray-100 text-gray-600',
        pending: 'bg-yellow-100 text-yellow-800',
        paid: 'bg-green-100 text-green-800',
        processing: 'bg-blue-100 text-blue-800',
        sent: 'bg-purple-100 text-purple-800',
        delivered: 'bg-emerald-100 text-emerald-800',
        cancelled: 'bg-red-100 text-red-800',
        refunded: 'bg-orange-100 text-orange-800',
      };

      try {
        var config = window.__MERFY_CONFIG__ || {};
        var apiUrl = config.apiUrl || '';
        var storeId = config.shopId || config.storeId || config.siteId || '';
        var token = window.CustomerStore.getToken();

        var PAGE_SIZE = 10;
        var currentSkip = 0;

        function buildUrl(skip) {
          var u = apiUrl + '/store/orders?skip=' + skip + '&take=' + PAGE_SIZE;
          if (storeId) u += '&store_id=' + encodeURIComponent(storeId);
          return u;
        }

        var resp = await fetch(buildUrl(0), {
          headers: { 'Authorization': 'Bearer ' + token },
        });
        var result = await resp.json();

        loadingEl.classList.add('hidden');

        if (!result.success || !result.data?.items?.length) {
          emptyEl.classList.remove('hidden');
          return;
        }

        var orders = result.data.items;
        var totalCount = result.data.total || orders.length;
        currentSkip = orders.length;
        listEl.classList.remove('hidden');

        function renderOrder(order) {
          var date = new Date(order.createdAt).toLocaleDateString('ru-RU', {
            day: 'numeric', month: 'long', year: 'numeric',
          });
          var total = order.totalCents
            ? (order.totalCents / 100).toLocaleString('ru-RU') + ' \u20bd'
            : '\u2014';
          var status = statusLabels[order.status] || order.status;
          var statusClass = statusColors[order.status] || 'bg-gray-100 text-gray-800';

          var itemsCount = order.itemsCount || (order.items ? order.items.length : 0);
          var itemsText = '';
          if (itemsCount > 0) {
            var lastDigit = itemsCount % 10;
            var lastTwo = itemsCount % 100;
            var word = '\u0442\u043e\u0432\u0430\u0440\u043e\u0432';
            if (lastTwo >= 11 && lastTwo <= 19) word = '\u0442\u043e\u0432\u0430\u0440\u043e\u0432';
            else if (lastDigit === 1) word = '\u0442\u043e\u0432\u0430\u0440';
            else if (lastDigit >= 2 && lastDigit <= 4) word = '\u0442\u043e\u0432\u0430\u0440\u0430';
            itemsText = itemsCount + ' ' + word;
          }

          var card = document.createElement('a');
          card.href = '/account/order?n=' + encodeURIComponent(order.orderNumber);
          card.className = 'block p-5 shadow-sm hover:shadow-md transition-shadow';
          card.style.cssText = 'background: rgb(var(--color-card)); border-radius: 0;';
          // Delivery status badge
          var deliveryBadge = '';
          if (order.deliveryStatusName && order.deliveryType && order.deliveryType.includes('cdek')) {
            var dColors = {
              CREATED: 'bg-gray-100 text-gray-600',
              ACCEPTED: 'bg-blue-50 text-blue-600',
              IN_TRANSIT: 'bg-blue-100 text-blue-700',
              READY_FOR_PICK_UP: 'bg-green-100 text-green-700',
              DELIVERED: 'bg-emerald-100 text-emerald-700',
              NOT_DELIVERED: 'bg-red-100 text-red-600',
              RETURNED: 'bg-orange-100 text-orange-600',
            };
            var dClass = dColors[order.deliveryStatus] || 'bg-gray-100 text-gray-600';
            deliveryBadge = '<span class="text-xs px-2 py-0.5 rounded-full font-medium ' + dClass + '">\u0421\u0414\u042d\u041a: ' + order.deliveryStatusName + '</span>';
          }

          card.innerHTML =
            '<div class="flex items-center justify-between mb-2">' +
              '<span class="font-medium">\u0417\u0430\u043a\u0430\u0437 \u2116' + order.orderNumber + '</span>' +
              '<div class="flex items-center gap-2">' +
                deliveryBadge +
                '<span class="text-xs px-2.5 py-1 rounded-full font-medium ' + statusClass + '">' + status + '</span>' +
              '</div>' +
            '</div>' +
            '<div class="flex items-center justify-between text-sm" style="color:rgb(var(--color-muted))">' +
              '<span>' + date + (itemsText ? ' \u00b7 ' + itemsText : '') + '</span>' +
              '<span class="font-medium" style="color:rgb(var(--color-foreground))">' + total + '</span>' +
            '</div>' +
            (order.promoCode ? '<div class="mt-1 text-xs text-green-600">\u041f\u0440\u043e\u043c\u043e\u043a\u043e\u0434: ' + order.promoCode + '</div>' : '');
          listEl.appendChild(card);
        }

        orders.forEach(renderOrder);

        // "Показать ещё" button
        if (currentSkip < totalCount) {
          var loadMoreBtn = document.createElement('button');
          loadMoreBtn.id = 'btn-load-more';
          loadMoreBtn.className = 'w-full py-3 px-4 font-medium transition-colors mt-4';
          loadMoreBtn.style.cssText = 'border: 1px solid rgb(var(--color-foreground) / 0.19); color: rgb(var(--color-foreground)); border-radius: 0;';
          loadMoreBtn.textContent = '\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u044c \u0435\u0449\u0451';
          listEl.parentElement.appendChild(loadMoreBtn);

          loadMoreBtn.addEventListener('click', async function() {
            loadMoreBtn.disabled = true;
            loadMoreBtn.textContent = '\u0417\u0430\u0433\u0440\u0443\u0437\u043a\u0430...';
            try {
              var moreResp = await fetch(buildUrl(currentSkip), {
                headers: { 'Authorization': 'Bearer ' + token },
              });
              var moreResult = await moreResp.json();
              if (moreResult.success && moreResult.data?.items?.length) {
                moreResult.data.items.forEach(renderOrder);
                currentSkip += moreResult.data.items.length;
                if (currentSkip >= totalCount || moreResult.data.items.length < PAGE_SIZE) {
                  loadMoreBtn.remove();
                } else {
                  loadMoreBtn.disabled = false;
                  loadMoreBtn.textContent = '\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u044c \u0435\u0449\u0451';
                }
              } else {
                loadMoreBtn.remove();
              }
            } catch (e) {
              loadMoreBtn.disabled = false;
              loadMoreBtn.textContent = '\u041f\u043e\u043f\u0440\u043e\u0431\u043e\u0432\u0430\u0442\u044c \u0441\u043d\u043e\u0432\u0430';
            }
          });
        }
      } catch (err) {
        loadingEl.classList.add('hidden');
        errorEl.classList.remove('hidden');
      }
    });
  </script>
</BaseLayout>

<style>
  .btn-primary { background-color: rgb(var(--color-primary)); color: #fff; }
  .btn-primary:hover { filter: brightness(0.85); }
</style>
