---
// Фаза B (vanilla, группа misc): новая канон-секция Newsletter в манере vanilla
// (см. themes/vanilla/MANNER.md §8; эталон процесса — themes/bloom Newsletter).
// Схема полей = packages/theme-base/blocks/Newsletter/Newsletter.puckConfig.ts.
// Тело = КОПИЯ src/components/footer/FooterNewsletter.astro (оригинал НЕ тронут —
// его использует Layout через showNewsletter): тёмное полотно №2 (#3A4530),
// заголовок Bitter italic 20 white, текст Arsenal italic 14/16 #F0F0F0,
// форма-рамка border-white max-w-[652px] с белой кнопкой; data-vanilla-newsletter
// сохранён — ::after-сшивка полос в global.css (g:166-203) работает и здесь.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading: string | { text, alignment, size }. Figma 1:19335 — ДОСЛОВНЫЙ
// плейсхолдер ПУСТОГО состояния Newsletter: «Подпишитесь на нашу рассылку»
// (дефолт-текст верстальщика FN:18 «Будьте в курсе уютных новостей» заменён на
// Figma-текст; эталон — themes/rose Newsletter.astro). Мерчант задал свой heading
// → рендерим ЕГО (?? срабатывает лишь при пустых данных). Роль FN:16 (Bitter
// italic 20 white) — фоллбек токена 255_255_255, как у верстальщика.
const heading =
	typeof p.heading === "string"
		? p.heading
		: (p.heading?.text ?? "Подпишитесь на нашу рассылку");
// Лестница §9 от базы-литерала 20 (medium): small 17, large 24.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small" ? "text-[17px]" : headingSize === "large" ? "text-[24px]" : "text-[20px]";
const headingCls = `m-0 font-vanilla-bitter ${headingSizeCls} font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,255_255_255))]`;

// Канон description (string) + text {content,size} (pupa-дубль). Figma 1:19335 —
// ДОСЛОВНЫЙ плейсхолдер ПУСТОГО состояния: «Узнавайте первыми о новых коллекциях
// и эксклюзивных предложениях.» (дефолт-текст верстальщика FN:23-24 «Станьте
// частью сообщества Vanila…» заменён на Figma-текст; эталон rose). Мерчант задал
// description/text → рендерим ЕГО (?? лишь при пустых данных). Рендер через
// set:html — поле может содержать <br />. Роль FN:21: Arsenal italic 14 lg:16,
// #F0F0F0 → токен text, фоллбек 240_240_240.
const description =
	(typeof p.description === "string" && p.description.trim() ? p.description : undefined) ??
	(typeof p.text?.content === "string" && p.text.content.trim() ? p.text.content : undefined) ??
	"Узнавайте первыми о новых коллекциях и эксклюзивных предложениях.";
// Лестница «текст полотна» §9 (литерал 14/16 = large): small 10/11, medium 12/14.
const descSize = p.text?.size;
const descSizeCls =
	descSize === "small"
		? "text-[10px] lg:text-[11px]"
		: descSize === "medium"
			? "text-[12px] lg:text-[14px]"
			: "text-[14px] lg:text-[16px]";

// Канон placeholder/buttonText. Figma 1:19335 — ДОСЛОВНЫЙ плейсхолдер ПУСТОГО
// состояния: input «email@example.com», кнопка «Кнопка» (дефолты верстальщика
// FN:36 «E-mail» / FN:44 «ОТПРАВИТЬ» заменены на Figma-текст; эталон rose).
// Мерчант задал свои placeholder/buttonText → рендерим ИХ (fallback лишь при пустых данных).
const placeholder =
	typeof p.placeholder === "string" && p.placeholder.trim() ? p.placeholder : "email@example.com";
const buttonText =
	typeof p.buttonText === "string" && p.buttonText.trim() ? p.buttonText : "Кнопка";

// Канон formLayout: blockDefaults темы 'inline-submit' (совпадает с отсутствием
// пропа) = форма FN:29-46 VERBATIM (рамка border-white p-3, sm-ряд h-14 pl-4
// pr-3, прозрачный input, белая кнопка h-9 sm:h-8); 'stacked' = поле-рамка +
// белая кнопка под ним (манера §3/§5: формы полотен — прозрачные, белый бордер,
// без радиуса).
const inlineSubmit = p.formLayout !== "stacked";

// Канон agreement (toggle 'true'/'false', default 'false'): при 'true' — чекбокс
// согласия под формой (манера vanilla: Arsenal italic мелкий, токен text на
// тёмном полотне); иначе ничего.
const showAgreement = p.agreement === "true";

// Канон alignment (blockDefaults 'left' = литерал FN:10 items-start text-left);
// center/right двигают колонку по контейнеру. Выравнивание живёт в под-панели
// «Заголовок» (heading.alignment) — основной контрол (как rose T17); top-level
// p.alignment скрыт (type:'hidden'), p.position — pupa-дубль; оба как fallback.
const alignmentValue = p.heading?.alignment ?? p.alignment ?? p.position;
const alignment =
	alignmentValue === "center" || alignmentValue === "right" ? alignmentValue : "left";
const alignCls =
	alignment === "center"
		? "items-center text-center"
		: alignment === "right"
			? "items-end text-right"
			: "items-start text-left";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id ? `${id}-title` : undefined;
---

<section
	class="vanilla-pad m-0 w-full shrink-0 border-0 bg-[rgb(var(--color-bg,58_69_48))] py-16 lg:py-[120px]"
	aria-labelledby={titleId}
	data-vanilla-newsletter
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div
		class={`mx-auto flex w-full max-w-[1280px] min-[1920px]:max-w-[1320px] flex-col gap-10 ${alignCls}`}
		data-animate
	>
		<div class="flex w-full flex-col gap-2">
			<h2
				id={titleId}
				class={headingCls}
				data-puck-subsection-parent={id}
				data-puck-subsection-index="100"
				data-puck-subsection-field="heading"
			>
				{heading}
			</h2>
			<p
				class={`m-0 w-full font-vanilla-arsenal ${descSizeCls} font-normal italic leading-none text-[rgb(var(--color-text,240_240_240))]`}
				data-puck-subsection-parent={id}
				data-puck-subsection-index="101"
				data-puck-subsection-field="text"
				set:html={description}
			/>
		</div>

		{
			inlineSubmit ? (
				<form
					class="flex w-full max-w-[652px] flex-col items-stretch justify-between gap-3 border border-white bg-transparent p-3 transition-colors focus-within:border-white/80 sm:h-14 sm:flex-row sm:items-center sm:gap-2 sm:py-0 sm:pl-4 sm:pr-3"
					data-newsletter-form
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="placeholder"
				>
					<input
						type="email"
						name="email"
						required
						placeholder={placeholder}
						aria-label={placeholder}
						class="min-w-0 flex-1 bg-transparent font-vanilla-arsenal text-base font-normal leading-none text-[rgb(var(--color-text,240_240_240))] placeholder:text-[rgb(var(--color-text,240_240_240))] outline-none"
					/>
					<button
						type="submit"
						class="inline-flex h-9 w-full shrink-0 items-center justify-center bg-[rgb(var(--color-button-2-bg,255_255_255))] px-2 py-2.5 font-vanilla-arsenal text-base font-normal uppercase leading-none text-[rgb(var(--color-button-2-text,58_69_48))] transition-opacity hover:opacity-80 sm:h-8 sm:w-auto"
					>
						{buttonText}
					</button>
				</form>
			) : (
				<form
					class="flex w-full max-w-[652px] flex-col gap-3"
					data-newsletter-form
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="placeholder"
				>
					<input
						type="email"
						name="email"
						required
						placeholder={placeholder}
						aria-label={placeholder}
						class="h-14 w-full border border-white bg-transparent px-4 font-vanilla-arsenal text-base font-normal leading-none text-[rgb(var(--color-text,240_240_240))] placeholder:text-[rgb(var(--color-text,240_240_240))] outline-none transition-colors focus-visible:border-white/80"
					/>
					<button
						type="submit"
						class="inline-flex h-12 min-h-12 items-center justify-center self-start bg-[rgb(var(--color-button-2-bg,255_255_255))] px-4 font-vanilla-arsenal text-base font-normal uppercase leading-none text-[rgb(var(--color-button-2-text,58_69_48))] transition-opacity hover:opacity-80"
					>
						{buttonText}
					</button>
				</form>
			)
		}
		{
			showAgreement && (
				<label class="flex w-full max-w-[652px] cursor-pointer items-start gap-2 font-vanilla-arsenal text-[13px] font-normal italic leading-snug text-[rgb(var(--color-text,240_240_240))]">
					<input
						type="checkbox"
						required
						class="mt-0.5 size-4 shrink-0 accent-[rgb(var(--color-button-2-bg,255_255_255))]"
					/>
					<span>Согласен на обработку персональных данных</span>
				</label>
			)
		}
		<p
			data-newsletter-status
			role="status"
			class="hidden font-vanilla-arsenal text-base font-normal leading-[1.5] text-[rgb(var(--color-text,255_255_255))]"
		></p>
	</div>
</section>

<script>
	// Сабмит-статус «Спасибо!…» (как FooterNewsletter.astro:55-66), но делегированно
	// на document: переживает hot-replace превью без повторной привязки (модуль
	// исполняется один раз — window-гард компилятора секций / дедупликация hoisted
	// скриптов astro build) и обслуживает любое число копий секции на странице.
	document.addEventListener("submit", (event) => {
		const form = (event.target as HTMLElement | null)?.closest?.<HTMLFormElement>(
			"form[data-newsletter-form]",
		);
		if (!form) return;
		event.preventDefault();
		const status = form
			.closest("[data-vanilla-newsletter]")
			?.querySelector<HTMLElement>("[data-newsletter-status]");
		if (status) {
			status.textContent = "Спасибо! Мы отправим вам приветственное письмо.";
			status.classList.remove("hidden");
		}
		form.reset();
	});
</script>
