---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";

// Фаза B (flux, группа misc): новая канон-секция Newsletter в манере flux (см.
// themes/flux/MANNER.md; эталоны — bloom Newsletter, rose T17). Схема полей =
// packages/theme-base/blocks/Newsletter/Newsletter.puckConfig.ts. Тело = КОПИЯ
// блока подписки подвала верстальщика (Footer.astro:36-74 — подвал не тронут):
// заголовок Comfortaa 16/18 uppercase, описание Roboto Flex 300 12/14 muted,
// форма h-11/12 c бордером #F5F5F5 и кнопкой-иконкой arrow-right, статус
// #4AD300. ⚠️ Радиус формы — через --radius-field (4px в theme.json), НЕ через
// --radius-input (8px — увёл бы литерал, §5). Скролл-анимаций нет (§6).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Live-конфиг подписки: shopId патчит build.service (patchShopIdInDist) → siteId
// на деплое (заменяет `const shopId = ""` в HTML); apiUrl — публичный gateway.
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";

// Канон heading: string | { text, alignment, size }; canon-default = литерал
// подвала «Подпишитесь на нашу рассылку» (F:42). Роль F:40 — Comfortaa 16/18
// uppercase leading-normal, цвет — токен heading с фоллбеком чёрного.
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Подпишитесь на нашу рассылку");
// Лестница §9 заголовка рассылки (дефолт роли — medium): отсутствие пропа и
// medium = литерал 16/md:18; small 11/13, large 19/22.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[11px] md:text-[13px]"
		: headingSize === "large"
			? "text-[19px] md:text-[22px]"
			: "text-[16px] md:text-[18px]";
const headingCls = `font-comfortaa ${headingSizeCls} font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))]`;
// «Выравнивание» (конструктор пишет position) рулит И позицией содержимого в
// контейнере (items-* двигает форму max-w-460 и текст-колонку), И выключкой
// заголовка/текста (text-*): «слева-слева»/«центр-центр»/«право-право». Раньше
// выравнивания по position не было вовсе (только headingAlignment, который
// конструктор не пишет) → «выравнивание не работает».
const position = p.position === "center" || p.position === "right" ? p.position : "left";
const alignCls =
	position === "center"
		? "items-center text-center"
		: position === "right"
			? "items-end text-right"
			: "items-start text-left";

// Канон description (string) + text {content, size} (pupa-дубль). ПУСТОЕ состояние:
// дословный Figma-плейсхолдер 1:19335 «Узнавайте первыми о новых коллекциях и
// эксклюзивных предложениях.» (НЕ литерал подвала верстальщика «Получайте
// информацию от нашего бренда»). Когда мерчант задал description/text.content —
// рендерим ЕГО (?? fallback срабатывает только при пустых данных). Roboto Flex
// 300 12/14 #999999 → токен muted. Лестница §9 текста рассылки: small 10/11,
// medium/отсутствие = литерал 12/14, large 14/17.
const description =
	(typeof p.description === "string" && p.description.trim() ? p.description : undefined) ??
	(typeof p.text?.content === "string" && p.text.content.trim() ? p.text.content : undefined) ??
	"Узнавайте первыми о новых коллекциях и эксклюзивных предложениях.";
const descSize = p.text?.size;
const descSizeCls =
	descSize === "small"
		? "text-[10px] md:text-[11px]"
		: descSize === "large"
			? "text-[14px] md:text-[17px]"
			: "text-[12px] md:text-[14px]";

// Канон placeholder. ПУСТОЕ состояние: дословный Figma-плейсхолдер 1:19335
// «email@example.com» (как канон theme-base Newsletter.astro), НЕ литерал подвала
// верстальщика «flux@example.ru». Заданный мерчантом placeholder — рендерим его.
const placeholder =
	typeof p.placeholder === "string" && p.placeholder.trim() ? p.placeholder : "email@example.com";

// Канон buttonText. ПУСТОЕ состояние: дословный Figma-плейсхолдер 1:19335 —
// текстовая кнопка «Кнопка» (НЕ иконка arrow-right верстальщика F:61-67).
// Текстовая чёрная кнопка манеры §3 (токены кнопки-2: в схемах flux чёрная
// кнопка = кнопка-2). Заданный мерчантом buttonText — рендерим его текстом.
// Иконка-ветка ниже остаётся фолбэком, если data явно зануляет buttonText.
const buttonText = typeof p.buttonText === "string" && p.buttonText.trim() ? p.buttonText : "Кнопка";

// Канон agreement (toggle 'true'/'false', default 'false'): при 'true' — чекбокс
// согласия под формой (манера flux: Roboto Flex 300 мелкий muted, акцент
// кнопки-2 чёрный); иначе ничего.
const showAgreement = p.agreement === "true";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 py-16 md:px-20 md:py-24 2xl:px-80"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class={`mx-auto flex w-full max-w-[1320px] flex-col gap-4 ${alignCls}`}>
		<div class="flex flex-col gap-1">
			<h2
				id={titleId}
				class={headingCls}
				data-puck-subsection-parent={id}
				data-puck-subsection-index="100"
				data-puck-subsection-field="heading"
			>
				{heading}
			</h2>
			<p
				class={`font-roboto-flex ${descSizeCls} font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]`}
				data-puck-subsection-parent={id}
				data-puck-subsection-index="101"
				data-puck-subsection-field="text"
			>
				{description}
			</p>
		</div>

		<form
			class="flex h-11 w-full max-w-[460px] items-center justify-between gap-2 rounded-[var(--radius-field,4px)] border border-[rgb(var(--color-surface,245_245_245))] bg-white pl-3 pr-1 md:h-12"
			data-newsletter-form
			data-puck-subsection-parent={id}
			data-puck-subsection-index="997"
			data-puck-subsection-field="placeholder"
		>
			<input
				type="email"
				name="email"
				required
				placeholder={placeholder}
				aria-label="Email"
				class="min-w-0 flex-1 bg-transparent font-manrope text-[12px] font-normal leading-normal text-[#000000] placeholder:text-[rgb(var(--color-muted,153_153_153))] outline-none md:text-[14px]"
			/>
			{
				buttonText ? (
					<button
						type="submit"
						class="inline-flex h-10 shrink-0 items-center justify-center rounded-[var(--radius-button,6px)] bg-[rgb(var(--color-button-2-bg,0_0_0))] px-3 font-manrope text-[12px] font-normal leading-normal text-[rgb(var(--color-button-2-text,255_255_255))] transition-opacity hover:opacity-95 md:text-[14px]"
					>
						{buttonText}
					</button>
				) : (
					<button
						type="submit"
						aria-label="Подписаться"
						class="flex size-10 shrink-0 items-center justify-center transition-opacity hover:opacity-80"
					>
						<NtIcon name="arrow-right" sizeClass="size-5" />
					</button>
				)
			}
		</form>
		{
			showAgreement && (
				<label class="flex w-full max-w-[460px] cursor-pointer items-start gap-2 font-roboto-flex text-[12px] font-light leading-snug text-[rgb(var(--color-muted,153_153_153))] md:text-[13px]">
					<input
						type="checkbox"
						required
						class="mt-0.5 size-4 shrink-0 accent-[rgb(var(--color-button-2-bg,0_0_0))]"
					/>
					<span>Согласен на обработку персональных данных</span>
				</label>
			)
		}
		<p
			data-newsletter-status
			role="status"
			class="hidden font-roboto-flex text-[12px] font-light text-[#4AD300] md:text-[14px]"
		></p>
	</div>
</section>

<script is:inline define:vars={{ shopId, apiUrl }}>
	// Реальная отправка подписки на gateway. Самодостаточно (не зависит от
	// скрипта футера): гард __merfyNewsletterWired исключает двойную привязку,
	// если на странице есть и футер, и эта секция. store_id — из пропатченного
	// shopId (деплой) либо window.__MERFY_SITE_ID__ (превью конструктора).
	(function () {
		window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
			shopId: shopId || "",
			apiUrl: apiUrl || "https://gateway.merfy.ru/api",
		};
		var cfg = window.__MERFY_CONFIG__;
		var base = String(cfg.apiUrl || "https://gateway.merfy.ru/api").replace(/\/+$/, "");
		var storeId = cfg.shopId || window.__MERFY_SITE_ID__ || "";

		function wire(form) {
			if (!form || form.__merfyNewsletterWired) return;
			form.__merfyNewsletterWired = true;
			var section = form.closest("section") || document;
			var status = section.querySelector("[data-newsletter-status]");
			var btn = form.querySelector('button[type="submit"]');

			function show(msg, isError) {
				if (!status) return;
				status.textContent = msg;
				status.style.color = isError ? "#E11D48" : "";
				status.classList.remove("hidden");
			}

			form.addEventListener("submit", function (event) {
				event.preventDefault();
				var input = form.querySelector('input[type="email"]');
				var email = input ? String(input.value || "").trim() : "";
				if (!email) return;
				if (btn) btn.disabled = true;
				show("Отправляем…", false);

				fetch(base + "/storefront/newsletter/subscribe", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ store_id: storeId, email: email }),
				})
					.then(function (res) {
						return res
							.json()
							.catch(function () { return {}; })
							.then(function (data) { return { ok: res.ok, code: res.status, data: data }; });
					})
					.then(function (r) {
						if (r.ok) {
							show(
								r.data && r.data.alreadySubscribed
									? "Вы уже подписаны на рассылку."
									: "Спасибо! Мы отправим вам приветственное письмо.",
								false,
							);
							form.reset();
						} else if (r.code === 429) {
							show("Слишком много попыток. Попробуйте позже.", true);
						} else {
							show("Не удалось подписаться. Попробуйте позже.", true);
						}
					})
					.catch(function () {
						show("Не удалось подписаться. Проверьте соединение.", true);
					})
					.finally(function () {
						if (btn) btn.disabled = false;
					});
			});
		}

		function init() {
			var forms = document.querySelectorAll("[data-newsletter-form]");
			for (var i = 0; i < forms.length; i++) wire(forms[i]);
		}
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", init);
		} else {
			init();
		}
	})();
</script>
