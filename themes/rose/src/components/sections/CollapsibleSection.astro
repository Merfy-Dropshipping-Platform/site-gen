---
// Фаза 3 (T16): новая канон-секция CollapsibleSection в манере rose (см.
// themes/rose/MANNER.md). Схема = packages/theme-base/blocks/CollapsibleSection/
// CollapsibleSection.puckConfig.ts. Секции нет у верстальщика — нативный
// <details>/<summary> (Container-safe, без JS); вопрос = .rose-title-роль меньшего
// размера, разделители #E5E5E5 §7, ответ = body-манера; chevron — svg c
// group-open-поворотом (tailwind, без <style>).
//
// Figma 1:19335 — ПУСТОЕ состояние: дословный плейсхолдер (заголовок
// «Сворачиваемый раздел» + ряд «Раздел» с хелпером «Ответь на самые популярные
// вопросы клиентов»), а НЕ мок-вопросы верстальщика. Когда мерчант задал
// sections/items — рендерим их (интерактивный <details>). Принцип паритета с
// Collections/MultiRows: пусто = surface-карточки + лейбл/хелпер, без контента.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading: string | { text, alignment, size }. Figma 1:19335 — ПУСТОЕ
// состояние секции «Сворачиваемый раздел»: дословный заголовок-плейсхолдер
// «Сворачиваемый раздел» (а НЕ дефолт-копирайт верстальщика «Часто задаваемые
// вопросы»). Мерчант задал свой heading → его и рендерим.
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Сворачиваемый раздел");
// heading.size (куда пишет hardcoded-панель конструктора) ПРИОРИТЕТНЕЕ top-level
// headingSize (у которого дефолт 'medium' — он перебивал правку размера в превью).
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? " [--size-section-heading:17px] [--size-section-heading-m:12px]"
		: headingSize === "large"
			? " [--size-section-heading:24px] [--size-section-heading-m:17px]"
			: "";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " !text-center"
		: headingAlignment === "right"
			? " !text-right"
			: "";
const headingCls = `rose-title${headingSizeCls}${headingAlignCls}`;

// Канон sections[] 1-10 {heading, content} (+ pupa items[] {title, content}).
// Когда мерчант ЗАДАЛ пункты — рендерим ИХ (content = set:html). Когда пусто —
// Figma 1:19335 ПУСТОЕ состояние: дословный плейсхолдер-ряд «Раздел» +
// хелпер-текст «Ответь на самые популярные вопросы клиентов» (а НЕ мок-вопросы
// верстальщика «Первый/Второй вопрос» с готовыми ответами). Паттерн пустого
// состояния как Collections/MultiRows: DEMO-массив + лейбл/хелпер, без контента.
const PLACEHOLDER_SECTIONS = [
	{ heading: "Раздел", content: "Ответь на самые популярные вопросы клиентов" },
];
const merchantSections = Array.isArray(p.sections) && p.sections.length
	? p.sections
	: Array.isArray(p.items) && p.items.length
		? p.items
		: null;
const isPlaceholder = !merchantSections;
const rawSections = merchantSections ?? PLACEHOLDER_SECTIONS;
const sections = rawSections.slice(0, 10).map((s: any) => ({
	heading:
		(typeof s.heading === "string" && s.heading) || (typeof s.title === "string" && s.title) || "",
	content: typeof s.content === "string" ? s.content : "",
}));

// Канон containerEnabled (toggle; legacy container.enabled) — обёртка-поверхность
// манеры (#F5F5F5, радиус карточки) вокруг списка. Canon-default отсутствует →
// без контейнера (голый список в манере «голых карточек» §4).
const containerEnabled = String(p.containerEnabled ?? p.container?.enabled ?? "false") === "true";
// Канон containerColorScheme (hidden) — класс схемы на контейнере.
const containerSchemeCls =
	typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";
const listWrapCls = containerEnabled
	? `rounded-[var(--radius-card,8px)] bg-[rgb(var(--color-surface,245_245_245))] p-6 md:p-10${containerSchemeCls}`
	: containerSchemeCls.trim();

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-14 pt-14 sm:px-5 sm:pb-16 sm:pt-16 md:px-10 md:pb-[100px] md:pt-[100px] lg:px-16 lg:pb-[120px] lg:pt-[120px] xl:px-20 xl:pb-[140px] xl:pt-[140px] 2xl:px-[280px]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[780px] flex-col gap-8 md:gap-10">
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-animate
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
					set:html={heading}
				/>
			)
		}
		<div class={listWrapCls} data-animate>
			<ul class="flex w-full flex-col" role="list">
				{
					sections.map((s, i) => (
						<li
							class="border-b border-solid border-[rgb(var(--color-border,229_229_229))] first:border-t"
							data-puck-subsection-parent={id}
							data-puck-subsection-index={i}
							data-puck-subsection-field="sections"
						>
							{isPlaceholder ? (
								/* Figma 1:19335 ПУСТОЕ состояние: дословный ряд-плейсхолдер —
								   лейбл «Раздел» (роль вопроса) + хелпер-текст «Ответь на самые
								   популярные вопросы клиентов». Без интерактивного <details>:
								   реального ответа нет, помощь видна сразу (паттерн пустого
								   состояния Collections/MultiRows). Шеврон сохранён для вида. */
								<div class="flex w-full flex-col gap-2 py-5">
									<div class="flex w-full items-center justify-between gap-4 font-comfortaa text-[14px] font-normal uppercase leading-snug text-[rgb(var(--color-heading,0_0_0))] sm:text-[16px]">
										<span class="min-w-0 flex-1 break-words">{s.heading}</span>
										<svg
											class="size-4 shrink-0 rotate-180"
											viewBox="0 0 16 16"
											fill="currentColor"
											aria-hidden="true"
										>
											<path d="M11.7899 10.3255C11.9111 10.1838 11.9118 9.9751 11.7916 9.83248L8.31861 5.71147C8.15213 5.51393 7.84787 5.51393 7.68139 5.71147L4.20838 9.83248C4.08819 9.9751 4.08892 10.1838 4.21011 10.3255C4.36289 10.5043 4.63951 10.5033 4.79103 10.3235L7.68139 6.89386C7.84787 6.69632 8.15213 6.69632 8.31861 6.89386L11.209 10.3235C11.3605 10.5033 11.6371 10.5043 11.7899 10.3255Z" />
										</svg>
									</div>
									<p class="font-manrope text-[16px] font-normal leading-[1.6] text-[rgb(var(--color-text,0_0_0))]">{s.content}</p>
								</div>
							) : (
								<details class="group">
									<summary class="cursor-pointer list-none py-5 [&::-webkit-details-marker]:hidden">
										<div class="flex w-full items-center justify-between gap-4 font-comfortaa text-[14px] font-normal uppercase leading-snug text-[rgb(var(--color-heading,0_0_0))] transition-opacity hover:opacity-70 sm:text-[16px]">
											<span class="min-w-0 flex-1 break-words" set:html={s.heading} />
											<svg
												class="size-4 shrink-0 rotate-180 transition-transform duration-200 group-open:rotate-0"
												viewBox="0 0 16 16"
												fill="currentColor"
												aria-hidden="true"
											>
												<path d="M11.7899 10.3255C11.9111 10.1838 11.9118 9.9751 11.7916 9.83248L8.31861 5.71147C8.15213 5.51393 7.84787 5.51393 7.68139 5.71147L4.20838 9.83248C4.08819 9.9751 4.08892 10.1838 4.21011 10.3255C4.36289 10.5043 4.63951 10.5033 4.79103 10.3235L7.68139 6.89386C7.84787 6.69632 8.15213 6.69632 8.31861 6.89386L11.209 10.3235C11.3605 10.5033 11.6371 10.5043 11.7899 10.3255Z" />
											</svg>
										</div>
									</summary>
									<div
										class="pb-5 font-manrope text-[16px] font-normal leading-[1.6] text-[rgb(var(--color-text,0_0_0))]"
										set:html={s.content}
									/>
								</details>
							)}
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
