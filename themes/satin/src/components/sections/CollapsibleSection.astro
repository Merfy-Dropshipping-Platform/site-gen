---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";

// Фаза B (satin, группа misc): канон-секция CollapsibleSection — адаптация
// src/components/sections/Faq.astro (тело КОПИЕЙ; оригинал не тронут —
// index.astro:33 и about.astro:61 продолжают его использовать). Схема полей =
// packages/theme-base/blocks/CollapsibleSection/CollapsibleSection.puckConfig.ts;
// манера — themes/satin/MANNER.md (эталон процесса — bloom CollapsibleSection).
// КРИТИЧНО: маркеры data-faq-item / data-faq-answer сохранены — их ищет GSAP
// initFaq (scripts/gsap/faq.ts: перехват клика, tween высоты/прозрачности
// 0.3/0.35s); без скрипта работает нативный <details>.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading: string | { text, alignment, size }. Figma 1:19335 — ПУСТОЕ
// состояние секции «Сворачиваемый раздел»: дословный заголовок-плейсхолдер
// «Сворачиваемый раздел» (а НЕ дефолт-копирайт коэрсера/верстальщика «Часто
// задаваемые вопросы»). Роль = заголовок секции §1 (font-logo 20 uppercase
// leading-[1.15], TextBlock.astro:15), токен heading с фоллбеком 0_0_0. Мерчант
// задал свой heading → его и рендерим (?? срабатывает только при пустых данных).
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Сворачиваемый раздел");
// Лестница §9 «Заголовок секции» (база-литерал 20 = canon-default medium): small 17, large 24.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small" ? "text-[17px]" : headingSize === "large" ? "text-[24px]" : "text-[20px]";
const headingAlignment =
	p.headingAlignment ?? (typeof p.heading === "object" ? p.heading?.alignment : undefined);
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-logo ${headingSizeCls} font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]${headingAlignCls}`;

// Лестница §9 «Заголовок-аккордеон» (база-литерал 18/md:20 = medium, Faq.astro:35):
// small 15/17, large 22/24. Управляется тем же headingSize.
const summarySizeCls =
	headingSize === "small"
		? "text-[15px] md:text-[17px]"
		: headingSize === "large"
			? "text-[22px] md:text-[24px]"
			: "text-[18px] md:text-[20px]";

// Канон sections[] 1-10 {heading, content} (+ pupa items[] {title, content}).
// Curated-модель (как theme-base PopularProducts/Collections, эталон процесса —
// bloom CollapsibleSection): секция показывает реальные пункты ТОЛЬКО когда
// мерчант их добавил. Гейт = наличие sections/items в пропах. Пусто → Figma
// 1:19335 ПУСТОЕ состояние: дословный ряд-плейсхолдер «Раздел» + хелпер-текст
// «Ответь на самые популярные вопросы клиентов» (а НЕ мок-демо верстальщика — 3
// FAQ из Faq.astro). Один DEMO-ряд (паритет bloom), без интерактивного
// <details> — реального ответа нет, помощь видна сразу. content — set:html.
const PLACEHOLDER_SECTIONS = [
	{ heading: "Раздел", content: "Ответь на самые популярные вопросы клиентов" },
];
const realSections =
	Array.isArray(p.sections) && p.sections.length
		? p.sections
		: Array.isArray(p.items) && p.items.length
			? p.items
			: null;
const hasRealSections = realSections !== null;
const isPlaceholder = !hasRealSections;
const rawSections = hasRealSections ? realSections : PLACEHOLDER_SECTIONS;
const sections = rawSections.slice(0, 10).map((s: any) => ({
	heading:
		(typeof s.heading === "string" && s.heading) || (typeof s.title === "string" && s.title) || "",
	content: typeof s.content === "string" ? s.content : "",
}));

// Канон containerEnabled (toggle; legacy container.enabled) — surface-подложка
// манеры §4 (245_245_245, p-6, БЕЗ радиуса — «подложечные» карточки satin только
// на сером) вокруг списка. Canon-default отсутствует → false = голый divide-y
// список (литерал Faq).
const containerEnabled = String(p.containerEnabled ?? p.container?.enabled ?? "false") === "true";
// Канон containerColorScheme (hidden) — класс схемы на контейнере.
const containerSchemeCls =
	typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";
const listWrapCls = containerEnabled
	? `bg-[rgb(var(--color-surface,245_245_245))] p-6${containerSchemeCls}`
	: containerSchemeCls.trim();

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

{/* Секция: вертикаль-стандарт §2 (py-10 md:py-14 — литерал Faq.astro:31), поля .satin-pad. */}
<section
	class="satin-pad w-full bg-[rgb(var(--color-bg,255_255_255))] py-10 md:py-14"
	aria-labelledby={titleId}
	aria-label={heading ? undefined : "Частые вопросы"}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="satin-container flex flex-col gap-8">
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
					set:html={heading}
				/>
			)
		}
		<div class={listWrapCls}>
			{/* Волосок #DDDDDD → канон-приём прозрачности от токена текста (≈ #DDD на белом). */}
			<div class="flex flex-col divide-y divide-[rgb(var(--color-text,0_0_0)/13%)]">
				{
					sections.map((s, i) =>
						isPlaceholder ? (
							/* Figma 1:19335 ПУСТОЕ состояние: дословный ряд-плейсхолдер —
							   лейбл «Раздел» (роль заголовка-аккордеона) + хелпер-текст
							   «Ответь на самые популярные вопросы клиентов». Без
							   интерактивного <details> / data-faq-item: реального ответа
							   нет, помощь видна сразу (паритет bloom CollapsibleSection,
							   паттерн пустого состояния Collections/MultiRows). Иконка plus
							   сохранена для вида. */
							<div class="flex w-full flex-col gap-3 py-5">
								<div
									class={`flex w-full items-center justify-between gap-4 font-logo ${summarySizeCls} font-normal uppercase leading-[1.2] text-[rgb(var(--color-heading,0_0_0))]`}
								>
									<span class="min-w-0 flex-1 break-words">{s.heading}</span>
									<NtIcon name="plus" sizeClass="size-8" class="shrink-0" />
								</div>
								<div class="satin-copy max-w-[1100px]">{s.content}</div>
							</div>
						) : (
							<details
								class="group py-5"
								open={i === 0}
								data-faq-item
								data-puck-subsection-parent={id}
								data-puck-subsection-index={i}
								data-puck-subsection-field="sections"
							>
								<summary class="cursor-pointer list-none [&::-webkit-details-marker]:hidden">
									<div
										class={`flex w-full items-center justify-between gap-4 font-logo ${summarySizeCls} font-normal uppercase leading-[1.2] text-[rgb(var(--color-heading,0_0_0))]`}
									>
										<span class="min-w-0 flex-1 break-words" set:html={s.heading} />
										<NtIcon name="plus" sizeClass="size-8" class="shrink-0 group-open:hidden" />
										<NtIcon name="minus" sizeClass="size-8" class="hidden shrink-0 group-open:block" />
									</div>
								</summary>
								<div class="overflow-hidden" data-faq-answer>
									<div class="satin-copy mt-3 max-w-[1100px]" set:html={s.content} />
								</div>
							</details>
						),
					)
				}
			</div>
		</div>
	</div>
</section>
