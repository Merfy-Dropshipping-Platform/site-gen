---
// Секция CollapsibleSection («Сворачиваемый раздел» / аккордеон-FAQ) в манере
// flux. Донора у верстальщика flux НЕТ (секций всего 4, MANNER §10) — потому
// дизайним в ЕДИНОМ flux-языке (эталон процесса — MainText.astro): ВСЯ секция
// font-roboto-flex (заголовок секции / вопрос / ответ); прежний дрейф на
// comfortaa/manrope (наследие разошедшегося rose-клона) УДАЛЁН. Шрифт-токен:
// .font-roboto-flex = var(--font-body, Roboto Flex), вес 300 (g:22-25). Заголовок
// секции — roboto-flex uppercase (как Popular/Collections/MainText), вопрос —
// roboto-flex 400 (роль заголовка пункта), ответ — roboto-flex 300 (font-light,
// body). Аккордеон — нативный <details>/<summary> (Container-safe, без JS):
// раскрытие работает CSS-механикой. Шеврон — currentColor токен с акцентом
// #FA5109 на раскрытом пункте (акцент flux: nav-active/Popular-badge, MANNER §1).
// Скролл-анимаций НЕТ — манера flux статична (MANNER §6), только hover-opacity.
//
// НАСТРОЙКИ = паритет rose CollapsibleSection (themes/rose/.../CollapsibleSection.astro):
// читаем те же поля heading/headingSize/headingAlignment/sections(items)/
// container(+Enabled/ColorScheme)/padding/colorScheme — идентичная логика,
// разнятся только flux-классы. colorScheme навешивается обёрткой composeV2Page;
// фон секции = bg-токен с белым фоллбеком (§7).
//
// Figma 1:19335 — ПУСТОЕ состояние: дословный плейсхолдер (заголовок
// «Сворачиваемый раздел» + ряд «Раздел» с хелпером «Ответь на самые популярные
// вопросы клиентов»), а НЕ мок-вопросы верстальщика про доставку/возврат. Когда
// мерчант задал sections/items — рендерим их (интерактивный <details>). Принцип
// паритета с Collections/MultiRows: пусто = лейбл/хелпер, без контента (эталон —
// rose CollapsibleSection).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading: string | { text, alignment, size }. Figma 1:19335 — ПУСТОЕ
// состояние секции «Сворачиваемый раздел»: дословный заголовок-плейсхолдер
// «Сворачиваемый раздел» (а НЕ дефолт-копирайт «Часто задаваемые вопросы»).
// Мерчант задал свой heading → его и рендерим.
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Сворачиваемый раздел");
// Канон headingSize (top-level hidden приоритетнее heading.size сабпанели — у
// него canon-default 'medium', он перебивал бы правку размера в превью). База
// flux = 19/md:23 (эталон MainText/Popular). 'medium' (canon-default) и
// отсутствие = база; small ступень ниже, large выше. Заголовок — roboto-flex
// uppercase, цвет = heading-токен с чёрным фоллбеком (§7) → colorScheme красит.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[16px] md:text-[19px]"
		: headingSize === "large"
			? "text-[23px] md:text-[29px]"
			: "text-[19px] md:text-[23px]"; // medium (canon-default) + absent
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-roboto-flex font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))] ${headingSizeCls}${headingAlignCls}`;

// Канон sections[] 1-10 {heading, content} (+ pupa items[] {title, content}).
// Когда мерчант ЗАДАЛ пункты — рендерим ИХ (интерактивный <details>, content =
// set:html). Когда пусто — Figma 1:19335 ПУСТОЕ состояние: дословный
// плейсхолдер-ряд «Раздел» + хелпер «Ответь на самые популярные вопросы
// клиентов» (а НЕ мок-вопросы верстальщика). Паттерн пустого состояния как
// Collections/MultiRows: DEMO-массив + лейбл/хелпер, без контента.
const PLACEHOLDER_SECTIONS = [
	{ heading: "Раздел", content: "Ответь на самые популярные вопросы клиентов" },
];
const merchantSections =
	Array.isArray(p.sections) && p.sections.length
		? p.sections
		: Array.isArray(p.items) && p.items.length
			? p.items
			: null;
const isPlaceholder = !merchantSections;
const rawSections = merchantSections ?? PLACEHOLDER_SECTIONS;
const sections = rawSections.slice(0, 10).map((s: any) => ({
	heading:
		(typeof s.heading === "string" && s.heading) || (typeof s.title === "string" && s.title) || "",
	content: typeof s.content === "string" ? s.content : "",
}));

// Канон containerEnabled (toggle; legacy container.enabled) — per-element:
// surface-бокс (color-surface, радиус карточки) на КАЖДЫЙ вопрос, НЕ один общий
// бокс вокруг списка. Canon-default отсутствует → false = голые разделители.
const containerEnabled = String(p.containerEnabled ?? p.container?.enabled ?? "false") === "true";
// Канон Nikita: класс схемы контейнера вешаем ТОЛЬКО при включённом контейнере.
// При ВЫКЛ контейнеров нет → работает основная (секционная) цв. схема.
const containerSchemeCls =
	containerEnabled && typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";
// Класс схемы — на обёртке списка <ul> (красит боксы вопросов), БЕЗ бокса/паддинга.
const listWrapCls = containerSchemeCls.trim();
// При ВКЛ контейнере боксы вопросов отделяются зазором; при ВЫКЛ — сплошной
// список с тонкими разделителями surface.
const listGapCls = containerEnabled ? "gap-3 md:gap-4" : "";
// Бокс вопроса (per-element): ВКЛ → surface-карточка манеры (radius-card 12px /
// color-surface / px; верт. отступ из py-5 контента); ВЫКЛ → тонкий разделитель
// surface (border-b first:border-t).
const itemBoxCls = containerEnabled
	? "rounded-[var(--radius-card,12px)] bg-[rgb(var(--color-surface,245_245_245))] px-6 md:px-8"
	: "border-b border-solid border-[rgb(var(--color-surface,245_245_245))] first:border-t";

// Канон padding {top,bottom} — inline-override вертикали ТОЛЬКО при заданном
// пропе (паттерн MainText): тогда py-классы контейнера снимаются, чтобы не было
// двойного отступа. Иначе эталонная вертикаль py-10 md:py-16.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

// Контейнер = flux-container эталона (носитель темы как Header/Footer/MainText:
// mx-auto max-w-[1920px] px-4 md:px-20 2xl:px-80). Вертикаль py-10 md:py-16
// (канон); при заданном padding (настройка) py-классы убираются — inline-стиль
// ставит padding-top/bottom.
const containerCls = paddingStyle
	? "mx-auto w-full max-w-[1920px] px-4 md:px-20 2xl:px-80"
	: "mx-auto w-full max-w-[1920px] px-4 py-10 md:px-20 md:py-16 2xl:px-80";

const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
>
	<div class={containerCls} style={paddingStyle}>
		{/* Колонка читаемой ширины max-w-[780px], центрирована (mx-auto) — список
		    вопросов под комфортную длину строки (паттерн MainText). Заголовок секции
		    + список; выравнивание заголовка — headingAlignCls (по умолчанию слева). */}
		<div class="mx-auto flex w-full max-w-[780px] flex-col gap-8 md:gap-10">
			{
				heading && (
					<h2
						id={titleId}
						class={headingCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="100"
						data-puck-subsection-field="heading"
						set:html={heading}
					/>
				)
			}
			<ul class={["flex w-full flex-col", listGapCls, listWrapCls].filter(Boolean).join(" ")} role="list">
				{
					sections.map((s, i) => (
						<li
							class={itemBoxCls}
							data-puck-subsection-parent={id}
							data-puck-subsection-index={i}
							data-puck-subsection-field="sections"
						>
							{isPlaceholder ? (
								/* Figma 1:19335 ПУСТОЕ состояние: дословный ряд-плейсхолдер —
								   лейбл «Раздел» (роль вопроса) + хелпер-текст «Ответь на самые
								   популярные вопросы клиентов». Без интерактивного <details>:
								   реального ответа нет, помощь видна сразу (паттерн пустого
								   состояния Collections/MultiRows). Шеврон сохранён для вида. */
								<div class="flex w-full flex-col gap-2 py-5">
									<div class="flex w-full items-center justify-between gap-4 font-roboto-flex text-[16px] font-normal leading-snug text-[rgb(var(--color-heading,0_0_0))] md:text-[19px]">
										<span class="min-w-0 flex-1 break-words">{s.heading}</span>
										<svg
											class="size-5 shrink-0 rotate-180 text-[rgb(var(--color-heading,0_0_0))]"
											viewBox="0 0 16 16"
											fill="currentColor"
											aria-hidden="true"
										>
											<path d="M11.7899 10.3255C11.9111 10.1838 11.9118 9.9751 11.7916 9.83248L8.31861 5.71147C8.15213 5.51393 7.84787 5.51393 7.68139 5.71147L4.20838 9.83248C4.08819 9.9751 4.08892 10.1838 4.21011 10.3255C4.36289 10.5043 4.63951 10.5033 4.79103 10.3235L7.68139 6.89386C7.84787 6.69632 8.15213 6.69632 8.31861 6.89386L11.209 10.3235C11.3605 10.5033 11.6371 10.5043 11.7899 10.3255Z" />
										</svg>
									</div>
									<p class="font-roboto-flex text-[16px] font-light leading-[1.6] text-[rgb(var(--color-text,0_0_0))]">
										{s.content}
									</p>
								</div>
							) : (
								<details class="group">
									<summary class="cursor-pointer list-none py-5 [&::-webkit-details-marker]:hidden">
										<div class="flex w-full items-center justify-between gap-4 font-roboto-flex text-[16px] font-normal leading-snug text-[rgb(var(--color-heading,0_0_0))] transition-opacity hover:opacity-70 md:text-[19px]">
											<span class="min-w-0 flex-1 break-words" set:html={s.heading} />
											<svg
												class="size-5 shrink-0 rotate-180 text-[rgb(var(--color-heading,0_0_0))] transition-[transform,color] duration-300 group-open:rotate-0 group-open:text-[#FA5109]"
												viewBox="0 0 16 16"
												fill="currentColor"
												aria-hidden="true"
											>
												<path d="M11.7899 10.3255C11.9111 10.1838 11.9118 9.9751 11.7916 9.83248L8.31861 5.71147C8.15213 5.51393 7.84787 5.51393 7.68139 5.71147L4.20838 9.83248C4.08819 9.9751 4.08892 10.1838 4.21011 10.3255C4.36289 10.5043 4.63951 10.5033 4.79103 10.3235L7.68139 6.89386C7.84787 6.69632 8.15213 6.69632 8.31861 6.89386L11.209 10.3235C11.3605 10.5033 11.6371 10.5043 11.7899 10.3255Z" />
											</svg>
										</div>
									</summary>
									<div
										class="pb-5 font-roboto-flex text-[16px] font-light leading-[1.6] text-[rgb(var(--color-text,0_0_0))]"
										set:html={s.content}
									/>
								</details>
							)}
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
