---
// Pixel-perfect port of legacy rose.merfy.ru Header markup as an additive
// variant of the base Header block. Selected by `theme-base/Header.astro`
// when `variant === 'rose-classic'`.
//
// Differs from base `standard` variant:
//   • Wider 1920px max-width container with 2xl:px-[280px]
//   • Large nav gaps (2xl:gap-[80px]), actions gap-[25px]
//   • Comfortaa logo style (text-[20px] uppercase color-primary)
//   • Tighter logoImg responsive heights (h-5/h-6/h-[26px])
//   • Heavier shadow wrapper, rose-specific inline SVG cart/profile/search/hamburger
//
// User explicit (2026-06-03): inline SVG paths остаются 1:1 — нет
// token-driven mask-image, "лого в конструкторе грузится через интерфейс".
//
// Все классы — через `C.variant['rose-classic'].*`, single source в
// `theme-base/blocks/Header/Header.classes.ts`. Hex/rgb/hsl literals
// запрещены (theme-base CLAUDE.md) — color через `rgb(var(--color-*))`.
//
// NO `<style>` блока — Astro bake виртуальный `?astro&type=style` import
// в .mjs → ENOENT в Docker preview iframe.
//
// `<script is:inline>` — vanilla JS only (без TS-аннотаций), иначе те же
// virtual-imports в скомпилированном .mjs.
import type { HeaderProps } from '../Header.puckConfig';
import { HeaderClasses as Base } from '../Header.classes';

interface Props extends HeaderProps {
  id?: string;
}

const C = Base.variant['rose-classic'];

const {
  id,
  siteTitle = 'Store',
  logo = '/logo.svg',
  logoPosition = 'top-left',
  stickiness = 'scroll-up',
  colorScheme,
  padding,
  navigationLinks = [
    { label: 'Главная', href: '/' },
    { label: 'Каталог', href: '/catalog' },
    { label: 'О нас', href: '/about' },
    { label: 'Контакты', href: '/contacts' },
  ],
  menuColorScheme,
  actionButtons = { showSearch: true, showCart: true, showProfile: true },
} = Astro.props as Props;

// HeaderProps.actionButtons — boolean. У legacy props были строки 'true'.
// Используем boolean напрямую с safe fallback на true (showcase default).
const showSearch = actionButtons?.showSearch ?? true;
const showCart = actionButtons?.showCart ?? true;
const showProfile = actionButtons?.showProfile ?? true;

// Padding из HeaderProps (constructor → seed default). Legacy fallback = 0.
const paddingTop = padding?.top ?? 0;
const paddingBottom = padding?.bottom ?? 0;
const useCustomPadding = paddingTop > 0 || paddingBottom > 0;
const paddingStyle = useCustomPadding
  ? `padding-top:${paddingTop}px; padding-bottom:${paddingBottom}px;`
  : '';

// Color scheme как CSS class (token cascade зайдёт через `color-scheme-N`).
const schemeClass = colorScheme
  ? `color-scheme-${String(colorScheme).replace('scheme-', '')}`
  : '';
// Меню может иметь свою схему. Если совпадает с основной — не добавляем
// дополнительный wrapper class (наследование от outer schemeClass).
const menuSchemeClass =
  menuColorScheme && menuColorScheme !== colorScheme
    ? `color-scheme-${String(menuColorScheme).replace('scheme-', '')}`
    : '';

const isCenterLeft = logoPosition === 'center-left';

// Treat seed default `/logo.svg` как «нет custom logo» — `<img>` грузит SVG
// в isolated context, который не наследует `currentColor`, и mark рендерится
// чёрным на dark scheme. Текстовый logo через `<span>` подхватывает
// --color-primary через C.logoText (CSS-var cascade).
const hasCustomLogo =
  typeof logo === 'string' && logo.length > 0 && logo !== '/logo.svg';
---

<div
  class:list={[C.wrapper, C.sticky[stickiness], schemeClass]}
  data-header-wrapper
  data-header-variant="rose-classic"
  data-puck-component-id={id}
>
  <header
    class:list={[C.header, !useCustomPadding && !isCenterLeft && 'min-h-[64px]']}
    style={paddingStyle}
  >
    <nav class:list={[C.nav, !isCenterLeft && C.navJustified]} aria-label="Primary navigation">

      {/* ============ LAYOUT: top-left (default) ============ */}
      {logoPosition === 'top-left' && (
        <>
          {/* Mobile hamburger */}
          <button id="mobile-menu-button" aria-label="Меню" aria-expanded="false" class={C.hamburger}>
            <svg id="menu-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M11 17H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M11 23H29" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {/* Logo */}
          <div class={C.logoWrap['top-left']}>
            <a href="/" class={C.logoLink}>
              {hasCustomLogo ? (
                <img src={logo} alt={siteTitle} class={C.logoImg} />
              ) : (
                <span class={C.logoText}>{siteTitle}</span>
              )}
            </a>
          </div>

          {/* Desktop nav */}
          <div class:list={[C.navMenu, menuSchemeClass]}>
            {navigationLinks?.map((link) => (
              <a href={link.href} class={C.navLink}>{link.label}</a>
            ))}
          </div>

          {/* Actions */}
          <div class={C.actions}>
            {showSearch && (
              <button type="button" aria-label="Поиск" class={C.actionSearch} data-action="search">
                <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </button>
            )}
            {showCart && (
              <a href="/cart" id="header-cart-link" class={C.actionCart} aria-label="Корзина" data-action="cart">
                <svg class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 lg:w-10 lg:h-10" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M18.0295 11.6923C16.8004 11.6923 15.6678 12.3587 15.0708 13.4332C13.8175 15.6892 15.4488 18.4615 18.0295 18.4615H21.9704C24.5511 18.4615 26.1824 15.6892 24.9291 13.4332C24.3321 12.3587 23.1996 11.6923 21.9704 11.6923H18.0295ZM16.6847 14.3298C16.956 13.8414 17.4708 13.5385 18.0295 13.5385H21.9704C22.5291 13.5385 23.0439 13.8414 23.3152 14.3298C23.8849 15.3552 23.1434 16.6154 21.9704 16.6154H18.0295C16.8565 16.6154 16.115 15.3552 16.6847 14.3298Z" fill="currentColor"/>
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M17.2489 8C15.1954 8 13.2924 9.07744 12.2359 10.8383L8.83312 16.5096C8.28797 17.4182 8 18.4579 8 19.5175V26.1538C8 29.3826 10.6174 32 13.8462 32H26.1538C29.3826 32 32 29.3826 32 26.1538V19.5175C32 18.4579 31.712 17.4182 31.1669 16.5096L27.7641 10.8383C26.7076 9.07744 24.8046 8 22.7511 8H17.2489ZM13.819 11.7882C14.5419 10.5833 15.8439 9.84615 17.2489 9.84615H22.7511C24.1561 9.84615 25.4581 10.5833 26.181 11.7882L29.5838 17.4595C29.9568 18.0811 30.1538 18.7925 30.1538 19.5175V26.1538C30.1538 28.363 28.363 30.1538 26.1538 30.1538H13.8462C11.637 30.1538 9.84615 28.363 9.84615 26.1538V19.5175C9.84615 18.7925 10.0432 18.0811 10.4162 17.4595L13.819 11.7882Z" fill="currentColor"/>
                </svg>
                <span id="cart-badge" class={C.cartBadge}>0</span>
              </a>
            )}
            {showProfile && (
              <a href="/login" aria-label="Аккаунт" class={C.actionProfile} data-action="profile">
                <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
