---
import CollectionCardItem from './shared/CollectionCardItem.astro';

interface Props {
  title?: string;
  subtitle?: string;
  titleSize?: string;
  subtitleSize?: string;
  dataSource?: string;
  collections?: Array<{ name: string; image: string; slug?: string }>;
  columnsCount?: number;
  imageView?: string;
  colorScheme?: string;
  padding?: { top?: number; bottom?: number };
}

const {
  title = 'Снова в продаже',
  subtitle = 'Стиль для каждой ситуации - найдите свой в каталоге.',
  titleSize = 'small',
  subtitleSize = 'small',
  dataSource = 'auto',
  collections = [],
  columnsCount = 3,
  imageView = 'portrait',
  colorScheme,
  padding = { top: 80, bottom: 80 },
} = Astro.props;
const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';

const headingSizeMap: Record<string, string> = {
  small: 'text-lg sm:text-xl md:text-2xl lg:text-[24px]',
  medium: 'text-xl sm:text-2xl md:text-3xl lg:text-[32px]',
  large: 'text-2xl sm:text-3xl md:text-4xl lg:text-[40px]',
};
const textSizeMap: Record<string, string> = {
  small: 'text-xs sm:text-sm md:text-base lg:text-[16px]',
  medium: 'text-sm sm:text-base md:text-lg lg:text-xl xl:text-[24px]',
  large: 'text-base sm:text-lg md:text-xl lg:text-2xl xl:text-[28px]',
};

const aspectMap: Record<string, string> = {
  portrait: '430/500',
  square: '1/1',
  wide: '16/9',
};

let collectionsData = collections || [];

if (dataSource === 'auto' || collectionsData.length === 0) {
  try {
    const imported = await import('../data/collections.json');
    collectionsData = imported.default || [];
  } catch {
    collectionsData = [];
  }
}

const cols = columnsCount || 3;
const aspect = aspectMap[imageView] || aspectMap.portrait;
---

<section id="collections" class={`w-full scroll-mt-16 sm:scroll-mt-20 ${schemeClass}`} style={`background: rgb(var(--color-background)); color: rgb(var(--color-foreground)); padding: ${padding?.top || 80}px 0 ${padding?.bottom || 80}px;`}>
  <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 md:px-8 lg:px-10 xl:px-12">
    <div class="flex flex-col items-center gap-2 sm:gap-3 md:gap-4 lg:gap-[5px] mb-8 sm:mb-10 md:mb-12 lg:mb-16 xl:mb-20">
      <h2 class={`${headingSizeMap[titleSize] || headingSizeMap.small} font-normal uppercase leading-[1.115] text-center font-heading text-theme-accent`}>
        {title}
      </h2>
      {subtitle && (
        <p class={`${textSizeMap[subtitleSize] || textSizeMap.small} font-normal leading-[1.366] text-center px-2 sm:px-4 font-body text-theme-foreground`}>
          {subtitle}
        </p>
      )}
    </div>

    {collectionsData.length > 0 && (
    <div class="grid collections-grid" role="list">
      {collectionsData.map((collection, index) => (
        <CollectionCardItem
          name={collection.name}
          image={collection.image}
          slug={collection.slug}
          aspect={aspect}
          eager={index < 2}
        />
      ))}
    </div>
    )}
  </div>
</section>

<style define:vars={{ cols }}>
  .collections-grid {
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .collections-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }
  @media (min-width: 1024px) {
    .collections-grid {
      grid-template-columns: repeat(var(--cols), 1fr);
      gap: 2.5rem;
    }
  }
</style>
