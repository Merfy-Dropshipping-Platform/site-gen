---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { SITE_TITLE } from "../consts";
import { withBase } from "../lib/with-base";

const today = new Date();
const leftCol = [
	{ label: "Коллекции", href: "/catalog" },
	{ label: "История", href: "/about" },
	{ label: "Контакты", href: "/contacts" },
];
// Вторая колонка ассортимента — литерал дефолт-ветки БЕЗ канон-поля (F:12-17).
const midCol = [
	{ label: "Мужское", href: "/catalog?collection=Мужское" },
	{ label: "Женское", href: "/catalog?collection=Женское" },
	{ label: "Весна 25'", href: "/catalog" },
	{ label: "Лето 25'", href: "/catalog" },
];
const payments = [
	{ src: "/icons/MasterCard.svg", alt: "Mastercard" },
	{ src: "/icons/Visa.png", alt: "Visa" },
	{ src: "/icons/MIR.png", alt: "МИР" },
];

// ОЖИВЛЕНИЕ (Фаза B, объём rose/bloom Footer): канон-схема theme-base Footer.puckConfig —
// siteTitle, phone, email/socialColumn.email, newsletter.enabled, navigationColumn,
// informationColumn, socialColumn.socialLinks, copyright, bottomStrip, padding.
// Тело ниже — verbatim верстальщика; дефолтные ветки = прежним строкам байт-в-байт
// (цвета → токены с пиксель-фоллбеком MANNER.md §7); новые элементы (заголовки колонок)
// не рендерятся без пропсов. Подвал satin СЕРЫЙ — фон = surface-токен (литерал
// var(--satin-surface) #F5F5F5, F:44).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустая строка (canon default Puck / коэрсер) не должна ронять «Satin».
const siteTitle = typeof p.siteTitle === "string" && p.siteTitle.trim() ? p.siteTitle : SITE_TITLE;
const phone = typeof p.phone === "string" && p.phone.trim() ? p.phone.trim() : "";
const rawEmail = p.socialColumn?.email ?? p.email ?? "";
const email = typeof rawEmail === "string" ? rawEmail.trim() : "";
// Произвольные контакт-поля (адрес/часы/ИНН и т.п.) — всё КРОМЕ phone/email,
// build кладёт их в socialColumn.contactFields = [{label,value}].
const contactFields: Array<{ label: string; value: string }> = Array.isArray(p.socialColumn?.contactFields)
	? p.socialColumn.contactFields.filter((f: any) => f && typeof f.value === "string" && f.value.trim())
	: [];
// Платёжки (касса подключена) — НОВЫЙ проп.
const paymentEnabled = p.paymentEnabled === true || p.paymentEnabled === "true";
// Placeholder поля рассылки — не зависит от контактного email (НЕ ТРОГАТЬ).
const emailPlaceholder = "example@satin.merfy";

// Канон newsletter.enabled — скрыть блок подписки ТОЛЬКО при явном false/'false'
// (булево может прийти строкой). Отсутствие пропа → блок показан = пиксель.
const newsletterEnabled = !(
	p.newsletter &&
	(p.newsletter.enabled === false || p.newsletter.enabled === "false")
);

// Оживление полей панели «Заголовок»/«Текст» рассылки (Figma 314-34558, паритет
// rose): заголовок из пропа heading.text с fallback на литерал верстальщика
// (satin ALL-CAPS «Будьте в курсе наших новостей»). Подзаголовок text.content —
// НОВЫЙ элемент, рендерится ТОЛЬКО при непустом значении (в родной вёрстке satin
// подзаголовка нет → дефолт байт-в-байт). Раньше оба поля были мертвы.
const newsletterHeadingText =
	typeof p.heading?.text === "string" && p.heading.text.trim()
		? p.heading.text
		: "Будьте в курсе наших новостей";
const newsletterText =
	typeof p.text?.content === "string" && p.text.content.trim() ? p.text.content : "";

// Канон «Выравнивание» (contentAlign) left/center/right — паритет rose Footer:
// ОДНО значение выравнивает блок колонок И контент внутри на десктопе. Раньше было
// мёртвым (satin читал только heading.alignment). Классы ЛИТЕРАЛАМИ (Tailwind JIT).
// Дефолт left = родная вёрстка байт-в-байт (нав слева / контакты справа).
const _ca = ["left", "center", "right"].includes(p.contentAlign) ? p.contentAlign : "left";
// Верхний ряд (нав-блок ↔ рассылка+контакты): left = justify-between (текущее);
// center = группа по центру; right = к правому краю.
const topRowJustifyCls =
	_ca === "center" ? "md:justify-center md:gap-24" : _ca === "right" ? "md:justify-end" : "md:justify-between";
// Правая колонка (рассылка+контакты): left = прижата вправо (items-end, текущее);
// center = по центру; right = вправо.
const rightColAlignCls =
	_ca === "center" ? "items-center text-center" : _ca === "right" ? "items-end text-right" : "items-end";
// Нижний info-ряд (копирайт ↔ инфо-ссылки): left = space-between; center = центр;
// right = к правому краю.
const bottomRowJustifyCls =
	_ca === "center" ? "justify-center" : _ca === "right" ? "justify-end" : "justify-between";

// Канон colorScheme на <footer> (паритет rose): hot-render одиночного блока в
// превью (без scheme-обёртки композитора) берёт :root = тёмный BASE_DEFAULT → не
// тот фон. Свою схему кладём на <footer>; на live обёртка композитора даёт ту же
// (дубль безвреден). Пусто → :root (как раньше).
const footerSchemeClass =
	typeof p.colorScheme === "string" && p.colorScheme
		? `color-scheme-${String(p.colorScheme).replace("scheme-", "")}`
		: "";

// Канон-колонки {title, links:[{label,href}]}: ссылки из пропсов с fallback на
// литералы верстальщика (навигация = leftCol Коллекции/История/Контакты F:7-11;
// информация = правовые ссылки F:18-23); заголовок колонки — НОВЫЙ элемент,
// рендерится только при непустом title (в вёрстке верстальщика заголовков нет).
const coerceColumnLinks = (
	col: any,
	fallback: Array<{ label: string; href: string }>,
): Array<{ label: string; href: string }> =>
	Array.isArray(col?.links) && col.links.length > 0
		? col.links.map((l: any) => ({ label: String(l?.label ?? ""), href: String(l?.href ?? "/") }))
		: fallback;
const navLinks = coerceColumnLinks(p.navigationColumn, leftCol);
const infoLinks = coerceColumnLinks(p.informationColumn, []);
const columnTitle = (col: any): string | undefined =>
	typeof col?.title === "string" && col.title.trim() ? col.title : undefined;
const navColTitle = columnTitle(p.navigationColumn);
const infoColTitle = columnTitle(p.informationColumn);
// Роль заголовка над списком ссылок в манере satin — рубрика мега-меню (H:229):
// Arsenal 16 400 uppercase на токене текста.
const columnTitleCls =
	"font-manrope text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))]";

// Канон socialColumn.socialLinks (enum платформ) → имена NtIcon верстальщика;
// fallback = литеральный набор 5 соцсетей F:24-30 дословно (size-6 gap-3 desktop).
const SOCIAL_PLATFORMS: Record<string, { name: string; label: string }> = {
	telegram: { name: "social-telegram", label: "Telegram" },
	vk: { name: "social-vk", label: "VK" },
	tiktok: { name: "social-tiktok", label: "TikTok" },
	youtube: { name: "social-youtube", label: "YouTube" },
	dzen: { name: "social-yandex-dzen", label: "Дзен" },
};
const socials = Array.isArray(p.socialColumn?.socialLinks)
	? p.socialColumn.socialLinks
			.map((s: any) => {
				const meta = SOCIAL_PLATFORMS[String(s?.platform ?? "")];
				const href = String(s?.href ?? "").trim();
				return meta && href && href !== "#" ? { name: meta.name, label: meta.label, href } : null;
			})
			.filter((s: any) => s !== null)
	: [];

// Канон copyright {companyName, poweredBy, showYear} (+ legacy-строка целиком).
// Дефолтная сборка = литерал info-ряда верстальщика байт-в-байт:
// «© {год} {siteTitle} Theme Все права защищены.» — БЕЗ хвоста Powered by
// (он живёт в чёрной полосе bottomStrip). canon-default poweredBy 'Powered by Merfy'
// из puckConfig трактуется как «не задан» → литерал (правило canon-default → пиксель).
const copyrightProp = p.copyright;
const copyrightOverride =
	typeof copyrightProp === "string" && copyrightProp.trim() ? copyrightProp : undefined;
const copyrightObj = copyrightProp && typeof copyrightProp === "object" ? copyrightProp : {};
const showYear = !(copyrightObj.showYear === false || copyrightObj.showYear === "false");
const companyPart =
	typeof copyrightObj.companyName === "string" && copyrightObj.companyName.trim()
		? copyrightObj.companyName
		: `${siteTitle} Theme`;
const poweredByTail =
	typeof copyrightObj.poweredBy === "string" &&
	copyrightObj.poweredBy.trim() &&
	copyrightObj.poweredBy !== "Powered by Merfy"
		? copyrightObj.poweredBy
		: "";
const copyrightText =
	copyrightOverride ??
	`© ${showYear ? `${today.getFullYear()} ` : ""}${companyPart} Все права защищены.${poweredByTail ? ` ${poweredByTail}` : ""}`;

// Канон bottomStrip {enabled, text} — чёрная полоса верстальщика (F:180-182):
// bg 0_0_0 py-4, font-inter 12/md:16 light, «Powered by Merfy». enabled false/'false'
// → полоса скрыта; непустой text перебивает литеральную сборку.
const strip = p.bottomStrip && typeof p.bottomStrip === "object" ? p.bottomStrip : undefined;
const bottomStripVisible = !(strip && (strip.enabled === false || strip.enabled === "false"));
const stripText =
	typeof strip?.text === "string" && strip.text.trim()
		? strip.text
		: `© ${today.getFullYear()} ${siteTitle} Theme Все права защищены. Powered by Merfy`;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при пропе, на носителях отступов
// верстальщика (desktop pt-16 pb-10, mobile pt-8 pb-8). {80,80} = canon-default
// puckConfig (его впрыскивает коэрсер) → литерал (правило canon-default → пиксель).
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const isCanonPad = pad && Number(pad.top) === 80 && Number(pad.bottom) === 80;
const footerPadStyle =
	pad && !isCanonPad
		? `padding-top:${Number(pad.top) || 0}px;padding-bottom:${Number(pad.bottom) || 0}px;`
		: undefined;
const desktopWrapCls = footerPadStyle
	? "satin-pad mx-auto w-full max-w-[1920px]"
	: "satin-pad mx-auto w-full max-w-[1920px] pb-10 pt-16";
const mobileWrapCls = footerPadStyle ? "px-4 md:hidden" : "px-4 pb-8 pt-8 md:hidden";

const linkClass =
	"font-manrope text-[14px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] transition-opacity hover:opacity-70";
const linkClassSm =
	"font-manrope text-[12px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] transition-opacity hover:opacity-70";
---

<footer class:list={["w-full bg-[rgb(var(--color-surface,245_245_245))]", footerSchemeClass]} data-puck-component-id={id}>
	<!-- Desktop (≥ md) — Figma 905-16327 -->
	<div class="hidden w-full md:block">
		<div class={desktopWrapCls} style={footerPadStyle}>
			<div class="satin-container flex flex-col gap-10">
				<!-- Top: two columns (logo+menu | newsletter+contacts) -->
				<div class={`flex items-start gap-10 ${topRowJustifyCls}`}>
					<!-- Left: logo + navigation (40px gap between logo and menu) -->
					<div class="flex flex-col gap-10">
						<a href="/" class="font-logo text-xl font-normal uppercase leading-none text-[rgb(var(--color-heading,0_0_0))] transition-opacity hover:opacity-80">{siteTitle}</a>
						<div class="flex gap-16">
							<ul
								class="flex flex-col gap-2.5"
								role="list"
								data-puck-subsection-parent={id}
								data-puck-subsection-index="996"
								data-puck-subsection-field="navigationColumn"
							>
								{navColTitle && (
									<li><span class={columnTitleCls}>{navColTitle}</span></li>
								)}
								{navLinks.map((link) => (
									<li><a href={link.href} class={linkClass}>{link.label}</a></li>
								))}
							</ul>
							<ul class="flex flex-col gap-2.5" role="list">
								{midCol.map((link) => (
									<li><a href={link.href} class={linkClass}>{link.label}</a></li>
								))}
							</ul>
						</div>
					</div>

					<!-- Right: newsletter + contacts -->
					<div class={`flex flex-col gap-10 ${rightColAlignCls}`}>
						{newsletterEnabled && (
							<div class="flex w-full max-w-[320px] flex-col gap-3">
								<p
									class="font-logo text-[14px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))]"
									data-puck-subsection-parent={id}
									data-puck-subsection-index="100"
									data-puck-subsection-field="newsletter"
								>
									{newsletterHeadingText}
								</p>
								{newsletterText && (
									<p
										class="font-manrope text-xs font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
										data-puck-subsection-parent={id}
										data-puck-subsection-index="100"
										data-puck-subsection-field="text"
									>
										{newsletterText}
									</p>
								)}
								<form
									class="flex h-10 w-full items-center justify-between border border-[rgb(var(--color-muted,153_153_153))] pl-3 pr-2.5"
									data-newsletter-form
									data-puck-subsection-parent={id}
									data-puck-subsection-index="997"
									data-puck-subsection-field="newsletter"
								>
									<input type="email" name="email" required placeholder={emailPlaceholder} aria-label="Email" class="min-w-0 flex-1 bg-transparent font-manrope text-xs font-light leading-normal text-[rgb(var(--color-text,0_0_0))] placeholder:text-[rgb(var(--color-muted,153_153_153))] outline-none" />
									<button type="submit" aria-label="Подписаться" class="flex h-6 w-6 shrink-0 items-center justify-center transition-opacity hover:opacity-80"><NtIcon name="arrow-right" sizeClass="size-5" /></button>
								</form>
								<p data-newsletter-status role="status" class="hidden font-manrope text-xs font-light text-[rgb(var(--color-text,0_0_0))]"></p>
							</div>
						)}
						{(phone || email || contactFields.length > 0) && (
							<div
								class={`flex flex-col gap-2 ${_ca === "center" ? "text-center" : "text-right"}`}
								data-puck-subsection-parent={id}
								data-puck-subsection-index="994"
								data-puck-subsection-field="socialColumn"
							>
								{phone && <a href={`tel:${phone.replace(/[^+\d]/g, "")}`} class={linkClass}>{phone}</a>}
								{email && <a href={`mailto:${email}`} class={linkClass}>{email}</a>}
								{contactFields.map((f) => (
									<div class={linkClass}><span class="text-[rgb(var(--color-text,0_0_0))]">{f.label}:</span> {f.value}</div>
								))}
							</div>
						)}
					</div>
				</div>

				<!-- C. Socials + payments -->
				<div class="flex items-center justify-between gap-4">
					{socials.length > 0 && (
						<div class="flex items-center gap-3">
							{socials.map((s) => (
								<a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="flex h-6 w-6 items-center justify-center transition-opacity hover:opacity-70">
									<NtIcon name={s.name} sizeClass="size-6" />
								</a>
							))}
						</div>
					)}
					{paymentEnabled && (
						<div class="flex items-center gap-2">
							{payments.map((pay) => (
								<span class="flex h-6 items-center justify-center rounded-[4px] bg-[#fafafa] px-1">
									<img src={withBase(pay.src)} alt={pay.alt} class="h-4 w-auto object-contain" loading="lazy" />
								</span>
							))}
						</div>
					)}
				</div>

				<!-- D. Info row -->
				<div class={`flex items-center gap-4 border-t border-[rgb(var(--color-text,0_0_0)/13%)] pt-6 ${bottomRowJustifyCls}`}>
					<p
						class="font-manrope text-[14px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]"
						data-puck-subsection-parent={id}
						data-puck-subsection-index="993"
						data-puck-subsection-field="copyright"
					>
						{copyrightText}
					</p>
					{(infoColTitle || infoLinks.length > 0) && (
						<div
							class="flex flex-wrap items-center gap-x-6 gap-y-2"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="995"
							data-puck-subsection-field="informationColumn"
						>
							{infoColTitle && <span class={columnTitleCls}>{infoColTitle}</span>}
							{infoLinks.map((link) => (
								<a href={link.href} class={linkClass}>{link.label}</a>
							))}
						</div>
					)}
				</div>
			</div>
		</div>
	</div>

	<!-- Mobile (< md) — Figma 1-21690 -->
	<div class={mobileWrapCls} style={footerPadStyle}>
		<!-- Logo + socials -->
		<div class="flex items-center justify-between">
			<a href="/" class="font-logo text-lg font-normal uppercase leading-none text-[rgb(var(--color-heading,0_0_0))] transition-opacity hover:opacity-80">{siteTitle}</a>
			{socials.length > 0 && (
				<div class="flex items-center gap-2">
					{socials.map((s) => (
						<a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="flex h-5 w-5 items-center justify-center transition-opacity hover:opacity-70">
							<NtIcon name={s.name} sizeClass="size-5" />
						</a>
					))}
				</div>
			)}
		</div>

		<!-- Menu (left: collections/seasons, right: nav) -->
		<div class="mt-10 grid grid-cols-2 gap-x-8 gap-y-6">
			<ul class="flex flex-col gap-2.5" role="list">
				{midCol.map((link) => (
					<li><a href={link.href} class={linkClass}>{link.label}</a></li>
				))}
			</ul>
			<ul class="flex flex-col gap-2.5" role="list">
				{navColTitle && (
					<li><span class={columnTitleCls}>{navColTitle}</span></li>
				)}
				{navLinks.map((link) => (
					<li><a href={link.href} class={linkClass}>{link.label}</a></li>
				))}
			</ul>
		</div>

		<!-- Newsletter -->
		{newsletterEnabled && (
			<div class="mt-8 flex flex-col gap-3">
				<p class="font-logo text-[14px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))]">{newsletterHeadingText}</p>
				{newsletterText && (
					<p class="font-manrope text-xs font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]">{newsletterText}</p>
				)}
				<form class="flex h-10 w-full items-center justify-between border border-[rgb(var(--color-muted,153_153_153))] pl-3 pr-2.5" data-newsletter-form>
					<input type="email" name="email" required placeholder={emailPlaceholder} aria-label="Email" class="min-w-0 flex-1 bg-transparent font-manrope text-xs font-light leading-normal text-[rgb(var(--color-text,0_0_0))] placeholder:text-[rgb(var(--color-muted,153_153_153))] outline-none" />
					<button type="submit" aria-label="Подписаться" class="flex h-6 w-6 shrink-0 items-center justify-center transition-opacity hover:opacity-80"><NtIcon name="arrow-right" sizeClass="size-5" /></button>
				</form>
				<p data-newsletter-status role="status" class="hidden font-manrope text-xs font-light text-[rgb(var(--color-text,0_0_0))]"></p>
			</div>
		)}

		<!-- Contacts -->
		{(phone || email || contactFields.length > 0) && (
			<div class="mt-8 flex flex-col gap-2">
				{phone && <a href={`tel:${phone.replace(/[^+\d]/g, "")}`} class={linkClassSm}>{phone}</a>}
				{email && <a href={`mailto:${email}`} class={linkClassSm}>{email}</a>}
				{contactFields.map((f) => (
					<div class={linkClassSm}><span class="text-[rgb(var(--color-text,0_0_0))]">{f.label}:</span> {f.value}</div>
				))}
			</div>
		)}

		<!-- Divider + bottom (copyright/payments | policies) -->
		<div class="mt-8 flex justify-between gap-4 border-t border-[rgb(var(--color-text,0_0_0)/13%)] pt-6">
			<div class="flex flex-col gap-4">
				<p class="font-manrope text-[12px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]">{copyrightText}</p>
				{paymentEnabled && (
					<div class="flex items-center gap-2">
						{payments.map((pay) => (
							<span class="flex h-4 items-center justify-center rounded-[2px] bg-[#fafafa] px-1">
								<img src={withBase(pay.src)} alt={pay.alt} class="h-2.5 w-auto object-contain" loading="lazy" />
							</span>
						))}
					</div>
				)}
			</div>
			{(infoColTitle || infoLinks.length > 0) && (
				<div class="flex flex-col gap-2">
					{infoColTitle && <span class={columnTitleCls}>{infoColTitle}</span>}
					{infoLinks.map((link) => (
						<a href={link.href} class={linkClassSm}>{link.label}</a>
					))}
				</div>
			)}
		</div>
	</div>

	{bottomStripVisible && (
		<div
			class="w-full bg-[rgb(var(--color-bg,0_0_0))] py-4"
			data-puck-subsection-parent={id}
			data-puck-subsection-index="992"
			data-puck-subsection-field="bottomStrip"
		>
			<p class="text-center font-inter text-[12px] font-light leading-normal text-[rgb(var(--color-text,255_255_255))] md:text-[16px]">{stripText}</p>
		</div>
	)}
</footer>

<script>
	document.querySelectorAll<HTMLFormElement>("[data-newsletter-form]").forEach((form) => {
		form.addEventListener("submit", (event) => {
			event.preventDefault();
			const status = form.parentElement?.querySelector<HTMLElement>("[data-newsletter-status]");
			if (status) {
				status.textContent = "Спасибо! Мы отправим вам приветственное письмо.";
				status.classList.remove("hidden");
			}
			form.reset();
		});
	});
</script>
