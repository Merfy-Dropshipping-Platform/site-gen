---
// Фаза B: новая канон-секция Slideshow в манере bloom (см. themes/bloom/MANNER.md;
// процесс-эталон — rose T17 Slideshow). Схема полей = packages/theme-base/blocks/
// Slideshow/Slideshow.puckConfig.ts. Композиция = полотно Hero bloom: лестница
// аспектов героя, контент блоком max-w-[330px] в левом нижнем углу, розовая
// pill-CTA (токены кнопки-1), каскад hero-animate-1/2/3 на активном слайде.
// Параметры скрипту — ТОЛЬКО data-атрибуты (define:vars компилятором секций не
// поддерживается); идемпотентность — data-slideshow-hydrated; реинициализация —
// astro:page-load (его шлёт превью-агент после hot-replace).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон slides[] 1-5 (item: imageUrl|image, heading(string|{text,size}), subtitle,
// text{content,size}, ctaText/ctaUrl | button{text,link}, container, position,
// alignment, colorScheme).
//
// ПУСТОЕ СОСТОЯНИЕ (Figma 1:19335): когда мерчант НЕ добавил ни одного слайда —
// секция рендерит ПЛЕЙСХОЛДЕР контракта (пустой image-rect #FBFBFB-эквивалент
// surface + заголовок секции + поясняющий текст + Кнопка + точки-навигация), а
// НЕ мок-демо верстальщика (3 слайда-болванки «Ритуал сияния/HYDRO/Бестселлеры»
// + фоллбек-фото /images/hero-background.webp …). Образец гейта — theme-base
// Collections.astro (hasManualCollections → DEMO) и манера пустого rect темы
// bloom — ImageWithText.astro (тот же Figma-контракт: bg surface + заголовок +
// текст + розовый pill). Когда слайды ВЫБРАНЫ (p.slides.length) — рендер
// реальных слайдов БЕЗ изменений; слайд без фото = ПУСТАЯ surface-плитка
// (ветка s.image ? <img> : <div bg-surface> ниже), а НЕ мок-ассет верстальщика;
// клиентский слайдер (prev/next/dots при ≥2 слайдах) не затрагивается.
// Figma 1:19335 — слайд пустого состояния несёт дизайн-ассет landscape-slideshow.png
// (раздаётся на каждой теме из packages/theme-base/public/placeholders, copyPublic),
// а НЕ пустой image-rect (surface) и НЕ ассет верстальщика (контракт картиночных
// секций, эталон rose Slideshow.astro). Текст плейсхолдера дословно по Figma:
// «Слайд-шоу» + «Добавь несколько изображений с информацией о своём бренде» + «Кнопка».
const PLACEHOLDER_SLIDE_IMAGE = "/placeholders/landscape-slideshow.png";
const PLACEHOLDER_SLIDE = {
	id: "placeholder",
	imageUrl: PLACEHOLDER_SLIDE_IMAGE,
	heading: "Слайд-шоу",
	subtitle: "Добавь несколько изображений с информацией о своём бренде",
	ctaText: "Кнопка",
	ctaUrl: "/catalog",
};
const hasSlides = Array.isArray(p.slides) && p.slides.length > 0;
const rawSlides = hasSlides ? p.slides : [PLACEHOLDER_SLIDE];

// Заголовок слайда — лестница hero h1 манеры (§9): large (canon-носитель
// blockDefaults Hero) и отсутствие = литерал верстальщика 18/md:20;
// medium 15/17, small 13/14. Цвета — токены с фоллбеком родного #E38E9F.
const slideHeadingCls = (s: string | undefined) =>
	s === "small"
		? "font-urbanist text-[13px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[14px]"
		: s === "medium"
			? "font-urbanist text-[15px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[17px]"
			: "font-urbanist text-[18px] font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))] md:text-[20px]";
// Текст слайда — лестница hero-подзаголовка (§9): 14/16 литерал → 12/14 → 10/11.
const slideTextCls = (s: string | undefined) =>
	s === "small"
		? "font-inter text-[10px] font-light leading-[1.2] text-[rgb(var(--color-text,227_142_159))] md:text-[11px]"
		: s === "medium"
			? "font-inter text-[12px] font-light leading-[1.2] text-[rgb(var(--color-text,227_142_159))] md:text-[14px]"
			: "font-inter text-[14px] font-light leading-[1.2] text-[rgb(var(--color-text,227_142_159))] md:text-[16px]";

// Реальный слайд мерчанта без фото = ПУСТАЯ surface-карточка (ветка
// s.image ? <img> : <div bg-surface> ниже), а НЕ мок-ассет верстальщика
// (контракт Figma 1:19335). Мок-фолбэки /images/hero-background.webp … УБРАНЫ:
// слайд без imageUrl/image теперь даёт image="" → пустая surface-плитка. В ПУСТОМ
// состоянии (!hasSlides) слайд-плейсхолдер несёт дизайн-ассет landscape-slideshow.png
// (PLACEHOLDER_SLIDE выше).
const slides = rawSlides.slice(0, 5).map((s: any, i: number) => {
	const ctaText =
		(typeof s.ctaText === "string" && s.ctaText.trim() ? s.ctaText : undefined) ??
		(typeof s.button?.text === "string" && s.button.text.trim() ? s.button.text : undefined);
	return {
		image:
			(typeof s.imageUrl === "string" && s.imageUrl.trim()) ||
			(typeof s.image === "string" && s.image.trim()) ||
			"",
		heading: typeof s.heading === "string" ? s.heading : (s.heading?.text ?? ""),
		headingCls: slideHeadingCls(typeof s.heading === "object" ? s.heading?.size : undefined),
		subtitle:
			(typeof s.subtitle === "string" && s.subtitle.trim() ? s.subtitle : undefined) ??
			(typeof s.text?.content === "string" && s.text.content.trim() ? s.text.content : undefined),
		textCls: slideTextCls(s.text?.size),
		ctaText,
		ctaHref:
			(typeof s.ctaUrl === "string" && s.ctaUrl ? s.ctaUrl : undefined) ??
			s.button?.link?.href ??
			(typeof s.button?.link === "string" && s.button.link ? s.button.link : undefined) ??
			"/catalog",
		boxed: String(s.container ?? "false") === "true",
		schemeCls:
			typeof s.colorScheme === "string" && s.colorScheme
				? ` color-scheme-${String(s.colorScheme).replace("scheme-", "")}`
				: "",
		// position per-slide (приоритет) | top-level contentAlign; 'left'
		// (canon-default blockDefaults) и отсутствие = левый нижний угол героя.
		posCls:
			s.position === "center" || (!s.position && p.contentAlign === "center")
				? "justify-center"
				: s.position === "right"
					? "justify-end"
					: "justify-start",
		// alignment per-slide; 'left' (canon-default blockDefaults) и отсутствие =
		// items-start героя.
		alignCls:
			s.alignment === "center"
				? "items-center text-center"
				: s.alignment === "right"
					? "items-end text-right"
					: "items-start text-left",
		active: i === 0,
	};
});

// Канон interval (slider 1-20 c, схема до 60) / autoplay: canon-defaults 5 / true.
const intervalMs = String(
	(typeof p.interval === "number" && p.interval >= 1 && p.interval <= 60 ? p.interval : 5) * 1000,
);
const autoplay = p.autoplay === false || p.autoplay === "false" ? "false" : "true";

// Канон size (s/m/l): medium и отсутствие = полотно героя (лестница аспектов
// верстальщика, min-h-[560px]); small/large — фиксированный шаг высоты от него.
const canvasCls =
	p.size === "small"
		? "relative mx-auto w-full overflow-hidden h-[min(60svh,420px)]"
		: p.size === "large"
			? "relative mx-auto w-full overflow-hidden h-[min(80svh,720px)]"
			: "relative mx-auto w-full overflow-hidden min-h-[560px] aspect-[375/812] sm:aspect-[768/968] md:aspect-[1280/968] xl:aspect-[1920/925]";

// Канон imagePosition: fullscreen (canon-default; полотно во всю ширину секции,
// как герой) | contained (+legacy left/right) — внутри контейнера манеры с
// полями секции и радиусом медиа. imageFullBleed=true возвращает full-bleed.
const contained =
	(p.imagePosition === "contained" || p.imagePosition === "left" || p.imagePosition === "right") &&
	p.imageFullBleed !== true &&
	p.imageFullBleed !== "true";

// Канон overlay 0-100 — затемнение между фото и контентом (паттерн Hero).
const overlayN = Math.max(0, Math.min(100, Number(p.overlay) || 0));

// Канон pagination: 'numbers' (canon-default из blockDefaults bloom) и
// отсутствие = цифры Inter 14; dots = точки манеры h-2 w-2 rounded-full
// (активная белая на фото, неактивная white/50); counter/lines/none — канон.
const pagination =
	p.pagination === "dots" ||
	p.pagination === "counter" ||
	p.pagination === "lines" ||
	p.pagination === "none"
		? p.pagination
		: "numbers";

// Канон buttonStyle: solid (canon-default) = розовая pill-CTA героя дословно
// (токены кнопки-1 §3); outlined = контурный pill ветки героя.
const ctaCls =
	p.buttonStyle === "outlined"
		? "inline-flex h-12 items-center justify-center rounded-[var(--radius-button,100px)] border border-solid border-[rgb(var(--color-button-bg,227_142_159))] bg-transparent px-4 font-inter text-[16px] font-light leading-none text-[rgb(var(--color-button-bg,227_142_159))] transition-opacity hover:opacity-90 active:scale-95"
		: "inline-flex h-12 items-center justify-center rounded-[var(--radius-button,100px)] bg-[rgb(var(--color-button-bg,227_142_159))] px-4 font-inter text-[16px] font-light leading-none text-[rgb(var(--color-button-text,255_255_255))] transition-opacity hover:opacity-90 active:scale-95";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	class="relative w-full overflow-hidden bg-[rgb(var(--color-bg,255_255_255))]"
	data-puck-component-id={id}
	data-bloom-slideshow
	data-interval={intervalMs}
	data-autoplay={autoplay}
	style={paddingStyle}
>
	<div class={contained ? "w-full px-4 md:px-20 2xl:px-[300px]" : "w-full"}>
		<div class={`${canvasCls}${contained ? " max-w-[1320px] rounded-[var(--radius-media,12px)]" : ""}`}>
			{
				slides.map((s, i) => (
					<div
						data-slide
						class={`!absolute inset-0 transition-opacity duration-700 ease-out ${s.active ? "opacity-100" : "pointer-events-none opacity-0"}${s.schemeCls}`}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="slides"
					>
						{s.image ? (
							<img
								src={s.image}
								alt={s.heading || "Слайд"}
								loading={i === 0 ? "eager" : "lazy"}
								class="absolute inset-0 !h-full !w-full object-cover object-center"
							/>
						) : (
							<div class="absolute inset-0 bg-[rgb(var(--color-surface,245_245_245))]" aria-hidden="true" />
						)}
						{overlayN > 0 && s.image && (
							<div
								class="pointer-events-none absolute inset-0 bg-black"
								style={`opacity:${overlayN / 100}`}
								aria-hidden="true"
							/>
						)}
						{/* Контент в нижнем углу полотна — манера героя bloom (блок 330px,
						    поля px-4 md:px-20 2xl:px-[300px], pb-8/12/20). */}
						<div
							class={`relative z-10 flex h-full w-full items-end px-4 pb-8 md:px-20 md:pb-12 xl:pb-20 2xl:px-[300px] ${s.posCls}`}
						>
							<div
								class={`flex max-w-[330px] flex-col gap-4 ${s.alignCls}${s.boxed ? " rounded-[var(--radius-card,12px)] bg-[rgb(var(--color-bg,255_255_255))]/90 p-6" : ""}`}
							>
								<div class={`flex flex-col gap-2 ${s.alignCls}`}>
									{s.heading && <h2 class={`hero-animate-1 ${s.headingCls}`}>{s.heading}</h2>}
									{s.subtitle && <p class={`hero-animate-2 ${s.textCls}`}>{s.subtitle}</p>}
								</div>
								{s.ctaText && (
									<a href={s.ctaHref} class={`hero-animate-3 ${ctaCls}`}>
										{s.ctaText}
									</a>
								)}
							</div>
						</div>
					</div>
				))
			}

			{
				slides.length > 1 && (
					<>
						<button
							type="button"
							data-slide-prev
							aria-label="Предыдущий слайд"
							class="absolute left-4 top-1/2 z-20 flex size-10 -translate-y-1/2 items-center justify-center !rounded-full !bg-white/80 !text-black transition-opacity hover:opacity-90 active:scale-95"
						>
							<svg class="size-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
								<path d="M12.5 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</button>
						<button
							type="button"
							data-slide-next
							aria-label="Следующий слайд"
							class="absolute right-4 top-1/2 z-20 flex size-10 -translate-y-1/2 items-center justify-center !rounded-full !bg-white/80 !text-black transition-opacity hover:opacity-90 active:scale-95"
						>
							<svg class="size-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
								<path d="M7.5 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</button>
						{pagination !== "none" && (
							<div class="absolute bottom-5 right-4 z-20 flex items-center gap-2 md:right-20 2xl:right-[300px]">
								{pagination === "numbers" &&
									slides.map((_, i) => (
										<button
											type="button"
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											aria-label={`Слайд ${i + 1}`}
											class="font-inter text-[14px] font-light leading-none !text-white/60 transition-colors data-[active=true]:!text-white"
										>
											{i + 1}
										</button>
									))}
								{pagination === "dots" &&
									slides.map((_, i) => (
										<button
											type="button"
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											aria-label={`Слайд ${i + 1}`}
											class="h-2 w-2 !rounded-full !bg-white/50 transition-colors data-[active=true]:!bg-white"
										/>
									))}
								{pagination === "lines" &&
									slides.map((_, i) => (
										<button
											type="button"
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											aria-label={`Слайд ${i + 1}`}
											class="h-0.5 w-6 !bg-white/50 transition-colors data-[active=true]:!bg-white"
										/>
									))}
								{pagination === "counter" &&
									slides.map((_, i) => (
										<span
											data-slide-dot
											data-active={i === 0 ? "true" : "false"}
											class="font-inter text-[14px] font-light leading-none text-white data-[active=false]:hidden"
										>
											{i + 1} / {slides.length}
										</span>
									))}
							</div>
						)}
					</>
				)
			}

			{
				/* ПЛЕЙСХОЛДЕР пустого состояния (Figma 1:19335): точки-навигация —
				   декоративные (3 точки, одна активная) на светлом surface-полотне,
				   тёмный токен heading вместо белого реальных слайдов. JS-логики нет
				   (один слайд) — чисто визуальный контракт пустого состояния. */
				!hasSlides && (
					<div class="absolute bottom-5 left-1/2 z-20 flex -translate-x-1/2 items-center gap-2" aria-hidden="true">
						{[0, 1, 2].map((i) => (
							<span class={`h-2 w-2 !rounded-full ${i === 0 ? "bg-white" : "bg-white/50"}`} />
						))}
					</div>
				)
			}
		</div>
	</div>
</section>

<script is:inline>
	(function () {
		function initOne(root) {
			if (root.dataset.slideshowHydrated === "true") return;
			root.dataset.slideshowHydrated = "true";
			var interval = parseInt(root.dataset.interval || "5000", 10);
			var autoplay = root.dataset.autoplay !== "false";
			var slides = root.querySelectorAll("[data-slide]");
			var dots = root.querySelectorAll("[data-slide-dot]");
			if (slides.length < 2) return;
			var idx = 0,
				timer = null;
			// Каскад hero-animate-1/2/3 на активном слайде — перезапуск CSS-анимации
			// манеры (animation:none → reflow → снятие), как при загрузке героя.
			function replayCascade(slide) {
				var els = slide.querySelectorAll(".hero-animate-1,.hero-animate-2,.hero-animate-3");
				for (var j = 0; j < els.length; j++) {
					els[j].style.animation = "none";
					void els[j].offsetWidth;
					els[j].style.animation = "";
				}
			}
			function show(n) {
				idx = (n + slides.length) % slides.length;
				for (var j = 0; j < slides.length; j++) {
					slides[j].style.opacity = j === idx ? "1" : "0";
					slides[j].style.pointerEvents = j === idx ? "auto" : "none";
				}
				for (var j = 0; j < dots.length; j++) {
					dots[j].setAttribute("data-active", j === idx ? "true" : "false");
				}
				replayCascade(slides[idx]);
			}
			function restart() {
				if (timer) clearInterval(timer);
				if (autoplay)
					timer = setInterval(function () {
						show(idx + 1);
					}, interval);
			}
			root.querySelectorAll("[data-slide-prev]").forEach(function (b) {
				b.addEventListener("click", function () {
					show(idx - 1);
					restart();
				});
			});
			root.querySelectorAll("[data-slide-next]").forEach(function (b) {
				b.addEventListener("click", function () {
					show(idx + 1);
					restart();
				});
			});
			dots.forEach(function (d, i) {
				d.addEventListener("click", function () {
					show(i);
					restart();
				});
			});
			show(0);
			restart();
		}
		function initAll() {
			var roots = document.querySelectorAll("[data-bloom-slideshow]");
			for (var k = 0; k < roots.length; k++) initOne(roots[k]);
		}
		initAll();
		// Hot-replace превью вставляет секцию заново (новый узел без флага) и шлёт
		// astro:page-load — реинициализация подхватит свежий слайдер.
		document.addEventListener("astro:page-load", initAll);
	})();
</script>
