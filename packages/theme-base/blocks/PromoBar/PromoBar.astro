---
import type { PromoBarProps } from './PromoBar.puckConfig';
import { PromoBarClasses as C } from './PromoBar.classes';

interface Props extends PromoBarProps {
  id?: string;
}

const { id, text, linkText, linkHref } = Astro.props as Props;
const colorSchemeRaw = (Astro.props as Record<string, unknown>).colorScheme;
const schemeClass = typeof colorSchemeRaw === 'string'
  ? `color-scheme-${colorSchemeRaw.replace('scheme-', '')}`
  : '';
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-block="promo-bar"
>
  <div class={C.container}>
    <p class={C.text}>
      <span data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="text">{text}</span>
      {linkText && linkHref && (
        <>
          {' '}
          <a href={linkHref} class={C.link} data-puck-subsection-parent={id} data-puck-subsection-index="101" data-puck-subsection-field="link">{linkText}</a>
        </>
      )}
    </p>
  </div>
</section>
