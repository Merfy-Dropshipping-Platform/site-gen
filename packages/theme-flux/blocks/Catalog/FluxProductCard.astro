---
/**
 * FluxProductCard (порт из themes/flux/src/components/products/FluxProductCard.astro).
 *
 * Тип Product заинлайнен (минимальный shape витрины) вместо импорта
 * ../../types/product — block-папка override-темы автономна (компилятор превью
 * не резолвит пути за пределы папки). FluxPicture — sibling (./).
 *
 * Добавлены props (cardAspectClass / showQuickAdd / quickAddText / btnStyle /
 * btnBg / btnFg / btnBorder) для parity с настройками карточки Catalog и
 * client-функцией renderCardHtml (SSG ≡ live). Меняется СИНХРОННО с renderCardHtml.
 */
import FluxPicture from "./FluxPicture.astro";

interface VariantSwatchLite {
  value?: string;
  color?: string | null;
  available?: boolean;
}
interface VariantGroupLite {
  name?: string;
  options?: Array<{ value?: string; swatchHex?: string | null; images?: string[] | null }>;
}
interface VariantComboLite {
  options?: Record<string, string>;
  available?: boolean;
}
interface Product {
  name: string;
  price: string;
  oldPrice?: string;
  image: string;
  id?: string;
  discount?: boolean;
  // Опц. вариант-данные (parity с client renderCardHtml). Demo-товары их НЕ несут
  // → свотчи/чипы не рендерятся; реальный товар (если прокинут) рисует как эталон.
  variantSwatches?: VariantSwatchLite[];
  variantGroups?: VariantGroupLite[];
  variantCombinations?: VariantComboLite[];
  compareAtPrice?: number | string | null;
}

interface Props {
  product: Product;
  priority?: boolean;
  /** Вид изображения карточки (Tailwind aspect-класс). Дефолт flux — квадрат
      (theme.json blockDefaults.Catalog.productCard.cardStyle = 'square').
      Передаётся из Catalog.astro (настройка «Вид изображения»),
      зеркалит client renderCardHtml для parity. */
  cardAspectClass?: string;
  /** Быстрое действие: кнопка под карточкой (none → нет; иначе текст). */
  showQuickAdd?: boolean;
  quickAddText?: string;
  /** Inline-стили кнопки quickAdd по «Стилю кнопки» (primary/secondary/link). */
  btnStyle?: string;
  btnBg?: string;
  btnFg?: string;
  btnBorder?: string;
  /** «Контейнер» карточки (Figma productCard.cardBackground). true → контент с
      внутренним отступом 12px (фото/кнопка inset, surface-фон карточки);
      false (дефолт) → флеш к краям (фото full-bleed, кнопка full-width).
      Зеркалит client renderCardHtml для parity. */
  cardContainerOn?: boolean;
}

const {
  product,
  priority = false,
  cardAspectClass = "aspect-square",
  showQuickAdd = false,
  quickAddText = "В КОРЗИНУ",
  btnStyle = "primary",
  btnBg = "rgb(var(--color-button-bg,0 0 0))",
  btnFg = "rgb(var(--color-button-text,255 255 255))",
  btnBorder = "1px solid rgb(var(--color-button-bg,0 0 0))",
  cardContainerOn = false,
} = Astro.props as Props;
const href = `/products/${product.id}`;

// ─── Свотчи цвета / чипы памяти-размера / бейдж «-N%» (parity с эталоном
//     FluxProductCard.astro + client renderCardHtml). Логика деривации
//     заинлайнена (block-папка автономна — без import за пределы папки). ───
const HEX_RE = /^#([0-9a-f]{3}|[0-9a-f]{6})$/i;
const COLOR_GROUP_RE = /^(цвет|color)$/i;
const CHIP_GROUP_RE = /^(память|memory|storage|накопитель|размер|объ[её]м памяти|размер памяти)$/i;
const COLOR_NAME_HEX: Record<string, string> = {
  белый: "#FFFFFF", white: "#FFFFFF", "чёрный": "#000000", черный: "#000000", black: "#000000",
  красный: "#E02D2D", red: "#E02D2D", синий: "#2D4BE0", blue: "#2D4BE0", голубой: "#6FB7E0",
  "зелёный": "#2DA84F", зеленый: "#2DA84F", green: "#2DA84F", "жёлтый": "#F2C53D", желтый: "#F2C53D",
  yellow: "#F2C53D", оранжевый: "#FA5109", orange: "#FA5109", серый: "#9A9A9A", gray: "#9A9A9A",
  grey: "#9A9A9A", серебро: "#C0C0C0", серебряный: "#C0C0C0", silver: "#C0C0C0", графит: "#3A3A3A",
  graphite: "#3A3A3A", "бежевый": "#E8D9C0", beige: "#E8D9C0", коричневый: "#7A5230", brown: "#7A5230",
  розовый: "#F2A0C0", pink: "#F2A0C0", фиолетовый: "#7A3FB0", purple: "#7A3FB0", violet: "#7A3FB0",
  бордовый: "#6E1423", золотой: "#D4AF37", gold: "#D4AF37", бирюзовый: "#2DBFB0", teal: "#2DBFB0",
};
function colorToHex(value?: string | null, hint?: string | null): string | null {
  const h = String(hint ?? "").trim();
  if (HEX_RE.test(h)) return h;
  const v = String(value ?? "").trim();
  if (HEX_RE.test(v)) return v;
  return COLOR_NAME_HEX[v.toLowerCase()] ?? null;
}
// Свотч flux несёт СВОЮ картинку цвета-варианта (фича flux, нет у rose):
// { color:#hex, image:url|null, available }. image = группа «Цвет» variantGroups →
// option.images[0], сопоставление по value (имя цвета) и по hex. Нет картинки →
// image=null → свотч рисуется статичным <span> (эталон). Зеркалит client
// deriveCardSwatches в Catalog.astro (parity SSG↔live).
interface CardSwatch {
  color: string;
  image: string | null;
  available: boolean;
}
function deriveSwatches(p: Product): { swatches: CardSwatch[]; swatchDisabled: boolean } {
  const out: CardSwatch[] = [];
  const seen = new Set<string>();
  let swatchDisabled = false;
  // Лукап картинок цвета из группы «Цвет» variantGroups (option.images[0]):
  // по имени цвета (value) и по hex.
  const imageByValue = new Map<string, string>();
  const imageByHex = new Map<string, string>();
  const colorGroup = Array.isArray(p.variantGroups)
    ? p.variantGroups.find((g) => COLOR_GROUP_RE.test(String(g?.name ?? "").trim()))
    : undefined;
  if (colorGroup && Array.isArray(colorGroup.options)) {
    for (const o of colorGroup.options) {
      const img =
        (o && Array.isArray(o.images) && typeof o.images[0] === "string" && o.images[0]) || null;
      if (!img) continue;
      const val = String(o?.value ?? "").trim().toLowerCase();
      if (val && !imageByValue.has(val)) imageByValue.set(val, img);
      const hx = colorToHex(o?.value, o?.swatchHex);
      if (hx && !imageByHex.has(hx.toLowerCase())) imageByHex.set(hx.toLowerCase(), img);
    }
  }
  const push = (hex: string | null, available?: boolean, value?: string | null): void => {
    if (!hex) return;
    if (available === false) { swatchDisabled = true; return; }
    const key = hex.toLowerCase();
    if (seen.has(key)) return;
    seen.add(key);
    const val = String(value ?? "").trim().toLowerCase();
    const image = (val ? imageByValue.get(val) : undefined) ?? imageByHex.get(key) ?? null;
    out.push({ color: hex, image, available: available !== false });
  };
  if (Array.isArray(p.variantSwatches) && p.variantSwatches.length) {
    for (const s of p.variantSwatches) push(colorToHex(s?.value, s?.color), s?.available, s?.value);
  }
  if (out.length === 0 && Array.isArray(p.variantGroups)) {
    const group = p.variantGroups.find((g) => COLOR_GROUP_RE.test(String(g?.name ?? "").trim()));
    if (group && Array.isArray(group.options)) {
      for (const o of group.options) push(colorToHex(o?.value, o?.swatchHex), undefined, o?.value);
    }
  }
  if (out.length === 0 && Array.isArray(p.variantCombinations)) {
    for (const c of p.variantCombinations) {
      const name = c?.options?.["Цвет"] ?? c?.options?.["Color"];
      push(colorToHex(name), c?.available, name);
    }
  }
  return { swatches: out.slice(0, 6), swatchDisabled };
}
function deriveChips(p: Product): Array<{ value: string; disabled: boolean }> {
  const groups = Array.isArray(p.variantGroups) ? p.variantGroups : [];
  const combos = Array.isArray(p.variantCombinations) ? p.variantCombinations : [];
  const availableValues = new Set<string>();
  let haveComboData = false;
  for (const c of combos) {
    const opts = c?.options ?? {};
    for (const k of Object.keys(opts)) {
      if (!CHIP_GROUP_RE.test(String(k).trim())) continue;
      haveComboData = true;
      if (c?.available !== false) availableValues.add(String(opts[k]).trim().toLowerCase());
    }
  }
  const out: Array<{ value: string; disabled: boolean }> = [];
  const seen = new Set<string>();
  const add = (value?: string | null): void => {
    const s = String(value ?? "").trim();
    if (!s) return;
    const key = s.toLowerCase();
    if (seen.has(key)) return;
    seen.add(key);
    out.push({ value: s, disabled: haveComboData && !availableValues.has(key) });
  };
  for (const g of groups) {
    if (!g || !CHIP_GROUP_RE.test(String(g.name ?? "").trim())) continue;
    for (const o of g.options ?? []) add(o?.value);
  }
  if (out.length === 0) {
    for (const c of combos) {
      const opts = c?.options ?? {};
      for (const k of Object.keys(opts)) {
        if (CHIP_GROUP_RE.test(String(k).trim())) add(opts[k]);
      }
    }
  }
  return out.slice(0, 4);
}
function parsePriceNum(v: number | string | null | undefined): number | null {
  if (v === null || v === undefined || v === "") return null;
  if (typeof v === "number") return Number.isFinite(v) && v > 0 ? v : null;
  const n = parseInt(String(v).replace(/[^\d]/g, ""), 10);
  return Number.isFinite(n) && n > 0 ? n : null;
}
const { swatches, swatchDisabled } = deriveSwatches(product);
const chips = deriveChips(product);
// Бейдж: «-N%» при уценке (oldPrice/compareAtPrice > price); иначе legacy «Скидка»
// (demo-флаг discount, чтобы не потерять заглушку пустой сборки).
const _oldNum = parsePriceNum(product.oldPrice ?? product.compareAtPrice ?? null);
const _curNum = parsePriceNum(product.price);
const salePercent =
  _oldNum && _curNum && _oldNum > _curNum ? Math.round(((_oldNum - _curNum) / _oldNum) * 100) : null;
const saleBadgeLabel =
  salePercent && salePercent > 0 ? `-${salePercent}%` : product.discount === true ? "Скидка" : null;
// «Контейнер» (cardBackground): true → внутренний отступ 12px со всех сторон +
//   surface-фон → фото/название/цена/кнопка inset (кнопка width:100% становится
//   cardW−24, НЕ во всю ширину). false (дефолт) → флеш к краям, фон не задаётся,
//   кнопка край-в-край. Бейдж «Скидка» остаётся ~8px от края (top-2/left-2 = 8px)
//   в обоих состояниях. inline-style зеркалит client renderCardHtml (parity).
const cardContainerStyle = cardContainerOn
  ? "padding:12px;background:rgb(var(--color-surface,245 245 245));border-radius:var(--radius-media,8px);"
  : "";
// Стиль кнопки quickAdd (зеркалит client renderCardHtml). link → текст-ссылка.
const quickBtnStyle =
  `width:100%;height:44px;padding:0 12px;border-radius:var(--radius-button,6px);` +
  `font-family:var(--font-body);font-size:14px;text-transform:uppercase;cursor:pointer;` +
  `display:flex;align-items:center;justify-content:center;` +
  `background:${btnBg};color:${btnFg};border:${btnBorder};` +
  (btnStyle === "link" ? "text-decoration:underline;background:transparent;" : "");

// Outline-сердце избранного (SSR-дефолт). Геометрия = public/icons/favourite.svg
// flux и зеркалит wishlist.ts heartSvg(false). Инлайн (НЕ <img> NtIcon) — чтобы
// глобальный делегат initWishlistUI мог переключать fill на filled (акцент flux).
// На SSG нет window → рисуем outline; делегат поставит filled на page-load если
// товар в избранном. SVG-строка автономна (block-папка override-темы не резолвит
// импорты наружу — путь дублируется здесь намеренно).
const defaultHeartSvg =
  '<svg viewBox="0 0 17.4 15.4" width="100%" height="100%" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="display:block">' +
  '<path d="M7.428 14.2615C5.172 12.5239 0.7 8.55212 0.7 4.97729C0.7 2.61547 2.384 0.7 4.7 0.7C5.9 0.7 7.1 1.11175 8.7 2.75876C10.3 1.11175 11.5 0.7 12.7 0.7C15.016 0.7 16.7 2.61547 16.7 4.97729C16.7 8.5513 12.228 12.5239 9.972 14.2615C9.212 14.8462 8.188 14.8462 7.428 14.2615Z" ' +
  'fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>' +
  "</svg>";
---

<article
  class="group flex w-full flex-col gap-3 md:gap-4"
  data-nt="flux-product-card"
  data-card-container={cardContainerOn ? "true" : "false"}
  style={cardContainerStyle}
  aria-label={product.name}
>
  {/* Обёртка медиа: relative-родитель для overlay-сердца избранного. Сердце —
      sibling <a> (НЕ внутри: button-in-anchor невалиден + клик по сердцу не должен
      открывать товар). aspect-класс несёт сам <a>; обёртка только позиционирует. */}
  <div class="relative w-full">
  <a
    href={href}
    class:list={[cardAspectClass, "relative block w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-[#F5F5F5]"]}
    aria-label={product.name}
  >
    {product.image ? (
      <FluxPicture
        src={product.image}
        alt={product.name}
        width="318"
        height="444"
        loading="eager"
        fetchpriority={priority ? "high" : undefined}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        data-card-img="true"
        data-img-primary={product.image}
      />
    ) : (
      /* Товар без фото: surface-плейсхолдер вместо <img> (битой иконки).
         Цвета только токенами; разметку зеркалит CARD_MEDIA_FALLBACK_HTML
         в client renderCardHtml — менять синхронно. */
      <div
        class="absolute inset-0 flex items-center justify-center"
        style="background:rgb(var(--color-surface,245 245 245))"
        aria-hidden="true"
      >
        <svg
          class="size-10"
          style="color:rgb(var(--color-muted,153 153 153))"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="3" width="18" height="18" rx="2"></rect>
          <circle cx="9" cy="9" r="2"></circle>
          <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
        </svg>
      </div>
    )}
    {saleBadgeLabel && (
      <div class="absolute left-2 top-2 z-10 flex flex-col items-start gap-1">
        <span class="inline-flex items-center justify-center rounded-[4px] bg-[#FA5109] px-1.5 py-1 font-roboto-flex text-[12px] font-light leading-none text-white md:text-[14px]">
          {saleBadgeLabel}
        </span>
      </div>
    )}
  </a>
    {/* Сердце избранного (overlay top-right, зеркалит бейдж «Скидка» по позиции).
        data-product-id ловит глобальный делегат initWishlistUI: toggle + перерисовка
        состояния (filled-акцент/outline + aria-pressed). Начальное состояние ставит
        делегат на page-load (SSG рендер без window — рисуем outline-сердце). z-20
        поверх фото/бейджа. Зеркалит client renderCardHtml (parity SSG↔live). */}
    <button
      type="button"
      data-wishlist-toggle
      data-product-id={product.id}
      aria-pressed="false"
      aria-label="В избранное"
      class="absolute right-2 top-2 z-20 flex size-9 items-center justify-center rounded-full bg-white/90 text-[#000000] shadow-[0_2px_8px_rgba(0,0,0,0.10)] backdrop-blur-sm transition-opacity hover:opacity-80"
    >
      <span data-wishlist-icon class="block size-[18px]" set:html={defaultHeartSvg}></span>
    </button>
  </div>
  {/* Свотчи цвета (эталон): цветные квадраты + опц. перечёркнутый «недоступный».
      Demo-товары без вариантов → массив пуст → блок не рендерится. */}
  {swatches.length > 0 && (
    <div class="flex items-center gap-1">
      {swatches.map((s) =>
        s.image ? (
          /* Свотч С картинкой цвета → кликабельная кнопка: клик меняет фото
             карточки на фото цвета (делегат в Catalog.astro inline-скрипте).
             Классы = span-эталон + cursor/p-0; border снят inline. */
          <button
            type="button"
            data-swatch-img={s.image}
            aria-pressed="false"
            aria-label="Показать фото цвета"
            class="size-5 rounded-[2px] cursor-pointer p-0"
            style={`background:${s.color};border:0`}
          ></button>
        ) : (
          <span class="size-5 rounded-[2px]" style={`background:${s.color}`} aria-hidden="true"></span>
        ),
      )}
      {swatchDisabled && (
        <span class="relative size-5 rounded-[2px] bg-[#F5F5F5]" aria-hidden="true">
          <span class="absolute inset-0 m-auto h-[1px] w-[26px] origin-center -rotate-45 bg-[#999999]"></span>
        </span>
      )}
    </div>
  )}
  <div class="flex w-full flex-col gap-1 text-left">
    <a
      href={href}
      class="flux-product-name block w-full font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-80 md:text-[16px]"
    >
      {product.name}
    </a>
    <div class="flex w-full flex-wrap items-baseline gap-2">
      <span class="flux-product-price font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]">
        {product.price}
      </span>
      {product.oldPrice && (
        <span class="flux-product-oldprice font-manrope text-[12px] font-normal leading-[1.366] text-[rgb(var(--color-muted,153_153_153))] line-through md:text-[14px]">
          {product.oldPrice}
        </span>
      )}
    </div>
  </div>
  {/* Чипы памяти/размера (эталон): приглушённый чип = недоступное значение. */}
  {chips.length > 0 && (
    <div class="flex flex-wrap items-start gap-1">
      {chips.map((m) => (
        <span
          class:list={[
            "inline-flex items-center rounded-[2px] border border-solid p-1 font-roboto-flex text-[12px] font-light leading-none",
            m.disabled ? "border-[#F5F5F5] bg-[#F5F5F5] text-[#CCCCCC]" : "border-[#F5F5F5] text-[#000000]",
          ]}
        >
          {m.value}
        </span>
      ))}
    </div>
  )}
  {/* Быстрое действие (настройка «Быстрое добавление»). Кнопка СНАРУЖИ <a>
      (button-in-anchor — невалидный HTML). Зеркалит client renderCardHtml.
      data-* (имя/цена/фото/старая цена) — контракт nt-cart для quick-add-handler
      в Catalog.astro (единый стор flux:cart:v1). Demo-товары без вариантов →
      цвет/размер/combo-id не несём. Цена demo — строка ("59 990 ₽"), nt-cart
      parsePrice её нормализует (снимает non-digits). */}
  {showQuickAdd && (
    <button
      type="button"
      data-quick-add-id={product.id}
      data-name={product.name}
      data-price={product.price}
      data-old-price={product.oldPrice ?? ""}
      data-image={product.image}
      style={quickBtnStyle}
    >
      {quickAddText}
    </button>
  )}
</article>
