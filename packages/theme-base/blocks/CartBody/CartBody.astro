---
// CartBody — Self-contained Astro block для Cart Puck-driven page.
// Heading + empty state + items list + inline render JS (рендерит из cartStore).
// Раньше JS жил в pages/cart.astro template, теперь Cart — обычная Puck-страница
// и каждый блок несёт свою логику.
import type { CartBodyProps } from './CartBody.puckConfig';

interface Props extends CartBodyProps {
  id?: string;
}

const { id, padding, colorScheme } = Astro.props as Props;

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : 'padding-top:80px; padding-bottom:40px;';

const schemeClass =
  typeof colorScheme === 'string' && colorScheme
    ? `color-scheme-${colorScheme.replace('scheme-', '')}`
    : '';
---
<section
  class:list={['relative w-full bg-[rgb(var(--color-bg))] text-[rgb(var(--color-text))]', schemeClass]}
  data-puck-component-id={id}
  data-block="cart-body"
  style={paddingStyle}
>
  <div class="max-w-[768px] mx-auto px-4 sm:px-6">
    <h1 class="[font-family:var(--font-heading)] uppercase text-center" style="font-size: 24px; line-height: 27px; color: rgb(var(--color-heading)); margin: 0 0 25px 0;">
      Корзина
    </h1>

    {/* Empty state — visible by default; inline JS hides when items present */}
    <div id="cart-page-empty">
      <div class="flex flex-col items-center py-16 gap-4">
        <p class="[font-family:var(--font-body)]" style="font-size: 20px; line-height: 27px; color: rgb(var(--color-muted)); text-align:center;">
          Вы пока не добавили товар в корзину.
        </p>
        <a href="/catalog" class="[font-family:var(--font-body)] bg-[rgb(var(--color-button-bg))]! text-[rgb(var(--color-button-text))]! hover:bg-[rgb(var(--color-button-bg-hover))]! hover:text-[rgb(var(--color-button-text-hover))]!" style="display:inline-flex; align-items:center; justify-content:center; padding: 12px 24px; font-size: 16px; line-height: 22px; border-radius: var(--radius-button, 8px); text-decoration: none; transition: background 0.15s, color 0.15s;">
          Продолжить покупки
        </a>
      </div>
    </div>

    {/* Items state */}
    <div id="cart-page-content" style="display: none;">
      <div id="cart-page-items" class="flex flex-col" style="gap: 50px;"></div>
    </div>
  </div>
</section>

<style is:inline>
  @media (max-width: 767px) {
    .cart-item-row { flex-direction: column !important; height: auto !important; align-items: stretch !important; gap: 16px !important; }
    .cart-item-left { gap: 16px !important; }
    .cart-item-img, .cart-item-img-placeholder { width: 120px !important; height: 120px !important; }
    .cart-item-actions { flex-direction: row !important; width: 100% !important; height: auto !important; padding: 0 !important; justify-content: space-between !important; align-items: center !important; }
  }
</style>

<script is:inline>
  (function () {
    function fmt(cents) {
      if (!cents && cents !== 0) return '0 ₽';
      return new Intl.NumberFormat('ru-RU', { style: 'currency', currency: 'RUB', minimumFractionDigits: 0 }).format(cents / 100);
    }
    function variantLines(item) {
      var lines = [];
      if (item.options && typeof item.options === 'object') {
        var keys = Object.keys(item.options);
        for (var i = 0; i < keys.length; i++) {
          lines.push(keys[i] + ': ' + item.options[keys[i]]);
        }
      }
      return lines;
    }
    function renderCart() {
      var emptyEl = document.getElementById('cart-page-empty');
      var contentEl = document.getElementById('cart-page-content');
      var itemsContainer = document.getElementById('cart-page-items');
      if (!emptyEl || !contentEl) return;

      var items = (window.cartStore && typeof window.cartStore.getItems === 'function') ? window.cartStore.getItems() : [];

      if (items.length === 0) {
        emptyEl.style.display = '';
        contentEl.style.display = 'none';
        return;
      }
      emptyEl.style.display = 'none';
      contentEl.style.display = '';

      if (itemsContainer) {
        itemsContainer.innerHTML = items.map(function (item, index) {
          var img = item.imageUrl || (item.images && item.images[0]) || item.image || '';
          var name = item.name || item.productName || 'Товар';
          var price = item.unitPriceCents || item.priceCents || item.price || 0;
          var qty = item.quantity || 1;
          var vLines = variantLines(item);

          var imgHtml = img
            ? '<img src="' + img + '" alt="' + name + '" class="cart-item-img" style="width: 184px; height: 184px; border-radius: 10px; object-fit: cover; flex-shrink: 0;">'
            : '<div class="cart-item-img-placeholder" style="width: 184px; height: 184px; border-radius: 10px; background: rgb(var(--color-muted) / 0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: rgb(var(--color-muted));"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg></div>';
          var vHtml = vLines.map(function (l) {
            return '<div class="font-body" style="font-size: 16px; line-height: 22px; color: rgb(var(--color-muted));">' + l + '</div>';
          }).join('');
          var divider = index < items.length - 1
            ? '<div style="width: 100%; height: 0; border-top: 1px solid rgb(var(--color-muted) / 0.2);"></div>'
            : '';
          return '<div>' +
            '<div class="cart-item-row" style="display: flex; justify-content: space-between; align-items: flex-end; height: 184px;">' +
              '<div class="cart-item-left" style="display: flex; align-items: center; gap: 50px;">' + imgHtml +
                '<div style="display: flex; flex-direction: column; gap: 10px;">' +
                  '<div style="display: flex; flex-direction: column; gap: 5px;">' +
                    '<div class="font-body" style="font-size: 20px; line-height: 27px; text-transform: uppercase; color: rgb(var(--color-heading));">' + name + '</div>' +
                    '<div style="display: flex; align-items: center; gap: 15px;">' +
                      '<span class="font-body" style="font-size: 24px; line-height: 33px; color: rgb(var(--color-text));">' + fmt(price) + '</span>' +
                    '</div>' +
                  '</div>' + vHtml +
                '</div>' +
              '</div>' +
              '<div class="cart-item-actions" style="display: flex; flex-direction: column; justify-content: space-between; align-items: flex-end; padding: 15px 0; width: 130px; height: 184px; box-sizing: border-box;">' +
                '<button data-action="remove" data-item-id="' + item.id + '" aria-label="Удалить" style="background: none; border: none; cursor: pointer; padding: 0; color: rgb(var(--color-muted));">' +
                  '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 6H5H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M8 6V4C8 3.46957 8.21071 2.96086 8.58579 2.58579C8.96086 2.21071 9.46957 2 10 2H14C14.5304 2 15.0391 2.21071 15.4142 2.58579C15.7893 2.96086 16 3.46957 16 4V6M19 6V20C19 20.5304 18.7893 21.0391 18.4142 21.4142C18.0391 21.7893 17.5304 22 17 22H7C6.46957 22 5.96086 21.7893 5.58579 21.4142C5.21071 21.0391 5 20.5304 5 20V6H19Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>' +
                '</button>' +
                '<div style="display: flex; align-items: center; gap: 5px;">' +
                  '<button data-action="decrease" data-item-id="' + item.id + '"' + (qty <= 1 ? ' disabled' : '') + ' style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 8px; border: 1px solid rgb(var(--color-text)); background: rgb(var(--color-bg)); cursor: pointer; color: rgb(var(--color-text));' + (qty <= 1 ? ' opacity: 0.4; cursor: not-allowed;' : '') + '">' +
                    '<svg width="20" height="20" viewBox="0 0 32 32" fill="none"><path d="M8 16H24" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>' +
                  '</button>' +
                  '<div style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">' +
                    '<span class="font-body" style="font-size: 16px; line-height: 22px; color: rgb(var(--color-text));">' + qty + '</span>' +
                  '</div>' +
                  '<button data-action="increase" data-item-id="' + item.id + '" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 8px; border: 1px solid rgb(var(--color-text)); background: rgb(var(--color-bg)); cursor: pointer; color: rgb(var(--color-text));">' +
                    '<svg width="20" height="20" viewBox="0 0 32 32" fill="none"><path d="M16 8V24M8 16H24" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>' +
                  '</button>' +
                '</div>' +
              '</div>' +
            '</div>' + divider +
          '</div>';
        }).join('');
      }
    }

    document.addEventListener('click', async function (e) {
      var btn = e.target.closest && e.target.closest('[data-action]');
      if (!btn || !window.cartStore) return;
      var inCart = btn.closest('#cart-page-content');
      if (!inCart) return;
      var action = btn.getAttribute('data-action');
      var itemId = btn.getAttribute('data-item-id');
      if (!itemId) return;
      btn.disabled = true;
      try {
        if (action === 'remove') {
          await window.cartStore.removeItem(itemId);
        } else if (action === 'decrease') {
          var items = window.cartStore.getItems();
          var it = items.find(function (i) { return i.id === itemId; });
          if (it && it.quantity > 1) await window.cartStore.updateQuantity(itemId, it.quantity - 1);
        } else if (action === 'increase') {
          var items = window.cartStore.getItems();
          var it = items.find(function (i) { return i.id === itemId; });
          if (it) await window.cartStore.updateQuantity(itemId, it.quantity + 1);
        }
      } finally {
        btn.disabled = false;
      }
    });

    document.addEventListener('cart:updated', renderCart);
    document.addEventListener('DOMContentLoaded', function () { setTimeout(renderCart, 150); });
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      setTimeout(renderCart, 150);
    }
  })();
</script>
