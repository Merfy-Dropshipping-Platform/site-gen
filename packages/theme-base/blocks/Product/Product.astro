---
/**
 * Product — orchestrator (headless refactor).
 *
 * Behaviour stays identical to the pre-headless version:
 *  1. Live SSG resolves productId → real product from data/products.json
 *  2. Constructor preview gets siteId injected and re-fetches storefront-data
 *  3. Standalone fallback shows skeleton primitives
 *
 * What changed: data normalisation moved to Product.headless.ts and the
 * markup is composed from `parts/*.astro` primitives. Visual differences
 * between themes (rose/flux) are driven entirely by `theme.json
 * blockDefaults.Product.visualConfig` — no per-theme override files.
 */
import type { ProductProps } from './Product.puckConfig';
import type { ProductView, ProductVisualConfig, RawProduct } from './Product.types';
import { DEFAULT_VISUAL_CONFIG } from './Product.types';
import { emptyProductView, normaliseProduct, resolveProduct } from './Product.headless';

// Primitives — colocated with Product.astro so compile-astro-blocks (flat
// per-block discovery) picks them up. They are presentational only; data
// flows through the headless layer above.
import ProductGallery from './ProductGallery.astro';
import ProductInfo from './ProductInfo.astro';
import ProductPrice from './ProductPrice.astro';
import ProductVariants from './ProductVariants.astro';
import ProductCounter from './ProductCounter.astro';
import ProductActions from './ProductActions.astro';
import ProductDescription from './ProductDescription.astro';
import ProductShare from './ProductShare.astro';

interface Props extends ProductProps {
  id?: string;
  siteId?: string;
  /** Theme-side visual variants (theme.json blockDefaults.Product.visualConfig). */
  visualConfig?: Partial<ProductVisualConfig>;
}

const {
  id,
  siteId,
  productId,
  text,
  title: titleProp,
  price: priceProp,
  quantity,
  buttons,
  description,
  share,
  variants: variantsProp,
  badge,
  colorScheme,
  padding,
  visualConfig: visualConfigProp,
  photoPosition = 'left',
  zoomMode = 'hover',
  size: sizeProp,
  layout: layoutProp,
} = Astro.props as Props;

// Layout switch (Figma 648:55733).
//   split        — карусель сбоку: thumbs col рядом с main image
//   carousel     — карусель снизу: main image + thumbs row
//   two-columns  — все фото в grid 2×N равными
//   stacked      — большой main + thumbs grid 2×N снизу
const VALID_LAYOUTS = ['split', 'carousel', 'two-columns', 'stacked'] as const;
const layout: 'split' | 'carousel' | 'two-columns' | 'stacked' =
  (typeof layoutProp === 'string' && (VALID_LAYOUTS as readonly string[]).includes(layoutProp))
    ? (layoutProp as 'split' | 'carousel' | 'two-columns' | 'stacked')
    : 'two-columns';

// — Sidebar size mapping (Figma 648:55733). Single source of truth: data → CSS-var → token cascade.
//
//   size        → main image (440/552/640) + thumb (72/88/96).
//   title.size  → h1 (18/24/32).
//   text.size   → brand + description body (14/16/18).
//
// Primitives (ProductInfo, ProductDescription, ProductGallery) consume these
// vars via `text-[length:var(--product-...,fallback)]` so theme cascade still
// works for themes that don't emit them.
// Top-level `size` (Figma 314-34639) → размер МАКЕТА: main image + thumb.
// title.size (sub-panel) → размер заголовка независимо.
// text.size (sub-panel) → размер brand-line / описания независимо.
// Раньше всё было привязано к одному `size` — сменa «Размер» в sidebar
// меняла и шрифты, и фото. Теперь decoupled: «Размер» в main panel —
// только layout; шрифты — в своих sub-panels.
const _size = (sizeProp === 'small' || sizeProp === 'large' ? sizeProp : 'medium');
const _titleSize = (titleProp?.size === 'small' || titleProp?.size === 'large' ? titleProp.size : 'medium');
const _textSize = (text?.size === 'small' || text?.size === 'large' ? text.size : 'medium');

const MAIN_IMAGE_PX = { small: 440, medium: 552, large: 640 } as const;
const THUMB_PX      = { small:  72, medium:  88, large:  96 } as const;
const TITLE_PX      = { small:  18, medium:  24, large:  32 } as const;
const TEXT_PX       = { small:  14, medium:  16, large:  18 } as const;

const sizeVarsStyle = `--product-title-size:${TITLE_PX[_titleSize]}px;--product-text-size:${TEXT_PX[_textSize]}px;--product-main-image-size:${MAIN_IMAGE_PX[_size]}px;--product-thumb-size:${THUMB_PX[_size]}px;`;

// — Visual configuration (LAYOUT only — colours come from active scheme). —
const visual: ProductVisualConfig = {
  ...DEFAULT_VISUAL_CONFIG,
  ...(visualConfigProp ?? {}),
  gallery: { ...DEFAULT_VISUAL_CONFIG.gallery, ...(visualConfigProp?.gallery ?? {}) },
  counter: { ...DEFAULT_VISUAL_CONFIG.counter, ...(visualConfigProp?.counter ?? {}) },
};

// — Section-level styling (color scheme + padding). —
const paddingStyle = padding
  ? `padding-top:${padding.top ?? 75}px; padding-bottom:${padding.bottom ?? 75}px;`
  : 'padding-top:75px; padding-bottom:75px;';
const schemeClass =
  typeof colorScheme === 'string' && colorScheme
    ? `color-scheme-${colorScheme.replace('scheme-', '')}`
    : '';

// — Authored prop fallbacks. —
const apiBase = 'https://gateway.merfy.ru/api';
const photoOnLeft = photoPosition !== 'right';
const priceVisible = priceProp?.show !== 'false' && priceProp?.show !== false;
const quantityVisible = quantity?.enabled !== 'false' && quantity?.enabled !== false;
const textContent = text?.content ?? badge?.text ?? '';
const addBtnText = buttons?.addToCart?.text ?? 'Добавить в корзину';
const buyBtnText = buttons?.buyNow?.text ?? 'Купить сейчас';
const shareText = share?.text ?? 'Поделиться';
const fallbackDescription = description?.content ?? '';

// — Variant display controls (variants sub-panel: «Стиль» + «Вариации»). —
//   style: 'button' (дефолт) — опции чипами в ряд (текущий вид);
//          'list'           — каждая группа отдельной строкой (лейбл + чипы).
//   shape: 'none' (дефолт)  — текущий pill-чип; 'circle' / 'square' — явный
//          выбор формы. Дефолт 'none' (а не puck-дефолт 'circle') гарантирует
//          неизменный вид существующих товаров — см. Product.puckConfig defaults.
const variantsStyle: 'button' | 'list' =
  variantsProp?.style === 'list' ? 'list' : 'button';
const variantsShape: 'circle' | 'square' | 'none' =
  variantsProp?.shape === 'circle' || variantsProp?.shape === 'square'
    ? variantsProp.shape
    : 'none';

// — Resolve product → ProductView (single source of truth). —
//
// Path 1 (live SSG): products.json snapshot is baked at build time; resolve
//   by productId/slug/handle from that array.
// Path 2 (preview iframe): products.json absent → fetch storefront-data
//   server-side so Astro renders complete HTML (variants, thumbs, etc) instead
//   of relying on JS-driven post-load DOM patching.
let realProducts: RawProduct[] = [];
try {
  const productsData = await import('../data/products.json');
  realProducts = ((productsData as { default?: RawProduct[] }).default ?? (productsData as unknown as RawProduct[])) as RawProduct[];
} catch {
  realProducts = [];
}
let resolved = resolveProduct(productId, realProducts);
if (!resolved && siteId) {
  // Preview path: pull product directly from sites service so SSR is complete.
  // Local hostname inside the container; falls back to public gateway in case
  // the block is rendered outside the sites service process.
  try {
    const qs = productId ? `?product=${encodeURIComponent(productId)}` : '';
    const internalBase = (import.meta as unknown as { env?: { SITES_INTERNAL_BASE?: string } }).env?.SITES_INTERNAL_BASE
      ?? 'http://localhost:3114';
    const res = await fetch(`${internalBase}/api/sites/${siteId}/storefront-data${qs}`).catch(() => null);
    if (res && res.ok) {
      const data = (await res.json()) as { product?: RawProduct; products?: RawProduct[] };
      const single = data.product ?? data.products?.[0] ?? null;
      if (single) resolved = single;
    }
  } catch {
    // swallow — fall through to emptyProductView
  }
}
const view: ProductView = resolved
  ? normaliseProduct(resolved, fallbackDescription)
  : emptyProductView(fallbackDescription);

// Brand line — currently sourced from `text` prop (legacy). When the headless
// layer learns to extract brand from the raw product (vendor/category) this
// fallback chain is the single place to change.
const brandText = textContent || view.brand || '';

// — nt-cart SSR payload (declarative `[data-add-to-cart]`). —
// On live SSG the product is resolved server-side, so the add-to-cart button
// ships with real data baked in and works on first paint (before hydration).
// Hydration (inline script below) refreshes these as variant/qty change.
// Default variant = first combination, mirroring the live PDP.
const defaultVariantId = resolved
  ? String(
      resolved.variants?.[0]?.id ??
        resolved.variantCombinations?.[0]?.id ??
        '',
    )
  : '';
const cartProductId = view.id || productId || '';
const cartUnitPrice = view.price.amount > 0 ? Math.round(view.price.amount) : '';
const cartOldPrice = view.hasDiscount ? Math.round(view.oldPrice.amount) : '';
const cartImage = view.gallery.hero?.src ?? '';
---
<section
  class:list={[schemeClass]}
  data-puck-component-id={id}
  data-block="product"
  data-site-id={siteId}
  data-api-base={apiBase}
  data-product-id={view.id || productId}
  data-product-slug={view.slug || productId}
  data-product-handle={view.handle || productId}
  data-zoom-mode={zoomMode}
  style={`background:rgb(var(--color-bg, var(--color-bg)));color:rgb(var(--color-text, var(--color-text)));${paddingStyle}${sizeVarsStyle}`}
>
  {view.jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(view.jsonLd)} />
  )}

  <div class="w-full max-w-[1320px] mx-auto px-4 md:px-6">
    <div
      class:list={[
        'flex flex-col lg:flex-row gap-10 lg:gap-10 items-start',
        photoOnLeft ? '' : 'lg:flex-row-reverse',
      ]}
      data-product-grid
      data-photo-position={photoOnLeft ? 'left' : 'right'}
    >
      {/* MEDIA col. split раздвигается за счёт thumbs+main inline (auto-width).
          Остальные макеты — фикс 652px на desktop (как до 091). */}
      <div class:list={[
        'w-full shrink-0',
        layout === 'split' ? 'lg:w-auto' : 'lg:w-[652px]',
      ]} data-product-images>
        <ProductGallery
          gallery={view.gallery}
          variant={visual.gallery.variant}
          layout={layout}
          photoPosition={photoPosition}
          showDiscountBadge={visual.gallery.showDiscountBadge}
          hasDiscount={view.hasDiscount}
        />
      </div>

      {/* Right: info + variants + actions + description + share. */}
      <div class="flex flex-col gap-10 flex-1 min-w-0 w-full">
        <div
          class="flex flex-col gap-2 w-full"
          data-puck-subsection-parent={id}
          data-puck-subsection-index="100"
          data-puck-subsection-field="info"
        >
          <ProductInfo
            brand={brandText}
            title={view.name || 'Товар'}
            variant="uppercase-title"
          />
          {priceVisible && view.price.formatted && (
            <div
              class="mt-2"
              data-puck-subsection-parent={id}
              data-puck-subsection-index="102"
              data-puck-subsection-field="price"
            >
              <ProductPrice
                price={view.price}
                oldPrice={view.oldPrice}
                hasDiscount={view.hasDiscount}
                variant={visual.gallery.variant === 'inline-small' ? 'spaced' : 'compact'}
              />
            </div>
          )}
        </div>

        {view.hasVariants && view.variantGroups.length > 0 && (
          <div
            data-puck-subsection-parent={id}
            data-puck-subsection-index="103"
            data-puck-subsection-field="variants"
          >
            <ProductVariants
              groups={view.variantGroups}
              type={visual.variantsType}
              style={variantsStyle}
              shape={variantsShape}
            />
          </div>
        )}

        {quantityVisible && (
          <div
            data-puck-subsection-parent={id}
            data-puck-subsection-index="104"
            data-puck-subsection-field="quantity"
          >
            <ProductCounter variant={visual.counter.variant} initialValue={1} />
          </div>
        )}

        <div
          data-puck-subsection-parent={id}
          data-puck-subsection-index="105"
          data-puck-subsection-field="buttons"
        >
          <ProductActions
            addToCartLabel={addBtnText}
            buyNowLabel={buyBtnText}
            size={visual.gallery.variant === 'inline-small' ? 'tall' : 'compact'}
            productId={cartProductId}
            productName={view.name || ''}
            price={cartUnitPrice}
            oldPrice={cartOldPrice}
            image={cartImage}
            variantCombinationId={defaultVariantId}
          />
        </div>

        {visual.showDescription && (view.description || '').trim() && (
          <div
            data-puck-subsection-parent={id}
            data-puck-subsection-index="106"
            data-puck-subsection-field="description"
          >
            <ProductDescription content={view.description} />
          </div>
        )}

        <div
          data-puck-subsection-parent={id}
          data-puck-subsection-index="107"
          data-puck-subsection-field="share"
        >
          <ProductShare label={shareText} />
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ siteId, apiBase, productId }}>
  // Hydration: live SSG already rendered real data via headless normaliser.
  // In preview mode (siteId set) we re-fetch storefront-data and patch DOM
  // through the same primitive selectors. The contract:
  //   data-product-hero            wrapper div for the hero image
  //   data-product-hero-image      <img> inside the hero wrapper
  //   data-product-thumbs          flex container of thumb buttons
  //   data-product-thumb           individual thumb button
  //   data-product-info            brand + title wrapper
  //   data-product-price-current   current price <span>
  //   data-product-price-old       strike-through old price <span>
  //   data-variant-chip / [data-variant-key,value]   chip-style variant button
  //   data-variant-select          <select> dropdown variant
  //   data-counter-action="increment|decrement"   qty buttons
  //   data-counter-value           qty display
  //   data-product-action="add-to-cart|buy-now|share"  CTA + share buttons
  (function () {
    const root = document.querySelector('section[data-block="product"]');
    if (!root) return;

    const heroEl = root.querySelector('[data-product-hero]');
    const heroImg = root.querySelector('[data-product-hero-image]');
    const thumbsEl = root.querySelector('[data-product-thumbs]');
    const titleEl = root.querySelector('[data-product-info] h1');
    const priceCur = root.querySelector('[data-product-price-current]');
    const priceOld = root.querySelector('[data-product-price-old]');
    const counterValEl = root.querySelector('[data-counter-value]');
    const decBtn = root.querySelector('[data-counter-action="decrement"]');
    const incBtn = root.querySelector('[data-counter-action="increment"]');
    const addBtn = root.querySelector('[data-product-action="add-to-cart"]');
    const buyBtn = root.querySelector('[data-product-action="buy-now"]');
    const shareBtn = root.querySelector('[data-product-action="share"]');

    let currentQty = 1;
    let productData = null;
    let selectedOptions = {};

    function escAttr(s) {
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
    function fmtPrice(p) {
      const num = typeof p === 'number' ? p : parseFloat(String(p).replace(/[^\d.,-]/g, '').replace(',', '.'));
      if (!Number.isFinite(num) || num <= 0) return '';
      return Math.round(num).toLocaleString('ru-RU') + ' ₽';
    }
    function findVariantByOptions(variants, sel) {
      const keys = Object.keys(sel);
      if (!keys.length) return null;
      for (const v of variants) {
        if (!v.options) continue;
        let match = true;
        for (const k of keys) {
          if (v.options[k] !== sel[k]) { match = false; break; }
        }
        if (match) return v;
      }
      return null;
    }
    function getProductVariants() {
      if (!productData) return [];
      if (Array.isArray(productData.variants) && productData.variants.length) return productData.variants;
      if (Array.isArray(productData.variantCombinations) && productData.variantCombinations.length) return productData.variantCombinations;
      return [];
    }
    function getActiveVariant() {
      const vs = getProductVariants();
      if (!vs.length) return null;
      if (Object.keys(selectedOptions).length > 0) return findVariantByOptions(vs, selectedOptions);
      return vs[0] || null;
    }
    function getActiveVariantId() {
      const v = getActiveVariant();
      return v ? v.id : null;
    }
    function refreshPriceFromVariant() {
      if (priceCur) {
        const v = getActiveVariant();
        const total = (v && v.price != null ? parseFloat(String(v.price)) : null);
        const base = total != null ? total : (productData ? parseFloat(String(productData.basePrice ?? productData.price ?? 0)) : 0);
        priceCur.textContent = fmtPrice(base * currentQty);
        if (priceOld) {
          const old = productData ? parseFloat(String(productData.compareAtPrice ?? productData.oldPrice ?? 0)) : 0;
          if (old > 0) {
            priceOld.textContent = fmtPrice(old * currentQty);
            priceOld.style.display = '';
          } else {
            priceOld.style.display = 'none';
          }
        }
      }
      // Keep the declarative add-to-cart payload in sync (nt-cart delegate reads
      // it on click). Runs even when price is hidden — `if (priceCur)` only
      // guards the price DOM update, not the cart contract.
      updateCartAttrs();
    }

    // Sync the add-to-cart button's data-* with the active variant + quantity so
    // the theme's `[data-add-to-cart]` delegate (and Buy Now, which reads them)
    // always get the current line. Mirrors how the live PDP populates the same
    // attributes. Unit price (not ×qty): nt-cart multiplies by data-quantity.
    function updateCartAttrs() {
      if (!addBtn) return;
      const v = getActiveVariant();
      let unit = (v && v.price != null) ? parseFloat(String(v.price))
        : (productData ? parseFloat(String(productData.basePrice ?? productData.price ?? 0)) : 0);
      if (!Number.isFinite(unit) || unit < 0) unit = 0;
      const old = productData ? parseFloat(String(productData.compareAtPrice ?? productData.oldPrice ?? 0)) : 0;
      const pid = (productData && productData.id) || root.getAttribute('data-product-id') || productId || '';
      const name = (productData && (productData.name || productData.title)) || (titleEl ? titleEl.textContent : '') || '';
      const heroSrc = (heroImg && heroImg.getAttribute('src')) || '';
      if (pid) addBtn.setAttribute('data-product-id', pid);
      if (name) addBtn.setAttribute('data-name', name);
      addBtn.setAttribute('data-price', String(Math.round(unit)));
      if (Number.isFinite(old) && old > 0) addBtn.setAttribute('data-old-price', String(Math.round(old)));
      else addBtn.removeAttribute('data-old-price');
      if (heroSrc) addBtn.setAttribute('data-image', heroSrc);
      addBtn.setAttribute('data-quantity', String(currentQty));
      const vid = getActiveVariantId();
      if (vid) addBtn.setAttribute('data-variant-combination-id', vid);
      else addBtn.removeAttribute('data-variant-combination-id');
      // Map selected options → color/size (nt-cart line label + identity).
      let col = '', sz = '';
      for (const k in selectedOptions) {
        const kl = k.toLowerCase();
        if (kl === 'цвет' || kl === 'color') col = selectedOptions[k];
        else if (kl === 'размер' || kl === 'size') sz = selectedOptions[k];
      }
      if (col) addBtn.setAttribute('data-variant-color', col); else addBtn.removeAttribute('data-variant-color');
      if (sz) addBtn.setAttribute('data-variant-size', sz); else addBtn.removeAttribute('data-variant-size');
    }

    // Apply product (preview re-render). Assumes primitive structure exists.
    function applyProduct(p) {
      if (!p) return;
      productData = p;
      const imgs = (Array.isArray(p.images) ? p.images : [])
        .map((it) => (typeof it === 'string' ? it : (it && it.url) || null))
        .filter(Boolean);
      const heroSrc = imgs[0] || null;
      if (heroSrc && heroImg) {
        heroImg.setAttribute('src', heroSrc);
        heroImg.setAttribute('alt', p.title || p.name || '');
      }
      if (titleEl) titleEl.textContent = p.title || p.name || '';
      refreshPriceFromVariant();
    }

    // Thumb click → swap hero src.
    if (thumbsEl) {
      thumbsEl.addEventListener('click', function (ev) {
        const btn = ev.target && ev.target.closest('[data-product-thumb]');
        if (!btn) return;
        const img = btn.querySelector('img');
        if (img && heroImg) heroImg.setAttribute('src', img.getAttribute('src') || '');
      });
    }

    // Variant chip select. Active chip uses primaryButton tokens; inactive
    // uses secondaryButton tokens. Both are scheme-driven via CSS vars.
    var ACTIVE_CHIP_STYLE =
      'background:rgb(var(--color-button-bg, var(--color-text))); color:rgb(var(--color-button-text, var(--color-bg))); border-color:rgb(var(--color-button-border, var(--color-text)));';
    var INACTIVE_CHIP_STYLE =
      'background:rgb(var(--color-button-secondary-bg, var(--color-bg))); color:rgb(var(--color-button-secondary-text, var(--color-text))); border-color:rgb(var(--color-button-secondary-border, var(--color-text)));';
    // Свотч-чипы (форма circle/square + цвет): заливка живёт на внутреннем
    // [data-variant-swatch-fill], поэтому на click меняем ТОЛЬКО border-color
    // обводки — иначе фон кнопки перетёр бы цветную заливку. Зеркалит
    // swatchBorderStyle() из ProductVariants.astro.
    var ACTIVE_SWATCH_STYLE = 'border-color:rgb(var(--color-button-bg, var(--color-text)));';
    var INACTIVE_SWATCH_STYLE = 'border-color:rgb(var(--color-text)/0.2);';
    root.addEventListener('click', function (ev) {
      const chip = ev.target && ev.target.closest && ev.target.closest('[data-variant-chip]');
      if (!chip || chip.getAttribute('data-variant-available') === 'false') return;
      const key = chip.getAttribute('data-variant-key');
      const val = chip.getAttribute('data-variant-value');
      if (!key || val == null) return;
      selectedOptions[key] = val;
      root.querySelectorAll('[data-variant-chip][data-variant-key="' + key + '"]').forEach(function (c) {
        const isActive = c === chip;
        c.setAttribute('data-variant-active', isActive ? 'true' : 'false');
        if (c.getAttribute('data-variant-available') === 'false') return;
        var isSwatch = c.hasAttribute('data-variant-swatch');
        c.setAttribute(
          'style',
          isSwatch
            ? (isActive ? ACTIVE_SWATCH_STYLE : INACTIVE_SWATCH_STYLE)
            : (isActive ? ACTIVE_CHIP_STYLE : INACTIVE_CHIP_STYLE),
        );
      });
      refreshPriceFromVariant();
    });

    // Variant dropdown select.
    root.querySelectorAll('[data-variant-select]').forEach(function (sel) {
      sel.addEventListener('change', function () {
        const key = sel.getAttribute('data-variant-key');
        if (key) selectedOptions[key] = sel.value;
        refreshPriceFromVariant();
      });
    });

    // Counter +/-.
    if (decBtn && counterValEl) {
      decBtn.addEventListener('click', function (ev) {
        ev.stopPropagation();
        if (currentQty > 1) currentQty--;
        counterValEl.textContent = String(currentQty);
        refreshPriceFromVariant();
      }, true);
    }
    if (incBtn && counterValEl) {
      incBtn.addEventListener('click', function (ev) {
        ev.stopPropagation();
        currentQty++;
        counterValEl.textContent = String(currentQty);
        refreshPriceFromVariant();
      }, true);
    }

    // Add to cart — declarative, unified with the product group + live PDP.
    // The button carries `data-add-to-cart` + nt-cart data-* (kept current by
    // updateCartAttrs). The theme's global delegate (rose: nt-cart-rose.ts via
    // initCartUI) handles the click: writes the line into `<theme>:cart:v1`,
    // opens the drawer, updates the badge. No window.cartStore here — storefront
    // Layouts don't load cart-store.js, so that global is undefined on storefront
    // pages, which is exactly why the old direct call silently no-oped.

    // Buy now — express checkout, mirroring the live PDP. Writes ONLY the clicked
    // product to sessionStorage `<theme>:buynow` (theme from the build-injected
    // window.__MERFY_THEME__) and navigates to a clean /checkout, which reads that
    // key and builds a cart from just this item; the shopper's nt-cart is left
    // untouched. In the constructor preview iframe the hard nav is replaced by a
    // postMessage the nav-agent intercepts.
    if (buyBtn) {
      buyBtn.addEventListener('click', function (ev) {
        ev.stopPropagation();
        ev.preventDefault();
        if (buyBtn.disabled) return;
        updateCartAttrs();
        const pid = (addBtn && addBtn.getAttribute('data-product-id')) || root.getAttribute('data-product-id') || productId || '';
        if (!pid) return;
        const vci = (addBtn && addBtn.getAttribute('data-variant-combination-id')) || getActiveVariantId() || '';
        const inIframe = window.parent && window.parent !== window;
        if (inIframe) {
          // Constructor preview: hand the express item to the checkout via
          // sessionStorage (NOT the cart). «Купить сейчас» must NOT add the item to
          // the visible preview cart/badge — mirroring live, where express goes via
          // sessionStorage and leaves the cart untouched. The preview cart store
          // seeds this item for display ONLY on the checkout page and clears it on
          // leaving (see PREVIEW_CART_STORE_INLINE). Navigate via the nav-agent.
          try {
            sessionStorage.setItem('__mfy_pv_express', JSON.stringify({ productId: pid, variantCombinationId: vci || null, quantity: currentQty }));
          } catch (e) { /* sessionStorage unavailable — silent */ }
          try { window.parent.postMessage({ type: 'navigate', path: '/checkout' }, '*'); } catch (e) { /* cross-origin — silent */ }
          return;
        }
        const themeKey = (window.__MERFY_THEME__ || '').trim();
        try {
          if (themeKey) {
            sessionStorage.setItem(
              themeKey + ':buynow',
              JSON.stringify({ productId: pid, variantCombinationId: vci || null, quantity: currentQty }),
            );
          }
        } catch (e) { /* sessionStorage unavailable — checkout falls back to cart */ }
        window.location.href = '/checkout';
      }, true);
    }

    // Share.
    if (shareBtn) {
      shareBtn.addEventListener('click', function () {
        const url = window.location.href;
        const title = titleEl ? titleEl.textContent : '';
        const span = shareBtn.querySelector('span');
        const orig = span ? span.textContent : '';
        if (navigator.share) {
          navigator.share({ title: title, url: url }).catch(function () {});
        } else if (navigator.clipboard) {
          navigator.clipboard.writeText(url);
          if (span) {
            span.textContent = 'Ссылка скопирована!';
            setTimeout(function () { span.textContent = orig; }, 1500);
          }
        }
      });
    }

    // Увеличение фото товара. Управляется data-zoom-mode на root section:
    //   - 'hover' — tracking zoom: scale 2x + transform-origin перемещается
    //                 за курсором по площади фото.
    //   - 'click' — lightbox popup: фото на полный экран + лента thumbs.
    //   - 'none'  — поведение отключено.
    const zoomMode = root.getAttribute('data-zoom-mode') || 'hover';

    if (heroEl && heroImg && zoomMode === 'hover') {
      heroImg.style.transition = 'transform 0.2s ease, transform-origin 0.05s linear';
      heroEl.style.cursor = 'zoom-in';
      heroEl.addEventListener('mouseenter', function () {
        heroImg.style.transform = 'scale(2)';
      });
      heroEl.addEventListener('mousemove', function (e) {
        const rect = heroEl.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        heroImg.style.transformOrigin = x + '% ' + y + '%';
      });
      heroEl.addEventListener('mouseleave', function () {
        heroImg.style.transform = '';
        heroImg.style.transformOrigin = '';
      });
    }

    if (heroEl && heroImg && zoomMode === 'click') {
      heroEl.style.cursor = 'zoom-in';
      heroEl.addEventListener('click', function () {
        openLightbox();
      });
    }

    // Lightbox: full-screen popup с большим фото + thumb-полосой.
    // Создаётся лениво при первом click (zoomMode='click').
    function openLightbox() {
      // Собираем все URL фотографий (hero + thumbs).
      const urls = [];
      if (heroImg && heroImg.getAttribute('src')) {
        urls.push(heroImg.getAttribute('src'));
      }
      const thumbImgs = root.querySelectorAll('[data-product-thumb] img');
      thumbImgs.forEach(function (img) {
        const src = img.getAttribute('src');
        if (src && urls.indexOf(src) === -1) urls.push(src);
      });
      if (urls.length === 0) return;

      let activeIdx = 0;

      const overlay = document.createElement('div');
      overlay.setAttribute('data-product-lightbox', '');
      overlay.style.cssText = [
        'position:fixed', 'inset:0', 'z-index:100',
        'background:rgba(0,0,0,0.92)',
        'display:flex', 'flex-direction:column',
        'align-items:center', 'justify-content:center',
        'padding:32px', 'gap:16px',
        'animation:merfy-lightbox-fade 0.15s ease-out',
      ].join(';');

      const closeBtn = document.createElement('button');
      closeBtn.setAttribute('type', 'button');
      closeBtn.setAttribute('aria-label', 'Закрыть');
      closeBtn.style.cssText = [
        'position:absolute', 'top:16px', 'right:16px',
        'width:40px', 'height:40px', 'border:none',
        'background:rgba(255,255,255,0.1)', 'color:#fff',
        'border-radius:50%', 'cursor:pointer',
        'font-size:24px', 'line-height:1',
        'display:flex', 'align-items:center', 'justify-content:center',
      ].join(';');
      closeBtn.innerHTML = '×';
      overlay.appendChild(closeBtn);

      const mainImg = document.createElement('img');
      mainImg.style.cssText = [
        'max-width:100%', 'max-height:calc(100vh - 200px)',
        'object-fit:contain', 'display:block',
        'border-radius:8px',
      ].join(';');
      mainImg.src = urls[0];
      overlay.appendChild(mainImg);

      const strip = document.createElement('div');
      strip.style.cssText = [
        'display:flex', 'gap:8px',
        'overflow-x:auto', 'max-width:100%',
        'padding:8px',
      ].join(';');

      const thumbBtns = urls.map(function (url, idx) {
        const btn = document.createElement('button');
        btn.setAttribute('type', 'button');
        btn.style.cssText = [
          'width:80px', 'height:80px', 'flex-shrink:0',
          'border:2px solid ' + (idx === 0 ? '#fff' : 'transparent'),
          'border-radius:6px', 'overflow:hidden',
          'cursor:pointer', 'padding:0', 'background:transparent',
          'transition:border-color 0.15s',
        ].join(';');
        const img = document.createElement('img');
        img.src = url;
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
        btn.appendChild(img);
        btn.addEventListener('click', function () {
          activeIdx = idx;
          mainImg.src = url;
          thumbBtns.forEach(function (b, i) {
            b.style.borderColor = i === idx ? '#fff' : 'transparent';
          });
        });
        strip.appendChild(btn);
        return btn;
      });

      overlay.appendChild(strip);

      function close() {
        overlay.remove();
        document.removeEventListener('keydown', onKey);
      }

      function onKey(e) {
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowRight' && activeIdx < urls.length - 1) {
          activeIdx++;
          mainImg.src = urls[activeIdx];
          thumbBtns.forEach(function (b, i) {
            b.style.borderColor = i === activeIdx ? '#fff' : 'transparent';
          });
        }
        if (e.key === 'ArrowLeft' && activeIdx > 0) {
          activeIdx--;
          mainImg.src = urls[activeIdx];
          thumbBtns.forEach(function (b, i) {
            b.style.borderColor = i === activeIdx ? '#fff' : 'transparent';
          });
        }
      }

      closeBtn.addEventListener('click', close);
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) close();
      });
      document.addEventListener('keydown', onKey);

      document.body.appendChild(overlay);
    }

    // Initial hydration.
    function initFromGlobalProducts() {
      try {
        const slug = root.getAttribute('data-product-slug') || productId;
        const fromGlobal = (window.__MERFY_PRODUCTS__ || []).find((p) =>
          p && (p.slug === slug || p.handle === slug || p.id === slug),
        );
        if (fromGlobal) applyProduct(fromGlobal);
      } catch {}
    }
    initFromGlobalProducts();

    if (siteId) {
      const qs = productId ? '?product=' + encodeURIComponent(productId) : '';
      fetch(apiBase + '/sites/' + siteId + '/storefront-data' + qs, { credentials: 'omit' })
        .catch(() => null)
        .then((r) => (r && r.ok ? r.json() : null))
        .then((data) => {
          if (!data) return;
          const single = data.product;
          const list = data.products || (data.data && data.data.products) || [];
          applyProduct(single || list[0]);
        })
        .catch(() => {});
    }
  })();
</script>
