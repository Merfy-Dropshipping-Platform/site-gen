---
import type { HeroProps } from './Hero.puckConfig';
import { HeroClasses as C } from './Hero.classes';

interface Props extends HeroProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  title,
  subtitle,
  image,
  images,
  cta,
  variant: variantProp,
  colorScheme = 1,
  padding,
  size,
  overlay: overlayRaw,
} = raw as Props & {
  size?: 'small' | 'medium' | 'large';
  overlay?: number;
  [k: string]: unknown;
};

// Legacy constructor schema passes heading/text as nested objects (heading.text, text.content)
// plus backgroundImage + primaryButton.link.href. Normalise both shapes so any revision works.
const heading = raw.heading as { text?: string } | string | undefined;
const textObj = raw.text as { content?: string } | string | undefined;
const primaryButton = raw.primaryButton as
  | { text?: string; link?: { href?: string } | string }
  | undefined;
const backgroundImage = typeof raw.backgroundImage === 'string' ? raw.backgroundImage : '';

const resolvedTitle =
  (typeof title === 'string' && title) ||
  (typeof heading === 'string' ? heading : heading?.text) ||
  '';
const resolvedSubtitle =
  (typeof subtitle === 'string' && subtitle) ||
  (typeof textObj === 'string' ? textObj : textObj?.content) ||
  '';
const primaryLink = typeof primaryButton?.link === 'object'
  ? primaryButton.link?.href
  : primaryButton?.link;
const resolvedCta = cta ?? (primaryButton?.text
  ? { text: primaryButton.text, href: primaryLink ?? '#' }
  : undefined);

// Determine variant: explicit prop wins, else if any background image → overlay.
const variant = (variantProp as HeroProps['variant'])
  ?? (backgroundImage ? 'overlay' : 'centered');

const schemeNum = (() => {
  if (typeof colorScheme === 'number') return colorScheme;
  const m = String(colorScheme).match(/(\d+)/);
  return m ? Number(m[1]) : 1;
})();
const scheme = `color-scheme-${schemeNum}`;
const innerClass = C.inner[variant];
const imageClass = C.image[variant];
const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';

// Hero min-height by size, matching 072 live templates.
const heightVars = {
  small:  '--h-base:280px;--h-sm:320px;--h-md:360px;--h-lg:400px;--h-xl:440px;--h-xxl:480px;',
  medium: '--h-base:340px;--h-sm:400px;--h-md:480px;--h-lg:560px;--h-xl:640px;--h-xxl:720px;',
  large:  '--h-base:400px;--h-sm:500px;--h-md:600px;--h-lg:700px;--h-xl:800px;--h-xxl:1080px;',
}[size ?? 'medium'];

const overlayPct = typeof overlayRaw === 'number' ? overlayRaw / 100 : 0.3;
const overlayStyle = `background-color: rgb(var(--color-foreground) / ${overlayPct});`;

// Normalise image reference across shapes preview coercer may pass through.
const imageUrlFromObj =
  typeof image === 'string'
    ? image
    : image && typeof (image as { url?: unknown }).url === 'string'
      ? (image as { url: string }).url
      : '';
const imageUrl = imageUrlFromObj || backgroundImage;
const imageAlt =
  image && typeof (image as { alt?: unknown }).alt === 'string'
    ? (image as { alt: string }).alt
    : '';

// grid-4: take up to 4 images from `images[]`; fall back to duplicating the
// single `image` prop so previews never look broken before the merchant
// configures all 4 slots.
type ImageShape = { url: string; alt: string };
const gridFallback: ImageShape = { url: imageUrl, alt: imageAlt };
const gridImages: ImageShape[] =
  variant === 'grid-4'
    ? (Array.isArray(images) && images.length > 0
        ? images.slice(0, 4).map((i) => ({
            url: typeof i === 'string' ? i : ((i as ImageShape)?.url ?? ''),
            alt: typeof i === 'string' ? '' : ((i as ImageShape)?.alt ?? ''),
          }))
        : [gridFallback, gridFallback, gridFallback, gridFallback])
    : [];
// Pad to exactly 4 tiles (empty tiles render as placeholder background)
while (gridImages.length < 4 && variant === 'grid-4') {
  gridImages.push(gridFallback);
}
---
<section
  class:list={[C.root, scheme, variant === 'overlay' ? 'min-h-[var(--h-base)] sm:min-h-[var(--h-sm)] md:min-h-[var(--h-md)] lg:min-h-[var(--h-lg)] xl:min-h-[var(--h-xl)] 2xl:min-h-[var(--h-xxl)]' : '']}
  data-puck-component-id={id}
  data-variant={variant}
  style={`${paddingStyle} ${variant === 'overlay' ? heightVars : ''}`}
>
  {variant === 'overlay' && imageUrl && (
    <>
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat"
        style={`background-image: url('${imageUrl}');`}
        aria-hidden="true"
      />
      <div class="absolute inset-0" style={overlayStyle} aria-hidden="true" />
    </>
  )}
  {variant !== 'overlay' && variant !== 'grid-4' && imageUrl && (
    <img src={imageUrl} alt={imageAlt} class={imageClass} />
  )}
  <div class:list={[C.container, innerClass, 'relative z-10']} style="min-height: inherit;">
    <div class="flex flex-col items-center text-center gap-4 sm:gap-5 md:gap-6 lg:gap-5 xl:gap-[25px] w-full max-w-7xl px-4 sm:px-6 md:px-8">
      <header class="flex flex-col gap-1 sm:gap-2 md:gap-3 lg:gap-4 xl:gap-[5px]">
        {resolvedTitle && <h1 class={C.title}>{resolvedTitle}</h1>}
        {resolvedSubtitle && <p class={C.subtitle}>{resolvedSubtitle}</p>}
      </header>
      {variant === 'grid-4' && (
        <div class={C.gridContainer} role="group" aria-label="Hero image grid">
          {gridImages.map((img, i) => (
            <div class={C.gridTile}>
              {img.url ? (
                <img
                  src={img.url}
                  alt={img.alt || `Hero image ${i + 1}`}
                  class="absolute inset-0 w-full h-full object-cover"
                  loading={i < 2 ? 'eager' : 'lazy'}
                />
              ) : (
                <span class="sr-only">Пустой слот изображения</span>
              )}
            </div>
          ))}
        </div>
      )}
      {resolvedCta?.text && (
        <div class="flex flex-wrap gap-[25px]">
          <a href={resolvedCta.href} class={C.ctaButton}>{resolvedCta.text}</a>
        </div>
      )}
    </div>
  </div>
</section>
