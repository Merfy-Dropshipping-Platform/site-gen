---
import NtSectionHeading from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtSectionHeading.astro";
import RoseProductCard from "../products/RoseProductCard.astro";
import { catalogProducts } from "../../data/products";

// ОЖИВЛЕНИЕ: конструкторная схема PopularProducts (heading/subtitle union). Тело + данные verbatim.
// T13: полная канон-схема (cards/columns/headingSize/textSize/imageView/nextPhotoOnHover/
// quickAddMode/quickAddText/buttonStyle/viewAll/padding). Дефолтные ветки тернарников =
// прежние строки байт-в-байт; канон-дефолты конструктора (small/small/square/none/4) и
// впрыск коэрсера cards=4/columns=4 → пиксель верстальщика (прецедент T11 'center').
const p = Astro.props as Record<string, any>;
const id = p.id;
const sectionTitle = p.heading?.text ?? p.heading ?? "Главные хиты";
const sectionSubtitle =
	p.text?.content ?? p.subtitle?.content ?? p.subtitle ?? "Найдите стиль на каждый случай — коллекции, которые помогают выразить себя вне времени и трендов.";

// Канон cards 2-24: лимит среза demo-витрины и гидрации (data-cards на гриде).
// 4 = срез верстальщика (и впрыск коэрсера при отсутствии) → дефолт-ветка.
const cardsN = typeof p.cards === "number" && p.cards > 0 ? Math.max(1, Math.min(24, Math.round(p.cards))) : 4;
const products = catalogProducts.slice(0, cardsN);

// Канон headingSize (top-level приоритетнее legacy heading.size): 'small'
// (canon-default) и отсутствие = NtSectionHeading верстальщика дословно (20px);
// medium → 24px, large → 29px (≈канонный ряд small 20 / medium 24, окр. до px).
const headingSize = p.headingSize ?? p.heading?.size;
const headingSizeCls =
	headingSize === "medium"
		? " [&_h2]:!text-[24px]"
		: headingSize === "large"
			? " [&_h2]:!text-[29px]"
			: "";
// Канон textSize (top-level приоритетнее legacy text.size): 'small' (canon-default)
// и отсутствие = 16px верстальщика; medium → 19px, large → 23px.
const textSize = p.textSize ?? p.text?.size;
const textSizeCls =
	textSize === "medium"
		? " [&_p]:!text-[19px]"
		: textSize === "large"
			? " [&_p]:!text-[23px]"
			: "";
const headWrapCls = `flex w-full justify-center${headingSizeCls}${textSizeCls}`;

// Канон columns 1-6: 4 (canon-default = xl:grid-cols-4 верстальщика, впрыск коэрсера)
// и отсутствие → дефолт-ветка; иное → inline-var, действует с lg (мобильная лестница
// верстальщика 2→3 сохраняется).
const colsRaw = typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : undefined;
const cols = colsRaw && colsRaw !== 4 ? colsRaw : undefined;
// Канон imageView square/portrait/wide (+legacy alias adaptive→wide): 'square'
// (canon-default) и отсутствие = литерал верстальщика 318/444 байт-в-байт;
// portrait → 430/500 (канонный портрет), wide → 16/9.
const tileAspectCls =
	p.imageView === "portrait"
		? " [&_li>article>a]:aspect-[430/500]"
		: p.imageView === "wide" || p.imageView === "adaptive"
			? " [&_li>article>a]:aspect-[16/9]"
			: "";
const gridBase =
	"grid w-full grid-cols-2 gap-x-3 gap-y-8 sm:gap-x-4 sm:gap-y-9 md:grid-cols-3 md:gap-x-4 md:gap-y-10 xl:grid-cols-4 xl:gap-x-5";
const gridCls =
	(cols
		? "grid w-full grid-cols-2 gap-x-3 gap-y-8 sm:gap-x-4 sm:gap-y-9 md:grid-cols-3 md:gap-x-4 md:gap-y-10 lg:grid-cols-[repeat(var(--cols),minmax(0,1fr))] xl:grid-cols-[repeat(var(--cols),minmax(0,1fr))] xl:gap-x-5"
		: gridBase) + tileAspectCls;
const gridStyle = cols ? `--cols:${cols}` : undefined;

// Канон quickAddMode none/standard/cart (+legacy alias count→cart): кнопка
// быстрого добавления на карточке (в манере — появляется при hover, в потоке под
// ценой как канон). Клик → механика rose:cart: глобальный обработчик
// [data-add-to-cart] (initCartUI, lib/nt-cart-rose.ts) добавляет строку и
// открывает drawer. Для реальных товаров с вариантами добавление без выбора
// варианта невозможно — кнопка ведёт на страницу товара (фиксация решения).
const qaModeRaw = p.quickAddMode === "count" ? "cart" : p.quickAddMode;
const quickAddMode = qaModeRaw === "standard" || qaModeRaw === "cart" ? qaModeRaw : undefined;
// Канон quickAddText (default 'В КОРЗИНУ'); без него standard → 'В корзину' (как канон).
const quickAddText =
	(typeof p.quickAddText === "string" && p.quickAddText) ||
	(quickAddMode === "cart" ? "В КОРЗИНУ" : "В корзину");
// Канон buttonStyle link/primary/secondary — стиль кнопки карточки (носитель в rose
// появляется только вместе с quickAdd): primary/отсутствие = кнопка-1, secondary =
// кнопка-2 (манерный образец «Добавить в корзину» PDP), link = текстовая ссылка.
const quickAddCls =
	p.buttonStyle === "secondary"
		? "mt-3 inline-flex h-10 w-full items-center justify-center rounded-[var(--radius-button,6px)] border border-solid border-[rgb(var(--color-button-2-border,0_0_0))] !bg-[rgb(var(--color-button-2-bg,255_255_255))] px-4 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-button-2-text,0_0_0))] opacity-0 transition-opacity hover:opacity-90 focus-visible:opacity-100 group-hover:opacity-100"
		: p.buttonStyle === "link"
			? "mt-3 inline-flex h-10 w-full items-center justify-center px-4 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-text,0_0_0))] underline underline-offset-4 opacity-0 transition-opacity hover:opacity-70 focus-visible:opacity-100 group-hover:opacity-100"
			: "mt-3 inline-flex h-10 w-full items-center justify-center rounded-[var(--radius-button,6px)] !border-0 !bg-[rgb(var(--color-button-bg,0_0_0))] px-4 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-button-text,255_255_255))] opacity-0 transition-opacity hover:opacity-90 focus-visible:opacity-100 group-hover:opacity-100";

// Канон nextPhotoOnHover (toggle, true/'true'): смена фото на вторую картинку
// товара при наведении. Носитель данных: data-image-2 на <li> (demo — gallery[1]
// верстальщика; реальные товары — images[1] из products.json, ставит гидрация).
const nextPhoto = p.nextPhotoOnHover === true || p.nextPhotoOnHover === "true";
// is:inline + set:html (без define:vars — компилятор секций его не умеет);
// идемпотентность data-np-hydrated; без data-image-2 скрипт — no-op без ошибок.
const NEXT_PHOTO_JS = [
	"(function(){",
	"var grids=document.querySelectorAll('[data-nt=\"popular-grid\"][data-next-photo]');",
	"for(var i=0;i<grids.length;i++){(function(g){",
	"if(g.getAttribute('data-np-hydrated')==='true')return;",
	"g.setAttribute('data-np-hydrated','true');",
	"function swap(li,on){",
	"var u=on?li.getAttribute('data-image-2'):null;",
	"var im=li.querySelectorAll('img');",
	"for(var j=0;j<im.length;j++){",
	"if(on){if(!im[j].getAttribute('data-image-1'))im[j].setAttribute('data-image-1',im[j].getAttribute('src')||'');im[j].setAttribute('src',u);}",
	"else{var s1=im[j].getAttribute('data-image-1');if(s1)im[j].setAttribute('src',s1);}",
	"}",
	"var so=li.querySelectorAll('source');",
	"for(var k=0;k<so.length;k++){",
	"if(on){if(!so[k].getAttribute('data-srcset-1'))so[k].setAttribute('data-srcset-1',so[k].getAttribute('srcset')||'');so[k].setAttribute('srcset',u);}",
	"else{var ss=so[k].getAttribute('data-srcset-1');if(ss)so[k].setAttribute('srcset',ss);}",
	"}",
	"}",
	"g.addEventListener('mouseover',function(e){",
	"var t=e.target;if(!t||!t.closest)return;",
	"var li=t.closest('li[data-image-2]');",
	"if(!li||!g.contains(li)||li.getAttribute('data-np-on')==='true')return;",
	"li.setAttribute('data-np-on','true');swap(li,true);",
	"});",
	"g.addEventListener('mouseout',function(e){",
	"var t=e.target;if(!t||!t.closest)return;",
	"var li=t.closest('li[data-image-2]');",
	"if(!li||li.getAttribute('data-np-on')!=='true')return;",
	"var to=e.relatedTarget;if(to&&li.contains(to))return;",
	"li.setAttribute('data-np-on','false');swap(li,false);",
	"});",
	"})(grids[i]);}",
	"})();",
].join("");

// Канон viewAll {show,text,href} (+legacy true/'true'): кнопка под гридом,
// манера — вторичная кнопка (классы = secondaryButton Hero T11), дефолты канона
// 'Смотреть ещё' / '/catalog'.
const viewAllRaw = p.viewAll;
const viewAllShow =
	viewAllRaw === true ||
	viewAllRaw === "true" ||
	(!!viewAllRaw &&
		typeof viewAllRaw === "object" &&
		(viewAllRaw.show === true || viewAllRaw.show === "true"));
const viewAllText =
	(!!viewAllRaw && typeof viewAllRaw === "object" && typeof viewAllRaw.text === "string" && viewAllRaw.text) ||
	"Смотреть ещё";
const viewAllHref =
	(!!viewAllRaw && typeof viewAllRaw === "object" && typeof viewAllRaw.href === "string" && viewAllRaw.href) ||
	"/catalog";

// Канон collection (collectionPicker, id или slug): носитель — data-collection
// на гриде; фильтрацию делает гидрация (filterByCollection: productIds коллекции
// → membership товара → все, паритет theme-base). Demo-сборка без данных — no-op.
const collectionRef =
	typeof p.collection === "string" && p.collection.trim() ? p.collection.trim() : undefined;

// Контейнер-подложка (toggle containerEnabled + containerColorScheme), паттерн
// CollapsibleSection / Figma 314-35006: включён → обёртка-поверхность вокруг
// контента блока (radius, surface, внутренние паддинги) + отдельная цв. схема
// контейнера. Основная (секционная) схема остаётся на <section>.
const containerEnabled = String(p.containerEnabled ?? "false") === "true";
const containerSchemeCls =
	typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";
const containerWrapCls = containerEnabled
	? `flex w-full flex-col gap-8 md:gap-10 rounded-[var(--radius-card,8px)] bg-[rgb(var(--color-surface,245_245_245))] p-6 md:p-10${containerSchemeCls}`
	: `flex w-full flex-col gap-8 md:gap-10${containerSchemeCls}`;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id="popular"
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-14 pt-14 sm:px-5 sm:pb-16 sm:pt-16 md:px-10 md:pb-[100px] md:pt-[100px] lg:px-16 lg:pb-[120px] lg:pt-[120px] xl:px-20 xl:pb-[140px] xl:pt-[140px] 2xl:px-[280px]"
	aria-labelledby="popular-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto w-full max-w-[1320px]">
		<div class={containerWrapCls}>
		<div class={headWrapCls} data-animate data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">
			<NtSectionHeading variant="rose" titleId="popular-title" title={sectionTitle} subtitle={sectionSubtitle} />
		</div>

		<ul
			data-animate
			data-animate-delay="0.1s"
			class={gridCls}
			role="list"
			data-nt="popular-grid"
			style={gridStyle}
			data-cards={cardsN !== 4 ? String(cardsN) : undefined}
			data-collection={collectionRef}
			data-next-photo={nextPhoto ? "true" : undefined}
			data-quick-add={quickAddMode}
			data-qa-text={quickAddMode ? quickAddText : undefined}
			data-qa-class={quickAddMode ? quickAddCls : undefined}
		>
			{products.map((product) => (
				<li data-product-id={product.id} class:list={quickAddMode ? ["group"] : undefined} data-image-2={nextPhoto ? product.gallery?.[1] : undefined}>
					<RoseProductCard product={product} />{quickAddMode && (
						<button
							type="button"
							data-add-to-cart
							data-product-id={product.id}
							data-name={product.name}
							data-price={product.price}
							data-old-price={product.oldPrice}
							data-image={product.image}
							class={quickAddCls}
						>
							{quickAddText}
						</button>
					)}
				</li>
			))}
		</ul>{viewAllShow && (
			<div class="flex w-full justify-center">
				<a
					href={viewAllHref}
					class="inline-flex h-10 min-h-10 w-auto min-w-[120px] items-center justify-center rounded border border-solid border-[rgb(var(--color-button-2-border,0_0_0))] !bg-[rgb(var(--color-button-2-bg,255_255_255))] px-3 py-2.5 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-button-2-text,0_0_0))] transition-opacity hover:opacity-90 sm:h-[52px] sm:min-h-[52px] sm:min-w-[160px] sm:rounded-[var(--radius-button,6px)] sm:px-6 sm:py-[10px] sm:text-[15px] md:text-[16px]"
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="viewAll"
				>
					{viewAllText}
				</a>
			</div>
		)}
		</div>
	</div>
</section>{nextPhoto && <script is:inline set:html={NEXT_PHOTO_JS} />}

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		resolveCollectionProducts,
		renderCardHtml,
		escapeHtml,
		productHref,
		productImage,
	} from "../../lib/storefront-hydrate";

	// Реальные товары (Option B): первые N из /data/products.json (N = data-cards
	// грида, дефолт 4 — поведение верстальщика). Demo-сборка → no-op. Канон-поля
	// T13 поверх: data-quick-add/-qa-text/-qa-class → кнопка на гидрированной
	// карточке (товары с вариантами → ссылка на PDP), data-next-photo → data-image-2
	// (вторая картинка товара) для hover-скрипта, data-collection → фильтр по
	// выбранной в конструкторе коллекции (раньше настройка игнорировалась).
	const hydratePopular = async () => {
		const grids = Array.from(document.querySelectorAll<HTMLElement>('[data-nt="popular-grid"]'));
		if (grids.length === 0) return;
		const products = await loadRealProducts();
		if (!products) return;
		const needCollections = grids.some((g) => g.getAttribute("data-collection"));
		const collections = needCollections ? await loadRealCollections() : null;
		for (const grid of grids) {
			const collectionRef = grid.getAttribute("data-collection");
			// Shopify-модель: без явно выбранной коллекции секция оставляет
			// SSR-моки (demo), а не подтягивает весь каталог магазина.
			if (!collectionRef) continue;
			const matched = resolveCollectionProducts(products, collections, collectionRef);
			// Коллекция пуста / не найдена → тоже оставляем моки.
			if (matched.length === 0) continue;
			const limitRaw = Number(grid.getAttribute("data-cards"));
			const limit = Number.isFinite(limitRaw) && limitRaw > 0 ? limitRaw : 4;
			const quickAdd = grid.getAttribute("data-quick-add");
			const qaText = grid.getAttribute("data-qa-text") || "В корзину";
			const qaClass = grid.getAttribute("data-qa-class") || "";
			const wantNextPhoto = grid.hasAttribute("data-next-photo");
			const items = matched.slice(0, limit);
			grid.innerHTML = items
				.map((p) => {
					const img2 =
						wantNextPhoto && Array.isArray(p.images) && p.images[1]
							? ` data-image-2="${escapeHtml(p.images[1])}"`
							: "";
					const liClass = quickAdd ? ' class="group"' : "";
					const hasVariants =
						p.hasVariants === true ||
						(Array.isArray(p.variantCombinations) && p.variantCombinations.length > 0);
					const qaBtn = quickAdd
						? hasVariants
							? `<a href="${escapeHtml(productHref(p))}" class="${qaClass}">${escapeHtml(qaText)}</a>`
							: `<button type="button" data-add-to-cart data-product-id="${escapeHtml(p.id)}" data-name="${escapeHtml(p.name)}" data-price="${escapeHtml(String(p.price))}"${p.oldPrice || p.compareAtPrice ? ` data-old-price="${escapeHtml(String(p.oldPrice || p.compareAtPrice))}"` : ""} data-image="${escapeHtml(productImage(p))}" class="${qaClass}">${escapeHtml(qaText)}</button>`
						: "";
					return `<li data-product-id="${escapeHtml(p.id)}"${liClass}${img2}>${renderCardHtml(p)}${qaBtn}</li>`;
				})
				.join("");
		}
	};

	hydratePopular();
	document.addEventListener("astro:page-load", hydratePopular);
</script>

<style>
	/* Figma 375: section title Comfortaa 14, subtitle Manrope 12. NtSectionHeading не пробрасывает class на h2/p. */
	@media (max-width: 639.98px) {
		:global(#popular-title) {
			font-size: 14px !important;
			line-height: 1 !important;
		}

		:global(#popular-title ~ p) {
			font-size: 12px !important;
			line-height: 1.4 !important;
			max-width: 100% !important;
			width: 100% !important;
			padding-inline: 0 !important;
		}

		:global([data-nt="section-heading"]) {
			max-width: 100% !important;
			width: 100% !important;
		}
	}
</style>
