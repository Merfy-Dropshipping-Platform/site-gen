---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { SITE_TITLE } from "../consts";

// Live-конфиг подписки: shopId патчит build.service (patchShopIdInDist) → siteId
// на деплое (заменяет `const shopId = ""` в HTML); apiUrl — публичный gateway.
const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";

const today = new Date();

const navColumnDefault = [
	{ label: "Смартфоны", href: "/catalog?collection=Смартфоны" },
	{ label: "Наушники", href: "/catalog?collection=Наушники" },
	{ label: "Ноутбуки", href: "/catalog?collection=Ноутбуки" },
	{ label: "Аксессуары", href: "/catalog?collection=Аксессуары" },
];

// ОЖИВЛЕНИЕ (Фаза B, контракт bloom Footer): канон-схема theme-base Footer.puckConfig —
// siteTitle, phone, email/socialColumn.email, newsletter, navigationColumn,
// informationColumn, socialColumn.socialLinks, copyright, bottomStrip, padding.
// Тело ниже — verbatim верстальщика (F:33-148); дефолтные ветки = прежним строкам
// байт-в-байт (цвета → токены с пиксель-фоллбеком §7). blockDefaults flux в theme.json
// местами расходятся с литералами (тексты рассылки, hrefs колонок, порядок соцсетей) —
// canon-значения трактуются как «не задано» → литерал (правило canon-default → пиксель).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустая строка (canon default Puck / коэрсер) не должна ронять «Flux».
const siteTitle = typeof p.siteTitle === "string" && p.siteTitle.trim() ? p.siteTitle : SITE_TITLE;
const phone = typeof p.phone === "string" && p.phone.trim() ? p.phone.trim() : "";
const rawEmail = p.socialColumn?.email ?? p.email ?? "";
const email = typeof rawEmail === "string" ? rawEmail.trim() : "";

// Канон newsletter.enabled — скрыть блок подписки ТОЛЬКО при явном false/'false'
// (булево может прийти строкой). Отсутствие пропа → блок показан = пиксель.
const newsletterEnabled = !(
	p.newsletter &&
	(p.newsletter.enabled === false || p.newsletter.enabled === "false")
);
// Тексты рассылки: canon-default blockDefaults («Введите электронную почту…») ≠
// литералу верстальщика — решаем в пользу литералов для дефолт-ветки.
const CANON_NL_DESCRIPTION = "Введите электронную почту и получайте информацию нашего бренда";
const nlHeading =
	typeof p.newsletter?.heading === "string" && p.newsletter.heading.trim()
		? p.newsletter.heading
		: "Подпишитесь на нашу рассылку";
const nlDescriptionRaw =
	typeof p.newsletter?.description === "string" && p.newsletter.description.trim()
		? p.newsletter.description
		: undefined;
const nlDescription =
	nlDescriptionRaw && nlDescriptionRaw !== CANON_NL_DESCRIPTION
		? nlDescriptionRaw
		: "Получайте информацию от нашего бренда";
const nlPlaceholderRaw =
	typeof p.newsletter?.placeholder === "string" && p.newsletter.placeholder.trim()
		? p.newsletter.placeholder
		: undefined;
const nlPlaceholder =
	nlPlaceholderRaw && nlPlaceholderRaw !== "flux@example.ru" ? nlPlaceholderRaw : "flux@example.ru";

// Канон-колонки {title, links[]}: ссылки из пропсов с fallback на литералы; canon-набор
// blockDefaults (те же label, hrefs '/catalog' и '/legal/returns') → литеральные hrefs.
// Заголовок колонки — НОВЫЙ элемент (в вёрстке верстальщика заголовков нет), рендерится
// только при непустом НЕ-canon title.
const coerceColumnLinks = (
	col: any,
	fallback: Array<{ label: string; href: string }>,
): Array<{ label: string; href: string }> =>
	Array.isArray(col?.links) && col.links.length > 0
		? col.links.map((l: any) => ({ label: String(l?.label ?? ""), href: String(l?.href ?? "/") }))
		: fallback;
const isCanonColumn = (
	links: Array<{ label: string; href: string }>,
	canon: Array<[string, string]>,
): boolean =>
	links.length === canon.length &&
	canon.every(([label, href], i) => links[i]?.label === label && links[i]?.href === href);
const CANON_NAV: Array<[string, string]> = [
	["Смартфоны", "/catalog"],
	["Наушники", "/catalog"],
	["Ноутбуки", "/catalog"],
	["Аксессуары", "/catalog"],
];
const CANON_INFO: Array<[string, string]> = [
	["Политика доставки", "/legal/delivery"],
	["Политика возврата", "/legal/returns"],
	["Условия обслуживания", "/legal/terms"],
	["Политика конфиденциальности", "/legal/privacy"],
];
const navLinksRaw = coerceColumnLinks(p.navigationColumn, navColumnDefault);
const navLinks = isCanonColumn(navLinksRaw, CANON_NAV) ? navColumnDefault : navLinksRaw;
const infoLinksRaw = coerceColumnLinks(p.informationColumn, []);
const infoLinks = isCanonColumn(infoLinksRaw, CANON_INFO) ? [] : infoLinksRaw;
const columnTitle = (col: any, canon: string): string | undefined => {
	const t = typeof col?.title === "string" ? col.title.trim() : "";
	return t && t !== canon ? t : undefined;
};
const navColTitle = columnTitle(p.navigationColumn, "Навигация");
const infoColTitle = columnTitle(p.informationColumn, "Информация");
const columnTitleCls =
	"font-comfortaa text-[14px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))] md:text-[16px]";

// Канон socialColumn.socialLinks (enum платформ) → подписи + NtIcon-глифы верстальщика;
// canon-набор blockDefaults (тот же состав в другом порядке) и пустой массив → литеральный
// порядок верстальщика дословно (Telegram VK TikTok YouTube Дзен, F:24-30).
const SOCIAL_PLATFORMS: Record<string, { platform: string; icon: string }> = {
	telegram: { platform: "Telegram", icon: "social-telegram" },
	vk: { platform: "VK", icon: "social-vk" },
	tiktok: { platform: "TikTok", icon: "social-tiktok" },
	youtube: { platform: "YouTube", icon: "social-youtube" },
	dzen: { platform: "Дзен", icon: "social-yandex-dzen" },
};
const socialsRaw = Array.isArray(p.socialColumn?.socialLinks) ? p.socialColumn.socialLinks : [];
const socials = socialsRaw
	.map((s: any) => {
		const meta = SOCIAL_PLATFORMS[String(s?.platform ?? "")];
		const href = String(s?.href ?? "").trim();
		return meta && href && href !== "#" ? { ...meta, href } : null;
	})
	.filter((s: any) => s !== null);

// Канон copyright {companyName, poweredBy, showYear} (+ legacy-строка целиком).
// Дефолтная сборка = литерал чёрной полосы верстальщика байт-в-байт:
// «© {год} {siteTitle} Theme. Все права защищены. Powered by Merfy» (F:146) — у flux
// хвост Powered by Merfy В литерале (инверсия bloom). canon-default blockDefaults
// {poweredBy 'Powered by Merfy', showYear true} = литерал и так; явная пустая строка
// poweredBy скрывает хвост.
const copyrightProp = p.copyright;
const copyrightOverride =
	typeof copyrightProp === "string" && copyrightProp.trim() ? copyrightProp : undefined;
const copyrightObj = copyrightProp && typeof copyrightProp === "object" ? copyrightProp : {};
const showYear = !(copyrightObj.showYear === false || copyrightObj.showYear === "false");
const companyPart =
	typeof copyrightObj.companyName === "string" && copyrightObj.companyName.trim()
		? copyrightObj.companyName
		: `${siteTitle} Theme`;
const poweredByTail =
	typeof copyrightObj.poweredBy === "string" ? copyrightObj.poweredBy.trim() : "Powered by Merfy";
const copyrightText =
	copyrightOverride ??
	`© ${showYear ? `${today.getFullYear()} ` : ""}${companyPart}. Все права защищены.${poweredByTail ? ` ${poweredByTail}` : ""}`;

// Канон bottomStrip {enabled, text} — у flux копирайт ЖИВЁТ в чёрной полосе (блок 3
// верстальщика = одна полоса на оба канона): strip = носитель (subsection 992),
// текст в ней = copyright (993). enabled false/'false' скрывает полосу; непустой
// text перебивает сборку copyright.
const strip = p.bottomStrip && typeof p.bottomStrip === "object" ? p.bottomStrip : undefined;
const bottomStripVisible = !(strip && (strip.enabled === false || strip.enabled === "false"));
const stripText =
	typeof strip?.text === "string" && strip.text.trim() ? strip.text : copyrightText;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при не-canon пропе. {64,64} =
// canon-default theme.json flux (его впрыскивает коэрсер) → литерал pt-12 md:pt-16 +
// pb-12 md:pb-16 секции ссылок (правило canon-default → пиксель). При override
// контейнер несёт обе стороны inline, низ секции ссылок снимается.
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const isCanonPad = pad && Number(pad.top) === 64 && Number(pad.bottom) === 64;
const footerPadStyle =
	pad && !isCanonPad
		? `padding-top:${Number(pad.top) || 0}px;padding-bottom:${Number(pad.bottom) || 0}px;`
		: undefined;
const footerContainerCls = footerPadStyle
	? "mx-auto w-full max-w-[1920px] px-4 md:px-20 2xl:px-80"
	: "mx-auto w-full max-w-[1920px] px-4 pt-12 md:px-20 md:pt-16 2xl:px-80";
const linksSectionCls = footerPadStyle
	? "mx-auto grid w-full max-w-[1320px] grid-cols-2 gap-8 md:grid-cols-4 md:gap-6"
	: "mx-auto grid w-full max-w-[1320px] grid-cols-2 gap-8 pb-12 md:grid-cols-4 md:gap-6 md:pb-16";

// Платёжные бейджи (Mastercard/VISA/МИР) — рендерим только при подключённой кассе.
const paymentEnabled = p.paymentEnabled === true || p.paymentEnabled === "true";

// Произвольные контакт-поля «Информация о компании» (адрес/часы/ИНН/…). Build кладёт
// сюда все контакт-поля КРОМЕ телефона/почты (те рендерятся как tel:/mailto: выше).
const contactFields: Array<{ label: string; value: string }> = Array.isArray(p.socialColumn?.contactFields)
	? p.socialColumn.contactFields.filter((f: any) => f && typeof f.value === "string" && f.value.trim())
	: [];
---

<footer class="w-full bg-[rgb(var(--color-bg,255_255_255))]" data-puck-component-id={id}>
	<div class={footerContainerCls} style={footerPadStyle}>
	<!-- Newsletter -->
	{newsletterEnabled && (
	<section class="mx-auto flex w-full max-w-[1320px] flex-col gap-4 pb-12 md:pb-16" aria-labelledby="newsletter-heading">
		<div class="flex flex-col gap-1">
			<h2
				id="newsletter-heading"
				class="font-comfortaa text-[16px] font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))] md:text-[18px]"
				data-puck-subsection-parent={id}
				data-puck-subsection-index="100"
				data-puck-subsection-field="newsletter"
			>
				{nlHeading}
			</h2>
			<p class="font-roboto-flex text-[12px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] md:text-[14px]">
				{nlDescription}
			</p>
		</div>

		<form
			class="flex h-11 w-full max-w-[460px] items-center justify-between gap-2 rounded-[var(--radius-field,4px)] border border-[rgb(var(--color-surface,245_245_245))] bg-white pl-3 pr-1 md:h-12"
			data-newsletter-form
			data-puck-subsection-parent={id}
			data-puck-subsection-index="997"
			data-puck-subsection-field="newsletter"
		>
			<input
				type="email"
				name="email"
				required
				placeholder={nlPlaceholder}
				aria-label="Email"
				class="min-w-0 flex-1 bg-transparent font-manrope text-[12px] font-normal leading-normal text-[#000000] placeholder:text-[#999999] outline-none md:text-[14px]"
			/>
			<button
				type="submit"
				aria-label="Подписаться"
				class="flex size-10 shrink-0 items-center justify-center transition-opacity hover:opacity-80"
			>
				<NtIcon name="arrow-right" sizeClass="size-5" />
			</button>
		</form>
		<p
			data-newsletter-status
			role="status"
			class="hidden font-roboto-flex text-[12px] font-light text-[#4AD300] md:text-[14px]"
		></p>
	</section>
	)}

	<!-- Links -->
	<section
		class={linksSectionCls}
		aria-label="Навигация по сайту"
	>
		<ul
			class="flex flex-col gap-2"
			role="list"
			data-puck-subsection-parent={id}
			data-puck-subsection-index="996"
			data-puck-subsection-field="navigationColumn"
		>
			{navColTitle && (
				<li>
					<h3 class={columnTitleCls}>{navColTitle}</h3>
				</li>
			)}
			{navLinks.map((link) => (
				<li>
					<a
						href={link.href}
						class="font-roboto-flex text-[12px] font-light leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70 md:text-[14px]"
					>
						{link.label}
					</a>
				</li>
			))}
		</ul>

		{(infoColTitle || infoLinks.length > 0) && (
		<ul
			class="flex flex-col gap-2"
			role="list"
			data-puck-subsection-parent={id}
			data-puck-subsection-index="995"
			data-puck-subsection-field="informationColumn"
		>
			{infoColTitle && (
				<li>
					<h3 class={columnTitleCls}>{infoColTitle}</h3>
				</li>
			)}
			{infoLinks.map((link) => (
				<li>
					<a
						href={link.href}
						class="font-roboto-flex text-[12px] font-light leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70 md:text-[14px]"
					>
						{link.label}
					</a>
				</li>
			))}
		</ul>
		)}

		{(phone || email || contactFields.length > 0) && (
		<div
			class="flex flex-col gap-2"
			data-puck-subsection-parent={id}
			data-puck-subsection-index="994"
			data-puck-subsection-field="socialColumn"
		>
			{phone && (
			<a
				href={`tel:${phone.replace(/[^+\d]/g, "")}`}
				class="font-roboto-flex text-[12px] font-light leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70 md:text-[14px]"
			>
				{phone}
			</a>
			)}
			{email && (
			<a
				href={`mailto:${email}`}
				class="font-roboto-flex text-[12px] font-light leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70 md:text-[14px]"
			>
				{email}
			</a>
			)}
			{contactFields.map((f) => (
			<div class="font-roboto-flex text-[12px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))] md:text-[14px]">
				<span class="text-[rgb(var(--color-text,0_0_0))]">{f.label}:</span> {f.value}
			</div>
			))}
		</div>
		)}

		<div class="flex flex-col items-start gap-3 md:items-end">
			{socials.length > 0 && (
			<div class="flex flex-wrap items-center gap-2">
				{socials.map((s) => (
					<a
						href={s.href}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={s.platform}
						class="flex size-6 items-center justify-center transition-opacity hover:opacity-70"
					>
						<NtIcon name={s.icon as any} sizeClass="size-5" />
					</a>
				))}
			</div>
			)}
			{paymentEnabled && (
			<div class="flex items-center gap-2">
				<span class="font-roboto-flex text-[10px] font-light leading-none text-[rgb(var(--color-text,0_0_0))] md:text-[12px]">Mastercard</span>
				<span class="font-roboto-flex text-[10px] font-light leading-none text-[rgb(var(--color-text,0_0_0))] md:text-[12px]">VISA</span>
				<span class="font-roboto-flex text-[10px] font-light leading-none text-[rgb(var(--color-text,0_0_0))] md:text-[12px]">МИР</span>
			</div>
			)}
		</div>
	</section>
	</div>

	<!-- Copyright -->
	{bottomStripVisible && (
		<div
			class="w-full bg-[rgb(var(--color-bg,0_0_0))] py-4 md:py-5"
			data-puck-subsection-parent={id}
			data-puck-subsection-index="992"
			data-puck-subsection-field="bottomStrip"
		>
			<p
				class="text-center font-manrope text-[11px] font-normal leading-normal text-[rgb(var(--color-text,255_255_255))] md:text-[12px]"
				data-puck-subsection-parent={id}
				data-puck-subsection-index="993"
				data-puck-subsection-field="copyright"
			>
				{stripText}
			</p>
		</div>
	)}
</footer>

<script is:inline define:vars={{ shopId, apiUrl }}>
	// Реальная отправка подписки на gateway (была demo-заглушка — фейковое
	// «Спасибо» без запроса). store_id — из пропатченного shopId (деплой) либо
	// window.__MERFY_SITE_ID__ (превью). Гард __merfyNewsletterWired исключает
	// двойную привязку, если на странице есть и эта форма, и секция Newsletter.
	(function () {
		window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
			shopId: shopId || "",
			apiUrl: apiUrl || "https://gateway.merfy.ru/api",
		};
		var cfg = window.__MERFY_CONFIG__;
		var base = String(cfg.apiUrl || "https://gateway.merfy.ru/api").replace(/\/+$/, "");
		var storeId = cfg.shopId || window.__MERFY_SITE_ID__ || "";

		function wire(form) {
			if (!form || form.__merfyNewsletterWired) return;
			form.__merfyNewsletterWired = true;
			var status = document.querySelector("[data-newsletter-status]");
			var btn = form.querySelector('button[type="submit"]');

			function show(msg, isError) {
				if (!status) return;
				status.textContent = msg;
				status.style.color = isError ? "#E11D48" : "";
				status.classList.remove("hidden");
			}

			form.addEventListener("submit", function (event) {
				event.preventDefault();
				var input = form.querySelector('input[type="email"]');
				var email = input ? String(input.value || "").trim() : "";
				if (!email) return;
				if (btn) btn.disabled = true;
				show("Отправляем…", false);

				fetch(base + "/storefront/newsletter/subscribe", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ store_id: storeId, email: email }),
				})
					.then(function (res) {
						return res
							.json()
							.catch(function () { return {}; })
							.then(function (data) { return { ok: res.ok, code: res.status, data: data }; });
					})
					.then(function (r) {
						if (r.ok) {
							show(
								r.data && r.data.alreadySubscribed
									? "Вы уже подписаны на рассылку."
									: "Спасибо! Мы отправим вам приветственное письмо.",
								false,
							);
							form.reset();
						} else if (r.code === 429) {
							show("Слишком много попыток. Попробуйте позже.", true);
						} else {
							show("Не удалось подписаться. Попробуйте позже.", true);
						}
					})
					.catch(function () {
						show("Не удалось подписаться. Проверьте соединение.", true);
					})
					.finally(function () {
						if (btn) btn.disabled = false;
					});
			});
		}

		function init() {
			var forms = document.querySelectorAll("[data-newsletter-form]");
			for (var i = 0; i < forms.length; i++) wire(forms[i]);
		}
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", init);
		} else {
			init();
		}
	})();
</script>
