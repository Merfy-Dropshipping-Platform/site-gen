---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";

// Фаза B (flux, группа misc): новая канон-секция CollapsibleSection в манере
// flux (см. themes/flux/MANNER.md; эталоны — bloom CollapsibleSection, rose T16).
// Схема полей = packages/theme-base/blocks/CollapsibleSection/
// CollapsibleSection.puckConfig.ts. Секции нет у верстальщика — нативный
// <details>/<summary> (Container-safe, без JS): заголовок = роль внутреннего h2
// §1 (Comfortaa 24/28 uppercase), вопрос Manrope 16 400, ответ Manrope 16 light
// muted leading-[1.6], разделители #F5F5F5 (роль низа шапки H:32 и разделителей
// корзины cart.astro:59); chevron — NtIcon dropdown-chevron с group-open-поворотом
// (паттерн details-фильтров каталога catalog.astro:41-48; только conditional
// Tailwind, без <style>-блока). Скролл-анимаций в манере flux нет (§6) —
// data-animate не ставим.
//
// Figma 1:19335 — ПУСТОЕ состояние: дословный плейсхолдер (заголовок
// «Сворачиваемый раздел» + ряд «Раздел» с хелпером «Ответь на самые популярные
// вопросы клиентов»), а НЕ мок-вопросы верстальщика (CANON_SECTIONS про
// доставку/возврат). Когда мерчант задал sections/items — рендерим их
// (интерактивный <details>). Принцип паритета с Collections/MultiRows: пусто =
// surface-карточки + лейбл/хелпер, без контента (эталон — rose CollapsibleSection).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading: string | { text, alignment, size }. Figma 1:19335 — ПУСТОЕ
// состояние секции «Сворачиваемый раздел»: дословный заголовок-плейсхолдер
// «Сворачиваемый раздел» (а НЕ дефолт-копирайт верстальщика «Часто задаваемые
// вопросы»). Мерчант задал свой heading → его и рендерим.
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Сворачиваемый раздел");
// Лестница §9 внутреннего h2 (дефолт роли — large): отсутствие пропа и large =
// литерал 24/md:28; medium 20/24, small 17/20.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[17px] md:text-[20px]"
		: headingSize === "medium"
			? "text-[20px] md:text-[24px]"
			: "text-[24px] md:text-[28px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-comfortaa ${headingSizeCls} font-normal uppercase leading-[1.115] text-[rgb(var(--color-heading,0_0_0))]${headingAlignCls}`;

// Канон sections[] 1-10 {heading, content} (+ pupa items[] {title, content}).
// Когда мерчант ЗАДАЛ пункты — рендерим ИХ (интерактивный <details>, content =
// set:html). Когда пусто — Figma 1:19335 ПУСТОЕ состояние: дословный
// плейсхолдер-ряд «Раздел» + хелпер-текст «Ответь на самые популярные вопросы
// клиентов» (а НЕ мок-вопросы верстальщика про доставку/возврат). Паттерн
// пустого состояния как Collections/MultiRows: DEMO-массив + лейбл/хелпер,
// без контента (эталон — rose CollapsibleSection).
const PLACEHOLDER_SECTIONS = [
	{ heading: "Раздел", content: "Ответь на самые популярные вопросы клиентов" },
];
const merchantSections =
	Array.isArray(p.sections) && p.sections.length
		? p.sections
		: Array.isArray(p.items) && p.items.length
			? p.items
			: null;
const isPlaceholder = !merchantSections;
const rawSections = merchantSections ?? PLACEHOLDER_SECTIONS;
const sections = rawSections.slice(0, 10).map((s: any) => ({
	heading:
		(typeof s.heading === "string" && s.heading) || (typeof s.title === "string" && s.title) || "",
	content: typeof s.content === "string" ? s.content : "",
}));

// Канон containerEnabled (toggle; legacy container.enabled) — подложка-поверхность
// манеры §4 (surface #F5F5F5; --radius-card: 12px из theme.json — карточных
// литералов у верстальщика нет) вокруг списка. Canon-default отсутствует →
// false = голый список (карточки flux «голые», §4).
const containerEnabled = String(p.containerEnabled ?? p.container?.enabled ?? "false") === "true";
// Канон Nikita: класс схемы контейнера вешаем ТОЛЬКО при включённом контейнере.
// При ВЫКЛ контейнеров нет → работает основная (секционная) цв. схема.
const containerSchemeCls =
	containerEnabled && typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";
// Канон Nikita (ИСПРАВЛЕНИЕ: общий бокс вокруг списка был неверен): «Контейнер» ВКЛ →
// surface-бокс на КАЖДЫЙ вопрос (<li>), НЕ общий бокс вокруг <ul>. Класс схемы — на
// ОБЁРТКЕ СПИСКА (<ul>), внешний div (с заголовком) без бокса и без схемы. Эталон
// per-element — bloom MultiColumns (cardSurfaceCls на каждом <li>). Сохранены
// flux-значения (radius-card 12px, surface 245_245_245).
// listWrapCls = ТОЛЬКО класс схемы (без бокса), вешается на <ul>.
const listWrapCls = containerSchemeCls.trim();
// При ВКЛ <ul> получает зазор между боксами-вопросами; при ВЫКЛ список слитный.
const listGapCls = containerEnabled ? "gap-3 md:gap-4" : "";
// Каждый <li>-вопрос: ВКЛ — surface-бокс (radius 12px + горизонтальный px, вертикаль —
// от внутренних py-5); ВЫКЛ — текущий border-divider (first:border-t).
const itemBoxCls = containerEnabled
	? "rounded-[var(--radius-card,12px)] bg-[rgb(var(--color-surface,245_245_245))] px-6 md:px-8"
	: "border-b border-solid border-[rgb(var(--color-surface,245_245_245))] first:border-t";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-16 pt-16 md:px-20 md:pb-24 md:pt-24 2xl:px-80"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-8 md:gap-12">
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
					set:html={heading}
				/>
			)
		}
		<ul class={["flex w-full flex-col", listGapCls, listWrapCls].filter(Boolean).join(" ")} role="list">
			{
				sections.map((s, i) => (
					<li
						class={itemBoxCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="sections"
					>
						{isPlaceholder ? (
							/* Figma 1:19335 ПУСТОЕ состояние: дословный ряд-плейсхолдер —
							   лейбл «Раздел» (роль вопроса) + хелпер-текст «Ответь на самые
							   популярные вопросы клиентов». Без интерактивного <details>:
							   реального ответа нет, помощь видна сразу (паттерн пустого
							   состояния Collections/MultiRows). Шеврон сохранён для вида. */
							<div class="flex w-full flex-col gap-2 py-5">
								<div class="flex w-full items-center justify-between gap-4 font-manrope text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))]">
									<span class="min-w-0 flex-1 break-words">{s.heading}</span>
									<NtIcon
										name="dropdown-chevron"
										sizeClass="size-5"
										class="shrink-0 rotate-180"
									/>
								</div>
								<p class="font-manrope text-[16px] font-light leading-[1.6] text-[rgb(var(--color-muted,153_153_153))]">
									{s.content}
								</p>
							</div>
						) : (
							<details class="group">
								<summary class="cursor-pointer list-none py-5 [&::-webkit-details-marker]:hidden">
									<div class="flex w-full items-center justify-between gap-4 font-manrope text-[16px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70">
										<span class="min-w-0 flex-1 break-words" set:html={s.heading} />
										<NtIcon
											name="dropdown-chevron"
											sizeClass="size-5"
											class="shrink-0 transition-transform duration-300 group-open:rotate-180"
										/>
									</div>
								</summary>
								<div
									class="pb-5 font-manrope text-[16px] font-light leading-[1.6] text-[rgb(var(--color-muted,153_153_153))]"
									set:html={s.content}
								/>
							</details>
						)}
					</li>
				))
			}
		</ul>
	</div>
</section>
