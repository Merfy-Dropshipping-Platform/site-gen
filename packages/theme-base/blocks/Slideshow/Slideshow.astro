---
import type { SlideshowProps } from './Slideshow.puckConfig';
import { SlideshowClasses as C } from './Slideshow.classes';
import { PLACEHOLDER_ASSETS } from '../../runtime/placeholders';
import { sanitizeInline } from '../../runtime/rich-text';

interface Props extends SlideshowProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  slides = [],
  interval = 5,
  autoplay = true,
  padding,
} = raw as Props;

const normalizedAutoplay =
  typeof autoplay === 'string' ? autoplay === 'true' : Boolean(autoplay);

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';

const colorScheme = raw.colorScheme as string | undefined;
const schemeClass = colorScheme ? `color-scheme-${String(colorScheme).replace('scheme-', '')}` : '';

const size = raw.size === 'small' || raw.size === 'medium' || raw.size === 'large'
  ? raw.size
  : 'large';
const imagePosition = raw.imagePosition === 'contained' || raw.imagePosition === 'left' || raw.imagePosition === 'right'
  ? 'contained'
  : 'fullscreen';
const frameContainerClass = imagePosition === 'contained' ? C.container : C.containerFullscreen;
const frameClass = imagePosition === 'contained' ? C.frameContained : '';

function hasOwn(obj: Record<string, unknown>, key: string): boolean {
  return Object.prototype.hasOwnProperty.call(obj, key);
}

function resolveLink(value: unknown): string | undefined {
  if (typeof value === 'string') return value;
  if (value && typeof value === 'object' && typeof (value as { href?: unknown }).href === 'string') {
    return (value as { href: string }).href;
  }
  return undefined;
}

type SlidePosition = keyof typeof C.position;
function normalizePosition(value: unknown, contentAlign: unknown): SlidePosition {
  if (value === 'left') return 'center-left';
  if (value === 'right') return 'center-right';
  if (typeof value === 'string' && value in C.position) return value as SlidePosition;
  return contentAlign === 'left' ? 'center-left' : 'center';
}

function clampOverlay(value: unknown): number {
  const numeric = Number(value);
  return Number.isFinite(numeric) ? Math.min(100, Math.max(0, numeric)) : 0;
}

// Tolerant renderer boundary: canonical nested fields first, legacy aliases only
// when the current field is absent. Empty current values intentionally suppress
// stale legacy content.
function normalizeSlide(slide: any) {
  const headingObj = slide.heading;
  const headingText =
    typeof headingObj === 'object' ? headingObj?.text : (typeof headingObj === 'string' ? headingObj : '');
  const headingSize = typeof headingObj === 'object' && headingObj?.size in C.headingSize
    ? headingObj.size as keyof typeof C.headingSize
    : 'medium';
  const textObj = slide.text;
  const textContent =
    typeof textObj === 'object' ? textObj?.content :
    typeof textObj === 'string' ? textObj :
    (slide.subtitle ?? '');
  const textSize = typeof textObj === 'object' && textObj?.size in C.textSize
    ? textObj.size as keyof typeof C.textSize
    : 'medium';
  const buttonObj = slide.button && typeof slide.button === 'object' ? slide.button : {};
  const buttonText = hasOwn(buttonObj, 'text') ? buttonObj.text : slide.ctaText;
  const hasCurrentLink = hasOwn(buttonObj, 'link') || hasOwn(buttonObj, 'href');
  const buttonLink = hasCurrentLink
    ? resolveLink(hasOwn(buttonObj, 'link') ? buttonObj.link : buttonObj.href)
    : resolveLink(slide.ctaUrl);
  const image = hasOwn(slide, 'image') && typeof slide.image === 'string'
    ? slide.image
    : slide.imageUrl;
  const position = normalizePosition(slide.position, raw.contentAlign);
  return {
    id: slide.id,
    headingText,
    headingSize,
    textContent,
    textSize,
    buttonText,
    buttonLink,
    image,
    overlayN: clampOverlay(slide.overlay ?? raw.overlay),
    container: slide.container === undefined
      ? true
      : slide.container === true || String(slide.container) === 'true',
    position,
    alignment: slide.alignment,
    colorScheme: slide.colorScheme,
  };
}

const allSlides = (slides ?? []).map(normalizeSlide);
const pagination = raw.pagination === 'dots' || raw.pagination === 'counter' ||
  raw.pagination === 'lines' || raw.pagination === 'none'
  ? raw.pagination
  : 'numbers';

// 084 vanilla pilot: additive `buttonStyle` variant for hero CTA.
// `solid` (default) preserves pre-084 themed bg+border. `outlined`
// renders transparent fill + 1.3px white border + uppercase per
// Vanilla scheme-1 Figma reference. Mirrors MainText.buttonStyle.
const buttonStyleProp =
  raw.buttonStyle === 'outlined' || raw.buttonStyle === 'solid'
    ? (raw.buttonStyle as 'outlined' | 'solid')
    : 'solid';
const buttonStyleClass = C.buttonStyle[buttonStyleProp];

// 084 vanilla pilot: additive `imageFullBleed` variant. Default false
// keeps image constrained to container (rose/satin/bloom/flux). When
// true, image escapes via 100vw + center-translate trick (vanilla
// 1920×880 Figma reference).
const imageFullBleed = raw.imageFullBleed === true;
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  data-autoplay={String(normalizedAutoplay)}
    data-interval={interval}
    data-pagination={pagination}
    data-size={size}
    data-image-position={imagePosition}
    style={paddingStyle}
  >
  <div class={frameContainerClass}>
    <div class:list={[C.frame, frameClass]} data-merfy-slideshow>
      {allSlides.map((slide, idx) => {
        // 084 vanilla pilot: text-align resolved via `C.align` map so we
        // never emit conflicting `text-center text-left` pairs. When the
        // slide has no explicit alignment, fall back to `center`
        // (pre-084 default) — matches the previous `text-center` baked
        // into `C.content`.
        const textAlignment: 'left' | 'center' | 'right' =
          slide.alignment === 'left' || slide.alignment === 'right' || slide.alignment === 'center'
            ? slide.alignment
            : 'center';
        const slideAlignClass = C.align[textAlignment];
        const slideSchemeClass = slide.colorScheme
          ? `color-scheme-${String(slide.colorScheme).replace('scheme-', '')}`
          : '';
        return (
          <div
            class:list={[C.slide, C.size[size], C.position[slide.position], slideAlignClass, slideSchemeClass, idx === 0 ? '' : 'hidden']}
            data-slide-id={slide.id}
            data-slide-index={idx}
            data-puck-subsection-parent={id}
            data-puck-subsection-index={idx}
            data-puck-subsection-field="slides"
          >
            {slide.image ? (
              <img src={slide.image} alt={slide.headingText ?? ''} class:list={[C.image, imageFullBleed && C.imageFullBleed]} />
            ) : slide.headingText || slide.textContent || slide.buttonText ? (
              /* Slide имеет text/button content — neutral gray background, без Figma PNG
                 (PNG asset содержит built-in white card что overlap'ало бы с real content). */
              <div class:list={[C.image, imageFullBleed && C.imageFullBleed, '-z-10 bg-[rgb(var(--color-muted)/0.12)]']} aria-hidden="true" />
            ) : (
              /* Полностью пустой slide — full empty-state PNG из Figma. */
              <img src={PLACEHOLDER_ASSETS.landscape.slideshow} alt="" class:list={[C.image, imageFullBleed && C.imageFullBleed, '-z-10 object-cover']} aria-hidden="true" loading="lazy" />
            )}
            {slide.overlayN > 0 && slide.image && (
              <div class={C.overlay} style={`opacity:${slide.overlayN / 100}`} aria-hidden="true" />
            )}
            <div class:list={[C.content, slide.container && C.contentBox, slideAlignClass, C.contentItems[textAlignment]]}>
              {slide.headingText && <h2 class:list={[C.heading, C.headingSize[slide.headingSize]]}><Fragment set:html={sanitizeInline(slide.headingText)} /></h2>}
              {slide.textContent && <p class:list={[C.subtitle, C.textSize[slide.textSize]]}><Fragment set:html={sanitizeInline(slide.textContent)} /></p>}
              {slide.buttonText && (
                <a href={slide.buttonLink ?? '#'} class:list={[C.ctaButton, buttonStyleClass]}>{slide.buttonText}</a>
              )}
            </div>
          </div>
        );
      })}
      {allSlides.length > 1 && pagination !== 'none' && (
        <div class={C.pagination} data-merfy-slideshow-pagination>
          {pagination === 'counter' ? (
            <span class={C.paginationCounter} data-slide-counter>
              <span data-slide-counter-current>1</span> / {allSlides.length}
            </span>
          ) : allSlides.map((_, idx) => (
              <button
                type="button"
                class:list={[
                  C.paginationButton,
                  pagination === 'dots' ? C.paginationDots :
                  pagination === 'lines' ? C.paginationLines :
                  C.paginationNumbers,
                  idx === 0 ? C.paginationActive : C.paginationInactive,
                ]}
                data-slide-target={idx}
                aria-label={`Слайд ${idx + 1}`}
              >{pagination === 'numbers' ? idx + 1 : ''}</button>
            ))}
        </div>
      )}
    </div>
  </div>
</section>

<script is:inline define:vars={{ blockId: id }}>
  // Pupa parity: simple carousel rotation (vanilla JS, no React island).
  // is:inline — script emitted as-is в HTML без Astro/Vite bundling.
  // Spec 102 — скоуп к СВОЕЙ секции через __merfyRoot: при 2+ «Слайд-шоу» прежний
  // querySelectorAll(ВСЕ).forEach двоил обработчики (hot-replace перезапускает скрипт).
  (function () {
    var section = window.__merfyRoot(blockId);
    if (!section) return;
    var root = section.querySelector('[data-merfy-slideshow]');
    if (!root) return;
    var slides = root.querySelectorAll('[data-slide-index]');
    var pagination = root.querySelectorAll('[data-slide-target]');
    var counter = root.querySelector('[data-slide-counter-current]');
    if (slides.length <= 1) return;

    var autoplay = section.dataset.autoplay === 'true';
    var intervalSec = parseInt(section.dataset.interval || '5', 10);

    var current = 0;
    function show(idx) {
      slides.forEach(function (s, i) { s.classList.toggle('hidden', i !== idx); });
      pagination.forEach(function (p, i) {
        p.classList.toggle('opacity-100', i === idx);
        p.classList.toggle('opacity-40', i !== idx);
      });
      if (counter) counter.textContent = String(idx + 1);
      current = idx;
    }

    pagination.forEach(function (p) {
      p.addEventListener('click', function () {
        var target = parseInt(p.dataset.slideTarget || '0', 10);
        show(target);
      });
    });

    if (autoplay) {
      setInterval(function () { show((current + 1) % slides.length); }, intervalSec * 1000);
    }
  })();
</script>
