{
  "content": [
    { "type": "Header", "props": { "id": "Header-collection" } },
    {
      "type": "Catalog",
      "props": {
        "id": "Catalog-collection",
        "categoryTitle": { "text": "{{COLLECTION_NAME}}" },
        "categorySubtitle": { "text": "{{COLLECTION_DESCRIPTION}}" },
        "heading": { "text": "{{COLLECTION_NAME}}", "size": "large" },
        "colorScheme": "scheme-3",
        "columns": 2,
        "cards": 24,
        "showFilter": "true",
