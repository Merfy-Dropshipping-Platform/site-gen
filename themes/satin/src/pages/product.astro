---
/**
 * Универсальная страница товара `/product?id=<id>` (Option B, спек 098).
 *
 * Реальные товары не имеют статических `/products/{id}` страниц (getStaticPaths
 * знает только demo-товары на сборке сервиса). Эта одна страница рендерит
 * нейтральный skeleton и клиентски патчит его реальным товаром из
 * `/data/products.json` по `?id=`. Разметка — общий `SatinProductDetail` (parity
 * с demo `[id].astro`).
 */
import Layout from "../layouts/Layout.astro";
import SatinProductDetail from "../components/products/satinProductDetail.astro";
import type { CatalogProduct } from "../data/products";

// Нейтральный skeleton: рендерится до клиентского патча (и на demo-сборке без
// products.json). placeholder-картинка, без галереи/старой цены/цветов.
const skeleton = {
	id: "",
	name: "Товар",
	price: "",
	image: "/images/placeholder.png",
	gallery: ["/images/placeholder.png"],
	colors: [],
	inStock: true,
	description: "",
} as CatalogProduct;
---

<Layout title="Товар">
	{/* Вся гидрация (живой /api/store/products → products.json → storefront-data),
	    варианты, корзина, галерея и блок «Товар не найден» живут ВНУТРИ
	    SatinProductDetail (единый inline-script, parity с demo `products/[id]`).
	    Эта страница — тонкий консьюмер: рендерит скелетон, build.service инжектит
	    window.__MERFY_SITE_ID__/DEFAULT_PRODUCT_ID в <head> этого product/index.html. */}
	<SatinProductDetail product={skeleton} />
</Layout>
