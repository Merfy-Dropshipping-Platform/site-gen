---
interface Props {
	id?: string;
	name: string;
	price: string;
	oldPrice?: string;
	image: string;
	href?: string;
	quantity?: number;
	quickAdd?: boolean;
}

const { id, name, price, oldPrice, image, href = '#', quantity, quickAdd = false } = Astro.props;
const hasImage = image && !image.includes('placeholder');
---

<article class="flex flex-col gap-[20px] group cursor-pointer">
	<a href={href} class="cursor-pointer">
		<div class="overflow-hidden w-full" style="aspect-ratio: 1 / 1; background: rgb(var(--color-background));">
			{hasImage ? (
				<img
					src={image}
					alt={name}
					loading="lazy"
					class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
				/>
			) : (
				<div class="w-full h-full flex items-center justify-center" style="background: rgb(var(--color-foreground) / 0.05);">
					<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-theme-muted">
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
						<circle cx="8.5" cy="8.5" r="1.5" />
						<polyline points="21 15 16 10 5 21" />
					</svg>
				</div>
			)}
		</div>
	</a>
	<div class="flex flex-col gap-[4px]">
		<a href={href} class="no-underline text-inherit">
			<h3 class="text-[16px] font-normal uppercase text-theme-foreground leading-[1.25] font-body line-clamp-2">
				{name}
			</h3>
		</a>
		<div class="flex items-center gap-[8px] flex-wrap">
			<span class="text-[16px] font-normal text-theme-foreground leading-[1.25] font-body">
				{price}
			</span>
			{oldPrice && (
				<span class="text-[14px] font-normal text-theme-muted line-through leading-[1.25] font-body">
					{oldPrice}
				</span>
			)}
		</div>
		{quickAdd && id && (
			<button
				type="button"
				class="add-to-cart-btn mt-2 w-full py-2 px-4 text-sm font-normal hover:opacity-90 transition-colors font-body"
				style="background: rgb(var(--color-button)); color: rgb(var(--color-button-text));"
				data-product-id={id}
				data-stock={quantity != null ? quantity : undefined}
			>
				В корзину
			</button>
		)}
	</div>
</article>
