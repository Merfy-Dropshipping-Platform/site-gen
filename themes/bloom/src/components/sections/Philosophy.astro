---
// Philosophy = текст-манифест + CTA без картинки (bloom-аналог MainText, см.
// themes/bloom/MANNER.md §10). Используется на home (index.astro) и страницах.
//
// Пустое состояние (Figma 1:19335): когда секция НЕ получила контента мерчанта —
// рендерим ПЛЕЙСХОЛДЕР контракта («Расскажи о своем бренде» / «Расскажи подробнее
// о своем онлайн-магазине в этом блоке» / Кнопка), а НЕ мок-манифест верстальщика
// «Уход за кожей…»→«Подробнее»→/about. Образец — packages/theme-base/blocks/
// MainText/MainText.astro (гейт на наличии пропа) и канон-секция MainText.astro
// (та же адаптация Philosophy). Любой заданный проп = реальные данные мерчанта →
// рендер как есть (заголовок только при непустом, кнопка только при непустой);
// SSR-с-данными при этом не ломается — Philosophy данных не гидрирует.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Гейт пустого состояния = ни одно из contentful-полей (heading/text/button|cta)
// не задано. Тогда рендерим полный плейсхолдер контракта вместо мока верстальщика.
const headingProvided =
	(typeof p.heading === "string" && p.heading.trim()) ||
	(typeof p.heading?.text === "string" && p.heading.text.trim());
const textProvided =
	(typeof p.text === "string" && p.text.trim()) ||
	(typeof p.text?.content === "string" && p.text.content.trim()) ||
	(typeof p.description === "string" && p.description.trim());
const buttonProvided =
	p.button !== undefined ||
	p.cta !== undefined ||
	(typeof p.ctaText === "string" && p.ctaText.trim());
const isEmptyState = !headingProvided && !textProvided && !buttonProvided;

// Канон heading: string | { text }. Пустое состояние → плейсхолдер-заголовок
// контракта; иначе рендер ТОЛЬКО при заданном непустом.
const heading = headingProvided
	? (typeof p.heading === "string" ? p.heading : p.heading.text)
	: (isEmptyState ? "Расскажи о своем бренде" : "");

// Канон text: string | { content } (+ legacy `description`). Пустое состояние
// (Figma 1:19335) → плейсхолдер-подсказка контракта, НЕ манифест верстальщика.
const text = textProvided
	? (typeof p.text === "string"
		? p.text
		: (typeof p.text?.content === "string" ? p.text.content : p.description))
	: (isEmptyState
		? "Расскажи подробнее о своем онлайн-магазине в этом блоке"
		: "");

// Кнопка: canon-сабпанель button {text, link} приоритетнее legacy cta/ctaText.
// Пустое состояние → плейсхолдер-«Кнопка» (не мок-CTA «Подробнее»→/about). Когда
// секция уже заполнена, но кнопка не задана — кнопка СКРЫТА. Заданный текст
// рендерится как есть; пустой — СКРЫВАЕТ кнопку.
const btnTextProp =
	(typeof p.button?.text === "string" && p.button.text.trim() ? p.button.text : undefined) ??
	(typeof p.cta?.text === "string" && p.cta.text.trim() ? p.cta.text : undefined) ??
	(typeof p.ctaText === "string" && p.ctaText.trim() ? p.ctaText : undefined);
const btnText = btnTextProp ?? (isEmptyState ? "Кнопка" : undefined);
const btnHref =
	p.button?.link?.href ??
	(typeof p.button?.link === "string" && p.button.link ? p.button.link : undefined) ??
	(typeof p.cta?.href === "string" && p.cta.href ? p.cta.href : undefined) ??
	(typeof p.cta?.link === "string" && p.cta.link ? p.cta.link : undefined) ??
	(typeof p.ctaLink === "string" && p.ctaLink ? p.ctaLink : undefined) ??
	"/";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const textId = id ? `${id}-text` : "philosophy-text";
---

<section
	id={id ? undefined : "philosophy"}
	class="w-full bg-[rgb(var(--color-bg,227_142_159))] px-4 py-20 md:px-20 md:py-[120px] 2xl:px-[300px]"
	aria-labelledby={textId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col items-center gap-10 text-center">
		{
			heading && (
				<h2
					data-animate
					class="w-full max-w-[1320px] font-urbanist text-[24px] font-normal uppercase leading-none text-[rgb(var(--color-heading,255_255_255))]"
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}

		{
			text && (
				<p
					id={textId}
					data-animate
					class="w-full max-w-[1320px] font-urbanist text-[24px] font-normal uppercase leading-none text-[rgb(var(--color-text,255_255_255))]"
					data-puck-subsection-parent={id}
					data-puck-subsection-index="101"
					data-puck-subsection-field="text"
				>
					{text}
				</p>
			)
		}

		{
			btnText && (
				<a
					href={btnHref}
					class="inline-flex h-12 items-center justify-center rounded-[var(--radius-button,100px)] bg-[rgb(var(--color-button-2-bg,255_255_255))] px-6 font-inter text-[16px] font-light leading-none text-[rgb(var(--color-button-2-text,0_0_0))] transition-opacity hover:opacity-90 active:scale-95"
					data-animate
					data-animate-delay="0.1s"
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="button"
				>
					{btnText}
				</a>
			)
		}
	</div>
</section>
