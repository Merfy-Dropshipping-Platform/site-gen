---
import NtPromoBanner from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtPromoBanner.astro";
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { SITE_TITLE } from "../consts";

interface NavLink {
	label: string;
	href: string;
	match?: (pathname: string) => boolean;
}

const defaultNav: NavLink[] = [
	{ label: "Главная", href: "/", match: (path) => path === "/" },
	{ label: "Смартфоны", href: "/catalog?collection=%D0%A1%D0%BC%D0%B0%D1%80%D1%82%D1%84%D0%BE%D0%BD%D1%8B", match: (path) => path.startsWith("/catalog") || path.startsWith("/products") },
	{ label: "Наушники", href: "/catalog?collection=%D0%9D%D0%B0%D1%83%D1%88%D0%BD%D0%B8%D0%BA%D0%B8" },
	{ label: "Ноутбуки", href: "/catalog?collection=%D0%9D%D0%BE%D1%83%D1%82%D0%B1%D1%83%D0%BA%D0%B8" },
	{ label: "Аксессуары", href: "/catalog?collection=%D0%90%D0%BA%D1%81%D0%B5%D1%81%D1%81%D1%83%D0%B0%D1%80%D1%8B" },
];

// ОЖИВЛЕНИЕ (Фаза B, контракт bloom Header): канон-схема theme-base Header.puckConfig —
// siteTitle, navigationLinks, logo, logoPosition, stickiness, padding. Тело ниже —
// verbatim верстальщика; дефолтные ветки тернарников = прежним строкам байт-в-байт
// (цвета → токены с пиксель-фоллбеком родных литералов §7).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустая строка (впрыск коэрсера live-пути) не должна гасить название магазина.
const siteTitle = typeof p.siteTitle === "string" && p.siteTitle.trim() ? p.siteTitle : SITE_TITLE;
const nav: NavLink[] =
	Array.isArray(p.navigationLinks) && p.navigationLinks.length > 0
		? p.navigationLinks.map((l: any) => ({ label: l.label ?? l.text ?? "", href: l.href ?? l.link ?? "/" }))
		: defaultNav;

// Канон logo (URL картинки; панель «Логотип» пишет в props.logo): непустая строка →
// <img> высотой var(--size-logo-width) в mobile И desktop. Дефолт flux = ТЕКСТ-лого
// {SITE_TITLE} Comfortaa uppercase (mobile 18px / desktop 24 → lg:28, H:54, 85);
// фоллбек токена 24px = --size-logo-width из theme.json flux.
const logo = typeof p.logo === "string" && p.logo.trim() ? p.logo : undefined;
const logoImgCls = "h-[var(--size-logo-width,24px)] w-auto max-w-[160px] object-contain";

// Канон logoPosition: 'top-left' (canon-default) / 'top-center' / 'center-left' /
// 'center-absolute'. Отсутствие / неизвестное значение → 'top-left' (designer default,
// два ряда). isTwoRow: два ряда (top-left, top-center); single-row: center-left / center-absolute.
const logoPosition = typeof p.logoPosition === "string" ? p.logoPosition : "";
const isTwoRow = logoPosition === "top-left" || logoPosition === "top-center";
// center-absolute: лого absolute по центру single-row
const isAbsoluteCenter = logoPosition === "center-absolute";

// Канон stickiness: литерал верстальщика УЖЕ sticky top-0 z-50 (H:24) — 'none' /
// 'always' / canon-default / отсутствие → sticky остаётся. 'scroll-up' → прячем при
// скролле вниз, показываем при скролле вверх: is:inline скрипт через data-атрибут
// (компилятор секций не умеет define:vars), идемпотентность через data-hydrated.
const stickiness = typeof p.stickiness === "string" ? p.stickiness : "";
const rootCls =
	stickiness === "scroll-up"
		? "sticky top-0 z-50 w-full transition-transform duration-300"
		: "sticky top-0 z-50 w-full";
const SCROLL_UP_JS = [
	"(function(){",
	"var root=document.querySelector('[data-flux-sticky=\"scroll-up\"]');",
	"if(!root||root.getAttribute('data-hydrated')==='true')return;",
	"root.setAttribute('data-hydrated','true');",
	"var last=window.scrollY;",
	"window.addEventListener('scroll',function(){",
	"var y=window.scrollY;",
	"if(y>last&&y>root.offsetHeight){root.style.transform='translateY(-100%)';}else{root.style.transform='';}",
	"last=y;",
	"},{passive:true});",
	"})();",
].join("");

// Канон padding {top,bottom} — clamp ≤64 на носителе отступов верстальщика
// (desktop-ряд md:py-4; мобильная строка h-14 фиксированная). {12,12} = canon-default
// puckConfig (theme.json flux Header без padding) → ЛИТЕРАЛ md:py-4; inline-стиль
// только при ином значении (паттерн bloom Header:100-107).
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const isCanonPad = pad && Number(pad.top) === 12 && Number(pad.bottom) === 12;
const headerPad =
	pad && !isCanonPad
		? { top: Math.min(Number(pad.top) || 0, 64), bottom: Math.min(Number(pad.bottom) || 0, 64) }
		: undefined;
const headerPadStyle = headerPad
	? `padding-top:${headerPad.top}px;padding-bottom:${headerPad.bottom}px;`
	: undefined;
// single-row classes (center-left / center-absolute)
const singleRowCls = [
	"w-full max-w-[1920px] mx-auto px-4 flex items-center justify-between md:px-20 2xl:px-80",
	headerPad ? "" : "py-4",
	isAbsoluteCenter ? "relative" : "",
].filter(Boolean).join(" ");
const desktopLogoCls = logo
	? `flex shrink-0 items-center hover:opacity-90${isAbsoluteCenter ? " md:absolute md:left-1/2 md:-translate-x-1/2" : ""}`
	: `shrink-0 font-comfortaa text-[24px] font-normal uppercase leading-none text-[rgb(var(--color-heading,0_0_0))] hover:opacity-90 lg:text-[28px]${isAbsoluteCenter ? " md:absolute md:left-1/2 md:-translate-x-1/2" : ""}`;
const mobileLogoCls = logo
	? "flex items-center hover:opacity-80"
	: "font-comfortaa text-[18px] font-normal uppercase text-[rgb(var(--color-heading,0_0_0))] hover:opacity-80";

const pathname = Astro.url.pathname;
const isActive = (link: NavLink) => (link.match ? link.match(pathname) : pathname === link.href);
---

<div
	class={rootCls}
	data-flux-header
	data-puck-component-id={id}
	data-flux-sticky={stickiness === "scroll-up" ? "scroll-up" : undefined}
>
	{
		/* Встроенная полоса объявления — ТОЛЬКО статик-режим (без props.id):
		   в канон-композиции полоса = отдельная секция PromoBanner, иначе дубль
		   (паттерн bloom Header:117-133). */
		!id && (
			<NtPromoBanner
				text="Бесплатная доставка на весь ассортимент до 30.06.2026."
				link="/catalog"
				linkText="Перейти"
			/>
		)
	}

	<header
		class="w-full border-b border-[rgb(var(--color-surface,245_245_245))] bg-[rgb(var(--color-bg,255_255_255))]"
		data-nt="flux-header"
	>
	<!-- Mobile 375 -->
	<div class="relative z-[60] flex h-14 items-center justify-between bg-[rgb(var(--color-bg,255_255_255))] px-4 md:hidden">
		<button
			type="button"
			id="flux-burger-btn"
			class="flex size-8 items-center justify-center transition-opacity hover:opacity-70"
			aria-label="Меню"
			aria-expanded="false"
			aria-controls="flux-burger"
		>
			<span class="burger-icon" data-icon="open">
				<NtIcon name="menu-burger" sizeClass="size-6" />
			</span>
			<span class="burger-icon hidden" data-icon="close">
				<NtIcon name="menu-close" sizeClass="size-6" />
			</span>
		</button>
		<a href="/" class={mobileLogoCls} aria-label={siteTitle}>
			{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
		</a>
		<div class="flex items-center gap-3">
			<a href="#" data-action="toggle-search" class="flex size-6 items-center justify-center" aria-label="Поиск">
				<NtIcon name="search-sm" sizeClass="size-6" />
			</a>
			<button
				type="button"
				data-cart-open
				class="relative flex size-6 items-center justify-center"
				aria-label="Корзина"
			>
				<NtIcon name="cart-sm" sizeClass="size-4" />
				<span
					data-cart-count
					data-empty="true"
					class="absolute -right-2 -top-2 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#FA5109] px-1 font-manrope text-[10px] font-normal leading-none text-[#000000] data-[empty=true]:hidden"
				>0</span>
			</button>
			<a href="/auth/sign-in" class="flex size-6 items-center justify-center" aria-label="Аккаунт">
				<NtIcon name="user-sm" sizeClass="size-4" />
			</a>
		</div>
	</div>

	<!-- Desktop -->
	<div class="hidden w-full md:block">
		{isTwoRow ? (
			/* ── TWO-ROW LAYOUTS: top-left / top-center ── */
			<div
				class={[
					"w-full max-w-[1920px] mx-auto px-4 flex flex-col md:px-20 2xl:px-80",
					headerPad ? "" : "md:py-4",
				].filter(Boolean).join(" ")}
				style={headerPadStyle}
			>
				{logoPosition === "top-left" || logoPosition === "" ? (
					/* top-left (designer default): Row1=[logo LEFT + actions RIGHT], Row2=[nav LEFT] */
					<>
						<div class="flex w-full items-center justify-between">
							<a href="/" class={desktopLogoCls} aria-label={siteTitle}>
								{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
							</a>
							<div class="flex items-center gap-4 lg:gap-5">
								<button
									type="button"
									data-action="toggle-search"
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80 lg:size-10"
									aria-label="Поиск"
								>
									<NtIcon name="search-lg" sizeClass="size-6" />
								</button>
								<button
									type="button"
									data-cart-open
									class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80 lg:size-10"
									aria-label="Корзина"
								>
									<NtIcon name="cart" sizeClass="size-6" />
									<span
										data-cart-count
										data-empty="true"
										class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#FA5109] px-1 font-manrope text-[10px] font-normal leading-none text-[#000000] data-[empty=true]:hidden"
									>0</span>
								</button>
								<a
									href="/auth/sign-in"
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80 lg:size-10"
									aria-label="Аккаунт"
								>
									<NtIcon name="user" sizeClass="size-6" />
								</a>
							</div>
						</div>
						<nav
							class="mt-3 flex w-full items-center justify-start gap-8 lg:gap-10"
							aria-label="Основная навигация"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="997"
							data-puck-subsection-field="navigationLinks"
						>
							{nav.map((link) => {
								const active = isActive(link);
								return (
									<a
										href={link.href}
										aria-current={active ? "page" : undefined}
										class:list={[
											"relative pb-1 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70 lg:text-[16px]",
											active && "after:absolute after:bottom-0 after:left-0 after:h-[2px] after:w-full after:bg-[rgb(var(--color-accent,250_81_9))] after:content-['']",
										]}
									>
										{link.label}
									</a>
								);
							})}
						</nav>
					</>
				) : (
					/* top-center: Row1=[search LEFT | logo CENTER | cart+user RIGHT], Row2=[nav CENTER] */
					<>
						<div class="grid w-full grid-cols-[1fr_auto_1fr] items-center">
							<div class="flex items-center">
								<button
									type="button"
									data-action="toggle-search"
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80 lg:size-10"
									aria-label="Поиск"
								>
									<NtIcon name="search-lg" sizeClass="size-6" />
								</button>
							</div>
							<div class="flex items-center justify-center">
								<a href="/" class={desktopLogoCls} aria-label={siteTitle}>
									{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
								</a>
							</div>
							<div class="flex items-center justify-end gap-4 lg:gap-5">
								<button
									type="button"
									data-cart-open
									class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80 lg:size-10"
									aria-label="Корзина"
								>
									<NtIcon name="cart" sizeClass="size-6" />
									<span
										data-cart-count
										data-empty="true"
										class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#FA5109] px-1 font-manrope text-[10px] font-normal leading-none text-[#000000] data-[empty=true]:hidden"
									>0</span>
								</button>
								<a
									href="/auth/sign-in"
									class="flex size-8 items-center justify-center transition-opacity hover:opacity-80 lg:size-10"
									aria-label="Аккаунт"
								>
									<NtIcon name="user" sizeClass="size-6" />
								</a>
							</div>
						</div>
						<nav
							class="mt-3 flex w-full items-center justify-center gap-8 lg:gap-10"
							aria-label="Основная навигация"
							data-puck-subsection-parent={id}
							data-puck-subsection-index="997"
							data-puck-subsection-field="navigationLinks"
						>
							{nav.map((link) => {
								const active = isActive(link);
								return (
									<a
										href={link.href}
										aria-current={active ? "page" : undefined}
										class:list={[
											"relative pb-1 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70 lg:text-[16px]",
											active && "after:absolute after:bottom-0 after:left-0 after:h-[2px] after:w-full after:bg-[rgb(var(--color-accent,250_81_9))] after:content-['']",
										]}
									>
										{link.label}
									</a>
								);
							})}
						</nav>
					</>
				)}
			</div>
		) : (
			/* ── SINGLE-ROW LAYOUTS: center-left / center-absolute ── */
			<div class={singleRowCls} style={headerPadStyle}>
				<a href="/" class={desktopLogoCls} aria-label={siteTitle}>
					{logo ? <img src={logo} alt={siteTitle} class={logoImgCls} /> : siteTitle}
				</a>

				<nav
					class="flex items-center gap-8 lg:gap-10"
					aria-label="Основная навигация"
					data-puck-subsection-parent={id}
					data-puck-subsection-index="997"
					data-puck-subsection-field="navigationLinks"
				>
					{nav.map((link) => {
						const active = isActive(link);
						return (
							<a
								href={link.href}
								aria-current={active ? "page" : undefined}
								class:list={[
									"relative pb-1 font-manrope text-[14px] font-normal leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70 lg:text-[16px]",
									active && "after:absolute after:bottom-0 after:left-0 after:h-[2px] after:w-full after:bg-[rgb(var(--color-accent,250_81_9))] after:content-['']",
								]}
							>
								{link.label}
							</a>
						);
					})}
				</nav>

				<div class="flex items-center gap-4 lg:gap-5">
					<button
						type="button"
						data-action="toggle-search"
						class="flex size-8 items-center justify-center transition-opacity hover:opacity-80 lg:size-10"
						aria-label="Поиск"
					>
						<NtIcon name="search-lg" sizeClass="size-6" />
					</button>
					<button
						type="button"
						data-cart-open
						class="relative flex size-8 items-center justify-center transition-opacity hover:opacity-80 lg:size-10"
						aria-label="Корзина"
					>
						<NtIcon name="cart" sizeClass="size-6" />
						<span
							data-cart-count
							data-empty="true"
							class="absolute right-0 top-0 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#FA5109] px-1 font-manrope text-[10px] font-normal leading-none text-[#000000] data-[empty=true]:hidden"
						>0</span>
					</button>
					<a
						href="/auth/sign-in"
						class="flex size-8 items-center justify-center transition-opacity hover:opacity-80 lg:size-10"
						aria-label="Аккаунт"
					>
						<NtIcon name="user" sizeClass="size-6" />
					</a>
				</div>
			</div>
		)}
	</div>

	<!-- Desktop Search Panel (expandable) -->
	<div
		data-search-panel
		class="hidden w-full border-t border-[rgb(var(--color-surface,245_245_245))] bg-[rgb(var(--color-bg,255_255_255))] px-4 py-4 md:px-20 2xl:px-80"
		hidden
	>
		<form role="search" action="/catalog" method="get" class="mx-auto flex h-12 w-full max-w-[1320px] items-center justify-between gap-2 rounded-[4px] border border-[#FA5109] bg-white pl-3 pr-1">
			<input
				type="search"
				name="q"
				placeholder="Поиск..."
				aria-label="Поиск"
				class="min-w-0 flex-1 bg-transparent font-manrope text-[14px] font-normal leading-normal text-[#000000] placeholder:text-[#999999] outline-none md:text-[16px]"
			/>
			<button
				type="submit"
				class="flex h-10 shrink-0 items-center justify-center rounded-[4px] bg-[#FA5109] px-3 py-2 font-manrope text-[12px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-95 md:text-[14px]"
			>
				Найти
			</button>
		</form>
	</div>
	</header>

	<!-- Мобильный бургер -->
	<div
		id="flux-burger"
		class="fixed inset-x-0 top-[56px] bottom-0 z-[55] hidden w-full overflow-y-auto bg-white px-4 pt-4 pb-8 md:hidden"
		role="dialog"
		aria-modal="true"
		aria-label="Меню"
	>
		<div class="flex items-center gap-2">
			<form class="flex h-10 min-h-10 flex-1 items-center justify-between rounded-[4px] border border-[#999999] bg-white pl-3 pr-2" role="search" action="/catalog" method="get">
				<input
					type="search"
					name="q"
					placeholder="Поиск"
					class="min-w-0 flex-1 bg-transparent font-manrope text-[12px] font-normal leading-normal text-[#000000] placeholder:text-[#999999] outline-none"
				/>
				<button type="submit" class="flex h-6 w-6 shrink-0 items-center justify-center" aria-label="Найти">
					<NtIcon name="search-sm" sizeClass="size-6" />
				</button>
			</form>
			<a
				href="/auth/sign-in"
				class="flex size-10 shrink-0 items-center justify-center rounded-[4px] bg-[#FA5109]"
				aria-label="Профиль"
			>
				<NtIcon name="user" sizeClass="size-6" />
			</a>
		</div>

		<nav class="mt-6 flex flex-col gap-4" aria-label="Основное меню">
			{nav.map((link) => {
				const active = isActive(link);
				return (
					<div class="flex flex-col gap-1">
						<a
							href={link.href}
							class:list={[
								"text-[14px] font-normal leading-normal",
								active ? "text-[#000000]" : "text-[#999999]",
							]}
						>
							{link.label}
						</a>
						{active && <div class="h-[2px] w-[54px] bg-[#FA5109]" aria-hidden="true"></div>}
					</div>
				);
			})}
			<a href="/cart" class="text-[14px] font-normal leading-normal text-[#999999]">Корзина</a>
			<a href="/auth/sign-up" class="text-[14px] font-normal leading-normal text-[#999999]">Регистрация</a>
		</nav>
	</div>

	{stickiness === "scroll-up" && <script is:inline set:html={SCROLL_UP_JS} />}
</div>

<script>
	const burgerBtn = document.getElementById("flux-burger-btn");
	const burger = document.getElementById("flux-burger");

	const setBurger = (open: boolean) => {
		if (!burger || !burgerBtn) return;
		burger.classList.toggle("hidden", !open);
		burgerBtn.setAttribute("aria-expanded", String(open));
		burgerBtn.querySelectorAll<HTMLElement>(".burger-icon").forEach((el) => {
			const key = el.dataset.icon;
			if (key === "open") el.classList.toggle("hidden", open);
			else el.classList.toggle("hidden", !open);
		});
		document.body.style.overflow = open ? "hidden" : "";
	};

	burgerBtn?.addEventListener("click", () => {
		const isHidden = burger?.classList.contains("hidden");
		setBurger(Boolean(isHidden));
	});

	burger?.querySelectorAll("a").forEach((a) => {
		a.addEventListener("click", () => setBurger(false));
	});

	document.querySelectorAll<HTMLElement>("[data-action='toggle-search']").forEach((el) => {
		el.addEventListener("click", (event) => {
			event.preventDefault();
			const panel = document.querySelector<HTMLElement>("[data-search-panel]");
			if (!panel) return;
			const hidden = panel.hasAttribute("hidden");
			if (hidden) {
				panel.removeAttribute("hidden");
				panel.classList.remove("hidden");
				panel.classList.add("block");
				panel.querySelector<HTMLInputElement>("input[type='search']")?.focus();
			} else {
				panel.setAttribute("hidden", "");
				panel.classList.add("hidden");
				panel.classList.remove("block");
			}
		});
	});
</script>
