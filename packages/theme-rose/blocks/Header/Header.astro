---
// theme-rose Header OVERRIDE — ported from verstalshik repo
// (rose-theme/src/components/Header.astro). Consumes the SAME base HeaderProps
// (schema frozen) but renders rose's pixel-perfect markup. Styling lives in a
// scoped <style> block (works in preview after the compile-astro-blocks.mjs
// fix); icons are inlined as SVG (currentColor) so the block is self-contained
// (no @merfy-dropshipping-platform/design-systems-theme dependency). Client JS
// is <script is:inline> so it ships verbatim into the preview + live HTML.
interface NavLink {
  label: string;
  href?: string;
  submenu?: NavLink[];
}
interface Props {
  id?: string;
  siteTitle?: string;
  navigationLinks?: NavLink[];
  actionButtons?: { showSearch?: boolean; showCart?: boolean; showProfile?: boolean };
  colorScheme?: string | number;
  padding?: { top?: number; bottom?: number };
  promoBar?: { enabled?: boolean | string; text?: string; linkText?: string; linkHref?: string };
}

const {
  id,
  siteTitle = 'ROSE',
  navigationLinks = [
    { label: 'Главная', href: '/' },
    { label: 'Каталог', href: '/catalog' },
    { label: 'Контакты', href: '/contacts' },
  ],
  actionButtons = { showSearch: true, showCart: true, showProfile: true },
  colorScheme,
  padding,
  promoBar,
} = Astro.props as Props;

const schemeClass = colorScheme
  ? `color-scheme-${String(colorScheme).replace('scheme-', '')}`
  : '';
const padStyle = padding
  ? `padding-top:${padding.top ?? 0}px;padding-bottom:${padding.bottom ?? 0}px;`
  : '';
const promoEnabled = promoBar?.enabled === true || promoBar?.enabled === 'true';
const promoText = (promoBar?.text || 'Скидка 10% на общую сумму заказа от 9 000₽').trim();
const promoLinkText = (promoBar?.linkText || 'Перейти').trim();
const promoLinkHref = promoBar?.linkHref || '/catalog';
const links = navigationLinks.length ? navigationLinks : [];
const showSearch = actionButtons?.showSearch !== false;
const showCart = actionButtons?.showCart !== false;
const showProfile = actionButtons?.showProfile !== false;
---

<div class={`rose-header-wrap ${schemeClass}`} data-puck-component-id={id} data-header-wrapper>
  {promoEnabled && (
    <div class="rose-promo" data-nt="promo-banner">
      <span class="rose-promo__text">{promoText}</span>
      <a class="rose-promo__link" href={promoLinkHref}>{promoLinkText}</a>
    </div>
  )}

  <header class="rose-header" data-nt="rose-header" style={padStyle}>
    {/* Mobile bar */}
    <div class="rose-header__mobile">
      <button type="button" id="rose-burger-btn" class="rose-header__burger" aria-label="Меню" aria-expanded="false">
        <span class="burger-icon" data-icon="open">
          <svg viewBox="0 0 15.2 8.2" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0.6 7.6H14.6M0.6 0.6H14.6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="burger-icon hidden" data-icon="close">
          <svg viewBox="0 0 13.2 13.2" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0.6 0.6L12.6 12.6M0.6 12.6L12.6 0.6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </button>
      <a href="/" class="rose-header__logo">{siteTitle}</a>
      {showCart && (
        <button type="button" data-cart-open class="rose-header__mobile-cart" aria-label="Корзина">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M6.68635 2.46154C5.8669 2.46154 5.11186 2.90581 4.7139 3.62214C3.87836 5.12611 4.96588 6.97436 6.68636 6.97436H9.31359C11.0341 6.97436 12.1216 5.12611 11.286 3.62214C10.8881 2.90581 10.133 2.46154 9.31359 2.46154H6.68635ZM5.78978 4.21985C5.97068 3.89425 6.31388 3.69231 6.68635 3.69231H9.31359C9.68607 3.69231 10.0293 3.89425 10.2102 4.21985C10.59 4.90348 10.0956 5.74359 9.31359 5.74359H6.68636C5.90432 5.74359 5.40999 4.90348 5.78978 4.21985Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M6.16596 0C4.79693 0 3.52829 0.718293 2.82393 1.89222L0.555412 5.67309C0.191979 6.27881 0 6.97192 0 7.67831V12.1026C0 14.2551 1.74494 16 3.89744 16H12.1026C14.2551 16 16 14.2551 16 12.1026V7.67831C16 6.97192 15.808 6.27881 15.4446 5.67309L13.1761 1.89222C12.4717 0.718293 11.2031 0 9.83404 0H6.16596ZM3.87931 2.52545C4.36124 1.72223 5.22926 1.23077 6.16596 1.23077H9.83404C10.7707 1.23077 11.6388 1.72223 12.1207 2.52545L14.3892 6.30632C14.6379 6.72076 14.7692 7.19499 14.7692 7.67831V12.1026C14.7692 13.5753 13.5753 14.7692 12.1026 14.7692H3.89744C2.42468 14.7692 1.23077 13.5753 1.23077 12.1026V7.67831C1.23077 7.19499 1.36212 6.72076 1.61079 6.30632L3.87931 2.52545Z" fill="currentColor"/></svg>
          <span data-cart-count data-empty="true" class="rose-header__cartcount">0</span>
        </button>
      )}
    </div>

    {/* Desktop bar */}
    <div class="rose-header__desktop">
      <div class="rose-header__inner">
        <a href="/" class="rose-header__logo">{siteTitle}</a>

        <nav class="rose-header__nav" data-nav-inline aria-label="Основная навигация">
          {links.map((link) => (
            <a href={link.href || '#'} class="rose-header__navlink">{link.label}</a>
          ))}
        </nav>

        <div class="rose-header__actions">
          {showSearch && (
            <button type="button" data-action="toggle-search" class="rose-header__iconbtn" aria-label="Поиск" aria-expanded="false">
              <svg viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 17L25 25M10.3333 19.6667C5.17868 19.6667 1 15.488 1 10.3333C1 5.17868 5.17868 1 10.3333 1C15.488 1 19.6667 5.17868 19.6667 10.3333C19.6667 15.488 15.488 19.6667 10.3333 19.6667Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          )}
          {showCart && (
            <button type="button" data-cart-open class="rose-header__iconbtn" aria-label="Корзина">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M10.0295 3.69231C8.80035 3.69231 7.66779 4.35871 7.07085 5.43321C5.81754 7.68916 7.44882 10.4615 10.0295 10.4615H13.9704C16.5511 10.4615 18.1824 7.68916 16.9291 5.43321C16.3321 4.35871 15.1996 3.69231 13.9704 3.69231H10.0295ZM8.68468 6.32978C8.95601 5.84137 9.47081 5.53846 10.0295 5.53846H13.9704C14.5291 5.53846 15.0439 5.84137 15.3152 6.32978C15.8849 7.35521 15.1434 8.61538 13.9704 8.61538H10.0295C8.85648 8.61538 8.11499 7.35521 8.68468 6.32978Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M9.24894 0C7.1954 0 5.29244 1.07744 4.2359 2.83833L0.833118 8.50964C0.287969 9.41822 0 10.4579 0 11.5175V18.1538C0 21.3826 2.61741 24 5.84615 24H18.1538C21.3826 24 24 21.3826 24 18.1538V11.5175C24 10.4579 23.712 9.41822 23.1669 8.50964L19.7641 2.83833C18.7076 1.07744 16.8046 0 14.7511 0H9.24894ZM5.81897 3.78817C6.54186 2.58335 7.84389 1.84615 9.24894 1.84615H14.7511C16.1561 1.84615 17.4581 2.58335 18.181 3.78817L21.5838 9.45948C21.9568 10.0811 22.1538 10.7925 22.1538 11.5175V18.1538C22.1538 20.363 20.363 22.1538 18.1538 22.1538H5.84615C3.63701 22.1538 1.84615 20.363 1.84615 18.1538V11.5175C1.84615 10.7925 2.04319 10.0811 2.41618 9.45948L5.81897 3.78817Z" fill="currentColor"/></svg>
              <span data-cart-count data-empty="true" class="rose-header__cartcount">0</span>
            </button>
          )}
          {showProfile && (
            <a href="/auth/sign-in" class="rose-header__iconbtn" aria-label="Аккаунт">
              <svg viewBox="0 0 19 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M15.4375 6C15.4375 9.31371 12.7792 12 9.5 12C6.22081 12 3.5625 9.31371 3.5625 6C3.5625 2.68629 6.22081 0 9.5 0C12.7792 0 15.4375 2.68629 15.4375 6ZM13.6562 6C13.6562 8.3196 11.7954 10.2 9.5 10.2C7.20457 10.2 5.34375 8.3196 5.34375 6C5.34375 3.6804 7.20457 1.8 9.5 1.8C11.7954 1.8 13.6562 3.6804 13.6562 6Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M19 18.6C19 21.5823 14.7467 24 9.5 24C4.2533 24 0 21.5823 0 18.6C0 15.6177 4.2533 13.2 9.5 13.2C14.7467 13.2 19 15.6177 19 18.6ZM17.2188 18.6C17.2188 19.1521 16.8063 20.0185 15.3442 20.8495C13.938 21.6489 11.8754 22.2 9.5 22.2C7.12463 22.2 5.062 21.6489 3.65576 20.8495C2.1937 20.0185 1.78125 19.1521 1.78125 18.6C1.78125 18.0479 2.1937 17.1815 3.65576 16.3505C5.062 15.5511 7.12463 15 9.5 15C11.8754 15 13.938 15.5511 15.3442 16.3505C16.8063 17.1815 17.2188 18.0479 17.2188 18.6Z" fill="currentColor"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>

    {/* Search panel */}
    {showSearch && (
      <div id="rose-search-panel" data-search-panel class="rose-search-panel" aria-hidden="true">
        <div class="rose-search-panel__inner">
          <form role="search" action="/catalog" method="get" class="rose-search-form">
            <input type="search" name="q" placeholder="Поиск..." aria-label="Поиск" />
            <button type="submit">Найти</button>
          </form>
        </div>
      </div>
    )}
  </header>

  {/* Mobile burger drawer */}
  <div id="rose-burger" class="rose-burger-drawer hidden" role="dialog" aria-modal="true" aria-label="Меню">
    <nav class="rose-burger-drawer__nav" aria-label="Основное меню">
      {links.map((link) => (
        <a href={link.href || '#'} class="rose-burger-drawer__link">{link.label}</a>
      ))}
    </nav>
  </div>
</div>

<style>
  .rose-header-wrap { width: 100%; }
  .rose-promo {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    background: rgb(var(--color-text)); color: rgb(var(--color-bg));
    padding: 12px 16px; font-family: var(--font-body, 'Manrope', sans-serif);
    font-size: 14px; line-height: 1;
  }
  .rose-promo__link { color: inherit; text-decoration: underline; }

  .rose-header {
    position: relative; width: 100%; overflow: visible;
    background: rgb(var(--color-bg)); color: rgb(var(--color-text));
  }

  /* Mobile bar */
  .rose-header__mobile {
    position: relative; z-index: 60; display: flex; height: 44px;
    align-items: center; justify-content: space-between; padding: 0 16px;
  }
  @media (min-width: 640px) { .rose-header__mobile { padding: 0 20px; } }
  @media (min-width: 768px) { .rose-header__mobile { padding: 0 40px; } }
  @media (min-width: 1024px) { .rose-header__mobile { display: none; } }
  .rose-header__mobile .rose-header__logo { font-size: 20px; }

  /* Desktop bar */
  .rose-header__desktop { display: none; }
  @media (min-width: 1024px) { .rose-header__desktop { display: block; width: 100%; } }
  .rose-header__inner {
    margin: 0 auto; max-width: 1920px; display: flex; align-items: center;
    justify-content: space-between; padding: 20px 16px;
  }
  @media (min-width: 640px)  { .rose-header__inner { padding-left: 20px; padding-right: 20px; } }
  @media (min-width: 768px)  { .rose-header__inner { padding-left: 40px; padding-right: 40px; } }
  @media (min-width: 1024px) { .rose-header__inner { padding: 24px 64px; } }
  @media (min-width: 1280px) { .rose-header__inner { padding-left: 80px; padding-right: 80px; } }
  @media (min-width: 1536px) { .rose-header__inner { padding-left: 280px; padding-right: 280px; } }

  .rose-header__logo {
    flex-shrink: 0; font-family: var(--font-heading, 'Comfortaa', sans-serif);
    font-size: 24px; font-weight: 400; text-transform: uppercase; line-height: 1;
    color: rgb(var(--color-text)); text-decoration: none;
  }
  .rose-header__logo:hover { opacity: 0.9; }

  .rose-header__nav { display: flex; align-items: center; gap: 32px; }
  @media (min-width: 1024px) { .rose-header__nav { gap: 48px; } }
  .rose-header__navlink {
    position: relative; padding-bottom: 4px;
    font-family: var(--font-body, 'Manrope', sans-serif); font-size: 14px;
    font-weight: 400; color: rgb(var(--color-text)); text-decoration: none;
    transition: opacity 0.2s;
  }
  @media (min-width: 1024px) { .rose-header__navlink { font-size: 16px; } }
  .rose-header__navlink:hover { opacity: 0.7; }
  .rose-header__navlink[aria-current="page"]::after {
    content: ""; position: absolute; bottom: 0; left: 0; height: 1px; width: 100%;
    background: rgb(var(--color-text));
  }

  .rose-header__actions { display: flex; align-items: center; gap: 16px; }
  @media (min-width: 1024px) { .rose-header__actions { gap: 24px; } }
  .rose-header__iconbtn {
    position: relative; display: flex; width: 40px; height: 40px; align-items: center;
    justify-content: center; background: none; border: none; cursor: pointer;
    color: rgb(var(--color-text)); text-decoration: none; transition: opacity 0.2s;
  }
  .rose-header__iconbtn:hover { opacity: 0.8; }
  .rose-header__iconbtn svg { width: 24px; height: 24px; display: block; }

  .rose-header__cartcount {
    position: absolute; right: 0; top: 0; display: inline-flex; height: 16px;
    min-width: 16px; align-items: center; justify-content: center;
    border-radius: 9999px; background: rgb(var(--color-text)); padding: 0 4px;
    font-family: var(--font-body, 'Manrope', sans-serif); font-size: 10px;
    line-height: 1; color: rgb(var(--color-bg));
  }
  .rose-header__cartcount[data-empty="true"] { display: none; }

  .rose-header__burger {
    display: flex; width: 20px; height: 20px; align-items: center;
    justify-content: center; background: none; border: none; cursor: pointer;
    color: rgb(var(--color-text)); flex-shrink: 0;
  }
  .rose-header__burger svg { width: 20px; height: 20px; display: block; }
  .rose-header__mobile-cart {
    position: relative; display: flex; width: 24px; height: 24px; align-items: center;
    justify-content: center; background: none; border: none; cursor: pointer;
    color: rgb(var(--color-text)); flex-shrink: 0;
  }
  .rose-header__mobile-cart svg { width: 24px; height: 24px; display: block; }
  .burger-icon.hidden { display: none; }

  .rose-search-panel {
    pointer-events: none; position: absolute; left: 0; right: 0; top: 100%;
    z-index: 40; width: 100%; overflow: hidden; max-height: 0;
    transition: max-height 0.3s ease-in-out;
  }
  .rose-search-panel__inner { padding: 8px 16px; }
  @media (min-width: 1024px) { .rose-search-panel__inner { padding: 8px 64px; } }
  @media (min-width: 1280px) { .rose-search-panel__inner { padding-left: 80px; padding-right: 80px; } }
  @media (min-width: 1536px) { .rose-search-panel__inner { padding-left: 280px; padding-right: 280px; } }
  .rose-search-form {
    pointer-events: auto; margin: 0 auto; display: flex; height: 48px; width: 100%;
    max-width: 1320px; align-items: center; gap: 8px; border-radius: 4px;
    border: 1px solid #e5e5e5; background: #fff; padding-left: 12px; padding-right: 4px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .rose-search-form input {
    flex: 1; min-width: 0; background: transparent; border: none; outline: none;
    padding: 4px 0; font-family: var(--font-body, 'Manrope', sans-serif);
    font-size: 16px; font-weight: 300; color: #000;
  }
  .rose-search-form input::placeholder { color: #999; }
  .rose-search-form button {
    display: flex; height: 40px; flex-shrink: 0; align-items: center; justify-content: center;
    border-radius: 4px; border: none; background: #000; padding: 0 12px;
    font-family: var(--font-body, 'Manrope', sans-serif); font-size: 14px; color: #fff; cursor: pointer;
  }

  .rose-burger-drawer {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 55; width: 100%;
    overflow-y: auto; background: #fff; padding: 16px 16px 32px;
  }
  .rose-burger-drawer.hidden { display: none; }
  @media (min-width: 1024px) { .rose-burger-drawer { display: none; } }
  .rose-burger-drawer__nav { display: flex; flex-direction: column; align-items: flex-start; gap: 20px; margin-top: 16px; }
  .rose-burger-drawer__link {
    font-family: var(--font-body, 'Manrope', sans-serif); font-size: 14px;
    color: rgb(var(--color-text)); text-decoration: none;
  }
</style>

<script is:inline>
  (function () {
    var panel = document.querySelector('[data-search-panel]');
    var burger = document.getElementById('rose-burger');
    var burgerBtn = document.getElementById('rose-burger-btn');

    function searchOpen() {
      return !!(panel && panel.style.maxHeight && panel.style.maxHeight !== '0px');
    }
    function setSearch(open) {
      if (!panel) return;
      panel.setAttribute('aria-hidden', String(!open));
      panel.style.maxHeight = open ? panel.scrollHeight + 'px' : '0px';
      document.querySelectorAll("[data-action='toggle-search']").forEach(function (b) {
        b.setAttribute('aria-expanded', String(open));
      });
    }
    function syncBurgerIcons(open) {
      if (!burgerBtn) return;
      burgerBtn.querySelectorAll('.burger-icon').forEach(function (el) {
        var k = el.getAttribute('data-icon');
        el.classList.toggle('hidden', k === 'open' ? open : !open);
      });
    }
    function setBurger(open) {
      if (!burger || !burgerBtn) return;
      if (open) setSearch(false);
      burger.classList.toggle('hidden', !open);
      burgerBtn.setAttribute('aria-expanded', String(open));
      syncBurgerIcons(open);
    }

    document.addEventListener('click', function (e) {
      var el = e.target instanceof Element ? e.target : null;
      if (!el) return;
      if (el.closest('#rose-burger-btn')) {
        e.preventDefault();
        setBurger(burger ? burger.classList.contains('hidden') : false);
      } else if (el.closest("[data-action='toggle-search']")) {
        e.preventDefault();
        setSearch(!searchOpen());
      } else if (el.closest('#rose-burger a[href]')) {
        setBurger(false);
      }
    });
  })();
</script>
