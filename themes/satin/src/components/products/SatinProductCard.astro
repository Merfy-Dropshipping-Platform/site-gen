---
import type { Product } from "../../types/product";
import SatinPicture from "../img/SatinPicture.astro";

interface Props {
	product: Product;
	priority?: boolean;
}

const { product, priority = false } = Astro.props;
const href = `/products/${product.id}`;
---

<article
	class="group flex h-full flex-col gap-3"
	data-nt="satin-product-card"
	aria-label={product.name}
>
	<div class="relative aspect-[430/564] w-full shrink-0 overflow-hidden bg-[#F5F5F5]">
		<a href={href} class="block size-full" aria-label={product.name}>
			{product.image ? (
				<SatinPicture
					src={product.image}
					alt={product.name}
					width="430"
					height="564"
					loading="eager"
					fetchpriority={priority ? "high" : undefined}
					class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
				/>
			) : (
				/* Товар без фото: surface-плейсхолдер вместо битого <img> (паттерн rose).
				   Разметку зеркалит CARD_MEDIA_FALLBACK_HTML в lib/storefront-hydrate.ts. */
				<div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
					<svg class="size-10" style="color:rgb(var(--color-muted,153 153 153))" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
					</svg>
				</div>
			)}
		</a>
		{product.discount && (
			<span class="pointer-events-none absolute left-0 top-0 inline-flex h-6 items-center bg-[#000000] px-2 font-manrope text-[12px] font-medium uppercase leading-none text-white">
				Скидка
			</span>
		)}
		{/* Избранное: overlay-сердце [data-wishlist-toggle] (механизм lib/wishlist.ts,
		    общий с rose). ИНЛАЙН-SVG (геометрия favourite.svg) — NtIcon (<img>) нельзя
		    перекрасить в 2 состояния. Острые углы satin. initWishlistUI (Layout) красит
		    filled/aria-pressed на загрузке + ведёт делегат клика. */}
		<button
			type="button"
			data-wishlist-toggle
			data-product-id={product.id}
			aria-label="В избранное"
			aria-pressed="false"
			class="satin-fav absolute right-3 top-3 z-20 flex size-8 items-center justify-center bg-white text-[#000000] shadow-[0_2px_8px_rgba(0,0,0,0.10)] transition-opacity hover:opacity-80"
		>
			<span data-wishlist-icon class="block size-[18px]">
				<svg viewBox="0 0 32 32" width="100%" height="100%" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="display:block">
					<g transform="translate(4.22 5.867)">
						<path d="M10.0342 18.882C6.93786 16.5652 0.8 11.2695 0.8 6.50305C0.8 3.35396 3.11131 0.8 6.29004 0.8C7.93705 0.8 9.58406 1.349 11.7801 3.54502C13.9761 1.349 15.6231 0.8 17.2701 0.8C20.4488 0.8 22.7601 3.35396 22.7601 6.50305C22.7601 11.2684 16.6223 16.5652 13.5259 18.882C12.4828 19.6616 11.0773 19.6616 10.0342 18.882Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
					</g>
				</svg>
			</span>
		</button>
	</div>
	<div class="flex flex-1 flex-col gap-1.5 md:gap-2">
		<a
			href={href}
			class="font-manrope text-[16px] font-normal uppercase leading-tight text-[#000000] hover:opacity-80"
		>
			{product.name}
		</a>
		<div class="flex flex-wrap items-baseline gap-1.5 md:gap-2">
			<span class="font-manrope text-[16px] font-normal leading-tight text-[#000000]">
				{product.price}
			</span>
			{product.oldPrice && (
				<span class="font-manrope text-[14px] font-light leading-tight text-[#999999] line-through">
					{product.oldPrice}
				</span>
			)}
		</div>
	</div>
	<button
		type="button"
		data-add-to-cart
		data-product-id={product.id}
		data-name={product.name}
		data-price={product.price}
		data-old-price={product.oldPrice ?? ""}
		data-image={product.image}
		class="flex h-11 w-full shrink-0 items-center justify-center bg-[#000000] px-3 font-manrope text-[14px] font-normal uppercase leading-none text-white transition-opacity hover:opacity-80"
	>
		В корзину
	</button>
</article>

{/* Избранное обслуживается ГЛОБАЛЬНО: initWishlistUI() в Layout.astro вешает
    делегат клика по [data-wishlist-toggle] и красит сердца/бейджи. Прежний
    локальный `satin-favourites`-скрипт удалён — один механизм (lib/wishlist.ts)
    вместо двух (как пилот rose). */}
