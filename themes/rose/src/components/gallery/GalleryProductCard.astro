---
interface Props {
	name: string;
	price: string;
	oldPrice: string;
	image: string;
}

const { name, price, oldPrice, image } = Astro.props;
---

<article class="flex flex-col gap-[20px]">
	<div class="w-full aspect-[430/430] bg-gray-100 rounded-[8px] overflow-hidden cursor-pointer">
		<img
			src={image}
			alt={name}
			decoding="async"
			class="w-full h-full object-cover"
		/>
	</div>
	<div class="flex flex-col gap-[4px]">
		<h3 class="font-manrope text-[14px] font-normal leading-none text-[#000000]">
			{name}
		</h3>
		<div class="flex items-center gap-[15px] flex-wrap">
			<span class="text-[16px] font-normal text-black font-manrope leading-[1.366]">
				{price}
			</span>
			<span class="text-[14px] font-normal text-[#999999] line-through leading-[1.366] font-manrope">
				{oldPrice}
			</span>
		</div>
	</div>
</article>
