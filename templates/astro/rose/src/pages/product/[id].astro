---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import products from '../../data/products.json';

// Puck block components — render content from pagesData['page-product'].content[]
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import PopularProducts from '../../components/PopularProducts.astro';
import Gallery from '../../components/Gallery.astro';
import TextBlock from '../../components/TextBlock.astro';
import MultiColumns from '../../components/MultiColumns.astro';
import MultiRows from '../../components/MultiRows.astro';
import Slideshow from '../../components/Slideshow.astro';
import Video from '../../components/Video.astro';
import ImageWithText from '../../components/ImageWithText.astro';
import ContactForm from '../../components/ContactForm.astro';
import PromoBanner from '../../components/PromoBanner.astro';
import Publications from '../../components/Publications.astro';
import CollapsibleSection from '../../components/CollapsibleSection.astro';
import Collections from '../../components/Collections.astro';
import Newsletter from '../../components/Newsletter.astro';
import Product from '../../components/Product.astro';

// SSG: getStaticPaths must return all product ids.
export function getStaticPaths() {
  const productList = ((products as unknown) as Array<{ id: string; slug?: string; handle?: string }>) ?? [];
  return productList.map((product) => ({
    params: { id: product.slug ?? (product as any).handle ?? product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const urlProductId = Astro.params.id as string;

// Resolve page-product blocks from multipage revision shape
const allPagesData = (data as any)?.pagesData ?? {};
const productPage =
  allPagesData['page-product'] ??
  ((data as any)?.currentPageId === 'page-product' ? data : null);

const pageBlocks: any[] = productPage?.content
  ? (Array.isArray(productPage.content) ? productPage.content : [])
  : [];

// Header/Footer fallbacks к home
const homePage = allPagesData['home'];
const homeBlocks: any[] = (homePage?.content && Array.isArray(homePage.content))
  ? homePage.content
  : [];
const headerBlock =
  pageBlocks.find((b: any) => b?.type === 'Header') ??
  homeBlocks.find((b: any) => b?.type === 'Header');
const footerBlock =
  pageBlocks.find((b: any) => b?.type === 'Footer') ??
  homeBlocks.find((b: any) => b?.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};

// Content blocks (excluding chrome)
const contentBlocks = pageBlocks.filter(
  (b: any) => b?.type && b.type !== 'Header' && b.type !== 'Footer'
);
const hasProductBlock = contentBlocks.some((b: any) => b.type === 'Product');

const componentMap: Record<string, any> = {
  Hero,
  PopularProducts,
  Gallery,
  TextBlock,
  MainText: TextBlock,
  MultiColumns,
  MultiRows,
  Slideshow,
  Video,
  ImageWithText,
  ContactForm,
  PromoBanner,
  Publications,
  CollapsibleSection,
  Collections,
  Newsletter,
  Product,
};

// SEO meta tags with fallback logic (preserved from previous implementation)
const meta = (data as any)?.meta ?? {};
const shopTitle = meta?.title ?? 'Мой магазин';
const rawMetaTitle = product?.metaTitle;
const rawMetaDescription = product?.metaDescription;
const productName = product?.name ?? 'Товар';
const productDescription = product?.description ?? '';

// Title: metaTitle (if non-empty) -> product name
const seoTitle = (rawMetaTitle && rawMetaTitle.trim())
  ? rawMetaTitle.trim()
  : productName;

// Description: metaDescription (if non-empty, as-is) -> truncated product description (160 chars) -> ""
const seoDescription = (rawMetaDescription && rawMetaDescription.trim())
  ? rawMetaDescription.trim()
  : (productDescription && productDescription.trim())
    ? productDescription.trim().slice(0, 160)
    : '';

// Page title includes shop name suffix
const pageTitle = `${seoTitle} — ${shopTitle}`;

// OG image fallback from product
const productImages: string[] = Array.isArray(product?.images)
  ? product.images.filter(Boolean)
  : product?.image
    ? [product.image]
    : [];
const mainImage = productImages[0] || null;
---
<BaseLayout
  title={pageTitle}
  description={seoDescription}
  ogTitle={seoTitle}
  ogDescription={seoDescription}
  ogImage={mainImage ?? undefined}
>
  <Header {...headerProps} />

  <main class="flex-1 w-full">
    {contentBlocks.map((block: any) => {
      const Component = componentMap[block.type];
      if (!Component) return null;
      // Inject productId into Product block so the universal block knows
      // which product to render. URL slug → looked up against products.json.
      const extraProps = block.type === 'Product' ? { productId: urlProductId } : {};
      return <Component {...(block.props ?? {})} {...extraProps} />;
    })}

    {/* Fallback: revision без Product блока — рендерим default Product */}
    {!hasProductBlock && (
      <Product productId={urlProductId} />
    )}
  </main>

  <Footer {...footerProps} />
</BaseLayout>
