---
// Фаза B (vanilla, группа misc): новая канон-секция CollapsibleSection в манере
// vanilla (см. themes/vanilla/MANNER.md; эталоны — themes/bloom CollapsibleSection,
// процесс-эталон rose T16). Схема полей = packages/theme-base/blocks/
// CollapsibleSection/CollapsibleSection.puckConfig.ts.
// ПУСТОЕ СОСТОЯНИЕ (без sections[]/items[]) = ПЛЕЙСХОЛДЕР по контракту Figma
// 1:19335 (заголовок «Сворачиваемый раздел» + ряд «Раздел» с хелпером «Ответь
// на самые популярные вопросы клиентов»), НЕ мок-демо верстальщика. Секции нет у
// верстальщика — нативный <details>/<summary> (Container-safe, без JS): заголовок
// = роль секции §1 (Bitter italic 20, #26311C на светлом), вопрос Arsenal 16
// uppercase, ответ
// Arsenal 14/16 muted, разделители в стиле строк «Стоимость» каталога (fc:33,
// цвет --vanilla-line #D9D9D2); chevron — svg дропдаунов каталога (Cat:117) с
// group-open-поворотом tailwind-классами, без <style>-блока.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading: string | { text, alignment, size }. Figma 1:19335 — ПУСТОЕ
// состояние секции «Сворачиваемый раздел»: дословный заголовок-плейсхолдер
// «Сворачиваемый раздел» (а НЕ дефолт-копирайт верстальщика «Часто задаваемые
// вопросы»). Роль = заголовок секции (Col:20), цвет — токен с пиксель-фоллбеком
// #26311C (38 49 28). Мерчант задал свой heading → его и рендерим.
const heading =
	typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Сворачиваемый раздел");
// Лестница §9 (база-литерал 20 = canon-default medium): small 17, large 24.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small" ? "text-[17px]" : headingSize === "large" ? "text-[24px]" : "text-[20px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-vanilla-bitter ${headingSizeCls} font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]${headingAlignCls}`;

// Канон sections[] 1-10 {heading, content} (+ pupa items[] {title, content}).
// Когда мерчант ЗАДАЛ пункты — рендерим ИХ (content = set:html, интерактивный
// <details>). Когда пусто — Figma 1:19335 ПУСТОЕ состояние: дословный
// ряд-плейсхолдер «Раздел» + хелпер-текст «Ответь на самые популярные вопросы
// клиентов» (а НЕ мок-демо верстальщика — раньше 2 вопроса про Vanila-бренд).
// Паттерн пустого состояния как Collections/MultiRows (паритет rose/bloom T16):
// один DEMO-ряд + лейбл/хелпер видны сразу, без интерактивного <details>
// (реального ответа нет). Shopify-модель: пустой выбор = заглушка, выбранное =
// данные.
const PLACEHOLDER_SECTIONS = [
	{ heading: "Раздел", content: "Ответь на самые популярные вопросы клиентов" },
];
// hasManualSections: мерчант явно добавил хотя бы одну строку (Shopify-модель).
const hasManualSections =
	(Array.isArray(p.sections) && p.sections.length > 0) ||
	(Array.isArray(p.items) && p.items.length > 0);
const isPlaceholder = !hasManualSections;
const rawSections = hasManualSections
	? Array.isArray(p.sections) && p.sections.length
		? p.sections
		: p.items
	: PLACEHOLDER_SECTIONS;
const sections = rawSections.slice(0, 10).map((s: any) => ({
	heading:
		(typeof s.heading === "string" && s.heading) || (typeof s.title === "string" && s.title) || "",
	content: typeof s.content === "string" ? s.content : "",
}));

// Канон containerEnabled (toggle; legacy container.enabled) — подложка манеры §4
// (медиа-подложка #ECEBE7, БЕЗ радиуса — у vanilla всё плоское) вокруг списка.
// Canon-default отсутствует → false = голый список.
const containerEnabled = String(p.containerEnabled ?? p.container?.enabled ?? "false") === "true";
// Канон Nikita: класс схемы контейнера вешаем ТОЛЬКО при включённом контейнере.
// При ВЫКЛ контейнеров нет → работает основная (секционная) цв. схема.
const containerSchemeCls =
	containerEnabled && typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";
const listWrapCls = containerEnabled
	? `bg-[rgb(var(--color-surface,236_235_231))] p-6 md:p-10${containerSchemeCls}`
	: containerSchemeCls.trim();

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="vanilla-pad w-full bg-[rgb(var(--color-bg,238_238_238))] py-20 md:py-28"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="vanilla-container flex max-w-[1180px] flex-col gap-8">
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-animate
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
					set:html={heading}
				/>
			)
		}
		<div class={listWrapCls} data-animate data-animate-delay="0.1s">
			<ul class="flex w-full flex-col" role="list">
				{
					sections.map((s, i) => (
						<li
							class="border-b border-solid border-[rgb(var(--color-muted,217_217_210))]"
							data-puck-subsection-parent={isPlaceholder ? undefined : id}
							data-puck-subsection-index={isPlaceholder ? undefined : i}
							data-puck-subsection-field={isPlaceholder ? undefined : "sections"}
						>
							{isPlaceholder ? (
								/* Figma 1:19335 ПУСТОЕ состояние: дословный ряд-плейсхолдер —
								   лейбл «Раздел» (роль вопроса) + хелпер-текст «Ответь на самые
								   популярные вопросы клиентов». Без интерактивного <details>:
								   реального ответа нет, помощь видна сразу (паттерн пустого
								   состояния Collections/MultiRows). Шеврон сохранён для вида. */
								<div class="flex w-full flex-col gap-2 py-5">
									<div class="flex w-full items-center justify-between gap-4 font-vanilla-arsenal text-base font-normal uppercase leading-snug text-[rgb(var(--color-text,10_10_10))]">
										<span class="min-w-0 flex-1 break-words">{s.heading}</span>
										<svg
											aria-hidden="true"
											viewBox="0 0 10 6"
											fill="none"
											class="h-[6px] w-[10px] shrink-0 rotate-180"
										>
											<path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" />
										</svg>
									</div>
									<p class="font-vanilla-arsenal text-[14px] font-normal leading-[1.45] text-[rgb(var(--color-muted,68_68_68))] lg:text-base">
										{s.content}
									</p>
								</div>
							) : (
								<details class="group">
									<summary class="cursor-pointer list-none py-5 [&::-webkit-details-marker]:hidden">
										<div class="flex w-full items-center justify-between gap-4 font-vanilla-arsenal text-base font-normal uppercase leading-snug text-[rgb(var(--color-text,10_10_10))] transition-opacity hover:opacity-70">
											<span class="min-w-0 flex-1 break-words" set:html={s.heading} />
											<svg
												aria-hidden="true"
												viewBox="0 0 10 6"
												fill="none"
												class="h-[6px] w-[10px] shrink-0 transition-transform duration-300 group-open:rotate-180"
											>
												<path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" />
											</svg>
										</div>
									</summary>
									<div
										class="pb-5 font-vanilla-arsenal text-[14px] font-normal leading-[1.45] text-[rgb(var(--color-muted,68_68_68))] lg:text-base"
										set:html={s.content}
									/>
								</details>
							)}
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
