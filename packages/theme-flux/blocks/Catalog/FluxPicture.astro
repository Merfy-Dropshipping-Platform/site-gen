---
/**
 * FluxPicture (порт из themes/flux/src/components/img/FluxPicture.astro).
 * Тонкая обёртка <picture> с WebP-source. Без внешних импортов — копия 1:1.
 *
 * Атрибут `src` указывает на PNG/JPG в /public/. Рядом должен лежать соимённый
 * .webp (генерируется images:optimize). Загруженные пользователем картинки
 * (http(s)/MinIO/data:) рендерятся сквозным <img> без srcset-трансформации.
 */
interface Props {
  src: string;
  alt: string;
  width?: number | string;
  height?: number | string;
  class?: string;
  /** "eager" по умолчанию. Lazy задавать явно. */
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
  decoding?: "sync" | "async" | "auto";
  sizes?: string;
  /** Доп. data-атрибуты на <img>. */
  [key: `data-${string}`]: string | number | boolean | undefined;
}

const {
  src,
  alt,
  width,
  height,
  class: className,
  loading = "eager",
  fetchpriority,
  decoding = "async",
  sizes,
  ...rest
} = Astro.props as Props;

// WebP-source только для ЛОКАЛЬНЫХ ассетов темы (/public/*.png рядом лежит .webp).
// Для внешних URL (MinIO, загруженные мерчантом) соимённого .webp нет —
// иначе <source> отдаёт битый webp и картинка не показывается.
const isLocalThemeAsset = src.startsWith("/") && !src.startsWith("//");
const webp = src.replace(/\.(png|jpe?g)$/i, ".webp");
const hasWebp = isLocalThemeAsset && webp !== src;
---

<picture class="contents">
  {hasWebp && <source srcset={webp} type="image/webp" />}
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class={className}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding={decoding}
    sizes={sizes}
    {...rest}
  />
</picture>
