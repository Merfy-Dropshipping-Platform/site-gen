---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/data.json';
import siteConfig from '../../data/site-config.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};
---
<BaseLayout title={`Заказ — ${meta?.title ?? 'Мой сайт'}`}>
  <Header {...headerProps} />

  <main class="account-page-container">
    <a href="/account/orders" class="account-back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Вернуться назад
    </a>

    <div class="account-title">
      <h1>Активные заказы</h1>
      <span class="account-subtitle" id="order-subtitle">Загрузка...</span>
    </div>

    <div id="order-loading" style="color: rgb(var(--color-text-muted)); font-family: var(--font-body);">Загрузка...</div>

    <div id="order-not-found" class="hidden" style="font-family: var(--font-body); color: rgb(var(--color-text-muted));">
      Заказ не найден. <a href="/account/orders" class="account-text-link" style="font-size: 0.875rem;">Вернуться к заказам</a>
    </div>

    <div id="order-meta" class="account-order-meta hidden"></div>
    <div id="order-content" class="account-order-columns hidden">
      <div id="order-products" style="display: flex; flex-direction: column; gap: 0.75rem;"></div>
      <div id="order-info" class="account-info-container"></div>
    </div>
  </main>

  <Footer {...footerProps} />

  <div id="cancel-modal" class="hidden" style="position: fixed; inset: 0; z-index: 50;">
    <div id="cancel-modal-overlay" style="position: fixed; inset: 0; background: rgba(0,0,0,0.4);"></div>
    <div style="position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; padding: 1rem;">
      <div style="background: rgb(var(--color-background)); border-radius: var(--radius-card); box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); max-width: 28rem; width: 100%; padding: 1.5rem;">
        <h3 style="font-family: var(--font-heading); font-size: 1.125rem; margin: 0 0 0.5rem;">Отмена заказа</h3>
        <p style="font-family: var(--font-body); font-size: 0.875rem; color: rgb(var(--color-text-muted)); margin: 0 0 1rem;">После отмены восстановить заказ невозможно.</p>
        <textarea id="cancel-reason" rows="3" maxlength="500" required placeholder="Укажите причину отмены" class="auth-input" style="height: auto; padding: 0.75rem 1rem; resize: none; margin-bottom: 0.5rem;"></textarea>
        <p id="cancel-error" class="hidden" style="font-family: var(--font-body); font-size: 0.75rem; color: rgb(var(--color-error)); margin: 0 0 0.75rem;"></p>
        <div style="display: flex; gap: 0.75rem;">
          <button id="btn-cancel-confirm" type="button" class="account-button" style="flex: 1; background: rgb(var(--color-error));">Подтвердить отмену</button>
          <button id="btn-cancel-close" type="button" class="account-button" style="flex: 1; background: transparent; color: rgb(var(--color-foreground)); border: 1px solid rgb(var(--color-border));">Нет, оставить</button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline src="/scripts/customer-store.js"></script>
  <script is:inline src="/scripts/customer-auth.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', async function() {
      if (!window.CustomerStore || !window.CustomerStore.isLoggedIn()) {
        var currentPath = window.location.pathname + window.location.search;
        window.location.href = '/login?redirect=' + encodeURIComponent(currentPath);
        return;
      }

      var params = new URLSearchParams(window.location.search);
      var orderNumber = params.get('n');

      if (!orderNumber) {
        document.getElementById('order-loading').classList.add('hidden');
        document.getElementById('order-not-found').classList.remove('hidden');
        return;
      }

      var loadingEl = document.getElementById('order-loading');
      var notFoundEl = document.getElementById('order-not-found');
      var subtitleEl = document.getElementById('order-subtitle');
      var metaEl = document.getElementById('order-meta');
      var contentEl = document.getElementById('order-content');
      var productsEl = document.getElementById('order-products');
      var infoEl = document.getElementById('order-info');

      var statusLabels = {
        cart: 'Корзина', pending: 'Ожидает оплаты', paid: 'Оплачен',
        processing: 'В сборке', sent: 'Отправлен', delivered: 'Доставлен',
        cancelled: 'Отменён', refunded: 'Возврат',
      };

      function formatPrice(cents) {
        if (!cents && cents !== 0) return '—';
        return (cents / 100).toLocaleString('ru-RU') + ' ₽';
      }

      try {
        var config = window.__MERFY_CONFIG__ || {};
        var apiUrl = config.apiUrl || '';
        var storeId = config.shopId || config.storeId || config.siteId || '';
        var token = window.CustomerStore.getToken();

        var url = apiUrl + '/store/orders/' + encodeURIComponent(orderNumber);
        if (storeId) url += '?store_id=' + encodeURIComponent(storeId);

        var resp = await fetch(url, {
          headers: { 'Authorization': 'Bearer ' + token },
        });

        loadingEl.classList.add('hidden');

        if (resp.status === 404) {
          notFoundEl.classList.remove('hidden');
          return;
        }

        var result = await resp.json();
        if (!result.success || !result.data) {
          notFoundEl.classList.remove('hidden');
          return;
        }

        var order = result.data;
        subtitleEl.textContent = 'Заказ №' + order.orderNumber;

        var date = new Date(order.createdAt).toLocaleDateString('ru-RU', {
          day: '2-digit', month: '2-digit', year: '2-digit',
        });
        var itemsCount = order.items ? order.items.length : 0;
        var countWord = 'товаров';
        var lastDigit = itemsCount % 10;
        var lastTwo = itemsCount % 100;
        if (lastTwo >= 11 && lastTwo <= 19) countWord = 'товаров';
        else if (lastDigit === 1) countWord = 'товар';
        else if (lastDigit >= 2 && lastDigit <= 4) countWord = 'товара';

        metaEl.innerHTML = '<span>' + itemsCount + ' ' + countWord + '</span><span>от ' + date + '</span>';
        metaEl.classList.remove('hidden');

        // Render product cards
        if (order.items && order.items.length) {
          order.items.forEach(function(item) {
            var imgHtml = item.imageUrl
              ? '<img src="' + item.imageUrl + '" alt="" loading="lazy">'
              : '<div style="width: 5rem; height: 5rem; background: rgb(var(--color-surface-muted)); border-radius: var(--radius-field); flex-shrink: 0;"></div>';

            var oldPrice = '';
            if (item.comparePriceCents && item.comparePriceCents > item.priceCents) {
              oldPrice = '<span class="product-price-old">' + formatPrice(item.comparePriceCents) + '</span>';
            }

            var variant = '';
            if (item.variantLabel || (item.options && Object.keys(item.options).length)) {
              var vText = item.variantLabel || Object.values(item.options || {}).join(', ');
              variant = '<span class="product-variant">' + vText + '</span>';
            }

            var card = document.createElement('div');
            card.className = 'account-product-card';
            card.innerHTML =
              imgHtml +
              '<div class="product-info">' +
                '<span class="product-name">' + (item.productName || 'Товар') + '</span>' +
                '<span class="product-prices">' +
                  '<span class="product-price">' + formatPrice(item.priceCents) + '</span>' +
                  oldPrice +
                '</span>' +
                variant +
              '</div>' +
              '<span class="product-qty">' + item.quantity + ' шт.</span>';
            productsEl.appendChild(card);
          });
        }

        // Render info grid
        var status = statusLabels[order.status] || order.status;

        var deliveryMethod = '—';
        if (order.deliveryType === 'pickup') deliveryMethod = 'Самовывоз';
        else if (order.deliveryType && order.deliveryType.includes('cdek')) deliveryMethod = 'СДЭК';
        else if (order.deliveryProfileName) deliveryMethod = order.deliveryProfileName;
        else if (order.deliveryType) deliveryMethod = order.deliveryType;

        var address = '—';
        if (order.shippingAddress) {
          var a = order.shippingAddress;
          var parts = [a.city, a.street, a.building ? 'д. ' + a.building : ''].filter(Boolean);
          if (parts.length) address = parts.join(', ');
        }
        if (order.deliveryType === 'pickup' && order.pickupAddress) {
          address = order.pickupAddress;
        }

        var deliveryDate = '—';
        if (order.deliveryPeriodMin && order.deliveryPeriodMax) {
          deliveryDate = order.deliveryPeriodMin + '–' + order.deliveryPeriodMax + ' дней';
        }

        var paymentMethod = 'Онлайн';

        var gridHtml =
          '<div class="account-info-grid">' +
            '<div class="account-info-cell"><span class="info-label">Статус</span><span class="info-value">' + status + '</span></div>' +
            '<div class="account-info-cell"><span class="info-label">Номер заказа</span><span class="info-value">№' + order.orderNumber + '</span></div>' +
            '<div class="account-info-cell"><span class="info-label">Способ доставки</span><span class="info-value">' + deliveryMethod + '</span></div>' +
            '<div class="account-info-cell"><span class="info-label">Адрес доставки</span><span class="info-value">' + address + '</span></div>' +
            '<div class="account-info-cell"><span class="info-label">Дата доставки</span><span class="info-value">' + deliveryDate + '</span></div>' +
            '<div class="account-info-cell"><span class="info-label">Способ оплаты</span><span class="info-value">' + paymentMethod + '</span></div>' +
          '</div>' +
          '<div class="account-info-cell"><span class="info-label">Итоговая стоимость</span><span class="info-value">' + formatPrice(order.totalCents) + '</span></div>';

        infoEl.innerHTML = gridHtml;
        contentEl.classList.remove('hidden');

        // Cancel button (for paid/processing orders)
        var cancellableStatuses = ['paid', 'processing'];
        var blockedDelivery = ['IN_TRANSIT', 'DELIVERED', 'NOT_DELIVERED', 'RECEIVED', 'RETURNED'];
        var canCancel = cancellableStatuses.indexOf(order.status) !== -1 &&
          (!order.deliveryStatus || blockedDelivery.indexOf(order.deliveryStatus) === -1);

        if (canCancel) {
          var cancelBtn = document.createElement('button');
          cancelBtn.type = 'button';
          cancelBtn.className = 'account-text-link';
          cancelBtn.style.cssText = 'color: rgb(var(--color-error)); margin-top: 1rem;';
          cancelBtn.textContent = 'Отменить заказ';
          contentEl.parentElement.appendChild(cancelBtn);

          var modal = document.getElementById('cancel-modal');
          var overlay = document.getElementById('cancel-modal-overlay');
          var btnClose = document.getElementById('btn-cancel-close');
          var btnConfirm = document.getElementById('btn-cancel-confirm');
          var reasonEl = document.getElementById('cancel-reason');
          var errorEl = document.getElementById('cancel-error');

          function openModal() { modal.classList.remove('hidden'); }
          function closeModal() { modal.classList.add('hidden'); errorEl.classList.add('hidden'); }

          cancelBtn.addEventListener('click', openModal);
          overlay.addEventListener('click', closeModal);
          btnClose.addEventListener('click', closeModal);

          btnConfirm.addEventListener('click', async function() {
            var reason = (reasonEl.value || '').trim();
            if (!reason) {
              errorEl.textContent = 'Укажите причину отмены';
              errorEl.classList.remove('hidden');
              return;
            }
            btnConfirm.disabled = true;
            btnConfirm.textContent = 'Отменяем...';
            errorEl.classList.add('hidden');

            try {
              var cancelUrl = apiUrl + '/store/orders/' + encodeURIComponent(orderNumber) + '/cancel';
              if (storeId) cancelUrl += '?store_id=' + encodeURIComponent(storeId);

              var cancelResp = await fetch(cancelUrl, {
                method: 'POST',
                headers: {
                  'Authorization': 'Bearer ' + token,
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify({ reason: reason }),
              });

              var cancelResult = await cancelResp.json();
              if (cancelResult.success) {
                window.location.reload();
              } else {
                errorEl.textContent = cancelResult.error || 'Не удалось отменить заказ';
                errorEl.classList.remove('hidden');
                btnConfirm.disabled = false;
                btnConfirm.textContent = 'Подтвердить отмену';
              }
            } catch (e) {
              errorEl.textContent = 'Ошибка сети. Попробуйте позже.';
              errorEl.classList.remove('hidden');
              btnConfirm.disabled = false;
              btnConfirm.textContent = 'Подтвердить отмену';
            }
          });
        }
      } catch (err) {
        loadingEl.textContent = 'Не удалось загрузить заказ';
      }
    });
  </script>
</BaseLayout>
