---
import NtSectionHeading from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtSectionHeading.astro";

// ОЖИВЛЕНИЕ (Фаза B, контракт bloom Collections): конструкторная схема
// theme-base Collections.puckConfig поверх разметки верстальщика. Тело +
// demo-данные verbatim (страницы зовут <Collections /> без пропсов — дефолты
// дают прежний рендер). Канон-дефолты конструктора (headingSize/subtitleSize
// small = литерал DS, columns 3, imageView 'square' → литерал 430/500) →
// пиксель верстальщика; дефолтная ветка каждого тернарника = прежняя строка
// классов байт-в-байт (цвета → токены с пиксель-фоллбеком родных литералов,
// MANNER.md §7). Скролл-анимаций нет — манера flux статична (MANNER.md §6).
const p = Astro.props as Record<string, any>;
const id = p.id;
// Figma 1:19335 — ПУСТОЕ состояние секции «Список коллекций»: дословный заголовок
// «Список коллекций» (без подзаголовка), а НЕ дефолт-копирайт верстальщика
// («Категории» / «Смартфоны, наушники, ноутбуки…»). Эталон — rose Collections.astro.
// Мерчант задал свой heading/subtitle → его и рендерим (?? срабатывает только при
// пустых данных; пустая строка subtitle скрывает <p> внутри DS-шапки).
const sectionTitle =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title ?? "Список коллекций";
const sectionSubtitle =
	(typeof p.subtitle === "string" ? p.subtitle : undefined) ?? "";

// Шапка — DS-компонент NtSectionHeading: класс внутрь не пробрасывается,
// размеры — через перекрытия на обёртке (лестница §9 от lg-базы 32 / xl-базы
// 24). Дефолт и 'small' = литерал DS (20/24/32 + 14/18/24) без перекрытий.
const headingSize = p.headingSize ?? p.heading?.size;
const headingSizeCls =
	headingSize === "medium"
		? " [&_h2]:!text-[38px]"
		: headingSize === "large"
			? " [&_h2]:!text-[46px]"
			: "";
const subtitleSizeCls =
	p.subtitleSize === "medium"
		? " [&_p]:!text-[29px]"
		: p.subtitleSize === "large"
			? " [&_p]:!text-[35px]"
			: "";
// Схемы flux включают ТЁМНЫЕ (scheme-1 bg 0 0 0) — хардкоды DS-шапки
// (#000000/#999999) всегда перекрываются токенами; фоллбеки = литералы DS →
// без схемы пиксель не меняется (MANNER.md §7).
const headColorCls =
	" [&_h2]:!text-[rgb(var(--color-heading,0_0_0))] [&_p]:!text-[rgb(var(--color-muted,153_153_153))]";
// Канон titleAlignment: центр = литерал DS (шапка flux центрована); left/right
// двигают заголовок и подзаголовок перекрытиями на обёртке.
const titleAlignCls =
	p.titleAlignment === "left"
		? " [&>div]:!items-start [&_h2]:!text-left [&_p]:!text-left"
		: p.titleAlignment === "right"
			? " [&>div]:!items-end [&_h2]:!text-right [&_p]:!text-right"
			: "";
const headWrapCls = [headingSizeCls, subtitleSizeCls, headColorCls, titleAlignCls].join("").trim();

// Канон columns 1-6: 3 (canon-default puckConfig) и отсутствие → дефолт-ветка
// (1→sm:2→lg:3). Заданное значение применяется уже с sm: раньше — только с lg,
// потому на sm-md (640-1023px) залипало 2 и слайдер игнорировался. Моб (<sm) = 1.
const colsRaw =
	typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : undefined;
const cols = colsRaw && colsRaw !== 3 ? colsRaw : undefined;
const gridBase = "grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3";
const gridCls = cols
	? "grid grid-cols-1 gap-6 sm:grid-cols-[repeat(var(--cols),minmax(0,1fr))]"
	: gridBase;
const gridStyle = cols ? `--cols:${cols}` : undefined;

// Канон gridAspect/imageView: дефолт (canon-default 'portrait' конструктора) =
// литерал плитки aspect-[430/500] (FluxCollectionCard); gridAspect '1:1' или
// imageView 'square' → квадрат, imageView 'wide' → 16/9. Раньше ветки 'square'
// не было → выбор «квадрат» падал в портрет 430/500 (как rose tileAspectCls).
// Дефолт-ветка (portrait/отсутствие) остаётся 430/500 байт-в-байт.
const tileAspect =
	p.gridAspect === "1:1" || p.imageView === "square"
		? "aspect-square"
		: p.imageView === "wide"
			? "aspect-[16/9]"
			: "aspect-[430/500]";
// Канон cardCaptionStyle: 'default' и отсутствие = обычный регистр подписи
// верстальщика; 'uppercase' — капсом.
const captionCase = p.cardCaptionStyle === "uppercase" ? " uppercase" : "";

// Канон collections[] (≤10): плитки коллекций из пропса при непустом массиве.
// Иначе — плейсхолдер пустого состояния (PLACEHOLDER_COLLECTIONS, ниже). SSR
// рендерит сохранённые поля item, резолв collectionId → имя/обложка делает
// гидрация ниже (data-collection-ref): live — /data/collections.json, превью —
// storefront-data; паритет theme-base (имя коллекции перебивает ручной
// heading, обложка — только при пустой своей).
const cardLinkBase =
	typeof p.cardLinkBase === "string" && p.cardLinkBase.trim() ? p.cardLinkBase : "/catalog?collection=";
const propCollections = (Array.isArray(p.collections) ? p.collections : [])
	.filter((c: any) => c && typeof c === "object")
	.slice(0, 10)
	.map((c: any, i: number) => {
		const collectionId =
			typeof c.collectionId === "string" && c.collectionId.trim() ? c.collectionId.trim() : null;
		return {
			collectionId,
			name:
				(typeof c.heading === "string" && c.heading) ||
				(typeof c.name === "string" && c.name) ||
				"Коллекция",
			// Плейсхолдер пустого состояния (Figma 1:19335, паритет rose T15):
			// карточка без выбранной картинки = ПУСТАЯ surface-плитка (НЕ мок-фото
			// верстальщика /images/4x/Коллекция_N.png — нарушало rose-эталон). На
			// live гидрация (data-collection-ref) подставит реальное фото коллекции
			// по collectionId; SSR-гард {c.image && <img>} держит surface пустой.
			image: typeof c.image === "string" && c.image ? c.image : "",
			hasOwnImage: !!(typeof c.image === "string" && c.image),
			href: collectionId ? `${cardLinkBase}${collectionId}` : "#",
		};
	});
const usePropCollections = propCollections.length > 0;

// SSR-резолв реальных коллекций по collectionId (Figma-цель: коллекция ВЫБРАНА →
// реальное имя/обложка ПРЯМО в статике, чтобы их видело и ПРЕВЬЮ конструктора —
// Astro Container не исполняет клиентскую module-гидрацию ниже). Эталон —
// rose Collections.astro / flux Popular.astro (siteId инжектит рендер-пайплайн
// preview.service / build). Нет siteId / выбранных collectionId / ошибка →
// resolved пуст → остаётся SSR (heading/обложка из пропса), а живая гидрация
// ниже освежит данные на live. Паритет theme-base resolveManual: имя коллекции
// перебивает ручной heading, обложка подставляется только при пустой своей.
const siteId = typeof p.siteId === "string" ? p.siteId : "";
const wantResolve = usePropCollections && propCollections.some((c) => c.collectionId);
const resolvedCols = new Map<string, { name?: string; image?: string }>();
if (wantResolve && siteId) {
	try {
		const base = (import.meta as any).env?.SITES_INTERNAL_BASE ?? "http://localhost:3114";
		const res = await fetch(`${base}/api/sites/${siteId}/storefront-data`).catch(() => null);
		if (res && res.ok) {
			const data: any = await res.json();
			const cols: any[] = Array.isArray(data?.collections) ? data.collections : [];
			for (const c of propCollections) {
				if (!c.collectionId) continue;
				const m = cols.find(
					(x) =>
						x &&
						(x.id === c.collectionId ||
							x.slug === c.collectionId ||
							x.name === c.collectionId ||
							x.handle === c.collectionId),
				);
				if (!m) continue;
				const cover =
					(typeof m.image === "string" && m.image) ||
					(Array.isArray(m.images) && typeof m.images[0] === "string" ? m.images[0] : "");
				resolvedCols.set(c.collectionId, {
					name: typeof m.name === "string" ? m.name : undefined,
					image: cover || undefined,
				});
			}
		}
	} catch {
		/* нет данных — остаётся SSR из пропса, гидрация освежит на live */
	}
}
// Применяем резолв к карточкам пропса: реальное имя перебивает ручной heading,
// обложка — только если мерчант не загрузил свою.
const resolvedCollections = propCollections.map((c) => {
	const r = c.collectionId ? resolvedCols.get(c.collectionId) : undefined;
	if (!r) return c;
	return {
		...c,
		name: r.name || c.name,
		image: c.hasOwnImage ? c.image : r.image || c.image,
	};
});

// Плейсхолдер пустого состояния (Figma 1:19335, контракт theme-base Collections
// DEMO_COLLECTIONS): без ручного выбора — 3 карточки с пустым rounded-rect
// (bg #FBFBFB / rgb(var(--color-surface))) и подписью «Коллекция». НЕ мок-демо
// верстальщика (раньше тут рендерились хардкод Смартфоны/Наушники/Ноутбуки с
// /images/4x/Коллекция_N.png). Реальные коллекции магазина при пустом пикере
// подтягивает autofillCollections (hydration ниже).
const PLACEHOLDER_COLLECTIONS = [
	{ name: "Коллекция" },
	{ name: "Коллекция" },
	{ name: "Коллекция" },
];

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id="collections"
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-16 pt-16 md:px-20 md:pb-24 md:pt-24 2xl:px-80"
	aria-labelledby="collections-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-8 md:gap-12">
		<div
			class={headWrapCls}
			data-puck-subsection-parent={id}
			data-puck-subsection-index="100"
			data-puck-subsection-field="heading"
			data-reveal
		>
			<NtSectionHeading titleId="collections-title" title={sectionTitle} subtitle={sectionSubtitle} />
		</div>

		<ul class={gridCls} role="list" style={gridStyle} data-collections-autofill={!usePropCollections ? "" : undefined}>
			{usePropCollections ? resolvedCollections.map((c, i) => (
				<li>
					<a
						href={c.href}
						class="group flex cursor-pointer flex-col gap-4 md:gap-5"
						aria-label={c.name}
						data-nt="flux-collection-card"
						data-collection-ref={c.collectionId ?? undefined}
						data-own-image={c.hasOwnImage ? "true" : undefined}
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="collections"
					>
						<div
							class={`${tileAspect} w-full overflow-hidden bg-[rgb(var(--color-surface,245_245_245))] rounded-[var(--radius-media,8px)]`}
							aria-hidden={c.image ? undefined : "true"}
						>
							{c.image && (
								<img
									src={c.image}
									alt={c.name}
									loading="lazy"
									class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
								/>
							)}
						</div>
						<h3
							class={`flux-collection-name font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]${captionCase}`}
						>
							{c.name}
						</h3>
					</a>
				</li>
			)) : PLACEHOLDER_COLLECTIONS.map((c) => (
				<li>
					<div
						class="group flex flex-col gap-4 md:gap-5"
						data-nt="flux-collection-card-placeholder"
						aria-label={c.name}
					>
						<div
							class={`${tileAspect} w-full overflow-hidden bg-[rgb(var(--color-surface,251_251_251))] rounded-[var(--radius-media,8px)]`}
							aria-hidden="true"
						></div>
						<h3
							class={`flux-collection-name font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]${captionCase}`}
						>
							{c.name}
						</h3>
					</div>
				</li>
			))}
		</ul>
	</div>
</section>

<script>
	import { loadRealCollections, findCollection, escapeHtml } from "../../lib/storefront-hydrate";

	// Резолв collectionId → имя/обложка на плитках (data-collection-ref).
	// Паритет theme-base resolveManual: имя коллекции перебивает ручной heading;
	// обложка коллекции подставляется, только если мерчант не загрузил свою
	// (data-own-image). Без данных (demo-сборка) — no-op, SSG остаётся.
	const hydrateCollectionTiles = async () => {
		const tiles = Array.from(
			document.querySelectorAll<HTMLElement>('[data-nt="flux-collection-card"][data-collection-ref]'),
		);
		if (tiles.length === 0) return;
		const collections = await loadRealCollections();
		if (!collections) return;
		for (const tile of tiles) {
			const col = findCollection(collections, tile.getAttribute("data-collection-ref"));
			if (!col) continue;
			if (col.name) {
				const h3 = tile.querySelector(".flux-collection-name");
				if (h3 && h3.textContent !== col.name) h3.textContent = col.name;
				tile.setAttribute("aria-label", col.name);
			}
			const cover = col.image || (Array.isArray(col.images) ? col.images[0] : "");
			if (cover && tile.getAttribute("data-own-image") !== "true") {
				const img = tile.querySelector("img");
				if (img && img.getAttribute("src") !== cover) {
					img.setAttribute("src", cover);
					if (col.name) img.setAttribute("alt", col.name);
				}
			}
		}
	};

	// АВТОПОДСТАНОВКА: пустой пикер (SSR = плейсхолдеры «Коллекция») → реальные
	// коллекции магазина из /data/collections.json (live) / storefront-data (превью).
	// Прежде показывались фейк-демо, что вводило в заблуждение. Явный выбор в пикере
	// имеет приоритет (грид не помечен data-collections-autofill). Реальных нет
	// (demo-сборка без collections.json) → no-op, плейсхолдеры остаются. Разметка
	// плитки = propCollections-ветка flux (canon-default при пустом пикере: imageView
	// 'portrait' → aspect-[430/500], cardCaptionStyle 'default' → без капса).
	// Обложка: своя картинка коллекции, иначе ПУСТАЯ surface-плитка (контракт Figma
	// 1:19335 / rose-эталон — у секции «Список коллекций» нет плейсхолдер-ассета;
	// мок-пути /images/4x/Коллекция_N.png убраны, паритет SSR-гарда {c.image && img}).
	const autofillCollections = async () => {
		const grids = Array.from(document.querySelectorAll<HTMLElement>("ul[data-collections-autofill]"));
		if (grids.length === 0) return;
		const collections = await loadRealCollections();
		if (!collections || collections.length === 0) return;
		const visible = collections.filter((c) => c && c.slug !== "general").slice(0, 6);
		if (visible.length === 0) return;
		const html = visible
			.map((c) => {
				const name = escapeHtml(c.name || "Коллекция");
				const ref = c.slug || c.id || "";
				const href = "/catalog?collection=" + encodeURIComponent(ref);
				const cover = c.image || (Array.isArray(c.images) ? c.images[0] : "");
				const media = cover
					? `<img src="${escapeHtml(cover)}" alt="${name}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]" />`
					: "";
				return `<li><a href="${href}" class="group flex cursor-pointer flex-col gap-4 md:gap-5" aria-label="${name}" data-nt="flux-collection-card">
			<div class="aspect-[430/500] w-full overflow-hidden bg-[rgb(var(--color-surface,245_245_245))] rounded-[var(--radius-media,8px)]"${cover ? "" : ' aria-hidden="true"'}>${media}</div>
			<h3 class="flux-collection-name font-manrope text-[14px] font-normal leading-[1.366] text-[rgb(var(--color-text,0_0_0))] md:text-[16px]">${name}</h3>
		</a></li>`;
			})
			.join("");
		for (const grid of grids) grid.innerHTML = html;
	};

	hydrateCollectionTiles();
	autofillCollections();
	document.addEventListener("astro:page-load", () => {
		hydrateCollectionTiles();
		autofillCollections();
	});
</script>
