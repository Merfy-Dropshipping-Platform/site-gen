---
/**
 * ProductGallery — image gallery primitive.
 *
 * Variants:
 *  - `wrap-large` (rose, default) — main 1:1 rounded-8, then 2 thumbs 318×318
 *    wrapping below; discount badge sits top-left of main image.
 *  - `inline-small` (flux) — main 1:1 rounded-12, then 2 thumbs 124×124 in a
 *    single row; thumbs may have a translucent overlay for inactive state.
 *
 * Receives normalised `GalleryView` — never sees raw API shape.
 */
import type { GalleryView } from '../Product.types';

interface Props {
  gallery: GalleryView;
  variant?: 'wrap-large' | 'inline-small';
  showDiscountBadge?: boolean;
  hasDiscount?: boolean;
  badgeText?: string;
}

const {
  gallery,
  variant = 'wrap-large',
  showDiscountBadge = false,
  hasDiscount = false,
  badgeText = 'Скидка',
} = Astro.props as Props;

const isInlineSmall = variant === 'inline-small';
const heroRadius = isInlineSmall ? 'rounded-[12px]' : 'rounded-[8px]';
const thumbRadius = isInlineSmall ? 'rounded-[8px]' : 'rounded-[8px]';
---
<div class="w-full" data-product-gallery data-gallery-variant={variant}>
  {gallery.hero ? (
    <div class:list={[
      'relative w-full overflow-hidden bg-[rgb(var(--color-surface,var(--color-text)/0.05))]',
      heroRadius,
    ]} style="aspect-ratio:1/1;" data-product-hero>
      <img
        src={gallery.hero.src}
        alt={gallery.hero.alt}
        loading="eager"
        class="absolute inset-0 w-full h-full object-cover block"
        data-product-hero-image
      />
      {showDiscountBadge && hasDiscount && (
        <div
          class="absolute top-3 left-3 inline-flex items-center justify-center h-6 px-1.5 rounded-[4px] text-xs [font-family:var(--font-body)]"
          style="background:rgb(var(--color-text)); color:rgb(var(--color-bg));"
        >
          {badgeText}
        </div>
      )}
    </div>
  ) : (
    <div class:list={[
      'w-full bg-[rgb(var(--color-surface,var(--color-text)/0.05))] flex items-center justify-center text-[rgb(var(--color-muted))]',
      heroRadius,
    ]} style="aspect-ratio:1/1;">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
        <circle cx="8.5" cy="8.5" r="1.5" />
        <polyline points="21,15 16,10 5,21" />
      </svg>
    </div>
  )}

  {gallery.thumbs.length > 0 && (
    <div
      class:list={[
        'mt-4',
        isInlineSmall
          ? 'flex flex-wrap gap-2'
          : 'flex flex-wrap gap-4',
      ]}
      data-product-thumbs
    >
      {gallery.thumbs.map((thumb, idx) => (
        <button
          type="button"
          data-product-thumb
          data-thumb-idx={idx + 1}
          aria-label={`Изображение ${idx + 2}`}
          class:list={[
            'relative overflow-hidden p-0 border-0 bg-transparent cursor-pointer',
            thumbRadius,
            isInlineSmall ? 'w-[124px] h-[124px] shrink-0' : 'w-[318px] h-[318px] max-w-full shrink-0',
          ]}
        >
          <img
            src={thumb.src}
            alt={thumb.alt}
            loading="lazy"
            class="w-full h-full object-cover block"
          />
        </button>
      ))}
    </div>
  )}
</div>
