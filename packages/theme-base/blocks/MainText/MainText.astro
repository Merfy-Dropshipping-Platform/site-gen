---
import type { MainTextProps } from './MainText.puckConfig';
import { MainTextClasses as C } from './MainText.classes';

interface Props extends MainTextProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  alignment: alignmentProp,
  padding,
} = Astro.props as Props & { alignment?: string };

// Constructor legacy schema wraps heading as { text, size } and text as
// { content, size }. Accept both shapes so merchant revisions written by
// the constructor don't render as "[object Object]".
const readText = (v: unknown): string | undefined => {
  if (typeof v === 'string') return v || undefined;
  if (v && typeof v === 'object') {
    const o = v as { text?: string; content?: string };
    return o.text ?? o.content ?? undefined;
  }
  return undefined;
};
const heading = readText(raw.heading);
const text = readText(raw.text);
const alignment = (alignmentProp as 'left' | 'center' | 'right' | undefined)
  ?? (raw.position as 'left' | 'center' | 'right' | undefined)
  ?? 'center';

const alignClass = C.align[alignment];
const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
// NOTE: `text` supports basic HTML (<b>, <i>) via set:html.
// Constructor inputs should sanitize HTML before persisting to DB to prevent XSS.
---
<section
  class={C.root}
  data-puck-component-id={id}
  data-alignment={alignment}
  style={paddingStyle}
>
  <div class:list={[C.container, alignClass]}>
    {heading && <h2 class={C.heading}>{heading}</h2>}
    {text && <div class={C.text} set:html={text} />}
  </div>
</section>
