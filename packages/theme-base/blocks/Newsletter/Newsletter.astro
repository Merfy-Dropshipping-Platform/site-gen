---
import type { NewsletterProps } from './Newsletter.puckConfig';
import { NewsletterClasses as C } from './Newsletter.classes';

interface Props extends NewsletterProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  heading: headingProp,
  description: descriptionProp,
  placeholder: placeholderProp,
  buttonText: buttonTextProp,
  padding,
} = Astro.props as Props;

// Constructor legacy schema writes heading as { text }, description as text.content,
// placeholder/buttonText inside form.*. Accept both shapes.
const h = headingProp ?? (raw.heading as { text?: string } | string | undefined);
const heading =
  typeof h === 'string' ? h : (h?.text ?? undefined);
const t = raw.text as { content?: string } | string | undefined;
const description =
  descriptionProp ?? (typeof t === 'string' ? t : t?.content) ?? '';
const form = raw.form as { placeholder?: string; buttonText?: string } | undefined;
const placeholder = placeholderProp ?? form?.placeholder ?? 'email@example.com';
const buttonText = buttonTextProp ?? form?.buttonText ?? 'Подписаться';

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';

// Pupa parity: heading.alignment, heading.size, position, colorScheme.
const headingObj = headingProp ?? raw.heading;
const headingAlignment = typeof headingObj === 'object' ? (headingObj as { alignment?: string })?.alignment : undefined;
const headingSize = typeof headingObj === 'object' ? (headingObj as { size?: string })?.size : undefined;
const textObj = raw.text;
const textSize = typeof textObj === 'object' ? (textObj as { size?: string })?.size : undefined;
// Position default depends on formLayout: vanilla `inline-submit` defaults
// to left-aligned items-start (matches Figma); other themes (no formLayout)
// keep the legacy centered position.
const formLayoutForPosition =
  raw.formLayout === 'inline-submit' || raw.formLayout === 'stacked'
    ? raw.formLayout
    : undefined;
const position = typeof raw.position === 'string'
  ? raw.position
  : (formLayoutForPosition === 'inline-submit' ? 'left' : 'center');
const colorScheme = raw.colorScheme as string | undefined;
const schemeClass = colorScheme ? `color-scheme-${String(colorScheme).replace('scheme-', '')}` : '';

const headingAlignClass =
  headingAlignment === 'left' ? 'text-left' :
  headingAlignment === 'right' ? 'text-right' :
  headingAlignment === 'center' ? 'text-center' : '';
const headingSizeClass =
  headingSize === 'large' ? 'text-3xl md:text-4xl' :
  headingSize === 'medium' ? 'text-2xl md:text-3xl' :
  headingSize === 'small' ? 'text-xl md:text-2xl' : '';
const textSizeClass =
  textSize === 'large' ? 'text-lg md:text-xl' :
  textSize === 'medium' ? 'text-base md:text-lg' :
  textSize === 'small' ? 'text-sm md:text-base' : '';
// 084 vanilla pilot: additive `formLayout` variant.
//   - 'inline-submit' (explicit, vanilla parity): full bordered input,
//     button INSIDE on right.
//   - 'stacked': button below input as block element.
//   - undefined (legacy themes — rose/satin/bloom/flux): underline-only
//     input + absolute arrow icon, identical to pre-084 behaviour.
const formLayoutPropRaw = raw.formLayout;
const isExplicitInline = formLayoutPropRaw === 'inline-submit';
const isStacked = formLayoutPropRaw === 'stacked';
const formLayoutProp: 'stacked' | 'inline-submit' | 'legacy' = isStacked
  ? 'stacked'
  : isExplicitInline
  ? 'inline-submit'
  : 'legacy';
const formClass =
  formLayoutProp === 'stacked'
    ? C.formWrapper.stacked
    : formLayoutProp === 'inline-submit'
    ? C.formWrapper['inline-submit']
    : C.form; // legacy underline
const submitButtonClass =
  formLayoutProp === 'stacked'
    ? C.buttonStacked
    : formLayoutProp === 'inline-submit'
    ? ((C as Record<string, unknown>).buttonInline as string)
    : C.button; // legacy absolute icon

// 084 vanilla pilot — inline-submit-specific typography overrides.
const headingClass = formLayoutProp === 'inline-submit'
  ? ((C as Record<string, unknown>).headingInline as string)
  : C.heading;
const descriptionClass = formLayoutProp === 'inline-submit'
  ? ((C as Record<string, unknown>).descriptionInline as string)
  : C.description;
const inputClass = formLayoutProp === 'inline-submit'
  ? ((C as Record<string, unknown>).inputInline as string)
  : C.input;

const positionClass =
  position === 'left' ? 'text-left items-start' :
  position === 'right' ? 'text-right items-end' :
  position === 'center' ? 'text-center items-center' : '';
// When left/right we override the default mx-auto centering on the inner
// wrapper so content sits flush with the section start (vanilla parity).
const innerOverrideClass =
  position === 'left' ? '!mx-0 !max-w-none flex flex-col gap-10' :
  position === 'right' ? '!ml-auto !mr-0 !max-w-none flex flex-col gap-10' :
  '';
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  style={paddingStyle}
>
  <div class={C.container}>
    <div class:list={[C.inner, positionClass, innerOverrideClass]}>
      {heading && (
        <h2 class:list={[headingClass, formLayoutProp === 'inline-submit' ? '' : headingAlignClass, formLayoutProp === 'inline-submit' ? '' : headingSizeClass]} data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">{heading}</h2>
      )}
      {description && (
        <p class:list={[descriptionClass, formLayoutProp === 'inline-submit' ? '' : textSizeClass]} data-puck-subsection-parent={id} data-puck-subsection-index="101" data-puck-subsection-field="text">{description}</p>
      )}
      <form
        class={formClass}
        method="POST"
        action="https://gateway.merfy.ru/api/storefront/newsletter/subscribe"
        data-newsletter-form
        data-puck-subsection-parent={id}
        data-puck-subsection-index="102"
        data-puck-subsection-field="form"
        data-form-layout={formLayoutProp}
      >
        {/*
          store_id is injected at runtime from window.__MERFY_CONFIG__.shopId
          (set by the per-site BaseLayout, see templates/.../layouts/BaseLayout.astro).
          We keep the field as a hidden input so the form remains a plain
          POST submit — no JS-handler / fetch / UI feedback in this block yet
          (that's a follow-up). The same inline script also rewrites `action`
          when a non-default apiUrl is configured (preview / staging).
        */}
        <input type="hidden" name="store_id" value="" data-newsletter-store-id />
        <input type="email" name="email" placeholder={placeholder} required class={inputClass} />
        <button type="submit" class={submitButtonClass} aria-label={buttonText}>
          {formLayoutProp === 'legacy' ? (
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4 10h12m0 0l-5-5m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          ) : (
            buttonText
          )}
        </button>
      </form>
    </div>
  </div>
</section>
<script is:inline define:vars={{ blockId: id }}>
  // Wire newsletter form to the storefront gateway endpoint.
  // - store_id comes from window.__MERFY_CONFIG__.shopId (set by BaseLayout).
  // - When __MERFY_CONFIG__.apiUrl differs from prod (preview / staging),
  //   we rebuild the action URL on the form so this block doesn't have to
  //   bake a host at build time.
  // This script keeps the form as a NATIVE POST submit — no fetch, no
  // success/error UI. {alreadySubscribed} / 429 handling lives in a future
  // JS-handler iteration; for MVP the browser shows the JSON response.
  (function () {
    function wire(form) {
      if (!form || form.__merfyNewsletterWired) return;
      form.__merfyNewsletterWired = true;
      var cfg = (typeof window !== 'undefined' && window.__MERFY_CONFIG__) || {};
      var hidden = form.querySelector('[data-newsletter-store-id]');
      if (hidden && cfg.shopId) {
        hidden.value = String(cfg.shopId);
      }
      if (cfg.apiUrl) {
        // Strip trailing slash, append the storefront path.
        var base = String(cfg.apiUrl).replace(/\/+$/, '');
        form.setAttribute('action', base + '/storefront/newsletter/subscribe');
      }
    }
    function init() {
      // Spec 102 — своя секция через __merfyRoot (не querySelectorAll по всем формам).
      var section = window.__merfyRoot(blockId);
      if (!section) return;
      var form = section.querySelector('form[data-newsletter-form]');
      if (form) wire(form);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
