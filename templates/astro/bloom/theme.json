{
  "name": "bloom",
  "label": "Bloom — Beauty & Cosmetics",
  "version": "1.0.0",
  "category": "beauty",
  "description": "Soft feminine theme with pink accent for beauty and cosmetics stores",
  "author": "Merfy",
  "features": {
    "variants": true,
    "collections": true,
    "sizeGuide": false,
    "colorSwatches": true,
    "filterSidebar": true,
    "newsletter": true,
    "wishlist": false,
    "blog": true,
    "rss": true
  },
  "pages": ["index", "product", "collection", "cart", "blog"],
  "settings_schema": [
    {
      "name": "colors",
      "settings": [
        { "id": "color_primary", "type": "color", "label": "Primary color", "default": "#000000" },
        { "id": "color_background", "type": "color", "label": "Background", "default": "#ffffff" },
        { "id": "color_foreground", "type": "color", "label": "Text", "default": "#000000" },
        { "id": "color_border", "type": "color", "label": "Border", "default": "#d9d9d9" },
        { "id": "color_button", "type": "color", "label": "Button", "default": "#cf7a8b" },
        { "id": "color_button_text", "type": "color", "label": "Button text", "default": "#ffffff" },
        { "id": "color_accent", "type": "color", "label": "Accent", "default": "#cf7a8b" },
        { "id": "color_accent_light", "type": "color", "label": "Accent light", "default": "#e38e9f" },
        { "id": "color_accent_text", "type": "color", "label": "Accent text", "default": "#f7a2b3" },
        { "id": "color_muted", "type": "color", "label": "Muted", "default": "#999999" }
      ]
    },
    {
      "name": "typography",
      "settings": [
        { "id": "font_heading", "type": "font", "label": "Heading font", "default": "Urbanist" },
        { "id": "font_body", "type": "font", "label": "Body font", "default": "Inter" },
        { "id": "font_product", "type": "font", "label": "Product name font", "default": "Roboto" }
      ]
    },
    {
      "name": "layout",
      "settings": [
        { "id": "radius_button", "type": "range", "label": "Button radius", "default": "100" },
        { "id": "radius_card", "type": "range", "label": "Card radius", "default": "12" },
        { "id": "page_width", "type": "text", "label": "Page width", "default": "1320px" }
      ]
    }
  ],
  "color_schemes": [
    {
      "id": 1,
      "name": "Pink Accent",
      "background": "#cf7a8b",
      "foreground": "#ffffff",
      "primary": "#ffffff",
      "border": "#e38e9f",
      "button": "#ffffff",
      "button_text": "#cf7a8b"
    },
    {
      "id": 2,
      "name": "Pink Section",
      "background": "#e38e9f",
      "foreground": "#ffffff",
      "primary": "#ffffff",
      "border": "#f7a2b3",
      "button": "#ffffff",
      "button_text": "#e38e9f"
    },
    {
      "id": 3,
      "name": "White",
      "background": "#ffffff",
      "foreground": "#000000",
      "primary": "#000000",
      "border": "#d9d9d9",
      "button": "#cf7a8b",
      "button_text": "#ffffff"
    },
    {
      "id": 4,
      "name": "Light Hero",
      "background": "#f7f7f9",
      "foreground": "#000000",
      "primary": "#000000",
      "border": "#d9d9d9",
      "button": "#cf7a8b",
      "button_text": "#ffffff"
    }
  ]
}
