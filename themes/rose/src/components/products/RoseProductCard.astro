---
import type { Product } from "../../types/product";
import RosePicture from "../img/RosePicture.astro";

interface Props {
	product: Product;
	priority?: boolean;
	/**
	 * aspect-ratio (W/H) карточного медиа — «Вид изображения» секции:
	 * "318/444" (Квадрат, дефолт) | "430/500" (Портрет) | "16/9" (Широкий).
	 * Дефолт = прежний литерал верстальщика (byte-identical до-фикса).
	 */
	aspectRatio?: string;
}

const { product, priority = false, aspectRatio = "318/444" } = Astro.props;
const href = `/products/${product.id}`;
const showSaleBadge = product.discount === true;

// Wishlist overlay-сердце на карточке (initWishlistUI из Layout красит filled/
// outline по localStorage на load + перекрашивает на toggle). Геометрия = rose
// favourite.svg (см. lib/wishlist.ts heartSvg / wishlist.astro).
const wishlistOutlineSvg =
	'<svg viewBox="0 0 17.4 15.4" width="100%" height="100%" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="display:block">' +
	'<path d="M7.428 14.2615C5.172 12.5239 0.7 8.55212 0.7 4.97729C0.7 2.61547 2.384 0.7 4.7 0.7C5.9 0.7 7.1 1.11175 8.7 2.75876C10.3 1.11175 11.5 0.7 12.7 0.7C15.016 0.7 16.7 2.61547 16.7 4.97729C16.7 8.5513 12.228 12.5239 9.972 14.2615C9.212 14.8462 8.188 14.8462 7.428 14.2615Z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>' +
	"</svg>";
---

<article
	class="group flex w-full flex-col gap-5"
	data-nt="rose-product-card"
	aria-label={product.name}
>
	<div class="relative w-full">
	<a
		href={href}
		class="relative block w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-white"
		style={`aspect-ratio:${aspectRatio}`}
		aria-label={product.name}
	>
		{product.image ? (
			<RosePicture
				src={product.image}
				alt={product.name}
				width="318"
				height="444"
				loading="eager"
				fetchpriority={priority ? "high" : undefined}
				class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
			/>
		) : (
			/* Товар без фото: surface-плейсхолдер вместо <img> (битой иконки).
			   Цвета только токенами; разметку зеркалит CARD_MEDIA_FALLBACK_HTML
			   в lib/storefront-hydrate.ts — менять синхронно. */
			<div
				class="absolute inset-0 flex items-center justify-center"
				style="background:rgb(var(--color-surface,245 245 245))"
				aria-hidden="true"
			>
				<svg
					class="size-10"
					style="color:rgb(var(--color-muted,153 153 153))"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<rect x="3" y="3" width="18" height="18" rx="2"></rect>
					<circle cx="9" cy="9" r="2"></circle>
					<path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
				</svg>
			</div>
		)}
		{showSaleBadge && (
			<span
				class="absolute left-3 top-3 z-10 flex h-6 min-w-12 items-center justify-center rounded-[4px] bg-[rgb(var(--color-accent,0_0_0))] px-2 font-manrope text-[12px] font-normal leading-none !text-white"
			>
				Скидка
			</span>
		)}
	</a>
	<button
		type="button"
		data-wishlist-toggle
		data-product-id={product.id}
		aria-pressed="false"
		aria-label="В избранное"
		class="absolute right-3 top-3 z-20 flex size-9 items-center justify-center rounded-full bg-white/90 text-[#000000] shadow-[0_2px_8px_rgba(0,0,0,0.10)] backdrop-blur-sm transition-opacity hover:opacity-80"
	>
		<span data-wishlist-icon class="block size-[18px]" set:html={wishlistOutlineSvg}></span>
	</button>
	</div>
	<div class="flex w-full flex-col gap-1 text-left">
		<a
			href={href}
			class="rose-product-name block w-full font-manrope text-[14px] font-normal leading-none tracking-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70"
		>
			{product.name}
		</a>
		<div class="flex w-full flex-wrap items-baseline gap-2">
			<span class="rose-product-price font-manrope !text-[16px] font-normal !leading-none text-[rgb(var(--color-text,0_0_0))]">
				{product.price}
			</span>
			{product.oldPrice && (
				<span class="rose-product-oldprice font-manrope !text-[14px] font-normal !leading-none text-[rgb(var(--color-muted,153_153_153))] line-through">
					{product.oldPrice}
				</span>
			)}
		</div>
	</div>
</article>

<style>
	/* Figma 375: name/price — Manrope 12, lh 100% */
	@media (max-width: 639.98px) {
		.rose-product-name {
			font-size: 12px !important;
		}

		.rose-product-price {
			font-size: 12px !important;
		}

		.rose-product-oldprice {
			font-size: 12px !important;
		}
	}
</style>
