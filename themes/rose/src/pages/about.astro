---
// Контентная страница «О нас». Шелл для системы контент-страниц
// (composeContentPagesIntoDist пересаживает Page-блоки ревизии в <main>). Берёт
// ПОЛНЫЙ storefront-Layout (Header+Footer+NtCartDrawer+ViewTransitions+initCart/
// Wishlist/Auth) — как contacts.astro — иначе бейджи корзины/избранного и
// View Transitions на странице мертвы (BlogPost.astro их не подключал).
import Layout from '../layouts/Layout.astro';
---

<Layout title="О нас" description="О нашем магазине">
	<section class="mx-auto w-full max-w-[800px] px-4 py-16 sm:px-6 lg:px-8">
		<p class="font-manrope text-[16px] leading-relaxed text-[rgb(var(--color-text,0_0_0))]">
			Расскажите о вашем магазине.
		</p>
	</section>
</Layout>
