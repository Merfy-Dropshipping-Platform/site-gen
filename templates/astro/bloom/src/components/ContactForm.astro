---
interface Props {
  heading?: { text?: string; size?: 'small' | 'medium' | 'large' };
  colorScheme?: string;
  padding?: { top?: number; bottom?: number };
}

const { heading, colorScheme, padding } = Astro.props;
const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';
const headingText = heading?.text ?? 'Свяжитесь с нами';
const padTop = padding?.top ?? 80;
const padBottom = padding?.bottom ?? 80;
---

<section
  class={`w-full ${schemeClass}`}
  style={`padding-top: ${padTop}px; padding-bottom: ${padBottom}px; background: rgb(var(--color-background)); color: rgb(var(--color-foreground));`}
>
  <div class="max-w-[600px] mx-auto px-5">
    <h2 class="text-[20px] font-normal leading-[1.2] font-heading text-center mb-[40px]" style="color: rgb(var(--color-foreground));">
      {headingText}
    </h2>
    <form class="flex flex-col gap-5" action="#" method="POST">
      <div class="flex flex-col gap-1.5">
        <label for="contact-name" class="text-[14px] font-normal font-body" style="color: rgb(var(--color-foreground));">Имя</label>
        <input
          type="text"
          id="contact-name"
          name="name"
          placeholder="Ваше имя"
          required
          class="py-3 px-4 text-base border border-theme rounded-none font-body transition-colors focus:outline-none focus:border-theme-foreground"
          style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));"
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="contact-email" class="text-[14px] font-normal font-body" style="color: rgb(var(--color-foreground));">Email</label>
        <input
          type="email"
          id="contact-email"
          name="email"
          placeholder="email@example.com"
          required
          class="py-3 px-4 text-base border border-theme rounded-none font-body transition-colors focus:outline-none focus:border-theme-foreground"
          style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));"
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="contact-message" class="text-[14px] font-normal font-body" style="color: rgb(var(--color-foreground));">Сообщение</label>
        <textarea
          id="contact-message"
          name="message"
          rows="5"
          placeholder="Ваше сообщение..."
          required
          class="py-3 px-4 text-base border border-theme rounded-none font-body transition-colors resize-y focus:outline-none focus:border-theme-foreground"
          style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));"
        ></textarea>
      </div>
      <button
        type="submit"
        class="inline-flex items-center justify-center h-[48px] px-[16px] text-[16px] font-normal uppercase rounded-none border-none cursor-pointer transition-colors hover:opacity-90 font-body"
        style="background: rgb(var(--color-button)); color: rgb(var(--color-button-text));"
      >
        Отправить
      </button>
    </form>
  </div>
</section>
