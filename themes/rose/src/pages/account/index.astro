---
import Layout from '../../layouts/Layout.astro';

const shopId = "";
const apiUrl = "https://gateway.merfy.ru/api";
---
<Layout title="Учётная запись" promo={false}>
  <script is:inline define:vars={{ shopId, apiUrl }}>
    window.__MERFY_CONFIG__ = window.__MERFY_CONFIG__ || {
      shopId: shopId || "",
      apiUrl: apiUrl || "https://gateway.merfy.ru/api",
    };
  </script>

  <div class="account-page-container" style="padding-top: 7rem;">
    <div class="account-title">
      <h1>Учётная запись</h1>
      <span class="account-subtitle" id="account-email">Загрузка...</span>
    </div>

    <nav class="account-nav-links" id="account-nav">
      <a href="/account/profile" class="active">Основные данные</a>
      <a href="/account/orders">Мои заказы</a>
    </nav>

    <button type="button" class="account-text-link" id="btn-logout">Выйти из аккаунта</button>
  </div>

  <script>
    import { navTo, fetchMe, logout, getToken } from '../../lib/auth';

    async function initAccountPage() {
      const root = document.getElementById('account-nav');
      if (!root || root.dataset.bound === 'true') return;
      root.dataset.bound = 'true';

      if (!getToken()) {
        navTo('/login');
        return;
      }

      const emailEl = document.getElementById('account-email');
      const logoutBtn = document.getElementById('btn-logout');

      const customer = await fetchMe();
      if (!customer) {
        navTo('/login');
        return;
      }
      if (emailEl) emailEl.textContent = customer.email || '';

      logoutBtn?.addEventListener('click', async () => {
        await logout();
        navTo('/login');
      });
    }

    initAccountPage();
    document.addEventListener('astro:page-load', initAccountPage);
  </script>
</Layout>
