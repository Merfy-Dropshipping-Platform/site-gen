---
import Layout from "../../layouts/Layout.astro";
import BloomProductCard from "../products/BloomProductCard.astro";
import NtFilterPanel from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtFilterPanel.astro";
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { categoryPages, getCategoryBySlug, type CategorySlug } from "../../data/categories";
import { catalogProducts } from "../../data/products";

interface Props {
	slug: CategorySlug;
}

const { slug } = Astro.props;
const category = getCategoryBySlug(slug) ?? categoryPages[0]!;
const products = catalogProducts.filter((product) => product.category === category.slug);
const totalCount = products.length;
const showLoadMore = totalCount > 3;

function pluralizeProducts(count: number): string {
	const mod10 = count % 10;
	const mod100 = count % 100;
	if (mod100 >= 11 && mod100 <= 14) return `${count} товаров`;
	if (mod10 === 1) return `${count} товар`;
	if (mod10 >= 2 && mod10 <= 4) return `${count} товара`;
	return `${count} товаров`;
}
---

<Layout title={category.label} description={category.description}>
	<section
		class="w-full bg-white px-4 pb-[80px] pt-10 md:px-20 md:pb-[120px] md:pt-16 2xl:px-[300px]"
		aria-labelledby="category-title"
	>
		<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-10">
			<header class="flex flex-col gap-2" data-animate>
				<h1
					id="category-title"
					class="font-comfortaa text-[28px] font-normal uppercase leading-[1.115] text-[#000000] md:text-[32px] lg:text-[36px]"
				>
					{category.title}
				</h1>
				<p class="font-manrope text-[16px] font-light leading-[1.366] text-[#999999] md:text-[18px] lg:text-[20px]">
					{category.subtitle}
				</p>
			</header>

			<div class="flex flex-col gap-6" data-animate data-animate-delay="0.1s">
				<div class="flex flex-wrap items-center justify-between gap-3" data-nt="catalog-filters">
					<div class="flex flex-wrap items-start gap-3">
						<details class="relative [&[open]]:z-30">
							<summary class="flex h-10 min-w-[180px] cursor-pointer list-none items-center justify-between gap-2 rounded-[6px] border border-[#F5F5F5] bg-white px-3 font-manrope text-[14px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span>Наличие</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-5" />
							</summary>
							<div class="absolute left-0 top-full z-30 mt-1 w-full">
								<NtFilterPanel panel="stock" />
							</div>
						</details>

						<details class="relative [&[open]]:z-30">
							<summary class="flex h-10 min-w-[180px] cursor-pointer list-none items-center justify-between gap-2 rounded-[6px] border border-[#F5F5F5] bg-white px-3 font-manrope text-[14px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span>Стоимость</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-5" />
							</summary>
							<div class="absolute left-0 top-full z-30 mt-1 w-full">
								<NtFilterPanel panel="price" />
							</div>
						</details>

						<details class="relative [&[open]]:z-30">
							<summary class="flex h-10 min-w-[180px] cursor-pointer list-none items-center justify-between gap-2 rounded-[6px] border border-[#F5F5F5] bg-white px-3 font-manrope text-[14px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span>Цвет</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-5" />
							</summary>
							<div class="absolute left-0 top-full z-30 mt-1 w-full">
								<NtFilterPanel panel="color" />
							</div>
						</details>

						{/* Фильтр по коллекциям: скрыт на demo-сборке, гидрация показывает
						    его при наличии коллекций магазина и уважает ?collection= из
						    ссылок тайлов Collections. Манера = details-дропдауны выше. */}
						<details class="relative [&[open]]:z-30" data-nt="catalog-collections-filter" style="display:none;">
							<summary class="flex h-10 min-w-[180px] cursor-pointer list-none items-center justify-between gap-2 rounded-[6px] border border-[#F5F5F5] bg-white px-3 font-manrope text-[14px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
								<span data-collections-label>Коллекции</span>
								<NtIcon name="dropdown-chevron" sizeClass="size-5" />
							</summary>
							<div class="absolute left-0 top-full z-30 mt-1 w-full">
								<div class="flex w-full flex-col gap-2 rounded-[6px] border border-[#F5F5F5] bg-white p-3 font-manrope text-[14px] font-normal leading-normal">
									<ul data-collections-options class="m-0 flex list-none flex-col gap-2 p-0"></ul>
								</div>
							</div>
						</details>
					</div>

					<details class="relative [&[open]]:z-30">
						<summary class="flex h-10 min-w-[180px] cursor-pointer list-none items-center justify-end gap-2 rounded-[6px] bg-white px-3 font-manrope text-[14px] font-normal leading-normal text-[#000000] transition-opacity hover:opacity-90 [&::-webkit-details-marker]:hidden">
							<span>По популярности</span>
							<NtIcon name="dropdown-chevron" sizeClass="size-5" />
						</summary>
						<div class="absolute right-0 top-full z-30 mt-1 w-[180px]">
							<NtFilterPanel panel="sort" />
						</div>
					</details>
				</div>

				<ul
					class="grid w-full grid-cols-1 gap-x-4 gap-y-10 sm:grid-cols-2 lg:grid-cols-3"
					role="list"
					data-nt="catalog-grid"
				>
					{products.map((product, index) => (
						<li data-product-id={product.id}>
							<BloomProductCard product={product} priority={index < 3} />
						</li>
					))}
				</ul>

				<div
					class:list={[
						"flex flex-col items-stretch gap-4 sm:flex-row sm:items-center",
						showLoadMore ? "sm:justify-between" : "sm:justify-end",
					]}
				>
					{showLoadMore && (
						<button
							type="button"
							data-action="load-more"
							class="inline-flex h-12 items-center justify-center rounded-[6px] bg-[#000000] px-6 font-manrope text-[14px] font-normal leading-normal text-white transition-opacity hover:opacity-95 active:scale-95 md:text-[16px]"
						>
							Смотреть ещё
						</button>
					)}
					<span class="font-manrope text-[14px] font-normal leading-normal text-[#999999] md:text-[16px]" data-nt="catalog-count">
						{pluralizeProducts(totalCount)}
					</span>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	document.addEventListener("click", (event) => {
		const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-action='load-more']");
		if (!button) return;
		button.disabled = true;
		button.textContent = "Больше товаров нет";
		button.classList.add("opacity-60", "pointer-events-none");
	});
</script>

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		filterByCollection,
		renderCardHtml,
		escapeHtml,
		updateCount,
		type RealCollection,
	} from "../../lib/storefront-hydrate";

	// Реальные товары (Option B): на published-сайте /data/products.json реальный →
	// перерисовываем demo-grid. На demo-сборке loadRealProducts() вернёт null → no-op.
	// ВНИМАНИЕ: demo-категории фильтруют товары по product.category, но реальный
	// products.json этого поля не несёт — поэтому в каждую категорию гидрируем ВЕСЬ
	// каталог (как единый catalog в rose). Это осознанное отклонение, см. отчёт.
	// Фильтр по коллекциям: ?collection= (slug/id из ссылок тайлов) + дропдаун
	// «Коллекции» (заполняется из collections.json/storefront-data).
	let catalogCollections: RealCollection[] | null = null;

	function currentCollectionRef(): string | null {
		return new URLSearchParams(window.location.search).get("collection");
	}

	async function renderCatalog() {
		const products = await loadRealProducts();
		if (!products) return; // demo-сборка
		const ref = currentCollectionRef();
		const items = ref ? filterByCollection(products, catalogCollections, ref) : products;
		const html = items
			.map((p) => `<li data-product-id="${escapeHtml(p.id)}">${renderCardHtml(p)}</li>`)
			.join("");
		for (const grid of Array.from(document.querySelectorAll('[data-nt="catalog-grid"]'))) {
			grid.innerHTML = html;
		}
		updateCount('[data-nt="catalog-count"]', items.length);
	}

	async function initCollectionsFilter() {
		const box = document.querySelector<HTMLElement>('[data-nt="catalog-collections-filter"]');
		const list = box?.querySelector<HTMLElement>("[data-collections-options]");
		if (!box || !list) return;
		if (box.getAttribute("data-cf-hydrated") === "true") return; // идемпотентность astro:page-load
		catalogCollections = await loadRealCollections();
		if (!catalogCollections || catalogCollections.length === 0) return;
		box.setAttribute("data-cf-hydrated", "true");
		box.style.display = "";
		const label = box.querySelector<HTMLElement>("[data-collections-label]");
		const ref = currentCollectionRef();
		const current = ref
			? catalogCollections.find((c) => c.id === ref || c.slug === ref || c.name === ref) ?? null
			: null;
		if (label && current?.name) label.textContent = current.name;
		// Манера опций = NtFilterPanel: активная строка text-[#000000], остальные text-[#999999].
		const optionHtml = (value: string, name: string, active: boolean) =>
			`<li><button type="button" data-collection-option="${escapeHtml(value)}" class="w-full cursor-pointer text-left font-manrope text-[14px] font-normal leading-normal transition-colors ${active ? "text-[#000000]" : "text-[#999999] hover:text-[#000000]"}">${escapeHtml(name)}</button></li>`;
		list.innerHTML =
			optionHtml("", "Все", !current) +
			catalogCollections
				.map((c) => optionHtml(c.slug ?? c.id, c.name ?? "Коллекция", !!current && current.id === c.id))
				.join("");
		list.addEventListener("click", (ev) => {
			const btn = (ev.target as HTMLElement).closest<HTMLElement>("[data-collection-option]");
			if (!btn) return;
			const value = btn.getAttribute("data-collection-option") ?? "";
			const params = new URLSearchParams(window.location.search);
			if (value) params.set("collection", value);
			else params.delete("collection");
			const qs = params.toString();
			window.history.replaceState({}, "", window.location.pathname + (qs ? `?${qs}` : ""));
			const col = catalogCollections?.find((c) => (c.slug ?? c.id) === value) ?? null;
			if (label) label.textContent = col?.name ?? "Коллекции";
			for (const b of Array.from(list.querySelectorAll("[data-collection-option]"))) {
				const on = b === btn;
				b.classList.toggle("text-[#000000]", on);
				b.classList.toggle("text-[#999999]", !on);
				b.classList.toggle("hover:text-[#000000]", !on);
			}
			box.removeAttribute("open");
			renderCatalog();
		});
	}

	async function hydrateCatalog() {
		await initCollectionsFilter();
		await renderCatalog();
	}

	hydrateCatalog();
	document.addEventListener("astro:page-load", hydrateCatalog);
</script>
