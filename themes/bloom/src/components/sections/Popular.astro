---
import NtSectionHeading from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtSectionHeading.astro";
import BloomProductCard from "../products/BloomProductCard.astro";

// ОЖИВЛЕНИЕ (Фаза B, контракт rose Popular T13): полная конструкторная схема
// theme-base PopularProducts.puckConfig поверх разметки верстальщика. Тело +
// demo-данные verbatim (дефолты без пропсов = прежний рендер). Канон-дефолты
// конструктора (headingSize/textSize small, imageView square, quickAddMode none)
// → пиксель верстальщика; дефолтные ветки тернарников = прежние строки
// байт-в-байт. ⚠️ blockDefaults bloom задают columns=3 при литерале верстальщика
// lg:grid-cols-4 — по решению аналитика 3 трактуется как canon-default →
// дефолт-ветка (литерал); рекомендация следующей фазе — поправить theme.json
// PopularProducts.columns на 4.
const p = Astro.props as Record<string, any>;
const id = p.id;
// Figma 1:19335 — ДОСЛОВНЫЙ плейсхолдер пустого состояния PopularProducts:
// заголовок «Коллекция товаров», без хелпер-подзаголовка (только заголовок +
// карточки). Дефолт-текст верстальщика («Главные хиты» + длинный подзаголовок)
// заменён на Figma-текст. Когда мерчант задал свой heading/text/subtitle —
// рендерим ЕГО (?? fallback срабатывает только при пустых данных).
const sectionTitle =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p.title ?? "Коллекция товаров";
const sectionSubtitle =
	(typeof p.text === "string" ? p.text : p.text?.content) ??
	(typeof p.subtitle === "string" ? p.subtitle : p.subtitle?.content) ??
	"";

// Канон cards 2-24: лимит среза demo-витрины и гидрации (data-cards на гриде).
// 4 = срез верстальщика (и отсутствие пропа) → дефолт-ветка.
const cardsN =
	typeof p.cards === "number" && p.cards > 0 ? Math.max(1, Math.min(24, Math.round(p.cards))) : 4;

// Канон collection (collectionPicker, id или slug): носитель — data-collection
// на гриде; фильтрацию делает гидрация (filterByCollection: productIds коллекции
// → membership товара → все, паритет theme-base). Demo-сборка без данных — no-op.
const collectionRef =
	typeof p.collection === "string" && p.collection.trim() ? p.collection.trim() : undefined;

// Пустое/некурированное состояние (Figma 1:19335) = ПЛЕЙСХОЛДЕР, не мок-демо
// верстальщика. Гейт = наличие выбранной коллекции (collectionRef). НЕТ выбора →
// плейсхолдер-карточки (цветные куртки, «Товар», «2 500 ₽»). ЕСТЬ выбор → SSR-фетч
// РЕАЛЬНЫХ товаров коллекции прямо на рендере (паритет rose Popular), плюс
// клиентская гидрация ниже освежает грид на live. Паритет theme-base
// PopularProducts.astro (DEMO_PRODUCTS на гейте collectionRef).
const SWEATER_PLACEHOLDERS = [
	"/placeholders/sweater-blue.svg",
	"/placeholders/sweater-yellow.svg",
	"/placeholders/sweater-red.svg",
	"/placeholders/sweater-green.svg",
];
const placeholderCards = Array.from({ length: cardsN }, (_, i) => ({
	image: SWEATER_PLACEHOLDERS[i % SWEATER_PLACEHOLDERS.length],
	title: "Товар",
	price: "2 500 ₽",
}));

// SSR-фетч реальных товаров выбранной коллекции (Figma-цель: коллекция выбрана →
// реальные товары ПРЯМО в статике, чтобы их видело и ПРЕВЬЮ конструктора — Astro
// Container не исполняет клиентскую module-гидрацию ниже). siteId инжектит
// рендер-пайплайн (preview.service / build). Нет коллекции / siteId / ошибка →
// realProducts пуст → секция рендерит плейсхолдер-куртки.
const siteId = typeof p.siteId === "string" ? p.siteId : "";
const fmtPrice = (v: unknown): string => {
	const n = typeof v === "number" ? v : parseFloat(String(v ?? ""));
	return Number.isFinite(n) ? `${Math.round(n).toLocaleString("ru-RU")} ₽` : "";
};
let realProducts: any[] = [];
if (collectionRef && siteId) {
	try {
		const base = (import.meta as any).env?.SITES_INTERNAL_BASE ?? "http://localhost:3114";
		const res = await fetch(`${base}/api/sites/${siteId}/storefront-data`).catch(() => null);
		if (res && res.ok) {
			const data: any = await res.json();
			const all: any[] = Array.isArray(data?.products) ? data.products : [];
			const cols: any[] = Array.isArray(data?.collections) ? data.collections : [];
			const matched = cols.find(
				(c) => c && (c.id === collectionRef || c.slug === collectionRef || c.name === collectionRef || c.handle === collectionRef),
			);
			const ids = matched && Array.isArray(matched.productIds) && matched.productIds.length ? new Set(matched.productIds) : null;
			const picked = (ids ? all.filter((pr) => pr?.id && ids.has(pr.id)) : all).slice(0, cardsN);
			realProducts = picked.map((pr) => {
				const img = Array.isArray(pr?.images) && pr.images[0]
					? (typeof pr.images[0] === "string" ? pr.images[0] : pr.images[0]?.url ?? "")
					: (pr?.image ?? "");
				const gal = Array.isArray(pr?.images)
					? pr.images.map((im: any) => (typeof im === "string" ? im : im?.url ?? "")).filter(Boolean)
					: [];
				return {
					id: String(pr?.id ?? ""),
					name: String(pr?.name ?? pr?.title ?? "Товар"),
					image: String(img ?? ""),
					gallery: gal,
					price: fmtPrice(pr?.basePrice ?? pr?.price),
					oldPrice: fmtPrice(pr?.compareAtPrice ?? pr?.oldPrice),
					discount: !!(pr?.compareAtPrice || pr?.oldPrice),
					// BloomProductCard читает эти поля напрямую (colors.length,
					// inStock) — без них SSR падает. storefront-data их не несёт →
					// дефолты: без свотчей, в наличии (как реальный сайт).
					colors: [] as string[],
					inStock: pr?.inStock !== false,
					volume: typeof pr?.volume === "string" ? pr.volume : undefined,
				};
			});
		}
	} catch {
		realProducts = [];
	}
}

// Канон headingSize (top-level приоритетнее legacy heading.size): 'small'
// (canon-default) и отсутствие = шапка DS NtSectionHeading верстальщика дословно
// (20/24/32); medium → 38px, large → 46px (§9, перекрытие утилитой на обёртке —
// внутрь DS-компонента класс не пробрасывается).
const headingSize = p.headingSize ?? p.heading?.size;
const headingSizeCls =
	headingSize === "medium"
		? " [&_h2]:!text-[38px]"
		: headingSize === "large"
			? " [&_h2]:!text-[46px]"
			: "";
// Канон textSize: 'small' (canon-default) и отсутствие = подзаголовок DS
// дословно (14/18/24); medium → 29px, large → 35px (множители ряда §9 от xl-базы 24).
const textSize = p.textSize ?? p.text?.size;
const textSizeCls =
	textSize === "medium"
		? " [&_p]:!text-[29px]"
		: textSize === "large"
			? " [&_p]:!text-[35px]"
			: "";
// Дефолт = прежний `<div data-animate>` без class байт-в-байт.
const headWrapCls = `${headingSizeCls}${textSizeCls}`.trim() || undefined;

// Канон columns 1-6: 3 (canon-default из blockDefaults bloom) и отсутствие →
// дефолт-ветка (литерал lg:grid-cols-4); иное → inline-var на гриде с lg
// (мобильная лестница верстальщика 2→sm:3 сохраняется).
const colsRaw =
	typeof p.columns === "number" ? Math.max(1, Math.min(6, Math.round(p.columns))) : undefined;
const cols = colsRaw && colsRaw !== 3 ? colsRaw : undefined;
// Канон imageView square/portrait/wide (+legacy alias adaptive→wide): 'square'
// (canon-default) и отсутствие = aspect-square карточки верстальщика;
// portrait → 430/500, wide → 16/9 (перекрытие медиа-ссылки карточки).
const tileAspectCls =
	p.imageView === "portrait"
		? " [&_li>article>a]:aspect-[430/500]"
		: p.imageView === "wide" || p.imageView === "adaptive"
			? " [&_li>article>a]:aspect-[16/9]"
			: "";
const gridBase = "grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4";
const gridCls =
	(cols
		? "grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-[repeat(var(--cols),minmax(0,1fr))]"
		: gridBase) + tileAspectCls;
const gridStyle = cols ? `--cols:${cols}` : undefined;

// Канон quickAddMode none/standard/cart (+legacy alias count→cart). НЮАНС bloom:
// карточка верстальщика УЖЕ несёт pill «В корзину» (data-add-to-cart) — дефолт
// 'none' (canon-default) = карточка verbatim со своей кнопкой; standard/cart
// сохраняют кнопку и переименовывают её в quickAddText (носители — data-quick-add
// и data-qa-text на гриде, текст ставит скрипт ниже и на demo, и на гидрации).
const qaModeRaw = p.quickAddMode === "count" ? "cart" : p.quickAddMode;
const quickAddMode = qaModeRaw === "standard" || qaModeRaw === "cart" ? qaModeRaw : undefined;
const quickAddText =
	(typeof p.quickAddText === "string" && p.quickAddText) ||
	(quickAddMode === "cart" ? "В КОРЗИНУ" : "В корзину");

// Канон buttonStyle link/primary/secondary — стиль встроенной кнопки карточки.
// primary/отсутствие = розовый pill верстальщика дословно; secondary = контурный
// pill в тонах кнопки-1; link = текстовая ссылка. Носитель — data-btn-style на
// гриде + глобальный <style> ниже (работает и для SSR-demo, и для гидрации).
const btnStyle =
	p.buttonStyle === "secondary" || p.buttonStyle === "link" ? p.buttonStyle : undefined;

// Канон nextPhotoOnHover (toggle, true/'true'): смена фото на вторую картинку
// товара при наведении. Носитель данных: data-image-2 на <li> (demo —
// gallery[1] верстальщика; реальные товары — images[1], ставит гидрация).
const nextPhoto = p.nextPhotoOnHover === true || p.nextPhotoOnHover === "true";
// is:inline + set:html (без define:vars — компилятор секций его не умеет);
// идемпотентность data-np-hydrated; без data-image-2 скрипт — no-op без ошибок.
const NEXT_PHOTO_JS = [
	"(function(){",
	"var grids=document.querySelectorAll('[data-nt=\"popular-grid\"][data-next-photo]');",
	"for(var i=0;i<grids.length;i++){(function(g){",
	"if(g.getAttribute('data-np-hydrated')==='true')return;",
	"g.setAttribute('data-np-hydrated','true');",
	"function swap(li,on){",
	"var u=on?li.getAttribute('data-image-2'):null;",
	"var im=li.querySelectorAll('img');",
	"for(var j=0;j<im.length;j++){",
	"if(on){if(!im[j].getAttribute('data-image-1'))im[j].setAttribute('data-image-1',im[j].getAttribute('src')||'');im[j].setAttribute('src',u);}",
	"else{var s1=im[j].getAttribute('data-image-1');if(s1)im[j].setAttribute('src',s1);}",
	"}",
	"var so=li.querySelectorAll('source');",
	"for(var k=0;k<so.length;k++){",
	"if(on){if(!so[k].getAttribute('data-srcset-1'))so[k].setAttribute('data-srcset-1',so[k].getAttribute('srcset')||'');so[k].setAttribute('srcset',u);}",
	"else{var ss=so[k].getAttribute('data-srcset-1');if(ss)so[k].setAttribute('srcset',ss);}",
	"}",
	"}",
	"g.addEventListener('mouseover',function(e){",
	"var t=e.target;if(!t||!t.closest)return;",
	"var li=t.closest('li[data-image-2]');",
	"if(!li||!g.contains(li)||li.getAttribute('data-np-on')==='true')return;",
	"li.setAttribute('data-np-on','true');swap(li,true);",
	"});",
	"g.addEventListener('mouseout',function(e){",
	"var t=e.target;if(!t||!t.closest)return;",
	"var li=t.closest('li[data-image-2]');",
	"if(!li||li.getAttribute('data-np-on')!=='true')return;",
	"var to=e.relatedTarget;if(to&&li.contains(to))return;",
	"li.setAttribute('data-np-on','false');swap(li,false);",
	"});",
	"})(grids[i]);}",
	"})();",
].join("");

// Канон viewAll {show,text,href}: кнопка под гридом — «Смотреть все товары»
// коллекции (Figma 1-33175, контракт rose Popular). По умолчанию ПОКАЗАНА
// (часть дизайна секции), скрыть — viewAll.show === false. Текст по умолчанию
// «Смотреть все товары»; href ведёт на каталог выбранной коллекции
// (?collection=) либо в общий каталог.
const viewAllRaw = p.viewAll;
const viewAllShow = !(
	viewAllRaw &&
	typeof viewAllRaw === "object" &&
	(viewAllRaw.show === false || viewAllRaw.show === "false")
);
const viewAllText =
	(!!viewAllRaw && typeof viewAllRaw === "object" && typeof viewAllRaw.text === "string" && viewAllRaw.text) ||
	"Смотреть все товары";
const viewAllCollection =
	typeof p.collection === "string" && p.collection.trim() ? p.collection.trim() : "";
const viewAllHref =
	(!!viewAllRaw && typeof viewAllRaw === "object" && typeof viewAllRaw.href === "string" && viewAllRaw.href) ||
	(viewAllCollection ? `/catalog?collection=${encodeURIComponent(viewAllCollection)}` : "/catalog");
// Стиль кнопки «Смотреть все» = единый «Стиль кнопки» секции (buttonStyle, Figma
// 1195-42536): link = текстовая ссылка с подчёркиванием, secondary = контурный
// pill в тонах кнопки-1, primary/отсутствие = розовый pill верстальщика (заливка
// кнопки-1). Манера bloom: font-inter font-light, rounded-button (100px).
const viewAllBase =
	"inline-flex h-12 items-center justify-center font-inter text-[16px] font-light leading-none transition-opacity";
const viewAllCls =
	p.buttonStyle === "link"
		? `${viewAllBase} px-0 text-[rgb(var(--color-text,0_0_0))] underline underline-offset-4 hover:opacity-70`
		: p.buttonStyle === "secondary"
			? `${viewAllBase} rounded-[var(--radius-button,100px)] border border-solid border-[rgb(var(--color-button-bg,227_142_159))] bg-transparent px-6 text-[rgb(var(--color-button-bg,227_142_159))] hover:opacity-90 active:scale-95`
			: `${viewAllBase} rounded-[var(--radius-button,100px)] bg-[rgb(var(--color-button-bg,227_142_159))] px-6 text-[rgb(var(--color-button-text,255_255_255))] hover:opacity-90 active:scale-95`;

// blockDefaults bloom headingAlignment/cardCaptionStyle — ключи вне канон-полей
// Popular, игнорируются (решение аналитика).

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id="popular"
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-[80px] pt-[80px] md:px-20 md:pb-[120px] md:pt-[120px] 2xl:px-[300px]"
	aria-labelledby="popular-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-10">
		<div
			data-animate
			class={headWrapCls}
			data-puck-subsection-parent={id}
			data-puck-subsection-index="100"
			data-puck-subsection-field="heading"
		>
			<NtSectionHeading titleId="popular-title" title={sectionTitle} subtitle={sectionSubtitle} />
		</div>

		<ul
			class={gridCls}
			role="list"
			data-animate
			data-animate-delay="0.1s"
			data-nt="popular-grid"
			style={gridStyle}
			data-cards={cardsN !== 4 ? String(cardsN) : undefined}
			data-collection={collectionRef}
			data-next-photo={nextPhoto ? "true" : undefined}
			data-quick-add={quickAddMode}
			data-qa-text={quickAddMode ? quickAddText : undefined}
			data-btn-style={btnStyle}
		>
			{/* SSR-цель (Figma 1:19335): коллекция ВЫБРАНА → реальные товары (фетч в
			    frontmatter, работает и в превью-Container); НЕ выбрана/пусто →
			    плейсхолдер-куртки. data-collection остаётся → клиентская гидрация на
			    live освежает данные. */}
			{realProducts.length > 0
				? realProducts.map((product: any) => (
						<li data-product-id={product.id} data-image-2={nextPhoto ? product.gallery?.[1] : undefined}>
							<BloomProductCard product={product} />
						</li>
					))
				: placeholderCards.map((ph) => (
						<li>
							<article class="flex flex-col gap-4" data-nt="bloom-product-card-placeholder" aria-label={ph.title}>
								<div class="relative block aspect-square w-full overflow-hidden rounded-[12px] bg-[rgb(var(--color-surface,245_245_245))]">
									<img
										src={ph.image}
										alt={ph.title}
										loading="lazy"
										class="absolute inset-0 h-full w-full object-contain p-[15%]"
									/>
								</div>
								<div class="flex flex-col gap-2">
									<span class="bloom-product-name font-inter text-[16px] font-light leading-none text-[rgb(var(--color-text,0_0_0))]">
										{ph.title}
									</span>
									<span class="bloom-product-price font-inter text-[16px] font-light leading-none text-[rgb(var(--color-text,0_0_0))]">
										{ph.price}
									</span>
								</div>
							</article>
						</li>
					))}
		</ul>{viewAllShow && (
			<div class="flex w-full justify-center">
				<a
					href={viewAllHref}
					class={viewAllCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="102"
					data-puck-subsection-field="viewAll"
				>
					{viewAllText}
				</a>
			</div>
		)}
	</div>
</section>{nextPhoto && <script is:inline set:html={NEXT_PHOTO_JS} />}

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		resolveCollectionProducts,
		renderCardHtml,
		escapeHtml,
	} from "../../lib/storefront-hydrate";

	// Текст встроенной кнопки карточки (quickAddText): применяется и к demo-SSR,
	// и к перерисованным гидрацией карточкам (renderCardHtml несёт «В корзину»).
	const applyQaText = (grid: HTMLElement) => {
		const text = grid.getAttribute("data-qa-text");
		if (!text) return;
		for (const btn of Array.from(grid.querySelectorAll<HTMLElement>("[data-add-to-cart]"))) {
			if (btn.textContent !== text) btn.textContent = text;
		}
	};

	// Реальные товары (Option B, rose-паритет Popular): первые N из
	// /data/products.json (N = data-cards грида, дефолт 4 — поведение
	// верстальщика). Канон-поля T13 поверх: data-collection → фильтр по
	// выбранной коллекции, data-next-photo → data-image-2 (вторая картинка
	// товара) для hover-скрипта, data-qa-text → текст кнопки карточки.
	// Demo-сборка → no-op (только переименование кнопки).
	const hydratePopular = async () => {
		const grids = Array.from(document.querySelectorAll<HTMLElement>('[data-nt="popular-grid"]'));
		if (grids.length === 0) return;
		const products = await loadRealProducts();
		if (!products) {
			for (const grid of grids) applyQaText(grid);
			return;
		}
		const needCollections = grids.some((g) => g.getAttribute("data-collection"));
		const collections = needCollections ? await loadRealCollections() : null;
		for (const grid of grids) {
			const limitRaw = Number(grid.getAttribute("data-cards"));
			const limit = Number.isFinite(limitRaw) && limitRaw > 0 ? limitRaw : 4;
			const wantNextPhoto = grid.hasAttribute("data-next-photo");
			const collectionRef = grid.getAttribute("data-collection");
			// Shopify-модель: без выбранной коллекции / пустая коллекция → оставляем
			// SSR-моки (demo), не подтягиваем весь каталог магазина.
			if (!collectionRef) continue;
			const pool = resolveCollectionProducts(products, collections, collectionRef);
			if (pool.length === 0) continue;
			const items = pool.slice(0, limit);
			grid.innerHTML = items
				.map((p) => {
					const img2 =
						wantNextPhoto && Array.isArray(p.images) && p.images[1]
							? ` data-image-2="${escapeHtml(p.images[1])}"`
							: "";
					return `<li data-product-id="${escapeHtml(p.id)}"${img2}>${renderCardHtml(p)}</li>`;
				})
				.join("");
			applyQaText(grid);
		}
	};

	hydratePopular();
	document.addEventListener("astro:page-load", hydratePopular);
</script>

<style is:global>
	/* Канон buttonStyle: перекрытие встроенной pill-кнопки карточки верстальщика
	   (и demo-SSR, и гидрированной разметки renderCardHtml). Дефолт (без
	   data-btn-style) — без правил, карточка байт-в-байт. */
	[data-nt="popular-grid"][data-btn-style="secondary"] [data-add-to-cart] {
		background: transparent;
		border: 1px solid rgb(var(--color-button-bg, 227 142 159));
		color: rgb(var(--color-button-bg, 227 142 159));
	}

	[data-nt="popular-grid"][data-btn-style="link"] [data-add-to-cart] {
		background: transparent;
		color: rgb(var(--color-text, 0 0 0));
		text-decoration: underline;
		text-underline-offset: 4px;
	}
</style>
