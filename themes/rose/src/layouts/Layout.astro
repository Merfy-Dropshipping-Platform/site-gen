---
import BaseHead from "../components/BaseHead.astro";
import PromoBanner from "../components/sections/PromoBanner.astro";
import Header from "../components/Header.astro";
import CheckoutHeader from "../../../../packages/theme-base/blocks/CheckoutHeader/CheckoutHeader.astro";
import CheckoutFooterStrip from "../../../../packages/theme-base/blocks/CheckoutFooterStrip/CheckoutFooterStrip.astro";
import Footer from "../components/Footer.astro";
import StorefrontRuntime from "../components/StorefrontRuntime.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { ViewTransitions } from "astro:transitions";

interface Props {
	title?: string;
	description?: string;
	// "checkout" → минимальная шапка оформления (CheckoutHeader, Figma 1:13563)
	// без PromoBanner; иначе обычная шапка магазина. build.service патчит бренд
	// CheckoutHeader под мерчанта на сборке сайта.
	header?: "default" | "checkout";
}

const { title, description = SITE_DESCRIPTION, header = "default" } = Astro.props;
const pageTitle = title ? `${title} — ${SITE_TITLE}` : SITE_TITLE;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={pageTitle} description={description} />
		{/* VT отключены на checkout: ClientRouter пере-выполняет is:inline-скрипты на
		    astro:page-load → cart-store грузится дважды → форма/сводка перерисовываются
		    ~1с = «скачки интерфейса». Checkout терминальный → грузим полной страницей. */}
		{header !== "checkout" && <ViewTransitions />}
		<slot name="head" />
	</head>
	<body class="antialiased bg-[rgb(var(--color-bg,255_255_255))]">
		{header === "checkout" ? (
			<div class="color-scheme-2" style="--size-checkout-brand:24px;--size-checkout-brand-image:32px;display:contents;">
				<CheckoutHeader siteTitle={SITE_TITLE} logoMode="text" logoImage={null} rightIcon="cart" accountLink="/account" backLink="/cart" cartLink="/cart" padding={{ top: 24, bottom: 24 }} />
			</div>
		) : (
			<Fragment>
				{/* Обёртка схемы зеркалит композер v2 (PromoBanner.colorScheme=scheme-4):
				    на сложных страницах tokens.css задаёт :root=scheme-1, без обёртки полоса белеет. */}
				<div class="color-scheme-4" data-block-scheme="4">
					<PromoBanner />
				</div>
				<Header />
			</Fragment>
		)}
		<main>
			<slot />
		</main>
		{/* Чекаут — без рассылки/меню (чистое оформление), но с чёрной полосой
		    копирайта (CheckoutFooterStrip): легальная строка должна быть. Полный
		    Footer — только на остальных страницах. */}
		{header !== "checkout" ? (
			<Footer />
		) : (
			<div class="color-scheme-2" style="display:contents;">
				<CheckoutFooterStrip siteTitle={SITE_TITLE} />
			</div>
		)}
		<StorefrontRuntime />

		<script>
			// Scroll-triggered анимации для секций
			const initScrollAnimations = () => {
				const targets = document.querySelectorAll<HTMLElement>("[data-animate]");
				if (!targets.length) return;

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								observer.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.08, rootMargin: "0px 0px -36px 0px" }
				);

				targets.forEach((el, i) => {
					const delay = el.dataset.animateDelay;
					if (delay) el.style.animationDelay = delay;
					observer.observe(el);
				});
			};

			initScrollAnimations();
			document.addEventListener("astro:after-swap", initScrollAnimations);
		</script>
	</body>
</html>
