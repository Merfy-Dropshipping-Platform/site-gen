---
interface Props {
	href: string;
	ariaLabel: string;
}

const { href, ariaLabel } = Astro.props;
---

<a
	href={href}
	aria-label={ariaLabel}
	class="w-6 h-6 flex items-center justify-center hover:opacity-70 transition-opacity"
>
	<svg
		class="w-full h-full"
		viewBox="0 0 24 24"
		fill="none"
		xmlns="http://www.w3.org/2000/svg"
	>
		<circle cx="12" cy="12" r="11.5" stroke="currentColor" opacity="0.6" />
	</svg>
</a>
