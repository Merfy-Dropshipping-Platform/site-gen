---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthShell from '../components/auth/AuthShell.astro';
import AuthInput from '../components/auth/AuthInput.astro';
import PasswordField from '../components/auth/PasswordField.astro';
import AuthButton from '../components/auth/AuthButton.astro';
import AuthSecondaryLink from '../components/auth/AuthSecondaryLink.astro';
import OtpInput from '../components/auth/islands/OtpInput.tsx';
import ResendTimer from '../components/auth/islands/ResendTimer.tsx';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import data from '../data/data.json';
import siteConfig from '../data/site-config.json';

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};
---
<BaseLayout title={`Восстановление пароля — ${meta?.title ?? 'Мой сайт'}`}>
  <Header {...headerProps} />
  <!--
    Reset-password 3-state flow:
      1. mode-email — ввод email (default)
      2. mode-otp — 4-значный OTP (?step=otp&email=...)
      3. mode-new-password — после успешного verify, ввод нового пароля (resetCredential в sessionStorage)
    Плюс legacy token-link mode (?token=...) для старых писем — обратная совместимость.
  -->
  <div id="mode-email" class="contents">
    <AuthShell
      title="Восстановление аккаунта"
      description="Мы отправим вам код подтверждения на этот e-mail"
    >
      <form id="email-form" class="w-full flex flex-col gap-6" novalidate>
        <AuthInput
          label="E-mail"
          type="email"
          name="email"
          id="forgot-email"
          placeholder="example@merfy.ru"
          required
          autocomplete="email"
        />
        <div class="auth-helper-error hidden text-center" id="email-error" role="alert"></div>
      </form>

      <div class="w-full flex flex-col items-center gap-8">
        <AuthButton id="btn-email-continue" form="email-form" loadingLabel="Отправка...">Продолжить</AuthButton>
        <AuthSecondaryLink href="/login" variant="muted">Вернуться назад</AuthSecondaryLink>
      </div>
    </AuthShell>
  </div>

  <div id="mode-otp" class="hidden contents">
    <AuthShell
      title="Восстановление аккаунта"
      description="Введите код подтверждения с вашего e-mail"
    >
      <div class="w-full flex flex-col items-center gap-20">
        <OtpInput client:load id="reset-otp" name="code" length={4} />
        <ResendTimer client:load id="reset-resend" seconds={60} />
      </div>

      <div class="w-full flex flex-col items-center gap-8">
        <div class="auth-helper-error hidden text-center" id="otp-error" role="alert"></div>
        <AuthButton id="btn-otp-continue" loadingLabel="Проверка...">Продолжить</AuthButton>
        <AuthSecondaryLink href="#" id="otp-back" variant="muted">Вернуться назад</AuthSecondaryLink>
      </div>
    </AuthShell>
  </div>

  <div id="mode-new-password" class="hidden contents">
    <AuthShell title="Новый пароль">
      <form id="new-password-form" class="w-full flex flex-col gap-6" novalidate>
        <PasswordField
          label="Новый пароль"
          name="password"
          id="new-password"
          placeholder="Минимум 8 символов"
          required
          minlength={8}
          autocomplete="new-password"
        />
        <PasswordField
          label="Подтвердите пароль"
          name="confirmPassword"
          id="new-confirm"
          placeholder="Повторите пароль"
          required
          minlength={8}
          autocomplete="new-password"
        />
        <div class="auth-helper-error hidden text-center" id="new-password-error" role="alert"></div>
      </form>

      <div class="w-full flex flex-col items-center gap-8">
        <AuthButton id="btn-new-password" form="new-password-form" loadingLabel="Сохранение...">Сменить пароль</AuthButton>
        <AuthSecondaryLink href="/login" variant="muted">Вернуться ко входу</AuthSecondaryLink>
      </div>
    </AuthShell>
  </div>

  <!-- Legacy token-link mode (?token=) — обратная совместимость со старыми письмами -->
  <div id="mode-legacy-token" class="hidden contents">
    <AuthShell title="Новый пароль">
      <form id="legacy-form" class="w-full flex flex-col gap-6" novalidate>
        <PasswordField
          label="Новый пароль"
          name="password"
          id="legacy-password"
          placeholder="Минимум 8 символов"
          required
          minlength={8}
          autocomplete="new-password"
        />
        <PasswordField
          label="Подтвердите пароль"
          name="confirmPassword"
          id="legacy-confirm"
          placeholder="Повторите пароль"
          required
          minlength={8}
          autocomplete="new-password"
        />
        <div class="auth-helper-error hidden text-center" id="legacy-error" role="alert"></div>
      </form>

      <div class="w-full flex flex-col items-center gap-8">
        <AuthButton id="btn-legacy" form="legacy-form" loadingLabel="Сохранение...">Сменить пароль</AuthButton>
        <AuthSecondaryLink href="/login" variant="muted">Вернуться ко входу</AuthSecondaryLink>
      </div>
    </AuthShell>
  </div>

  <Footer {...footerProps} />

  <script is:inline src="/scripts/customer-store.js"></script>
  <script is:inline src="/scripts/customer-auth.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var params = new URLSearchParams(window.location.search);
      var legacyToken = params.get('token');

      // Modes
      var modeEmail = document.getElementById('mode-email');
      var modeOtp = document.getElementById('mode-otp');
      var modeNewPassword = document.getElementById('mode-new-password');
      var modeLegacyToken = document.getElementById('mode-legacy-token');

      function showMode(mode) {
        [modeEmail, modeOtp, modeNewPassword, modeLegacyToken].forEach(function(m) {
          m.classList.add('hidden');
        });
        mode.classList.remove('hidden');
      }

      // ============ Legacy token-link mode (old emails) ============
      if (legacyToken) {
        showMode(modeLegacyToken);
        setupLegacyTokenHandler(legacyToken);
        return;
      }

      // Determine initial mode based on ?step= or sessionStorage
      var step = params.get('step');
      var emailParam = params.get('email');

      if (step === 'otp' && emailParam) {
        sessionStorage.setItem('resetEmail', emailParam);
        showMode(modeOtp);
        setupOtpHandlers(emailParam);
      } else if (step === 'new-password') {
        var savedCredential = sessionStorage.getItem('resetCredential');
        if (savedCredential) {
          showMode(modeNewPassword);
          setupNewPasswordHandlers(savedCredential);
        } else {
          // Нет credential — возврат на step 1
          showMode(modeEmail);
          setupEmailHandlers();
        }
      } else {
        showMode(modeEmail);
        setupEmailHandlers();
      }

      // ============ STEP 1: email ============
      function setupEmailHandlers() {
        var form = document.getElementById('email-form');
        var errorEl = document.getElementById('email-error');
        var btn = document.getElementById('btn-email-continue');
        var loadingEl = btn.querySelector('[data-loading]');
        var textEl = btn.querySelector('[data-button-text]');

        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          errorEl.classList.add('hidden');

          var emailInput = document.getElementById('forgot-email');
          var email = emailInput.value.trim();
          if (!email) {
            emailInput.setAttribute('data-error', 'true');
            errorEl.textContent = 'Введите e-mail';
            errorEl.classList.remove('hidden');
            return;
          }
          if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            emailInput.setAttribute('data-error', 'true');
            errorEl.textContent = 'Введите корректный e-mail';
            errorEl.classList.remove('hidden');
            return;
          }
          emailInput.setAttribute('data-error', 'false');

          loadingEl.classList.remove('hidden');
          textEl.classList.add('hidden');
          btn.disabled = true;

          try {
            await window.CustomerAuth.requestResetOTP({ email: email });
            sessionStorage.setItem('resetEmail', email);
            // Переход на step 2 через URL (shareable, refresh-safe)
            window.location.search = '?step=otp&email=' + encodeURIComponent(email);
          } catch (err) {
            var msg = 'Не удалось отправить код. Попробуйте позже';
            if (err && err.error && err.error.code === 'RATE_LIMIT_EXCEEDED') {
              msg = 'Слишком много запросов. Попробуйте позже';
            }
            errorEl.textContent = msg;
            errorEl.classList.remove('hidden');
            loadingEl.classList.add('hidden');
            textEl.classList.remove('hidden');
            btn.disabled = false;
          }
        });

        btn.addEventListener('click', function() { form.requestSubmit(); });
      }

      // ============ STEP 2: OTP ============
      function setupOtpHandlers(email) {
        var errorEl = document.getElementById('otp-error');
        var btn = document.getElementById('btn-otp-continue');
        var loadingEl = btn.querySelector('[data-loading]');
        var textEl = btn.querySelector('[data-button-text]');
        var backLink = document.getElementById('otp-back');
        var currentCode = '';
        var submitting = false;

        function clearOtpError() {
          document.querySelectorAll('.auth-otp-cell').forEach(function(c) {
            c.style.borderColor = '';
            c.style.outlineColor = '';
          });
        }
        function markOtpError() {
          document.querySelectorAll('.auth-otp-cell').forEach(function(c) {
            c.style.borderColor = '#FCA5A5';
          });
        }

        // Collect digits when all 4 entered, auto-submit
        window.addEventListener('otp:complete', function(e) {
          currentCode = e.detail.value;
          clearOtpError();
          if (!submitting) {
            submitting = true;
            submitOtp();
          }
        });

        // Clear error on any typing in OTP cells
        document.querySelectorAll('.auth-otp-cell').forEach(function(cell) {
          cell.addEventListener('input', function() { errorEl.classList.add('hidden'); clearOtpError(); });
        });

        // Resend handler
        window.addEventListener('otp:resend-request', async function() {
          errorEl.classList.add('hidden');
          try {
            await window.CustomerAuth.resendResetOTP({ email: email });
            window.dispatchEvent(new CustomEvent('otp:resend-ack', { detail: { id: 'reset-resend', seconds: 60 } }));
          } catch (err) {
            errorEl.textContent = 'Не удалось отправить код повторно';
            errorEl.classList.remove('hidden');
          }
        });

        async function submitOtp() {
          errorEl.classList.add('hidden');

          if (!currentCode || currentCode.length !== 4) {
            errorEl.textContent = 'Введите все 4 цифры';
            errorEl.classList.remove('hidden');
            submitting = false;
            return;
          }

          loadingEl.classList.remove('hidden');
          textEl.classList.add('hidden');
          btn.disabled = true;

          try {
            var result = await window.CustomerAuth.verifyResetOTP({ email: email, code: currentCode });
            if (result.success && result.data && result.data.resetCredential) {
              sessionStorage.setItem('resetCredential', result.data.resetCredential);
              window.location.search = '?step=new-password';
            } else {
              throw result;
            }
          } catch (err) {
            var code = err && err.error && err.error.code;
            var msg = 'Неверный код';
            if (code === 'OTP_EXPIRED') msg = 'Код устарел. Запросите новый';
            else if (code === 'OTP_INVALIDATED') msg = 'Слишком много неверных попыток. Запросите новый код';
            else if (err.error && err.error.attemptsRemaining !== undefined) {
              msg = 'Неверный код. Осталось попыток: ' + err.error.attemptsRemaining;
            }
            errorEl.textContent = msg;
            errorEl.classList.remove('hidden');
            markOtpError();
            loadingEl.classList.add('hidden');
            textEl.classList.remove('hidden');
            btn.disabled = false;
            submitting = false;
          }
        }

        btn.addEventListener('click', function(e) {
          e.preventDefault();
          if (!submitting) {
            submitting = true;
            submitOtp();
          }
        });

        backLink.addEventListener('click', function(e) {
          e.preventDefault();
          sessionStorage.removeItem('resetEmail');
          window.location.search = '';
        });
      }

      // ============ STEP 3: new password ============
      function setupNewPasswordHandlers(credential) {
        var form = document.getElementById('new-password-form');
        var errorEl = document.getElementById('new-password-error');
        var btn = document.getElementById('btn-new-password');
        var loadingEl = btn.querySelector('[data-loading]');
        var textEl = btn.querySelector('[data-button-text]');

        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          errorEl.classList.add('hidden');

          var passInput = document.getElementById('new-password');
          var confInput = document.getElementById('new-confirm');
          var password = passInput.value;
          var confirm = confInput.value;

          passInput.setAttribute('data-error', 'false');
          confInput.setAttribute('data-error', 'false');

          if (!password) {
            passInput.setAttribute('data-error', 'true');
            errorEl.textContent = 'Введите новый пароль';
            errorEl.classList.remove('hidden');
            return;
          }
          if (password.length < 8) {
            passInput.setAttribute('data-error', 'true');
            errorEl.textContent = 'Пароль должен быть не менее 8 символов';
            errorEl.classList.remove('hidden');
            return;
          }
          if (!confirm) {
            confInput.setAttribute('data-error', 'true');
            errorEl.textContent = 'Подтвердите пароль';
            errorEl.classList.remove('hidden');
            return;
          }
          if (password !== confirm) {
            confInput.setAttribute('data-error', 'true');
            errorEl.textContent = 'Пароли не совпадают';
            errorEl.classList.remove('hidden');
            return;
          }

          loadingEl.classList.remove('hidden');
          textEl.classList.add('hidden');
          btn.disabled = true;

          try {
            var result = await window.CustomerAuth.setNewPassword({ resetCredential: credential, password: password });
            if (result.success) {
              sessionStorage.removeItem('resetCredential');
              sessionStorage.removeItem('resetEmail');
              window.location.href = '/login';
              return;
            } else {
              throw result;
            }
          } catch (err) {
            var code = err && err.error && err.error.code;
            var msg = 'Не удалось сменить пароль';
            if (code === 'CREDENTIAL_EXPIRED' || code === 'CREDENTIAL_INVALID') {
              msg = 'Сессия восстановления истекла. Запросите новый код';
              sessionStorage.removeItem('resetCredential');
            } else if (code === 'PASSWORD_TOO_SHORT') {
              msg = 'Пароль должен быть не менее 8 символов';
            }
            errorEl.textContent = msg;
            errorEl.classList.remove('hidden');
            loadingEl.classList.add('hidden');
            textEl.classList.remove('hidden');
            btn.disabled = false;
          }
        });

        btn.addEventListener('click', function() { form.requestSubmit(); });
      }

      // ============ LEGACY: token-link из старых писем ============
      function setupLegacyTokenHandler(token) {
        var form = document.getElementById('legacy-form');
        var errorEl = document.getElementById('legacy-error');
        var btn = document.getElementById('btn-legacy');
        var loadingEl = btn.querySelector('[data-loading]');
        var textEl = btn.querySelector('[data-button-text]');

        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          errorEl.classList.add('hidden');

          var password = document.getElementById('legacy-password').value;
          var confirm = document.getElementById('legacy-confirm').value;

          if (password !== confirm) {
            errorEl.textContent = 'Пароли не совпадают';
            errorEl.classList.remove('hidden');
            return;
          }
          if (password.length < 8) {
            errorEl.textContent = 'Пароль должен быть не менее 8 символов';
            errorEl.classList.remove('hidden');
            return;
          }

          loadingEl.classList.remove('hidden');
          textEl.classList.add('hidden');
          btn.disabled = true;

          try {
            var result = await window.CustomerAuth.resetPassword({ token: token, password: password });
            if (result.success) {
              window.location.href = '/account';
            } else {
              throw result;
            }
          } catch (err) {
            var msg = 'Не удалось сменить пароль';
            if (err.error === 'TOKEN_EXPIRED' || err.code === 'TOKEN_EXPIRED') {
              msg = 'Ссылка устарела. Запросите новую.';
            }
            errorEl.textContent = msg;
            errorEl.classList.remove('hidden');
            loadingEl.classList.add('hidden');
            textEl.classList.remove('hidden');
            btn.disabled = false;
          }
        });

        btn.addEventListener('click', function() { form.requestSubmit(); });
      }
    });
  </script>
</BaseLayout>
