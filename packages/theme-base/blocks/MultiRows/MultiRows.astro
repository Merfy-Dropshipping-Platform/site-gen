---
import type { MultiRowsProps } from './MultiRows.puckConfig';
import { MultiRowsClasses as C } from './MultiRows.classes';

interface Props extends MultiRowsProps {
  id?: string;
}

const raw = Astro.props as Record<string, unknown>;
const {
  id,
  rows = [],
  padding,
} = raw as Props;

const colorScheme = raw.colorScheme as string | undefined;
const schemeClass = colorScheme ? `color-scheme-${String(colorScheme).replace('scheme-', '')}` : '';

const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';

// Pupa parity: nested heading object.
const headingObj = raw.heading as { text?: string; alignment?: string; size?: string } | string | undefined;
const headingText = typeof headingObj === 'string' ? headingObj : headingObj?.text;
const headingAlignment = (typeof headingObj === 'object' ? headingObj?.alignment : undefined) ?? raw.headingAlignment;
const headingSize = (typeof headingObj === 'object' ? headingObj?.size : undefined) ?? raw.headingSize;
const headingAlignClass =
  headingAlignment === 'left' ? 'text-left' :
  headingAlignment === 'right' ? 'text-right' :
  headingAlignment === 'center' ? 'text-center' : 'text-center';
const headingSizeClass =
  headingSize === 'large' ? 'text-4xl md:text-5xl' :
  headingSize === 'medium' ? 'text-3xl md:text-4xl' :
  headingSize === 'small' ? 'text-2xl md:text-3xl' : 'text-3xl md:text-4xl';

// Pupa: rowsPosition (alternate, left, right).
const rowsPosition = typeof raw.rowsPosition === 'string' ? raw.rowsPosition : '';
---
<section
  class:list={[C.root, schemeClass]}
  data-puck-component-id={id}
  style={paddingStyle}
>
  <div class={C.container}>
    {headingText && (
      <h2 class:list={[headingAlignClass, headingSizeClass, 'mb-8 font-medium']} data-puck-subsection-parent={id} data-puck-subsection-index="100" data-puck-subsection-field="heading">{headingText}</h2>
    )}
    <div class={C.stack}>
      {rows.map((row: any, i: number) => {
        // Pupa: rowsPosition alternate → odd rows mirror.
        let imagePos = row.imagePosition;
        if (rowsPosition === 'alternate') imagePos = i % 2 === 0 ? 'left' : 'right';
        else if (rowsPosition === 'left') imagePos = 'left';
        else if (rowsPosition === 'right') imagePos = 'right';
        const variantKey = imagePos === 'right' ? 'imageRight' : 'imageLeft';
        const rowImage = row.image || row.imageUrl;
        const rowTitle = row.title ?? row.heading;
        const rowDescription = row.description ?? row.text;
        const buttonHref =
          (row.button && typeof row.button === 'object' && 'link' in row.button && typeof row.button.link === 'string')
            ? row.button.link
            : row.button?.href;
        return (
          <div
            class={C.row[variantKey]}
            data-row-id={row.id}
            data-image-position={imagePos}
            data-puck-subsection-parent={id}
            data-puck-subsection-index={i}
            data-puck-subsection-field="rows"
          >
            <div class={C.imageCol[variantKey]}>
              {rowImage && (
                <img src={rowImage} alt={rowTitle ?? ''} class={C.image} />
              )}
            </div>
            <div class={C.textCol[variantKey]}>
              {rowTitle && <h3 class={C.rowHeading}>{rowTitle}</h3>}
              {rowDescription && <p class={C.rowText}>{rowDescription}</p>}
              {row.button?.text && (
                <a href={buttonHref ?? '#'} class={C.button}>{row.button.text}</a>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
