---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";

interface FaqItem {
	q: string;
	a: string;
}

interface Props {
	items?: FaqItem[];
}

const defaultItems: FaqItem[] = [
	{
		q: "Как узнать свой размер?",
		a: "Рекомендуем воспользоваться таблицей размеров, которая есть в карточке каждого товара. Указывайте свои мерки (обхват груди, талии, бёдер) и сверяйте их с таблицей. Если сомневаетесь, напишите нашему консультанту в онлайн-чат с вашими параметрами — мы поможем подобрать подходящий размер.",
	},
	{
		q: "Какой у вас срок доставки?",
		a: "Время доставки в регионы России занимает от 3 до 10 рабочих дней в зависимости от удалённости. Точные сроки и стоимость вы увидите при оформлении заказа, выбрав свой город.",
	},
	{
		q: "Можно ли вернуть или обменять товар?",
		a: "Да, конечно. В соответствии с законом о защите прав потребителей вы можете обменять неподошедшую вещь (кроме изделий из категорий «бельё» и «носки») в течение 14 дней с момента получения при сохранении товарного вида, бирок и чека.",
	},
];

const { items = defaultItems } = Astro.props;
---

<section class="satin-pad w-full bg-white py-10 md:py-14" aria-label="Частые вопросы">
	<div class="satin-container flex flex-col divide-y divide-[#DDDDDD]">
		{items.map((item, index) => (
			<details class="group py-5" open={index === 0} data-faq-item>
				<summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-logo text-[18px] font-normal uppercase leading-[1.2] text-[#000000] md:text-[20px] [&::-webkit-details-marker]:hidden">
					<span>{item.q}</span>
					<NtIcon name="plus" sizeClass="size-8" class="shrink-0 group-open:hidden" />
					<NtIcon name="minus" sizeClass="size-8" class="hidden shrink-0 group-open:block" />
				</summary>
				<div class="overflow-hidden" data-faq-answer>
						<p class="satin-copy mt-3 max-w-[1100px]">{item.a}</p>
					</div>
			</details>
		))}
	</div>
</section>
