---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/data.json';
import siteConfig from '../data/site-config.json';
import products from '../data/products.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PopularProducts from '../components/PopularProducts.astro';
import CatalogIsland from '../components/react/CatalogIsland';

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};
const branding = (siteConfig as any)?.branding ?? {};
---
<BaseLayout title={`Каталог — ${meta?.title ?? 'Мой сайт'}`} description={meta?.description}>
  <div class="catalog-page flex flex-col flex-1" style="background: #EEEEEE; color: rgb(var(--color-foreground));">
    <Header {...headerProps} />

    <main class="catalog-main flex-1 w-full max-w-[1320px] mx-auto">
      <!-- Page title block -->
      <div style="margin-bottom: 40px;">
        <h1
          class="font-heading italic"
          style="font-size: 20px; font-weight: 400; text-transform: uppercase; line-height: 1.2; color: rgb(var(--color-foreground)); margin: 0;"
        >КАТАЛОГ</h1>
      </div>

      <CatalogIsland client:only="react" />

      <noscript>
        <PopularProducts products={products} />
      </noscript>
    </main>

    <Footer {...footerProps} />
  </div>
</BaseLayout>

<style>
  .catalog-main {
    padding-left: 16px;
    padding-right: 16px;
    padding-top: 40px;
    padding-bottom: 40px;
  }
  @media (min-width: 640px) {
    .catalog-main {
      padding-left: 24px;
      padding-right: 24px;
      padding-top: 60px;
      padding-bottom: 60px;
    }
  }
  @media (min-width: 768px) {
    .catalog-main {
      padding-left: 32px;
      padding-right: 32px;
      padding-top: 80px;
      padding-bottom: 80px;
    }
  }
  @media (min-width: 1024px) {
    .catalog-main {
      padding-left: 64px;
      padding-right: 64px;
      padding-top: 100px;
      padding-bottom: 100px;
    }
  }
  @media (min-width: 1280px) {
    .catalog-main {
      padding-left: 96px;
      padding-right: 96px;
      padding-top: 120px;
      padding-bottom: 120px;
    }
  }
  @media (min-width: 1536px) {
    .catalog-main {
      padding-left: 300px;
      padding-right: 300px;
      padding-top: 120px;
      padding-bottom: 120px;
    }
  }
</style>
