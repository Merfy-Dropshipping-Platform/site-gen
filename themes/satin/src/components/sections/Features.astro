---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { withBase } from "../../lib/with-base";

interface Feature {
	title: string;
	body: string;
	icon: string;
}

interface Props {
	items?: Feature[];
}

// Legacy-блок верстальщика «Преимущества» (НЕ Puck-секция конструктора — нет в
// satinRegistry; его канон-наследник = MultiColumns.astro). Раньше при вызове
// без пропсов рисовал мок-демо верстальщика (2 карточки материалы/доставка с
// иконками /images/4x/feature-*.png). По контракту пустого состояния (Figma
// 1:19335, тип «MultiColumns», эталон satin MultiColumns.astro + rose
// MultiColumns.astro) мок ЗАМЕНЁН на ДОСЛОВНЫЙ ПЛЕЙСХОЛДЕР: заголовок
// «Мультиколонны» + 3 нейтральные surface-колонки (пустой rect
// rgb(var(--color-surface)) + «Колонна» + хелпер «Сочетай текст…» + per-column
// ссылка «Кнопка» в КАЖДОЙ колонке, не общая). Когда страница/мерчант реально
// передаёт items[] — рендер его данных без изменений (иконка 56×56 + title + body).
const { items } = Astro.props as Props;
const hasItems = Array.isArray(items) && items.length > 0;

// Пустое состояние (Figma 1:19335, тип «MultiColumns»): пустой rect
// (rgb(var(--color-surface))) + «Колонна» + хелпер + per-column ссылка «Кнопка».
// Текст ДОСЛОВНО совпадает с контрактом «Мультиколонны» (паритет satin
// MultiColumns.astro / rose MultiColumns.astro).
const PLACEHOLDER_HEADING = "Мультиколонны";
const PLACEHOLDER_COLUMN = {
	heading: "Колонна",
	text: "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.",
	link: { text: "Кнопка", href: "/catalog" },
};
const PLACEHOLDER_COUNT = 3;
---

<section class="satin-pad w-full bg-[rgb(var(--color-bg,255_255_255))] py-10 md:py-20" aria-label="Преимущества">
	{hasItems ? (
		<div class="satin-container grid grid-cols-1 gap-4 md:grid-cols-2">
			{items!.map((feature) => (
				<div class="flex flex-col items-center gap-6 bg-[rgb(var(--color-surface,245_245_245))] p-6 text-center">
					<img
						src={feature.icon.startsWith("/") ? withBase(feature.icon) : feature.icon}
						alt=""
						width="56"
						height="56"
						loading="lazy"
						class="h-14 w-14 shrink-0 object-contain"
						aria-hidden="true"
					/>
					<h3 class="font-logo text-[18px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))] md:text-[20px]">{feature.title}</h3>
					<p class="satin-copy max-w-[560px]">{feature.body}</p>
				</div>
			))}
		</div>
	) : (
		<div class="satin-container flex flex-col gap-8">
			{/* Дословный Figma-заголовок пустого состояния (контракт «MultiColumns»):
			    «Мультиколонны» (паритет satin MultiColumns.astro / rose). */}
			<h2 class="font-logo text-[20px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))]">{PLACEHOLDER_HEADING}</h2>
			<ul class="grid grid-cols-1 gap-4 md:grid-cols-3" role="list">
				{Array.from({ length: PLACEHOLDER_COUNT }).map(() => (
					<li class="flex flex-col items-center gap-6 text-center">
						{/* Пустой rect-плейсхолдер: подложка rgb(var(--color-surface))
						    вместо иконки-картинки колонки (паритет satin MultiColumns). */}
						<div
							class="aspect-[4/3] w-full bg-[rgb(var(--color-surface,251_251_251))]"
							aria-hidden="true"
						/>
						<h3 class="font-logo text-[18px] font-normal uppercase leading-[1.15] text-[rgb(var(--color-heading,0_0_0))] md:text-[20px]">{PLACEHOLDER_COLUMN.heading}</h3>
						<p class="max-w-[560px] text-[16px] font-light leading-[1.5] text-[rgb(var(--color-muted,153_153_153))]">{PLACEHOLDER_COLUMN.text}</p>
						{/* Per-column ссылка-плейсхолдер «Кнопка» в КАЖДОЙ колонке (Figma
						    1:19335, дословно как rose/satin MultiColumns.astro — не общая снизу). */}
						<a
							href={PLACEHOLDER_COLUMN.link.href}
							class="inline-flex items-center gap-2 font-manrope text-[14px] font-normal uppercase leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70"
						>
							<span>{PLACEHOLDER_COLUMN.link.text}</span>
							<NtIcon name="arrow-right" sizeClass="size-5" />
						</a>
					</li>
				))}
			</ul>
		</div>
	)}
</section>
