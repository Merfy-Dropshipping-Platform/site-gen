---
// Фаза B (bloom, группа misc): новая канон-секция Publications в манере bloom
// (см. themes/bloom/MANNER.md §4/§9/§11; rose-эталона НЕТ — в карте rose 15
// позиций без Publications). Схема полей = packages/theme-base/blocks/
// Publications/Publications.puckConfig.ts.
// ПУСТОЕ СОСТОЯНИЕ (нет реальных публикаций) = ПЛЕЙСХОЛДЕР по контракту Figma
// 1:19335 (3 колонки: пустой image-rect + «Колонна» + «Сочетай текст…» + кнопка), НЕ
// мок-демо верстальщика (статьи про уход + /images/trend-*.webp). Когда у
// магазина есть реальные публикации (SSR fetch /api/sites/<id>/publications →
// fallback publications.json) — рендерим их без изменений (Shopify-модель, как
// theme-base PopularProducts/Collections/MultiColumns: пустое = заглушка,
// данные = реальный контент). Платформенный резолв по publicationType остаётся
// data-атрибутом на гриде.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон heading (string | { text, alignment, size }); canon-default «Публикации».
// Роль = заголовок секции §1 (Collections.astro:18), акцент-токен #E38E9F.
const heading = typeof p.heading === "string" ? p.heading : (p.heading?.text ?? "Публикации");
// Лестница §9 (база-литерал 18/md:20 = canon-default medium): small 15/17, large 22/24.
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[15px] md:text-[17px]"
		: headingSize === "large"
			? "text-[22px] md:text-[24px]"
			: "text-[18px] md:text-[20px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " text-center"
		: headingAlignment === "right"
			? " text-right"
			: "";
const headingCls = `font-urbanist ${headingSizeCls} font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))]${headingAlignCls}`;

// Канон columnsCount (slider 1-6) приоритетнее hidden columns (1-4); дефолт 3.
// Дефолт = лестница литералов товарного грида манеры (Collections.astro:24,
// 1 → sm:2 → lg:3); иное значение — CSS-var на lg-брейкпоинте.
const columnsRaw =
	typeof p.columnsCount === "number" ? p.columnsCount : typeof p.columns === "number" ? p.columns : 3;
const columns = Math.max(1, Math.min(6, Math.round(columnsRaw) || 3));
const gridCls =
	columns === 3
		? "grid w-full grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3 lg:gap-x-[16px] lg:gap-y-10"
		: "grid w-full grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-[repeat(var(--pub-cols),minmax(0,1fr))] lg:gap-x-[16px] lg:gap-y-10";
const gridStyle = columns === 3 ? undefined : `--pub-cols:${columns};`;

// Канон cardsCount (slider 1-12) приоритетнее hidden cards (1-4); дефолт 3 карточки.
const cardsRaw =
	typeof p.cardsCount === "number" ? p.cardsCount : typeof p.cards === "number" ? p.cards : 3;
const cards = Math.max(1, Math.min(12, Math.round(cardsRaw) || 3));

// Канон showDateTime (toggle) / legacy dateTime.enabled (hidden). Паритет
// theme-base Publications.astro (dateTimeEnabled = enabled !== 'false'): дата
// показана ПО УМОЛЧАНИЮ (нет пропа = показать), скрывается ТОЛЬКО при явном
// 'false'. Раньше bloom дефолтил в 'false' (дата скрыта на реальных публикациях
// без выставленного тумблера) — расходилось с эталоном.
const showDate = String(p.showDateTime ?? p.dateTime?.enabled ?? "true") !== "false";

// Канон publicationType (pagePicker) — носитель data-атрибут на гриде для
// платформенного резолва публикаций.
const publicationType =
	typeof p.publicationType === "string" && p.publicationType ? p.publicationType : undefined;

// Реальные публикации: SSR fetch storefront-data (gateway → sites-service) c
// fallback на build-time publications.json (паттерн canonical theme-base
// Publications.astro). siteId инжектит build pipeline / preview controller.
type RawPublication = {
	id: string;
	title?: string;
	slug?: string;
	excerpt?: string;
	coverImageUrl?: string | null;
	publishedAt?: string | null;
};
const siteIdFromRoot = typeof p.siteId === "string" ? p.siteId : "";
let realPublications: RawPublication[] = [];
if (siteIdFromRoot) {
	try {
		const internalBase =
			(import.meta as unknown as { env?: { SITES_INTERNAL_BASE?: string } }).env?.SITES_INTERNAL_BASE ??
			"http://localhost:3114";
		const res = await fetch(`${internalBase}/api/sites/${siteIdFromRoot}/publications`).catch(() => null);
		if (res && res.ok) {
			const data = (await res.json()) as { publications?: RawPublication[] };
			realPublications = data.publications ?? [];
		}
	} catch {
		/* swallow */
	}
}
try {
	if (realPublications.length === 0) {
		const pubData = await import("../data/publications.json");
		realPublications = ((pubData as { default?: RawPublication[] }).default ??
			(pubData as unknown as RawPublication[])) as RawPublication[];
	}
} catch {
	/* swallow — publications.json отсутствует */
}

function formatPubDate(iso: string | null | undefined): string {
	if (!iso) return "";
	try {
		return new Intl.DateTimeFormat("ru-RU", { day: "numeric", month: "long", year: "numeric" }).format(
			new Date(iso),
		);
	} catch {
		return "";
	}
}

// Гейт пустого состояния (Shopify-модель): есть реальные публикации → рендерим
// их; нет — ПЛЕЙСХОЛДЕР по контракту Figma 1:19335 (3 колонки: пустой image-rect
// + «Колонна» + «Сочетай текст…» + кнопка), НЕ мок-демо верстальщика.
const hasRealPublications = realPublications.length > 0;
// ДОСЛОВНЫЙ Figma-плейсхолдер (контракт типа «Publications» 1:19335): колонка =
// дизайн-ассет /placeholders/publication-card.png (раздаётся на каждой теме из
// packages/theme-base/public/placeholders, copyPublic) + «Колонна» + «Сочетай
// текст…» + кнопка (= «стрелки/кнопки» контракта, рендер как «Кнопка» в манере
// bloom MultiColumns). Фото показывается ВСЕГДА (НЕ пустой image-rect, контракт
// картиночных секций). Текст байт-в-байт совпадает с MultiColumns.astro PLACEHOLDER_TEXT.
const PLACEHOLDER_IMAGE = "/placeholders/publication-card.png";
const PLACEHOLDER_TEXT = "Сочетай текст, чтобы подчеркнуть плюсы товара или коллекции.";
const PLACEHOLDER_LINK_TEXT = "Кнопка";
const PLACEHOLDER_LINK_HREF = "/catalog";
type PubItem = {
	title: string;
	date: string;
	image: string;
	slug?: string;
	isPlaceholder: boolean;
};
const items: PubItem[] = hasRealPublications
	? realPublications.slice(0, cards).map((pub) => ({
			title: pub.title ?? "",
			date: formatPubDate(pub.publishedAt),
			image: pub.coverImageUrl ?? "",
			slug: pub.slug,
			isPlaceholder: false,
		}))
	: Array.from({ length: cards }, () => ({
			title: "Колонна",
			date: "",
			image: PLACEHOLDER_IMAGE,
			isPlaceholder: true,
		}));

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 pb-20 pt-20 md:px-20 md:pb-[120px] md:pt-[120px] 2xl:px-[300px]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-10">
		{
			heading && (
				<div data-animate>
					<h2
						id={titleId}
						class={headingCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="100"
						data-puck-subsection-field="heading"
					>
						{heading}
					</h2>
				</div>
			)
		}

		<div
			class={gridCls}
			style={gridStyle}
			data-publication-type={publicationType}
			data-animate
			data-animate-delay="0.1s"
		>
			{
				items.map((item, i) => {
					const href = item.slug ? `/publication/${item.slug}` : undefined;
					const Wrapper = href ? "a" : "article";
					return (
						<Wrapper class="flex flex-col gap-4" href={href} data-publication-index={i}>
							{/* Медиа: реальная обложка ИЛИ дизайн-ассет publication-card.png
							   (плейсхолдер) → <img>. Публикация без обложки → пустой image-rect
							   surface (item.image=''). Контракт Figma 1:19335 (картиночная секция:
							   фото плейсхолдера показывается всегда). */}
							<div class="group relative aspect-[652/594] w-full overflow-hidden rounded-[var(--radius-media,12px)] bg-[rgb(var(--color-surface,245_245_245))]">
								{item.image && (
									<img
										src={item.image}
										alt={item.title}
										loading="lazy"
										class="absolute inset-0 size-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
									/>
								)}
							</div>
							<div class="flex flex-col gap-1">
								{showDate && !item.isPlaceholder && item.date && (
									<span class="font-inter text-[14px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]">
										{item.date}
									</span>
								)}
								<span class="font-inter text-[16px] font-light leading-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70">
									{item.title}
								</span>
								{/* Пустое состояние — ДОСЛОВНЫЙ Figma-плейсхолдер (контракт
								   «Publications»): хелпер-текст «Сочетай текст…» + кнопка
								   «Кнопка» (= «стрелки/кнопки» контракта), как bloom MultiColumns. */}
								{item.isPlaceholder && (
									<p class="font-inter text-[14px] font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]">
										{PLACEHOLDER_TEXT}
									</p>
								)}
								{item.isPlaceholder && (
									<a
										href={PLACEHOLDER_LINK_HREF}
										class="mt-2 font-inter text-[16px] font-light leading-none text-[rgb(var(--color-text,0_0_0))] underline underline-offset-4 transition-opacity hover:opacity-70"
									>
										{PLACEHOLDER_LINK_TEXT}
									</a>
								)}
							</div>
						</Wrapper>
					);
				})
			}
		</div>
	</div>
</section>
