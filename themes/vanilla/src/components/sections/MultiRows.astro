---
// Фаза B (vanilla): новая канон-секция MultiRows в манере vanilla (см.
// themes/vanilla/MANNER.md §10: секции нет у верстальщика — ряды «текст +
// медиа» по паттерну care-бэнда Gallery.astro:82-123 / about-сплита, с
// чередованием сторон). Светлая секция §2, медиа 652/366 без радиуса на тоне
// плейсхолдера §4, типографика §1, solid-CTA §3. Процесс-эталон — bloom
// MultiRows. Схема полей = packages/theme-base/blocks/MultiRows/
// MultiRows.puckConfig.ts.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон top-heading: string | { text, alignment, size } (+ legacy
// _headingLegacy). Figma 1:19335 — ПУСТОЕ состояние секции «Мультиряды»:
// дословный заголовок «Мультиряды» (а НЕ отсутствие шапки / дефолт-копирайт
// верстальщика). Мерчант задал свой heading → его и рендерим (?? срабатывает
// только при пустых данных). Роль = заголовок секции на светлом (Bitter italic
// 20 #26311C, Col:20). Лестница §9: medium/отсутствие = литерал 20, small 17,
// large 24.
const heading =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p._headingLegacy ?? "Мультиряды";
const headingSize = p.headingSize ?? p.heading?.size;
const headingSizeCls =
	headingSize === "small" ? "text-[17px]" : headingSize === "large" ? "text-[24px]" : "text-[20px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center" ? " text-center" : headingAlignment === "right" ? " text-right" : "";
const headingCls = `font-vanilla-bitter ${headingSizeCls} font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]${headingAlignCls}`;

// ──────────────────────────────────────────────────────────────────────────
// Гейт пустого состояния (Figma 1:19335 / 1:19953 — empty-state ЗАМЕНЯЕТ мок
// верстальщика). Данные этой секции = массив РЯДОВ. Пока мерчант не наполнил
// rows[] — секция в плейсхолдер-режиме: пустые surface-rect + дефолтные лейблы
// контракта Мультирядов («Изображение с текстом» / «Покажи и расскажи о своём
// товаре в одном блоке» / Кнопка), НЕ дизайнерский мок-бэнд верстальщика
// (текстиль/декор + реальные фото). Как только ряды заданы — рендер реальных
// данных без изменений. Эталон гейта: Collections.astro (hasManualCollections),
// PopularProducts.astro (collectionRef → DEMO_PRODUCTS).
const hasManualRows = Array.isArray(p.rows) && p.rows.length > 0;

// Канон rows[] 1-10 (item: heading|title, text|description, imageUrl|image,
// imagePosition, button {text, href|link}, size per-item, headingSize/textSize).
// Отсутствие массива → ПЛЕЙСХОЛДЕР контракта: 2 пустых ряда-болванки (лейблы
// Мультирядов), чередование лево/право. НЕ реальные заголовки/фото верстальщика.
// Дизайн-ассет фото ряда (Figma 1:19335) — раздаётся на каждой теме как
// /placeholders/landscape-multirows-image.png. Контракт картиночных секций:
// фото показывается ВСЕГДА (НЕ пустой surface-rect, НЕ мок верстальщика).
const PLACEHOLDER_ROW_IMAGE = "/placeholders/landscape-multirows-image.png";
const PLACEHOLDER_ROWS = [
	{
		id: "ph-row-1",
		heading: "Изображение с текстом",
		text: "Покажи и расскажи о своем товаре в одном блоке",
		imageUrl: PLACEHOLDER_ROW_IMAGE,
		imagePosition: "left",
		button: { text: "Кнопка", href: "/catalog" },
	},
	{
		id: "ph-row-2",
		heading: "Изображение с текстом",
		text: "Покажи и расскажи о своем товаре в одном блоке",
		imageUrl: PLACEHOLDER_ROW_IMAGE,
		imagePosition: "right",
		button: { text: "Кнопка", href: "/catalog" },
	},
];
const rawRows = hasManualRows ? p.rows : PLACEHOLDER_ROWS;

// Канон rowsPosition: left | right — все картинки с одной стороны; alternate /
// отсутствие — per-item imagePosition, иначе чередование по индексу.
const rowsPosition =
	p.rowsPosition === "left" || p.rowsPosition === "right" ? p.rowsPosition : undefined;

// Канон size (s/m/l) — аспект медиа ряда (топ-уровень, per-item приоритетнее).
// Лестница как у ImageWithText: medium/отсутствие = фото care-бэнда 652/366
// (литерал §4), small = широкое 16/9, large = квадрат.
const aspectFor = (s: string | undefined) =>
	s === "small" ? "aspect-[16/9]" : s === "large" ? "aspect-square" : "aspect-[652/366]";

// Фоллбек-ассеты дизайнера для РЯДА С ДАННЫМИ, но без выбранного фото (реальный
// ряд мерчанта → красивая болванка, принцип T15 rose). В плейсхолдер-режиме
// (hasManualRows=false) НЕ применяется — там пустой surface-rect по контракту.
// .webp — на диске после images:optimize (под Container API fs-резолв
// VanillaPicture недоступен).
const ROW_FALLBACKS = ["/images/vanilla-collection-textile.webp", "/images/vanilla-collection-decor.webp"];

// Шкалы per-item размеров: заголовок ряда = роль заголовка секции (лестница
// §9: 17/20*/24); текст = body-роль 16 (small 14, large 19).
const rowHeadingSizeCls = (s: string | undefined) =>
	s === "small" ? "text-[17px]" : s === "large" ? "text-[24px]" : "text-[20px]";
const rowTextSizeCls = (s: string | undefined) =>
	s === "small" ? "text-[14px]" : s === "large" ? "text-[19px]" : "text-base";

const rows = rawRows.slice(0, 10).map((r: any, i: number) => {
	const btnText =
		typeof r.button?.text === "string" && r.button.text.trim() ? r.button.text : undefined;
	return {
		heading:
			(typeof r.heading === "string" && r.heading) || (typeof r.title === "string" && r.title) || "",
		text:
			(typeof r.text === "string" && r.text) ||
			(typeof r.description === "string" && r.description) ||
			"",
		image:
			(typeof r.imageUrl === "string" && r.imageUrl.trim()) ||
			(typeof r.image === "string" && r.image.trim()) ||
			// Реальный ряд без фото → дизайнерский фоллбек. Плейсхолдер-ряды уже
			// несут PLACEHOLDER_ROW_IMAGE (берётся первой веткой выше), поэтому
			// сюда в пустом состоянии не попадают.
			(hasManualRows ? ROW_FALLBACKS[i % ROW_FALLBACKS.length] : PLACEHOLDER_ROW_IMAGE),
		right:
			rowsPosition === "right" ||
			(rowsPosition !== "left" &&
				(r.imagePosition === "right" || (r.imagePosition !== "left" && i % 2 === 1))),
		aspectCls: aspectFor(r.size ?? p.size),
		headingCls: rowHeadingSizeCls(r.headingSize),
		textCls: rowTextSizeCls(r.textSize),
		btnText,
		btnHref:
			(typeof r.button?.href === "string" && r.button.href ? r.button.href : undefined) ??
			r.button?.link?.href ??
			(typeof r.button?.link === "string" && r.button.link ? r.button.link : undefined) ??
			"/catalog",
	};
});

// Канон width (s/m/l/full): large/отсутствие = 1320 (.vanilla-container,
// контейнер манеры §2 без сужения), medium 1080, small 780, full — без лимита.
const widthCls =
	p.width === "small"
		? "max-w-[780px]"
		: p.width === "medium"
			? "max-w-[1080px]"
			: p.width === "full"
				? "max-w-none"
				: "max-w-[1320px]";

// Канон alignment — выравнивание текстовой колонки рядов (отсутствие = left,
// манера vanilla — всё слева, items-start).
const alignCls =
	p.alignment === "center"
		? "items-center text-center"
		: p.alignment === "right"
			? "items-end text-right"
			: "items-start text-left";

// Канон buttonStyle: solid/primary/black/отсутствие = solid-CTA манеры §3
// (bg полотна №2 #3A4530, белый текст, h-12 px-4 Arsenal 16 uppercase);
// outlined = бордер цвета заливки на прозрачном; white = кнопка-2 (белая
// заливка, текст цвета полотна №2). Радиус 0 ≡ var(--radius-button,0px);
// active:scale в манере НЕ используется (§3).
const btnBase =
	"inline-flex h-12 min-h-12 items-center justify-center rounded-[var(--radius-button,0px)] px-4 font-vanilla-arsenal text-base font-normal uppercase leading-none tracking-normal transition-opacity hover:opacity-90";
const btnCls =
	p.buttonStyle === "outlined"
		? `${btnBase} border border-[rgb(var(--color-button-bg,58_69_48))] bg-transparent text-[rgb(var(--color-button-bg,58_69_48))]`
		: p.buttonStyle === "white"
			? `${btnBase} bg-[rgb(var(--color-button-2-bg,255_255_255))] text-[rgb(var(--color-button-2-text,58_69_48))]`
			: `${btnBase} bg-[rgb(var(--color-button-bg,58_69_48))] text-[rgb(var(--color-button-text,255_255_255))]`;

// Канон containerColorScheme (hidden) — класс схемы на контейнере рядов.
const containerSchemeCls =
	typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

// colorScheme навешивает обёрткой composeV2Page; фон секции — токен с
// фоллбеком родного светлого фона (#EEEEEE = 238 238 238, МАННЕРА §7).
const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="vanilla-pad w-full bg-[rgb(var(--color-bg,238_238_238))] py-20 md:py-28"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class={`vanilla-container flex ${widthCls} flex-col gap-8${containerSchemeCls}`}>
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-animate
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}
		<ul class="flex w-full flex-col gap-10" role="list">
			{
				rows.map((r, i) => (
					<li
						class="grid w-full grid-cols-1 gap-4 md:gap-10 lg:grid-cols-2"
						data-animate
						data-puck-subsection-parent={id}
						data-puck-subsection-index={i}
						data-puck-subsection-field="rows"
					>
						<div
							class={`group relative w-full overflow-hidden rounded-[var(--radius-media,0px)] bg-[rgb(var(--color-surface,236_235_231))] ${r.aspectCls}${r.right ? " lg:order-2" : ""}`}
							aria-hidden={r.image ? undefined : "true"}
						>
							{r.image && (
								<img
									src={r.image}
									alt={r.heading || "Ряд"}
									loading="lazy"
									decoding="async"
									class="absolute inset-0 size-full object-cover transition-transform duration-300 ease-out group-hover:scale-105"
								/>
							)}
						</div>
						<div class={`flex w-full flex-col ${alignCls} lg:self-center${r.right ? " lg:order-1" : ""}`}>
							{r.heading && (
								<h3
									class={`font-vanilla-bitter ${r.headingCls} font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,38_49_28))]`}
								>
									{r.heading}
								</h3>
							)}
							{r.text && (
								<div
									class={`mt-5 w-full font-vanilla-arsenal ${r.textCls} font-normal leading-[1.45] text-[rgb(var(--color-muted,68_68_68))]`}
									set:html={r.text}
								/>
							)}
							{r.btnText && (
								<a href={r.btnHref} class={`mt-10 ${btnCls}`}>
									{r.btnText}
								</a>
							)}
						</div>
					</li>
				))
			}
		</ul>
	</div>
</section>
