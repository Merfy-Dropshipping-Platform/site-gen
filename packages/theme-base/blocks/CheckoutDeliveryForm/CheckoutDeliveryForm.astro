---
// CheckoutDeliveryForm — vanilla Astro + inline script (без React island).
// Floating-label паттерн + country dropdown + DaData автокомплит для city/address.
// DaData токен читается из window.__DADATA_TOKEN__ (инжектится в live build
// через meta.dadataToken; в preview iframe — через preview.service.ts).
import type { CheckoutDeliveryFormProps } from './CheckoutDeliveryForm.puckConfig';
import { CheckoutDeliveryFormClasses as C } from './CheckoutDeliveryForm.classes';

interface Props extends CheckoutDeliveryFormProps { id?: string; }
const {
  id,
  heading,
  country,
  nameField,
  cityDadata,
  addressDadata,
  indexAutoFill,
  requiredFields,
  padding,
} = Astro.props as Props;
const paddingStyle = padding
  ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;`
  : '';
---
<section
  class={C.root}
  data-puck-component-id={id}
  data-checkout-delivery
  style={paddingStyle}
>
  <h2 class={C.heading}>{heading}</h2>
  <div class={C.fields}>
    {country.enabled && (
      <div
        class={C.field}
        data-checkout-field="country"
        data-country-default={country.default}
        data-country-selectable={String(country.selectable)}
      >
        <input
          class={country.selectable ? C.inputWithIcon + ' cursor-pointer caret-transparent' : C.input}
          id="checkout-country"
          name="country"
          type="text"
          autocomplete="off"
          value={country.default}
          placeholder=" "
          readonly={!country.selectable}
          data-country-input
        />
        <label class={C.label} for="checkout-country">Страна/Регион</label>
        {country.selectable && (
          <span class={C.chevron} data-country-chevron>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </span>
        )}
        {country.selectable && (
          <ul class={C.dropdown} data-country-list hidden></ul>
        )}
      </div>
    )}

    {nameField.enabled && (nameField.splitFirstLast ? (
      <div class={C.fieldRow2}>
        <div class={C.field} data-checkout-field="firstName">
          <input class={C.input} id="checkout-firstName" name="firstName" type="text" autocomplete="off" placeholder=" " />
          <label class={C.label} for="checkout-firstName">Имя</label>
        </div>
        <div class={C.field} data-checkout-field="lastName">
          <input class={C.input} id="checkout-lastName" name="lastName" type="text" autocomplete="off" placeholder=" " />
          <label class={C.label} for="checkout-lastName">Фамилия</label>
        </div>
      </div>
    ) : (
      <div class={C.field} data-checkout-field="fullName">
        <input class={C.input} id="checkout-fullName" name="fullName" type="text" autocomplete="off" placeholder=" " />
        <label class={C.label} for="checkout-fullName">ФИО</label>
      </div>
    ))}

    {/* Город + Индекс — один ряд, 65/35 на десктопе. Индекс не вешает
        одиночный ряд, и логически связан с городом (postal_code города). */}
    <div class={C.cityIndexRow}>
      <div class={C.field} data-checkout-field="city" data-dadata={String(cityDadata)}>
        <input
          class={cityDadata ? C.inputWithIcon : C.input}
          id="checkout-city"
          name="city"
          type="text"
          autocomplete="off"
          placeholder=" "
          data-checkout-dadata-input="city"
        />
        <label class={C.label} for="checkout-city">Город</label>
        {cityDadata && (
          <span class={C.searchIcon}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
          </span>
        )}
        {cityDadata && (
          <ul class={C.dropdown} data-checkout-dadata-list="city" hidden></ul>
        )}
      </div>
      <div class={C.field} data-checkout-field="postalCode" data-autofill={String(indexAutoFill)}>
        <input class={C.input} id="checkout-postal" name="postalCode" type="text" autocomplete="off" placeholder=" " />
        <label class={C.label} for="checkout-postal">Индекс</label>
      </div>
    </div>

    {/* Адрес — full row, до квартиры. */}
    <div class={C.field} data-checkout-field="address" data-dadata={String(addressDadata)}>
      <input
        class={addressDadata ? C.inputWithIcon : C.input}
        id="checkout-address"
        name="address"
        type="text"
        autocomplete="off"
        placeholder=" "
        data-checkout-dadata-input="address"
      />
      <label class={C.label} for="checkout-address">Полный адрес</label>
      {addressDadata && (
        <span class={C.searchIcon}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
        </span>
      )}
      {addressDadata && (
        <ul class={C.dropdown} data-checkout-dadata-list="address" hidden></ul>
      )}
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var section = document.querySelector('[data-checkout-delivery]');
    if (!section) return;

    var ITEM_CLS = 'block w-full text-left px-3 py-2 cursor-pointer hover:bg-[rgb(var(--color-input-bg))] [font-family:var(--font-body)] text-[length:var(--size-body)] text-[rgb(var(--color-text))]';

    function escapeHtml(s) {
      return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    // Logistics: эмитим checkout:address-changed когда меняется
    // city/postal — CheckoutDeliveryMethod слушает и пересчитывает тарифы.
    var dispatchAddressTimer;
    function dispatchAddressChange() {
      clearTimeout(dispatchAddressTimer);
      dispatchAddressTimer = setTimeout(function () {
        var cityFiasId = section.getAttribute('data-selected-city-fias-id') || '';
        var postalInput = section.querySelector('[data-checkout-field="postalCode"] input');
        var postalCode = (postalInput && postalInput.value && postalInput.value.trim()) || '';
        document.dispatchEvent(new CustomEvent('checkout:address-changed', {
          detail: { cityFiasId: cityFiasId, postalCode: postalCode },
        }));
      }, 150);
    }

    // Postal input — пользователь меняет руками → перепосчёт логистики
    var postalInput = section.querySelector('[data-checkout-field="postalCode"] input');
    if (postalInput) {
      postalInput.addEventListener('change', dispatchAddressChange);
      postalInput.addEventListener('blur', dispatchAddressChange);
    }

    // === Country selector ===
    var countryField = section.querySelector('[data-checkout-field="country"]');
    if (countryField && countryField.getAttribute('data-country-selectable') === 'true') {
      var countryInput = countryField.querySelector('[data-country-input]');
      var countryList = countryField.querySelector('[data-country-list]');
      var countryChevron = countryField.querySelector('[data-country-chevron]');

      var COUNTRIES = [
        'Российская Федерация',
        'Беларусь',
        'Казахстан',
        'Армения',
        'Киргизия',
        'Узбекистан',
        'Таджикистан',
        'Азербайджан',
        'Молдова',
        'Грузия',
        'Украина',
        'Турция',
        'Германия',
        'Польша',
        'Латвия',
        'Литва',
        'Эстония',
        'Сербия',
        'Болгария',
        'Чехия'
      ];

      countryList.innerHTML = COUNTRIES.map(function (c) {
        return '<li class="' + ITEM_CLS + '" data-country-value="' + escapeHtml(c) + '">' + escapeHtml(c) + '</li>';
      }).join('');

      function openCountryList() {
        countryList.hidden = false;
        if (countryChevron) countryChevron.style.transform = 'translateY(-50%) rotate(180deg)';
      }
      function closeCountryList() {
        countryList.hidden = true;
        if (countryChevron) countryChevron.style.transform = '';
      }

      countryInput.addEventListener('focus', openCountryList);
      countryInput.addEventListener('click', openCountryList);

      countryList.addEventListener('mousedown', function (e) {
        var li = e.target.closest && e.target.closest('[data-country-value]');
        if (!li) return;
        e.preventDefault();
        var val = li.getAttribute('data-country-value') || '';
        countryInput.value = val;
        countryInput.dispatchEvent(new Event('input', { bubbles: true }));
        closeCountryList();
      });

      document.addEventListener('click', function (e) {
        if (!countryField.contains(e.target)) closeCountryList();
      });
    }

    // === DaData autocomplete (city + address) ===
    var DADATA_URL = 'https://suggestions.dadata.ru/suggestions/api/4_1/rs/suggest/address';

    function getDadataToken() {
      return window.__DADATA_TOKEN__
        || (window.__MERFY_CONFIG__ && window.__MERFY_CONFIG__.dadataToken)
        || null;
    }

    function setupDadata(kind) {
      var input = section.querySelector('[data-checkout-dadata-input="' + kind + '"]');
      var list = section.querySelector('[data-checkout-dadata-list="' + kind + '"]');
      if (!input || !list) return;

      var debounce = null;
      var lastQuery = '';

      function shortAddrFromData(d) {
        var parts = [];
        if (d.street_with_type) parts.push(d.street_with_type);
        if (d.house) parts.push(((d.house_type || 'д') + ' ' + d.house).trim());
        if (d.flat) parts.push(((d.flat_type || 'кв') + ' ' + d.flat).trim());
        return parts.join(', ').trim();
      }

      async function fetchSuggestions(query) {
        var token = getDadataToken();
        if (!token || query.length < 2) {
          list.hidden = true;
          list.innerHTML = '';
          return;
        }
        var body = { query: query, count: 8 };
        if (kind === 'city') {
          body.from_bound = { value: 'city' };
          body.to_bound = { value: 'settlement' };
        }
        if (kind === 'address') {
          // Подсказки от улицы до квартиры — точная адресная навигация.
          body.from_bound = { value: 'street' };
          body.to_bound = { value: 'flat' };
          // Приоритет: сохранённый city_fias_id (после выбора города) → текст города → fallback страна
          var storedFiasId = section.getAttribute('data-selected-city-fias-id') || '';
          var cityInput = section.querySelector('[data-checkout-dadata-input="city"]');
          var cityVal = cityInput && cityInput.value && cityInput.value.trim();
          if (storedFiasId) {
            body.locations = [{ city_fias_id: storedFiasId }];
          } else if (cityVal) {
            body.locations = [{ city: cityVal }];
          } else {
            body.locations = [{ country: 'Россия' }];
          }
        }
        try {
          var res = await fetch(DADATA_URL, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Authorization: 'Token ' + token,
              Accept: 'application/json',
            },
            body: JSON.stringify(body),
          });
          var json = await res.json();
          var suggestions = (json && json.suggestions) || [];
          if (suggestions.length === 0) {
            list.hidden = true;
            list.innerHTML = '';
            return;
          }
          var rendered = suggestions
            .map(function (s) {
              var v = (s && s.value) || '';
              var d = (s && s.data) || {};
              var setVal = v;
              if (kind === 'address') {
                var sa = shortAddrFromData(d);
                if (sa) setVal = sa;
              }
              return { setVal: setVal, d: d };
            })
            // Фильтр: убираем подсказку identical с текущим input.value,
            // чтобы progressive refetch не показал «то же самое».
            .filter(function (r) { return r.setVal !== input.value; });

          if (rendered.length === 0) {
            list.hidden = true;
            list.innerHTML = '';
            return;
          }

          list.innerHTML = rendered.map(function (r) {
            return '<li class="' + ITEM_CLS + '"'
              + ' data-suggest-value="' + escapeHtml(r.setVal) + '"'
              + ' data-postal="' + escapeHtml(r.d.postal_code || '') + '"'
              + ' data-city="' + escapeHtml(r.d.city || '') + '"'
              + ' data-fias-id="' + escapeHtml(r.d.city_fias_id || r.d.fias_id || '') + '"'
              + '>' + escapeHtml(r.setVal) + '</li>';
          }).join('');
          list.hidden = false;
        } catch (e) {
          list.hidden = true;
        }
      }

      input.addEventListener('input', function () {
        var q = (input.value || '').trim();
        if (q === lastQuery) return;
        lastQuery = q;
        // Юзер изменил город руками → сохранённый fias_id больше не валиден
        // для фильтрации адресных подсказок. Очищаем.
        if (kind === 'city') {
          section.removeAttribute('data-selected-city-fias-id');
        }
        clearTimeout(debounce);
        debounce = setTimeout(function () { fetchSuggestions(q); }, 200);
      });

      input.addEventListener('focus', function () {
        if ((input.value || '').trim().length >= 2 && list.children.length > 0) {
          list.hidden = false;
        }
      });

      // Авто-resolve city_fias_id для paste / autofill / typing-without-click.
      // Browser autofill НЕ диспатчит input/change/blur — поэтому делаем
      // initial probe при загрузке + blur fallback при ручном выходе.
      async function resolveCityIfMissing() {
        if (kind !== 'city') return;
        if (section.getAttribute('data-selected-city-fias-id')) return;
        var q = (input.value || '').trim();
        if (q.length < 3) return;
        var token = getDadataToken();
        if (!token) return;
        try {
          var res = await fetch(DADATA_URL, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Authorization: 'Token ' + token,
              Accept: 'application/json',
            },
            body: JSON.stringify({
              query: q,
              count: 1,
              from_bound: { value: 'city' },
              to_bound: { value: 'settlement' },
            }),
          });
          var json = await res.json();
          var first = json && json.suggestions && json.suggestions[0];
          var fiasId = first && first.data && (first.data.city_fias_id || first.data.settlement_fias_id);
          if (!fiasId) return;
          section.setAttribute('data-selected-city-fias-id', fiasId);
          if (first.value && first.value !== q) {
            input.value = first.value;
            lastQuery = first.value;
          }
          var postal = first.data && first.data.postal_code;
          var postalField = section.querySelector('[data-checkout-field="postalCode"]');
          if (postalField && postalField.getAttribute('data-autofill') === 'true' && postal) {
            var pInput = postalField.querySelector('input');
            if (pInput && !pInput.value) {
              pInput.value = postal;
              pInput.dispatchEvent(new Event('change', { bubbles: true }));
            }
          }
          dispatchAddressChange();
        } catch (e) {
          // silent
        }
      }

      input.addEventListener('blur', function () {
        // 150ms — даём mousedown на suggestion отработать первым
        setTimeout(resolveCityIfMissing, 150);
      });

      // Initial probe — если value уже есть (browser autofill / SSR-prefilled).
      if (kind === 'city' && (input.value || '').trim().length >= 3) {
        setTimeout(function () {
          // Если fiasId уже выставлен — сразу диспатчим event для recalculate
          // тарифов (например после reload страницы с заполненным адресом).
          if (section.getAttribute('data-selected-city-fias-id')) {
            dispatchAddressChange();
          } else {
            resolveCityIfMissing();
          }
        }, 50);
      }

      list.addEventListener('mousedown', function (e) {
        var li = e.target.closest && e.target.closest('[data-suggest-value]');
        if (!li) return;
        e.preventDefault();
        var val = li.getAttribute('data-suggest-value') || '';
        var postal = li.getAttribute('data-postal') || '';
        var fiasId = li.getAttribute('data-fias-id') || '';

        // CRITICAL: ставим lastQuery + чистим debounce ДО смены value,
        // иначе input-event ре-триггерит fetch.
        lastQuery = val;
        clearTimeout(debounce);

        input.value = val;
        // 'change' не триггерит наш input-listener (не ре-fetch'нет DaData)
        input.dispatchEvent(new Event('change', { bubbles: true }));

        if (kind === 'city') {
          // Сохраняем city_fias_id — точная фильтрация для address-подсказок.
          if (fiasId) section.setAttribute('data-selected-city-fias-id', fiasId);
          else section.removeAttribute('data-selected-city-fias-id');
          // City selection — dropdown закрывается (нет progressive для города)
          list.hidden = true;
          list.innerHTML = '';
          // Postal autofill из city.data.postal_code — без него logistics
          // отдаёт BadRequest и тарифы СДЭК не считаются.
          var cityPostalField = section.querySelector('[data-checkout-field="postalCode"]');
          if (cityPostalField && cityPostalField.getAttribute('data-autofill') === 'true' && postal) {
            var cityPostalInput = cityPostalField.querySelector('input');
            if (cityPostalInput && !cityPostalInput.value) {
              cityPostalInput.value = postal;
              cityPostalInput.dispatchEvent(new Event('change', { bubbles: true }));
            }
          }
          // Logistics — известна новая локация → пересчитать варианты доставки
          dispatchAddressChange();
        }

        if (kind === 'address') {
          // Postal autofill ТОЛЬКО при выборе полного адреса.
          var indexField = section.querySelector('[data-checkout-field="postalCode"]');
          if (indexField && indexField.getAttribute('data-autofill') === 'true' && postal) {
            var postalInput = indexField.querySelector('input');
            if (postalInput) {
              postalInput.value = postal;
              postalInput.dispatchEvent(new Event('change', { bubbles: true }));
            }
          }

          // PROGRESSIVE DISCLOSURE: refetch в этом же dropdown'е без
          // промежуточного hide/clear. fetchSuggestions подменит innerHTML
          // когда DaData ответит. Если deeper level нет — закроет dropdown.
          fetchSuggestions(val);

          // Logistics — postal мог обновиться через autofill → пересчёт
          if (postal) dispatchAddressChange();
        }
      });

      var field = input.closest('[data-checkout-field]');
      document.addEventListener('click', function (e) {
        if (field && !field.contains(e.target)) {
          list.hidden = true;
        }
      });
    }

    setupDadata('city');
    setupDadata('address');
  })();
</script>
