---
// Figma 1:19335 — ПУСТОЕ СОСТОЯНИЕ секции «Галерея» (заменяет мок-демо
// верстальщика). Гейт = наличие выбранных в конструкторе плиток `p.items[]`
// (товар/коллекция/изображение).
//   • БЕЗ выбора (useItems=false) → ПЛЕЙСХОЛДЕР по контракту: пустой image-rect
//     + карточка-товар (куртка blue + «Товар»/«2 500 ₽») + карточка
//     «Выбери коллекцию». НЕ длинный мок-копирайт/видео/care-сплит верстальщика.
//   • С выбором (useItems=true) → промо-шапка + грид плиток в манере §4 с
//     гидрацией данных платформы (data-gallery-product / data-gallery-collection)
//     — рендер реальных данных и клиентская гидрация НЕ ТРОГАЮТСЯ.
// Цвета → токены темы (rgb(var(--color-*)) с пиксель-фоллбеком), MANNER.md §7;
// курточный ассет доступен на vanilla-сайте как и в Popular/PDP плейсхолдерах
// (theme-base/public/placeholders/* → /placeholders/* через assemble-from-packages).
const p = Astro.props as Record<string, any>;
const id = p.id;

// Плейсхолдер-куртка (Figma 1:19335) — тот же URL, что VanillaProductDetail и
// storefront-hydrate, единая декорация пустого состояния по всей теме.
const PLACEHOLDER_SWEATER_BLUE = "/placeholders/sweater-blue.png";

// Заголовок/текст шапки: рендерятся только когда мерчант их задал (пустое
// состояние = плейсхолдер-сетка без мок-копирайта верстальщика).
const sectionTitle =
	(typeof p.heading === "string" && p.heading.trim() ? p.heading : p.heading?.text) || "";
const rawText =
	(typeof p.text === "string" ? p.text : p.text?.content) ??
	(typeof p.subtitle === "string" ? p.subtitle : undefined);
const sectionText = typeof rawText === "string" && rawText.trim() ? rawText : "";

// Канон headingSize (top-level приоритетнее legacy heading.size): 'medium'
// (canon-default) и отсутствие = УЗКАЯ роль верстальщика дословно (Bitter
// italic 16, Gal:34). Лестница §9: small 14, large 20.
const headingSize = p.headingSize ?? p.heading?.size;
const headingCls =
	headingSize === "small"
		? "font-vanilla-bitter text-[14px] font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,255_255_255))]"
		: headingSize === "large"
			? "font-vanilla-bitter text-[20px] font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,255_255_255))]"
			: "font-vanilla-bitter text-[16px] font-normal italic leading-none tracking-normal text-[rgb(var(--color-heading,255_255_255))]";
// Канон textSize: лестница MANNER §9 «Текст полотна» — литерал верстальщика
// 14px/min-1920:16px = large И отсутствие пропа; small 10/11, medium 12/14.
// ⚠️ canon-default puckConfig textSize='medium' ниже литерала — рекомендация
// следующей фазе: blockDefaults Gallery.textSize='large' в theme.json.
const textSize = p.textSize ?? p.text?.size;
const textCls =
	textSize === "small"
		? "mt-10 w-full max-w-[680px] font-vanilla-arsenal text-[10px] font-normal italic leading-[1.5] text-[rgb(var(--color-text,240_240_240))] min-[1920px]:max-w-[1320px] min-[1920px]:text-[11px]"
		: textSize === "medium"
			? "mt-10 w-full max-w-[680px] font-vanilla-arsenal text-[12px] font-normal italic leading-[1.5] text-[rgb(var(--color-text,240_240_240))] min-[1920px]:max-w-[1320px] min-[1920px]:text-[14px]"
			: "mt-10 w-full max-w-[680px] font-vanilla-arsenal text-[14px] font-normal italic leading-[1.5] text-[rgb(var(--color-text,240_240_240))] min-[1920px]:max-w-[1320px] min-[1920px]:text-[16px]";

// Канон imagePosition left/right: 'left' (canon-default) = порядок плиток как
// есть; 'right' зеркалит первую пару плиток в проп-ветке.
const mirror = p.imagePosition === "right";

// Канон items[] (≤3, типы image/product/collection): плитки из пропсов.
// SSR рендерит канон-плейсхолдеры («Товар» 2 500₽ / «Выбери коллекцию»);
// резолв productId/collectionId→имя/цена/картинка/ссылка делает гидрация
// ниже (data-gallery-product/-collection): live — /data/{products,
// collections}.json, превью — storefront-data. Ссылки: товар /product?id=,
// коллекция /catalog?collection= (каталог vanilla уважает ?collection=).
type GalleryTile = {
	kind: "image" | "product" | "collection";
	url: string;
	alt: string;
	label: string;
	price: string;
	href: string;
	ref: string | null;
};
const galleryTiles: GalleryTile[] = (Array.isArray(p.items) ? p.items : [])
	.filter((x: any) => x && typeof x === "object")
	.slice(0, 3)
	.map((it: any): GalleryTile => {
		if (it.type === "product") {
			const pid = typeof it.productId === "string" && it.productId ? it.productId : null;
			return {
				kind: "product",
				url: "",
				alt: "Товар",
				label: "Товар",
				price: "2 500₽",
				href: pid ? `/product?id=${encodeURIComponent(pid)}` : "/catalog",
				ref: pid,
			};
		}
		if (it.type === "collection") {
			const cid = typeof it.collectionId === "string" && it.collectionId ? it.collectionId : null;
			return {
				kind: "collection",
				url: "",
				alt: "Коллекция",
				label: "Выбери коллекцию",
				price: "",
				href: cid ? `/catalog?collection=${encodeURIComponent(cid)}` : "/catalog",
				ref: cid,
			};
		}
		return {
			kind: "image",
			url: typeof it.url === "string" ? it.url : "",
			alt: typeof it.alt === "string" ? it.alt : "",
			label: "",
			price: "",
			href: "/catalog",
			ref: null,
		};
	});
// Плитка product/collection без своей картинки = пустой surface-rect (Figma
// 1:19335); реальную обложку подставит гидрация (data-gallery-product/-collection).
// Изображение-плитка без url тоже остаётся пустым rect (контракт пустого состояния).
const useItems = galleryTiles.length > 0;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн rose T11).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	id="gallery"
	class="w-full text-white"
	aria-labelledby="gallery-title"
	data-vanilla-gallery
	data-vanilla-stack
	data-puck-component-id={id}
	style={paddingStyle}
>
	<!-- Figma promo: laptop max 1280 / text 680×14px; desktop 1920 / text 1320×16px; py 80, gap 40 -->
	<div
		class="vanilla-pad bg-[rgb(var(--color-bg,58_69_48))] py-16 lg:py-20"
		data-gallery-promo
		data-animate
	>
		<div
			class="mx-auto flex w-full max-w-[1280px] min-[1920px]:max-w-[1320px] flex-col items-center text-center"
		>
			{sectionTitle && (
				<h2
					id="gallery-title"
					class={headingCls}
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{sectionTitle}
				</h2>
			)}
			{sectionText && (
				<p class={textCls}>
					{sectionText}
				</p>
			)}
			{useItems ? (
				<ul class="mt-10 grid w-full grid-cols-1 gap-4 text-left lg:grid-cols-2" role="list">
					{galleryTiles.map((tile, i) => (
						<li class={mirror && i === 0 ? "lg:order-2" : mirror && i === 1 ? "lg:order-1" : undefined}>
							<a
								href={tile.href}
								class="group flex w-full cursor-pointer flex-col gap-3"
								aria-label={tile.label || tile.alt || "Перейти в каталог"}
								data-gallery-product={tile.kind === "product" ? (tile.ref ?? undefined) : undefined}
								data-gallery-collection={tile.kind === "collection" ? (tile.ref ?? undefined) : undefined}
								data-puck-subsection-parent={id}
								data-puck-subsection-index={i}
								data-puck-subsection-field="items"
							>
								<div class="relative aspect-square w-full overflow-hidden bg-[rgb(var(--color-surface,236_235_231))]">
									{tile.url && (
										<img
											src={tile.url}
											alt={tile.alt || tile.label}
											loading="lazy"
											class={`absolute inset-0 size-full object-cover transition-transform duration-500 ease-out ${i === 0 ? "group-hover:scale-[1.03]" : "group-hover:scale-[1.05]"}`}
										/>
									)}
								</div>
								{(tile.label || tile.price) && (
									<div class="flex flex-col gap-1">
										{tile.label && (
											<span
												class={
													tile.kind === "collection"
														? "vanilla-gallery-collection-title font-vanilla-arsenal text-base font-normal uppercase leading-none text-[rgb(var(--color-text,240_240_240))] transition-opacity group-hover:opacity-70"
														: "vanilla-gallery-product-title font-vanilla-arsenal text-base font-normal uppercase leading-none text-[rgb(var(--color-text,240_240_240))] transition-opacity group-hover:opacity-70"
												}
											>
												{tile.label}
											</span>
										)}
										{tile.price && (
											<span class="vanilla-gallery-product-price font-vanilla-arsenal text-base font-normal leading-none text-[rgb(var(--color-text,240_240_240))]">
												{tile.price}
											</span>
										)}
									</div>
								)}
							</a>
						</li>
					))}
				</ul>
			) : (
				<!-- Figma 1:19335 пустое состояние: пустой image-rect + карточка-товар
				     (куртка blue / «Товар» / «2 500 ₽») + карточка «Выбери коллекцию».
				     Плейсхолдер вместо мок-демо верстальщика; реальные плитки рендерит
				     ветка useItems выше. -->
				<ul
					class="mt-10 grid w-full grid-cols-1 gap-4 text-left lg:grid-cols-2"
					role="list"
					data-gallery-placeholder
				>
					<li>
						<div class="flex w-full flex-col gap-3">
							<div
								class="relative aspect-square w-full overflow-hidden bg-[rgb(var(--color-surface,236_235_231))]"
								aria-hidden="true"
							></div>
						</div>
					</li>
					<li>
						<div class="flex w-full flex-col gap-3">
							<div class="relative aspect-square w-full overflow-hidden bg-[rgb(var(--color-surface,236_235_231))]">
								<img
									src={PLACEHOLDER_SWEATER_BLUE}
									alt="Товар"
									loading="lazy"
									class="absolute inset-0 size-full object-contain p-[15%]"
								/>
							</div>
							<div class="flex flex-col gap-1">
								<span class="font-vanilla-arsenal text-base font-normal uppercase leading-none text-[rgb(var(--color-text,240_240_240))]">
									Товар
								</span>
								<span class="font-vanilla-arsenal text-base font-normal leading-none text-[rgb(var(--color-text,240_240_240))]">
									2 500 ₽
								</span>
							</div>
						</div>
					</li>
					<li>
						<div class="flex w-full flex-col gap-3">
							<div
								class="relative aspect-square w-full overflow-hidden bg-[rgb(var(--color-surface,236_235_231))]"
								aria-hidden="true"
							></div>
							<div class="flex flex-col gap-1">
								<span class="font-vanilla-arsenal text-base font-normal uppercase leading-none text-[rgb(var(--color-text,240_240_240))]">
									Выбери коллекцию
								</span>
							</div>
						</div>
					</li>
				</ul>
			)}
		</div>
	</div>

</section>

<script>
	import {
		loadRealProducts,
		loadRealCollections,
		findCollection,
		formatPrice,
		productHref,
		productImage,
	} from "../../lib/storefront-hydrate";

	// Резолв выбранных в конструкторе товара/коллекции на плитках галереи
	// (data-gallery-product / data-gallery-collection). SSR несёт
	// канон-плейсхолдеры; здесь подставляем имя/цену/картинку/ссылку реальной
	// сущности. Без данных (demo-сборка) — no-op.
	const hydrateGalleryTiles = async () => {
		const prodTiles = Array.from(document.querySelectorAll<HTMLElement>("[data-gallery-product]"));
		const colTiles = Array.from(
			document.querySelectorAll<HTMLElement>("[data-gallery-collection]"),
		);
		if (prodTiles.length === 0 && colTiles.length === 0) return;
		const [products, collections] = await Promise.all([
			prodTiles.length ? loadRealProducts() : Promise.resolve(null),
			colTiles.length ? loadRealCollections() : Promise.resolve(null),
		]);
		for (const tile of prodTiles) {
			const ref = tile.getAttribute("data-gallery-product");
			const product = products?.find((x) => x.id === ref || x.slug === ref) ?? null;
			if (!product) continue;
			const title = tile.querySelector(".vanilla-gallery-product-title");
			if (title && product.name) title.textContent = product.name;
			const price = tile.querySelector(".vanilla-gallery-product-price");
			if (price) price.textContent = formatPrice(product.price);
			const img = tile.querySelector("img");
			const cover = productImage(product);
			if (img && cover) {
				img.setAttribute("src", cover);
				if (product.name) img.setAttribute("alt", product.name);
			}
			tile.setAttribute("href", productHref(product));
			if (product.name) tile.setAttribute("aria-label", product.name);
		}
		for (const tile of colTiles) {
			const col = findCollection(collections, tile.getAttribute("data-gallery-collection"));
			if (!col) continue;
			const title = tile.querySelector(".vanilla-gallery-collection-title");
			if (title && col.name) title.textContent = col.name;
			const cover = col.image || (Array.isArray(col.images) ? col.images[0] : "");
			const img = tile.querySelector("img");
			if (img && cover) {
				img.setAttribute("src", cover);
				if (col.name) img.setAttribute("alt", col.name);
			}
			if (col.name) tile.setAttribute("aria-label", col.name);
			if (col.slug) tile.setAttribute("href", `/catalog?collection=${encodeURIComponent(col.slug)}`);
		}
	};

	hydrateGalleryTiles();
	document.addEventListener("astro:page-load", hydrateGalleryTiles);
</script>
