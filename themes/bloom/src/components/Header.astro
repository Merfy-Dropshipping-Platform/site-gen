---
import NtIcon from "@merfy-dropshipping-platform/design-systems-theme/components/ui/NtIcon.astro";
import { SITE_TITLE } from "../consts";
import { DEFAULT_CATEGORY_HREF, categoryPages, getCategoryBySlug } from "../data/categories";
import { getProductById } from "../data/products";

interface NavLink {
	label: string;
	href: string;
	match?: (pathname: string) => boolean;
}

function pathnameBase(pathname: string): string {
	const base = pathname.replace(/\/+$/, "");
	return base === "" ? "/" : base;
}

function categoryHrefFromProduct(pathname: string): string | null {
	const match = pathname.match(/^\/products\/([^/]+)$/);
	if (!match?.[1]) return null;
	const product = getProductById(match[1]);
	return product ? (getCategoryBySlug(product.category)?.href ?? null) : null;
}

const defaultNav: NavLink[] = [
	...categoryPages.map((category) => ({
		label: category.label,
		href: category.href,
		match: (path: string) => path === category.href || categoryHrefFromProduct(path) === category.href,
	})),
	{ label: "О нас", href: "/about", match: (path) => path.startsWith("/about") },
];

// ОЖИВЛЕНИЕ (Фаза B, объём rose Header): канон-схема theme-base Header.puckConfig —
// siteTitle, navigationLinks, logo, logoPosition, stickiness, padding. Тело ниже —
// verbatim верстальщика; дефолтные ветки тернарников = прежним строкам байт-в-байт.
const p = Astro.props as Record<string, any>;
const id = p.id;
// Пустая строка (впрыск коэрсера live-пути) не должна гасить название магазина.
const siteTitle = typeof p.siteTitle === "string" && p.siteTitle.trim() ? p.siteTitle : SITE_TITLE;
const nav: NavLink[] =
	Array.isArray(p.navigationLinks) && p.navigationLinks.length > 0
		? p.navigationLinks.map((l: any) => ({ label: l.label ?? l.text ?? "", href: l.href ?? l.link ?? "/" }))
		: defaultNav;

// Канон logo (URL картинки; панель «Логотип» пишет в props.logo): непустая строка →
// <img> ВЫСОТОЙ var(--size-logo-width) (семантика канона: слайдер «Размер» задаёт
// высоту лого) в mobile И desktop. Дефолт = лого верстальщика /icons/Bloom.svg
// h-[19px] литералом, фоллбек токена = родные 19px.
const logo = typeof p.logo === "string" && p.logo.trim() ? p.logo : undefined;
const logoImgCls = "h-[var(--size-logo-width,19px)] w-auto max-w-[160px] object-contain";

// Канон logoPosition: 'top-center' (canon-default) → TWO rows: row1=grid [search|logo|icons],
// row2=nav centered (ЛИТЕРАЛ верстальщика, пиксель-перфект).
// 'top-left' → TWO rows: row1=flex [logo LEFT + icons RIGHT], row2=nav LEFT.
// 'center-left' → ONE row: [logo LEFT] [nav CENTER] [icons RIGHT].
// 'center-absolute' → ONE row: nav LEFT, logo ABSOLUTE-center, icons RIGHT.
const logoPosition = typeof p.logoPosition === "string" ? p.logoPosition : "";
const isTwoRow = logoPosition === "top-left" || logoPosition === "top-center";

// Канон stickiness: литерал верстальщика УЖЕ sticky top-0 z-50 — 'none' / 'always' /
// canon-default / отсутствие → sticky остаётся (правило canon-default → пиксель).
// 'scroll-up' → прячем при скролле вниз, показываем при скролле вверх: is:inline
// скрипт через data-атрибут (компилятор секций не умеет define:vars),
// идемпотентность через data-hydrated.
const stickiness = typeof p.stickiness === "string" ? p.stickiness : "";
const rootCls =
	stickiness === "scroll-up"
		? "sticky top-0 z-50 w-full transition-transform duration-300"
		: "sticky top-0 z-50 w-full";
const SCROLL_UP_JS = [
	"(function(){",
	"var root=document.querySelector('[data-bloom-sticky=\"scroll-up\"]');",
	"if(!root||root.getAttribute('data-hydrated')==='true')return;",
	"root.setAttribute('data-hydrated','true');",
	"var last=window.scrollY;",
	"window.addEventListener('scroll',function(){",
	"var y=window.scrollY;",
	"if(y>last&&y>root.offsetHeight){root.style.transform='translateY(-100%)';}else{root.style.transform='';}",
	"last=y;",
	"},{passive:true});",
	"})();",
].join("");

// Канон padding {top,bottom} — clamp ≤64 на носителе отступов верстальщика
// (desktop-контейнер py-6; мобильная строка h-16 фиксированная). blockDefaults
// {16,16} = canon-default → ЛИТЕРАЛ py-6; inline-стиль только при ином значении.
const pad = p.padding && typeof p.padding === "object" ? p.padding : undefined;
const isCanonPad = pad && Number(pad.top) === 16 && Number(pad.bottom) === 16;
const headerPad =
	pad && !isCanonPad
		? { top: Math.min(Number(pad.top) || 0, 64), bottom: Math.min(Number(pad.bottom) || 0, 64) }
		: undefined;
const headerPadStyle = headerPad
	? `padding-top:${headerPad.top}px;padding-bottom:${headerPad.bottom}px;`
	: undefined;
// Two-row outer wrapper (top-left / top-center): flex-col, same padding as original.
const desktopTwoRowWrapCls = headerPad
	? "relative mx-auto hidden w-full max-w-[1920px] px-20 md:flex 2xl:px-[300px]"
	: "relative mx-auto hidden w-full max-w-[1920px] px-20 py-6 md:flex 2xl:px-[300px]";
// Single-row outer wrapper (center-left / center-absolute): single flex row, relative for absolute logo.
const desktopSingleRowWrapCls = headerPad
	? "relative mx-auto hidden w-full max-w-[1920px] items-center px-20 md:flex 2xl:px-[300px]"
	: "relative mx-auto hidden w-full max-w-[1920px] items-center px-20 py-6 md:flex 2xl:px-[300px]";

const pathname = pathnameBase(Astro.url.pathname);
const categorySearchAction =
	categoryPages.find((category) => category.href === pathname)?.href ??
	categoryHrefFromProduct(pathname) ??
	DEFAULT_CATEGORY_HREF;
const isActive = (link: NavLink) => (link.match ? link.match(pathname) : pathname === link.href);

// Канон menuType: 'dropdown' (по умолчанию) / 'mega-menu' (Расширенное) / 'sidebar' (Боковое).
// Для mega-menu добавляем uppercase + tracking к десктопным ссылкам нав-меню.
// Для sidebar — десктопный inline-nav скрыт, показывается hamburger → правая шторка.
const menuType = typeof p.menuType === "string" ? p.menuType : "dropdown";
const isMegaMenu = menuType === "mega-menu";
const isSidebar = menuType === "sidebar";
const megaLinkCls = isMegaMenu ? "uppercase tracking-[0.06em] font-medium" : "";

// Канон menuColorScheme: опциональная отдельная цветовая схема для десктопного <nav>.
// При задании — добавляем класс color-scheme-<X> к обёртке <nav>.
const menuColorScheme = typeof p.menuColorScheme === "string" ? p.menuColorScheme : "";
const menuSchemeClass = menuColorScheme ? `color-scheme-${menuColorScheme.replace("scheme-", "")}` : "";
---

<div
	class={rootCls}
	data-bloom-header
	data-puck-component-id={id}
	data-bloom-sticky={stickiness === "scroll-up" ? "scroll-up" : undefined}
>
	{
		/* Встроенная полоса объявления — ТОЛЬКО статик-режим (без props.id):
		   в канон-композиции полоса = отдельная секция PromoBanner, иначе дубль. */
		!id && (
			<div class="w-full bg-[#E38E9F] py-2 text-center" role="region" aria-live="polite" data-bloom-announcement>
				<p class="font-inter text-[12px] font-normal uppercase leading-normal text-white">
					Акция на новую коллекцию. Узнать больше
				</p>
			</div>
		)
	}

	<header class="relative w-full overflow-visible border-b border-[#F5F5F5] bg-[rgb(var(--color-bg,255_255_255))]" data-nt="bloom-header">
		<!-- Mobile -->
		<div class="relative z-[60] flex h-16 items-center justify-between bg-[rgb(var(--color-bg,255_255_255))] px-4 md:hidden">
			<button
				type="button"
				id="bloom-burger-btn"
				data-burger-toggle
				class="flex size-8 items-center justify-center transition-opacity hover:opacity-70"
				aria-label="Меню"
				aria-expanded="false"
				aria-controls="bloom-burger"
			>
				<span class="burger-icon" data-icon="open">
					<NtIcon name="menu-burger" sizeClass="size-5" />
				</span>
				<span class="burger-icon hidden" data-icon="close">
					<NtIcon name="menu-close" sizeClass="size-5" />
				</span>
			</button>
			<a href="/" class="flex items-center hover:opacity-80" aria-label={siteTitle}>
				{
					logo ? (
						<img src={logo} alt={siteTitle} class={logoImgCls} />
					) : (
						<img
							src="/icons/Bloom.svg"
							alt={siteTitle}
							width="65"
							height="19"
							class="h-[19px] w-auto"
						/>
					)
				}
			</a>
			<div class="flex items-center gap-4">
				<button
					type="button"
					data-action="toggle-search"
					class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
					aria-label="Поиск"
					aria-expanded="false"
					aria-controls="bloom-search-panel"
				>
					<NtIcon name="search-sm" sizeClass="size-5" />
				</button>
				<button
					type="button"
					data-cart-open
					class="relative flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
					aria-label="Корзина"
				>
					<NtIcon name="cart" sizeClass="size-5" />
					<span
						data-cart-count
						data-empty="true"
						class="absolute -right-2 -top-2 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#e38e9f] px-1 font-inter text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
					>0</span>
				</button>
				<a href="/auth/sign-in" class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80" aria-label="Аккаунт">
					<NtIcon name="user" sizeClass="size-5" />
				</a>
			</div>
		</div>

		<!-- Desktop -->
		{isTwoRow ? (
			/* ── TWO-ROW LAYOUTS: top-left / top-center ── */
			<div class={desktopTwoRowWrapCls} style={headerPadStyle}>
				<div class="mx-auto flex w-full max-w-[1320px] flex-col gap-4">
					{logoPosition === "top-left" ? (
						/* top-left: Row1=[logo LEFT + icons RIGHT], Row2=[nav LEFT] */
						<>
							<div class="flex w-full items-center justify-between">
								<a href="/" class="flex items-center hover:opacity-90" aria-label={siteTitle}>
									{
										logo ? (
											<img src={logo} alt={siteTitle} class={logoImgCls} />
										) : (
											<img
												src="/icons/Bloom.svg"
												alt={siteTitle}
												width="65"
												height="19"
												class="h-[19px] w-[65px]"
											/>
										)
									}
								</a>
								<div class="flex items-center gap-4">
									<button
										type="button"
										data-action="toggle-search"
										class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
										aria-label="Поиск"
										aria-expanded="false"
										aria-controls="bloom-search-panel"
									>
										<NtIcon name="search-sm" sizeClass="size-5" />
									</button>
									<button
										type="button"
										data-cart-open
										class="relative flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
										aria-label="Корзина"
									>
										<NtIcon name="cart" sizeClass="size-5" />
										<span
											data-cart-count
											data-empty="true"
											class="absolute -right-1 -top-1 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#E38E9F] px-1 font-inter text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
										>0</span>
									</button>
									<a
										href="/auth/sign-in"
										class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
										aria-label="Аккаунт"
									>
										<NtIcon name="user" sizeClass="size-5" />
									</a>
									{isSidebar && (
										<button
											type="button"
											data-burger-toggle
											class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
											aria-label="Меню"
											aria-expanded="false"
											aria-controls="bloom-burger"
										>
											<span class="burger-icon" data-icon="open">
												<NtIcon name="menu-burger" sizeClass="size-5" />
											</span>
											<span class="burger-icon hidden" data-icon="close">
												<NtIcon name="menu-close" sizeClass="size-5" />
											</span>
										</button>
									)}
								</div>
							</div>
							<nav
								class:list={["flex flex-wrap items-center justify-start gap-8 lg:gap-10", menuSchemeClass, isSidebar && "md:!hidden"]}
								aria-label="Основная навигация"
								data-puck-subsection-parent={id}
								data-puck-subsection-index="997"
								data-puck-subsection-field="navigationLinks"
							>
								{nav.map((link) => {
									const active = isActive(link);
									return (
										<a
											href={link.href}
											aria-current={active ? "page" : undefined}
											class:list={[
												"font-inter text-[16px] font-light leading-[100%] text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70",
												active && "underline decoration-[rgb(var(--color-accent,227_142_159))] underline-offset-4",
												megaLinkCls,
											]}
										>
											{link.label}
										</a>
									);
								})}
							</nav>
						</>
					) : (
						/* top-center: Row1=[search LEFT | logo CENTER | cart+user RIGHT], Row2=[nav CENTER] */
						/* ЛИТЕРАЛ верстальщика — пиксель-перфект bloom default */
						<>
							<div class="grid w-full grid-cols-[1fr_auto_1fr] items-center">
								<div class="flex items-center justify-start">
									<button
										type="button"
										data-action="toggle-search"
										class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
										aria-label="Поиск"
										aria-expanded="false"
										aria-controls="bloom-search-panel"
									>
										<NtIcon name="search-sm" sizeClass="size-5" />
									</button>
								</div>

								<a href="/" class="flex items-center justify-center hover:opacity-90" aria-label={siteTitle}>
									{
										logo ? (
											<img src={logo} alt={siteTitle} class={logoImgCls} />
										) : (
											<img
												src="/icons/Bloom.svg"
												alt={siteTitle}
												width="65"
												height="19"
												class="h-[19px] w-[65px]"
											/>
										)
									}
								</a>

								<div class="flex items-center justify-end gap-4">
									<button
										type="button"
										data-cart-open
										class="relative flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
										aria-label="Корзина"
									>
										<NtIcon name="cart" sizeClass="size-5" />
										<span
											data-cart-count
											data-empty="true"
											class="absolute -right-1 -top-1 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#E38E9F] px-1 font-inter text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
										>0</span>
									</button>
									<a
										href="/auth/sign-in"
										class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
										aria-label="Аккаунт"
									>
										<NtIcon name="user" sizeClass="size-5" />
									</a>
									{isSidebar && (
										<button
											type="button"
											data-burger-toggle
											class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
											aria-label="Меню"
											aria-expanded="false"
											aria-controls="bloom-burger"
										>
											<span class="burger-icon" data-icon="open">
												<NtIcon name="menu-burger" sizeClass="size-5" />
											</span>
											<span class="burger-icon hidden" data-icon="close">
												<NtIcon name="menu-close" sizeClass="size-5" />
											</span>
										</button>
									)}
								</div>
							</div>

							<nav
								class:list={["flex flex-wrap items-center justify-center gap-8 lg:gap-10", menuSchemeClass, isSidebar && "md:!hidden"]}
								aria-label="Основная навигация"
								data-puck-subsection-parent={id}
								data-puck-subsection-index="997"
								data-puck-subsection-field="navigationLinks"
							>
								{nav.map((link) => {
									const active = isActive(link);
									return (
										<a
											href={link.href}
											aria-current={active ? "page" : undefined}
											class:list={[
												"font-inter text-[16px] font-light leading-[100%] text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70",
												active && "underline decoration-[rgb(var(--color-accent,227_142_159))] underline-offset-4",
												megaLinkCls,
											]}
										>
											{link.label}
										</a>
									);
								})}
							</nav>
						</>
					)}
				</div>
			</div>
		) : (
			/* ── SINGLE-ROW LAYOUTS: center-left / center-absolute ── */
			<div class={desktopSingleRowWrapCls} style={headerPadStyle}>
				<div class="relative mx-auto flex w-full max-w-[1320px] items-center">
					{logoPosition === "center-absolute" ? (
						/* center-absolute: nav LEFT, logo ABSOLUTE-center, icons RIGHT */
						<>
							<nav
								class:list={["flex flex-wrap items-center justify-start gap-8 lg:gap-10", menuSchemeClass, isSidebar && "md:!hidden"]}
								aria-label="Основная навигация"
								data-puck-subsection-parent={id}
								data-puck-subsection-index="997"
								data-puck-subsection-field="navigationLinks"
							>
								{nav.map((link) => {
									const active = isActive(link);
									return (
										<a
											href={link.href}
											aria-current={active ? "page" : undefined}
											class:list={[
												"font-inter text-[16px] font-light leading-[100%] text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70",
												active && "underline decoration-[rgb(var(--color-accent,227_142_159))] underline-offset-4",
												megaLinkCls,
											]}
										>
											{link.label}
										</a>
									);
								})}
							</nav>

							<a href="/" class="absolute left-1/2 top-1/2 flex -translate-x-1/2 -translate-y-1/2 items-center hover:opacity-90" aria-label={siteTitle}>
								{
									logo ? (
										<img src={logo} alt={siteTitle} class={logoImgCls} />
									) : (
										<img
											src="/icons/Bloom.svg"
											alt={siteTitle}
											width="65"
											height="19"
											class="h-[19px] w-[65px]"
										/>
									)
								}
							</a>

							<div class="ml-auto flex items-center gap-4">
								<button
									type="button"
									data-action="toggle-search"
									class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
									aria-label="Поиск"
									aria-expanded="false"
									aria-controls="bloom-search-panel"
								>
									<NtIcon name="search-sm" sizeClass="size-5" />
								</button>
								<button
									type="button"
									data-cart-open
									class="relative flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
									aria-label="Корзина"
								>
									<NtIcon name="cart" sizeClass="size-5" />
									<span
										data-cart-count
										data-empty="true"
										class="absolute -right-1 -top-1 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#E38E9F] px-1 font-inter text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
									>0</span>
								</button>
								<a
									href="/auth/sign-in"
									class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
									aria-label="Аккаунт"
								>
									<NtIcon name="user" sizeClass="size-5" />
								</a>
								{isSidebar && (
									<button
										type="button"
										data-burger-toggle
										class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
										aria-label="Меню"
										aria-expanded="false"
										aria-controls="bloom-burger"
									>
										<span class="burger-icon" data-icon="open">
											<NtIcon name="menu-burger" sizeClass="size-5" />
										</span>
										<span class="burger-icon hidden" data-icon="close">
											<NtIcon name="menu-close" sizeClass="size-5" />
										</span>
									</button>
								)}
							</div>
						</>
					) : (
						/* center-left: logo LEFT, nav CENTER, icons RIGHT */
						<>
							<a href="/" class="flex shrink-0 items-center hover:opacity-90" aria-label={siteTitle}>
								{
									logo ? (
										<img src={logo} alt={siteTitle} class={logoImgCls} />
									) : (
										<img
											src="/icons/Bloom.svg"
											alt={siteTitle}
											width="65"
											height="19"
											class="h-[19px] w-[65px]"
										/>
									)
								}
							</a>

							<nav
								class:list={["mx-auto flex flex-wrap items-center justify-center gap-8 lg:gap-10", menuSchemeClass, isSidebar && "md:!hidden"]}
								aria-label="Основная навигация"
								data-puck-subsection-parent={id}
								data-puck-subsection-index="997"
								data-puck-subsection-field="navigationLinks"
							>
								{nav.map((link) => {
									const active = isActive(link);
									return (
										<a
											href={link.href}
											aria-current={active ? "page" : undefined}
											class:list={[
												"font-inter text-[16px] font-light leading-[100%] text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70",
												active && "underline decoration-[rgb(var(--color-accent,227_142_159))] underline-offset-4",
												megaLinkCls,
											]}
										>
											{link.label}
										</a>
									);
								})}
							</nav>

							<div class="flex shrink-0 items-center gap-4">
								<button
									type="button"
									data-action="toggle-search"
									class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
									aria-label="Поиск"
									aria-expanded="false"
									aria-controls="bloom-search-panel"
								>
									<NtIcon name="search-sm" sizeClass="size-5" />
								</button>
								<button
									type="button"
									data-cart-open
									class="relative flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
									aria-label="Корзина"
								>
									<NtIcon name="cart" sizeClass="size-5" />
									<span
										data-cart-count
										data-empty="true"
										class="absolute -right-1 -top-1 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#E38E9F] px-1 font-inter text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
									>0</span>
								</button>
								<a
									href="/auth/sign-in"
									class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
									aria-label="Аккаунт"
								>
									<NtIcon name="user" sizeClass="size-5" />
								</a>
								{isSidebar && (
									<button
										type="button"
										data-burger-toggle
										class="flex size-8 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
										aria-label="Меню"
										aria-expanded="false"
										aria-controls="bloom-burger"
									>
										<span class="burger-icon" data-icon="open">
											<NtIcon name="menu-burger" sizeClass="size-5" />
										</span>
										<span class="burger-icon hidden" data-icon="close">
											<NtIcon name="menu-close" sizeClass="size-5" />
										</span>
									</button>
								)}
							</div>
						</>
					)}
				</div>
			</div>
		)}

		<div
			id="bloom-search-panel"
			data-search-panel
			class="pointer-events-none absolute left-0 right-0 top-full z-40 w-full overflow-hidden bg-transparent transition-[max-height] duration-300 ease-in-out"
			style="max-height: 0;"
			aria-hidden="true"
		>
			<div class="px-4 py-2 md:px-20 2xl:px-[300px]">
				<form role="search" action={categorySearchAction} method="get" class="pointer-events-auto mx-auto flex h-12 w-full max-w-[1320px] items-center justify-between gap-2 rounded-[4px] border border-[#e38e9f] bg-white pl-3 pr-1 shadow-[0_8px_24px_rgba(0,0,0,0.08)]">
					<input
						type="search"
						name="q"
						placeholder="Поиск..."
						aria-label="Поиск"
						class="min-w-0 flex-1 bg-transparent font-inter text-[16px] font-light leading-normal text-[#000000] placeholder:text-[#999999] outline-none"
					/>
					<button
						type="submit"
						class="flex h-10 shrink-0 items-center justify-center rounded-[4px] bg-[#e38e9f] px-3 py-2.5 font-inter text-[14px] font-normal leading-normal text-white transition-opacity hover:opacity-95"
					>
						Найти
					</button>
				</form>
			</div>
		</div>
	</header>

	<div
		id="bloom-burger"
		class:list={[
			"fixed z-[55] hidden overflow-y-auto bg-white",
			isSidebar
				? "inset-y-0 right-0 bottom-0 w-[360px] max-w-[90vw] px-6 pt-6 pb-8"
				: "inset-x-0 bottom-0 w-full px-4 pt-4 pb-8 md:hidden",
		]}
		role="dialog"
		aria-modal="true"
		aria-label="Меню"
	>
		{isSidebar ? (
			/* Sidebar drawer: logo + cart at top */
			<div class="flex items-center justify-between">
				<a href="/" class="flex items-center hover:opacity-90" aria-label={siteTitle}>
					{
						logo ? (
							<img src={logo} alt={siteTitle} class={logoImgCls} />
						) : (
							<img
								src="/icons/Bloom.svg"
								alt={siteTitle}
								width="65"
								height="19"
								class="h-[19px] w-auto"
							/>
						)
					}
				</a>
				<button
					type="button"
					data-cart-open
					class="relative flex size-8 shrink-0 items-center justify-center rounded-[8px] transition-opacity hover:opacity-80"
					aria-label="Корзина"
				>
					<NtIcon name="cart" sizeClass="size-5" />
					<span
						data-cart-count
						data-empty="true"
						class="absolute -right-1 -top-1 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-[#e38e9f] px-1 font-inter text-[10px] font-normal leading-none text-white data-[empty=true]:hidden"
					>0</span>
				</button>
			</div>
		) : (
			/* Mobile drawer: search + profile */
			<div class="flex items-center gap-2">
				<form class="flex h-10 min-h-10 flex-1 items-center justify-between rounded-[4px] border border-[#999999] bg-white pl-3 pr-2" role="search" action={categorySearchAction} method="get">
					<input
						type="search"
						name="q"
						placeholder="Поиск"
						class="min-w-0 flex-1 bg-transparent font-inter text-[12px] font-normal leading-normal text-[#000000] placeholder:text-[#999999] outline-none"
					/>
					<button type="submit" class="flex h-5 w-5 shrink-0 items-center justify-center" aria-label="Найти">
						<NtIcon name="search-sm" sizeClass="size-5" />
					</button>
				</form>
				<a
					href="/auth/sign-in"
					class="flex size-10 shrink-0 items-center justify-center rounded-full bg-[#e38e9f]"
					aria-label="Профиль"
				>
					<NtIcon name="user" sizeClass="size-5" />
				</a>
			</div>
		)}

		<nav class="mt-10 flex flex-col gap-5" aria-label="Основное меню">
			{nav.map((link) => {
				const active = isActive(link);
				return (
					<div class="flex flex-col gap-1">
						<a
							href={link.href}
							class:list={[
								"font-inter text-[14px] font-light leading-normal",
								active ? "text-[#000000]" : "text-[#999999]",
							]}
						>
							{link.label}
						</a>
						{active && <div class="h-px w-[54px] bg-[#e38e9f]" aria-hidden="true"></div>}
					</div>
				);
			})}
			<a href="/cart" class="font-inter text-[14px] font-light leading-normal text-[#999999]">Корзина</a>
			<a href="/auth/sign-up" class="font-inter text-[14px] font-light leading-normal text-[#999999]">Регистрация</a>
		</nav>
	</div>

	{stickiness === "scroll-up" && <script is:inline set:html={SCROLL_UP_JS} />}
</div>

<script>
	const headerOffsetBelowPromo = () => {
		const promo = document.querySelector<HTMLElement>("[data-bloom-announcement]");
		const headerEl = document.querySelector<HTMLElement>('[data-nt="bloom-header"]');
		const p = promo?.offsetHeight ?? 32;
		const h = headerEl?.offsetHeight ?? 64;
		return p + h;
	};

	const positionBurger = () => {
		const burger = document.getElementById("bloom-burger");
		if (!burger) return;
		burger.style.top = `${headerOffsetBelowPromo()}px`;
	};

	const setSearchOpen = (open: boolean) => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel) return;
		panel.setAttribute("aria-hidden", String(!open));
		if (open) {
			panel.style.maxHeight = `${panel.scrollHeight}px`;
			queueMicrotask(() => {
				panel.querySelector<HTMLInputElement>("input[type='search']")?.focus();
			});
		} else {
			panel.style.maxHeight = "0px";
		}
		document.querySelectorAll<HTMLElement>("[data-action='toggle-search']").forEach((btn) => {
			btn.setAttribute("aria-expanded", String(open));
		});
	};

	const isSearchPanelOpen = () => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel) return false;
		const h = panel.style.maxHeight;
		return Boolean(h && h !== "0px" && h !== "0");
	};

	const syncSearchPanelHeight = () => {
		const panel = document.querySelector<HTMLElement>("[data-search-panel]");
		if (!panel || !isSearchPanelOpen()) return;
		panel.style.maxHeight = `${panel.scrollHeight}px`;
	};

	const isSidebarDrawer = () => {
		const burger = document.getElementById("bloom-burger");
		// Sidebar right-panel has inset-y-0 — detect via right-side positioning
		return burger ? burger.classList.contains("inset-y-0") : false;
	};

	const syncBurgerButtonIcons = (open: boolean) => {
		// Update ALL burger toggle buttons (mobile #bloom-burger-btn + desktop [data-burger-toggle])
		document.querySelectorAll<HTMLElement>("[data-burger-toggle]").forEach((burgerBtn) => {
			burgerBtn.setAttribute("aria-expanded", String(open));
			burgerBtn.querySelectorAll<HTMLElement>(".burger-icon").forEach((el) => {
				const key = el.dataset.icon;
				if (key === "open") el.classList.toggle("hidden", open);
				else el.classList.toggle("hidden", !open);
			});
		});
	};

	const setBurger = (open: boolean) => {
		const burger = document.getElementById("bloom-burger");
		if (!burger) return;
		if (open) setSearchOpen(false);
		burger.classList.toggle("hidden", !open);
		syncBurgerButtonIcons(open);
		document.body.style.overflow = open ? "hidden" : "";
		// positionBurger only for mobile bottom-sheet (not right-side panel)
		if (open && !isSidebarDrawer()) positionBurger();
	};

	const syncHeaderChromeAfterNavigation = () => {
		document.body.style.overflow = "";
		setSearchOpen(false);
		const burgerEl = document.getElementById("bloom-burger");
		if (burgerEl) burgerEl.classList.add("hidden");
		syncBurgerButtonIcons(false);
		if (!isSidebarDrawer()) positionBurger();
	};

	let headerDelegatesBound = false;
	const bindHeaderDelegatedClicks = () => {
		if (headerDelegatesBound) return;
		headerDelegatesBound = true;

		document.addEventListener("click", (event: MouseEvent) => {
			const raw = event.target;
			const el = raw instanceof Element ? raw : null;
			if (!el) return;

			if (el.closest("[data-burger-toggle]")) {
				const burgerEl = document.getElementById("bloom-burger");
				if (!burgerEl) return;
				event.preventDefault();
				setBurger(burgerEl.classList.contains("hidden"));
				return;
			}

			if (el.closest("[data-action='toggle-search']")) {
				event.preventDefault();
				event.stopPropagation();
				const willOpen = !isSearchPanelOpen();
				if (willOpen) {
					const burgerEl = document.getElementById("bloom-burger");
					if (burgerEl && !burgerEl.classList.contains("hidden")) {
						setBurger(false);
					}
				}
				setSearchOpen(willOpen);
				return;
			}

			if (el.closest("#bloom-burger a[href]")) {
				setBurger(false);
			}
		});

		document.addEventListener("click", (event: MouseEvent) => {
			if (!isSearchPanelOpen()) return;
			const target = event.target;
			if (!(target instanceof Node)) return;
			const panel = document.querySelector<HTMLElement>("[data-search-panel]");
			if (panel?.contains(target)) return;
			const tEl = target instanceof Element ? target : null;
			if (tEl?.closest?.("[data-action='toggle-search']")) return;
			setSearchOpen(false);
		});

		window.addEventListener("resize", () => {
			syncSearchPanelHeight();
			positionBurger();
		});
	};

	bindHeaderDelegatedClicks();
	document.addEventListener("astro:page-load", syncHeaderChromeAfterNavigation);
	syncHeaderChromeAfterNavigation();
</script>
