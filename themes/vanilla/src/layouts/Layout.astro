---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import CheckoutHeader from "../../../../packages/theme-base/blocks/CheckoutHeader/CheckoutHeader.astro";
import Footer from "../components/Footer.astro";
import FooterNewsletter from "../components/footer/FooterNewsletter.astro";
import LoginDrawer from "../components/LoginDrawer.astro";
import VanillaCartDrawer from "../components/VanillaCartDrawer.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { ViewTransitions } from "astro:transitions";

interface Props {
	title?: string;
	description?: string;
	showNewsletter?: boolean;
	// "checkout" → минимальная шапка оформления (CheckoutHeader, Figma 1:13563);
	// build.service патчит бренд CheckoutHeader под мерчанта на сборке сайта.
	header?: "default" | "checkout";
}

const { title, description = SITE_DESCRIPTION, showNewsletter = false, header = "default" } = Astro.props;
const pageTitle = title ? `${title} — ${SITE_TITLE}` : SITE_TITLE;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={pageTitle} description={description} />
		<ViewTransitions />
	</head>
	<body class="vanilla-page antialiased">
		{header === "checkout" ? (
			<div class="color-scheme-2" style="--size-checkout-brand:24px;--size-checkout-brand-image:32px;">
				<CheckoutHeader siteTitle={SITE_TITLE} logoMode="text" logoImage={null} rightIcon="cart" accountLink="/account" backLink="/cart" cartLink="/cart" padding={{ top: 24, bottom: 24 }} />
			</div>
		) : (
			<Header />
		)}
		<main>
			<slot />
		</main>
		{showNewsletter && <FooterNewsletter />}
		<Footer />
		<LoginDrawer />
		<VanillaCartDrawer rootId="vanilla-cart-drawer-root" eventPrefix="vanilla:cart" />
		<script>
			import { initCartUI } from "../lib/cart";
			import { initWishlistUI } from "../lib/wishlist";
			import { initAuthUI } from "../lib/auth";
			initCartUI();
			// Избранное (wishlist) — глобальный делегат сердец/бейджей, зеркало корзины.
			initWishlistUI();
			initAuthUI();

			// Регулярное оформление («Оформить» корзины/страницы /cart, data-action=checkout)
			// сбрасывает express «Купить сейчас» (sessionStorage vanilla:buynow) — чтобы
			// чекаут показал корзину покупателя, а не залипший buy-now товар. NB: vanilla
			// drawer ведёт на /cart (<a>), а реальная кнопка checkout живёт на /cart.
			document.addEventListener(
				"click",
				(e) => {
					const el = e.target as Element | null;
					if (el && el.closest("[data-action='checkout']")) {
						try { sessionStorage.removeItem("vanilla:buynow"); } catch (err) {}
					}
				},
				true,
			);

				// Корзина «Сайдбар»/«Страница» (--cart-type). Иконка корзины в vanilla —
				// <a href="/cart">: для page это уже верный переход (no-op). Для drawer в
				// capture-фазе отменяем переход и открываем панель событием vanilla:cart:open
				// (его слушает VanillaCartDrawer). Так настройка работает на live.
				document.addEventListener(
					"click",
					(e) => {
						const el = e.target as Element | null;
						if (!el || !el.closest('a[aria-label="Корзина"]')) return;
						const cartType = getComputedStyle(document.documentElement)
							.getPropertyValue("--cart-type")
							.trim()
							.replace(/['"]/g, "");
						if (cartType === "page") return;
						e.preventDefault();
						e.stopImmediatePropagation();
						window.dispatchEvent(new CustomEvent("vanilla:cart:open"));
					},
					true,
				);
		</script>

		<script>
			const initScrollAnimations = () => {
				const targets = document.querySelectorAll<HTMLElement>("[data-animate]");
				if (!targets.length) return;

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								observer.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.08, rootMargin: "0px 0px -36px 0px" },
				);

				targets.forEach((el) => {
					el.classList.remove("is-visible");
					const delay = el.dataset.animateDelay;
					if (delay) el.style.animationDelay = delay;
					observer.observe(el);
				});
			};

			initScrollAnimations();
			document.addEventListener("astro:after-swap", initScrollAnimations);
		</script>
	</body>
</html>
