{
  "name": "vanilla",
  "label": "Vanilla — Decor & Interior",
  "version": "1.0.0",
  "category": "decor",
  "description": "Warm brown theme for decor and interior stores with Comfortaa/Manrope fonts",
  "author": "Merfy",
  "features": {
    "variants": true,
    "collections": true,
    "sizeGuide": false,
    "colorSwatches": true,
    "filterSidebar": true,
    "newsletter": true,
    "wishlist": false,
    "blog": true,
    "rss": true
  },
  "pages": ["index", "product", "collection", "cart", "blog"],
  "settings_schema": [
    {
      "name": "colors",
      "settings": [
        { "id": "color_primary", "type": "color", "label": "Primary color", "default": "#292524" },
        { "id": "color_background", "type": "color", "label": "Background", "default": "#ffffff" },
        { "id": "color_foreground", "type": "color", "label": "Text", "default": "#000000" },
        { "id": "color_border", "type": "color", "label": "Border", "default": "#e5e7eb" },
        { "id": "color_button", "type": "color", "label": "Button", "default": "#8b7355" },
        { "id": "color_button_text", "type": "color", "label": "Button text", "default": "#ffffff" }
      ]
    },
    {
      "name": "typography",
      "settings": [
        { "id": "font_heading", "type": "font", "label": "Heading font", "default": "Comfortaa" },
        { "id": "font_body", "type": "font", "label": "Body font", "default": "Manrope" }
      ]
    },
    {
      "name": "layout",
      "settings": [
        { "id": "radius_button", "type": "range", "label": "Button radius", "default": "10" },
        { "id": "radius_card", "type": "range", "label": "Card radius", "default": "10" },
        { "id": "page_width", "type": "text", "label": "Page width", "default": "1920px" }
      ]
    }
  ],
  "color_schemes": [
    {
      "id": 1,
      "name": "Dark",
      "background": "#000000",
      "foreground": "#ffffff",
      "primary": "#ffffff",
      "border": "#444444"
    },
    {
      "id": 2,
      "name": "Warm brown",
      "background": "#8b7355",
      "foreground": "#ffffff",
      "primary": "#ffffff",
      "border": "#a08c73"
    },
    {
      "id": 3,
      "name": "Light gray",
      "background": "#f5f5f5",
      "foreground": "#000000",
      "primary": "#292524",
      "border": "#e5e7eb"
    },
    {
      "id": 4,
      "name": "White",
      "background": "#ffffff",
      "foreground": "#000000",
      "primary": "#292524",
      "border": "#e5e7eb"
    }
  ]
}
