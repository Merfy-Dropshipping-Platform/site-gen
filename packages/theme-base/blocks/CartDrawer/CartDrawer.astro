---
import type { CartDrawerProps } from './CartDrawer.puckConfig';
import { CartDrawerClasses as C } from './CartDrawer.classes';

interface Props extends CartDrawerProps {
  id?: string;
}

const {
  id,
  position,
  showCheckoutButton,
  padding,
} = Astro.props as Props;

const paddingStyle = padding ? `padding-top:${padding.top}px; padding-bottom:${padding.bottom}px;` : '';
---
{/* CartDrawer placeholder — interactive UI rendered by CartDrawerIsland mounted in Header.astro. */}
<aside
  class:list={[C.root, C.position[position]]}
  data-puck-component-id={id}
  data-position={position}
  style={paddingStyle}
  aria-label="Корзина (mini)"
  hidden
>
  <div id="cart-drawer-island-mount" data-show-checkout={showCheckoutButton ? 'true' : 'false'}></div>
</aside>
