# Theme is a STANDALONE Astro project. Auth for the private design-system dep
# from GitHub Packages (root .npmrc is NOT picked up from this subdir under pnpm).
# Workspace isolation is enforced via the `--ignore-workspace` CLI flag in
# ThemeBuildService (the .npmrc `ignore-workspace` key is unreliable here).
@merfy-dropshipping-platform:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
