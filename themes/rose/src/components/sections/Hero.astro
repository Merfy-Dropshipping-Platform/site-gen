---
import { SITE_TITLE } from "../../consts";
import RosePicture from "../img/RosePicture.astro";

// ОЖИВЛЕНИЕ: читаем существующую конструкторную Hero-схему (theme-base
// Hero.puckConfig) и раскладываем по переменным разметки верстальщика. Тело
// ниже — verbatim. Значения rose = дефолты. Поддержаны flat и nested (Pupa) пропсы.
const p = Astro.props as Record<string, any>;
const id = p.id;
const title = p.heading?.text ?? p.title ?? SITE_TITLE;
const subtitle =
	p.text?.content ?? p.subtitle ?? "Там, где классика встречается с характером";
const ctaText = p.primaryButton?.text ?? p.cta?.text ?? p.ctaText ?? "В каталог";
const ctaLink =
	p.primaryButton?.link?.href ?? p.primaryButton?.link ?? p.cta?.href ?? p.ctaLink ?? "/catalog";
const backgroundImage =
	p.backgroundImages?.url1 ?? p.backgroundImage ?? p.image?.url ?? "/images/Главный_экран.png";
// Канон backgroundImages (imagePair url2) / legacy backgroundImage2: сплит двух
// картинок 50/50 ТОЛЬКО когда второе фото задано; иначе одиночный рендер дословно.
const backgroundImage2 = p.backgroundImages?.url2 ?? p.backgroundImage2;

// Канон heading.size / text.size: 'large' (= blockDefaults rose) и отсутствующий
// проп → ЛИТЕРАЛЬНАЯ лестница верстальщика. Уменьшенные варианты в манере:
// medium ≈0.85×, small ≈0.7× от лестницы large, округление до целых px:
//   заголовок large 20/28/36/40 → medium 17/24/31/34 → small 14/20/25/28
//   текст     large 14/16/18/20 → medium 12/14/15/17 → small 10/11/13/14
// Дефолтная ветка каждого тернарника = прежняя строка классов байт-в-байт.
// «Размер» (p.size) — ЕДИНСТВЕННОЕ видимое размерное поле панели «Изображение»
// (heading/text.size скрыты hiddenInMainPanel, у Hero нет дефолта p.size). p.size
// ПРИОРИТЕТНЕЕ: иначе сохранённый heading.size='large' (из seed/пресета) перебивал
// выбор «Размера» и поле не работало (баг тестера). heading.size/text.size —
// фолбэк (точечная подсекция, когда «Размер» не задан).
const headingSize = p.size ?? p.heading?.size;
const headingCls =
	headingSize === "small"
		? "hero-animate-1 !text-[14px] !font-normal !leading-none uppercase tracking-normal text-[rgb(var(--color-heading,255_255_255))] sm:!text-[20px] md:!text-[25px] lg:!text-[28px]"
		: headingSize === "medium"
			? "hero-animate-1 !text-[17px] !font-normal !leading-none uppercase tracking-normal text-[rgb(var(--color-heading,255_255_255))] sm:!text-[24px] md:!text-[31px] lg:!text-[34px]"
			: "hero-animate-1 !text-[20px] !font-normal !leading-none uppercase tracking-normal text-[rgb(var(--color-heading,255_255_255))] sm:!text-[28px] md:!text-[36px] lg:!text-[length:var(--size-hero-heading,40px)]";
const textSize = p.size ?? p.text?.size;
const subtitleCls =
	textSize === "small"
		? "hero-animate-2 max-w-xl px-1 font-manrope text-[10px] font-normal leading-none text-[rgb(var(--color-text,255_255_255))] sm:text-[11px] md:text-[13px] lg:text-[14px]"
		: textSize === "medium"
			? "hero-animate-2 max-w-xl px-1 font-manrope text-[12px] font-normal leading-none text-[rgb(var(--color-text,255_255_255))] sm:text-[14px] md:text-[15px] lg:text-[17px]"
			: "hero-animate-2 max-w-xl px-1 font-manrope text-[14px] font-normal leading-none text-[rgb(var(--color-text,255_255_255))] sm:text-[16px] md:text-[18px] lg:text-[20px]";

// Канон secondaryButton {text, link: string|{href}} — рендер ТОЛЬКО при непустом тексте.
const secondaryText =
	typeof p.secondaryButton?.text === "string" && p.secondaryButton.text.trim()
		? p.secondaryButton.text
		: undefined;
const secondaryLink =
	p.secondaryButton?.link?.href ??
	(typeof p.secondaryButton?.link === "string" ? p.secondaryButton.link : undefined) ??
	"/catalog";

// Канон overlay 0-100 (число или строка) → слой затемнения между фото (z-0) и контентом (z-10).
const overlayN = Math.max(0, Math.min(100, Number(p.overlay) || 0));

// Канон container (toggle «Контейнер» панели «Изображение», Figma 1:33159) —
// подложка-плашка ТОЛЬКО под текстовым блоком (фон схемы + паддинги + радиус),
// НЕ затемнение всего экрана (это отдельная настройка «Затемнение»/overlay).
// Паттерн Slideshow boxed: на светлой плашке белый текст героя не читается —
// переключаем заголовок/текст на тёмный цвет схемы ([&_h1]/[&_p] override).
const boxed = String(p.container ?? "false") === "true";
const boxedCls = boxed
	? " rounded-[var(--radius-card,8px)] bg-[rgb(var(--color-bg,255_255_255))]/95 p-6 shadow-sm md:p-10 [&_h1]:!text-[rgb(var(--color-heading,0_0_0))] [&_p]:!text-[rgb(var(--color-text,0_0_0))]"
	: "";

// Канон position (видимое поле панели) / contentPosition (legacy, те же 9 значений).
// Позиция управляет РАЗМЕЩЕНИЕМ контент-блока по сетке 3×3 (Figma 648-55404):
//   вертикаль — top / center(=середина) / bottom; горизонталь — left / center / right.
// Пустой проп = дефолт верстальщика (низ-центр; дефолт пишется как position:"bottom-center").
// Явное 'center' (По центру) = СЕРЕДИНА (раньше ошибочно падало вниз — это и был баг).
// Выравнивание (alignment) теперь НЕЗАВИСИМО и отвечает только за выравнивание ТЕКСТА.
const posRaw =
	typeof p.position === "string" && p.position
		? p.position
		: typeof p.contentPosition === "string"
			? p.contentPosition
			: "";
const vPos = posRaw.startsWith("top")
	? "top"
	: posRaw.startsWith("bottom")
		? "bottom"
		: posRaw === "center" || posRaw.startsWith("center")
			? "middle"
			: ""; // пусто = дефолт (низ)
const hPos = posRaw.endsWith("left") ? "left" : posRaw.endsWith("right") ? "right" : "center";
const vJustifyCls = vPos === "top" ? "justify-start" : vPos === "middle" ? "justify-center" : "justify-end";
const hItemsCls = hPos === "left" ? "items-start" : hPos === "right" ? "items-end" : "items-center";
// alignment — выравнивание КОНТЕНТА внутри блока (НЕ двигает сам блок — это делает
// Позиция через items на внешнем контейнере). items-* выравнивают заголовок/текст/
// кнопки друг относительно друга, text-align — многострочный текст.
const textAlignCls = p.alignment === "left" ? "text-left" : p.alignment === "right" ? "text-right" : "text-center";
const alignItemsCls = p.alignment === "left" ? "items-start" : p.alignment === "right" ? "items-end" : "items-center";
const buttonsJustifyCls = p.alignment === "left" ? "justify-start" : p.alignment === "right" ? "justify-end" : "justify-center";

// Канон buttonStyle solid|outlined: outlined = бордер/текст цвета заливки кнопки,
// прозрачный фон; solid/отсутствие = текущий вид CTA дословно (кнопка-1 токены, T8).
const ctaCls =
	p.buttonStyle === "outlined"
		? "inline-flex h-10 min-h-10 w-auto min-w-[120px] items-center justify-center rounded border border-solid border-[rgb(var(--color-button-bg,255_255_255))] !bg-transparent px-3 py-2.5 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-button-bg,255_255_255))] transition-opacity hover:opacity-90 sm:h-[52px] sm:min-h-[52px] sm:min-w-[160px] sm:rounded-[var(--radius-button,6px)] sm:px-6 sm:py-[10px] sm:text-[15px] md:text-[16px]"
		: "inline-flex h-10 min-h-10 w-auto min-w-[120px] items-center justify-center rounded !border-0 !bg-[rgb(var(--color-button-bg,255_255_255))] px-3 py-2.5 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-button-text,0_0_0))] transition-opacity hover:opacity-90 sm:h-[52px] sm:min-h-[52px] sm:min-w-[160px] sm:rounded-[var(--radius-button,6px)] sm:px-6 sm:py-[10px] sm:text-[15px] md:text-[16px]";

// Кнопочный ряд: дефолт (нет второй кнопки) = прежняя строка дословно; при
// secondaryButton кнопки встают рядом (row) с зазором манеры.
const buttonsCls = secondaryText
	? `hero-animate-3 flex w-full flex-row flex-wrap items-center gap-3 ${buttonsJustifyCls} sm:gap-4`
	: `hero-animate-3 flex w-full flex-col ${alignItemsCls} justify-center`;

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе (паттерн T14).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
---

<section
	class="relative w-full overflow-hidden bg-[rgb(var(--color-bg,255_255_255))]"
	aria-labelledby="hero-title"
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div
		class="relative w-full min-h-[min(70svh,560px)] sm:min-h-[560px] md:min-h-[420px] lg:min-h-[460px] aspect-[10/15] sm:aspect-[4/5] md:aspect-[4/3] lg:aspect-[16/9] xl:aspect-[2/1] 2xl:aspect-[21/9]"
	>
		{
			backgroundImage2 ? (
				<div class="absolute inset-0 z-0 grid grid-cols-2">
					<RosePicture
						src={backgroundImage}
						alt={title}
						loading="eager"
						fetchpriority="high"
						class="!size-full object-cover object-center"
					/>
					<RosePicture
						src={backgroundImage2}
						alt={title}
						loading="eager"
						fetchpriority="high"
						class="!size-full object-cover object-center"
					/>
				</div>
			) : (
				<RosePicture
					src={backgroundImage}
					alt={title}
					loading="eager"
					fetchpriority="high"
					class="absolute inset-0 z-0 !size-full object-cover object-center"
				/>
			)
		}

		{
			overlayN > 0 && (
				<div
					class="pointer-events-none absolute inset-0 z-[1] bg-black"
					style={`opacity:${overlayN / 100}`}
				/>
			)
		}

		<div
			class={`absolute inset-0 z-10 flex w-full flex-col ${hItemsCls} ${vJustifyCls} px-4 pb-10 pt-28 sm:px-5 sm:pb-11 sm:pt-32 md:px-10 md:pb-14 md:pt-36 lg:px-16 lg:pb-16 xl:px-20 xl:pb-20 2xl:px-[280px]`}
		>
			<div class={`flex w-full max-w-[540px] flex-col ${alignItemsCls} gap-6 sm:gap-10 md:max-w-[640px]${boxedCls}`}>
				<div class={`flex flex-col ${alignItemsCls} gap-2 ${textAlignCls} sm:gap-3 md:gap-4`}>
					<h1
						id="hero-title"
						class={headingCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="100"
						data-puck-subsection-field="heading"
					>
						{title}
					</h1>
					<p
						class={subtitleCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="101"
						data-puck-subsection-field="text"
					>
						{subtitle}
					</p>
				</div>

				<div class={buttonsCls}>
					<a
						href={ctaLink}
						class={ctaCls}
						data-puck-subsection-parent={id}
						data-puck-subsection-index="102"
						data-puck-subsection-field="primaryButton"
					>
						{ctaText}
					</a>
					{
						secondaryText && (
							<a
								href={secondaryLink}
								class="inline-flex h-10 min-h-10 w-auto min-w-[120px] items-center justify-center rounded border border-solid border-[rgb(var(--color-button-2-border,0_0_0))] !bg-[rgb(var(--color-button-2-bg,255_255_255))] px-3 py-2.5 font-manrope text-[14px] font-normal leading-none !text-[rgb(var(--color-button-2-text,0_0_0))] transition-opacity hover:opacity-90 sm:h-[52px] sm:min-h-[52px] sm:min-w-[160px] sm:rounded-[var(--radius-button,6px)] sm:px-6 sm:py-[10px] sm:text-[15px] md:text-[16px]"
								data-puck-subsection-parent={id}
								data-puck-subsection-index="103"
								data-puck-subsection-field="secondaryButton"
							>
								{secondaryText}
							</a>
						)
					}
				</div>
			</div>
		</div>
	</div>
</section>
