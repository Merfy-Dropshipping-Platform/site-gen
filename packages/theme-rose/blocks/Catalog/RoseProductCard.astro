---
/**
 * RoseProductCard (порт из themes/rose/src/components/products/RoseProductCard.astro).
 *
 * Тип Product заинлайнен (минимальный shape витрины) вместо импорта
 * ../../types/product — block-папка override-темы автономна (компилятор превью
 * не резолвит пути за пределы папки). RosePicture — sibling (./).
 */
import RosePicture from "./RosePicture.astro";

interface Product {
  name: string;
  price: string;
  oldPrice?: string;
  image: string;
  id?: string;
  discount?: boolean;
}

interface Props {
  product: Product;
  priority?: boolean;
  /** Вид изображения карточки (Tailwind aspect-класс). Дефолт — родной rose
      портрет 318/444. Передаётся из Catalog.astro (настройка «Вид изображения»),
      зеркалит client renderCardHtml для parity. */
  cardAspectClass?: string;
  /** Быстрое действие: кнопка под карточкой (none → нет; иначе текст). */
  showQuickAdd?: boolean;
  quickAddText?: string;
  /** Inline-стили кнопки quickAdd по «Стилю кнопки» (primary/secondary/link). */
  btnStyle?: string;
  btnBg?: string;
  btnFg?: string;
  btnBorder?: string;
  /** «Контейнер» карточки (настройка cardBackground). true → surface-подложка +
      внутр. отступ 12px (фото/текст/кнопка inset); false (дефолт) → флеш-вид rose.
      Зеркалит client renderCardHtml (parity SSG↔client). */
  cardContainerOn?: boolean;
}

const {
  product,
  priority = false,
  cardAspectClass = "aspect-[318/444]",
  showQuickAdd = false,
  quickAddText = "БЫСТРЫЙ ПРОСМОТР",
  btnStyle = "secondary",
  btnBg = "rgb(var(--color-button-secondary-bg,255 255 255))",
  btnFg = "rgb(var(--color-button-secondary-text,0 0 0))",
  btnBorder = "1px solid rgb(var(--color-button-secondary-border,0 0 0))",
  cardContainerOn = false,
} = Astro.props as Props;
const href = `/products/${product.id}`;
const showSaleBadge = product.discount === true;
// «Контейнер» карточки (cardBackground). true → surface-подложка + внутр. отступ
// 12px на article: фото/заголовок/цена/кнопка автоматически inset на 12px (кнопка
// width:100% → cardW−24). false (дефолт) → пусто, родной флеш-вид (фото full-bleed,
// кнопка край-в-край). Зеркалит client renderCardHtml (CARD_CONTAINER_STYLE) — parity.
const cardContainerStyle = cardContainerOn
  ? "background:rgb(var(--color-surface,245 245 245));border-radius:var(--product-card-radius,8px);padding:12px;"
  : undefined;
// Стиль кнопки quickAdd (зеркалит client renderCardHtml). link → текст-ссылка.
const quickBtnStyle =
  `width:100%;height:44px;padding:0 12px;border-radius:var(--radius-button,6px);` +
  `font-family:var(--font-body);font-size:14px;text-transform:uppercase;cursor:pointer;` +
  `display:flex;align-items:center;justify-content:center;` +
  `background:${btnBg};color:${btnFg};border:${btnBorder};` +
  (btnStyle === "link" ? "text-decoration:underline;background:transparent;" : "");

// Outline-сердце избранного (SSR-дефолт). Геометрия = public/icons/favourite.svg
// и зеркалит wishlist.ts heartSvg(false). Инлайн (НЕ <img> RoseNtIcon) — чтобы
// глобальный делегат initWishlistUI мог переключать fill на filled. На SSG нет
// window → рисуем outline; делегат поставит filled на page-load если товар в избранном.
// SVG-строка автономна (block-папка override-темы не резолвит импорты наружу).
const defaultHeartSvg =
  '<svg viewBox="0 0 17.4 15.4" width="100%" height="100%" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="display:block">' +
  '<path d="M7.428 14.2615C5.172 12.5239 0.7 8.55212 0.7 4.97729C0.7 2.61547 2.384 0.7 4.7 0.7C5.9 0.7 7.1 1.11175 8.7 2.75876C10.3 1.11175 11.5 0.7 12.7 0.7C15.016 0.7 16.7 2.61547 16.7 4.97729C16.7 8.5513 12.228 12.5239 9.972 14.2615C9.212 14.8462 8.188 14.8462 7.428 14.2615Z" ' +
  'fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>' +
  "</svg>";
---

<article
  class="group flex w-full flex-col gap-5"
  data-nt="rose-product-card"
  data-card-bg={cardContainerOn ? "true" : "false"}
  style={cardContainerStyle}
  aria-label={product.name}
>
  {/* Обёртка медиа: relative-родитель для overlay-сердца избранного. Сердце —
      sibling <a> (НЕ внутри: button-in-anchor невалиден + клик по сердцу не должен
      открывать товар). aspect-класс несёт сам <a>; обёртка только позиционирует. */}
  <div class="relative w-full">
  <a
    href={href}
    class:list={[cardAspectClass, "relative block w-full overflow-hidden rounded-[var(--radius-media,8px)] bg-white"]}
    aria-label={product.name}
  >
    {product.image ? (
      <RosePicture
        src={product.image}
        alt={product.name}
        width="318"
        height="444"
        loading="eager"
        fetchpriority={priority ? "high" : undefined}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        data-img-primary={product.image}
      />
    ) : (
      /* Товар без фото: surface-плейсхолдер вместо <img> (битой иконки).
         Цвета только токенами; разметку зеркалит CARD_MEDIA_FALLBACK_HTML
         в storefront-hydrate.ts — менять синхронно. */
      <div
        class="absolute inset-0 flex items-center justify-center"
        style="background:rgb(var(--color-surface,245 245 245))"
        aria-hidden="true"
      >
        <svg
          class="size-10"
          style="color:rgb(var(--color-muted,153 153 153))"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="3" width="18" height="18" rx="2"></rect>
          <circle cx="9" cy="9" r="2"></circle>
          <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
        </svg>
      </div>
    )}
    {showSaleBadge && (
      <span
        class="absolute left-3 top-3 z-10 flex h-6 min-w-12 items-center justify-center rounded-[4px] bg-[rgb(var(--color-accent,0_0_0))] px-2 font-manrope text-[12px] font-normal leading-none !text-white"
      >
        Скидка
      </span>
    )}
  </a>
    {/* Сердце избранного (overlay top-right). data-product-id ловит глобальный
        делегат initWishlistUI: toggle + перерисовка состояния (filled/outline +
        aria-pressed). Начальное состояние ставит делегат на page-load (SSG рендер
        без window — рисуем outline-сердце по умолчанию). z-20 поверх фото/бейджа. */}
    <button
      type="button"
      data-wishlist-toggle
      data-product-id={product.id}
      aria-pressed="false"
      aria-label="В избранное"
      class="absolute right-3 top-3 z-20 flex size-9 items-center justify-center rounded-full bg-white/90 text-[rgb(var(--color-text,0_0_0))] shadow-[0_2px_8px_rgba(0,0,0,0.10)] backdrop-blur-sm transition-opacity hover:opacity-80"
    >
      <span data-wishlist-icon class="block size-[18px]" set:html={defaultHeartSvg}></span>
    </button>
  </div>
  <div class="flex w-full flex-col gap-1 text-left">
    <a
      href={href}
      class="rose-product-name block w-full font-manrope text-[14px] font-normal leading-none tracking-normal text-[rgb(var(--color-text,0_0_0))] transition-opacity hover:opacity-70"
    >
      {product.name}
    </a>
    <div class="flex w-full flex-wrap items-baseline gap-2">
      <span class="rose-product-price font-manrope !text-[16px] font-normal !leading-none text-[rgb(var(--color-text,0_0_0))]">
        {product.price}
      </span>
      {product.oldPrice && (
        <span class="rose-product-oldprice font-manrope !text-[14px] font-normal !leading-none text-[rgb(var(--color-muted,153_153_153))] line-through">
          {product.oldPrice}
        </span>
      )}
    </div>
  </div>
  {/* Быстрое действие (настройка «Быстрое добавление»). Кнопка СНАРУЖИ <a>
      (button-in-anchor — невалидный HTML). Зеркалит client renderCardHtml. */}
  {showQuickAdd && (
    <button type="button" data-quick-add-id={product.id} style={quickBtnStyle}>
      {quickAddText}
    </button>
  )}
</article>

<style>
  /* Figma 375: name/price — Manrope 12, lh 100% */
  @media (max-width: 639.98px) {
    .rose-product-name {
      font-size: 12px !important;
    }

    .rose-product-price {
      font-size: 12px !important;
    }

    .rose-product-oldprice {
      font-size: 12px !important;
    }
  }
</style>
