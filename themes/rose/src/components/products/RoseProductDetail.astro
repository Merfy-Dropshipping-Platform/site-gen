			function applyGallery(list) {
				var arr = (Array.isArray(list) ? list : []).filter(function (s) {
					return typeof s === "string" && s;
				});
				var mainSrc = arr[0] || productImage(p);
				var mainImg = section.querySelector("[data-pdp-main]");
				if (mainImg) {
					mainImg.src = mainSrc;
					mainImg.alt = p.name || "";
					// <picture><source webp> от skeleton/demo больше не валиден — снимаем.
					var picture = mainImg.closest("picture");
					var source = picture && picture.querySelector("source");
					if (source) source.removeAttribute("srcset");
				}
