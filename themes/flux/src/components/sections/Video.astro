---
// Канон-секция Video в чистой манере flux (см. themes/flux/MANNER.md; эталон
// чистого стиля — Collections.astro). Шапка font-roboto-flex uppercase (дефолт
// 19/23), подзаголовок font-roboto-flex font-light muted; медиа aspect-video в
// контейнере max-w-[1920px] (px-4 md:px-20 2xl:px-80, вертикаль py-10 md:py-16)
// со скруглением 12px на surface-подложке. Только utility-классы с токенами
// (MANNER §7), без <style>-блока и hex-литералов (кроме SVG play-иконки — на
// токенах). Скролл-анимаций в манере flux нет (§6) — без data-animate.
// Схема полей = packages/theme-base/blocks/Video/Video.puckConfig.ts; настройки
// применяются как rose (heading / headingSize / subheading / textSize / videoUrl /
// coverImage / padding / colorScheme). Провайдеры YouTube/Vimeo → embed-iframe
// (parseVideo), self-hosted → <video>; пустое состояние → Figma-плейсхолдер
// landscape-video.png + Play-иконка.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон videoUrl + pupa video{url, coverImage}. blob:-URL — временные ObjectURL
// вкладки конструктора, на live дадут 404 — отбрасываем (паттерн theme-base Video).
const rawVideoUrl =
	typeof p.video?.url === "string" ? p.video.url : typeof p.videoUrl === "string" ? p.videoUrl : "";
const videoUrl = rawVideoUrl.startsWith("blob:") ? "" : rawVideoUrl;

// Провайдер видео: YouTube/Vimeo → embed-iframe, иначе self-hosted <video>.
// (flux ранее рендерил только <video src> — YouTube/Vimeo ссылки не воспроизводились.)
type VideoKind = "youtube" | "vimeo" | "file";
function parseVideo(url: string): { kind: VideoKind; embedUrl: string } {
	if (!url) return { kind: "file", embedUrl: "" };
	const yt =
		url.match(/youtu\.be\/([A-Za-z0-9_-]{6,})/) ||
		url.match(/youtube\.com\/watch\?v=([A-Za-z0-9_-]{6,})/) ||
		url.match(/youtube\.com\/embed\/([A-Za-z0-9_-]{6,})/);
	if (yt) return { kind: "youtube", embedUrl: `https://www.youtube.com/embed/${yt[1]}` };
	const vm =
		url.match(/vimeo\.com\/(?:video\/)?(\d{6,})/) ||
		url.match(/player\.vimeo\.com\/video\/(\d{6,})/);
	if (vm) return { kind: "vimeo", embedUrl: `https://player.vimeo.com/video/${vm[1]}` };
	return { kind: "file", embedUrl: url };
}
const video = parseVideo(videoUrl);

// Канон coverImage/poster (+ video.coverImage). Пустое состояние (нет ни видео,
// ни обложки) = Figma-плейсхолдер (1:19335, контракт картиночных секций): дизайн-
// ассет /placeholders/landscape-video.png (раздаётся на каждой теме) + Play-иконка
// по центру, а НЕ пустой surface-rect и НЕ мок верстальщика.
const poster =
	(typeof p.video?.coverImage === "string" && p.video.coverImage ? p.video.coverImage : undefined) ??
	(typeof p.coverImage === "string" && p.coverImage ? p.coverImage : undefined) ??
	(typeof p.poster === "string" && p.poster ? p.poster : undefined);
const posterFallback = poster ?? "/placeholders/landscape-video.png";

// Канон heading (как rose): string | {text, alignment, enabled, size} +
// content.heading-конверт. Пустое состояние = Figma-плейсхолдер «Видео» НАД медиа
// (мерчант задал свой heading → рендерим его; fallback только при пустом тексте).
// Роль — шапка секции flux: font-roboto-flex uppercase (эталон Collections.astro).
const headingRaw = p.heading ?? p.content?.heading;
const headingRawText =
	typeof headingRaw === "string" ? headingRaw : ((headingRaw?.text as string | undefined) ?? "");
const headingText = headingRawText.trim() ? headingRawText : "Видео";
const headingEnabled = String(p.content?.heading?.enabled ?? "true") !== "false";
const showHeading = headingEnabled;
// Канон headingSize («Размер заголовка», кегль <h2>; дубли heading.size /
// content.heading.size). Секционный `size` теперь = ВЫСОТА блока (не кегль) —
// исключён из цепочки. Лестница на базе эталона 19/23 (канон-дефолт medium):
// small 16/19, medium 19/23, large 23/29 (паттерн flux Collections).
const headingSize =
	(typeof headingRaw === "object" ? headingRaw?.size : undefined) ??
	p.content?.heading?.size;
const headingSizeCls =
	headingSize === "small"
		? "text-[16px] md:text-[19px]"
		: headingSize === "large"
			? "text-[23px] md:text-[29px]"
			: "text-[19px] md:text-[23px]";
// Канон alignment (как rose titleAlignment): дефолт/left — слева; center/right
// двигают шапку (items-* + text-*) на flex-обёртке заголовка.
const headingAlignment =
	p.titleAlignment ??
	p.headingAlignment ??
	(typeof headingRaw === "object" ? headingRaw?.alignment : undefined) ??
	p.content?.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center"
		? " items-center text-center"
		: headingAlignment === "right"
			? " items-end text-right"
			: "";
const headingCls = `font-roboto-flex ${headingSizeCls} font-normal uppercase leading-normal text-[rgb(var(--color-heading,0_0_0))]`;

// Канон subheading «Подзаголовок» (как rose) — string | {text} +
// content.subheading.{text,enabled}. Рендер ТОЛЬКО при непустом тексте И
// enabled !== 'false' (default-preserving). Стиль — flux body font-light muted.
const subEnvelope = p.content?.subheading as { text?: string; enabled?: string } | undefined;
const subEnabled = String(subEnvelope?.enabled ?? "true") !== "false";
const subheadingText = (() => {
	if (!subEnabled) return "";
	const s = p.subheading ?? subEnvelope;
	if (typeof s === "string") return s.trim();
	if (s && typeof s === "object") return String((s as { text?: string }).text ?? "").trim();
	return "";
})();
// Канон textSize «Размер текста» подзаголовка (дубли subheadingSize /
// subheading.size). Лестница flux Collections-subtitle: small 14/16 (канон-дефолт),
// medium 16/19, large 19/23.
const subSize =
	p.textSize ??
	p.subheadingSize ??
	(typeof p.subheading === "object" ? (p.subheading as any)?.size : undefined);
const subSizeCls =
	subSize === "medium"
		? "text-[16px] md:text-[19px]"
		: subSize === "large"
			? "text-[19px] md:text-[23px]"
			: "text-[14px] md:text-[16px]";
const subheadingCls = `font-roboto-flex ${subSizeCls} font-light leading-normal text-[rgb(var(--color-muted,153_153_153))]`;

// Канон position contained|fullscreen («Положение видео» — ВИДИМОЕ поле) + align
// container|fullbleed + padded (hidden 084-пилот). Default = контейнер 1920 с
// полями/вертикалью эталона; fullscreen/fullbleed → full-bleed без скругления и
// клампа (align приоритетнее position); padded=false убирает горизонтальные поля.
const alignProp = p.align === "fullbleed" || p.align === "container" ? p.align : undefined;
const positionProp = typeof p.position === "string" ? p.position : "contained";
const fullBleed = alignProp ? alignProp === "fullbleed" : positionProp === "fullscreen";
const padded = !(p.padded === false || p.padded === "false");

// Канон padding {top,bottom} — inline-стиль на контейнере ТОЛЬКО при заданном
// пропе; тогда py-классы убираются (паттерн flux Collections — без двойного отступа).
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;
const pyCls = paddingStyle ? "" : " py-10 md:py-16";
const containerCls = fullBleed
	? `flex w-full flex-col gap-8${pyCls}`
	: padded
		? `mx-auto flex w-full max-w-[1920px] flex-col gap-8 px-4 md:px-20 2xl:px-80${pyCls}`
		: `mx-auto flex w-full max-w-[1920px] flex-col gap-8${pyCls}`;
// На full-bleed полотне шапка остаётся в полях секций эталона.
const headingWrapPx = fullBleed ? " px-4 md:px-20 2xl:px-80" : "";
const mediaCls = fullBleed
	? "relative aspect-video w-full overflow-hidden bg-[rgb(var(--color-surface,245_245_245))]"
	: "relative aspect-video w-full overflow-hidden rounded-[12px] bg-[rgb(var(--color-surface,245_245_245))]";

// Канон overlay 0-100 — слой поверх медиа; клики проходят сквозь (controls видео
// остаются доступны).
const overlayN = Math.max(0, Math.min(100, Number(p.overlay) || 0));

// «Размер» (секционный size) — ВЫСОТА медиа-плитки (канон Hero). small короче
// (21:9), large выше (4:3); medium/absent = базовый aspect-video (без override).
const mediaHeightStyle =
	p.size === "small" ? "aspect-ratio:21/9" : p.size === "large" ? "aspect-ratio:4/3" : undefined;

const titleId = id && showHeading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
>
	<div class={containerCls} style={paddingStyle}>
		{
			(showHeading || subheadingText) && (
				<div class={`flex flex-col gap-2${headingAlignCls}${headingWrapPx}`}>
					{showHeading && (
						<h2
							id={titleId}
							class={headingCls}
							data-puck-subsection-parent={id}
							data-puck-subsection-index="100"
							data-puck-subsection-field="heading"
						>
							{headingText}
						</h2>
					)}
					{subheadingText && <p class={subheadingCls}>{subheadingText}</p>}
				</div>
			)
		}

		<div class={mediaCls} style={mediaHeightStyle}>
			{
				video.kind === "youtube" || video.kind === "vimeo" ? (
					<iframe
						src={video.embedUrl}
						class="absolute inset-0 size-full"
						loading="lazy"
						allowfullscreen
						allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
					/>
				) : videoUrl ? (
					<video
						src={videoUrl}
						poster={poster}
						controls
						playsinline
						preload="metadata"
						class="absolute inset-0 size-full object-cover"
					/>
				) : poster ? (
					<img
						src={poster}
						alt=""
						aria-hidden="true"
						loading="lazy"
						class="absolute inset-0 size-full object-cover"
					/>
				) : (
					/* Пустое состояние (Figma 1:19335, контракт картиночных секций): без
					   видео и без обложки — дизайн-ассет landscape-video.png на всю плитку
					   + Play-иконка по центру (НЕ пустой surface). Цвета Play — токены темы
					   на SVG-узлах: контраст круг/стрелка гарантирован в любой схеме (не
					   зависит от Tailwind-JIT). */
					<>
						<img
							src={posterFallback}
							alt=""
							aria-hidden="true"
							loading="lazy"
							class="absolute inset-0 size-full object-cover"
						/>
						<div
							class="pointer-events-none absolute inset-0 flex items-center justify-center"
							aria-hidden="true"
							data-media-placeholder
						>
							<svg width="64" height="64" viewBox="0 0 64 64" fill="none">
								<circle cx="32" cy="32" r="32" style="fill:rgb(var(--color-heading,0_0_0))" />
								<path d="M27 22L43 32L27 42V22Z" style="fill:rgb(var(--color-bg,255_255_255))" />
							</svg>
						</div>
					</>
				)
			}
			{
				overlayN > 0 && (
					<div
						class="pointer-events-none absolute inset-0 z-[1] bg-black"
						style={`opacity:${overlayN / 100}`}
					/>
				)
			}
		</div>
	</div>
</section>
