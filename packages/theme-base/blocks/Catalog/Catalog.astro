---
// Catalog — pupa-style SSG render. Mirrors the live CatalogIsland visual
// structure (top sort pills + sidebar filters + product grid) so the
// constructor preview shows the same layout that the live storefront
// renders. The interactive island on the live site replaces this HTML
// with React-driven filtering/pagination.
import { CatalogClasses as C } from './Catalog.classes';
import type { CatalogProps } from './Catalog.puckConfig';

interface Props extends CatalogProps {
  id?: string;
}

const { id, padding, showCollectionFilter, showSidebar } = Astro.props as Props;

const paddingStyle = padding
  ? `padding-top:${padding.top ?? 40}px; padding-bottom:${padding.bottom ?? 80}px;`
  : 'padding-top:40px; padding-bottom:80px;';

const sidebar = showSidebar !== 'false' && showSidebar !== false;
const collFilter = showCollectionFilter !== 'false' && showCollectionFilter !== false;

const placeholderCards = Array.from({ length: 6 });
---
<section
  data-puck-component-id={id}
  data-block="catalog"
  style={`background:#ffffff;color:#000000;${paddingStyle}`}
>
  <div class={C.container}>
    <div style="margin-bottom: 24px;">
      <h1 style="font-size: clamp(20px, 3vw, 36px); font-weight: 400; text-transform: uppercase; line-height: 1.1; color: #000000; margin: 0; font-family: var(--font-heading);">КАТАЛОГ</h1>
      <p style="font-size: clamp(14px, 1.5vw, 20px); font-weight: 400; line-height: 1.4; color: #999999; margin-top: 6px; font-family: var(--font-body);">Здесь начинается персональный стиль</p>
    </div>

    <div style="margin-bottom: 16px; color: #000000; font-size: 14px;">{placeholderCards.length} товаров</div>

    <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px;">
      <button type="button" disabled style="padding: 8px 18px; border: 1px solid #ff5a1f; background: #ffffff; color: #000000; border-radius: 999px; font-size: 14px; cursor: pointer;">По популярности</button>
      <button type="button" disabled style="padding: 8px 18px; border: 1px solid #000000; background: #000000; color: #ffffff; border-radius: 999px; font-size: 14px; cursor: pointer;">По новизне</button>
      <button type="button" disabled style="padding: 8px 18px; border: 1px solid #ff5a1f; background: #ffffff; color: #000000; border-radius: 999px; font-size: 14px; cursor: pointer;">По возрастанию цены</button>
      <button type="button" disabled style="padding: 8px 18px; border: 1px solid #ff5a1f; background: #ffffff; color: #000000; border-radius: 999px; font-size: 14px; cursor: pointer;">По убыванию цены</button>
    </div>

    <div style={`display: grid; grid-template-columns: ${sidebar ? '220px 1fr' : '1fr'}; gap: 32px; align-items: start;`}>
      {sidebar && (
        <aside style="display: flex; flex-direction: column; gap: 24px; font-size: 14px; color: #000000;">
          <div style="font-weight: 500; opacity: 0.7;">Фильтры:</div>

          {collFilter && (
            <div>
              <div style="font-weight: 500; margin-bottom: 8px;">Коллекции</div>
              <label style="display: flex; align-items: center; gap: 8px; padding: 4px 0; cursor: pointer;">
                <input type="radio" name="cat-coll" checked disabled />
                <span>Все</span>
              </label>
              <label style="display: flex; align-items: center; gap: 8px; padding: 4px 0; cursor: pointer; opacity: 0.7;">
                <input type="radio" name="cat-coll" disabled />
                <span>Первая</span>
              </label>
              <label style="display: flex; align-items: center; gap: 8px; padding: 4px 0; cursor: pointer; opacity: 0.7;">
                <input type="radio" name="cat-coll" disabled />
                <span>Товары</span>
              </label>
            </div>
          )}

          <div>
            <div style="font-weight: 500; margin-bottom: 8px;">Наличие</div>
            <label style="display: flex; align-items: center; gap: 8px; padding: 4px 0; cursor: pointer;">
              <input type="radio" name="cat-stock" checked disabled />
              <span>Все</span>
            </label>
            <label style="display: flex; align-items: center; gap: 8px; padding: 4px 0; cursor: pointer; opacity: 0.7;">
              <input type="radio" name="cat-stock" disabled />
              <span>В наличии</span>
            </label>
            <label style="display: flex; align-items: center; gap: 8px; padding: 4px 0; cursor: pointer; opacity: 0.7;">
              <input type="radio" name="cat-stock" disabled />
              <span>Распродано</span>
            </label>
          </div>

          <div>
            <div style="font-weight: 500; margin-bottom: 8px;">Стоимость</div>
            <input type="text" placeholder="от" disabled style="width: 100%; padding: 6px 8px; border: 1px solid rgba(0,0,0,0.15); margin-bottom: 6px; background: #ffffff; color: #000000;" />
            <input type="text" placeholder="до" disabled style="width: 100%; padding: 6px 8px; border: 1px solid rgba(0,0,0,0.15); background: #ffffff; color: #000000;" />
          </div>
        </aside>
      )}

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px;">
        {placeholderCards.map(() => (
          <article style="display: flex; flex-direction: column; gap: 8px;">
            <div style="aspect-ratio: 3 / 4; background: rgba(0,0,0,0.05); border-radius: 4px;"></div>
            <div style="height: 12px; width: 70%; background: rgba(0,0,0,0.06); border-radius: 2px;"></div>
            <div style="height: 12px; width: 30%; background: rgba(0,0,0,0.06); border-radius: 2px;"></div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
