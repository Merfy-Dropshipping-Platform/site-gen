---
import Layout from "../../layouts/Layout.astro";
import { legalPages, type LegalSlug } from "../../data/legal";

export const getStaticPaths = async () => {
	const { legalPages } = await import("../../data/legal");
	return Object.keys(legalPages).map((slug) => ({
		params: { slug },
		props: { slug },
	}));
};

const { slug } = Astro.props as { slug: LegalSlug };
const page = legalPages[slug];
const disclaimer =
	"Сайт создан для ознакомления с функциональными возможностями Сервиса. Покупка товаров невозможна.";
---

<Layout title={page.title} description={page.title}>
	<section
		class="w-full bg-white px-4 pb-[120px] pt-16 text-center md:px-20 md:pb-[160px] md:pt-24 2xl:px-[300px]"
	>
		<div class="mx-auto flex w-full max-w-[760px] flex-col items-center gap-4">
			<h1 class="font-comfortaa text-[28px] font-normal uppercase leading-[1.115] text-[#000000] md:text-[32px] lg:text-[36px]">
				{page.title}
			</h1>
			<p class="font-manrope text-[16px] font-light leading-[1.6] text-[#606060]">
				{disclaimer}
			</p>
		</div>
	</section>
</Layout>
