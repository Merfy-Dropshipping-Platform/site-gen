---
// Фаза B (bloom): новая канон-секция MultiRows в манере bloom (см.
// themes/bloom/MANNER.md). Секции нет у верстальщика — ряды «картинка + текст»
// в чередующейся раскладке по паттерну ImageWithText (медиа галереи §4,
// типографика §1, розовый pill §3, сетка §2); процесс-эталон — rose MultiRows
// (T16). Схема полей = packages/theme-base/blocks/MultiRows/MultiRows.puckConfig.ts.
const p = Astro.props as Record<string, any>;
const id = p.id;

// Канон top-heading: string | { text, alignment, size } (+ legacy _headingLegacy).
// Figma 1:19335 — ПУСТОЕ состояние секции «Мультиряды»: дословный заголовок
// «Мультиряды» (а НЕ отсутствие шапки/дефолт-копирайт верстальщика). Мерчант задал
// свой heading → его и рендерим. Роль = заголовок секции на белом (Urbanist
// uppercase, розовый токен, МАННЕРА §1). Лестница §9: medium/отсутствие = 18/md:20,
// small 15/17, large 22/24.
const heading =
	(typeof p.heading === "string" ? p.heading : p.heading?.text) ?? p._headingLegacy ?? "Мультиряды";
const headingSize = p.heading?.size ?? p.headingSize;
const headingSizeCls =
	headingSize === "small"
		? "text-[15px] md:text-[17px]"
		: headingSize === "large"
			? "text-[22px] md:text-[24px]"
			: "text-[18px] md:text-[20px]";
const headingAlignment = p.headingAlignment ?? p.heading?.alignment;
const headingAlignCls =
	headingAlignment === "center" ? " text-center" : headingAlignment === "right" ? " text-right" : "";
const headingCls = `font-urbanist ${headingSizeCls} font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))]${headingAlignCls}`;

// Канон rows[] 1-10 (item: heading|title, text|description, imageUrl|image,
// imagePosition, button {text, href|link}, size per-item, headingSize/textSize).
// Figma 1:19335 — ПУСТОЕ состояние секции: ряды-плейсхолдеры (дизайн-ассет
// /placeholders/landscape-multirows-image.png в плитке + дословный текст
// «Изображение с текстом» / «Покажи и расскажи о своем товаре в одном блоке» +
// кнопка «Кнопка»), а НЕ дефолт-контент/мок верстальщика и НЕ пустая surface
// (контракт картиночных секций, эталон rose MultiRows.astro). Ассет раздаётся на
// каждой теме из packages/theme-base/public/placeholders (copyPublic). Пара рядов
// с чередованием лево/право. Мерчант задал rows → его и рендерим (поведение ниже не
// меняется); реальный ряд без картинки → пустая surface-плитка.
const PLACEHOLDER_ROW_IMAGE = "/placeholders/landscape-multirows-image.png";
const PLACEHOLDER_ROWS = [
	{
		id: "ph-row-1",
		heading: "Изображение с текстом",
		text: "Покажи и расскажи о своем товаре в одном блоке",
		imageUrl: PLACEHOLDER_ROW_IMAGE,
		imagePosition: "left",
		button: { text: "Кнопка", href: "/catalog" },
	},
	{
		id: "ph-row-2",
		heading: "Изображение с текстом",
		text: "Покажи и расскажи о своем товаре в одном блоке",
		imageUrl: PLACEHOLDER_ROW_IMAGE,
		imagePosition: "right",
		button: { text: "Кнопка", href: "/catalog" },
	},
];
// Курировано? — мерчант задал ряды (есть массив rows с длиной). Тогда рендерим
// реальные данные без изменений; иначе — плейсхолдер выше.
const hasRealRows = Array.isArray(p.rows) && p.rows.length > 0;
const rawRows = hasRealRows ? p.rows : PLACEHOLDER_ROWS;

// Канон «Позиция рядов»: ряды ВСЕГДА чередуют сторону медиа по индексу. Свитчер
// (Слева/Справа) задаёт сторону ТОЛЬКО первого ряда (i=0). per-item imagePosition
// больше не учитываем (нет в UI).
const firstRowRight = p.rowsPosition === "right";

// Канон size (s/m/l) — аспект медиа ряда (топ-уровень, per-item приоритетнее).
// Лестница как у ImageWithText: medium/отсутствие = плитка галереи 652/594
// (литерал §4), small = широкое 16/9, large = квадрат.
const aspectFor = (s: string | undefined) =>
	s === "small" ? "aspect-[16/9]" : s === "large" ? "aspect-square" : "aspect-[652/594]";

// Плейсхолдер пустого состояния (Figma 1:19335): ряд несёт дизайн-ассет
// landscape-multirows-image.png (PLACEHOLDER_ROWS выше), НЕ мок-ассеты верстальщика
// (/images/trend-*.webp) и НЕ пустую surface. Реальный ряд мерчанта без картинки →
// пустая surface-плитка (image='' → <img> не рендерится, контейнер ниже имеет
// bg-[--color-surface]). На live мерчант грузит своё фото.

// Шкалы per-item размеров: заголовок ряда = роль заголовка секции (лестница §9);
// текст = body-роль 16 (small 14, large 19).
const rowHeadingSizeCls = (s: string | undefined) =>
	s === "small" ? "text-[15px] md:text-[17px]" : s === "large" ? "text-[22px] md:text-[24px]" : "text-[18px] md:text-[20px]";
const rowTextSizeCls = (s: string | undefined) =>
	s === "small" ? "text-[14px]" : s === "large" ? "text-[19px]" : "text-[16px]";

const rows = rawRows.slice(0, 10).map((r: any, i: number) => {
	const btnText =
		typeof r.button?.text === "string" && r.button.text.trim() ? r.button.text : undefined;
	return {
		heading:
			(typeof r.heading === "string" && r.heading) || (typeof r.title === "string" && r.title) || "",
		text:
			(typeof r.text === "string" && r.text) ||
			(typeof r.description === "string" && r.description) ||
			"",
		image:
			(typeof r.imageUrl === "string" && r.imageUrl.trim()) ||
			(typeof r.image === "string" && r.image.trim()) ||
			PLACEHOLDER_ROW_IMAGE,
		right: firstRowRight ? i % 2 === 0 : i % 2 === 1,
		aspectCls: aspectFor(r.size ?? p.size),
		headingCls: rowHeadingSizeCls(r.headingSize),
		textCls: rowTextSizeCls(r.textSize),
		btnText,
		btnHref:
			(typeof r.button?.href === "string" && r.button.href ? r.button.href : undefined) ??
			r.button?.link?.href ??
			(typeof r.button?.link === "string" && r.button.link ? r.button.link : undefined) ??
			"/catalog",
	};
});

// Канон width (s/m/l/full): large/отсутствие = 1320 (контейнер манеры §2),
// medium 1080, small 780, full — без лимита.
const widthCls =
	p.width === "small"
		? "max-w-[780px]"
		: p.width === "medium"
			? "max-w-[1080px]"
			: p.width === "full"
				? "max-w-none"
				: "max-w-[1320px]";

// Канон alignment — выравнивание текстовой колонки рядов (отсутствие = left).
const alignCls =
	p.alignment === "center"
		? "items-center text-center"
		: p.alignment === "right"
			? "items-end text-right"
			: "items-start text-left";

// Канон buttonStyle: solid/primary/отсутствие = розовый pill манеры §3 (родная
// solid-кнопка bloom на белом); black = тёмная кнопка (инверсия text↔bg —
// паритет rose MultiRows «чёрная заливка», отлична и от white, и от розового
// дефолта; раньше 'black' проваливался в розовый); white = белый pill (button-2
// токены, CTA Philosophy); outlined = бордер цвета заливки на прозрачном.
const btnBase =
	"inline-flex h-12 items-center justify-center rounded-[var(--radius-button,100px)] px-6 font-inter text-[16px] font-light leading-none transition-opacity hover:opacity-90 active:scale-95";
const btnCls =
	p.buttonStyle === "outlined"
		? `${btnBase} border border-solid border-[rgb(var(--color-button-bg,227_142_159))] bg-transparent text-[rgb(var(--color-button-bg,227_142_159))]`
		: p.buttonStyle === "white"
			? `${btnBase} bg-[rgb(var(--color-button-2-bg,255_255_255))] text-[rgb(var(--color-button-2-text,0_0_0))]`
			: p.buttonStyle === "black"
				? `${btnBase} bg-[rgb(var(--color-text,0_0_0))] text-[rgb(var(--color-bg,255_255_255))]`
				: `${btnBase} bg-[rgb(var(--color-button-bg,227_142_159))] text-[rgb(var(--color-button-text,255_255_255))]`;

// Канон containerEnabled (toggle; puckConfig готов). ИСПРАВЛЕНИЕ канона (Nikita):
// «контейнер» = surface-бокс манеры §4 (surface #F5F5F5, радиус карточки 12px) НА
// КАЖДЫЙ ряд (<li>), а НЕ общий бокс/схема на внешнем div. Canon-default отсутствует
// → false = голые ряды без бокса/схемы.
const containerEnabled = String(p.containerEnabled ?? "false") === "true";
// Канон Nikita: класс схемы контейнера — ТОЛЬКО при ВКЛ и вешается на ОБЁРТКУ
// СПИСКА (<ul>), НЕ на внешний div с заголовком. При ВЫКЛ → основная схема секции.
const containerSchemeCls =
	containerEnabled && typeof p.containerColorScheme === "string" && p.containerColorScheme
		? ` color-scheme-${String(p.containerColorScheme).replace("scheme-", "")}`
		: "";
// Per-element surface-бокс на КАЖДЫЙ ряд при ВКЛ; при ВЫКЛ — голый ряд.
const rowBoxCls = containerEnabled
	? " rounded-[var(--radius-card,12px)] bg-[rgb(var(--color-surface,245_245_245))] p-6 md:p-8"
	: "";

// Канон padding {top,bottom} — inline-стиль ТОЛЬКО при заданном пропе.
const paddingStyle = p.padding
	? `padding-top:${p.padding.top}px;padding-bottom:${p.padding.bottom}px;`
	: undefined;

const titleId = id && heading ? `${id}-title` : undefined;
---

<section
	class="w-full bg-[rgb(var(--color-bg,255_255_255))] px-4 py-20 md:px-20 md:py-[120px] 2xl:px-[300px]"
	aria-labelledby={titleId}
	data-puck-component-id={id}
	style={paddingStyle}
>
	<div class={`mx-auto flex w-full ${widthCls} flex-col gap-10`}>
		{
			heading && (
				<h2
					id={titleId}
					class={headingCls}
					data-animate
					data-puck-subsection-parent={id}
					data-puck-subsection-index="100"
					data-puck-subsection-field="heading"
				>
					{heading}
				</h2>
			)
		}
		<ul class={`flex w-full flex-col gap-10${containerSchemeCls}`} role="list">
			{
				rows.map((r, i) => (
					<li
						class={`grid w-full grid-cols-1 gap-4 lg:grid-cols-2${rowBoxCls}`}
						data-animate
						data-puck-subsection-parent={hasRealRows ? id : undefined}
						data-puck-subsection-index={hasRealRows ? i : undefined}
						data-puck-subsection-field={hasRealRows ? "rows" : undefined}
					>
						<div
							class={`group relative w-full overflow-hidden rounded-[var(--radius-media,12px)] bg-[rgb(var(--color-surface,245_245_245))] ${r.aspectCls}${r.right ? " lg:order-2" : ""}`}
							aria-hidden={r.image ? undefined : "true"}
						>
							{r.image && (
								<img
									src={r.image}
									alt={r.heading || "Ряд"}
									loading="lazy"
									class="absolute inset-0 size-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
								/>
							)}
						</div>
						<div class={`flex w-full flex-col gap-6 ${alignCls}${r.right ? " lg:order-1" : ""}`}>
							{r.heading && (
								<h3
									class={`font-urbanist ${r.headingCls} font-normal uppercase leading-none text-[rgb(var(--color-heading,227_142_159))]`}
								>
									{r.heading}
								</h3>
							)}
							{r.text && (
								<div
									class={`font-inter ${r.textCls} font-light leading-normal text-[rgb(var(--color-text,0_0_0))]`}
									set:html={r.text}
								/>
							)}
							{r.btnText && (
								<div class="mt-2">
									<a href={r.btnHref} class={btnCls}>
										{r.btnText}
									</a>
								</div>
							)}
						</div>
					</li>
				))
			}
		</ul>
	</div>
</section>
