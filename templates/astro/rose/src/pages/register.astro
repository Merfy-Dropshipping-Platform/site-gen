---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthShell from '../components/auth/AuthShell.astro';
import AuthInput from '../components/auth/AuthInput.astro';
import PasswordField from '../components/auth/PasswordField.astro';
import AuthButton from '../components/auth/AuthButton.astro';
import AuthSecondaryLink from '../components/auth/AuthSecondaryLink.astro';
import OtpInput from '../components/auth/islands/OtpInput.tsx';
import ResendTimer from '../components/auth/islands/ResendTimer.tsx';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import data from '../data/data.json';
import siteConfig from '../data/site-config.json';

const meta = data?.meta ?? {};
const blocks = data?.content ?? [];
const headerBlock = blocks.find((b: any) => b.type === 'Header');
const footerBlock = blocks.find((b: any) => b.type === 'Footer');
const headerProps = headerBlock?.props ?? (siteConfig as any)?.header ?? {};
const footerProps = footerBlock?.props ?? (siteConfig as any)?.footer ?? {};
---
<BaseLayout title={`Регистрация — ${meta?.title ?? 'Мой сайт'}`}>
  <Header {...headerProps} />

  <!-- Step 1 — register form (email + password) -->
  <div id="mode-register" class="contents">
    <AuthShell
      title="Регистрация аккаунта"
      description="Введите свои данные чтобы создать аккаунт"
    >
      <div id="invite-expired-msg" class="hidden w-full text-center flex flex-col items-center gap-4">
        <p class="text-base text-theme-text-muted">Ссылка для регистрации устарела или уже была использована.</p>
        <AuthSecondaryLink href="/register">Зарегистрироваться самостоятельно</AuthSecondaryLink>
      </div>

      <form id="register-form" class="w-full flex flex-col gap-6" novalidate>
        <AuthInput
          label="E-mail"
          type="email"
          name="email"
          id="reg-email"
          placeholder="example@merfy.ru"
          required
          autocomplete="email"
        />
        <PasswordField
          label="Пароль"
          name="password"
          id="reg-password"
          placeholder="Минимум 8 символов"
          required
          minlength={8}
          autocomplete="new-password"
        />
        <div class="auth-helper-error hidden text-center" id="register-error" role="alert"></div>
      </form>

      <div class="w-full flex flex-col items-center gap-10">
        <AuthButton id="btn-register" form="register-form" loadingLabel="Регистрация...">Зарегистрироваться</AuthButton>
        <AuthSecondaryLink href="/login" helper="Уже есть аккаунт?">Войти</AuthSecondaryLink>
      </div>
    </AuthShell>
  </div>

  <!-- Step 2 — email verification via 4-digit OTP -->
  <div id="mode-verify-email" class="hidden contents">
    <AuthShell
      title="Подтверждение почты"
      description="Введите код подтверждения с вашего e-mail"
    >
      <div class="w-full flex flex-col items-center gap-20">
        <OtpInput client:load id="register-verify-otp" name="code" length={4} />
        <ResendTimer client:load id="register-verify-resend" seconds={60} />
      </div>

      <div class="w-full flex flex-col items-center gap-8">
        <div class="auth-helper-error hidden text-center" id="verify-error" role="alert"></div>
        <AuthButton id="btn-verify-continue" type="button" loadingLabel="Проверка...">Продолжить</AuthButton>
        <AuthSecondaryLink href="#" id="verify-back" variant="muted">Вернуться назад</AuthSecondaryLink>
      </div>
    </AuthShell>
  </div>

  <Footer {...footerProps} />

  <script is:inline src="/scripts/customer-store.js"></script>
  <script is:inline src="/scripts/customer-auth.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      if (window.CustomerStore && window.CustomerStore.isLoggedIn()) {
        window.location.href = '/account';
        return;
      }

      var modeRegister = document.getElementById('mode-register');
      var modeVerify = document.getElementById('mode-verify-email');
      function showMode(m) {
        [modeRegister, modeVerify].forEach(function(x) { x.classList.add('hidden'); });
        m.classList.remove('hidden');
      }

      var params = new URLSearchParams(window.location.search);
      var step = params.get('step');
      var verifyEmail = params.get('email') || sessionStorage.getItem('verifyEmail');

      if (step === 'verify-email' && verifyEmail) {
        sessionStorage.setItem('verifyEmail', verifyEmail);
        showMode(modeVerify);
        setupVerifyHandlers(verifyEmail);
      } else {
        showMode(modeRegister);
        setupRegisterHandlers();
      }

      // ============ STEP 1 register ============
      function setupRegisterHandlers() {
        var form = document.getElementById('register-form');
        var errorEl = document.getElementById('register-error');
        var btn = document.getElementById('btn-register');
        var loadingEl = btn.querySelector('[data-loading]');
        var textEl = btn.querySelector('[data-button-text]');
        var emailField = document.getElementById('reg-email');
        var passwordField = document.getElementById('reg-password');
        var expiredMsg = document.getElementById('invite-expired-msg');

        var inviteToken = params.get('invite');
        var inviteEmail = params.get('email');
        var isInviteMode = !!(inviteToken && inviteEmail);
        if (isInviteMode) {
          emailField.value = inviteEmail;
          emailField.readOnly = true;
          emailField.setAttribute('data-error', 'false');
        }

        function mark(field, ok) { if (field) field.setAttribute('data-error', ok ? 'false' : 'true'); }

        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          errorEl.classList.add('hidden');
          errorEl.textContent = '';
          mark(emailField, true);
          mark(passwordField, true);

          var email = emailField.value.trim();
          var password = passwordField.value;

          if (!email) { mark(emailField, false); errorEl.textContent = 'Введите e-mail'; errorEl.classList.remove('hidden'); return; }
          if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { mark(emailField, false); errorEl.textContent = 'Введите корректный e-mail'; errorEl.classList.remove('hidden'); return; }
          if (!password) { mark(passwordField, false); errorEl.textContent = 'Введите пароль'; errorEl.classList.remove('hidden'); return; }
          if (password.length < 8) { mark(passwordField, false); errorEl.textContent = 'Пароль должен содержать минимум 8 символов'; errorEl.classList.remove('hidden'); return; }

          loadingEl.classList.remove('hidden');
          textEl.classList.add('hidden');
          btn.disabled = true;

          try {
            if (isInviteMode) {
              var config = window.__MERFY_CONFIG__ || {};
              var apiBase = config.apiUrl || '';
              var resp = await fetch(apiBase + '/store/auth/invite-register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token: inviteToken, password: password }),
              });
              var ir = await resp.json();
              if (!resp.ok || !ir.success) throw ir;
              if (ir.data && ir.data.token) window.CustomerStore.saveToken(ir.data.token);
              window.location.href = '/account';
              return;
            }

            var derivedName = email.split('@')[0];
            var result = await window.CustomerAuth.register({ email: email, name: derivedName, password: password });
            if (!result.success) throw result;

            if (result.data && result.data.requiresEmailVerification) {
              sessionStorage.setItem('verifyEmail', email);
              window.location.search = '?step=verify-email&email=' + encodeURIComponent(email);
              return;
            }
            // Legacy path — session immediately (old backend)
            window.location.href = '/account';
          } catch (err) {
            var msg = 'Не удалось зарегистрироваться. Попробуйте позже.';
            if (err.error === 'INVITE_EXPIRED' || err.error === 'INVITE_USED') {
              form.classList.add('hidden');
              expiredMsg.classList.remove('hidden');
              return;
            } else if (err.error === 'ALREADY_REGISTERED') {
              window.location.href = '/login?email=' + encodeURIComponent(inviteEmail || email);
              return;
            } else if (err.code === 'CUSTOMER_ALREADY_EXISTS' || err.error === 'EMAIL_EXISTS') {
              msg = 'Пользователь с таким email уже зарегистрирован';
            } else if (err.code === 'PASSWORD_TOO_SHORT') {
              msg = 'Пароль должен содержать минимум 8 символов';
            } else if (err.code === 'VALIDATION_ERROR' || err.error === 'VALIDATION_ERROR') {
              msg = err.error || 'Проверьте введённые данные';
            } else if (err.error) {
              msg = err.error;
            } else if (err.message) {
              msg = err.message;
            }
            errorEl.textContent = msg;
            errorEl.classList.remove('hidden');
          } finally {
            loadingEl.classList.add('hidden');
            textEl.classList.remove('hidden');
            btn.disabled = false;
          }
        });
      }

      // ============ STEP 2 verify email OTP ============
      function setupVerifyHandlers(email) {
        var errorEl = document.getElementById('verify-error');
        var btn = document.getElementById('btn-verify-continue');
        var loadingEl = btn.querySelector('[data-loading]');
        var textEl = btn.querySelector('[data-button-text]');
        var backLink = document.getElementById('verify-back');
        var currentCode = '';
        var submitting = false;

        function clearCellsError() {
          document.querySelectorAll('.auth-otp-cell').forEach(function(c) {
            c.style.borderColor = '';
          });
        }
        function markCellsError() {
          document.querySelectorAll('.auth-otp-cell').forEach(function(c) {
            c.style.borderColor = '#FCA5A5';
          });
        }

        window.addEventListener('otp:complete', function(e) {
          currentCode = e.detail.value;
          clearCellsError();
          if (!submitting) { submitting = true; submitVerify(); }
        });

        document.querySelectorAll('.auth-otp-cell').forEach(function(cell) {
          cell.addEventListener('input', function() { errorEl.classList.add('hidden'); clearCellsError(); });
        });

        window.addEventListener('otp:resend-request', async function() {
          errorEl.classList.add('hidden');
          try {
            await window.CustomerAuth.requestEmailVerifyOTP({ email: email });
            window.dispatchEvent(new CustomEvent('otp:resend-ack', { detail: { id: 'register-verify-resend', seconds: 60 } }));
          } catch (err) {
            errorEl.textContent = 'Не удалось отправить код повторно';
            errorEl.classList.remove('hidden');
          }
        });

        async function submitVerify() {
          errorEl.classList.add('hidden');
          if (!currentCode || currentCode.length !== 4) {
            errorEl.textContent = 'Введите все 4 цифры';
            errorEl.classList.remove('hidden');
            submitting = false;
            return;
          }
          loadingEl.classList.remove('hidden');
          textEl.classList.add('hidden');
          btn.disabled = true;
          try {
            var result = await window.CustomerAuth.verifyEmailOTP({ email: email, code: currentCode });
            if (result.success) {
              sessionStorage.removeItem('verifyEmail');
              window.location.href = '/account';
              return;
            }
            throw result;
          } catch (err) {
            var code = err && err.error && err.error.code;
            var msg = 'Неверный код';
            if (code === 'OTP_EXPIRED') msg = 'Код устарел. Запросите новый';
            else if (code === 'OTP_INVALIDATED') msg = 'Слишком много неверных попыток. Запросите новый код';
            else if (err.error && err.error.attemptsRemaining !== undefined) {
              msg = 'Неверный код. Осталось попыток: ' + err.error.attemptsRemaining;
            }
            errorEl.textContent = msg;
            errorEl.classList.remove('hidden');
            markCellsError();
            loadingEl.classList.add('hidden');
            textEl.classList.remove('hidden');
            btn.disabled = false;
            submitting = false;
          }
        }

        btn.addEventListener('click', function(e) {
          e.preventDefault();
          if (!submitting) { submitting = true; submitVerify(); }
        });

        backLink.addEventListener('click', function(e) {
          e.preventDefault();
          sessionStorage.removeItem('verifyEmail');
          window.location.search = '';
        });
      }
    });
  </script>
</BaseLayout>
