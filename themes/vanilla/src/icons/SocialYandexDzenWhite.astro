---
import { withBase } from "../lib/with-base";

interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<img
	src={withBase("/icons/social-yandex-dzen-white.svg")}
	alt=""
	width="20"
	height="20"
	loading="lazy"
	decoding="async"
	draggable={false}
	aria-hidden="true"
	class:list={["block shrink-0 object-contain", className]}
/>
