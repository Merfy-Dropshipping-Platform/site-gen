---
interface Props {
  heading?: { text?: string; size?: 'small' | 'medium' | 'large' };
  colorScheme?: string;
  padding?: { top?: number; bottom?: number };
}

const { heading, colorScheme, padding } = Astro.props;
const schemeClass = colorScheme ? `color-scheme-${colorScheme.replace('scheme-', '')}` : '';
const headingText = heading?.text ?? 'Свяжитесь с нами';
const headingSize = heading?.size ?? 'medium';
const padTop = padding?.top ?? 80;
const padBottom = padding?.bottom ?? 80;

const headingFontSizes: Record<string, string> = {
  small: '1.5rem',
  medium: '2rem',
  large: '2.5rem',
};
const headingFS = headingFontSizes[headingSize] || '2rem';
---

<section
  class={`w-full ${schemeClass}`}
  style={`padding-top: ${padTop}px; padding-bottom: ${padBottom}px; background: rgb(var(--color-background)); color: rgb(var(--color-foreground));`}
>
  <div class="max-w-[600px] mx-auto px-5">
    <h2 class="font-medium text-theme-foreground text-center mb-10 font-heading contact-form-heading" style={`--cf-fs:${headingFS};`}>
      {headingText}
    </h2>
    <style>
      .contact-form-heading { font-size: var(--cf-fs); line-height: 1.2; }
      @media (max-width: 767px) { .contact-form-heading { font-size: 1.75rem; } }
    </style>
    <form class="flex flex-col gap-5" action="#" method="POST">
      <div class="flex flex-col gap-1.5">
        <label for="contact-name" class="text-[0.9rem] font-medium text-theme-foreground font-body">Имя</label>
        <input
          type="text"
          id="contact-name"
          name="name"
          placeholder="Ваше имя"
          required
          class="py-3 px-4 text-base border border-theme rounded-lg font-body transition-colors focus:outline-none focus:border-theme-foreground"
          style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));"
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="contact-email" class="text-[0.9rem] font-medium text-theme-foreground font-body">Email</label>
        <input
          type="email"
          id="contact-email"
          name="email"
          placeholder="email@example.com"
          required
          class="py-3 px-4 text-base border border-theme rounded-lg font-body transition-colors focus:outline-none focus:border-theme-foreground"
          style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));"
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="contact-message" class="text-[0.9rem] font-medium text-theme-foreground font-body">Сообщение</label>
        <textarea
          id="contact-message"
          name="message"
          rows="5"
          placeholder="Ваше сообщение..."
          required
          class="py-3 px-4 text-base border border-theme rounded-lg font-body transition-colors resize-y focus:outline-none focus:border-theme-foreground"
          style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));"
        ></textarea>
      </div>
      <button
        type="submit"
        class="inline-flex items-center justify-center py-3.5 px-8 text-[0.95rem] font-medium rounded-lg border-none bg-theme-primary text-theme-button-text cursor-pointer transition-colors hover:opacity-90 font-body"
      >
        Отправить
      </button>
    </form>
  </div>
</section>
